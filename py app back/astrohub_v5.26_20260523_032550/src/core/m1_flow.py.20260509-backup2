def _collect_system_info() -> dict:
    """P1.1: 收集主机硬件信息."""
    info: dict = {
        "hostname": platform.node(),
        "cpu_model": "",
        "ram_gb": 0,
        "gpu_count": 0,
        "gpu_names": [],
        "vram_gb": 0,
    }

    # CPU
    try:
        if platform.system() == "Windows":
            result = subprocess.run(
                ["wmic", "cpu", "get", "name"],
                capture_output=True, text=True, timeout=10,
                creationflags=subprocess.CREATE_NO_WINDOW,
            )
            lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]
            if len(lines) >= 2:
                info["cpu_model"] = lines[1].strip()
    except Exception:
        pass

    # RAM - 按 method.csv P1.1: wmic computersystem get totalphysicalsize 优先
    try:
        if platform.system() == "Windows":
            result = subprocess.run(
                ["wmic", "computersystem", "get", "totalphysicalsize"],
                capture_output=True, text=True, timeout=10,
                creationflags=subprocess.CREATE_NO_WINDOW,
            )
            lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]
            if len(lines) >= 2:
                ram_bytes = int(lines[1].strip())
                info["ram_gb"] = round(ram_bytes / (1024 ** 3))
    except Exception:
        # 回退到 psutil
        if HAS_PSUTIL:
            info["ram_gb"] = round(psutil.virtual_memory().total / (1024 ** 3))

    # GPU - NVIDIA 优先 (nvidia-smi), AMD 回退 (wmic Win32_VideoController AdapterRAM)
    try:
        result = subprocess.run(
            ["nvidia-smi", "--query-gpu=name,memory.total", "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=10, check=False,
        )
        if result.returncode == 0 and result.stdout.strip():
            for line in result.stdout.strip().splitlines():
                parts = [p.strip() for p in line.split(",")]
                if len(parts) >= 2:
                    info["gpu_names"].append(parts[0])
                    try:
                        vram_mb = float(parts[1])
                        info["vram_gb"] += round(vram_mb / 1024)
                    except ValueError:
                        pass
            info["gpu_count"] = len(info["gpu_names"])
    except Exception:
        pass

    # GPU 回退 (AMD / 非 NVIDIA): wmic Win32_VideoController
    if info["gpu_count"] == 0:
        try:
            result = subprocess.run(
                ["wmic", "path", "win32_videocontroller", "get", "name,AdapterRAM"],
                capture_output=True, text=True, timeout=10,
                creationflags=subprocess.CREATE_NO_WINDOW,
            )
            lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]
            # 跳过头行, 解析数据行
            for line in lines[1:]:
                parts = line.split()
                if len(parts) >= 2:
                    # AdapterRAM 单位为字节, 转 GB
                    try:
                        adapter_ram_bytes = int(parts[-1])
                        vram_gb = round(adapter_ram_bytes / (1024 ** 3))
                        if vram_gb > 0:
                            info["vram_gb"] = vram_gb
                    except ValueError:
                        pass
                    info["gpu_names"].append(" ".join(parts[:-1]))
                    info["gpu_count"] = len(info["gpu_names"])
        except Exception:
            pass

    return info


def _format_system_info(info: dict) -> str:
    """格式化硬件信息以供显示."""
    lines = [
        f"主机名: {info['hostname']}",
        f"CPU: {info['cpu_model'] or '未知'}",
        f"内存: {info['ram_gb']} GB",
        f"显卡: {info['gpu_count']} 张",
    ]
    for gpu in info.get("gpu_names", []):
        lines.append(f"  - {gpu}")
    if info.get("vram_gb", 0) > 0:
        lines.append(f"显存: ~{info['vram_gb']} GB")
    return "\n".join(lines)


