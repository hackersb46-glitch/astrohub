def _mask_password(password: str, visible_chars: int = 2) -> str:
    """遮蔽密码, 默认仅显示前 2 位."""
    if len(password) <= visible_chars:
        return "*" * len(password)
    return password[:visible_chars] + "*" * (len(password) - visible_chars)


def _get_credentials() -> Optional[tuple[str, str]]:
    """P3.1: 交互式获取设备凭据.
    
    返回 (username, password) 或 None (Q 退出).
    """
    try:
        import getpass
    except ImportError:
        # 非交互模式下回退到 input()
        username = input("请输入用户名 [admin]: ").strip() or "admin"
        password = input("请输入密码: ").strip()
        if not password:
            return None
        confirm = input("请再次输入密码确认: ").strip()
        if confirm != password:
            print("[error] 两次输入的密码不一致, 请重新输入")
            return _get_credentials()
        return (username, password)

    while True:
        username = input("请输入用户名 [admin]: ").strip() or "admin"
        password = getpass.getpass("请输入密码: ")
        if not password:
            print("[warning] 密码不能为空, 请重新输入")
            continue
        confirm = getpass.getpass("请再次输入密码确认: ")
        if confirm != password:
            print("[error] 两次输入的密码不一致, 请重新输入")
            continue
        return (username, password)


def verify_isapi_auth(ip: str, username: str, password: str, port: int = 80) -> tuple[bool, Optional[str]]:
    """P3.2: 验证 ISAPI 认证.
    
    返回 (success, error_message).
    多端点尝试直到 HTTP 200 确认成功, 或 HTTP 401 确认密码错误.
    """
    if not HAS_REQUESTS:
        return False, "requests 库未安装"

    # 清除代理环境变量
    for key in list(os.environ.keys()):
        if "proxy" in key.lower():
            del os.environ[key]

    session = requests.Session()
    session.trust_env = False
    session.headers.update({"Content-Type": "application/xml; charset=UTF-8"})

    # 多端点尝试列表
    endpoints = [
        "/ISAPI/System/deviceInfo",
        "/ISAPI/System/DeviceInfo",
        "/ISAPI/System/status/deviceInfo",
        "/ISAPI/System/capabilities",
        "/ISAPI/DeviceManagement/DeviceInfo",
        "/ISAPI/System/network/interfaces",
    ]

    last_error = ""

    for endpoint in endpoints:
        url = f"http://{ip}:{port}{endpoint}"
        session.auth = HTTPDigestAuth(username, password)
        try:
            response = session.get(url, timeout=5)
            if response.status_code == 200:
                # 认证成功
                return True, None
            elif response.status_code == 401:
                # 端点存在但密码错误
                last_error = "密码错误 (HTTP 401)"
                return False, last_error
            else:
                last_error = f"{endpoint} 返回 {response.status_code}"
        except requests.exceptions.Timeout:
            last_error = f"{endpoint} 超时"
            continue
        except requests.exceptions.ConnectionError:
            last_error = f"{endpoint} 连接被拒绝"
            continue
        except Exception as e:
            last_error = f"{endpoint} 异常: {e}"
            continue

    return False, f"所有端点均失败: {last_error}"


