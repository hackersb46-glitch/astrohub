{"type":"message","id":"06a53575","parentId":"80983835","timestamp":"2026-06-11T19:33:05.462Z","message":{"role":"assistant","content":[{"type":"text","text":"页面是动态加载的，内容是空的。让我导航到正确的配置页面："},{"type":"toolCall","id":"call_276d48c594a84ef89b0ce543","name":"write","arguments":{"content":"\"\"\"\n访问海康摄像头配置-图像页面\n找到聚焦控制按钮\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\nIP = \"192.168.5.72\"\nUSERNAME = \"admin\"\nPASSWORD = \"Nftw1357\"\n\ndef test():\n    with open(\"focus_log.txt\", \"w\", encoding=\"utf-8\") as log:\n        def p(msg):\n            print(msg)\n            log.write(msg + \"\\n\")\n        \n        with sync_playwright() as p_browser:\n            browser = p_browser.chromium.launch(headless=True)\n            context = browser.new_context(ignore_https_errors=True)\n            page = context.new_page()\n            \n            # 捕获请求\n            requests_list = []\n            def capture(req):\n                if 'ISAPI' in req.url:\n                    requests_list.append({\n                        'time': time.time(),\n                        'method': req.method,\n                        'url': req.url.split('/ISAPI/')[-1] if '/ISAPI/' in req.url else req.url,\n                        'data': req.post_data or ''\n                    })\n            page.on('request', capture)\n            \n            p(\"=== 1. 登录 ===\")\n            page.goto(f\"http://{IP}/doc/index.html\", timeout=30000)\n            page.wait_for_timeout(2000)\n            \n            try:\n                page.fill('input[placeholder*=\"用户名\"], input[id*=\"username\"], input[name=\"username\"]', USERNAME, timeout=5000)\n                page.fill('input[type=\"password\"]', PASSWORD, timeout=5000)\n                page.click('button:has-text(\"登录\"), button[type=\"submit\"]', timeout=5000)\n                page.wait_for_timeout(5000)\n                p(\"   登录成功\")\n            except Exception as e:\n                p(f\"   登录: {e}\")\n            \n            # 点击配置菜单\n            p(\"\\n=== 2. 点击配置菜单 ===\")\n            try:\n                # 查找配置按钮\n                config_btn = page.locator('[title*=\"配置\"], .nav li:has-text(\"配置\")')\n                if config_btn.count() > 0:\n                    config_btn.first.click()\n                    page.wait_for_timeout(3000)\n                    p(\"   点击配置菜单\")\n            except Exception as e:\n                p(f\"   配置菜单: {e}\")\n            \n            p(f\"   当前 URL: {page.url}\")\n            \n            # 点击图像子菜单\n            p(\"\\n=== 3. 点击图像子菜单 ===\")\n            try:\n                image_btn = page.locator(':text(\"图像\"), :text(\"图像设置\")')\n                if image_btn.count() > 0:\n                    image_btn.first.click()\n                    page.wait_for_timeout(3000)\n                    p(\"   点击图像菜单\")\n            except Exception as e:\n                p(f\"   图像菜单: {e}\")\n            \n            # 查找聚焦按钮\n            p(\"\\n=== 4. 查找聚焦按钮 ===\")\n            page.wait_for_timeout(5000)\n            \n            # 获取所有按钮和可点击元素\n            all_clickable = page.locator('button, [role=\"button\"], .btn, [class*=\"btn\"]')\n            count = all_clickable.count()\n            p(f\"   页面共有 {count} 个可点击元素\")\n            \n            focus_related = []\n            for i in range(count):\n                try:\n                    elem = all_clickable.nth(i)\n                    text = elem.text_content() or ''\n                    title = elem.get_attribute('title') or ''\n                    cls = elem.get_attribute('class') or ''\n                    \n                    # 检查是否与聚焦相关\n                    if '焦' in text or '焦' in title or 'focus' in text.lower() or 'focus' in title.lower():\n                        focus_related.append({\n                            'text': text.strip(),\n                            'title': title,\n                            'class': cls[:80]\n                        })\n                        p(f\"   找到: text='{text.strip()}' title='{title}'\")\n                except:\n                    pass\n            \n            # 如果没找到，打印所有按钮文本\n            if not focus_related:\n                p(\"\\n   未找到聚焦按钮，打印所有按钮:\")\n                for i in range(min(count, 50)):\n                    try:\n                        elem = all_clickable.nth(i)\n                        text = elem.text_content() or ''\n                        if text.strip():\n                            p(f\"     [{i}] '{text.strip()[:50]}'\")\n                    except:\n                        pass\n            \n            # 清空请求记录\n            requests_list.clear()\n            t0 = time.time()\n            \n            # 尝试点击聚焦按钮\n            if focus_related:\n                p(\"\\n=== 5. 点击第一个聚焦按钮 ===\")\n                try:\n                    # 查找包含\"聚焦\"的按钮\n                    focus_btn = page.locator('button, [role=\"button\"]').filter(has_text='焦').first\n                    if focus_btn.count() > 0:\n                        focus_btn.click()\n                        page.wait_for_timeout(3000)\n                        p(\"   已点击\")\n                except Exception as e:\n                    p(f\"   点击失败: {e}\")\n            \n            # 打印捕获的请求\n            p(f\"\\n=== 6. 捕获的 ISAPI 请求 ({len(requests_list)} 条) ===\")\n            for r in requests_list:\n                elapsed = r['time'] - t0\n                p(f\"   [{elapsed:.2f}s] {r['method']} {r['url']}\")\n                if r['data'] and ('focus' in r['data'].lower() or '焦' in r['data']):\n                    p(f\"      DATA: {r['data'][:400]}\")\n            \n            # 截图\n            page.screenshot(path=\"hikvision_config.png\", full_page=True)\n            p(\"\\n截图: hikvision_config.png\")\n            \n            browser.close()\n\nif __name__ == \"__main__\":\n    test()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/hikvision_focus_config.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":129970,"output":1287,"cacheRead":0,"cacheWrite":0,"totalTokens":131257,"cost":{"input":0.12997,"output":0.0041184,"cacheRead":0,"cacheWrite":0,"total":0.1340884}},"stopReason":"toolUse","timestamp":1781206356737,"responseId":"cht000d3f01@dx19eb82c16a6b958232"}}
