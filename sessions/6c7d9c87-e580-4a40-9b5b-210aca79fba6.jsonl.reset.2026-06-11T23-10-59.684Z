{"type":"message","id":"9f2c9aa2","parentId":"5fc5e2c8","timestamp":"2026-06-11T18:17:53.444Z","message":{"role":"assistant","content":[{"type":"text","text":"**Zoom 仍然不变！** 这说明问题不在鼠标操作方式。\n\n让我检查浏览器控制台是否有错误："},{"type":"toolCall","id":"call_15f3589491d54100a2f99d1f","name":"write","arguments":{"content":"\"\"\"\nE2E Test - Check browser console for errors\n\"\"\"\nimport time\nfrom playwright.sync_api import sync_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\ndef test_with_console():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context()\n        page = context.new_page()\n        \n        # Collect console messages\n        console_messages = []\n        page.on(\"console\", lambda msg: console_messages.append(f\"[{msg.type}] {msg.text}\"))\n        \n        # Collect page errors\n        page_errors = []\n        page.on(\"pageerror\", lambda err: page_errors.append(str(err)))\n        \n        # Open page\n        page.goto(BASE_URL, timeout=30000)\n        page.wait_for_load_state('networkidle')\n        \n        # Navigate to console\n        console_btn = page.locator('[data-page=\"console\"]')\n        console_btn.click()\n        page.wait_for_timeout(2000)\n        \n        # Get zoom-out button\n        zoom_out_btn = page.locator('button:has-text(\"焦距-\")')\n        if zoom_out_btn.count() > 0:\n            # Click with hold\n            btn_box = zoom_out_btn.bounding_box()\n            btn_x = btn_box['x'] + btn_box['width'] / 2\n            btn_y = btn_box['y'] + btn_box['height'] / 2\n            \n            print(\"Pressing Zoom-Out button...\")\n            page.mouse.move(btn_x, btn_y)\n            page.mouse.down()\n            page.wait_for_timeout(2000)\n            page.mouse.up()\n            \n            page.wait_for_timeout(1000)\n        \n        # Check console messages\n        print(\"\\n=== Console Messages ===\")\n        for msg in console_messages:\n            print(msg)\n        \n        print(\"\\n=== Page Errors ===\")\n        for err in page_errors:\n            print(err)\n        \n        # Check network requests\n        print(\"\\n=== Last Network Requests ===\")\n        # Use evaluate to check last API calls\n        log_content = page.evaluate(\"() => document.getElementById('ptzLogBox')?.textContent || 'No log'\")\n        print(f\"Log box content: {log_content[:500]}\")\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    test_with_console()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_console_check.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":159226,"output":533,"cacheRead":0,"cacheWrite":0,"totalTokens":159759,"cost":{"input":0.159226,"output":0.0017056,"cacheRead":0,"cacheWrite":0,"total":0.1609316}},"stopReason":"toolUse","timestamp":1781201856610,"responseId":"cht000d4a3d@dx19eb7e76c3cb9cb212"}}
