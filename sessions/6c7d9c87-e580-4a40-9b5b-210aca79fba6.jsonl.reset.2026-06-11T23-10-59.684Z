{"type":"message","id":"d0ae07a9","parentId":"11ca278a","timestamp":"2026-06-11T20:01:55.532Z","message":{"role":"toolResult","toolCallId":"tool-c24270a5fe9240d5ab074937ffa74a2a","toolName":"read","content":[{"type":"text","text":"                            <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+ 焦距+</button>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍- 焦距-</button>\r\n                        </div>\r\n                        <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:12px\">\r\n                            <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">🔧- 前移</button>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">🔧+ 后移</button>\r\n                            <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\r\n                                <option value=\"manual\">手动</option>\r\n                                <option value=\"auto\">自动</option>\r\n                                <option value=\"semiauto\">半自动</option>\r\n                            </select>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 中: 实时画面 + 媒体 -->\r\n                    <div class=\