{"type":"message","id":"718c54b2","parentId":"b23eb3a3","timestamp":"2026-06-11T18:05:27.543Z","message":{"role":"assistant","content":[{"type":"text","text":"API 调用成功。现在运行 E2E 测试："},{"type":"toolCall","id":"call_89d8233fad164d91b8f44585","name":"write","arguments":{"content":"\"\"\"v5.47 E2E Test - Zoom & Focus Fix Verification\"\"\"\nimport time\nfrom playwright.sync_api import sync_playwright\n\nBASE_URL = \"http://localhost:10280\"\nDEVICE_IP = \"192.168.5.72\"\n\ndef test_zoom_focus():\n    results = []\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context()\n        page = context.new_page()\n        \n        # 1. Open page\n        print(\"1. Opening page...\")\n        page.goto(f\"{BASE_URL}/\", timeout=30000)\n        page.wait_for_timeout(2000)\n        \n        # 2. Navigate to Console\n        print(\"2. Navigating to Console...\")\n        try:\n            page.click('[data-page=\"console\"]')\n            page.wait_for_timeout(2000)\n        except:\n            pass\n        \n        # 3. Connect device\n        print(\"3. Connecting device...\")\n        try:\n            # Check if already connected\n            status = page.locator('#deviceStatus')\n            if status.count() > 0 and 'connected' not in status.text_content().lower():\n                device_select = page.locator('#ptzDeviceSelect')\n                if device_select.count() > 0:\n                    device_select.first.select_option(value=DEVICE_IP)\n                    page.wait_for_timeout(500)\n                connect_btn = page.locator('button:has-text(\"连接\")')\n                if connect_btn.count() > 0:\n                    connect_btn.first.click()\n                    page.wait_for_timeout(3000)\n        except Exception as e:\n            print(f\"  Warning: {e}\")\n        \n        # 4. Get initial zoom value\n        print(\"4. Getting initial zoom...\")\n        initial_zoom = 0\n        try:\n            pos_div = page.locator('#ptzPosition')\n            if pos_div.count() > 0:\n                text = pos_div.text_content()\n                import re\n                match = re.search(r'Zoom:\\s*(\\d+)', text)\n                if match:\n                    initial_zoom = int(match.group(1))\n                    print(f\"  Initial zoom: {initial_zoom}\")\n        except:\n            pass\n        \n        # 5. Test Zoom buttons\n        print(\"5. Testing Zoom +/- buttons...\")\n        try:\n            zoom_in_btn = page.locator('button:has-text(\"焦距+\"), button[onmousedown*=\"ptzZoom(\\'in\\'\"]')\n            zoom_out_btn = page.locator('button:has-text(\"焦距-\"), button[onmousedown*=\"ptzZoom(\\'out\\'\"]')\n            \n            if zoom_out_btn.count() > 0:\n                # Click zoom out\n                zoom_out_btn.first.click()\n                page.wait_for_timeout(2500)  # Wait for movement\n                \n                # Get new zoom\n                pos_div = page.locator('#ptzPosition')\n                if pos_div.count() > 0:\n                    text = pos_div.text_content()\n                    match = re.search(r'Zoom:\\s*(\\d+)', text)\n                    if match:\n                        new_zoom = int(match.group(1))\n                        if new_zoom != initial_zoom:\n                            print(f\"  Zoom changed: {initial_zoom} -> {new_zoom}\")\n                            results.append((\"Zoom Buttons\", \"PASS\", f\"Zoom changed from {initial_zoom} to {new_zoom}\"))\n                        else:\n                            results.append((\"Zoom Buttons\", \"FAIL\", f\"Zoom unchanged: {initial_zoom}\"))\n            else:\n                results.append((\"Zoom Buttons\", \"SKIP\", \"Buttons not found\"))\n        except Exception as e:\n            results.append((\"Zoom Buttons\", \"FAIL\", str(e)))\n        \n        # 6. Test Focus buttons\n        print(\"6. Testing Focus +/- buttons...\")\n        try:\n            focus_near_btn = page.locator('button:has-text(\"前移\"), button[onmousedown*=\"ptzFocus(\\'near\\'\"]')\n            focus_far_btn = page.locator('button:has-text(\"后移\"), button[onmousedown*=\"ptzFocus(\\'far\\'\"]')\n            \n            if focus_far_btn.count() > 0:\n                # Get current focus mode\n                focus_mode = page.locator('#focusMode')\n                initial_mode = \"\"\n                if focus_mode.count() > 0:\n                    initial_mode = focus_mode.first.input_value() or focus_mode.first.evaluate('el => el.value')\n                    print(f\"  Initial focus mode: {initial_mode}\")\n                \n                # Click focus far\n                focus_far_btn.first.click()\n                page.wait_for_timeout(2000)\n                \n                # Check if mode changed unexpectedly\n                if focus_mode.count() > 0:\n                    new_mode = focus_mode.first.input_value() or focus_mode.first.evaluate('el => el.value')\n                    if new_mode != initial_mode and initial_mode != \"manual\":\n                        results.append((\"Focus Buttons\", \"FAIL\", f\"Mode changed unexpectedly: {initial_mode} -> {new_mode}\"))\n                    else:\n                        results.append((\"Focus Buttons\", \"PASS\", \"Focus command sent, mode preserved\"))\n            else:\n                results.append((\"Focus Buttons\", \"SKIP\", \"Buttons not found\"))\n        except Exception as e:\n            results.append((\"Focus Buttons\", \"FAIL\", str(e)))\n        \n        # 7. Test OSD Info toggle\n        print(\"7. Testing OSD Info toggle...\")\n        try:\n            info_osd_off = page.locator('#btnInfoOsdOff')\n            \n            if info_osd_off.count() > 0:\n                start = time.time()\n                info_osd_off.click()\n                page.wait_for_timeout(500)\n                \n                # Wait for response (max 5 seconds)\n                try:\n                    page.wait_for_selector('.toast-success, .toast-error', timeout=5000)\n                except:\n                    pass\n                \n                elapsed = time.time() - start\n                results.append((\"OSD Info Toggle\", \"INFO\", f\"Response time: {elapsed:.2f}s\"))\n                print(f\"  OSD Info response time: {elapsed:.2f}s\")\n            else:\n                results.append((\"OSD Info Toggle\", \"SKIP\", \"Button not found\"))\n        except Exception as e:\n            results.append((\"OSD Info Toggle\", \"FAIL\", str(e)))\n        \n        browser.close()\n    \n    # Print summary\n    print(\"\\n\" + \"=\"*50)\n    print(\"TEST SUMMARY\")\n    print(\"=\"*50)\n    for name, status, detail in results:\n        symbol = \"PASS\" if status == \"PASS\" else (\"SKIP\" if status == \"SKIP\" else (\"INFO\" if status == \"INFO\" else \"FAIL\"))\n        print(f\"  [{symbol}] {name}: {detail}\")\n    \n    return all(r[1] in (\"PASS\", \"SKIP\", \"INFO\") for r in results)\n\nif __name__ == \"__main__\":\n    success = test_zoom_focus()\n    exit(0 if success else 1)\n","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_v547.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":142794,"output":1478,"cacheRead":0,"cacheWrite":0,"totalTokens":144272,"cost":{"input":0.142794,"output":0.0047296000000000005,"cacheRead":0,"cacheWrite":0,"total":0.1475236}},"stopReason":"toolUse","timestamp":1781201093384,"responseId":"cht000de92e@dx19eb7dbd31bb85f582"}}
