{"type":"message","id":"c50d0680","parentId":"93f002e4","timestamp":"2026-06-11T18:01:02.973Z","message":{"role":"assistant","content":[{"type":"text","text":"修复 ptzFocus 函数（移除强制切换逻辑）："},{"type":"toolCall","id":"tool-fec05d8c8014430da65241757021ff0c","name":"edit","arguments":{"edits":[{"newText":"        // 对焦控制：直接发送移动指令，不强制切换模式\n        function ptzFocus(mode) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            \n            var dir = mode === 'near' ? 'focus-near' : mode === 'far' ? 'focus-far' : 'focus-auto';\n            var speed = mode === 'auto' ? 0 : parseInt(document.getElementById('ptzSpeed').value);\n            \n            apiPost('/api/v1/ptz/' + dev + '/move', {\n                direction: dir,\n                speed: speed\n            }).then(function(result) {\n                if (result && result.success) {\n                    addLog('info', '对焦: ' + mode);\n                } else {\n                    showToast('error', result ? result.message : '对焦失败');\n                }\n            }).catch(function(e) { showToast('error', '对焦异常: ' + e.message); });\n        }","oldText":"        // 对焦控制\n        // 对焦调整：focus+/- 需要手动模式，自动切换\n        function ptzFocus(mode) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            \n            // focus+/- 需要手动对焦模式，先切换\n            if (mode === 'near' || mode === 'far') {\n                // 先设置为手动模式\n                apiPost('/api/v1/ptz/' + dev + '/focus/mode', { mode: 'manual' }).then(function(result) {\n                    if (result && result.success) {\n                        // 更新下拉框显示\n                        var sel = document.getElementById('focusMode');\n                        if (sel) sel.value = 'manual';\n                        showToast('info', '已切换到手动对焦模式');\n                        \n                        // 然后发送 focus 移动指令\n                        var dir = mode === 'near' ? 'focus-near' : 'focus-far';\n                        apiPost('/api/v1/ptz/' + dev + '/move', {\n                            direction: dir,\n                            speed: parseInt(document.getElementById('ptzSpeed').value)\n                        }).catch(function(e) { addLog('info', 'PTZ 对焦: ' + mode); });\n                    } else {\n                        showToast('error', '切换手动对焦失败');\n                    }\n                }).catch(function(e) { \n                    showToast('error', '切换手动对焦异常: ' + e.message); \n                });\n            } else if (mode === 'auto') {\n                // 自动对焦直接调用\n                apiPost('/api/v1/ptz/' + dev + '/move', {\n                    direction: 'focus-auto',\n                    speed: 0\n                }).catch(function(e) { addLog('info', 'PTZ 对焦: auto'); });\n            }\n        }"}],"path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/src/web/index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":134270,"output":743,"cacheRead":0,"cacheWrite":0,"totalTokens":135013,"cost":{"input":0.13427,"output":0.0023776,"cacheRead":0,"cacheWrite":0,"total":0.1366476}},"stopReason":"toolUse","timestamp":1781200839436,"responseId":"cht000daabe@dx19eb7d7ffe4b85e102"}}
