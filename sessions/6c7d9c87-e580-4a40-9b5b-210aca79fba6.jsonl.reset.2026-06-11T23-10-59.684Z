{"type":"message","id":"de1847a2","parentId":"a349a0a9","timestamp":"2026-06-11T18:02:01.030Z","message":{"role":"assistant","content":[{"type":"text","text":"OSD Info 的 XML 很完整。问题可能是 PUT 时需要发送完整的 XML 结构，而不是修改后的版本。\n\n让我检查官方的 ISAPI PUT 是否需要完整 XML："},{"type":"toolCall","id":"call_75dc61e23edb42a5b2ca8858","name":"write","arguments":{"content":"\"\"\"Test official ISAPI OSD put methods\"\"\"\nimport time\nimport requests\nfrom requests.auth import HTTPDigestAuth\n\nIP = \"192.168.5.72\"\nAUTH = HTTPDigestAuth(\"admin\", \"Nftw1357\")\nENDPOINT = f\"http://{IP}/ISAPI/System/Video/inputs/channels/1/overlays\"\n\n# Method 1: Get original, modify, put back (current implementation)\nprint(\"=== Method 1: GET + Modify + PUT ===\")\nstart = time.time()\nresp = requests.get(ENDPOINT, auth=AUTH, timeout=5)\noriginal = resp.text\nget_time = (time.time() - start) * 1000\nprint(f\"GET: {get_time:.1f}ms\")\n\n# Parse and modify\nimport xml.etree.ElementTree as ET\nroot = ET.fromstring(original)\nfor target in [\"DateTimeOverlay\", \"channelNameOverlay\"]:\n    elem = root.find(target)\n    if elem is not None:\n        enabled = elem.find(\"enabled\")\n        if enabled is not None:\n            enabled.text = \"true\"\n\nxml_str = ET.tostring(root, encoding='unicode')\nxml_str = xml_str.replace('ns0:', '').replace('xmlns:ns0=', 'xmlns=')\nnew_xml = '<?xml version=\"1.0\" encoding=\"UTF-8\"?>' + xml_str\n\nstart = time.time()\nresp = requests.put(ENDPOINT, auth=AUTH, data=new_xml, headers={\"Content-Type\": \"application/xml\"}, timeout=10)\nput_time = (time.time() - start) * 1000\nprint(f\"PUT (modified XML): {put_time:.1f}ms, HTTP {resp.status_code}\")\n\n# Method 2: PUT original XML unchanged (to test if PUT itself is slow)\nprint(\"\\n=== Method 2: PUT original XML unchanged ===\")\nstart = time.time()\nresp = requests.put(ENDPOINT, auth=AUTH, data=original, headers={\"Content-Type\": \"application/xml\"}, timeout=10)\nput_time = (time.time() - start) * 1000\nprint(f\"PUT (original XML): {put_time:.1f}ms, HTTP {resp.status_code}\")\n\n# Method 3: PUT minimal XML (just enabled fields)\nprint(\"\\n=== Method 3: PUT minimal XML ===\")\nminimal_xml = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<VideoOverlay version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<DateTimeOverlay><enabled>true</enabled></DateTimeOverlay>\n<channelNameOverlay><enabled>true</enabled></channelNameOverlay>\n</VideoOverlay>'''\nstart = time.time()\nresp = requests.put(ENDPOINT, auth=AUTH, data=minimal_xml, headers={\"Content-Type\": \"application/xml\"}, timeout=10)\nput_time = (time.time() - start) * 1000\nprint(f\"PUT (minimal XML): {put_time:.1f}ms, HTTP {resp.status_code}\")\n","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/test_osd_methods.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":139863,"output":695,"cacheRead":0,"cacheWrite":0,"totalTokens":140558,"cost":{"input":0.139863,"output":0.0022240000000000003,"cacheRead":0,"cacheWrite":0,"total":0.142087}},"stopReason":"toolUse","timestamp":1781200899299,"responseId":"cht000d1894@dx19eb7d8cfbfb958232"}}
