{"type":"message","id":"8bab9628","parentId":"375ce94e","timestamp":"2026-06-11T20:18:38.461Z","message":{"role":"assistant","content":[{"type":"text","text":"使用 Playwright 验证 Web 界面 Focus 功能："},{"type":"toolCall","id":"tool-fcd45aa4c9fa481d831aad6073166952","name":"write","arguments":{"content":"\"\"\"\n验证 AstroHub Focus 功能\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time, re\n\nBASE = \"http://localhost:10280\"\n\ndef test():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        # 捕获请求\n        requests_log = []\n        page.on(\"request\", lambda r: requests_log.append({\n            'time': time.time(),\n            'method': r.method,\n            'url': r.url,\n            'data': r.post_data or ''\n        }) if 'ISAPI' in r.url or '/ptz/' in r.url else None)\n        \n        print(\"=== 1. 打开 AstroHub ===\")\n        page.goto(BASE, timeout=30000)\n        page.wait_for_load_state('networkidle')\n        \n        print(\"=== 2. 进入 Console ===\")\n        page.click('[data-page=\"console\"]')\n        page.wait_for_timeout(3000)\n        \n        # 检查连接状态\n        status = page.evaluate(\"() => document.getElementById('deviceStatus')?.textContent || ''\")\n        print(f\"   Status: {status}\")\n        \n        # 清空请求记录\n        requests_log.clear()\n        t0 = time.time()\n        \n        print(\"\\n=== 3. 点击 Focus Far (后移) 按钮 ===\")\n        focus_far = page.locator('button:has-text(\"后移\")')\n        if focus_far.count() > 0:\n            focus_far.click(delay=3000)  # 按住 3 秒\n            page.wait_for_timeout(2000)\n            print(\"   已点击并按住 3 秒\")\n        else:\n            print(\"   未找到后移按钮\")\n        \n        print(\"\\n=== 4. 点击 Focus Near (前移) 按钮 ===\")\n        focus_near = page.locator('button:has-text(\"前移\")')\n        if focus_near.count() > 0:\n            focus_near.click(delay=3000)\n            page.wait_for_timeout(2000)\n            print(\"   已点击并按住 3 秒\")\n        else:\n            print(\"   未找到前移按钮\")\n        \n        # 打印捕获的请求\n        print(f\"\\n=== 5. 捕获的 PTZ/Focus 请求 ===\")\n        for r in requests_log:\n            elapsed = r['time'] - t0\n            if 'focus' in r['url'].lower() or 'focus' in r['data'].lower():\n                url_short = r['url'].split('/')[-1] if '/' in r['url'] else r['url']\n                print(f\"   [{elapsed:.2f}s] {r['method']} {url_short}\")\n                if r['data']:\n                    print(f\"      DATA: {r['data'][:200]}\")\n        \n        # 检查日志\n        log_box = page.evaluate(\"() => document.getElementById('ptzLogBox')?.textContent || ''\")\n        print(f\"\\n=== 6. 操作日志 ===\")\n        if '对焦' in log_box or '焦点' in log_box:\n            print(\"   发现对焦操作日志\")\n            print(f\"   内容: {log_box[-200:]}\")\n        else:\n            print(\"   未发现对焦操作日志\")\n        \n        browser.close()\n        \n        # 验证是否发送了 focus=60\n        focus_requests = [r for r in requests_log if 'focus' in r['data'].lower()]\n        if focus_requests:\n            print(\"\\n=== 验证结果 ===\")\n            for r in focus_requests:\n                if '<focus>60</focus>' in r['data'] or '<focus>-60</focus>' in r['data']:\n                    print(\"   PASS: 发送了 focus=±60\")\n                else:\n                    print(f\"   FAIL: 发送了 {r['data'][:100]}\")\n        else:\n            print(\"\\n=== 验证结果 ===\")\n            print(\"   FAIL: 未捕获到 Focus 请求\")\n\nif __name__ == \"__main__\":\n    test()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/verify_focus.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":141310,"output":907,"cacheRead":0,"cacheWrite":0,"totalTokens":142217,"cost":{"input":0.14131,"output":0.0029024000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1442124}},"stopReason":"toolUse","timestamp":1781209096204,"responseId":"cht000d8f17@dx19eb855e141b