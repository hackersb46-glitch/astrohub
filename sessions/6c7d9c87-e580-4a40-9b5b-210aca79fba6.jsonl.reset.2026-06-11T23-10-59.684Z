{"type":"message","id":"75fab7da","parentId":"7f093449","timestamp":"2026-06-11T18:24:16.590Z","message":{"role":"assistant","content":[{"type":"text","text":"`API_BASE` 设置正确。\n\n让我在前端测试中捕获网络请求："},{"type":"toolCall","id":"call_ff186a9114ab459eae214951","name":"write","arguments":{"content":"\"\"\"\nE2E Test - Capture network requests\n\"\"\"\nfrom playwright.sync_api import sync_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\ndef test_network():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context()\n        page = context.new_page()\n        \n        # Capture network requests\n        requests_log = []\n        def log_request(request):\n            if 'ptz' in request.url or 'move' in request.url:\n                requests_log.append(f\"{request.method} {request.url}\")\n        \n        page.on(\"request\", log_request)\n        \n        page.goto(BASE_URL, timeout=30000)\n        page.wait_for_load_state('networkidle')\n        \n        # Navigate to console\n        console_btn = page.locator('[data-page=\"console\"]')\n        console_btn.click()\n        page.wait_for_timeout(2000)\n        \n        print(\"=== Calling ptzZoom('out') ===\")\n        result = page.evaluate(\"() => ptzZoom('out')\")\n        print(f\"Result: {result}\")\n        \n        # Wait for any network requests\n        page.wait_for_timeout(3000)\n        \n        print(\"\\n=== Network Requests ===\")\n        for r in requests_log:\n            print(f\"  {r}\")\n        \n        # Check position\n        pos = page.evaluate(\"() => document.getElementById('ptzPosition')?.textContent\")\n        print(f\"\\n=== Position ===\\n  {pos}\")\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    test_network()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_network.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":52161,"outpu