{"type":"message","id":"5282a122","parentId":"416f9b63","timestamp":"2026-06-11T18:21:28.928Z","message":{"role":"assistant","content":[{"type":"text","text":"代码已正确加载。让我直接在浏览器中测试函数调用："},{"type":"toolCall","id":"call_9bc54cd43d92435699f63575","name":"write","arguments":{"content":"\"\"\"\nE2E Test - Direct function call test\n\"\"\"\nfrom playwright.sync_api import sync_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\ndef test_direct_call():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context()\n        page = context.new_page()\n        \n        page.goto(BASE_URL, timeout=30000)\n        page.wait_for_load_state('networkidle')\n        \n        # Navigate to console\n        console_btn = page.locator('[data-page=\"console\"]')\n        console_btn.click()\n        page.wait_for_timeout(3000)\n        \n        # Check if ptzZoom function exists\n        print(\"Checking if ptzZoom exists...\")\n        result = page.evaluate(\"() => typeof ptzZoom\")\n        print(f\"  typeof ptzZoom: {result}\")\n        \n        # Check if ptzFocus function exists\n        result = page.evaluate(\"() => typeof ptzFocus\")\n        print(f\"  typeof ptzFocus: {result}\")\n        \n        # Check connected device\n        result = page.evaluate(\"() => window.connectedDevice\")\n        print(f\"  connectedDevice: {result}\")\n        \n        # Get current position\n        result = page.evaluate(\"() => document.getElementById('ptzPosition')?.textContent\")\n        print(f\"  Current position: {result}\")\n        \n        # Directly call ptzZoom('out')\n        print(\"\\nCalling ptzZoom('out') directly...\")\n        try:\n            result = page.evaluate(\"() => ptzZoom('out')\")\n            print(f\"  Result: {result}\")\n        except Exception as e:\n            print(f\"  Error: {e}\")\n        \n        # Wait for movement\n        page.wait_for_timeout(3000)\n        \n        # Get new position\n        result = page.evaluate(\"() => document.getElementById('ptzPosition')?.textContent\")\n        print(f\"  New position: {result}\")\n        \n        # Check log box\n        result = page.evaluate(\"() => document.getElementById('ptzLogBox')?.textContent\")\n        print(f\"  Log: {result[:300] if result else 'None'}\")\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    test_direct_call()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_direct_call.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":46836,"output":512,"cacheRead":0,"cacheWrite":0,"totalTokens":47348,"cost":{"input":0.046835999999999996,"output":0.0016384000000000001,"cacheRead":0,"cacheWrite":0,"total":0.048474399999999994}},"stopReason":"toolUse","timestamp":1781202066592,"responseId":"cht000d6722@dx19eb7eaa657b9ca102"}}
