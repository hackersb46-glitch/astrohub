{"type":"message","id":"6f69eeb0","parentId":"c8fb7820","timestamp":"2026-06-11T18:40:21.987Z","message":{"role":"toolResult","toolCallId":"call_1e83304a883e43169d3bdcc1","toolName":"process","content":[{"type":"text","text":"1. Loading page...\r\n2. Opening Console...\r\n   Status: 4k 32X DC\r\n\r\n3. Testing Zoom-Out (hold 2s)...\r\n   Zoom before: 20\r\n   Zoom after:  20\r\n\r\n4. Testing Zoom-In (hold 2s)...\r\n   Zoom after:  20\r\n\r\n5. Testing Focus Near (hold 2s)...\r\n   Focus mode before: manual\r\n   Focus mode after:  manual\r\n\r\n6. Testing Focus Far (hold 2s)...\r\n\r\n7. Testing PTZ OSD toggle...\r\n\r\n8. Testing OSD Info toggle...\r\n\r\n9. Checking JS errors...\r\n\r\n============================================================\r\nSUMMARY\r\n============================================================\r\n  [FAIL] Zoom-Out: 20 -> 20\r\n  [FAIL] Zoom-In: 20 -> 20\r\n  [PASS] Focus Near: mode preserved=True (manual -> manual)\r\n  [PASS] Focus Far: mode preserved=True (manual -> manual)\r\n  [PASS] PTZ OSD: toggle time: 1.1s\r\n  [PASS] OSD Info Off: time: 4.0s\r\n  [PASS] OSD Info On: time: 4.1s\r\n  [PASS] JS Errors: no errors\r\n\r\nTotal: 8 | Pass: 6 | Fail: 2\n\nProcess exited with code 1."}],"details":{"status":"failed","sessionId":"wild-pine","exitCode":1,"aggregated":"1. Loading page...\r\n2. Opening Console...\r\n   Status: 4k 32X DC\r\n\r\n3. Testing Zoom-Out (hold 2s)...\r\n   Zoom before: 20\r\n   Zoom after:  20\r\n\r\n4. Testing Zoom-In (hold 2s)...\r\n   Zoom after:  20\r\n\r\n5. Testing Focus Near (hold 2s)...\r\n   Focus mode before: manual\r\n   Focus mode after:  manual\r\n\r\n6. Testing Focus Far (hold 2s)...\r\n\r\n7. Testing PTZ OSD toggle...\r\n\r\n8. Testing OSD Info toggle...\r\n\r\n9. Checking JS errors...\r\n\r\n============================================================\r\nSUMMARY\r\n============================================================\r\n  [FAIL] Zoom-Out: 20 -> 20\r\n  [FAIL] Zoom-In: 20 -> 20\r\n  [PASS] Focus Near: mode preserved=True (manual -> manual)\r\n  [PASS] Focus Far: mode preserved=True (manual -> manual)\r\n  [PASS] PTZ OSD: toggle time: 1.1s\r\n  [PASS] OSD Info Off: time: 4.0s\r\n  [PASS] OSD Info On: time: 4.1s\r\n  [PASS] JS Errors: no errors\r\n\r\nTotal: 8 | Pass: 6 | Fail: 2\r\n","name":"cd C:\\Users\\admin\\.opencl...s\\dev-factory\\astrohub"},"isError":false,"timestamp":1781203221987}}
{"type":"message","id":"63544ee4","parentId":"6f69eeb0","timestamp":"2026-06-11T18:41:12.493Z","message":{"role":"assistant","content":[{"type":"text","text":"Playwright 测试还是失败。但 curl 测试成功了。问题在于 Playwright 测试中 `dispatchEvent` 发送 `mousedown` 后，`ptzZoom` 被调用但 API 请求没有正确发送。\n\n让我修改测试，使用 `page.click()` 并指定 `delay` 参数："},{"type":"toolCall","id":"call_601fb24f95ee4b3e843e395c","name":"write","arguments":{"content":"\"\"\"\nv5.47 Final E2E - Use page.click() with delay for hold behavior\n\"\"\"\nimport re, time\nfrom playwright.sync_api import sync_playwright\n\nBASE = \"http://localhost:10280\"\n\ndef get_zoom(page):\n    txt = page.evaluate(\"() => document.getElementById('ptzPosition')?.textContent || ''\")\n    m = re.search(r'Zoom:\\s*(\\d+)', txt)\n    return int(m.group(1)) if m else -1\n\ndef test():\n    results = []\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n\n        page.goto(BASE, timeout=30000)\n        page.wait_for_load_state('networkidle')\n\n        # Go to Console\n        page.click('[data-page=\"console\"]')\n        page.wait_for_timeout(3000)\n\n        # Check connection\n        status = page.evaluate(\"() => document.getElementById('deviceStatus')?.textContent || ''\")\n        print(f\"Status: {status}\")\n\n        # ---- Zoom-Out test ----\n        print(\"\\n1. Zoom-Out test (click hold 2s)...\")\n        z0 = get_zoom(page)\n        print(f\"   Zoom before: {z0}\")\n\n        zoom_out = page.locator('button:has-text(\"焦距-\")')\n        # click with delay = hold mousedown for 2 seconds\n        zoom_out.click(delay=2000)\n        page.wait_for_timeout(1500)\n\n        z1 = get_zoom(page)\n        print(f\"   Zoom after:  {z1}\")\n        results.append((\"Zoom-Out\", \"PASS\" if z1 < z0 else \"FAIL\", f\"{z0} -> {z1}\"))\n\n        # ---- Zoom-In test ----\n        print(\"\\n2. Zoom-In test (click hold 2s)...\")\n        zoom_in = page.locator('button:has-text(\"焦距+\")')\n        zoom_in.click(delay=2000)\n        page.wait_for_timeout(1500)\n\n        z2 = get_zoom(page)\n        print(f\"   Zoom after:  {z2}\")\n        results.append((\"Zoom-In\", \"PASS\" if z2 > z1 else \"FAIL\", f\"{z1} -> {z2}\"))\n\n        # ---- Focus Near test ----\n        print(\"\\n3. Focus Near test (click hold 2s)...\")\n        mode0 = page.evaluate(\"() => document.getElementById('focusMode')?.value || ''\")\n        focus_near = page.locator('button:has-text(\"前移\")')\n        focus_near.click(delay=2000)\n        page.wait_for_timeout(1000)\n\n        mode1 = page.evaluate(\"() => document.getElementById('focusMode')?.value || ''\")\n        preserved = mode1 == mode0\n        print(f\"   Mode: {mode0} -> {mode1} (preserved={preserved})\")\n        results.append((\"Focus Near\", \"PASS\" if preserved else \"FAIL\", f\"mode {mode0}->{mode1}\"))\n\n        # ---- Focus Far test ----\n        print(\"\\n4. Focus Far test (click hold 2s)...\")\n        focus_far = page.locator('button:has-text(\"后移\")')\n        focus_far.click(delay=2000)\n        page.wait_for_timeout(1000)\n\n        mode2 = page.evaluate(\"() => document.getElementById('focusMode')?.value || ''\")\n        preserved2 = mode2 == mode0\n        print(f\"   Mode: {mode0} -> {mode2} (preserved={preserved2})\")\n        results.append((\"Focus Far\", \"PASS\" if preserved2 else \"FAIL\", f\"mode {mode0}->{mode2}\"))\n\n        # ---- PTZ OSD ----\n        print(\"\\n5. PTZ OSD toggle...\")\n        page.click('#btnPtzOsdOff')\n        page.wait_for_timeout(500)\n        page.click('#btnPtzOsdOn')\n        page.wait_for_timeout(500)\n        results.append((\"PTZ OSD\", \"PASS\", \"toggle OK\"))\n\n        # ---- OSD Info ----\n        print(\"\\n6. OSD Info toggle...\")\n        t0 = time.time()\n        page.click('#btnInfoOsdOff')\n        page.wait_for_timeout(4000)\n        t1 = time.time()\n        page.click('#btnInfoOsdOn')\n        page.wait_for_timeout(4000)\n        t2 = time.time()\n        results.append((\"OSD Info\", \"PASS\", f\"off={t1-t0:.1f}s on={t2-t1:.1f}s\"))\n\n        browser.close()\n\n    print(\"\\n\" + \"=\" * 60)\n    print(\"SUMMARY\")\n    print(\"=\" * 60)\n    for name, status, detail in results:\n        sym = \"[PASS]\" if status == \"PASS\" else \"[FAIL]\"\n        print(f\"  {sym} {name}: {detail}\")\n    fails = sum(1 for _, s, _ in results if s == \"FAIL\")\n    print(f\"\\nTotal: {len(results)} | Pass: {len(results)-fails} | Fail: {fails}\")\n    return fails == 0\n\nif __name__ == \"__main__\":\n    ok = test()\n    exit(0 if ok else 1)\n","path":"C:/Users/admin/./.openclaw/agents/dev-factory/astrohub/tests/e2e_v547_final.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":76545,"output":1204,"cacheRead":0,"cacheWrite":0,"totalTokens":77749,"cost":{"input":0.076545,"output":0.0038528000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0803978}},"stopReason":"toolUse","timestamp":1781203221990,"responseId":"cht000d11e9@dx19eb7fc43fcb894142"}}
