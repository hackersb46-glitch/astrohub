{"type":"message","id":"af888f2f","parentId":"0e24caff","timestamp":"2026-06-11T19:16:22.150Z","message":{"role":"assistant","content":[{"type":"text","text":"收到。我将使用 Playwright 打开摄像头官方 Web 界面，观察官方是如何实现 Focus 控制的。"},{"type":"toolCall","id":"call_05c6c60a01754d83b3dbad2f","name":"write","arguments":{"content":"\"\"\"\n打开海康摄像头官方 Web 界面，观察 Focus 控制\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\nIP = \"192.168.5.72\"\nUSERNAME = \"admin\"\nPASSWORD = \"Nftw1357\"\n\ndef test():\n    with sync_playwright() as p:\n        # 启动浏览器（非 headless，以便观察）\n        browser = p.chromium.launch(headless=False, slow_mo=500)\n        context = browser.new_context(ignore_https_errors=True)\n        page = context.new_page()\n        \n        # 捕获网络请求\n        requests_log = []\n        page.on(\"request\", lambda r: requests_log.append(f\"{r.method} {r.url}\") if 'focus' in r.url.lower() or 'ptz' in r.url.lower() else None)\n        \n        print(f\"1. 打开摄像头登录页面: http://{IP}/\")\n        page.goto(f\"http://{IP}/\", timeout=30000)\n        page.wait_for_load_state('networkidle')\n        page.wait_for_timeout(3000)\n        \n        print(\"2. 等待登录页面加载...\")\n        # 海康登录页面通常是输入用户名密码后点击登录\n        try:\n            # 查找用户名输入框\n            username_input = page.locator('input[type=\"text\"], input[name=\"username\"], input[id*=\"username\"], input[id*=\"user\"]').first\n            if username_input.count() > 0:\n                username_input.fill(USERNAME)\n                print(f\"   输入用户名: {USERNAME}\")\n        except:\n            pass\n        \n        try:\n            # 查找密码输入框\n            password_input = page.locator('input[type=\"password\"]').first\n            if password_input.count() > 0:\n                password_input.fill(PASSWORD)\n                print(f\"   输入密码: ****\")\n        except:\n            pass\n        \n        try:\n            # 查找登录按钮\n            login_btn = page.locator('button:has-text(\"登录\"), button:has-text(\"Login\"), input[type=\"submit\"]').first\n            if login_btn.count() > 0:\n                login_btn.click()\n                print(\"   点击登录\")\n        except:\n            pass\n        \n        print(\"3. 等待登录完成...\")\n        page.wait_for_timeout(5000)\n        \n        print(\"4. 当前页面 URL:\", page.url)\n        print(\"   页面标题:\", page.title())\n        \n        # 查找 PTZ 或 Focus 相关的菜单/按钮\n        print(\"\\n5. 查找 PTZ/Focus 相关元素...\")\n        \n        # 尝试各种可能的 PTZ 入口\n        ptz_keywords = ['PTZ', 'ptz', '云台', '对焦', 'Focus', 'focus', '镜头']\n        for kw in ptz_keywords:\n            try:\n                elem = page.locator(f':text(\"{kw}\")').first\n                if elem.count() > 0:\n                    print(f\"   找到元素包含 '{kw}'\")\n            except:\n                pass\n        \n        # 截图保存\n        page.screenshot(path=\"hikvision_login.png\")\n        print(\"\\n   已保存截图: hikvision_login.png\")\n        \n        # 等待用户观察\n        print(\"\\n请在浏览器中手动操作，找到 Focus 控制界面...\")\n        print(\"按 Enter 继续...\")\n        input()\n        \n        # 打印捕获的请求\n        if requests_log:\n            print(\"\\n捕获到的 Focus/PTZ 相关请求:\")\n            for r in requests_log:\n                print(f\"  {r}\")\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    test()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/hikvision_web_focus.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":110053,"output":828,"cacheRead":0,"cacheWrite":0,"totalTokens":110881,"cost":{"input":0.110053,"output":0.0026496000000000002,"cacheRead":0,"cacheWrite":0,"total":0.1127026}},"stopReason":"toolUse","timestamp":1781205349884,"responseId":"cht000d5cbb@dx19eb81ce437ba5b442"}}
