{"type":"message","id":"aeec2084","parentId":"b477195e","timestamp":"2026-06-11T19:09:59.192Z","message":{"role":"toolResult","toolCallId":"call_e20a8890536448f9aebce53b","toolName":"exec","content":[{"type":"text","text":"=== ���� PTZ capabilities �е� focus ��� ===\r\n\r\n> <isSupportPTZEagle[7mFocus[0ming>true</isSupportPTZEagleFocusing>\r\n> <[7mLFPosition[0mCap>[0m\r\n[7m[0m  <elevation min=\"-900\" max=\"2700\">0</elevation>[0m\r\n[7m[0m  <azimuth min=\"0\" max=\"3600\">0</azimuth>[0m\r\n[7m[0m  <absoluteZoom min=\"1\" max=\"1000\">0</absoluteZoom>[0m\r\n> </[7mLFPosition[0mCap>[0m\r\n[7m[0m  <isSupportManualWiper>true</isSupportManualWiper>[0m\r\n[7m[0m  <PTZAuxType opt=\"LIGHT,FAN,HEATER\"/>[0m\r\n[7m[0m  <isSupportGPSCtrl>true</isSupportGPSCtrl>[0m\r\n[7m[0m  <isSupportGyroVerify>true</isSupportGyroVerify>[0m\r\n[7m[0m  </PTZChanelCap>[0m"}],"details":{"status":"completed","exitCode":0,"durationMs":443,"aggregated":"=== ���� PTZ capabilities �е� focus ��� ===\r\n\r\n> <isSupportPTZEagle[7mFocus[0ming>true</isSupportPTZEagleFocusing>\r\n> <[7mLFPosition[0mCap>[0m\r\n[7m[0m  <elevation min=\"-900\" max=\"2700\">0</elevation>[0m\r\n[7m[0m  <azimuth min=\"0\" max=\"3600\">0</azimuth>[0m\r\n[7m[0m  <absoluteZoom min=\"1\" max=\"1000\">0</absoluteZoom>[0m\r\n> </[7mLFPosition[0mCap>[0m\r\n[7m[0m  <isSupportManualWiper>true</isSupportManualWiper>[0m\r\n[7m[0m  <PTZAuxType opt=\"LIGHT,FAN,HEATER\"/>[0m\r\n[7m[0m  <isSupportGPSCtrl>true</isSupportGPSCtrl>[0m\r\n[7m[0m  <isSupportGyroVerify>true</isSupportGyroVerify>[0m\r\n[7m[0m  </PTZChanelCap>[0m","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781204999192}}
