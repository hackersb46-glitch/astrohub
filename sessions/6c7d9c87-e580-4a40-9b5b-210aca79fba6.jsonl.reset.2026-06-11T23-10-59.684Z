{"type":"message","id":"43f6010b","parentId":"bf183a5f","timestamp":"2026-06-11T13:49:46.058Z","message":{"role":"assistant","content":[{"type":"text","text":"现在我理解文件格式了（使用 \\n 换行，但中文显示为乱码）。让我用 Python 直接修改："},{"type":"toolCall","id":"call_cd8cf4adfb3a475690ba36d8","name":"exec","arguments":{"command":"cd C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub && python -c \"\nimport re\n\nwith open('src/web/index.html', 'r', encoding='utf-8') as f:\n    content = f.read()\n\n# 找到 ptzFocus 函数并替换\nold_func = '''        function ptzFocus(mode) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            var dir = mode === 'auto' ? 'focus-auto' : mode === 'near' ? 'focus-near' : 'focus-far';\n            apiPost('/api/v1/ptz/' + dev + '/move', {\n                direction: dir,\n                speed: parseInt(document.getElementById('ptzSpeed').value)\n            }).catch(function(e) { addLog('info', 'PTZ 对焦: ' + mode); });\n        }'''\n\nnew_func = '''        // 对焦调整：focus+/- 需要手动模式，自动切换\n        function ptzFocus(mode) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            \n            // focus+/- 需要手动对焦模式，先切换\n            if (mode === 'near' || mode === 'far') {\n                // 先设置为手动模式\n                apiPost('/api/v1/ptz/' + dev + '/focus/mode', { mode: 'manual' }).then(function(result) {\n                    if (result && result.success) {\n                        // 更新下拉框显示\n                        var sel = document.getElementById('focusMode');\n                        if (sel) sel.value = 'manual';\n                        showToast('info', '已切换到手动对焦模式');\n                        \n                        // 然后发送 focus 移动指令\n                        var dir = mode === 'near' ? 'focus-near' : 'focus-far';\n                        apiPost('/api/v1/ptz/' + dev + '/move', {\n                            direction: dir,\n                            speed: parseInt(document.getElementById('ptzSpeed').value)\n                        }).catch(function(e) { addLog('info', 'PTZ 对焦: ' + mode); });\n                    } else {\n                        showToast('error', '切换手动对焦失败');\n                    }\n                }).catch(function(e) { \n                    showToast('error', '切换手动对焦异常: ' + e.message); \n                });\n            } else if (mode === 'auto') {\n                // 自动对焦直接调用\n                apiPost('/api/v1/ptz/' + dev + '/move', {\n                    direction: 'focus-auto',\n                    speed: 0\n                }).catch(function(e) { addLog('info', 'PTZ 对焦: auto'); });\n            }\n        }'''\n\nif old_func in content:\n    content = content.replace(old_func, new_func)\n    with open('src/web/index.html', 'w', encoding='utf-8') as f:\n        f.write(content)\n    print('SUCCESS: ptzFocus function updated')\nelse:\n    print('ERROR: Could not find exact match')\n    # Try to find similar pattern\n    import re\n    match = re.search(r'function ptzFocus\\(mode\\) \\{[^}]+\\}', content, re.DOTALL)\n    if match:\n        print('Found similar pattern:')\n        print(match.group(0)[:200])\n\""}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":94257,"output":771,"cacheRead":0,"cacheWrite":0,"totalTokens":95028,"cost":{"input":0.094257,"output":0.0024672,"cacheRead":0,"cacheWrite":0,"total":0.0967242}},"stopReason":"toolUse","timestamp":1781185763306,"responseId":"cht000ddab1@dx19eb6f1e819ba5b442"}}
