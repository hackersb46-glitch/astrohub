{"type":"message","id":"2aba50a6","parentId":"209a174f","timestamp":"2026-06-11T18:44:43.175Z","message":{"role":"assistant","content":[{"type":"text","text":"Zoom 还是失败。但 **curl 测试成功了**（zoom 从 133→20）。\n\n问题在于 **前端按钮点击时，API 请求没有正确发送**。\n\n让我直接检查浏览器中按钮点击时的网络请求："},{"type":"toolCall","id":"tool-59a1be7fa4864713befa54d5d280a4ed","name":"write","arguments":{"content":"\"\"\"\nDebug - Check network requests when button clicked\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\nBASE = \"http://localhost:10280\"\n\ndef test():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        requests_log = []\n        page.on(\"request\", lambda r: requests_log.append((time.time(), r.method, r.url)) if '/ptz/' in r.url else None)\n        \n        page.goto(BASE)\n        page.wait_for_load_state('networkidle')\n        page.click('[data-page=\"console\"]')\n        page.wait_for_timeout(3000)\n        \n        t0 = time.time()\n        \n        # Use page.click() with delay\n        print(\"Clicking zoom-out button with delay=2000...\")\n        zoom_out = page.locator('button:has-text(\"焦距-\")')\n        zoom_out.click(delay=2000)\n        \n        page.wait_for_timeout(2000)\n        \n        print(\"\\nRequests:\")\n        for ts, method, url in sorted(requests_log):\n            rel = ts - t0\n            short_url = url.split('/')[-1] if '/' in url else url\n            print(f\"  [{rel:.3f}s] {method} {short_url}\")\n        \n        # Check zoom\n        import re\n        txt = page.evaluate(\"() => document.getElementById('ptzPosition')?.textContent || ''\")\n        m = re.search(r'Zoom:\\s*(\\d+)', txt)\n        zoom = int(m.group(1)) if m else -1\n        print(f\"\\nZoom: {zoom}\")\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    test()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_network_debug.py"}}],"api":"o