{"type":"message","id":"1f06aa6d","parentId":"69a5ac12","timestamp":"2026-06-11T19:17:59.011Z","message":{"role":"assistant","content":[{"type":"text","text":"只捕获了 2 条 ISAPI 请求，没有 focus 相关。让我直接访问摄像头 Web 界面并查找 PTZ 控制页面："},{"type":"toolCall","id":"call_22d3f64a56af4d3496fb84cd","name":"write","arguments":{"content":"\"\"\"\n直接访问海康摄像头 ISAPI 文档和 PTZ 控制页面\n查找官方 Focus 控制方法\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\nIP = \"192.168.5.72\"\nUSERNAME = \"admin\"\nPASSWORD = \"Nftw1357\"\n\ndef test():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        # 使用 HTTP 认证\n        context = browser.new_context(ignore_https_errors=True)\n        page = context.new_page()\n        \n        # 设置认证\n        page.set_extra_http_headers({\n            'Authorization': 'Basic ' + __import__('base64').b64encode(f'{USERNAME}:{PASSWORD}'.encode()).decode()\n        })\n        \n        all_requests = []\n        def capture(req):\n            if 'ISAPI' in req.url or 'focus' in req.url.lower():\n                all_requests.append({\n                    'method': req.method,\n                    'url': req.url,\n                    'data': req.post_data[:500] if req.post_data else ''\n                })\n        page.on('request', capture)\n        \n        print(\"=== 1. 访问登录页面 ===\")\n        page.goto(f\"http://{IP}/doc/index.html\", timeout=30000)\n        page.wait_for_timeout(3000)\n        \n        print(f\"   URL: {page.url}\")\n        \n        # 登录\n        print(\"\\n=== 2. 执行登录 ===\")\n        try:\n            # 填写用户名密码\n            page.fill('input[placeholder*=\"用户名\"], input[id*=\"username\"], input[name=\"username\"]', USERNAME)\n            page.fill('input[type=\"password\"]', PASSWORD)\n            page.click('button:has-text(\"登录\"), button[type=\"submit\"]')\n            page.wait_for_timeout(5000)\n            print(f\"   登录后 URL: {page.url}\")\n        except Exception as e:\n            print(f\"   登录操作: {e}\")\n        \n        # 查找 PTZ 或预览页面\n        print(\"\\n=== 3. 查找 PTZ/预览页面 ===\")\n        \n        # 海康常见路径\n        paths = [\n            \"/doc/page/preview.asp\",\n            \"/doc/page/PTZ.asp\", \n            \"/doc/page/main.asp\",\n            \"/doc/index.html#/app/preview\",\n            \"/doc/index.html#/app/ptz\",\n        ]\n        \n        for path in paths:\n            try:\n                url = f\"http://{IP}{path}\"\n                print(f\"   尝试: {url}\")\n                page.goto(url, timeout=10000)\n                page.wait_for_timeout(3000)\n                \n                # 查找 focus 相关元素\n                focus_btns = page.locator('button:has-text(\"对焦\"), button:has-text(\"Focus\"), [title*=\"对焦\"], [title*=\"Focus\"]')\n                if focus_btns.count() > 0:\n                    print(f\"   找到 Focus 控制按钮!\")\n                    break\n            except Exception as e:\n                print(f\"   失败: {str(e)[:50]}\")\n        \n        # 打印捕获的请求\n        print(\"\\n=== 4. 捕获的 ISAPI 请求 ===\")\n        for r in all_requests[-30:]:\n            url_short = r['url'].replace(f'http://{IP}/ISAPI/', '')\n            print(f\"   {r['method']} {url_short}\")\n            if 'focus' in r['data'].lower() or 'focus' in url_short.lower():\n                print(f\"      DATA: {r['data'][:200]}\")\n        \n        # 截图\n        page.screenshot(path=\"hikvision_ptz.png\")\n        print(\"\\n截图已保存: hikvision_ptz.png\")\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    test()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/hikvision_web_full.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":112234,"output":880,"cacheRead":0,"cacheWrite":0,"totalTokens":113114,"cost":{"input":0.112234,"output":0.0028160000000000004,"cacheRead":0,"cacheWrite":0,"total":0.11505}},"stopReason":"toolUse","timestamp":1781205446844,"responseId":"cht000d6d43@dx19eb81