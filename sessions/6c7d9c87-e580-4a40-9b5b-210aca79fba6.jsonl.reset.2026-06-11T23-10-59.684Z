{"type":"message","id":"0169305d","parentId":"55079ee1","timestamp":"2026-06-11T19:16:42.822Z","message":{"role":"assistant","content":[{"type":"text","text":"由于 headless=False 需要显示器，让我改为捕获网络请求的方式："},{"type":"toolCall","id":"call_98b767e757074d73aabdb848","name":"write","arguments":{"content":"\"\"\"\n捕获海康摄像头官方 Web 界面的 Focus 相关 ISAPI 请求\n通过拦截网络请求，找到官方使用的端点和方法\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\nIP = \"192.168.5.72\"\nUSERNAME = \"admin\"\nPASSWORD = \"Nftw1357\"\n\ndef test():\n    all_requests = []\n    isapi_requests = []\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context(ignore_https_errors=True, http_credentials={\"username\": USERNAME, \"password\": PASSWORD})\n        page = context.new_page()\n        \n        # 拦截所有请求\n        def capture_request(request):\n            url = request.url\n            method = request.method\n            post_data = request.post_data or \"\"\n            \n            # 记录 ISAPI 相关请求\n            if 'ISAPI' in url:\n                isapi_requests.append({\n                    'time': time.strftime('%H:%M:%S'),\n                    'method': method,\n                    'url': url,\n                    'post_data': post_data[:500] if post_data else ''\n                })\n            \n            # 特别关注 focus 相关\n            if 'focus' in url.lower() or 'Focus' in post_data or 'focus' in post_data.lower():\n                all_requests.append({\n                    'time': time.strftime('%H:%M:%S'),\n                    'method': method,\n                    'url': url,\n                    'post_data': post_data\n                })\n        \n        page.on(\"request\", capture_request)\n        \n        print(f\"=== 1. 访问摄像头: http://{IP}/ ===\")\n        page.goto(f\"http://{IP}/\", timeout=30000, wait_until='networkidle')\n        page.wait_for_timeout(5000)\n        \n        print(f\"\\n=== 2. 当前 URL: {page.url} ===\")\n        print(f\"   标题: {page.title()}\")\n        \n        # 查找 PTZ 页面入口\n        print(\"\\n=== 3. 查找 PTZ 相关链接 ===\")\n        \n        # 尝试直接访问 PTZ 页面\n        ptz_urls = [\n            f\"http://{IP}/ISAPI/PTZCtrl\",\n            f\"http://{IP}/doc/page/PTZ.asp\",\n            f\"http://{IP}/doc/page/preview.asp\",\n            f\"http://{IP}/index.html\",\n        ]\n        \n        for url in ptz_urls:\n            try:\n                print(f\"   尝试: {url}\")\n                page.goto(url, timeout=10000, wait_until='networkidle')\n                page.wait_for_timeout(2000)\n                if 'PTZ' in page.title() or 'ptz' in page.url.lower():\n                    print(f\"   找到 PTZ 页面!\")\n                    break\n            except Exception as e:\n                print(f\"   失败: {e}\")\n        \n        # 打印捕获的 ISAPI 请求\n        print(\"\\n=== 4. 捕获到的 ISAPI 请求 ===\")\n        for r in isapi_requests[-20:]:  # 最近 20 条\n            print(f\"  [{r['time']}] {r['method']} {r['url'].split('/ISAPI/')[-1] if '/ISAPI/' in r['url'] else r['url']}\")\n            if r['post_data'] and 'focus' in r['post_data'].lower():\n                print(f\"    POST: {r['post_data'][:200]}\")\n        \n        # 打印 Focus 相关请求\n        if all_requests:\n            print(\"\\n=== 5. Focus 相关请求 ===\")\n            for r in all_requests:\n                print(f\"  [{r['time']}] {r['method']} {r['url']}\")\n                if r['post_data']:\n                    print(f\"    POST: {r['post_data'][:300]}\")\n        \n        browser.close()\n    \n    return isapi_requests, all_requests\n\nif __name__ == \"__main__\":\n    isapi, focus = test()\n    print(f\"\\n共捕获 {len(isapi)} 条 ISAPI 请求, {len(focus)} 条 Focus 相关请求\")","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/hikvision_isapi_capture.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":110927,"output":926,"cacheRead":0,"cacheWrite":0,"totalTokens"