{"type":"message","id":"91c923f5","parentId":"49225766","timestamp":"2026-06-11T19:19:36.105Z","message":{"role":"assistant","content":[{"type":"text","text":"让我使用不同的方法 - 直接在预览页面上查找 PTZ 控制面板并点击 Focus 按钮："},{"type":"toolCall","id":"call_8ff7dba931c247ed9a8f32dc","name":"write","arguments":{"content":"\"\"\"\n在海康预览页面查找并操作 PTZ/Focus 控制\n捕获实际的 ISAPI 请求\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time, json\n\nIP = \"192.168.5.72\"\nUSERNAME = \"admin\"\nPASSWORD = \"Nftw1357\"\n\ndef test():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context(ignore_https_errors=True)\n        page = context.new_page()\n        \n        # 捕获所有请求\n        all_requests = []\n        def capture(req):\n            if 'ISAPI' in req.url:\n                all_requests.append({\n                    'time': time.time(),\n                    'method': req.method,\n                    'url': req.url.split('/ISAPI/')[-1] if '/ISAPI/' in req.url else req.url,\n                    'data': req.post_data or ''\n                })\n        page.on('request', capture)\n        \n        print(\"=== 1. 登录摄像头 ===\")\n        page.goto(f\"http://{IP}/doc/index.html\", timeout=30000)\n        page.wait_for_timeout(2000)\n        \n        # 登录\n        try:\n            page.fill('input[placeholder*=\"用户名\"], input[id*=\"username\"], input[name=\"username\"]', USERNAME, timeout=5000)\n            page.fill('input[type=\"password\"]', PASSWORD, timeout=5000)\n            page.click('button:has-text(\"登录\"), button[type=\"submit\"]', timeout=5000)\n            page.wait_for_timeout(5000)\n            print(\"   登录成功\")\n        except Exception as e:\n            print(f\"   登录: {e}\")\n        \n        print(\"\\n=== 2. 进入预览页面 ===\")\n        page.goto(f\"http://{IP}/doc/index.html#/preview\", timeout=30000)\n        page.wait_for_timeout(5000)\n        \n        print(f\"   当前 URL: {page.url}\")\n        \n        # 查找 PTZ 控制按钮\n        print(\"\\n=== 3. 查找 PTZ 控制元素 ===\")\n        \n        # 获取页面 HTML 分析结构\n        html = page.content()\n        \n        # 查找可能的 PTZ 控制区域\n        ptz_selectors = [\n            '.ptz-control', '[class*=\"ptz\"]', '[class*=\"PTZ\"]',\n            'button:has-text(\"PTZ\")', 'button:has-text(\"云台\")',\n            '[title*=\"PTZ\"]', '[title*=\"云台\"]', '[title*=\"对焦\"]',\n            '.focus-control', '[class*=\"focus\"]'\n        ]\n        \n        found_elements = []\n        for sel in ptz_selectors:\n            try:\n                elems = page.locator(sel)\n                count = elems.count()\n                if count > 0:\n                    for i in range(min(count, 3)):\n                        elem = elems.nth(i)\n                        text = elem.text_content() or ''\n                        title = elem.get_attribute('title') or ''\n                        cls = elem.get_attribute('class') or ''\n                        found_elements.append(f\"{sel}: text='{text[:30]}' title='{title}' class='{cls[:50]}'\")\n            except:\n                pass\n        \n        if found_elements:\n            print(\"   找到 PTZ 相关元素:\")\n            for e in found_elements[:10]:\n                print(f\"     {e}\")\n        else:\n            print(\"   未找到 PTZ 相关元素\")\n        \n        # 尝试点击 PTZ 按钮展开控制面板\n        print(\"\\n=== 4. 尝试展开 PTZ 控制面板 ===\")\n        \n        # 常见的 PTZ 展开按钮\n        expand_selectors = [\n            'button:has-text(\"PTZ\")',\n            'button:has-text(\"云台\")',\n            '[class*=\"ptz-btn\"]',\n            '[class*=\"ptz-toggle\"]',\n            '.toolbar button:nth-child(1)',\n        ]\n        \n        for sel in expand_selectors:\n            try:\n                btn = page.locator(sel).first\n                if btn.count() > 0:\n                    print(f\"   点击: {sel}\")\n                    btn.click()\n                    page.wait_for_timeout(3000)\n                    break\n            except:\n                pass\n        \n        # 查找 Focus 相关按钮\n        print(\"\\n=== 5. 查找 Focus 控制按钮 ===\")\n        focus_selectors = [\n            'button:has-text(\"对焦\")', 'button:has-text(\"Focus\")',\n            '[title*=\"对焦\"]', '[title*=\"Focus\"]',\n            '[class*=\"focus\"]', '.focus-btn',\n            'button:has-text(\"前移\")', 'button:has-text(\"后移\")',\n            'button:has-text(\"近\")', 'button:has-text(\"远\")',\n        ]\n        \n        focus_found = []\n        for sel in focus_selectors:\n            try:\n                elems = page.locator(sel)\n                count = elems.count()\n                if count > 0:\n                    for i in range(count):\n                        elem = elems.nth(i)\n                        text = elem.text_content() or ''\n                        title = elem.get_attribute('title') or ''\n                        focus_found.append({'selector': sel, 'text': text, 'title': title})\n            except:\n                pass\n        \n        if focus_found:\n            print(\"   找到 Focus 相关按钮:\")\n            for f in focus_found:\n                print(f\"     {f}\")\n            \n            # 点击第一个 focus 按钮并捕获请求\n            print(\"\\n=== 6. 点击 Focus 按钮并捕获请求 ===\")\n            t0 = time.time()\n            \n            # 清空之前的请求记录\n            all_requests.clear()\n            \n            try:\n                first_btn = page.locator(focus_found[0]['selector']).first\n                first_btn.click()\n                page.wait_for_timeout(3000)\n                \n                # 打印捕获的请求\n                print(f\"\\n   捕获到 {len(all_requests)} 条 ISAPI 请求:\")\n                for r in all_requests:\n                    elapsed = r['time'] - t0\n                    print(f\"     [{elapsed:.2f}s] {r['method']} {r['url']}\")\n                    if r['data'] and ('focus' in r['data'].lower() or 'Focus' in r['data']):\n                        print(f\"        POST DATA: {r['data'][:300]}\")\n            except Exception as e:\n                print(f\"   点击失败: {e}\")\n        else:\n            print(\"   未找到 Focus 按钮\")\n        \n        # 截图\n        page.screenshot(path=\"hikvision_ptz_panel.png\")\n        print(\"\\n截图已保存: hikvision_ptz_panel.png\")\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    test()","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/hikvision_focus_capture.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":108274,"output":1501,"cacheRead":0,"cacheWrite":0,"totalTokens":109775,"cost":{"input":0.108274,"output":0.0048032000000000005,"cacheRead":0,"cacheWrite":0,"total":0.11307719999999999}},"stopReason":"toolUse","timestamp":1781205518736,"responseId":"cht000d5f69@dx19eb81f4a7bba5a412"}}
