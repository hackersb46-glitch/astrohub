 # 先切换到手动模式\n+1152         self.set_focus_mode('manual')\n 1141         \n-1142         # near 负方向（焦点前移），far 正方向（焦点后移）\n-1143         # 由于无法读取当前位置，使用连续移动方式\n-1144         return self.continuous_move(pan=0, tilt=0, zoom=0, focus=step if direction == 'far' else -step)\n+1154         # 使用 PTZ continuous 作为替代方案（设备不支持读取 focusPos）\n+1155         return self.focus_move_continuous(direction, step)\n 1145 \n 1146     def absolute_move(self, pan: float, tilt: float, zoom: float | None = None, speed: int = 50) -> bool:\n 1147         zoom_val = f\"<absoluteZoom>{zoom}</absoluteZoom>\" if zoom is not None else \"\"\n 1148         xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n      ...","firstChangedLine":1128},"isError":false,"timestamp":1781205079326}}
{"type":"message","id":"8d9c3dd8","parentId":"95b28645","timestamp":"2026-06-11T19:11:28.454Z","message":{"role":"assistant","content":[{"type":"text","text":"代码结构已修改，但核心逻辑保持不变（因为 PTZ continuous 中的 focus 参数虽然设备不支持读取，但 PUT 时仍然接受）。\n\n**最终结论**：\n\n海康 ISAPI Focus 控制有两种方法：\n1. **PTZ continuous** - 使用 `<focus>` 速度参数，但设备 capabilities 显示不支持\n2. **focusConfiguration** - 使用 `<focusPos>` 绝对位置，但无法读取当前位置\n\n**当前 AstroHub 使用方法 1**（PTZ continuous），虽然设备声称不支持，但 ISAPI 接口接受请求。\n\n**老板需要通过实际画面验证**：\n- 点击\"前移\"按钮按住 2-3 秒，观察画面清晰度变化\n- 点击\"后移\"按钮按住 2-3 秒，观察画面清晰度变化\n\n重启服务测试："},{"type":"toolCall","id":"tool-eebc58f73cb3453898fdf0d05f74c4b2","name":"process","arguments":{"action":"kill","sessionId":"swift-river"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":102545,"output":194,"cacheRead":0,"cacheWrite":0,"totalTokens":102739,"cost":{"input":0.102545,"output":0.0006208,"cacheRead":0,"cacheWrite":0,"total":0.1031658}},"stopReason":"toolUse","timestamp":1781205079328,"responseId":"cht000d3069@dx19eb81896beba5b442"}}
