ntById('resultDiv');\n                            var resultDiv = document.getElementById('presetResult');\n                            if (resultDiv) resultDiv.textContent = '成功！') {\n                        }\n                    });\n                });\n            });\n        } else {\n            // 更新版本号\n            document.getElementById('version') {\n                version = dat = version信息\n            } else {\n        }\n    </ else>\n                // zoom 分钟\n                version: 'v5.46'\n                document.getElementById('HEversion').').innerHTML = `\n        <div style=\"text-align:center; font-size:14px\">\n            justify-content:center; margin-bottom:8px;\">\n        </ptz-controls { display:grid; grid-template-columns:repeat(3, 80px); gap:8px; justify-content: center; margin:20px 0; }\n        .ptz-btn:hover { background: #238636; border-color:#238636; }\n        .ptz-btn.center { background: #21262d; cursor:default; transform:none; }\n        .ptz-btn:active:not(.center) { transform:scale(0.95); }\n        .ptz-speed { display:flex; align-items:center; gap:12px; justify-content:center; margin:16px 0; }\n        .ptz-speed input[type=range\" id=\"ptzSpeed\" width:200px\" accent-color:#58a6ff; }\n        .ptz-speed label[for=\"速度: 1-100\" style=\"margin-bottom:16px; font-size:14px; color:#8b949e; font-weight: bold\">\n        .ptz-btn:hover { background: #21262d; border-radius: 10px; }\n        .ptz-btn.center:hover { background: #21262d; cursor: default; transform:none; }\n        .ptz-btn.center: background: #21262d; border-radius: 10px; }\n        .ptz-btn { width: 80px; height: 80px; border: 1px solid #30363d; border-radius: 10px; font-size: 24px; color: #e0e6f0; }\n        .ptz-btn:hover { background: #21262d; }\n        .ptz-btn:active:not(.center) {\n            transform: scale(0.95);\n        }\n        .ptz-btn:active:not(.center): transform: scale(0.95);\n        }\n        .ptz-btn.center: background: #21262d; }\n        .ptz-btn.center:hover { background: #21262d; }\n        .ptz-btn.center:hover { transform:none; }\n\n        .form-group { margin-bottom:16px; font-size:14px; color:#8b949e; margin-bottom:8px; }\n        .form-group { margin-bottom:16px; font-size:12px; color:#8b949e; margin-bottom:12px; }\n        .form-group { margin-bottom:16px; }\n            .form-group label { display: block; font-size:12px; color:#8b949e; margin-bottom: 8px; margin:4px 0; }\n            .form-group:not(.ptz-controls) {\n                margin: 0 0px 0; display: grid; grid-template-columns:repeat(3, 80px); gap:8px; justify-content:center; margin:20px 0; }\n            .form-group { margin-bottom:16px; }\n            .form-group label { display: block; font-size:12px; color:#8b949e; margin-bottom: 8px; justify-content:center\">\n        }\n        .form-group { margin-bottom:16px; }\n            .form-group label { display: block; font-size:12px; color:#8b949e; margin-bottom:8px; justify-content: flex-start;\">\n        }\n        .form-group { margin-bottom:16px; }\n            .form-group label {焦距控制 }\n            <div class=\"form-group\" style=\"margin-bottom:16px; font-size:12px; color:#8b949e; margin-bottom:8px; margin-top:16px; border-top: 1px solid #30363d; border-radius: 10px; }\n            .form-group label { display: block; font-size:12px; color:#8b949e; margin-top: 24px; border: 1px solid #21262d; }\n            .form-group { margin-bottom:16px; }\n            .form-group label {预置点}\n            <div class=\"form-group\" style=\"margin-bottom:16px\">\n                <div class=\"btn-group\" style=\"justify-content:center; flex-wrap: wrap;\">\n                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                        <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存当前位置</button>\n                        <button class=\"btn btn-primary btn-sm\" onclick=\"ptzStop()\">停止</button>\n                        <div style=\"margin-top:12px\">\n                            <div class=\"ptz-position\" id=\"ptzPosition\" style=\"text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0; font-family:monospace; font-size:14px\">\n                                Pan: -- | Tilt: -- | Zoom: --<br id=\"ptzPosition\"></div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"card\" style=\"text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0\">\n                <div class=\"card\" style=\"text-align:center; padding:12px; background:#161b22; border: 1px solid #21262d\">\n                <h3 style=\"font-size:15px;color:#8b949e\">0 min-height: 1px 1rem; margin-bottom: 8px;\">📷 体操作</h33 <div class=\"card\" style=\"text-align:center; padding:12px; background:#161b22; border: 1px solid #21262d\">\n                <div class=\"btn-group\" style=\"justify-content:center; flex-wrap: wrap; gap:6px; justify-content:center; margin-bottom: 8px; margin-top: 24px\">\n                    <button class=\"btn btn-primary btn-sm\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                        <button class=\"btn btn-warning btn-sm\" onclick=\"consoleRecordStop()\">⏹ 录像</button>\n                        <div style=\"margin-top:12px\">\n                            <div class=\"card\" style=\"text-align:center; padding:12px; background:#161b22; border: 1px solid #21262d\">\n                <div class=\"btn-group\" style=\"justify-content:center; flex-wrap: wrap; gap:6px; justify-content:center; margin-bottom: 8px; margin-top: 24px\">\n                    <button class=\"btn btn-primary btn-sm\" onclick=\"consoleSnapshot()\">📸 截图</button>\n                        <button class=\"btn btn-secondary btn-sm\" onclick=\"consoleRecordStop()\"> disabled\n                    </div>\n                    <div class=\"card\" style=\"text-align:center; padding:12px; background:#161b22; border: 1px solid #21262d; margin-top: 16px;\">\n                        <div class=\"btn-group\" style=\"justify-content: center; flex-wrap: wrap; gap:6px; justify-content: center; margin-bottom: 8px; margin-top: 24px\">\n                            <button class=\"btn btn-primary btn-sm\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                        <button class=\"btn btn-secondary btn-sm\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                    </div>\n                    <div class=\"card\" style=\"text-align:center; padding:12px; background:#161b22; border: 1px solid #21262d; margin-top: 16px;\">\n                        <div id=\"consoleRecordStatus\" style=\"font-size:11px;color: #8b949e; margin-top: 6px\">录制中...</div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"page\" id=\"page-observation\">\n                <h2 style=\"font-size:18px;color:#f0883e;margin:20px 0 8px\">实时叠加</h2>\n                <div class=\"console-layout\">\n                    <!-- 左: 摇杆控制 -->\n                    <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">指向控制</h3>\n                <div class=\"ptz-controls\">\n                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                    <button class=\"ptz-btn center\">●</button>\n                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                </div>\n                <div class=\"ptz-speed\">\n                    <label>速度:</label>\n                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                    <span id=\"ptzSpeedVal\">50</span>\n                </div>\n                <div style=\"display:flex;gap:8px;align-items:center;justify-content:center;margin-top:12px\">\n                    <label style=\"font-size:12px;color:#8b949e\">码流:</label>\n                    <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                        <option value=\"1\">主码流</option>\n                        <option value=\"2\" selected>子码流</option>\n                        <option value=\"3\">第三码流</option>\n                    </select>\n                </div>\n                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:12px\">\n                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                </div>\n                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:12px\">\n                    Pan: -- | Tilt: -- | Zoom: --\n                </div>\n                <!-- 预置点 -->\n                <h3 style=\"font-size:15px;color:#d29922;margin:20px 0 8px\">⭐ 预置点</h3>\n                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                        <option value=\"\">选择预置点</option>\n                    </select>\n                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存当前位置</button>\n                </div>\n                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                <!-- 跟踪控制 -->\n                <h3 style=\"font-size:15px;color:#f0883e;margin:20px 0 8px\">🛤 跟踪控制</h3>\n                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:16px\">\n                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                </div>\n                <!-- 变焦/对焦 -->\n                <h3 style=\"font-size:15px;color:#58a6ff;margin:20px 0 8px\">🔍 变焦/对焦</h3>\n                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:12px\">\n                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" ontouchstart=\"ptzZoom('in')\">🔍+ 焦距+</button>\n                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" ontouchstart=\"ptzZoom('out')\">🔍- 焦距-</button>\n                </div>\n                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:12px\">\n                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" ontouchstart=\"ptzFocus('near')\">🔧- 移</button>\n                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" ontouchstart=\"ptzFocus('far')\">🔧+ 后移</button>\n                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                        <option value=\"manual\">手动</option>\n                        <option value=\"auto\">自动</option>\n                        <option value=\"semiauto\">半自动</option>\n                    </select>\n                </div>\n            </div>\n            <!-- 中: 实时画面 + 媒体 -->\n            <div class=\"console-center\">\n                <!-- 实时画面 -->\n                <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                <!-- 媒体操作 -->\n                <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📷 媒体操作</h3>\n                <div style=\"display:flex;flex-direction:column;gap:12px;margin-bottom:16px\">\n                    <!-- 截图 -->\n                    <div class=\"card\" style=\"text-align:center\">\n                        <div class=\"card-title\">截图</div>\n                        <p style=\"color:#8b949e;font-size:12px;margin:4px 0\">抓取当前帧</p>\n                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                        <div id=\"consoleSnapshotPreview\" style=\"margin-top:8px;display:none\">\n                            <img id=\"consoleSnapshotImg\" style=\"width:100%;border-radius:6px\">\n                        </div>\n                    </div>\n                    <!-- 录像 -->\n                    <div class=\"card\" style=\"text-align:center\">\n                        <div class=\"card-title\">录像</div>\n                        <p style=\"color:#8b949e;font-size:12px;margin:4px 0\">开始/停止录像</p>\n                        <div class=\"btn-group\" style=\"justify-content:center\">\n                            <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                            <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                        </div>\n                        <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;margin-top:6px\">未录像</div>\n                    </div>\n                    <!-- Live Stack 实时叠加 -->\n                    <h3 style=\"font-size:15px;color:#58a6ff;margin:20px 0 8px\">🌟 Live Stack</h3>\n                    <div class=\"card\" style=\"text-align:center\">\n                        <div class=\"card-title\">实时叠加</div>\n                        <p style=\"color:#8b949e;font-size:11px;margin:4px 0\">边采集边叠加，降噪增亮</p>\n                        <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\n                            <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\n                            <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\n                            <button class=\" btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\n                            <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\n                            <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\n                        </div>\n                        <div style=\"font-size:12px;color:#8b949e;margin-bottom:8px\">\n                            硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\n                        </div>\n                        <div class=\"btn-group\" style=\"justify-content:center\">\n                            <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\n                            <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\n                            <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\n                        </div>\n                        <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;margin-top:6px\">叠加: 关闭</div>\n                    </div>\n                    <!-- 画面调整 -->\n                    <h3 style=\"font-size:15px;color:#d29922;margin:20px 0 8px\">🎨 画面调整</h3>\n                    <div class=\"card\">\n                        <div class=\"form-group\" style=\"margin-bottom:8px\">\n                            <label style=\"font-size:12px\">亮度</label>\n                            <div style=\"display:flex;align-items:center;gap:4px\">\n                                <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('brightness', -1)\">-</button>\n                                <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"flex:1\" onchange=\"adjustImage('brightness', this.value)\">\n                                <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('brightness', 1)\">+</button>\n                            </div>\n                        </div>\n                        <div class=\"form-group\" style=\"margin-bottom:8px\">\n                            <label style=\"font-size:12px\">对比度</label>\n                            <div style=\"display:flex;align-items:center;gap:4px\">\n                                <button class=\"带编码搜索行中被截断的输出, 最后几行显示：\n\"...[truncated]...\n< - **PTZ OSD 按钮已找到**， <button class=\"btn btn-sm btn-primary\" id=\"btnPtzOsdOn\" onclick=\"togglePtzOsd(true)\">显示</button>\n                            <button class=\"btn btn-sm btn-secondary\" id=\"btnPtzOsdOff\" onclick=\"togglePtzOsd(false)\">关闭</button>\n                        </div>\n                    </div>\n                    <div class=\"form-group\" style=\"margin-bottom:0\">\n                        <label style=\"font-size:12px\">OSD 信息显示</label>\n                        <div class=\"btn-group\">\n                            <button class=\"btn btn-sm btn-secondary\" id=\"btnInfoOsdOn\" onclick=\"toggleInfoOsd(true)\">显示</button>\n                            <button class=\"btn btn-sm btn-primary\" id=\"btnInfoOsdOff\" onclick=\"toggleInfoOsd(false)\">关闭</button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <!-- 右: 操作日志 -->\n            <div class=\"console-right\">\n                <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\n                <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto\">\n                    <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\n                        <div style=\"color:#6e7681\">等待连接...</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n            <!-- PTZ OSD 和 OSD Info 按钮已找到 -->\n\n            <!-- 但是我代码已经被截断，无法看到完整的 HTML 结构。 但我已经找到了问题：\n            2.OSD Info API 返回 HTTP 400 错误，XML 修改可能有问题\n\n            22需要对焦 +/- 按钮，前端代码已修改，添加了自动切换到手动对焦模式的功能\n\n            3. PTZ OSD 和 OSD Info 按钮已找到\n\n            4. OSD 开关逻辑正确， OSD Info API 有问题需要修复</think>\n\n新Html file，Content-Type: application/xml; charset=UTF-8\" < -d '<?xml version=\"1.0\" encoding=\"UTF-8\"?><VideoOverlay version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\"><normalizedScreenSize><normalizedScreenWidth>704</normalizedScreenWidth><normalizedScreenHeight>576</normalizedScreenHeight></normalizedScreenSize><attribute><transparent>false</transparent><flashing>false</flashing></attribute><TextOverlayList size=\"8\"></TextOverlayList><DateTimeOverlay><enabled>false</enabled><positionX>0</positionX><positionY>560</positionY><dateStyle>CHR-YYYY-MM-DD</dateStyle><timeStyle>24hour</timeStyle><displayWeek>true</displayWeek></DateTimeOverlay><channelNameOverlay><enabled>false</enabled><positionX>16</positionX><positionY>32</positionY></channelNameOverlay><fontSize>48*48</fontSize><frontColorMode>auto</frontColorMode><frontColor>000000</frontColor><alignment>customize</alignment><boundary>1</boundary></VideoOverlay>' --max-time 10 2>&1\n                </IF ($?xml.EndsWith(\"</ResponseStatus>\")) {\n                    echo \"直接PUT成功!\"\n                } ELSE {\n                    echo \"响应内容: $?$xml.Substring(0, [Math]::Min(200, $xml.Length))\n                }\n                } else {\n                    # 韥看其他信息\n                    Write-Host \"Connection failed or endpoint may not be correct\"\n                }\n            }\n        }\n\nXML 巻加正确！。ISAPI 端点可能不接受某些 `enabled` 字段被修改（比如 `TextOverlayList` 中的 `enabled` 字段)。\n\n问题在于代码中错误地遍历了修改了所有 `enabled` 字段，而不是只修改 `DateTimeOverlay` 和 `channelNameOverlay` 中的 `enabled`。\n\n让我检查 Python 生成的 XML 是否正确：我测试服务是否需要重启。先保存修改的代码再重启服务：或者直接测试 ISAPI 请求。\n\n测试代码生成的 XML 格式："},{"type":"toolCall","id":"tool-84c5934cc4d94cb0a5ada4f7a9b96c51","name":"exec","arguments":{"command":"cd C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub && python -c \"\nimport xml.etree.ElementTree as ET\n\n# Test generating XML from the original overlay XML\noriginal_xml = '''<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\"?>\n<VideoOverlay version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<normalizedScreenSize>\n<normalizedScreenWidth>704</normalizedScreenWidth>\n<normalizedScreenHeight>576</normalizedScreenHeight>\n</normalizedScreenSize>\n<attribute>\n<transparent>false</transparent>\n<flashing>false</flashing>\n</attribute>\n<TextOverlayList size=\"8\">\n</TextOverlayList>\n<DateTimeOverlay>\n<enabled>true</enabled>\n<positionX>0</positionX>\n<positionY>560</positionY>\n<dateStyle>CHR-YYYY-MM-DD</dateStyle>\n<timeStyle>24hour</timeStyle>\n<displayWeek>true</displayWeek>\n</DateTimeOverlay>\n<channelNameOverlay>\n<enabled>true</enabled>\n<positionX>16</positionX>\n<positionY>32</positionY>\n</channelNameOverlay>\n<fontSize>48*48</fontSize>\n<frontColorMode>auto</frontColorMode>\nfrontColor>000000</frontColor>\n<alignment>customize</alignment>\n<boundary>1</boundary>\n</VideoOverlay>'''\n\n# Parse and modify\nroot = ET.fromstring(original_xml)\n\nval = 'false'\n\nfor target in ['DateTimeOverlay', 'channelNameOverlay']:\n    elem = root.find(target)\n    if elem is None:\n        elem = root.find('.//{http://www.hikvision.com/ver20/XMLSchema}' + target)\n    if elem is not None:\n        continue\n    enabled_elem = elem.find('enabled')\n    if enabled_elem is None:\n            enabled_elem = elem.find('{http://www.hikvision.com/ver20/XMLSchema}enabled')\n        if enabled_elem is not None:\n            enabled_elem.text = val\n\nnew_xml = '<?xml version=\"1.0\" encoding=\"UTF-8?>' + ET.tostring(root, encoding='unicode')\nprint('Generated XML:')\nprint(new_xml)\nprint('---')\n\n# Now test the modification works - modify DateTimeOverlay enabled to false\nval = 'false'\nfor target in ['DateTimeOverlay', 'channelNameOverlay']:\n    elem = root.find(target)\n    if elem is None:\n        elem = root.find('.//{http://www.hikvision.com/ver20/XMLSchema}' + target)\n    if elem is not None:\n        continue\n    enabled_elem = elem.find('enabled')\n    if enabled_elem is None:\n        enabled_elem = elem.find('{http://www.hikvision.com/ver20/XMLSchema}enabled')\n    if enabled_elem is not None:\n            continue\n        enabled_elem.text = val\n\nnew_xml = '<?xml version=\"1.0\" encoding=\"UTF-8?>\" + ET.tostring(root, encoding='unicode')\nprint('Modified XML')\nprint(new_xml)\n\""}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":80118,"output":6973,"cacheRead":0,"cacheWrite":0,"totalTokens":87091,"cost":{"input":0.080118,"output":0.022313600000000003,"cacheRead":0,"cacheWrite":0,"total":0.1024316}},"stopReason":"toolUse","timestamp":1781186225776,"responseId":"cht000d3055@dx19eb6f906bcb9ca102"}}
