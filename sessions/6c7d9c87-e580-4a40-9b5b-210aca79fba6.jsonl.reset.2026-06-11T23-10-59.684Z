{"type":"message","id":"345c8a8d","parentId":"2e8c1e83","timestamp":"2026-06-11T18:37:04.934Z","message":{"role":"toolResult","toolCallId":"tool-840be71a0ce24b8d861f7dab4ab20962","toolName":"read","content":[{"type":"text","text":"    def zoom_in(self, speed: int = 50) -> bool:\r\n        return self.continuous_move(0, 0, speed)\r\n\r\n    def zoom_out(self, speed: int = 50) -> bool:\r\n        return self.continuous_move(0, 0, -speed)\r\n\r\n    def zoom_range_test(self) -> dict:\r\n        LOG.log(\"info\", \"ZOOM 范围测试\")\r\n        result = {\"zoom_min\": 0, \"zoom_max\": 0, \"supported\": False}\r\n        initial_pos = self.get_position()\r\n        if not initial_pos:\r\n            return result\r\n        initial_zoom = initial_pos.get(\"zoom\", 0)\r\n        result[\"zoom_min\"] = initial_zoom\r\n        result[\"zoom_max\"] = initial_zoom\r\n        self.goto_home()\r\n        time.sleep(STABILIZATION_SECONDS)\r\n\r\n        self.zoom_in(speed=50)\r\n        time.sleep(2)\r\n\n[1523 more lines in file. Use offset=1169 to continue.]"}],"isError":false,"timestamp":1781203024934}}
{"type":"message","id":"0655c3ef","parentId":"345c8a8d","timestamp":"2026-06-11T18:37:13.175Z","message":{"role":"assistant","content":[{"type":"text","text":"`zoom_out` 调用 `continuous_move(0, 0, -speed)`，zoom 参数是负数。\n\n让我检查 `continuous_move` 如何处理 zoom："},{"type":"toolCall","id":"call_ab139b83488c435cb57bb271","name":"read","arguments":{"limit":80,"offset":1062,"path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/src/core/ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":70034,"output":82,"cacheRead":0,"cacheWrite":0,"totalTokens":70116,"cost":{"input":0.070034,"output":0.00026240000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0702964}},"stopReason":"toolUse","timestamp":1781203024936,"responseId":"cht000df853@dx19eb7f93d3eb9ca102"}}
{"type":"message","id":"5edde25c","parentId":"0655c3ef","timestamp":"2026-06-11T18:37:13.186Z","message":{"role":"toolResult","toolCallId":"call_ab139b83488c435cb57bb271","toolName":"read","content":[{"type":"text","text":"    def continuous_move(self, pan: float = 0, tilt: float = 0, zoom: float = 0, focus: float = 0) -> bool:\r\n        \"\"\"连续移动 PTZ。\r\n\r\n        ISAPI 2.0 格式: panSpeed/tiltSpeed 范围 -10(left/down) 到 10(right/up),\r\n        zoomSpeed -10(out) 到 10(in), focusSpeed -10(near) 到 10(far), 0 = stop.\r\n        \"\"\"\r\n        # 将 0-100 范围映射到 -10..10 (ISAPI 2.0 规范)\r\n        pan_speed = round(pan / 10.0)\r\n        tilt_speed = round(tilt / 10.0)\r\n        zoom_speed = round(zoom / 10.0)\r\n        focus_speed = round(focus / 10.0)\r\n\r\n        # 停止移动：使用 /continuous 端点速度全0\r\n        if pan_speed == 0 and tilt_speed == 0 and zoom_speed == 0 and focus_speed == 0:\r\n            xml = '<?xml version=\"1.0\" encoding=\"UTF-8\"?>'\r\n            xml += '<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">'\r\n            xml += '<ptzSpeed>'\r\n            xml += '<pan>0</pan><tilt>0</tilt><zoom>0</zoom><focus>0</focus>'\r\n            xml += '</ptzSpeed></PTZData>'\r\n            result = self.client.put(f\"{self._ptz_base()}/continuous\", xml)\r\n            return result.status_code == 200\r\n\r\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <ptzSpeed>\r\n    <pan>{pan_speed}</pan>\r\n    <tilt>{tilt_speed}</tilt>\r\n    <zoom>{zoom_speed}</zoom>\r\n    <focus>{focus_speed}</focus>\r\n  </ptzSpeed>\r\n</PTZData>\"\"\"\r\n        result = self.client.put(f\"{self._ptz_base()}/continuous\", xml)\r\n        return result.status_code == 200\r\n\r\n    def stop_move(self) -> bool:\r\n        \"\"\"停止连续移动。\"\"\"\r\n        return self.continuous_move(0, 0, 0, 0)\r\n\r\n    def continuous_move_duration(self, pan: float, tilt: float, duration: float) -> list[dict]:\r\n        positions = []\r\n        if not self.continuous_move(pan=pan, tilt=tilt, focus=0):\r\n            return positions\r\n        start = time.time()\r\n        while time.time() - start < duration:\r\n            pos = self.get_position()\r\n            if pos:\r\n                positions.append(pos)\r\n            time.sleep(SAMPLE_INTERVAL)\r\n        self.stop_move()\r\n        return positions\r\n\r\n    def set_focus_mode(self, mode: str) -> bool:\r\n        \"\"\"设置对焦模式。\r\n\r\n        mode: 'auto', 'manual', 'semiautomatic'\r\n        \"\"\"\r\n        mode_upper = mode.upper()\r\n        endpoint = f\"/Image/channels/{self.channel}/focusConfiguration\"\r\n        xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<FocusConfiguration version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <focusStyle>{mode_upper}</focusStyle>\r\n  <focusLimited>300</focusLimited>\r\n</FocusConfiguration>'''\r\n        result = self.client.put(endpoint, xml)\r\n        return result.status_code == 200\r\n\r\n    def absolute_move(self, pan: float, tilt: float, zoom: float | None = None, speed: int = 50) -> bool:\r\n        zoom_val = f\"<absoluteZoom>{zoom}</absoluteZoom>\" if zoom is not None else \"\"\r\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <AbsoluteHigh>\r\n    <azimuth>{pan}</azimuth><elevation>{tilt}</elevation>\r\n    {zoom_val}<speed>{speed}</speed>\r\n  </AbsoluteHigh>\r\n</PTZData>\"\"\"\r\n        result = self.client.put(f\"{self._ptz_base()}/absolute\", xml)\r\n        return result.status_code == 200\r\n\r\n    def relative_move(self, pan: float, tilt: float, zoom: float = 0) -> bool:\r\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n\n[1550 more lines in file. Use offset=1142 to continue.]"}],"isError":false,"timestamp":1781203033186}}
