{"type":"message","id":"2bb1c250","parentId":"3662c76f","timestamp":"2026-06-11T16:43:16.231Z","message":{"role":"assistant","content":[{"type":"text","text":"创建 E2E 测试脚本："},{"type":"toolCall","id":"call_1af14c8216fe40ccbaa39299","name":"write","arguments":{"content":"\"\"\"\nv5.46 E2E Test - OSD & Focus Fix Verification\n\"\"\"\nimport time\nfrom playwright.sync_api import sync_playwright, expect\n\nBASE_URL = \"http://localhost:10280\"\nDEVICE_IP = \"192.168.5.72\"\n\ndef test_osd_and_focus():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context()\n        page = context.new_page()\n        \n        results = []\n        \n        # 1. Open main page\n        print(\"1. Opening main page...\")\n        page.goto(f\"{BASE_URL}/\", timeout=30000)\n        page.wait_for_timeout(2000)\n        \n        # 2. Navigate to Console page\n        print(\"2. Navigating to Console...\")\n        try:\n            console_btn = page.locator('button[data-page=\"console\"], a[data-page=\"console\"]')\n            if console_btn.count() > 0:\n                console_btn.first.click()\n                page.wait_for_timeout(2000)\n            else:\n                # Try nav link\n                page.click('text=主控台')\n                page.wait_for_timeout(2000)\n        except Exception as e:\n            print(f\"  Warning: Could not navigate to console: {e}\")\n        \n        # 3. Connect device if needed\n        print(\"3. Checking device connection...\")\n        try:\n            device_select = page.locator('#ptzDeviceSelect, #deviceSelect')\n            if device_select.count() > 0:\n                # Select device\n                device_select.first.select_option(value=DEVICE_IP)\n                page.wait_for_timeout(1000)\n                \n                # Click connect button\n                connect_btn = page.locator('button:has-text(\"连接\"), #btnConnect')\n                if connect_btn.count() > 0:\n                    connect_btn.first.click()\n                    page.wait_for_timeout(3000)\n                    print(\"  Device connected\")\n        except Exception as e:\n            print(f\"  Warning: Device connect step: {e}\")\n        \n        # 4. Test PTZ OSD toggle\n        print(\"4. Testing PTZ OSD toggle...\")\n        try:\n            ptz_osd_on = page.locator('#btnPtzOsdOn')\n            ptz_osd_off = page.locator('#btnPtzOsdOff')\n            \n            if ptz_osd_on.count() > 0 and ptz_osd_off.count() > 0:\n                # Click OFF first\n                ptz_osd_off.click()\n                page.wait_for_timeout(2000)\n                \n                # Click ON\n                ptz_osd_on.click()\n                page.wait_for_timeout(2000)\n                \n                results.append((\"PTZ OSD Toggle\", \"PASS\"))\n                print(\"  PASS: PTZ OSD toggle works\")\n            else:\n                results.append((\"PTZ OSD Toggle\", \"SKIP - buttons not found\"))\n                print(\"  SKIP: PTZ OSD buttons not found\")\n        except Exception as e:\n            results.append((\"PTZ OSD Toggle\", f\"FAIL - {e}\"))\n            print(f\"  FAIL: {e}\")\n        \n        # 5. Test OSD Info toggle\n        print(\"5. Testing OSD Info toggle...\")\n        try:\n            info_osd_on = page.locator('#btnInfoOsdOn')\n            info_osd_off = page.locator('#btnInfoOsdOff')\n            \n            if info_osd_on.count() > 0 and info_osd_off.count() > 0:\n                # Click OFF\n                info_osd_off.click()\n                page.wait_for_timeout(2000)\n                \n                # Click ON\n                info_osd_on.click()\n                page.wait_for_timeout(2000)\n                \n                results.append((\"OSD Info Toggle\", \"PASS\"))\n                print(\"  PASS: OSD Info toggle works\")\n            else:\n                results.append((\"OSD Info Toggle\", \"SKIP - buttons not found\"))\n                print(\"  SKIP: OSD Info buttons not found\")\n        except Exception as e:\n            results.append((\"OSD Info Toggle\", f\"FAIL - {e}\"))\n            print(f\"  FAIL: {e}\")\n        \n        # 6. Test Focus Mode dropdown\n        print(\"6. Testing Focus Mode dropdown...\")\n        try:\n            focus_mode = page.locator('#focusMode')\n            \n            if focus_mode.count() > 0:\n                # Select manual\n                focus_mode.first.select_option(value='manual')\n                page.wait_for_timeout(1000)\n                \n                # Select auto\n                focus_mode.first.select_option(value='auto')\n                page.wait_for_timeout(1000)\n                \n                # Back to manual for focus+/- test\n                focus_mode.first.select_option(value='manual')\n                page.wait_for_timeout(1000)\n                \n                results.append((\"Focus Mode Dropdown\", \"PASS\"))\n                print(\"  PASS: Focus mode dropdown works\")\n            else:\n                results.append((\"Focus Mode Dropdown\", \"SKIP - dropdown not found\"))\n                print(\"  SKIP: Focus mode dropdown not found\")\n        except Exception as e:\n            results.append((\"Focus Mode Dropdown\", f\"FAIL - {e}\"))\n            print(f\"  FAIL: {e}\")\n        \n        # 7. Test Focus +/- buttons (they should auto-switch to manual mode)\n        print(\"7. Testing Focus +/- buttons...\")\n        try:\n            # Find focus buttons by their onclick handlers\n            focus_near_btn = page.locator('button:has-text(\"前移\"), button[onmousedown*=\"ptzFocus(\\'near\\'\"]')\n            focus_far_btn = page.locator('button:has-text(\"后移\"), button[onmousedown*=\"ptzFocus(\\'far\\'\"]')\n            \n            if focus_near_btn.count() > 0 and focus_far_btn.count() > 0:\n                # Set to auto mode first\n                focus_mode = page.locator('#focusMode')\n                if focus_mode.count() > 0:\n                    focus_mode.first.select_option(value='auto')\n                    page.wait_for_timeout(500)\n                \n                # Click focus near - should auto-switch to manual\n                focus_near_btn.first.click()\n                page.wait_for_timeout(1500)\n                \n                # Check if mode switched to manual\n                if focus_mode.count() > 0:\n                    current_mode = focus_mode.first.input_value()\n                    if current_mode == 'manual':\n                        results.append((\"Focus Auto-Mode Switch\", \"PASS\"))\n                        print(\"  PASS: Focus mode auto-switched to manual\")\n                    else:\n                        results.append((\"Focus Auto-Mode Switch\", f\"FAIL - mode is {current_mode}\"))\n                        print(f\"  FAIL: Mode is {current_mode}, expected manual\")\n                \n                # Click focus far\n                focus_far_btn.first.click()\n                page.wait_for_timeout(1000)\n                \n                results.append((\"Focus +/- Buttons\", \"PASS\"))\n                print(\"  PASS: Focus +/- buttons work\")\n            else:\n                results.append((\"Focus +/- Buttons\", \"SKIP - buttons not found\"))\n                print(\"  SKIP: Focus +/- buttons not found\")\n        except Exception as e:\n            results.append((\"Focus +/- Buttons\", f\"FAIL - {e}\"))\n            print(f\"  FAIL: {e}\")\n        \n        # 8. Test Zoom buttons\n        print(\"8. Testing Zoom +/- buttons...\")\n        try:\n            zoom_in_btn = page.locator('button:has-text(\"焦距+\"), button[onmousedown*=\"ptzZoom(\\'in\\'\"]')\n            zoom_out_btn = page.locator('button:has-text(\"焦距-\"), button[onmousedown*=\"ptzZoom(\\'out\\'\"]')\n            \n            if zoom_in_btn.count() > 0 and zoom_out_btn.count() > 0:\n                zoom_in_btn.first.click()\n                page.wait_for_timeout(500)\n                \n                zoom_out_btn.first.click()\n                page.wait_for_timeout(500)\n                \n                results.append((\"Zoom +/- Buttons\", \"PASS\"))\n                print(\"  PASS: Zoom +/- buttons work\")\n            else:\n                results.append((\"Zoom +/- Buttons\", \"SKIP - buttons not found\"))\n                print(\"  SKIP: Zoom +/- buttons not found\")\n        except Exception as e:\n            results.append((\"Zoom +/- Buttons\", f\"FAIL - {e}\"))\n            print(f\"  FAIL: {e}\")\n        \n        browser.close()\n        \n        # Print summary\n        print(\"\\n\" + \"=\"*50)\n        print(\"TEST SUMMARY\")\n        print(\"=\"*50)\n        for name, result in results:\n            status = \"✓\" if result == \"PASS\" else (\"○\" if \"SKIP\" in result else \"✗\")\n            print(f\"  {status} {name}: {result}\")\n        \n        # Count results\n        passed = sum(1 for _, r in results if r == \"PASS\")\n        failed = sum(1 for _, r in results if r.startswith(\"FAIL\"))\n        skipped = sum(1 for _, r in results if \"SKIP\" in r)\n        \n        print(f\"\\nTotal: {passed} passed, {failed} failed, {skipped} skipped\")\n        return failed == 0\n\nif __name__ == \"__main__\":\n    success = test_osd_and_focus()\n    exit(0 if success else 1)\n","path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_v546.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":102440,"output":1943,"cacheRead":0,"cacheWrite":0,"totalTokens":104383,"cost":{"input":0.10243999999999999,"output":0.0062176,"cacheRead":0,"cacheWrite":0,"total":0.1086576}},"stopReason":"toolUse","timestamp":1781196157488,"responseId":"cht000dc93c@dx19eb7908266b894142"}}
