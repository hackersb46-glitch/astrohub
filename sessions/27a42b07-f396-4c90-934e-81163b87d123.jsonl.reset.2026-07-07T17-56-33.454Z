 78                     except ValueError:\n+ 79                         pass\n+ 80                     break\n+ 81     except:\n+ 82         pass\n+ 83     return 1.0  # 无慢快门，返回1倍\n  70 \n- 71         import xml.etree.ElementTree as ET\n- 72         root = ET.fromstring(resp.xml)\n  73 \n- 74         min_limit = None\n- 75         max_limit = None\n- 76 \n- 77         for elem in root.iter():\n- 78             tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n- 79             if tag in (\"minShutterLevelLimit\", \"MinShutterLevelLimit\"):\n- 80                 min_limit = (elem.text or \"\").strip()\n- 81             elif tag in (\"maxShutterLevelLimit\", \"MaxShutterLevelLimit\"):\n- 82                 max_limit = (elem.text or \"\").strip()\n- 83 \n- 84         if min_limit and max_limit and min_limit != max_limit:\n- 85             min_time = _parse_shutter_level(min_limit)\n- 86             max_time = _parse_shutter_level(max_limit)\n- 87             if min_time > 0 and max_time > min_time:\n- 88                 return max_time - min_time\n- 89 \n- 90         return 0.0\n- 91     except Exception:\n- 92         return 0.0\n- 93 \n- 94 \n  95 def calc_stable_delay(client) -> float:\n- 96     \"\"\"计算操作后的稳定延时。\n- 97 \n- 98     公式: 固定1.5s + 1/25 × 慢快门倍率（如果有）\n+ 87     \"\"\"计算操作后的稳定延时 - v8.64:\n+ 88     等待时间 = 固定1.5s + 快门时间\n+ 89     快门时间 = 基础1/25 × 慢快门倍率\n  99     \"\"\"\n-100     slow_extra = get_exposure_time(client)\n-101     return 1.5 + slow_extra\n+ 91     shutter_factor = get_exposure_time(client)  # v8.64: 倍率1~N\n+ 92     base_shutter = 1.0 / 25.0  # 0.04s\n+ 93     shutter_time = base_shutter * shutter_factor\n+ 94     return 1.5 + shutter_time","firstChangedLine":1},"isError":false,"timestamp":1783443461965}}
