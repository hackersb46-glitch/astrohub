{"type":"message","id":"f5b5ee06","parentId":"1673e752","timestamp":"2026-07-07T17:30:16.469Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_f18c6bfbb4d14ef0885c4abc","name":"edit","arguments":{"edits":[{"newText":"// 对焦模式切换:显示/隐藏对应控件\nfunction onFocusModeChange(mode) {\n    var moveControls = document.getElementById('focusMoveControls');\n    var localControls = document.getElementById('focusLocalControls');\n\n    if (mode === 'manual') {\n        if (moveControls) moveControls.style.display = 'block';\n        if (localControls) localControls.style.display = 'none';\n        setFocusMode('manual');\n        stopFocusTimer();\n        var toggle = document.getElementById('focusTimerToggle');\n        if (toggle) toggle.checked = false;\n    } else if (mode === 'local') {\n        if (moveControls) moveControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'block';\n    } else {\n        // 自动\n        if (moveControls) moveControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'none';\n        setFocusMode('auto');\n        stopFocusTimer();\n        var toggle = document.getElementById('focusTimerToggle');\n        if (toggle) toggle.checked = false;\n    }\n}","oldText":"// 对焦模式切换:显示/隐藏对应控件\nfunction onFocusModeChange(mode) {\n    var moveControls = document.getElementById('focusMoveControls');\n    var localControls = document.getElementById('focusLocalControls');\n\n    if (mode === 'manual') {\n        if (moveControls) moveControls.style.display = 'block';\n        if (localControls) localControls.style.display = 'none';\n        setFocusMode('manual');\n        // v8.63: 切手动时停止定时器\n        stopFocusTimer();\n        var toggle = document.getElementById('focusTimerToggle');\n        if (toggle) toggle.checked = false;\n        // v8.64: 恢复主控台轮询\n        startPtzImagePoll();\n    } else if (mode === 'local') {\n        if (moveControls) moveControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'block';\n        // v8.63: 局部模式下不需要停止定时器\n        // v8.64: 局部模式暂停主控台轮询\n        stopPtzImagePoll();\n    } else {\n        // 自动\n        if (moveControls) moveControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'none';\n        setFocusMode('auto');\n        // v8.63: 切自动时停止定时器\n        stopFocusTimer();\n        var toggle = document.getElementById('focusTimerToggle');\n        if (toggle) toggle.checked = false;\n        // v8.64: 恢复主控台轮询\n        startPtzImagePoll();\n    }\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":136142,"output":697,"cacheRead":0,"cacheWrite":0,"totalTokens":136839,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783445363815,"responseId":"cht000d1c08@dx19f3da13ec629bb503"}}
