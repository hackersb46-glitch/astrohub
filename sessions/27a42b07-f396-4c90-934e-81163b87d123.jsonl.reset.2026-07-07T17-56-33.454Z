{"type":"message","id":"65d427f9","parentId":"944190a1","timestamp":"2026-07-07T17:50:08.568Z","message":{"role":"toolResult","toolCallId":"call_270da0fcde1c470b80b7c28c","toolName":"read","content":[{"type":"text","text":"}\r\n\r\n// ==================== v7.0: PTZ 坐标 + 图像参数实时刷新 ====================\r\nvar _ptzImagePollInterval = null;\r\n\r\nfunction startPtzImagePoll() {\r\n    if (_ptzImagePollInterval) return; // 已在运行\r\n\r\n    _ptzImagePollInterval = setInterval(function() {\r\n        if (!window.connectedDevice || !window.connectedDevice.ip) return;\r\n\r\n        var dev = window.connectedDevice.ip;\r\n\r\n        // 1. PTZ 坐标 - v7.55: 分别更新三个元素\r\n        apiGet('/api/v1/ptz/' + dev + '/position').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var panEl = document.getElementById('ptzPan');\r\n                var tiltEl = document.getElementById('ptzTilt');\r\n                var zoomEl = document.getElementById('ptzZoom');\r\n                if (panEl) panEl.textContent = r.data.pan || 0;\r\n                if (tiltEl) tiltEl.textContent = r.data.tilt || 0;\r\n                if (zoomEl) zoomEl.textContent = r.data.zoom || 0;\r\n            }\r\n        }).catch(function(e) {});\r\n\r\n        // 2. 白平衡 R/B - v7.55: 只显示数值\r\n        apiGet('/api/v1/ptz/' + dev + '/image/whitebalance').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var wb = r.data;\r\n                var rEl = document.getElementById('ptzWbR');\r\n                var bEl = document.getElementById('ptzWbB');\r\n                if (rEl) rEl.textContent = wb.red_gain || '--';\r\n                if (bEl) bEl.textContent = wb.blue_gain || '--';\r\n            }\r\n        }).catch(function(e) {});\r\n\r\n        // 3. 降噪空域/时域 - v7.55: 只显示数值\r\n        apiGet('/api/v1/ptz/' + dev + '/image/noisereduce').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var nr = r.data;\r\n                var sEl = document.getElementById('ptzDnrSpatial');\r\n                var tEl = document.getElementById('ptzDnrTemporal');\r\n                var spatialVal = (nr.spatial_level !== undefined && nr.spatial_level !== null) ? nr.spatial_level : '--';\r\n                var temporalVal = (nr.temporal_level !== undefined && nr.temporal_level !== null) ? nr.temporal_level : '--';\r\n                if (sEl) sEl.textContent = spatialVal;\r\n                if (tEl) tEl.textContent = temporalVal;\r\n            }\r\n        }).catch(function(e) {});\r\n\r\n        // 4. 光圈 - v8.58: 显示F-num格式 (如: F2.0表示f/2.0)\r\n        apiGet('/api/v1/ptz/' + dev + '/image/iris').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var ir = r.data;\r\n                var iEl = document.getElementById('ptzIris');\r\n                if (iEl) {\r\n                    var level = ir.current_level;\r\n                    if (level !== undefined && level !== null) {\r\n                        iEl.textContent = 'F' + (level / 100).toFixed(1);  // 如: 200 → F2.0\r\n                    } else {\r\n                        iEl.textContent = '--';\r\n                    }\r\n                }\r\n            }\r\n        }).catch(function(e) {});\r\n\r\n        // 5. 快门 - v7.55: 只显示数值\r\n        apiGet('/api/v1/ptz/' + dev + '/image/shutter').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var sh = r.data;\r\n                var sEl = document.getElementById('ptzShutter');\r\n                if (sEl) sEl.textContent = sh.current_level || '--';\r\n            }\r\n        }).catch(function(e) {});\r\n    }, 1000);\r\n}\r\n\r\nfunction stopPtzImagePoll() {\r\n    if (_ptzImagePollInterval) {\r\n        clearInterval(_ptzImagePollInterval);\r\n        _ptzImagePollInterval = null;\r\n\n[38 more lines in file. Use offset=2065 to continue.]"}],"isError":false,"timestamp":1783446608568}}
{"type":"message","id":"3afc25a5","parentId":"65d427f9","timestamp":"2026-07-07T17:50:22.645Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_6d9e8b13b71e4401bb4bac0d","name":"read","arguments":{"limit":100,"offset":250,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\controlpanel\\whitebalance.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":148508,"output":48,"cacheRead":0,"cacheWrite":0,"totalTokens":148556,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783446608570,"responseId":"cht000d1076@dx19f3db3bdce2872503"}}
{"type":"message","id":"96c5fc02","parentId":"3afc25a5","timestamp":"2026-07-07T17:50:22.654Z","message":{"role":"toolResult","toolCallId":"call_6d9e8b13b71e4401bb4bac0d","toolName":"read","content":[{"type":"text","text":"        self._interrupted = True\n    \n    async def run(self):\n        \"\"\"运行白平衡搜索，产生SSE事件\"\"\"\n        \n        # v8.64: 快门延迟只读一次\n        self._stable_delay = await asyncio.to_thread(calc_stable_delay, self.client)\n        \n        # 1. 读取当前模式+增益（v8.62）\n        current_mode, current_red, current_blue = await asyncio.to_thread(self._read_wb_status)\n        \n        # 2. 切换手动白平衡模式\n        ok = await asyncio.to_thread(self._set_wb_mode, \"manual\")\n        if not ok:\n            yield f\"data: {json.dumps({'type': 'warning', 'message': '切换手动白平衡失败'})}\\n\\n\"\n        \n        # 3. 初始值判断\n        if current_mode == \"auto\":\n            # 自动模式 → 从50/50起步，写入设备\n            current_red, current_blue = 50, 50\n            await asyncio.to_thread(self._set_wb_gains, 50, 50)\n            yield f\"data: {json.dumps({'type': 'info', 'message': '初始值: R=50, B=50'})}\\n\\n\"\n        else:\n            # locked/manual 模式 → 从当前值开始（已由上次锁定/设置完成）\n            yield f\"data: {json.dumps({'type': 'info', 'message': f'初始值: R={current_red}, B={current_blue}'})}\\n\\n\"\n        \n        # 4. 初始截图（v8.62 保持原有逻辑）\n        bgr, info = await asyncio.to_thread(self._capture)\n        if bgr is None:\n            yield f\"data: {json.dumps({'type': 'error', 'message': '截图失败'})}\\n\\n\"\n            return\n        \n        crop_msg = f\"X={info['crop_x1']}~{info['crop_x2']}, Y={info['crop_y1']}~{info['crop_y2']}, 共{info['pixels']}像素\"\n        yield f\"data: {json.dumps({'type': 'start', 'crop': crop_msg, 'initial_red': current_red, 'initial_blue': current_blue})}\\n\\n\"\n        \n        # 4. 白平衡循环\n        wb = IterativeWB(current_red, current_blue)\n        step_count = 0\n        \n        while True:\n            # v8.41: 检查中断\n            if self._interrupted:\n                # v8.62: 从 IterativeWB 实例获取 best 值\n                best_red = wb._best_red\n                best_blue = wb._best_blue\n                # 写入best值并锁定\n                await asyncio.to_thread(self._set_wb_gains, best_red, best_blue)\n                await asyncio.sleep(self._stable_delay)\n                await asyncio.to_thread(self._set_wb_mode, \"locked\")\n                \n                yield f\"data: {json.dumps({\n                    'type': 'interrupt',\n                    'message': '用户停止',\n                    'final_red': best_red,\n                    'final_blue': best_blue\n                })}\\n\\n\"\n                break\n            \n            cmd = wb.step(bgr)\n            step_count += 1\n            \n            # 发送步骤事件\n            event = {\n                \"type\": \"wb\",\n                \"step\": step_count,\n                \"stage\": cmd.get(\"stage\", \"\"),\n                \"step_size\": cmd.get(\"step_size\", 0),\n                \"red_gain\": cmd[\"red_gain\"],\n                \"blue_gain\": cmd[\"blue_gain\"],\n                \"r_avg\": cmd.get(\"r_avg\", 0),\n                \"g_avg\": cmd.get(\"g_avg\", 0),\n                \"b_avg\": cmd.get(\"b_avg\", 0),\n                \"delta\": cmd.get(\"delta\", 0),\n                \"best_delta\": cmd.get(\"best_delta\", 0),\n                \"message\": cmd[\"message\"]\n            }\n            yield f\"data: {json.dumps(event)}\\n\\n\"\n            \n            # 停止？\n            if cmd[\"action\"] == \"stop\":\n                # 应用最终增益\n                await asyncio.to_thread(self._set_wb_gains, cmd[\"red_gain\"], cmd[\"blue_gain\"])\n                await asyncio.sleep(self._stable_delay)\n                \n                # 验证\n                bgr2, _ = await asyncio.to_thread(self._capture)\n                verified_delta = cmd.get(\"best_delta\", cmd.get(\"delta\", 0))\n                \n                if bgr2 is not None:\n                    stats = _rgb_stats(bgr2)\n                    r_sum, g_sum, b_sum = stats[\"r_sum\"], stats[\"g_sum\"], stats[\"b_sum\"]\n                    verified_delta = abs(r_sum / max(1, g_sum) - 1.0) + abs(b_sum / max(1, g_sum) - 1.0)\n                \n                # 切换锁定白平衡模式\n                await asyncio.to_thread(self._set_wb_mode, \"locked\")\n                \n                yield f\"data: {json.dumps({'type': 'done', 'final_red': cmd['red_gain'], 'final_blue': cmd['blue_gain'], 'best_delta': round(cmd.get('best_delta', 0), 4), 'verified_delta': round(verified_delta, 4), 'total_steps': step_count, 'message': '切换锁定白平衡'})}\\n\\n\"\n                break\n            \n            # 应用增益\n\n[12 more lines in file. Use offset=350 to continue.]"}],"isError":false,"timestamp":1783446622654}}
