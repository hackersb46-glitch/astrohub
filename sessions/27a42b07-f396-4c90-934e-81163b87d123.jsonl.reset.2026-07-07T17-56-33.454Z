{"type":"message","id":"d13f958c","parentId":"1a11395e","timestamp":"2026-07-07T09:29:29.878Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_ef9a51e560c94ee79f984f86","name":"read","arguments":{"limit":50,"offset":1000,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}},{"type":"toolCall","id":"call_5de6ce25c9e4413e92bd2d26","name":"read","arguments":{"limit":50,"offset":1250,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}},{"type":"toolCall","id":"call_9f6992a3f8324aadb0f7b869","name":"read","arguments":{"limit":60,"offset":1340,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":32706,"output":140,"cacheRead":0,"cacheWrite":0,"totalTokens":32846,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783416560536,"responseId":"cht000db9a8@dx19f3be92a3c2872503"}}
{"type":"message","id":"e380fe15","parentId":"d13f958c","timestamp":"2026-07-07T09:29:29.895Z","message":{"role":"toolResult","toolCallId":"call_ef9a51e560c94ee79f984f86","toolName":"read","content":[{"type":"text","text":"\r\n// 加载白平衡\r\nfunction loadWhiteBalance(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/whitebalance').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var wb = r.data;\r\n            deviceImageParams.whiteBalance = wb;\r\n\r\n            var wbModeSelect = document.getElementById('wbMode');\r\n            if (wbModeSelect) {\r\n                // 根据设备返回的模式设置下拉菜单\r\n                if (wb.mode === 'manual') {\r\n                    wbModeSelect.value = 'manual';\r\n                } else {\r\n                    wbModeSelect.value = 'auto';\r\n                }\r\n                // 触发显示/隐藏逻辑\r\n                onWbModeChange(wbModeSelect.value);\r\n            }\r\n\r\n            // 更新 R/B 滑动条\r\n            var wbRed = document.getElementById('wbRed');\r\n            var wbBlue = document.getElementById('wbBlue');\r\n            var wbRedVal = document.getElementById('wbRedVal');\r\n            var wbBlueVal = document.getElementById('wbBlueVal');\r\n\r\n            if (wbRed && wb.red_gain !== undefined) {\r\n                wbRed.value = wb.red_gain;\r\n                if (wbRedVal) wbRedVal.textContent = wb.red_gain;\r\n            }\r\n            if (wbBlue && wb.blue_gain !== undefined) {\r\n                wbBlue.value = wb.blue_gain;\r\n                if (wbBlueVal) wbBlueVal.textContent = wb.blue_gain;\r\n            }\r\n\r\n            // 设置范围\r\n            if (wb.min !== undefined && wb.max !== undefined) {\r\n                if (wbRed) { wbRed.min = wb.min; wbRed.max = wb.max; }\r\n                if (wbBlue) { wbBlue.min = wb.min; wbBlue.max = wb.max; }\r\n            }\r\n\r\n            // 只有手动模式时 R/B 滑动条才可用\r\n            var isManual = wb.mode === 'manual';\r\n            if (wbRed) wbRed.disabled = !isManual;\r\n            if (wbBlue) wbBlue.disabled = !isManual;\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[WB] Load failed:', e);\r\n    });\r\n}\r\n\n[1026 more lines in file. Use offset=1050 to continue.]"}],"isError":false,"timestamp":1783416569895}}
{"type":"message","id":"3612a14d","parentId":"e380fe15","timestamp":"2026-07-07T09:29:29.895Z","message":{"role":"toolResult","toolCallId":"call_5de6ce25c9e4413e92bd2d26","toolName":"read","content":[{"type":"text","text":"// 白平衡模式切换:显示/隐藏对应控件\r\nfunction onWbModeChange(mode) {\r\n    var manualControls = document.getElementById('wbManualControls');\r\n    var localControls = document.getElementById('wbLocalControls');\r\n    var wbRed = document.getElementById('wbRed');\r\n    var wbBlue = document.getElementById('wbBlue');\r\n\r\n    if (mode === 'manual') {\r\n        if (manualControls) manualControls.style.display = 'flex';\r\n        if (localControls) localControls.style.display = 'none';\r\n        if (wbRed) wbRed.disabled = false;\r\n        if (wbBlue) wbBlue.disabled = false;\r\n        setWhiteBalanceMode('manual');\r\n    } else if (mode === 'local') {\r\n        if (manualControls) manualControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'block';\r\n        if (wbRed) wbRed.disabled = true;\r\n        if (wbBlue) wbBlue.disabled = true;\r\n        // v8.39: 局部模式自动切换到手动模式\r\n        setWhiteBalanceMode('manual');\r\n    } else {\r\n        // 自动\r\n        if (manualControls) manualControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'none';\r\n        if (wbRed) wbRed.disabled = true;\r\n        if (wbBlue) wbBlue.disabled = true;\r\n        setWhiteBalanceMode('auto');\r\n    }\r\n}\r\n\r\n// 停止自动白平衡\r\nfunction stopAutoWhiteBalance() {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    if (typeof operationLog === 'function') operationLog('用户停止', 'warning');\r\n    apiPost('/api/v1/vision/whitebalance-stop', {}).then(function(r) {\r\n        if (r && r.success) {\r\n            showToast('success', '已停止白平衡搜索');\r\n        }\r\n    }).catch(function(e) {\r\n        showToast('error', '停止失败');\r\n    });\r\n    // 恢复按钮状态\r\n    var stopBtn = document.getElementById('btnWbLocalStop');\r\n    var confirmBtn = document.getElementById('btnWbTimerConfirm');\r\n    var selectBtn = document.getElementById('btnWbRegionSelect');\r\n    if (stopBtn) stopBtn.disabled = true;\r\n    if (confirmBtn) { confirmBtn.disabled = true; confirmBtn.style.opacity = '0.5'; }\r\n    if (selectBtn) { selectBtn.style.opacity = '1'; }\r\n    selectBtn.style.opacity = '1';\r\n\n[776 more lines in file. Use offset=1300 to continue.]"}],"isError":false,"timestamp":1783416569895}}
{"type":"message","id":"68e288d0","parentId":"3612a14d","timestamp":"2026-07-07T09:29:29.896Z","message":{"role":"toolResult","toolCallId":"call_9f6992a3f8324aadb0f7b869","toolName":"read","content":[{"type":"text","text":"    if (confirmBtn) { confirmBtn.disabled = true; confirmBtn.style.opacity = '0.5'; }\r\n    if (selectBtn) { selectBtn.style.opacity = '1'; }\r\n    selectBtn.style.opacity = '1';\r\n    stopFocusTimer();\r\n}\r\n\r\n// v8.41: 白平衡定时器\r\nfunction updateWbTimerInput(input) {\r\n    input.value = input.value.replace(/[^0-9]/g, '');\r\n}\r\n\r\nfunction updateFocusTimerInput(input) {\r\n    input.value = input.value.replace(/[^0-9]/g, '');\r\n}\r\n\r\nfunction toggleWbTimer() {\r\n    var toggle = document.getElementById('wbTimerToggle');\r\n    var input = document.getElementById('wbTimerInput');\r\n    if (!toggle || !input) return;\r\n    var minutes = parseInt(input.value) || 0;\r\n    if (minutes <= 0) {\r\n        toggle.checked = false;\r\n        showToast('warning', '请输入大于0的分钟数');\r\n        return;\r\n    }\r\n    if (toggle.checked) {\r\n        var region = localStorage.getItem('region_whitebalance');\r\n        if (!region) {\r\n            toggle.checked = false;\r\n            showToast('warning', '请先框选区域');\r\n            return;\r\n        }\r\n        stopWbTimer();\r\n        wbTimerSeconds = minutes * 60;\r\n        updateWbTimerDisplay();\r\n        wbTimerId = setInterval(function() {\r\n            wbTimerSeconds--;\r\n            updateWbTimerDisplay();\r\n            if (wbTimerSeconds <= 0) {\r\n                clearInterval(wbTimerId);\r\n                wbTimerId = null;\r\n                executeScheduledSearch('whitebalance');\r\n            }\r\n        }, 1000);\r\n        showToast('success', '白平衡定时已启动: ' + minutes + '分钟');\r\n    } else {\r\n        stopWbTimer();\r\n        showToast('info', '白平衡定时已关闭');\r\n    }\r\n}\r\n\r\nfunction toggleFocusTimer() {\r\n    var toggle = document.getElementById('focusTimerToggle');\r\n    var input = document.getElementById('focusTimerInput');\r\n    if (!toggle || !input) return;\r\n    var minutes = parseInt(input.value) || 0;\r\n    if (minutes <= 0) {\r\n        toggle.checked = false;\r\n        showToast('warning', '请输入大于0的分钟数');\r\n        return;\r\n\n[676 more lines in file. Use offset=1400 to continue.]"}],"isError":false,"timestamp":1783416569895}}
{"type":"message","id":"2698ca32","parentId":"68e288d0","timestamp":"2026-07-07T09:29:39.328Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_97cdedd73fa54369b33eed16","name":"read","arguments":{"limit":80,"offset":1440,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}},{"type":"toolCall","id":"call_a90f08f26d44472a959c7c7f","name":"read","arguments":{"limit":60,"offset":1525,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":34334,"output":94,"cacheRead":0,"cacheWrite":0,"totalTokens":34428,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783416569896,"responseId":"cht000d4b8f@dx19f3be9516829c2503"}}
{"type":"message","id":"d5552db6","parentId":"2698ca32","timestamp":"2026-07-07T09:29:39.345Z","message":{"role":"toolResult","toolCallId":"call_97cdedd73fa54369b33eed16","toolName":"read","content":[{"type":"text","text":"    display.textContent = '(' + m + ':' + (s < 10 ? '0' : '') + s + ')';\r\n}\r\n\r\n// v8.40: 定时触发执行（使用保存的选区）\r\nfunction executeScheduledSearch(mode) {\r\n    var regionStr = localStorage.getItem('region_' + mode);\r\n    if (!regionStr) {\r\n        showToast('warning', (mode === 'whitebalance' ? '白平衡' : '对焦') + '无保存选区');\r\n        return;\r\n    }\r\n    var dev = window.connectedDevice;\r\n    if (!dev || !dev.ip) { showToast('error', '未连接设备'); return; }\r\n    var region = JSON.parse(regionStr);\r\n    var endpoint = mode === 'whitebalance' ? '/api/v1/vision/whitebalance-search' : '/api/v1/vision/focus-search';\r\n    var label = mode === 'whitebalance' ? '白平衡' : '对焦';\r\n    showToast('info', label + '定时执行中...');\r\n    operationLog('── ' + label + '定时执行 ──', 'info');\r\n    var body = JSON.stringify({ x: region.x, y: region.y, w: region.w, h: region.h });\r\n    fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })\r\n        .then(function(resp) {\r\n            if (!resp.ok) throw new Error('HTTP ' + resp.status);\r\n            var reader = resp.body.getReader();\r\n            var decoder = new TextDecoder();\r\n            var buf = '';\r\n            function pump() {\r\n                return reader.read().then(function(r) {\r\n                    if (r.done) return;\r\n                    buf += decoder.decode(r.value, { stream: true });\r\n                    var parts = buf.split('\\n\\n');\r\n                    buf = parts.pop();\r\n                    for (var i = 0; i < parts.length; i++) {\r\n                        var line = parts[i];\r\n                        if (!line.startsWith('data: ')) continue;\r\n                        try {\r\n                            var ev = JSON.parse(line.slice(6));\r\n                            if (ev.type === 'wb' || ev.type === 'focus') {\r\n                                operationLog('调整 #' + ev.step + ': ' + ev.stage + ' R=' + ev.red_gain + ' B=' + ev.blue_gain + ' Δ=' + ev.delta, 'info');\r\n                            } else if (ev.type === 'done') {\r\n                                operationLog('── ' + label + '完成: R=' + ev.final_red + ' B=' + ev.final_blue + ' (' + ev.total_steps + '步) ──', 'success');\r\n                            } else if (ev.type === 'error') {\r\n                                operationLog(label + '错误: ' + ev.message, 'error');\r\n                            }\r\n                        } catch (e) {}\r\n                    }\r\n                    return pump();\r\n                });\r\n            }\r\n            return pump();\r\n        })\r\n        .then(function() {\r\n            // 执行完成后，重新启动定时器\r\n            if (mode === 'whitebalance' && wbTimerId === null) {\r\n                var minutes = parseInt(document.getElementById('wbTimerInput').value) || 0;\r\n                if (minutes > 0) {\r\n                    wbTimerSeconds = minutes * 60;\r\n                    updateWbTimerDisplay();\r\n                    wbTimerId = setInterval(function() {\r\n                        wbTimerSeconds--;\r\n                        updateWbTimerDisplay();\r\n                        if (wbTimerSeconds <= 0) {\r\n                            clearInterval(wbTimerId);\r\n                            wbTimerId = null;\r\n                            executeScheduledSearch('whitebalance');\r\n                        }\r\n                    }, 1000);\r\n                }\r\n            }\r\n            if (mode === 'focus' && focusTimerId === null) {\r\n                var minutes = parseInt(document.getElementById('focusTimerInput').value) || 0;\r\n                if (minutes > 0) {\r\n                    focusTimerSeconds = minutes * 60;\r\n                    updateFocusTimerDisplay();\r\n                    focusTimerId = setInterval(function() {\r\n                        focusTimerSeconds--;\r\n                        updateFocusTimerDisplay();\r\n                        if (focusTimerSeconds <= 0) {\r\n                            clearInterval(focusTimerId);\r\n                            focusTimerId = null;\r\n                            executeScheduledSearch('focus');\r\n                        }\r\n\n[556 more lines in file. Use offset=1520 to continue.]"}],"isError":false,"timestamp":1783416579345}}
{"type":"message","id":"61e5ab74","parentId":"d5552db6","timestamp":"2026-07-07T09:29:39.346Z","message":{"role":"toolResult","toolCallId":"call_a90f08f26d44472a959c7c7f","toolName":"read","content":[{"type":"text","text":"            showToast('error', label + '定时执行失败: ' + e.message);\r\n        });\r\n}\r\nfunction setWhiteBalanceMode(mode) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: mode })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '白平衡: ' + (mode === 'auto' ? '自动' : '手动'));\r\n                if (typeof operationLog === 'function') operationLog('白平衡: ' + (mode === 'auto' ? '自动' : '手动'), 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置白平衡增益 R/B\r\nfunction setWhiteBalanceGain(channel, value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    // 更新显示\r\n    if (channel === 'red') {\r\n        var el = document.getElementById('wbRedVal');\r\n        if (el) el.textContent = value;\r\n    } else {\r\n        var el = document.getElementById('wbBlueVal');\r\n        if (el) el.textContent = value;\r\n    }\r\n\r\n    var key = channel === 'red' ? 'red_gain' : 'blue_gain';\r\n    var label = channel === 'red' ? 'R (红增益)' : 'B (蓝增益)';\r\n\r\n    // v6.56: 只发送增益值,不发送模式(模式已通过下拉菜单切换)\r\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', label + ': ' + value);\r\n                if (typeof operationLog === 'function') operationLog('白平衡' + label + ': ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置降噪\r\nfunction setNoiseReduce(type, value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    var el = document.getElementById(type === 'spatial' ? 'dnrSpatialVal' : 'dnrTemporalVal');\r\n    if (el) el.textContent = value;\r\n\r\n    var key = type === 'spatial' ? 'spatial_level' : 'temporal_level';\r\n    var label = type === 'spatial' ? '空域降噪' : '时域降噪';\r\n\r\n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', { [key]: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', label + ': ' + value);\r\n                if (typeof operationLog === 'function') operationLog(label + ': ' + value, 'success');\r\n            }\r\n\n[491 more lines in file. Use offset=1585 to continue.]"}],"isError":false,"timestamp":1783416579345}}
