{"type":"message","id":"b9915042","parentId":"d12428d1","timestamp":"2026-07-07T17:40:13.726Z","message":{"role":"assistant","content":[{"type":"text","text":"`index.html`（手动框选入口）改好了。现在改 `console.html` 的 `executeScheduledSearch`（定时入口）："},{"type":"toolCall","id":"call_c6724225a84a43798600d298","name":"edit","arguments":{"edits":[{"newText":"// v8.65: 定时触发执行（使用保存的选区）- 流程开始暂停轮询，结束恢复\nfunction executeScheduledSearch(mode) {\n    var regionStr = localStorage.getItem('region_' + mode);\n    if (!regionStr) {\n        showToast('warning', (mode === 'whitebalance' ? '白平衡' : '对焦') + '无保存选区');\n        return;\n    }\n    var dev = window.connectedDevice;\n    if (!dev || !dev.ip) { showToast('error', '未连接设备'); return; }\n    var region = JSON.parse(regionStr);\n    var endpoint = mode === 'whitebalance' ? '/api/v1/vision/whitebalance-search' : '/api/v1/vision/focus-search';\n    var label = mode === 'whitebalance' ? '白平衡' : '对焦';\n    showToast('info', label + '定时执行中...');\n    operationLog('── ' + label + '定时执行 ──', 'info');\n\n    // v8.65: 流程开始，暂停主控台轮询\n    stopPtzImagePoll();\n\n    var body = JSON.stringify({ x: region.x, y: region.y, w: region.w, h: region.h });\n    fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })","oldText":"// v8.40: 定时触发执行（使用保存的选区）\nfunction executeScheduledSearch(mode) {\n    var regionStr = localStorage.getItem('region_' + mode);\n    if (!regionStr) {\n        showToast('warning', (mode === 'whitebalance' ? '白平衡' : '对焦') + '无保存选区');\n        return;\n    }\n    var dev = window.connectedDevice;\n    if (!dev || !dev.ip) { showToast('error', '未连接设备'); return; }\n    var region = JSON.parse(regionStr);\n    var endpoint = mode === 'whitebalance' ? '/api/v1/vision/whitebalance-search' : '/api/v1/vision/focus-search';\n    var label = mode === 'whitebalance' ? '白平衡' : '对焦';\n    showToast('info', label + '定时执行中...');\n    operationLog('── ' + label + '定时执行 ──', 'info');\n    var body = JSON.stringify({ x: region.x, y: region.y, w: region.w, h: region.h });\n    fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":145210,"output":674,"cacheRead":0,"cacheWrite":0,"totalTokens":145884,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783445975949,"responseId":"cht000d0636@dx19f3daa55a72871503"}}
