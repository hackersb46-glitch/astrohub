{"type":"message","id":"7511afcf","parentId":"2d022a7d","timestamp":"2026-07-07T17:51:14.406Z","message":{"role":"toolResult","toolCallId":"call_ba5bd57f70c34d87ae596423","toolName":"read","content":[{"type":"text","text":"            await asyncio.to_thread(self._set_wb_gains, cmd[\"red_gain\"], cmd[\"blue_gain\"])\n            await asyncio.sleep(self._stable_delay)  # 等待稳定\n            \n            # 重新截图\n            bgr, _ = await asyncio.to_thread(self._capture)\n            if bgr is None:\n                yield f\"data: {json.dumps({'type': 'error', 'message': '截图失败'})}\\n\\n\"\n                break\n        \n        # 5. 清理\n        await asyncio.to_thread(self._cleanup_func, \"WB\", self.device_ip)\n        yield f\"data: {json.dumps({'type': 'cleanup'})}\\n\\n\""}],"isError":false,"timestamp":1783446674406}}
