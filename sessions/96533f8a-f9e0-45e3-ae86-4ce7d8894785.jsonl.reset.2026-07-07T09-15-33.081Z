{"type":"message","id":"d5c4716c","parentId":"156bc393","timestamp":"2026-07-06T23:21:52.144Z","message":{"role":"toolResult","toolCallId":"call_8918a27a72c84f1c869ad6ce","toolName":"read","content":[{"type":"text","text":"\"\"\"AstroHub v8.37 - 白平衡模块\n\n包含：\n- IterativeWB: 纯算法迭代搜索\n- WhiteBalanceSearcher: 执行层（截图、设置增益、验证、SSE事件）\n\"\"\"\n\nimport json\nimport asyncio\nfrom .region_base import _rgb_stats, calc_stable_delay\n\n\n# ─────────────────────────────────────────────\n# 纯算法层：迭代搜索\n# ─────────────────────────────────────────────\n\nclass IterativeWB:\n    \"\"\"白平衡迭代搜索器 - R/B 独立调整\n    \n    状态：粗调(±5) → 中调(±2) → 精调(±1)\n    每步评估 [双通道, 仅R, 仅B] 三个候选，选 delta 最小。\n    全程追踪 best_gains + best_delta，结束时回滚到最佳。\n    \n    输入：BGR图像\n    输出：dict（action, red_gain, blue_gain, delta, message等）\n    \n    不涉及任何设备操作，纯粹数学逻辑。\n    \"\"\"\n\n    def __init__(self, current_red=100, current_blue=100):\n        self._stage = 0\n        self._stage_steps = [5, 2, 1]\n        self._stage_min = [6, 3, 0]\n        self._tolerances = [0.70, 0.80, 0.95]\n        self._current_red = current_red\n        self._current_blue = current_blue\n        self._no_improve = 0\n        self._stage_step_count = 0\n        self._fine_steps = 0\n        self._best_red = current_red\n        self._best_blue = current_blue\n        self._best_delta = 999.0\n        self._best_step = 0\n        self._step_count = 0\n\n    def _eval(self, r_sum, g_sum, b_sum, red, blue) -> float:\n        \"\"\"评估RGB平衡程度\"\"\"\n        if g_sum < 1: g_sum = 1\n        ar = max(1, r_sum) * red / max(1, self._current_red)\n        ab = max(1, b_sum) * blue / max(1, self._current_blue)\n        return abs(ar / g_sum - 1.0) + abs(ab / g_sum - 1.0)\n\n    def step(self, bgr) -> dict:\n        \"\"\"输入BGR图像，返回下一步动作\"\"\"\n        stats = _rgb_stats(bgr)\n        n = stats[\"n\"]\n        r_sum, g_sum, b_sum = stats[\"r_sum\"], stats[\"g_sum\"], stats[\"b_sum\"]\n\n        self._step_count += 1\n        self._stage_step_count += 1\n        step = self._stage_steps[self._stage]\n\n        # 计算候选增益\n        cr = self._current_red + max(-step, min(step, int(g_sum / max(1, r_sum) * self._current_red) - self._current_red))\n        cb = self._current_blue + max(-step, min(step, int(g_sum / max(1, b_sum) * self._current_blue) - self._current_blue))\n        cr = max(1, min(255, cr))\n        cb = max(1, min(255, cb))\n\n        # 候选列表 (- stage 2: R/B独立调整)\n        if self._stage == 2:\n            # 精调阶段：全部R/B独立，无\"both\"候选\n            candidates = [(cr, self._current_blue, \"red\"), (self._current_red, cb, \"blue\")]\n        else:\n            candidates = [(cr, cb, \"both\"), (cr, self._current_blue, \"red\"), (self._current_red, cb, \"blue\")]\n\n        # 选最优候选\n        best_cand = None\n        best_d = 999.0\n        for r, b, label in candidates:\n            d = self._eval(r_sum, g_sum, b_sum, r, b)\n            if d < best_d:\n                best_d = d\n                best_cand = (r, b, label)\n\n        new_red, new_blue, direction = best_cand\n        new_red = int(new_red)\n        new_blue = int(new_blue)\n\n        # 计算当前delta\n        actual = abs(r_sum / max(1, g_sum) - 1.0) + abs(b_sum / max(1, g_sum) - 1.0)\n\n        # 更新best\n        prev_best = self._best_delta\n        if actual < self._best_delta:\n            self._best_delta = actual\n            self._best_red = self._current_red\n            self._best_blue = self._current_blue\n            self._best_step = self._step_count\n\n        # 无改善计数\n        tolerance = self._tolerances[self._stage]\n        if actual >= prev_best * tolerance:\n            self._no_improve += 1\n        else:\n            self._no_improve = 0\n\n        stage_name = [\"coarse\", \"medium\", \"fine\"][self._stage]\n        min_steps = self._stage_min[self._stage]\n\n        # 阶段升级\n        if self._stage < 2 and self._stage_step_count >= min_steps and self._no_improve >= 2:\n            self._stage += 1\n            self._stage_step_count = 0\n            self._no_improve = 0\n            # 进入精调时重置best追踪，避免粗调阶段的best覆盖精调结果\n            if self._stage == 2:\n                self._best_delta = 999.0\n                self._best_red = self._current_red\n                self._best_blue = self._current_blue\n                self._best_step = self._step_count\n            new_stage = [\"medium\", \"fine\"][self._stage - 1]\n            return {\n                \"action\": \"continue\",\n                \"stage\": new_stage,\n                \"step_size\": self._stage_steps[self._stage],\n                \"red_gain\": self._current_red, \"blue_gain\": self._current_blue,\n                \"r_avg\": round(stats[\"r_avg\"], 1), \"g_avg\": round(stats[\"g_avg\"], 1), \"b_avg\": round(stats[\"b_avg\"], 1),\n                \"delta\": round(actual, 4), \"best_delta\": round(self._best_delta, 4), \"pixels\": n,\n                \"message\": f\"进入{'中等' if self._stage == 1 else '精细'}调校 (step=±{self._stage_steps[self._stage]})\"\n            }\n\n        # 精调阶段处理\n        if self._stage == 2:\n            self._fine_steps += 1\n            if self._no_improve >= 3 or self._fine_steps >= 10:\n                rollback = (self._best_red != self._current_red or self._best_blue != self._current_blue)\n                self._current_red = self._best_red\n                self._current_blue = self._best_blue\n                return {\n                    \"action\": \"stop\",\n                    \"stage\": \"done\",\n                    \"step_size\": 0,\n                    \"red_gain\": self._best_red, \"blue_gain\": self._best_blue,\n                    \"r_avg\": round(stats[\"r_avg\"], 1), \"g_avg\": round(stats[\"g_avg\"], 1), \"b_avg\": round(stats[\"b_avg\"], 1),\n                    \"delta\": round(self._best_delta, 4), \"best_delta\": round(self._best_delta, 4), \"pixels\": n,\n                    \"message\": f\"白平衡完成 {'(回滚至最佳)' if rollback else '(已达最佳)'} 第{self._best_step}步\"\n                }\n\n        # 应用新增益\n        self._current_red = new_red\n\n[194 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1783380112144}}
{"type":"message","id":"d0c05c9f","parentId":"d5c4716c","timestamp":"2026-07-06T23:22:29.914Z","message":{"role":"assistant","content":[{"type":"text","text":"我现在完全理解了白平衡的代码结构。需要对精调阶段（stage 2）进行修改：\n\n**当前精调逻辑**：\n- 固定 step=1\n- `_fine_steps` 计数，最多10步\n- `_no_improve >= 3` 或 `_fine_steps >= 10` → 停止\n\n**需要改为**：\n- delta >= 200 → step=5\n- 10 <= delta < 200 → step=2\n- delta < 10 → step=1（上限30次）\n- 5步和2步模式：无次数限制\n- 1步模式：最多30次\n\n用 Python 脚本精确替换精调阶段逻辑："},{"type":"toolCall","id":"call_f3e02c04bc364568a54ee893","name":"write","arguments":{"content":"\"\"\"Fix whitebalance.py: replace fine stage logic with 3-tier dynamic step\"\"\"\n\npath = r\"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\controlpanel\\whitebalance.py\"\nwith open(path, \"r\", encoding=\"utf-8\") as f:\n    content = f.read()\n\n# Fix 1: Replace __init__ to add new fields\nold_init = \"\"\"    def __init__(self, current_red=100, current_blue=100):\n        self._stage = 0\n        self._stage_steps = [5, 2, 1]\n        self._stage_min = [6, 3, 0]\n        self._tolerances = [0.70, 0.80, 0.95]\n        self._current_red = current_red\n        self._current_blue = current_blue\n        self._no_improve = 0\n        self._stage_step_count = 0\n        self._fine_steps = 0\n        self._best_red = current_red\n        self._best_blue = current_blue\n        self._best_delta = 999.0\n        self._best_step = 0\n        self._step_count = 0\"\"\"\n\nnew_init = \"\"\"    def __init__(self, current_red=100, current_blue=100):\n        self._stage = 0\n        self._stage_steps = [5, 2, 1]\n        self._stage_min = [6, 3, 0]\n        self._tolerances = [0.70, 0.80, 0.95]\n        self._current_red = current_red\n        self._current_blue = current_blue\n        self._no_improve = 0\n        self._stage_step_count = 0\n        self._fine_steps = 0          # 1步模式计数器（上限30）\n        self._fine_step_mode = 0      # 当前精调步长：5/2/1\n        self._best_red = current_red\n        self._best_blue = current_blue\n        self._best_delta = 999.0\n        self._best_step = 0\n        self._step_count = 0\"\"\"\n\nif old_init not in content:\n    print(\"ERROR: old __init__ not found\")\n    exit(1)\ncontent = content.replace(old_init, new_init)\nprint(\"OK: __init__ updated\")\n\n# Fix 2: Replace the fine stage processing block\n# Find the old fine stage block\nold_fine_start = \"        # 精调阶段处理\\n        if self._stage == 2:\"\nold_fine_end = \"        # 应用新增益\"\nif old_fine_start not in content:\n    print(\"ERROR: old fine block not found\")\n    exit(1)\n\nfine_start_idx = content.find(old_fine_start)\napply_idx = content.find(old_fine_end, fine_start_idx)\nif apply_idx == -1:\n    print(\"ERROR: apply section not found\")\n    exit(1)\n\nold_fine_block = content[fine_start_idx:apply_idx]\n\nnew_fine_block = \"\"\"        # 精调阶段处理：3档动态步进\n        if self._stage == 2:\n            # 根据 delta 选择步长\n            if actual >= 200:\n                step = 5\n                self._fine_step_mode = 5\n            elif actual >= 10:\n                step = 2\n                self._fine_step_mode = 2\n            else:\n                step = 1\n                self._fine_step_mode = 1\n                self._fine_steps += 1\n                if self._fine_steps >= 30:\n                    rollback = (self._best_red != self._current_red or self._best_blue != self._current_blue)\n                    self._current_red = self._best_red\n                    self._current_blue = self._best_blue\n                    return {\n                        \"action\": \"stop\",\n                        \"stage\": \"done\",\n                        \"step_size\": 0,\n                        \"red_gain\": self._best_red, \"blue_gain\": self._best_blue,\n                        \"r_avg\": round(stats[\"r_avg\"], 1), \"g_avg\": round(stats[\"g_avg\"], 1), \"b_avg\": round(stats[\"b_avg\"], 1),\n                        \"delta\": round(self._best_delta, 4), \"best_delta\": round(self._best_delta, 4), \"pixels\": n,\n                        \"message\": f\"白平衡完成(1步精调{self._fine_steps}次上限) {'(回滚至最佳)' if rollback else '(已达最佳)'} 第{self._best_step}步\"\n                    }\n            # 5步和2步模式：无次数限制，继续搜索\n            # 更新 stage_steps[2] 为当前动态步长\n            self._stage_steps[2] = step\n\n\"\"\"\n\ncontent = content[:fine_start_idx] + new_fine_block + content[apply_idx:]\nprint(\"OK: fine stage replaced\")\n\n# Fix 3: The step variable in step() should use the dynamic value for stage 2\n# Currently: step = self._stage_steps[self._stage]\n# This is fine because we update self._stage_steps[2] in the fine block above\n# But the fine block runs AFTER candidates are computed with the OLD step\n# We need to move the dynamic step selection BEFORE candidate computation\n\n# Actually, let me re-examine the flow:\n# 1. step = self._stage_steps[self._stage]  (line ~step calculation)\n# 2. Compute candidates with step\n# 3. Select best candidate\n# 4. Compute actual delta\n# 5. Update best\n# 6. Check stage upgrade\n# 7. Fine stage processing (our new code)\n#\n# The problem: in step 1, step is read from _stage_steps[2] which is 1 (initial value)\n# Our new code in step 7 updates _stage_steps[2] for the NEXT iteration\n# But the current iteration already used step=1\n#\n# This is actually OK! The first time entering stage 2, the step is 1 (from _stage_steps[2])\n# Then our code computes the actual delta and sets _stage_steps[2] for the next iteration\n# Next iteration uses the updated step value\n#\n# Wait, but the initial _stage_steps[2] is 1. When we first enter stage 2, we use step=1.\n# If delta >= 200, we should use step=5, but we already used step=1 for this iteration.\n# This is a problem.\n#\n# Fix: compute dynamic step at the BEGINNING of step() for stage 2\n# But we need the actual delta first, which requires _rgb_stats\n#\n# Better approach: compute actual delta early, then set step dynamically\n\n# Let me restructure: move the \"compute actual delta\" before the step selection\n# Find \"step = self._stage_steps[self._stage]\" and replace with dynamic logic\n\nold_step_select = \"\"\"        self._step_count += 1\n        self._stage_step_count += 1\n        step = self._stage_steps[self._stage]\n\n        # 计算候选增益\"\"\"\n\nnew_step_select = \"\"\"        self._step_count += 1\n        self._stage_step_count += 1\n\n        # 计算当前delta（用于精调阶段动态步长）\n        actual = abs(r_sum / max(1, g_sum) - 1.0) + abs(b_sum / max(1, g_sum) - 1.0)\n\n        # 精调阶段：根据delta动态选择步长\n        if self._stage == 2:\n            if actual >= 200:\n                step = 5\n            elif actual >= 10:\n                step = 2\n            else:\n                step = 1\n            self._stage_steps[2] = step\n        else:\n            step = self._stage_steps[self._stage]\n\n        # 计算候选增益\"\"\"\n\nif old_step_select not in content:\n    print(\"ERROR: old step_select not found\")\n    exit(1)\ncontent = content.replace(old_step_select, new_step_select)\nprint(\"OK: step selection updated\")\n\n# Fix 4: Remove the duplicate \"actual\" computation later in the code\nold_actual = \"\"\"        # 计算当前delta\n        actual = abs(r_sum / max(1, g_sum) - 1.0) + abs(b_sum / max(1, g_sum) - 1.0)\"\"\"\n\nnew_actual = \"\"\"        # actual 已在上方计算\"\"\"\n\nif old_actual not in content:\n    print(\"ERROR: old actual computation not found\")\n    exit(1)\ncontent = content.replace(old_actual, new_actual)\nprint(\"OK: duplicate actual removed\")\n\n# Fix 5: Remove the old fine_steps increment in the fine block\n# (we already handle it in the new fine block)\n# Actually, our new fine block already replaces the old one, so this should be fine\n\n# Fix 6: Remove _fine_steps increment from the old fine block\n# The old code had \"self._fine_steps += 1\" in the fine block\n# Our new code only increments _fine_steps when step==1\n# This is correct\n\n# Fix 7: Update the fine block to remove _fine_steps increment for non-1-step modes\n# Our new fine block already handles this correctly\n\nwith open(path, \"w\", encoding=\"utf-8\") as f:\n    f.write(content)\n\nprint(\"DONE: whitebalance.py updated\")\n","path":"astrohub/_fix_whitebalance.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":61453,"output":2200,"cacheRead":0,"cacheWrite":0,"totalTokens":63653,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783380112146,"responseId":"cht000dd691@dx19f39bd076c2872503"}}
