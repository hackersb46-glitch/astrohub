{"type":"message","id":"c4ae9b4b","parentId":"1ad4ec28","timestamp":"2026-07-07T09:14:05.098Z","message":{"role":"toolResult","toolCallId":"call_9979f3abdb2f44a4a72957b6","toolName":"read","content":[{"type":"text","text":"        return;\r\n    }\r\n\r\n    var exposureValues = deviceFunctionData.functions.exposure_mode.opt_values;\r\n    if (!exposureValues || !Array.isArray(exposureValues) || exposureValues.length === 0) {\r\n        console.warn('[Exposure] exposure_mode not supported');\r\n        var select = document.getElementById('exposureMode');\r\n        if (select) {\r\n            select.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            select.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n\r\n    // 填充选项\r\n    var select = document.getElementById('exposureMode');\r\n    if (select) {\r\n        select.innerHTML = '';\r\n        select.disabled = false;\r\n\r\n        exposureValues.forEach(function(p) {\r\n            var opt = document.createElement('option');\r\n            opt.value = p;\r\n            // 中文标签\r\n            var labelMap = {\r\n                'manual': '手动',\r\n                'auto': '自动',\r\n                'IrisFirst': '光圈优先',\r\n                'ShutterFirst': '快门优先'\r\n            };\r\n            opt.textContent = labelMap[p] || p;\r\n            select.appendChild(opt);\r\n        });\r\n    }\r\n\r\n    // 获取当前值\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            if (select && r.data.mode) {\r\n                select.value = r.data.mode;\r\n\n[331 more lines in file. Use offset=1745 to continue.]"}],"isError":false,"timestamp":1783415645098}}
