{"type":"message","id":"f455459a","parentId":"634046e4","timestamp":"2026-06-14T03:17:37.340Z","message":{"role":"assistant","content":[{"type":"text","text":"服务启动中。让我创建测试脚本："},{"type":"toolCall","id":"tool-e39a68cfe0c84e3182ce20b17ea21463","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_v703():\n    results = []\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        page.goto('http://localhost:10280')\n        time.sleep(4)\n        \n        print('\\n=== 1. Version Check ===')\n        version = page.locator('.version').text_content()\n        results.append(('Version', version == 'v7.03', version))\n        \n        print('\\n=== 2. Console Page ===')\n        page.click('text=主控台')\n        time.sleep(2)\n        \n        # 检查降噪显示（应该显示数值，包括 0）\n        dnr_temporal = page.locator('#ptzDnrTemporal').text_content()\n        temporal_val = dnr_temporal.split(':')[-1].strip() if ':' in dnr_temporal else dnr_temporal\n        results.append(('Temporal DNR Shows Value', temporal_val == '0' or temporal_val.isdigit(), f'value={temporal_val}'))\n        \n        # 检查提示框是否居中\n        warning = page.locator('#consoleWarning')\n        if warning.count() > 0:\n            warning_style = warning.evaluate('el => el.style.position')\n            results.append(('Warning Position Fixed', warning_style == 'fixed', f'position={warning_style}'))\n        \n        print('\\n=== 3. Exposure Manual Mode ===')\n        # 点击画面控制展开\n        page.click('#imageControlSection .collapsible-header')\n        time.sleep(1)\n        \n        # 设置为手动模式\n        exposure_select = page.locator('#exposureMode')\n        exposure_select.select_option('manual')\n        time.sleep(2)\n        \n        # 检查快门/光圈/增益是否启用\n        shutter_disabled = page.locator('#shutterSpeed').evaluate('el => el.disabled')\n        iris_disabled = page.locator('#irisLevel').evaluate('el => el.disabled')\n        gain_disabled = page.locator('#gainLevel').evaluate('el => el.disabled')\n        \n        results.append(('Shutter Enabled in Manual', not shutter_disabled, f'disabled={shutter_disabled}'))\n        results.append(('Iris Enabled in Manual', not iris_disabled, f'disabled={iris_disabled}'))\n        results.append(('Gain Enabled in Manual', not gain_disabled, f'disabled={gain_disabled}'))\n        \n        # 检查增益控制是否存在\n        gain_slider = page.locator('#gainLevel')\n        results.append(('Gain Slider Exists', gain_slider.count() > 0, f'count={gain_slider.count()}'))\n        \n        if gain_slider.count() > 0:\n            gain_value = gain_slider.evaluate('el => el.value')\n            results.append(('Gain Value Loaded', True, f'value={gain_value}'))\n        \n        print('\\n=== 4. Test Shutter/Iris/Gain Settings ===')\n        # 设置快门\n        shutter_select = page.locator('#shutterSpeed')\n        shutter_select.select_option('1/60')\n        time.sleep(1)\n        \n        # 设置光圈\n        iris_select = page.locator('#irisLevel')\n        iris_select.select_option('1600')\n        time.sleep(1)\n        \n        # 设置增益\n        gain_slider = page.locator('#gainLevel')\n        gain_slider.fill('50')\n        time.sleep(1)\n        \n        results.append(('Manual Exposure Settings Applied', True, 'shutter=1/60, iris=1600, gain=50'))\n        \n        print('\\n=== 5. Restore Auto Mode ===')\n        exposure_select.select_option('auto')\n        time.sleep(2)\n        \n        # 检查快门/光圈/增益是否禁用\n        shutter_disabled_auto = page.locator('#shutterSpeed').evaluate('el => el.disabled')\n        iris_disabled_auto = page.locator('#irisLevel').evaluate('el => el.disabled')\n        gain_disabled_auto = page.locator('#gainLevel').evaluate('el => el.disabled')\n        \n        results.append(('Shutter Disabled in Auto', shutter_disabled_auto, f'disabled={shutter_disabled_auto}'))\n        results.append(('Iris Disabled in Auto', iris_disabled_auto, f'disabled={iris_disabled_auto}'))\n        results.append(('Gain Disabled in Auto', gain_disabled_auto, f'disabled={gain_disabled_auto}'))\n        \n        browser.close()\n    \n    # 输出结果\n    print('\\n' + '='*60)\n    print('v7.03 E2E Test Results')\n    print('='*60)\n    passed = 0\n    failed = 0\n    for name, success, detail in results:\n        status = 'PASS' if success else 'FAIL'\n        if success:\n            passed += 1\n        else:\n            failed += 1\n        print(f'[{status}] {name}: {detail}')\n    \n    print('='*60)\n    print(f'Total: {passed} passed, {failed} failed')\n    print('='*60)\n    \n    return failed == 0\n\nif __name__ == '__main__':\n    success = test_v703()\n    exit(0 if success else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_v703.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":137384,"output":1148,"cacheRead":0,"cacheWrite":0,"totalTokens":138532,"cost":{"input":0.137384,"output":0.0036736000000000004,"cacheRead":0,"cacheWrite":0,"total":0.1410576}},"stopReason":"toolUse","timestamp":1781407020507,"responseId":"cht000d2dd4@dx19ec42215e7b828232"}}
