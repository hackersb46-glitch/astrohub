{"type":"message","id":"2927e42b","parentId":"cc9b07f2","timestamp":"2026-06-14T10:43:37.098Z","message":{"role":"assistant","content":[{"type":"text","text":"让我直接测试 ISAPI 端点获取快门/光圈的能力信息："},{"type":"toolCall","id":"call_bded5aacf1fd4e15846c25de","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n获取快门/光圈 ISAPI 能力信息\n\"\"\"\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport xml.etree.ElementTree as ET\n\nBASE_URL = \"http://192.168.5.72\"\nAUTH = HTTPDigestAuth('admin', 'Nftw1357')\n\nprint(\"=\" * 60)\nprint(\"获取快门/光圈 ISAPI 能力信息\")\nprint(\"=\" * 60)\n\n# 1. 获取 Shutter 完整响应\nprint(\"\\n1. GET /ISAPI/Image/channels/1/Shutter\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'完整响应:\\n{resp.text}')\n\n# 解析所有字段\nroot = ET.fromstring(resp.text)\nprint(\"\\n解析所有字段:\")\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if elem.text and elem.text.strip():\n        print(f'  {tag}: {elem.text}')\n\n# 2. 获取 Iris 完整响应\nprint(\"\\n2. GET /ISAPI/Image/channels/1/Iris\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Iris', auth=AUTH, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'完整响应:\\n{resp.text}')\n\nroot = ET.fromstring(resp.text)\nprint(\"\\n解析所有字段:\")\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if elem.text and elem.text.strip():\n        print(f'  {tag}: {elem.text}')\n\n# 3. 尝试获取 capabilities 端点\nprint(\"\\n3. 尝试 capabilities 端点\")\nendpoints = [\n    '/ISAPI/Image/channels/1/Shutter/capabilities',\n    '/ISAPI/Image/channels/1/capabilities',\n    '/ISAPI/Image/capabilities',\n    '/ISAPI/System/capabilities',\n]\n\nfor ep in endpoints:\n    try:\n        resp = requests.get(f'{BASE_URL}{ep}', auth=AUTH, timeout=5)\n        print(f'  {ep}: {resp.status_code}')\n        if resp.status_code == 200:\n            print(f'    响应: {resp.text[:200]}')\n    except Exception as e:\n        print(f'  {ep}: 错误 - {e}')\n\n# 4. 获取 Exposure 完整响应\nprint(\"\\n4. GET /ISAPI/Image/channels/1/exposure\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', auth=AUTH, timeout=5)\nprint(f'完整响应:\\n{resp.text}')\n\nroot = ET.fromstring(resp.text)\nprint(\"\\n解析所有字段:\")\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if elem.text and elem.text.strip():\n        print(f'  {tag}: {elem.text}')\n\nprint(\"\\n\" + \"=\" * 60)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_isapi_capabilities.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":126297,"output":745,"cacheRead":0,"cacheWrite":0,"totalTokens":127042,"cost":{"input":0.126297,"output":0.0023840000000000003,"cacheRead":0,"cacheWrite":0,"total":0.128681}},"stopReason":"toolUse","timestamp":1781433801917,"responseId":"cht000d451e@dx19ec5ba9e49b85f582"}}
