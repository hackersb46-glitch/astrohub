{"type":"message","id":"a46c6f66","parentId":"df5356b5","timestamp":"2026-06-14T12:43:10.535Z","message":{"role":"assistant","content":[{"type":"text","text":"设备已连接。现在断开并测试："},{"type":"toolCall","id":"call_984d6de777274f29b3192ced","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"测试断开连接后控件禁用状态 v2\"\"\"\nimport asyncio\nimport requests\nfrom playwright.async_api import async_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\nasync def test_controls_disabled_v2():\n    \"\"\"测试断开后增益、OSD、PTZ 控件是否禁用\"\"\"\n    \n    print(\"=\" * 60)\n    print(\"测试：断开连接后控件禁用状态 v2\")\n    print(\"=\" * 60)\n    \n    # 1. 先断开设备\n    print(\"\\n[步骤 1] 断开设备\")\n    resp = requests.post(f\"{BASE_URL}/api/v1/devices/192.168.5.72/disconnect\")\n    print(f\"断开结果: {resp.json().get('message')}\")\n    \n    # 等待状态更新\n    await asyncio.sleep(1)\n    \n    # 2. 打开页面检查\n    print(\"\\n[步骤 2] 打开页面检查控件状态\")\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        page = await browser.new_page()\n        \n        # 打开主页\n        await page.goto(BASE_URL)\n        await asyncio.sleep(2)\n        \n        # 切换到主控台页面\n        await page.click('[data-page=\"console\"]')\n        await asyncio.sleep(1)\n        \n        # 检查控件状态\n        print(\"\\n[检查] 断开后控件状态\")\n        \n        # 检查增益控件\n        gain_el = await page.query_selector('#gainLevel')\n        if gain_el:\n            gain_disabled = await gain_el.get_attribute('disabled')\n            print(f\"增益控件 disabled: {gain_disabled}\")\n        else:\n            print(\"增益控件未找到\")\n        \n        # 检查 OSD 控件\n        info_osd = await page.query_selector('#infoOsdSwitch')\n        if info_osd:\n            osd_disabled = await info_osd.get_attribute('disabled')\n            print(f\"OSD 控件 disabled: {osd_disabled}\")\n        \n        # 检查 PTZ 按钮\n        ptz_btn = await page.query_selector('.ptz-btn')\n        if ptz_btn:\n            ptz_disabled = await ptz_btn.get_attribute('disabled')\n            print(f\"PTZ 按钮 disabled: {ptz_disabled}\")\n        \n        # 截图\n        await page.screenshot(path='test_controls_after_disconnect.png')\n        print(\"截图: test_controls_after_disconnect.png\")\n        \n        await browser.close()\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试完成\")\n    print(\"=\" * 60)\n\nif __name__ == \"__main__\":\n    asyncio.run(test_controls_disabled_v2())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_controls_disabled_v2.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":87348,"output":632,"cacheRead":0,"cacheWrite":0,"totalTokens":87980,"cost":{"input":0.087348,"output":0.0020224,"cacheRead":0,"cacheWrite":0,"total":0.08937039999999999}},"stopReason":"toolUse","timestamp":1781440970584,"responseId":"cht000deccc@dx19ec6280e0cb87f702"}}
