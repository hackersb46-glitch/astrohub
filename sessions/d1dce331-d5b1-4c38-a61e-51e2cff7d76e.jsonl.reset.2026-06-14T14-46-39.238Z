{"type":"message","id":"3ad3f578","parentId":"54209013","timestamp":"2026-06-14T03:04:02.497Z","message":{"role":"assistant","content":[{"type":"text","text":"--- -- (2)   增加 Gain (增益) 设置\n在 (1. 埥加速 /                 |\n                                 快门                                                                                                                                                                           (3) 将提示框放到页面最中间\n                ............................. (5) 断开连接后 WASM 覆盖层\n                    ........................... (4) 手动曝光：增益控制\n                    `曝光模式: 手动`\n                    `手动`\n                        `快门 (下拉)\n                        `光圈 (下拉)\n                        `增益 (滑块)\n                    ................................................................                                <!-- WASM 覆盖层 -->\n                    ............................. (6) 实时画面区域 -->\n                    <div id=\"wasm-disconnected-overlay\" style=\"position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;z-index:9999;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px\">\n                        var overlay = document.createElement('div');\n                        overlay.id = 'wasm-disconnected-overlay';\n                        overlay.innerHTML = '请连接设备';\n                        container.style.position = 'relative';\n                        container.appendChild(overlay);\n                    }\n                </ </div>\n            </ catch(e) { console.warn('[WASM] logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = '';\n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n            ...\n        }\n    }\n\n    function wasmLogout() {\n        // v7.01: 强制停止播放和登出，不依赖状态变量\n        try {\n            // v7.01: 强制停止播放，不管状态\n            try {\n                WebVideoCtrl.I_Stop();\n            } catch(stopErr) { \n                console.warn('[WASM] I_Stop error:', stopErr);\n            }\n            \n            // 强制登出\n            if (g_szDeviceIdentify2) {\n                try {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                } catch(logoutErr) {\n                        console.warn('[WASM] I_Logout error:', logoutErr);\n                    }\n            }\n            \n            // v7.01: 确保 WASM 容器存在并添加覆盖层\n            var container = document.getElementById('divPlugin');\n            if (container) {\n                // 移除旧的覆盖层\n                var oldOverlay = document.getElementById('wasm-disconnected-overlay');\n                if (oldOverlay) oldOverlay.remove();\n                \n                // v7.01: 先确保容器可见\n                container.style.display = 'block';\n                container.style.position = 'relative';\n                \n                // 创建灰色覆盖层(使用更高的 z-index 覆盖 WASM 内容)\n                var overlay = document.createElement('div');\n                overlay.id = 'wasm-disconnected-overlay';\n                overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;z-index:9999;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px';\n                overlay.innerHTML = '设备已断开';\n                container.appendChild(overlay);\n                console.log('[WASM] Overlay created on disconnect');\n            } else {\n                console.warn('[WASM] divPlugin container not found');\n            }\n        } catch(e) { console.warn('WASM logout error:', e) }\n        \n        // v7.01: 强制重置状态\n        g_bLoggedIn2 = false;\n        g_szDeviceIdentify2 = '';\n        g_bPlaying2 = false;\n        setLoginStatus('已登出', '#8b949e');\n        var loginBtn = document.getElementById('login-btn');\n        if (loginBtn) loginBtn.textContent = '登录';\n        ...\n        // v6.12: 更新 WASM 状态\n        if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n    }\n    function clickLogin2() {\n        console.log('[CLICKLOGIN2] Called');\n        if (typeof ptzLog === 'function') ptzLog('WASM SDK 登录开始...', 'debug');\n        \n        // v6.43: 检查是否已播放成功，避免重复设置 connecting\n        if (g_bPlaying2) {\n            console.log('[CLICKLOGIN2] Already playing, skip');\n            return;\n        }\n        ...\n        // 更新 WASM 状态为连接中\n        if (window.updateWasmStatus) window.updateWasmStatus('connecting');\n        \n        if (!window.connectedDevice || !window.connectedDevice.ip) {\n            console.log('[WASM SDK] No device connected');\n            if (typeof ptzLog === 'function') ptzLog('未连接设备，无法登录', 'warning');\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n            return;\n        }\n        console.log('[CLICKLOGIN2] Device IP: ' + window.connectedDevice.ip);\n        if (typeof ptzLog === 'function') ptzLog('连接设备: ' + window.connectedDevice.ip, 'info');\n        var szIP = window.connectedDevice.ip;\n        var szPort = window.connectedDevice.port || 80;\n        var szUsername = window.connectedDevice.username || 'admin';\n        var szPassword = window.connectedDevice.password || '';\n        g_szDeviceIdentify2 = szIP + '_' + szPort;\n        console.log('[WASM SDK] Login: ' + szIP + ':' + szPort);\n        \n        // 博客方案:I_Login\n        WebVideoCtrl.I_Login(szIP, 1, szPort, szUsername, szPassword, {\n            success: function(xmlDoc) {\n                g_bLoggedIn2 = true;\n                g_szDeviceIdentify2 = szIP + '_' + szPort;\n                console.log('[WASM SDK] Login success: ' + g_szDeviceIdentify2);\n                if (typeof ptzLog === 'function') ptzLog(szIP + ' 登录成功!', 'success');\n                if (window.showToast) window.showToast('success', '设备已连接: ' + szIP);\n                \n                // v7.0: 移除灰色覆盖层\n                var overlay = document.getElementById('wasm-disconnected-overlay');\n                if (overlay) overlay.remove();\n                ...\n        // 更新 WASM 状态为已连接\n        if (window.updateWasmStatus) window.updateWasmStatus('connected');\n                ...\n        error: function(status, xmlDoc) {\n            console.error('[WASM SDK] Login failed:', status);\n            if (typeof ptzLog === 'function') ptzLog('登录失败: ' + status, 'error');\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }\n    });\n}\n    function getChannelInfo() {\n        var szDeviceIdentify = g_szDeviceIdentify2;\n        console.log('[WASM SDK] getChannelInfo ' + szDeviceIdentify);\n        var promise1 = new Promise((resolve) => {\n            WebVideoCtrl.I_GetAnalogChannelInfo(szDeviceIdentify, {\n                async: true,\n                success: function(xmlDoc) {\n                    console.log('[WASM SDK] 获取模拟通道成功');\n                    if (typeof ptzLog === 'function') ptzLog(szDeviceIdentify + ' 获取模拟通道成功!', 'info');\n                    var channels = [];\n                    var nodeList = xmlDoc.getElementsByTagName('VideoInputChannel');\n                    for (var i = 0; i < nodeList.length; i++) {\n                        var id = nodeList[i].getElementsByTagName('id')[0]?.textContent || (i + 1);\n                        var name = nodeList[i].getElementsByTagName('name')[0]?.textContent || ('通道' + id);\n                        channels.push({ id: parseInt(id), name: name });\n                    }\n                    g_iChannelList = channels;\n                    g_iChannelID = channels.length > 0 ? channels[0].id : 1;\n                    console.log('[WASM SDK] Channels:', channels, 'Using ID:', g_iChannelID);\n                    resolve();\n                },\n                error: function(status, xmlDoc) {\n                    console.log('[WASM SDK] 获取模拟通道失败:', status);\n                    if (typeof ptzLog === 'function') ptzLog(szDeviceIdentify + ' 获取模拟通道失败!', 'warning');\n                    g_iChannelID = 1;\n                    resolve();\n                }\n            });\n        });\n        \n        var promise2 = new Promise((resolve) => {\n            WebVideoCtrl.I_GetDigitalChannelInfo(szDeviceIdentify, {\n                async: true,\n                success: function(xmlDoc) {\n                    console.log('[WASM SDK] 获取数字通道成功');\n                    resolve();\n                },\n                error: function(status, xmlDoc) {\n                    console.log('[WASM SDK] 获取数字通道失败:', status);\n                    resolve();\n                }\n            });\n        });\n        \n        var promise3 = new Promise((resolve) => {\n            WebVideoCtrl.I_GetZeroChannelInfo(szDeviceIdentify, {\n                async: true,\n                success: function(xmlDoc) {\n                    console.log('[WASM SDK] 获取零通道成功');\n                    resolve();\n                },\n                error: function(status, xmlDoc) {\n                    console.log('[WASM SDK] 获取零通道失败:', status);\n                    resolve();\n                }\n            });\n        });\n        \n        return Promise.all([promise1, promise2, promise3]);\n    }\n    ...\n    // 切换码流\n    function changeStreamType(streamType) {\n        console.log('[changeStreamType] streamType=' + streamType);\n        var parsedType = parseInt(streamType, 10);\n        \n        // 先停止当前播放\n        if (g_bPlaying2 && g_szDeviceIdentify2) {\n            try {\n                WebVideoCtrl.I_Stop({\n                    iWndIndex: 0,\n                    success: function() {\n                        console.log('[changeStreamType] stopped, starting new stream');\n                        g_bPlaying2 = false;\n                        \n                        // 启动新码流\n                        clickStartRealPlay({ iStreamType: parsedType });\n                    },\n                    error: function() {\n                        console.warn('[changeStreamType] stop failed, forcing restart');\n                        g_bPlaying2 = false;\n                        clickStartRealPlay({ iStreamType: parsedType });\n                    }\n                });\n            } catch(e) {\n                console.warn('[changeStreamType] stop error:', e);\n                g_bPlaying2 = false;\n                clickStartRealPlay({ iStreamType: parsedType });\n            }\n        } else {\n            clickStartRealPlay({ iStreamType: parsedType });\n        }\n    }\n    ...\n    // 博客方案：clickStartRealPlay\n    function clickStartRealPlay(options) {\n        console.log('[WASM SDK] clickStartRealPlay', options);\n        var iStreamType = options.iStreamType || 3;\n        var iChannelID = g_iChannelID || 1;\n        \n        if (typeof ptzLog === 'function') ptzLog('开始播放: 码流=' + iStreamType + ', 通道=' + iChannelID, 'info');\n        \n        // v7.01: 移除灰色覆盖层\n        var overlay = document.getElementById('wasm-disconnected-overlay');\n        if (overlay) overlay.remove();\n        \n        WebVideoCtrl.I_StartRealPlay(g_szDeviceIdentify2, {\n            iStreamType: iStreamType,\n            iChannelID: iChannelID,\n            bZeroChannel: false,\n            success: function() {\n                g_bPlaying2 = true;\n                console.log('[WASM SDK] 播放成功');\n                if (typeof ptzLog === 'function') ptzLog('视频播放中', 'success');\n                // v6.45: 播放成功，显示\"播放中\"\n                if (window.updateWasmStatus) window.updateWasmStatus('playing');\n                // 启动 PTZ 位置自动刷新\n                if (window.startPtzPositionPoll) window.startPtzPositionPoll();\n            },\n            error: function(status, xmlDoc) {\n                console.error('[WASM SDK] 播放失败:', status);\n                if (typeof ptzLog === 'function') ptzLog('播放失败: ' + status, 'error');\n            }\n        });\n    }\n    window.clickLogin2 = clickLogin2;\n    window.getChannelInfo = getChannelInfo;\n    window.clickStartRealPlay = clickStartRealPlay;\n    ...\n    // PTZ 位置自动刷新\n    var _ptzPosTimer = null;\n    function startPtzPositionPoll() {\n        if (_ptzPosTimer) return;\n        _ptzPosTimer = setInterval(function() {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                getPtzPosition();\n            }\n        }, 1000);\n    }\n    function stopPtzPositionPoll() {\n        if (_ptzPosTimer) {\n            clearInterval(_ptzPosTimer);\n            _ptzPosTimer = null;\n        }\n    }\n    ...\n    // v6.43: WASM 状态更新函数\n    window.updateWasmStatus = function(state) {\n        var statusEl = document.getElementById('wasm-status');\n        if (!statusEl) return;\n        ...\n        var statusMap = {\n            'disconnected': { text: '未连接', color: '#8b949e' },\n            'connecting': { text: '连接中', color: '#f0883e' },\n            'connected': { text: '已连接', color: '#3fb950' },\n            'playing': { text: '播放中', color: '#3fb950' }\n        };\n        var s = statusMap[state] || { text: state, color: '#8b949e' };\n        statusEl.textContent = s.text;\n        statusEl.style.color = s.color;\n    }\n    ...\n    function getPtzPosition() {\n        var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n        if (!dev) return;\n        apiGet('/api/v1/ptz/' + dev + '/position').then(function(result) {\n            if (result && result.success) {\n                var pan = result.data.pan || 0;\n                var tilt = result.data.tilt || 0;\n                var zoom = result.data.zoom || 0;\n                var posEl = document.getElementById('ptzPosition');\n                if (posEl) {\n                    posEl.innerHTML = 'Pan: ' + pan + ' | Tilt: ' + tilt + ' | Zoom: ' + zoom;\n                }\n            }\n        }).catch(function(e) {});\n    }\n    function ptzMove(dir) {\n        var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n        if (!dev) return;\n        var speed = document.getElementById('ptzSpeed').value;\n        apiPost('/api/v1/ptz/' + dev + '/move', { direction: dir, speed: parseInt(speed) }).then(function(result) {\n            if (result && result.success) {\n                console.log('PTZ move:', dir, 'speed:', speed);\n            }\n        }).catch(function(e) {\n                console.error('PTZ move error:', e);\n            });\n    }\n    function ptzHome() {\n        var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n        if (!dev) return;\n        apiPost('/api/v1/ptz/' + dev + '/home', null).then(function(result) {\n            if (result && result.success) {\n                console.log('PTZ home success');\n            }\n        }).catch(function(e) {\n            console.error('PTZ home error:', e);\n            });\n    }\n    function ptzStop() {\n        var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n        if (!dev) return;\n        apiPost('/api/v1/ptz/' + dev + '/stop', null).catch(function(e) {});\n    }\n    ...\n    // 快门/光圈预设值\n    var shutterPresets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000', '1/30000', '1/25'];\n    var irisPresets = [160, 200, 400, 800, 1200, 1600, 2000, 2400];\n    ...\n    window.updateDeviceStatus = function(device) {\n        var statusEl = document.getElementById('deviceStatus');\n        var dotEl = document.getElementById('deviceDot');\n        var panelEl = document.getElementById('deviceInfoPanel');\n        \n        if (!statusEl) return;\n        \n        if (device) {\n            statusEl.textContent = device.name || device.model || device.ip;\n            if (dotEl) dotEl.className = 'status-dot green';\n            if (panelEl) {\n                panelEl.style.display = 'block';\n                panelEl.innerHTML = '<strong>' + (device.name || device.model || '设备') + '</strong><br>' +\n                    'IP: ' + device.ip + '<br>' +\n                    '型号: ' + (device.model || '--') + '<br>' +\n                    'MAC: ' + (device.mac || '--');\n            }\n        } else {\n            statusEl.textContent = '未连接';\n            if (dotEl) dotEl.className = 'status-dot red';\n            if (panelEl) panelEl.style.display = 'none';\n        }\n    }\n    ...\n    window.updateWasmStatus = updateWasmStatus;\n    window.startPtzPositionPoll = startPtzPositionPoll;\n    window.stopPtzPositionPoll = stopPtzPositionPoll;\n    window.getPtzPosition = getPtzPosition;\n    window.ptzMove = ptzMove;\n    window.ptzHome = ptzHome;\n    window.ptzStop = ptzStop;\n    window.changeStreamType = changeStreamType;\n})();\n</script>\n</body>\n</html>\n```\n\n..."},{"type":"toolCall","id":"tool-2493bf70ef7b4fa884feb1fd64e2ebe5","name":"exec","arguments":{"command":"cd \"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\" && python -c \"\nimport requests\nfrom requests.auth import HTTPDigestAuth\n\nimport xml.etree.ElementTree as ET\n\nimport time\nimport sys\n\nsys.setrecursionlimit(2000)\n\n# Step 1: Set exposure to manual\nprint('=== Step 1: Set Exposure to Manual ===')\nxml_set = '''<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\n<Exposure version=\\\"2.0\\\" xmlns=\\\"http://www.hikvision.com/ver20/XMLSchema\\\">\n  <ExposureType>manual</ExposureType>\n</Exposure>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_set,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint('Set manual status:', resp.status_code)\n\ntime.sleep(1)\n\n# Step 2: Get exposure and see the structure\nprint('\\\\n=== Step 2: Get Exposure Structure ===')\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nprint('Get exposure:')\nprint(resp.text)\n\n# Parse to find all possible fields\nroot = ET.fromstring(resp.text)\nprint('\\\\n=== Parsing Exposure fields ===')\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if elem.text:\n        print(f'{tag}: {elem.text}')\n\n# Step 3: Try to set ShutterLevel in Exposure\nprint('\\\\n=== Step 3: Set ShutterLevel in Exposure ===')\nxml_set_shutter = '''<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\n<Exposure version=\\\"2.0\\\" xmlns=\\\"http://www.hikvision.com/ver20/XMLSchema\\\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>1/1000</ShutterLevel>\n</Exposure>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_set_shutter,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint('Set shutter in exposure status:', resp.status_code)\nprint('Response:', resp.text[:500])\n\ntime.sleep(1)\n\n# Step 4: Verify\nprint('\\\\n=== Step 4: Verify ShutterLevel ===')\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nroot = ET.fromstring(resp.text)\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if tag == 'ShutterLevel' and elem.text:\n        print(f'ShutterLevel: {elem.text}')\n\n# Step 5: Try Gain\nprint('\\\\n=== Step 5: Check for Gain field ===')\nxml_set_gain = '''<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\n<Exposure version=\\\"2.0\\\" xmlns=\\\"http://www.hikvision.com/ver20/XMLSchema\\\">\n  <ExposureType>manual</ExposureType>\n  <Gain>50</Gain>\n</Exposure>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_set_gain,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint('Set gain status:', resp.status_code)\nprint('Response:', resp.text[:500])\n\ntime.sleep(1)\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nroot = ET.fromstring(resp.text)\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if tag == 'Gain' and elem.text:\n        print(f'Gain: {elem.text}')\n\n# Step 6: Reset to auto\nprint('\\\\n=== Step 6: Reset to Auto ===')\nxml_auto = '''<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\n<Exposure version=\\\"2.0\\\" xmlns=\\\"http://www.hikvision.com/ver20/XMLSchema\\\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_auto,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint('Reset to auto status:', resp.status_code)\n\"","timeout":30}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":112226,"output":4955,"cacheRead":0,"cacheWrite":0,"totalTokens":117181,"cost":{"input":0.11222599999999999,"output":0.015856000000000002,"cacheRead":0,"cacheWrite":0,"total":0.128082}},"stopReason":"toolUse","timestamp":1781406114680,"responseId":"cht000d2dbb@dx19ec4148e82b894142"}}
