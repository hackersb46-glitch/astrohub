{"type":"message","id":"ad87fe18","parentId":"c496fb01","timestamp":"2026-06-14T12:41:33.838Z","message":{"role":"toolResult","toolCallId":"tool-3d6fd37eda6f40f180e4f93dcfdd492f","toolName":"read","content":[{"type":"text","text":"            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.connected && r.device) {\r\n                    window.connectedDevice = r.device;\r\n                    console.log('[v6.0] 已恢复连接:', r.device.ip);\r\n\r\n                    // v7.0: 启用所有控件\r\n                    if (window.enableAllControls) window.enableAllControls();\r\n\r\n                    // v6.34: 更新状态显示\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus(r.device);\r\n\r\n                    // v6.12: 加载图像参数\r\n                    if (window.loadDeviceImageParams) {\r\n                        setTimeout(function() { window.loadDeviceImageParams(r.device.ip); }, 300);\r\n                    }\r\n\r\n                    // v6.44: 移除这里的 clickLogin2 调用,让 WASM SDK cbInitPluginComplete 触发\r\n                    // 这样确保 WASM SDK 初始化完成后再登录\r\n                } else if (r && r.success && !r.connected) {\r\n                    // v6.16: 无上次连接设备\r\n                    console.log('[v6.16] 无上次连接设备');\r\n                    // v6.34: 更新状态显示\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus(null);\r\n                    // v7.0: 禁用所有控件\r\n                    if (window.disableAllControls) window.disableAllControls('请连接设备');\r\n                    // 显示提示(3秒后自动消失)\r\n                    setTimeout(function() {\r\n                        showToast('info', '无上次连接设备,请执行发现流程');\r\n                    }, 1000);\r\n                }\r\n            }).catch(function(e) {\r\n                console.warn('[v6.0] 获取连接状态失败:', e);\r\n                // v7.0: 禁用所有控件\r\n                if (window.disableAllControls) window.disableAllControls('请连接设备');\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  Navigation\r\n        // ================================================================\r\n        function initNav() {\r\n            document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n                btn.addEventListener('click', function() {\r\n                    document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n                    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n                    btn.classList.add('active');\r\n                    document.getElementById('page-' + btn.getAttribute('data-page')).classList.add('active');\r\n                    if (btn.getAttribute('data-page') === 'devices') { refreshDevices(); }\r\n                    if (btn.getAttribute('data-page') === 'console') {\r\n                        refreshPtzDeviceList();\r\n                        // v6.12: 预渲染 WASM(如果已连接)\r\n\n[2578 more lines in file. Use offset=310 to continue.]"}],"isError":false,"timestamp":1781440893838}}
