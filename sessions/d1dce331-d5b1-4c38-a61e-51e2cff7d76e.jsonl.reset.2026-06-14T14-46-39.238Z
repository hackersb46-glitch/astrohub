{"type":"message","id":"037c9bec","parentId":"63cd15ee","timestamp":"2026-06-14T13:22:43.381Z","message":{"role":"assistant","content":[{"type":"text","text":"现在测试无设备时的提示："},{"type":"toolCall","id":"call_748842c1675746f28a12fe3b","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"测试无上次设备时的提示\"\"\"\nimport asyncio\nimport requests\nfrom playwright.async_api import async_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\nasync def test_no_device():\n    \"\"\"测试无上次设备时显示提示\"\"\"\n    \n    print(\"=\" * 60)\n    print(\"E2E Test: No last connected device\")\n    print(\"=\" * 60)\n    \n    # 1. 检查状态\n    print(\"\\n[Step 1] Check initial state\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n    state = resp.json()\n    print(f\"connected: {state.get('connected')}\")\n    print(f\"device: {state.get('device')}\")\n    \n    # 2. 打开页面\n    print(\"\\n[Step 2] Open browser and check toast message\")\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        page = await browser.new_page()\n        \n        # 监听控制台日志\n        console_logs = []\n        page.on(\"console\", lambda msg: console_logs.append(msg.text))\n        \n        # 打开主页\n        await page.goto(BASE_URL)\n        await asyncio.sleep(3)\n        \n        # 检查是否有 toast 提示\n        toast = await page.query_selector('.toast')\n        if toast:\n            toast_text = await toast.inner_text()\n            print(f\"Toast message: {toast_text}\")\n        else:\n            print(\"No toast found\")\n        \n        # 截图\n        await page.screenshot(path='test_no_device.png')\n        print(\"Screenshot: test_no_device.png\")\n        \n        await browser.close()\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"TEST COMPLETE\")\n    print(\"=\" * 60)\n\nif __name__ == \"__main__\":\n    asyncio.run(test_no_device())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\e2e_test_no_device.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":94898,"output":447,"cacheRead":0,"cacheWrite":0,"totalTokens":95345,"cost":{"input":0.094898,"output":0.0014304,"cacheRead":0,"cacheWrite":0,"total":0.0963284}},"stopReason":"toolUse","timestamp":1781443349070,"responseId":"cht000ddf32@dx19ec64c4d1fb9cb212"}}
