{"type":"message","id":"adf775a4","parentId":"68db48be","timestamp":"2026-06-14T09:53:48.174Z","message":{"role":"assistant","content":[{"type":"text","text":"**发现问题**：通过 Exposure 端点设置 ShutterLevel 返回 200，但实际快门值没有改变（还是 1/1000）！\n\n让我检查 Exposure 端点设置后是否需要等待："},{"type":"toolCall","id":"call_c402d13d780c44d6b82c6ff0","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n测试 Exposure 端点设置快门 - 详细版\n\"\"\"\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport xml.etree.ElementTree as ET\n\nBASE_URL = \"http://192.168.5.72\"\nAUTH = HTTPDigestAuth('admin', 'Nftw1357')\n\ndef get_shutter():\n    resp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\n    root = ET.fromstring(resp.text)\n    for elem in root.iter():\n        tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n        if tag == 'ShutterLevel':\n            return elem.text\n    return None\n\ndef get_exposure():\n    resp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', auth=AUTH, timeout=5)\n    print(f'Exposure: {resp.text}')\n    return resp.text\n\nprint(\"=\" * 60)\nprint(\"测试 Exposure 端点设置快门 - 详细版\")\nprint(\"=\" * 60)\n\n# 1. 设置手动模式\nprint(\"\\n1. 设置手动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\n# 2. 获取当前快门\nprint(f\"\\n当前快门: {get_shutter()}\")\n\n# 3. 获取 Exposure 完整信息\nprint(\"\\n3. Exposure 完整信息:\")\nget_exposure()\n\n# 4. 设置快门 1/250（这是 Shutter 端点接受的值）\nprint(\"\\n4. 通过 Exposure 设置快门 1/250\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>1/250</ShutterLevel>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(2)\n\n# 5. 验证\nprint(f\"\\n快门: {get_shutter()}\")\nprint(\"\\nExposure 完整信息:\")\nget_exposure()\n\n# 6. 设置快门 1/1000\nprint(\"\\n6. 通过 Exposure 设置快门 1/1000\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>1/1000</ShutterLevel>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(2)\n\n# 7. 验证\nprint(f\"\\n快门: {get_shutter()}\")\n\n# 8. 恢复自动模式\nprint(\"\\n8. 恢复自动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_exposure_shutter3.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":121596,"output":1023,"cacheRead":0,"cacheWrite":0,"totalTokens":122619,"cost":{"input":0.121596,"output":0.0032736,"cacheRead":0,"cacheWrite":0,"total":0.1248696}},"stopReason":"toolUse","timestamp":1781430805304,"responseId":"cht000e3e7a@dx19ec58ce659b893102"}}
