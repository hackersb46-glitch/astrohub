{"type":"message","id":"908cdc37","parentId":"b705b1a9","timestamp":"2026-06-14T01:46:00.913Z","message":{"role":"toolResult","toolCallId":"call_9dafa5511f304e8db4c33c1f","toolName":"read","content":[{"type":"text","text":"                },\r\n                cbEvent: function(iEventType, iParam1, iParam2) {\r\n                    console.log(\"[WASM] Event:\", iEventType, iParam1, iParam2);\r\n                },\r\n                cbDoubleClickWnd: function(iWndIndex, bFullScreen) {\r\n                    WebVideoCtrl.I_Stop();\r\n                },\r\n                cbSelWnd: function(xmlDoc) {\r\n                    g_iWndIndex = parseInt($(xmlDoc).find(\"SelectWnd\").eq(0).text(), 10);\r\n                },\r\n                cbInitPluginComplete: function() {\r\n                    console.log('[WASM] cbInitPluginComplete - inserting plugin');\r\n                    WebVideoCtrl.I_InsertOBJECTPlugin(\"divPlugin\");\r\n\r\n                    // Patch: fix oStreamClient.openStream URL parsing\r\n                    // SDK adds ?deviceIdentify=... to WS URL, but openStream's\r\n                    // parser can't handle query params in the path segment\r\n                    var _origOpenStream = null;\r\n                    try {\r\n                        var ds = WebVideoCtrl.w_deviceSet;\r\n                        if (ds && ds.length > 0) {\r\n                            // Will be patched after login when oStreamClient is available\r\n                        }\r\n                    } catch(e) {}\r\n\r\n                    // WASM SDK ready - trigger login if device already connected\r\n                    if (window.connectedDevice && window.connectedDevice.ip && window.clickLogin2) {\r\n                        console.log('[WASM] Device already connected, triggering login');\r\n                        window.clickLogin2();\r\n                    }\r\n                    // Update device status display\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                },\r\n                cbPluginErrorHandler: function(iWndIndex, iErrorCode, oError) {\r\n                    console.error('[WASM] Plugin error:', iWndIndex, iErrorCode);\r\n                },\r\n                cbPerformanceLack: function() {\r\n                    console.error('[WASM] Performance issue');\r\n                }\r\n            });\r\n            console.log('[WASM] I_InitPlugin called');\r\n        }\r\n        if (document.readyState === 'loading') {\r\n            document.addEventListener('DOMContentLoaded', initWasm);\r\n        } else {\r\n            initWasm();\r\n        }\r\n\r\n        // 页面关闭/刷新时释放 WASM 和 ISAPI\r\n        window.addEventListener('beforeunload', function(e) {\r\n            if (window.wasmLogout) window.wasmLogout();\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                // 同步断开 ISAPI 连接(使用 navigator.sendBeacon)\r\n                var url = '/api/v1/devices/' + window.connectedDevice.ip + '/disconnect';\r\n                navigator.sendBeacon(url);\r\n            }\r\n        });\r\n    })();\r\n</script>\r\n    <script>\r\n// WASM SDK global variables\r\nvar g_szDeviceIdentify = '';\r\nvar g_bLoggedIn = false;\r\nvar g_bPlaying = false;\r\nvar g_iRtspPort = 554;\r\nvar g_szDeviceIdentify2 = \"\";\r\nvar g_bLoggedIn2 = false;\r\nvar g_bPlaying2 = false;\r\nvar g_iRtspPort2 = 554;\r\nvar g_iWndIndex2 = 0;\r\nvar g_iWebSocketPort = 7681;\r\nvar g_iWndIndex = 0;\r\nvar g_iChannelList = [];\r\nvar g_iChannelID = 1;\r\nvar g_iChannelID = 1;\r\n// var connectedDevice = null; // Removed: conflicts with window.connectedDevice\r\n// WASM SDK global functions (simple version)\r\nfunction setLoginStatus(msg, color) {\r\n    var el = document.getElementById('login-status');\r\n    if (el) {\r\n\n[417 more lines in file. Use offset=2435 to continue.]"}],"isError":false,"timestamp":1781401560913}}
{"type":"message","id":"f4aa104f","parentId":"908cdc37","timestamp":"2026-06-14T01:46:19.228Z","message":{"role":"assistant","content":[{"type":"text","text":"WASM SDK 初始化后会调用 `cbInitPluginComplete`，在这里我需要确保如果设备未连接，显示灰色覆盖层。让我检查是否在 `I_InsertOBJECTPlugin` 后需要添加覆盖层："},{"type":"toolCall","id":"call_058e9ca5f746498a95ce263b","name":"edit","arguments":{"edits":[{"newText":"                cbInitPluginComplete: function() {\n                    console.log('[WASM] cbInitPluginComplete - inserting plugin');\n                    WebVideoCtrl.I_InsertOBJECTPlugin(\"divPlugin\");\n                    \n                    // v7.0: 初始显示灰色覆盖层\n                    var container = document.getElementById('divPlugin');\n                    if (container && !document.getElementById('wasm-disconnected-overlay')) {\n                        var overlay = document.createElement('div');\n                        overlay.id = 'wasm-disconnected-overlay';\n                        overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px;z-index:10';\n                        overlay.innerHTML = '请连接设备';\n                        container.style.position = 'relative';\n                        container.appendChild(overlay);\n                    }\n\n                    // Patch: fix oStreamClient.openStream URL parsing\n                    // SDK adds ?deviceIdentify=... to WS URL, but openStream's\n                    // parser can't handle query params in the path segment\n                    var _origOpenStream = null;\n                    try {\n                        var ds = WebVideoCtrl.w_deviceSet;\n                        if (ds && ds.length > 0) {\n                            // Will be patched after login when oStreamClient is available\n                        }\n                    } catch(e) {}\n\n                    // WASM SDK ready - trigger login if device already connected\n                    if (window.connectedDevice && window.connectedDevice.ip && window.clickLogin2) {\n                        console.log('[WASM] Device already connected, triggering login');\n                        window.clickLogin2();\n                    }\n                    // Update device status display\n                    if (window.updateDeviceStatus) window.updateDeviceStatus();\n                },","oldText":"                cbInitPluginComplete: function() {\n                    console.log('[WASM] cbInitPluginComplete - inserting plugin');\n                    WebVideoCtrl.I_InsertOBJECTPlugin(\"divPlugin\");\n\n                    // Patch: fix oStreamClient.openStream URL parsing\n                    // SDK adds ?deviceIdentify=... to WS URL, but openStream's\n                    // parser can't handle query params in the path segment\n                    var _origOpenStream = null;\n                    try {\n                        var ds = WebVideoCtrl.w_deviceSet;\n                        if (ds && ds.length > 0) {\n                            // Will be patched after login when oStreamClient is available\n                        }\n                    } catch(e) {}\n\n                    // WASM SDK ready - trigger login if device already connected\n                    if (window.connectedDevice && window.connectedDevice.ip && window.clickLogin2) {\n                        console.log('[WASM] Device already connected, triggering login');\n                        window.clickLogin2();\n                    }\n                    // Update device status display\n                    if (window.updateDeviceStatus) window.updateDeviceStatus();\n                },"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":57484,"output":727,"cacheRead":0,"cacheWrite":0,"totalTokens":58211,"cost":{"input":0.057484