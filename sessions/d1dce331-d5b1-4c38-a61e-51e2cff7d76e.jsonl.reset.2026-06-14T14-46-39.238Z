{"type":"message","id":"62178176","parentId":"66faee80","timestamp":"2026-06-14T09:04:31.949Z","message":{"role":"toolResult","toolCallId":"call_4d8e66d6f5a94b3487b1cd6b","toolName":"exec","content":[{"type":"text","text":"2727:@api_router.get(\"/ptz/{device_id}/image/noisereduce\", summary=\"获取降噪设置\", tags=[\"Image\"])\r\n2728:async def get_noisereduce(device_id: str) -> dict:\r\n2745:        resp = client.get(\"/Image/channels/1/noiseReduce\")\r\n2768:@api_router.post(\"/ptz/{device_id}/image/noisereduce\", summary=\"设置降噪\", tags=[\"Image\"])\r\n2769:async def set_noisereduce(device_id: str, data: dict) -> dict:\r\n2790:        resp = client.get(\"/Image/channels/1/noiseReduce\")\r\n2815:        put_resp = client.put(\"/Image/channels/1/noiseReduce\", xml_str)\r\n2848:        \"noise_reduce\": 50,\r\n2880:        resp = client.put(\"/Image/channels/1/noiseReduce\", nr_xml)\r\n2881:        results[\"noise_reduce\"] = resp.status_code == 200"}],"details":{"status":"completed","exitCode":0,"durationMs":377,"aggregated":"2727:@api_router.get(\"/ptz/{device_id}/image/noisereduce\", summary=\"获取降噪设置\", tags=[\"Image\"])\r\n2728:async def get_noisereduce(device_id: str) -> dict:\r\n2745:        resp = client.get(\"/Image/channels/1/noiseReduce\")\r\n2768:@api_router.post(\"/ptz/{device_id}/image/noisereduce\", summary=\"设置降噪\", tags=[\"Image\"])\r\n2769:async def set_noisereduce(device_id: str, data: dict) -> dict:\r\n2790:        resp = client.get(\"/Image/channels/1/noiseReduce\")\r\n2815:        put_resp = client.put(\"/Image/channels/1/noiseReduce\", xml_str)\r\n2848:        \"noise_reduce\": 50,\r\n2880:        resp = client.put(\"/Image/channels/1/noiseReduce\", nr_xml)\r\n2881:        results[\"noise_reduce\"] = resp.status_code == 200","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781427871949}}
{"type":"message","id":"64176fdf","parentId":"62178176","timestamp":"2026-06-14T09:04:43.643Z","message":{"role":"assistant","content":[{"type":"text","text":"让我查看降噪设置代码："},{"type":"toolCall","id":"call_2dbff9b4b750484585359ffe","name":"read","arguments":{"limit":60,"offset":2768,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":98218,"output":53,"cacheRead":0,"cacheWrite":0,"totalTokens":98271,"cost":{"input":0.098218,"output":0.0001696,"cacheRead":0,"cacheWrite":0,"total":0.0983876}},"stopReason":"toolUse","timestamp":1781427871953,"responseId":"cht000d54a1@dx19ec56037f8b9ca102"}}
{"type":"message","id":"3c41e15e","parentId":"64176fdf","timestamp":"2026-06-14T09:04:43.652Z","message":{"role":"toolResult","toolCallId":"call_2dbff9b4b750484585359ffe","toolName":"read","content":[{"type":"text","text":"@api_router.post(\"/ptz/{device_id}/image/noisereduce\", summary=\"设置降噪\", tags=[\"Image\"])\r\nasync def set_noisereduce(device_id: str, data: dict) -> dict:\r\n    \"\"\"设置降噪参数。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        # 先获取当前降噪设置\r\n        current_spatial = 50\r\n        current_temporal = 50\r\n        \r\n        resp = client.get(\"/Image/channels/1/noiseReduce\")\r\n        if resp.status_code == 200:\r\n            import xml.etree.ElementTree as ET\r\n            root = ET.fromstring(resp.xml)\r\n            for elem in root.iter():\r\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n                if tag == \"FrameNoiseReduceLevel\":\r\n                    current_spatial = int(elem.text or 50)\r\n                elif tag == \"InterFrameNoiseReduceLevel\":\r\n                    current_temporal = int(elem.text or 50)\r\n        \r\n        # 使用传入值或当前值\r\n        spatial = data.get(\"spatial_level\", current_spatial)\r\n        temporal = data.get(\"temporal_level\", current_temporal)\r\n        \r\n        # ISAPI advanced 模式: FrameNoiseReduceLevel = 空域, InterFrameNoiseReduceLevel = 时域\r\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n<mode>advanced</mode>\r\n<AdvancedMode>\r\n<FrameNoiseReduceLevel>{spatial}</FrameNoiseReduceLevel>\r\n<InterFrameNoiseReduceLevel>{temporal}</InterFrameNoiseReduceLevel>\r\n</AdvancedMode>\r\n</NoiseReduce>'''\r\n\r\n        put_resp = client.put(\"/Image/channels/1/noiseReduce\", xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"降噪已更新\", \"data\": {\"spatial_level\": spatial, \"temporal_level\": temporal}}\r\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置降噪异常: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/image/reset\", summary=\"重置画面控制到默认值\", tags=[\"Image\"])\r\nasync def reset_image_controls(device_id: str) -> dict:\r\n    \"\"\"v6.51: 重置设备画面控制到默认值（不调用设备系统重置）。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n\n[581 more lines in file. Use offset=2828 to continue.]"}],"isError":false,"timestamp":1781427883652}}
