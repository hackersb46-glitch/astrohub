{"type":"message","id":"349fe2be","parentId":"6b8f9db1","timestamp":"2026-06-14T11:30:04.306Z","message":{"role":"toolResult","toolCallId":"call_c163b2e6a54149c19374a1d6","toolName":"read","content":[{"type":"text","text":"async def get_connected_device() -> dict:\r\n    \"\"\"v6.15: 从 registry.json 获取当前活跃设备信息。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\", \"connected\": False}\r\n    device = mgr.get_connected_device()\r\n    if not device:\r\n        return {\"success\": True, \"connected\": False, \"device\": None}\r\n    return {\"success\": True, \"connected\": True, \"device\": device}\r\n\r\n@api_router.get(\"/system/info\", summary=\"系统硬件信息 (P1.1)\", tags=[\"System\"])\r\nasync def get_system_info() -> dict:\r\n    \"\"\"获取本机系统硬件信息 (hostname/CPU/RAM/GPU/VRAM)。\"\"\"\r\n    try:\r\n        from src.ptz.core.system_info import collect_system_info\r\n        info = collect_system_info()\r\n        return {\"success\": True, \"data\": info}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": str(e)}\r\n\r\n\r\n@api_router.get(\"/system/nics\", summary=\"网络接口列表 (P1.2)\", tags=[\"System\"])\r\nasync def get_nics() -> dict:\r\n    \"\"\"获取所有网络接口列表，按优先级排序。\"\"\"\r\n    try:\r\n\n[2669 more lines in file. Use offset=739 to continue.]"}],"isError":false,"timestamp":1781436604306}}
{"type":"message","id":"253460aa","parentId":"349fe2be","timestamp":"2026-06-14T11:30:23.474Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了！API 在第 714 行。问题是：API 根据 `device` 是否为 None 来判断 `connected`，但 `get_connected_device()` 现在返回的是 `last_connected`（即使未连接）。\n\n需要修改 API 逻辑，检查 `active_device` 是否存在："},{"type":"toolCall","id":"call_0ae5c30baf9c42cb87fb2cc0","name":"edit","arguments":{"edits":[{"newText":"async def get_connected_device() -> dict:\n    \"\"\"v7.10: 获取当前连接状态和上次连接设备信息。\n    \n    返回:\n    - connected: 当前是否已连接（基于 active_device）\n    - device: 上次连接的设备信息（基于 last_connected，用于快速连接）\n    \"\"\"\n    import json\n    from src.config_paths import REGISTRY_FILE\n    \n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\", \"connected\": False, \"device\": None}\n    \n    # v7.10: 获取上次连接的设备（用于快速连接）\n    device = mgr.get_connected_device()\n    \n    # v7.10: 检查当前是否实际连接（基于 active_device）\n    connected = False\n    try:\n        if REGISTRY_FILE.exists():\n            registry = json.loads(REGISTRY_FILE.read_text(encoding='utf-8'))\n            active_mac = registry.get('active_device', '').strip()\n            connected = bool(active_mac)\n    except Exception:\n        pass\n    \n    if not device:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    \n    return {\"success\": True, \"connected\": connected, \"device\": device}","oldText":"async def get_connected_device() -> dict:\n    \"\"\"v6.15: 从 registry.json 获取当前活跃设备信息。\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\", \"connected\": False}\n    device = mgr.get_connected_device()\n    if not device:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    return {\"success\": True, \"connected\": True, \"device\": device}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":74018,"output":589,"cacheRead":0,"cacheWrite":0,"totalTokens":74607,"cost":{"input":0.074018,"output":0.0018848,"cacheRead":0,"cacheWrite":0,"total":0.0759028}},"stopReason":"toolUse","timestamp":1781436604309,"responseId":"cht000ed021@dx19ec5e57042b893102"}}
