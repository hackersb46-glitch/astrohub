{"type":"message","id":"2da952d1","parentId":"4d5c0a51","timestamp":"2026-06-14T02:24:35.720Z","message":{"role":"toolResult","toolCallId":"call_50f7931d0eb84ab2b583290a","toolName":"read","content":[{"type":"text","text":"            g_szDeviceIdentify2 = szIP + '_' + szPort;\r\n            console.log('[WASM SDK] Login success: ' + g_szDeviceIdentify2);\r\n            if (typeof ptzLog === 'function') ptzLog(szIP + ' 登录成功!', 'success');\r\n            if (window.showToast) window.showToast('success', '设备已连接: ' + szIP);\r\n            \r\n            // v7.0: 移除灰色覆盖层\r\n            var overlay = document.getElementById('wasm-disconnected-overlay');\r\n            if (overlay) overlay.remove();\r\n\r\n            // 更新 WASM 状态为已连接\r\n            if (window.updateWasmStatus) window.updateWasmStatus('connected');\r\n\r\n            // 博客方案:延迟500ms后执行 getDevicePort + getChannelInfo\r\n            setTimeout(() => {\r\n                // Step 1: getDevicePort\r\n                var oPort = WebVideoCtrl.I_GetDevicePort(g_szDeviceIdentify2);\r\n                console.log('[WASM SDK] GetDevicePort:', oPort);\r\n                if (oPort) {\r\n                    g_iRtspPort2 = oPort.iRtspPort || 554;\r\n                    g_iWebSocketPort = oPort.iWebSocketPort || 7681;\r\n                    if (typeof ptzLog === 'function') ptzLog('WebSocket端口: ' + g_iWebSocketPort, 'info');\r\n                    document.cookie = 'webVideoCtrlProxyWs=' + szIP + ':' + g_iWebSocketPort + '; path=/';\r\n                    document.cookie = 'webVideoCtrlProxyWsChannel=101; path=/';\r\n                }\r\n\r\n                // Step 1.5: 异步获取 token 修复 szAuth(同步XHR被弃用)\r\n                var deviceSet = WebVideoCtrl.w_deviceSet;\r\n                var device = deviceSet && deviceSet.length > 0 ? deviceSet[0] : null;\r\n                var tokenPromise = Promise.resolve();\r\n                if (device && !device.szAuth) {\r\n                    console.log('[WASM SDK] szAuth empty, fetching token async...');\r\n                    tokenPromise = fetch('/ISAPI/Security/token?format=json', {credentials:'include'})\r\n                        .then(function(r) { return r.json(); })\r\n                        .then(function(data) {\r\n                            if (data && data.Token && data.Token.value) {\r\n                                device.szAuth = data.Token.value;\r\n                                console.log('[WASM SDK] szAuth set async:', device.szAuth.substring(0,16) + '...');\r\n                                if (typeof ptzLog === 'function') ptzLog('Token获取成功', 'success');\r\n                            }\r\n                        })\r\n                        .catch(function(e) { console.log('[WASM SDK] Token fetch failed:', e); });\r\n                }\r\n\r\n                tokenPromise.then(function() {\r\n                getChannelInfo().then(function() {\r\n                    console.log('[WASM SDK] 获取通道结束');\r\n                    // v7.0: 默认使用第三码流\r\n                    clickStartRealPlay({ iStreamType: 3 });\r\n                }).catch(function(err) {\r\n                    console.log('[WASM SDK] 获取通道失败: ' + err);\r\n\n[334 more lines in file. Use offset=2533 to continue.]"}],"isError":false,"timestamp":1781403875720}}
{"type":"message","id":"f6acf74f","parentId":"2da952d1","timestamp":"2026-06-14T02:24:53.362Z","message":{"role":"assistant","content":[{"type":"text","text":"WASM SDK 初始化可能有问题。让我创建一个测试脚本来验证修复："},{"type":"toolCall","id":"tool-3b8d65b91ccd4e29bb4bd2658ad8cc23","name":"write","arguments":{"content":"from playwright.sync_api import sync_playwright\nimport time\n\nwith sync_playwright() as p:\n    browser = p.chromium.launch(headless=False)\n    page = browser.new_page()\n    page.goto('http://localhost:10280')\n    time.sleep(2)\n    \n    # 检查版本号\n    version = page.locator('.version').text_content()\n    print(f'版本号: {version}')\n    \n    # 进入主控台\n    page.click('text=主控台')\n    time.sleep(1)\n    \n    # 检查主控台提示框\n    warning = page.locator('#consoleWarning')\n    print(f'主控台提示框存在: {warning.count() > 0}')\n    if warning.count() > 0:\n        print(f'提示框内容: {warning.text_content()}')\n    \n    # 检查 OSD 开关状态\n    ptz_switch = page.locator('#ptzOsdSwitch')\n    info_switch = page.locator('#infoOsdSwitch')\n    print(f'PTZ OSD 开关状态: {ptz_switch.evaluate(\"el => el.checked\")}')\n    print(f'Info OSD 开关状态: {info_switch.evaluate(\"el => el.checked\")}')\n    \n    # 检查降噪显示\n    dnr_spatial = page.locator('#ptzDnrSpatial')\n    dnr_temporal = page.locator('#ptzDnrTemporal')\n    print(f'空域降噪: {dnr_spatial.text_content()}')\n    print(f'时域降噪: {dnr_temporal.text_content()}')\n    \n    browser.close()\n    print('\\nE2E 测试完成!')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_v701.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":78597,"output":405,"cacheRead":0,"cacheWrite":0,"totalTokens":79002,"cost":{"input":0.078597,"output":0.001296,"cacheRead":0,"cacheWrite":0,"total":0.079893}},"stopReason":"toolUse","timestamp":1781403875722,"responseId":"cht000de899@dx19ec3f2044fb894142"}}
