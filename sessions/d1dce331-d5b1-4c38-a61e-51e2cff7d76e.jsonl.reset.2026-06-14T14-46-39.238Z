{"type":"message","id":"202990dc","parentId":"48f54979","timestamp":"2026-06-14T13:21:09.952Z","message":{"role":"assistant","content":[{"type":"text","text":"---\n\n## 步骤 5：E2E 测试 - Playwright 验证自动连接"},{"type":"toolCall","id":"call_381c4e70ec704f4c8d58fe37","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nE2E 测试：刷新页面后自动连接\n\"\"\"\nimport asyncio\nimport requests\nfrom playwright.async_api import async_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\nasync def test_auto_connect():\n    \"\"\"测试刷新页面后自动连接\"\"\"\n    \n    print(\"=\" * 60)\n    print(\"E2E Test: Auto-connect after page refresh\")\n    print(\"=\" * 60)\n    \n    # 1. 确认当前状态：未连接但有 last_connected\n    print(\"\\n[Step 1] Check initial state\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n    state = resp.json()\n    print(f\"connected: {state.get('connected')}\")\n    print(f\"device: {state.get('device', {}).get('ip') if state.get('device') else 'None'}\")\n    \n    if state.get('connected'):\n        # 断开设备\n        print(\"\\n[Step 1.1] Disconnecting device...\")\n        requests.post(f\"{BASE_URL}/api/v1/devices/192.168.5.72/disconnect\")\n        await asyncio.sleep(1)\n    \n    # 2. 打开页面，检查是否自动连接\n    print(\"\\n[Step 2] Open browser and check auto-connect\")\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        page = await browser.new_page()\n        \n        # 监听控制台日志\n        console_logs = []\n        page.on(\"console\", lambda msg: console_logs.append(msg.text))\n        \n        # 打开主页\n        print(\"Opening page...\")\n        await page.goto(BASE_URL)\n        \n        # 等待自动连接\n        print(\"Waiting for auto-connect (5s)...\")\n        await asyncio.sleep(5)\n        \n        # 检查连接状态\n        resp2 = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n        state2 = resp2.json()\n        print(f\"\\nAfter page load:\")\n        print(f\"connected: {state2.get('connected')}\")\n        print(f\"device: {state2.get('device', {}).get('ip') if state2.get('device') else 'None'}\")\n        \n        # 检查控制台日志\n        print(\"\\nConsole logs:\")\n        for log in console_logs[-10:]:\n            if 'v7.12' in log or 'connect' in log.lower():\n                print(f\"  {log[:100]}\")\n        \n        # 截图\n        await page.screenshot(path='test_auto_connect.png')\n        print(\"\\nScreenshot: test_auto_connect.png\")\n        \n        await browser.close()\n    \n    # 3. 结论\n    print(\"\\n\" + \"=\" * 60)\n    print(\"TEST RESULT\")\n    print(\"=\" * 60)\n    \n    if state2.get('connected'):\n        print(\"PASS: Auto-connected successfully\")\n        return True\n    else:\n        print(\"FAIL: Did not auto-connect\")\n        return False\n\nif __name__ == \"__main__\":\n    result = asyncio.run(test_auto_connect())\n    exit(0 if result else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\e2e_test_auto_connect.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":93340,"output":731,"cacheRead":0,"cacheWrite":0,"totalTokens":94071,"cost":{"input":0.09333999999999999,"output":0.0023392,"cacheRead":0,"cacheWrite":0,"total":0.09567919999999999}},"stopReason":"toolUse","timestamp":1781443245480,"responseId":"cht000d3e89@dx19ec64acba1b87f702"}}
