{"type":"message","id":"099f6ea9","parentId":"3ae897b5","timestamp":"2026-06-14T01:34:51.998Z","message":{"role":"toolResult","toolCallId":"tool-2324b9b858304be39a4ae9c8b8b1731b","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">未连接</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\n                <div class=\"console-layout\">\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\n                    <div class=\"console-left\">\n                        <!-- PTZ控制（折叠） -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- 指向控制 -->\n                                <div class=\"section-subtitle\">指向</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\n                                    <button class=\"ptz-btn center\">●</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>速度:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"7\" value=\"4\">\n                                    <span id=\"ptzSpeedVal\">4</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- 预置点 -->\n                                <div class=\"section-subtitle\">预置点</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">选择预置点</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- 变焦/对焦 -->\n                                <div class=\"section-subtitle\">变焦/对焦</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">远</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">近</button>\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                                        <option value=\"manual\">手动</option>\n                                        <option value=\"auto\">自动</option>\n                                        <option value=\"semiauto\">半自动</option>\n                                    </select>\n                                </div>\n                            </div>\n                        </div>\n                        <!-- 跟踪控制 -->\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 中: 实时画面 + 媒体操作 -->\n                    <div class=\"console-center\">\n                        <!-- 实时画面 -->\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                        </div>\n                        <!-- 媒体操作（折叠，整合Live Stack + 码流） -->\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\n                                    <!-- 码流选择 -->\n                                    <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\n                                        <span style=\"color:#8b949e;font-size:13px\">码流:</span>\n                                        <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                                            <option value=\"1\">主码流</option>\n                                            <option value=\"2\" selected>子码流</option>\n                                            <option value=\"3\">第三码流</option>\n                                        </select>\n                                    </div>\n                                    <!-- 截图/录像 -->\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                                    </div>\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\n                                    <!-- Live Stack -->\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\n                                    </div>\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\n                                    </div>\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\n                                        <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\n                                    </div>\n                                    <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">叠加: 关闭</div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 右: 操作日志 + 画面控制 -->\n                    <div class=\"console-right\">\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto;max-height:200px\">\n                            <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\n                                <div style=\"color:#6e7681\">等待连接...</div>\n                            </div>\n                        </div>\n                        <!-- 画面控制（折叠，移到右侧） -->\n                        <div class=\"collapsible-section collapsed\" id=\"imageControlSection\" style=\"margin-top:12px\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('imageControlSection')\">\n                                <h3 style=\"font-size:15px;color:#d29922;margin:0\">🎨 画面控制</h3>\n                                <button class=\"btn btn-secondary btn-sm\" onclick=\"event.stopPropagation();refreshImageControls()\" style=\"margin-left:10px;padding:2px 8px;font-size:12px\">刷新</button>\n                                <button class=\"btn btn-secondary btn-sm\" onclick=\"event.stopPropagation();resetImageControls()\" style=\"margin-left:5px;padding:2px 8px;font-size:12px\">重置</button>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div class=\"card\">\n                                    <!-- 基础调节 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">亮度 <span id=\"brightnessVal\" style=\"color:#58a6ff\">50</span></label>\n                                            <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('brightnessVal').textContent=this.value\" onchange=\"adjustImage('brightness', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">对比度 <span id=\"contrastVal\" style=\"color:#58a6ff\">50</span></label>\n                                            <input type=\"range\" id=\"consoleContrast\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('contrastVal').textContent=this.value\" onchange=\"adjustImage('contrast', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 饱和度 + 锐度 - v6.02: 合并同一行 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">饱和度 <span id=\"saturationVal\" style=\"color:#58a6ff\">50</span></label>[... 37631 more characters truncated]"}],"isError":false,"timestamp":1781400891997}}
{"type":"message","id":"67a43bb8","parentId":"099f6ea9","timestamp":"2026-06-14T01:34:51.998Z","message":{"role":"toolResult","toolCallId":"tool-c6d2b67c6249410097e2104b0d03c644","toolName":"read","content":[{"type":"text","text":"\"\"\"\nM12 Unified Integration v1.0 - 全局常量定义\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom enum import Enum\nfrom pathlib import Path\n\n# === 版本与作者 ===\nVERSION = \"v6.56\"\nVERSION_NUM = \"6.56\"\nAUTHOR = \"雅痞张@南方天文\"\nPROJECT_NAME = \"MAIN\"\n\n# === 路径 ===\nBASE_DIR = Path(__file__).resolve().parent\n\n# === M1-M11 模块初始化顺序 ===\nMODULE_ORDER = [\n    \"ptz\",\n    \"device\",\n    \"stream\",\n    \"calibration\",\n    \"database\",\n    \"webui\",\n    \"rest_api\",\n    \"websocket\",\n    \"ascom\",\n    \"integration\",\n    \"deployment\",\n]\n\n\n# === 健康状态枚举 ===\nclass HealthStatus(Enum):\n    \"\"\"模块健康状态。\"\"\"\n    HEALTHY = \"healthy\"\n    DEGRADED = \"degraded\"\n    UNHEALTHY = \"unhealthy\"\n    UNKNOWN = \"unknown\"\n"}],"isError":false,"timestamp":1781400891997}}
{"type":"message","id":"8a5097cb","parentId":"67a43bb8","timestamp":"2026-06-14T01:35:06.544Z","message":{"role":"assistant","content":[{"type":"text","text":"继续读取 PTZ 控制相关代码和 index.html："},{"type":"toolCall","id":"call_e25c702dd01a4fdab12a1e57","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html","limit":500,"offset":1}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":34103,"output":57,"cacheRead":0,"cacheWrite":0,"totalTokens":34160,"cost":{"input":0.034103,"output":0.00018240000000000002,"cacheRead":0,"cacheWrite":0,"total":0.0342854}},"stopReason":"toolUse","timestamp":1781400891998,"responseId":"cht000d36bb@dx19ec3c49d94b85e102"}}
{"type":"message","id":"baa0a24c","parentId":"8a5097cb","timestamp":"2026-06-14T01:35:06.551Z","message":{"role":"toolResult","toolCallId":"call_e25c702dd01a4fdab12a1e57","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>AstroHub</title>\r\n    <style>\r\n        * { margin:0; padding:0; box-sizing:border-box; }\r\n        body { font-family: -apple-system, 'Segoe UI', sans-serif; background:#0a0e17; color:#e0e6f0; min-height:100vh; }\r\n        .header { background:linear-gradient(135deg, #1a1e2e, #0d1117); padding:12px 24px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #21262d; }\r\n        .logo { font-size:24px; font-weight:700; color:#58a6ff; }\r\n        .logo span { color:#f0883e; }\r\n        .version { font-size:12px; color:#8b949e; background:#21262d; padding:2px 8px; border-radius:12px; }\r\n        .status-bar { display:flex; gap:16px; align-items:center; }\r\n        .status-item { display:flex; align-items:center; gap:6px; font-size:13px; }\r\n        .status-dot { width:8px; height:8px; border-radius:50%; }\r\n        .status-dot.green { background:#3fb950; box-shadow:0 0 6px #3fb950; }\r\n        .status-dot.yellow { background:#d29922; box-shadow:0 0 6px #d29922; }\r\n        .status-dot.red { background:#f85149; box-shadow:0 0 6px #f85149; }\r\n        /* 开关样式 */\r\n        .switch { position:relative; display:inline-block; width:36px; height:18px; }\r\n        .switch input { opacity:0; width:0; height:0; }\r\n        .slider { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background-color:#30363d; transition:.2s; border-radius:18px; }\r\n        .slider:before { position:absolute; content:\"\"; height:12px; width:12px; left:3px; bottom:3px; background-color:#8b949e; transition:.2s; border-radius:50%; }\r\n        input:checked + .slider { background-color:#238636; }\r\n        input:checked + .slider:before { transform:translateX(18px); background-color:#fff; }\r\n        .nav { background:#161b22; padding:8px 24px; display:flex; gap:4px; align-items:center; border-bottom:1px solid #21262d; flex-wrap:wrap; }\r\n        .nav-btn { background:none; border:none; color:#8b949e; padding:8px 16px; cursor:pointer; border-radius:6px; font-size:14px; transition:all 0.2s; }\r\n        .nav-btn:hover { background:#21262d; color:#e0e6f0; }\r\n        .nav-btn.active { background:#238636; color:#fff; }\r\n        /* --- Advanced Page: Left Sidebar Layout --- */\r\n        .advanced-layout { display:flex; gap:0; min-height:600px; }\r\n        .advanced-sidebar { width:200px; background:#161b22; border-right:1px solid #21262d; padding:8px 0; flex-shrink:0; }\r\n        .advanced-sidebar .sidebar-item { background:none; border:none; color:#8b949e; padding:10px 16px; cursor:pointer; font-size:13px; transition:all 0.2s; width:100%; text-align:left; display:block; }\r\n        .advanced-sidebar .sidebar-item:hover { background:#21262d; color:#e0e6f0; }\r\n        .advanced-sidebar .sidebar-item.active { background:#238636; color:#fff; border-left:3px solid #3fb950; }\r\n        .advanced-content { flex:1; min-width:0; padding:20px; }\r\n        .advanced-content .page { display:none; }\r\n        .advanced-content .page.active { display:block; }\r\n        /* --- Observation Page Layout --- */\r\n        .observation-layout { display:grid; grid-template-columns:1fr 1fr; gap:20px; }\r\n        .obs-card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; }\r\n        .obs-card h3 { font-size:15px; color:#58a6ff; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #21262d; }\r\n        .obs-placeholder { color:#6e7681; font-size:13px; padding:20px 0; text-align:center; }\r\n        .obs-actions { margin-top:16px; display:flex; gap:8px; justify-content:flex-end; }\r\n        .main { padding:20px 24px; }\r\n        .page { display:none; }\r\n        .page.active { display:block; }\r\n        .grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:16px; margin-bottom:20px; }\r\n        .card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; transition:border-color 0.2s; }\r\n        .card:hover { border-color:#30363d; }\r\n        .card-title { font-size:12px; color:#8b949e; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }\r\n        .card-value { font-size:32px; font-weight:700; color:#e0e6f0; }\r\n        .card-value.green { color:#3fb950; }\r\n        .card-sub { font-size:12px; color:#6e7681; margin-top:4px; }\r\n        table { width:100%; border-collapse:collapse; }\r\n        th, td { text-align:left; padding:10px 16px; border-bottom:1px solid #21262d; font-size:14px; }\r\n        th { color:#8b949e; font-weight:500; background:#0d1117; }\r\n        tr:hover { background:#161b22; }\r\n        .badge { padding:2px 8px; border-radius:12px; font-size:12px; font-weight:500; }\r\n        .badge.online { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.offline { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .badge.sadp { background:rgba(88,166,255,0.15); color:#58a6ff; }\r\n        .badge.manual { background:rgba(240,136,62,0.15); color:#f0883e; }\r\n        .badge.yes { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.no { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .ptz-controls { display:grid; grid-template-columns:repeat(3, 80px); gap:8px; justify-content:center; margin:20px 0; }\r\n        .ptz-btn { width:80px; height:80px; border:1px solid #30363d; border-radius:10px; background:#161b22; color:#e0e6f0; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; }\r\n        .ptz-btn:hover { background:#238636; border-color:#238636; }\r\n        .ptz-btn.center { background:#21262d; cursor:default; }\r\n        .ptz-btn.center:hover { background:#21262d; transform:none; }\r\n        .ptz-btn:active:not(.center) { transform:scale(0.95); }\r\n        .ptz-speed { display:flex; align-items:center; gap:12px; justify-content:center; margin:16px 0; }\r\n        .ptz-speed input[type=range] { width:200px; accent-color:#58a6ff; }\r\n        .form-group { margin-bottom:16px; }\r\n        .form-group label { display:block; font-size:14px; color:#8b949e; margin-bottom:6px; }\r\n        .form-group input, .form-group select { width:100%; padding:10px 12px; background:#0d1117; border:1px solid #30363d; border-radius:6px; color:#e0e6f0; font-size:14px; }\r\n        .form-group input:focus, .form-group select:focus { outline:none; border-color:#58a6ff; }\r\n        .btn { padding:10px 20px; border:none; border-radius:6px; font-size:14px; cursor:pointer; transition:all 0.2s; }\r\n        .btn-primary { background:#238636; color:#fff; }\r\n        .btn-primary:hover { background:#2ea043; }\r\n        .btn-secondary { background:#30363d; color:#e0e6f0; }\r\n        .btn-secondary:hover { background:#484f58; }\r\n        .btn-danger { background:#da3633; color:#fff; }\r\n        .btn-danger:hover { background:#f85149; }\r\n        .btn-warning { background:#d29922; color:#0d1117; }\r\n        .btn-warning:hover { background:#e3b341; }\r\n        .btn-sm { padding:6px 12px; font-size:12px; }\r\n        .btn:disabled { opacity:0.5; cursor:not-allowed; }\r\n        .btn-group { display:flex; gap:8px; flex-wrap:wrap; }\r\n        .progress-bar { height:8px; background:#21262d; border-radius:4px; overflow:hidden; }\r\n        .progress-fill { height:100%; border-radius:4px; transition:width 0.3s; }\r\n        .progress-fill.green { background:#3fb950; }\r\n        .progress-fill.yellow { background:#d29922; }\r\n        .progress-fill.red { background:#f85149; }\r\n        .progress-fill.blue { background:#58a6ff; }\r\n        /* Advanced page status panel */\r\n        .advanced-status-panel { background:#0d1117; border:1px solid #21262d; border-radius:10px; padding:16px; margin:16px 0; }\r\n        .advanced-status-panel h4 { font-size:15px; color:#e0e6f0; margin-bottom:12px; border-bottom:1px solid #21262d; padding-bottom:8px; }\r\n        .status-row { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #21262d; font-size:14px; }\r\n        .status-row:last-child { border-bottom:none; }\r\n        .status-label { color:#8b949e; }\r\n        .status-value { color:#e0e6f0; font-family:monospace; }\r\n        .adv-header { display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap; }\r\n        .adv-header select { max-width:300px; }\r\n        .result-table { margin:16px 0; }\r\n        .progress-section { margin:16px 0; }\r\n        .progress-text { font-size:13px; color:#8b949e; margin-bottom:4px; }\r\n        .current-direction { font-size:18px; color:#58a6ff; font-family:monospace; text-align:center; padding:8px; background:#0d1117; border-radius:8px; margin:12px 0; }\r\n        .log-entry { padding:6px 12px; border-left:3px solid #30363d; margin-bottom:4px; font-size:13px; font-family:monospace; }\r\n        .log-entry.info { border-color:#58a6ff; }\r\n        .log-entry.warn { border-color:#d29922; }\r\n        .log-entry.error { border-color:#f85149; }\r\n        .log-entry.success { border-color:#3fb950; }\r\n        /* Toast notification */\r\n        .toast-container { position:fixed; top:60px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; }\r\n        .toast { padding:12px 20px; border-radius:8px; font-size:14px; animation:slideIn 0.3s ease; min-width:250px; max-width:400px; }\r\n        .toast.success { background:#1a4731; border:1px solid #3fb950; color:#3fb950; }\r\n        .toast.error { background:#4d1c1a; border:1px solid #f85149; color:#f85149; }\r\n        .toast.info { background:#1a3a52; border:1px solid #58a6ff; color:#58a6ff; }\r\n        .toast.warning { background:#4a3a1a; border:1px solid #d29922; color:#d29922; }\r\n        @keyframes slideIn { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }\r\n        /* Modal */\r\n        .modal-backdrop { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9000; display:flex; align-items:center; justify-content:center; }\r\n        .modal { background:#161b22; border:1px solid #30363d; border-radius:12px; padding:24px; width:400px; max-width:90vw; }\r\n        .modal h3 { margin-bottom:16px; font-size:18px; }\r\n        .modal .btn-group { justify-content:flex-end; margin-top:20px; }\r\n        /* Loading spinner */\r\n        .spinner { display:inline-block; width:16px; height:16px; border:2px solid #30363d; border-top-color:#58a6ff; border-radius:50%; animation:spin 0.8s linear infinite; }\r\n        @keyframes spin { to { transform:rotate(360deg); } }\r\n        .loading { pointer-events:none; opacity:0.7; }\r\n        /* Device actions */\r\n        .actions { display:flex; gap:4px; flex-wrap:wrap; }\r\n        /* PTZ status panel */\r\n        .ptz-position { text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0; font-family:monospace; font-size:14px; }\r\n        .toolbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap; }\r\n        .toolbar-actions { display:flex; gap:8px; }\r\n        .device-info-panel { background:#0d1117; border-radius:8px; padding:16px; margin-top:12px; font-size:13px; }\r\n        .device-info-panel .info-row { display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid #21262d; }\r\n        .device-info-panel .info-row:last-child { border-bottom:none; }\r\n        .device-info-panel .info-label { color:#8b949e; }\r\n        .device-info-panel .info-value { color:#e0e6f0; font-family:monospace; }\r\n        @media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-center, .console-right { width:100% !important; } }\r\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\r\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\r\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; }\r\n        .console-center { flex:1; min-width:0; display:flex; flex-direction:column; }\r\n        .console-right { flex:0 0 25%; max-width:300px; display:flex; flex-direction:column; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"header\">\r\n        <div class=\"logo\">Astro<span>Hub</span></div>\r\n        <div class=\"status-bar\">\r\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wsDot\"></span><span id=\"wsStatus\">ISAPI: 未连接</span></div>\r\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wasmDot\"></span><span id=\"wasmStatus\">视频: 未连接</span></div>\r\n            <div class=\"status-item\" id=\"clock\"></div>\r\n            <!-- 快速连接开关 -->\r\n            <div class=\"status-item\">\r\n                <span style=\"color:#8b949e;font-size:12px\">快速连接</span>\r\n                <label class=\"switch\">\r\n                    <input type=\"checkbox\" id=\"quickConnectSwitch\" onchange=\"quickConnect(this.checked)\">\r\n                    <span class=\"slider\"></span>\r\n                </label>\r\n            </div>\r\n            <!-- 重启按钮 -->\r\n            <button class=\"btn btn-secondary btn-sm\" onclick=\"confirmRestart()\" style=\"padding:2px 8px\">重启</button>\r\n            <span class=\"version\">v6.56</span>\r\n        </div>\r\n    </div>\r\n    <div class=\"nav\">\r\n        <button class=\"nav-btn active\" data-page=\"dashboard\">仪表盘</button>\r\n        <button class=\"nav-btn\" data-page=\"devices\">设备管理</button>\r\n        <button class=\"nav-btn\" data-page=\"console\">主控台</button>\r\n        <button class=\"nav-btn\" data-page=\"observation\">观测计划</button>\r\n        <!-- Advanced Features: 校准 功能测试 限位测试 速度测试 推流/存储 -->\r\n        <button class=\"nav-btn\" data-page=\"advanced\">高级功能</button>\r\n        <button class=\"nav-btn\" data-page=\"replay\">回放</button>\r\n    </div>\r\n    <div class=\"main\">\r\n        <!-- ==================== 仪表盘 ==================== -->\r\n\r\n        <!-- ==================== Page Modules ==================== -->\r\n        {% include \"includes/dashboard.html\" %}\r\n        {% include \"includes/devices.html\" %}\r\n        {% include \"includes/console.html\" %}\r\n        {% include \"includes/observation.html\" %}\r\n        {% include \"includes/advanced.html\" %}\r\n        {% include \"includes/replay.html\" %}\r\n    </div>\r\n    <!-- Toast 容器 -->\r\n    <div class=\"toast-container\" id=\"toastContainer\"></div>\r\n    <!-- Modal 容器 -->\r\n    <div id=\"modalContainer\"></div>\r\n    <!-- WASM SDK Plugin Container is in console.html -->\r\n    <script>\r\n        console.log(\"[MAIN SCRIPT] Starting script execution\");\r\n        // WASM SDK global variables (before IIFE)\r\n        var g_szDeviceIdentify = '';\r\n        var g_bLoggedIn = false;\r\n        var g_bPlaying = false;\r\n        var g_iRtspPort = 554;\r\nvar g_szDeviceIdentify2 = \"\";\r\nvar g_bLoggedIn2 = false;\r\nvar g_bPlaying2 = false;\r\nvar g_iRtspPort2 = 554;\r\nvar g_iWndIndex2 = 0;\r\nvar g_iWebSocketPort = 7681;\r\n        var g_iWndIndex = 0;\r\nvar g_iChannelList = [];\r\nvar g_iChannelID = 1;\r\n        var g_iChannelID = 1;\r\n// Global functions\r\n    (function() {\r\n        'use strict';\r\n        // ================================================================\r\n        //  Configuration\r\n        // ================================================================\r\n        var API_BASE = window.location.origin;\r\n        var WS_URL = (window.location.protocol === 'https:' ? 'wss' : 'ws') + '://' + window.location.host + '/ws';\r\n        // Cached device data\r\n        var allDevices = [];\r\n        var currentModal = null;\r\n        // --- v3: Global connected device state ---\r\n        // Advanced menu state (now sidebar)\r\n        var advMenuActive = false;\r\n        var advCurrentSub = 'calibration';\r\n        // Onboarding wizard state\r\n        var wizardState = {\r\n            step: 0,\r\n            totalSteps: 5,\r\n            mac: '',\r\n            deviceIP: '',\r\n            runningTest: false,\r[... 14586 more characters truncated]"}],"isError":false,"timestamp":1781400906551}}
{"type":"message","id":"171ee651","parentId":"baa0a24c","timestamp":"2026-06-14T01:35:15.569Z","message":{"role":"assistant","content":[{"type":"text","text":"继续读取 PTZ 控制相关代码："},{"type":"toolCall","id":"tool-9043c5682307418288005b40f6b662dd","name":"read","arguments":{"limit":500,"offset":501,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":39832,"output":54,"cacheRead":0,"cacheWrite":0,"totalTokens":39886,"cost":{"input":0.039832,"output":0.00017280000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0400048}},"stopReason":"toolUse","timestamp":1781400906551,"responseId":"cht000dada5@dx19ec3c4b824b828232"}}
{"type":"message","id":"b56aee0e","parentId":"171ee651","timestamp":"2026-06-14T01:35:15.577Z","message":{"role":"toolResult","toolCallId":"tool-9043c5682307418288005b40f6b662dd","toolName":"read","content":[{"type":"text","text":"                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '限位测试完成');\r\n                    addLog('success', '限位测试完成: ' + (resp.message || ''));\r\n                    renderLimitResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '限位测试失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded simulation)\r\n            var limitProgText = document.getElementById('limitProgressText');\r\n            var limitProgBar = document.getElementById('limitProgressBar');\r\n            var limitDirEl = document.getElementById('limitDirection');\r\n            if (limitProgText) limitProgText.textContent = '测试中... 等待设备响应';\r\n            if (limitProgBar) limitProgBar.style.width = '30%';\r\n            if (limitDirEl) { limitDirEl.textContent = '当前方向: 初始化...'; limitDirEl.style.display = 'block'; }\r\n            // simulateProgress/simulateDirections REMOVED - hardcoded fake progress\r\n        }\r\n        function renderLimitResults(results) {\r\n            var area = document.getElementById('limitResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>限位测试结果</h4>';\r\n            // P axis\r\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">P轴限位</span><span class=\"status-value\">' + pLimit[0] + ' ~ ' + pLimit[1] + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">T轴限位</span><span class=\"status-value\">' + tLimit[0] + ' ~ ' + tLimit[1] + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">翻转</span><span class=\"status-value\">' + (results.flip ? '有' : '无') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">稳定性</span><span class=\"status-value\">' + (results.stable ? '<span class=\"badge yes\">✅ 稳定</span>' : '<span class=\"badge no\">❌ 不稳定</span>') + '</span></div>';\r\n            if (results.csv_path) {\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">CSV 路径</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\r\n            }\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Speed Test (P5.4 + M4 P3)\r\n        // ================================================================\r\n        function speedTestRun() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('speedProgress').style.display = 'block';\r\n            document.getElementById('speedResultArea').innerHTML = '';\r\n            addLog('info', '速度测试开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '速度测试完成');\r\n                    addLog('success', '速度测试完成: ' + (resp.message || ''));\r\n                    renderSpeedResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '速度测试失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded speed labels)\r\n            var speedProgText = document.getElementById('speedProgressText');\r\n            var speedProgBar = document.getElementById('speedProgressBar');\r\n            if (speedProgText) speedProgText.textContent = '测试中... 等待设备响应';\r\n            if (speedProgBar) speedProgBar.style.width = '30%';\r\n            // REMOVED simulateProgress (was hardcoded: '速度档位 1', '50', '100')\r\n            // Speed results now display actual values returned from backend\r\n        }\r\n        function renderSpeedResults(results) {\r\n            var area = document.getElementById('speedResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>速度测试结果</h4>';\r\n            // Speed mapping table\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            var mapKeys = Object.keys(speedMap);\r\n            if (mapKeys.length > 0) {\r\n                html += '<table class=\"result-table\" style=\"margin:12px 0\"><thead><tr><th>速度档位</th><th>实际速率 (°/s)</th></tr></thead><tbody>';\r\n                mapKeys.forEach(function(k) {\r\n                    html += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\r\n                });\r\n                html += '</tbody></table>';\r\n            }\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">拟合曲线 R²</span><span class=\"status-value\">' + (results.r_squared || results.r2 || '--') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">精度</span><span class=\"status-value\">' + (results.accuracy || '--') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">通过</span><span class=\"status-value\">' + (results.passed ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>') + '</span></div>';\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Progress Simulation\r\n        // ================================================================\r\n        function simulateProgress(textId, barId, totalSteps, labels) {\r\n            var current = 0;\r\n            var interval = setInterval(function() {\r\n                current++;\r\n                if (current > totalSteps) { clearInterval(interval); return; }\r\n                var pct = Math.round((current / totalSteps) * 100);\r\n                var textEl = document.getElementById(textId);\r\n                var barEl = document.getElementById(barId);\r\n                if (textEl) textEl.textContent = labels ? labels[current-1] : '处理中... ' + current + '/' + totalSteps;\r\n                if (barEl) barEl.style.width = pct + '%';\r\n            }, 2000);\r\n        }\r\n        function simulateDirections() {\r\n            var dirs = ['P+ 移动中...', 'P- 移动中...', 'T+ 移动中...', 'T- 移动中...'];\r\n            var i = 0;\r\n            var interval = setInterval(function() {\r\n                var el = document.getElementById('limitDirection');\r\n                if (!el) { clearInterval(interval); return; }\r\n                if (i >= dirs.length) { clearInterval(interval); el.textContent = '测试完成 ✓'; el.style.color = '#3fb950'; return; }\r\n                el.textContent = '当前方向: ' + dirs[i];\r\n                i++;\r\n            }, 3000);\r\n        }\r\n        // ================================================================\r\n        //  Connect Device Page (高级功能 -> 连接设备)\r\n        // ================================================================\r\n        function onConnectDeviceChange() {\r\n            var ip = document.getElementById('advConnectDevice').value;\r\n            var noDevice = document.getElementById('connectNoDevice');\r\n            var controlArea = document.getElementById('connectControlArea');\r\n            var statusSpan = document.getElementById('connectDeviceStatus');\r\n            if (ip) {\r\n                var device = allDevices.find(function(d) { return d.ip === ip; });\r\n                noDevice.style.display = 'none';\r\n                controlArea.style.display = 'block';\r\n                statusSpan.textContent = device ? ('已连接: ' + ip) : ip;\r\n            } else {\r\n                noDevice.style.display = 'block';\r\n                controlArea.style.display = 'none';\r\n                statusSpan.textContent = '';\r\n            }\r\n        }\r\n        // 功能检测（连接设备页面版）\r\n        function connectFuncDetectRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectFuncRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 探测中...';\r\n            document.getElementById('connectFuncProgress').style.display = 'block';\r\n            document.getElementById('connectFuncResultMini').innerHTML = '';\r\n            addLog('info', '功能检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/function/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '功能检测完成');\r\n                    addLog('success', '功能检测完成: ' + (resp.message || ''));\r\n                    renderConnectFuncResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'function');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '探测失败');\r\n                    addLog('error', '功能检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectFuncResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '探测失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                showToast('error', '探测异常: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectFuncDetectRun\r\n        }\r\n        function renderConnectFuncResultMini(results) {\r\n            var area = document.getElementById('connectFuncResultMini');\r\n            var keys = Object.keys(results);\r\n            var supported = 0, total = keys.length;\r\n            keys.forEach(function(k) { if (results[k] && results[k].supported) supported++; });\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#3fb950\">✅ 支持 ' + supported + '/' + total + ' 项功能</span>';\r\n        }\r\n        // 限位检测（连接设备页面版）\r\n        function connectLimitTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectLimitRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('connectLimitProgress').style.display = 'block';\r\n            document.getElementById('connectLimitResultMini').innerHTML = '';\r\n            addLog('info', '限位检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/limit/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '限位检测完成');\r\n                    addLog('success', '限位检测完成: ' + (resp.message || ''));\r\n                    renderConnectLimitResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'limit');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '限位检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectLimitResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '测试失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectLimitTestRun\r\n        }\r\n        function renderConnectLimitResultMini(results) {\r\n            var area = document.getElementById('connectLimitResultMini');\r\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#d29922\">P: ' + pLimit[0] + '~' + pLimit[1] + ' | T: ' + tLimit[0] + '~' + tLimit[1] + '</span>';\r\n        }\r\n        // 速度检测（连接设备页面版）\r\n        function connectSpeedTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectSpeedRun');\r[... 15315 more characters truncated]"}],"isError":false,"timestamp":1781400915577}}
{"type":"message","id":"1ae1b0be","parentId":"b56aee0e","timestamp":"2026-06-14T01:35:22.723Z","message":{"role":"assistant","content":[{"type":"text","text":"继续读取 PTZ 移动和 WASM 相关代码："},{"type":"toolCall","id":"tool-3337f12cfd2d4ff59dfeddba9b23a2a8","name":"read","arguments":{"limit":500,"offset":1001,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":46732,"output":57,"cacheRead":0,"cacheWrite":0,"totalTokens":46789,"cost":{"input":0.046731999999999996,"output":0.00018240000000000002,"cacheRead":0,"cacheWrite":0,"total":0.046914399999999995}},"stopReason":"toolUse","timestamp":1781400915577,"responseId":"cht000da1d6@dx19ec3c4db5fba5d322"}}
{"type":"message","id":"8995fb00","parentId":"1ae1b0be","timestamp":"2026-06-14T01:35:22.730Z","message":{"role":"toolResult","toolCallId":"tool-3337f12cfd2d4ff59dfeddba9b23a2a8","toolName":"read","content":[{"type":"text","text":"                    if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#d29922\">未获取到预置点</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#f85149\">获取失败: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function ptzGotoSelectedPreset() {\r\n            var dev = window.connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            if (!presetId) { showToast('warning', '请先选择预置点'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '跳转到预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId, null).then(function(resp) {\r\n                if (resp && resp.success !== false) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已前往预置点 ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 跳转失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function ptzSetSelectedPreset() {\r\n            var dev = window.connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            if (!presetId) { showToast('warning', '请先选择预置点编号'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '保存当前位置为预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId + '/set', null).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已保存预置点 ' + presetId + '</span>';\r\n                    loadPresetList(); // refresh\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 保存失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function findMacByIP(ip) {\r\n            var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n            return dev ? dev.mac : '';\r\n        }\r\n        // PTZ Speed Slider\r\n        function initPtzSpeed() {\r\n            var slider = document.getElementById('ptzSpeed');\r\n            if (slider) {\r\n                slider.addEventListener('input', function(e) {\r\n                    document.getElementById('ptzSpeedVal').textContent = e.target.value;\r\n                });\r\n            }\r\n        }\r\n        // Mouse/Touch Up - stop PTZ\r\n        function initMouseUp() {\r\n            document.addEventListener('mouseup', function() { ptzStop(); });\r\n            document.addEventListener('touchend', function() { ptzStop(); });\r\n        }\r\n        // Clock\r\n        function updateClock() {\r\n            var clock = document.getElementById('clock');\r\n            if (clock) clock.textContent = new Date().toLocaleTimeString('zh-CN');\r\n        }\r\n        // Toast Notifications\r\n        function showToast(type, message) {\r\n            var container = document.getElementById('toastContainer');\r\n            var toast = document.createElement('div');\r\n            toast.className = 'toast ' + type;\r\n            toast.textContent = message;\r\n            container.appendChild(toast);\r\n            setTimeout(function() {\r\n                if (toast.parentNode) toast.parentNode.removeChild(toast);\r\n            }, 4000);\r\n        }\r\n        // Logging\r\n        function addLog(level, msg) {\r\n            var c = document.getElementById('logContainer');\r\n            if (!c) return;\r\n            var d = document.createElement('div');\r\n            d.className = 'log-entry ' + level;\r\n            d.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\r\n            c.insertBefore(d, c.firstChild);\r\n            if (c.children.length > 50) c.removeChild(c.lastChild);\r\n        }\r\n        // WebSocket\r\n        function connectWS() {\r\n            try {\r\n                var ws = new WebSocket(WS_URL);\r\n                ws.onopen = function() {\r\n                    addLog('info', 'WebSocket 已连接');\r\n                };\r\n                ws.onclose = function() {\r\n                    setTimeout(connectWS, 3000);\r\n                };\r\n                ws.onmessage = function(e) {\r\n                    try {\r\n                        var data = JSON.parse(e.data);\r\n                        if (data.type === 'health') updateHealth(data);\r\n                    } catch(err) {}\r\n                };\r\n            } catch(e) {\r\n                addLog('warn', 'WebSocket 连接失败');\r\n            }\r\n        }\r\n        function updateHealth(data) {\r\n            var s = data.system || {};\r\n            if (s.cpu !== undefined) {\r\n                var bar = document.getElementById('cpuBar');\r\n                bar.style.width = s.cpu + '%';\r\n                bar.className = 'progress-fill ' + (s.cpu < 60 ? 'green' : s.cpu < 85 ? 'yellow' : 'red');\r\n                document.getElementById('cpuVal').textContent = s.cpu + '%';\r\n            }\r\n            if (s.memory !== undefined) {\r\n                var bar = document.getElementById('memBar');\r\n                bar.style.width = s.memory + '%';\r\n                bar.className = 'progress-fill ' + (s.memory < 60 ? 'green' : s.memory < 85 ? 'yellow' : 'red');\r\n                document.getElementById('memVal').textContent = s.memory + '%';\r\n            }\r\n            if (s.disk !== undefined) {\r\n                var bar = document.getElementById('diskBar');\r\n                bar.style.width = s.disk + '%';\r\n                bar.className = 'progress-fill ' + (s.disk < 70 ? 'green' : s.disk < 90 ? 'yellow' : 'red');\r\n                document.getElementById('diskVal').textContent = s.disk + '%';\r\n            }\r\n        }\r\n        // SADP Discovery\r\n        function discoverDevices() {\r\n            var btn = document.getElementById('btnDiscover');\r\n            var spinner = document.getElementById('discoverSpinner');\r\n            btn.disabled = true;\r\n            spinner.style.display = 'inline-block';\r\n            addLog('info', 'SADP 设备发现开始...');\r\n            showToast('info', '正在扫描局域网设备 (10s)...');\r\n            apiGet('/api/v1/discovery/sadp').then(function(data) {\r\n                if (data.success) {\r\n                    addLog('success', 'SADP 发现 ' + data.count + ' 台设备: ' + data.message);\r\n                    showToast('success', data.message);\r\n                    refreshDevices();\r\n                } else {\r\n                    addLog('error', '发现失败: ' + (data.message || '未知错误'));\r\n                    showToast('error', data.message || '发现失败');\r\n                }\r\n            }).catch(function(e) {\r\n                addLog('error', 'SADP 发现异常: ' + e.message);\r\n                showToast('error', 'SADP 发现异常: ' + e.message);\r\n            }).finally(function() {\r\n                spinner.style.display = 'none';\r\n                btn.disabled = false;\r\n            });\r\n        }\r\n        // Device List\r\n        var _sadpAutoRunning = false;\r\n        function autoSadpDiscover() {\r\n            if (_sadpAutoRunning) return;\r\n            _sadpAutoRunning = true;\r\n            apiGet('/api/v1/discovery/sadp').then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', 'SADP 发现 ' + (result.count || 0) + ' 台设备');\r\n                }\r\n                refreshDevices();  // 刷新设备列表（含网关信息）\r\n                _sadpAutoRunning = false;\r\n            }).catch(function(e) {\r\n                _sadpAutoRunning = false;\r\n            });\r\n        }\r\n        function refreshDevices() {\r\n            console.log('[REFRESH] refreshDevices called');\r\n            return apiGet('/api/v1/devices').then(function(result) {\r\n                console.log('[REFRESH] API response:', result);\r\n                if (!result.success) {\r\n                    allDevices = [];\r\n                    renderDevices([]);\r\n                    return;\r\n                }\r\n                allDevices = result.data || [];\r\n                renderDevices(allDevices);\r\n                // Update dashboard counters\r\n                var online = allDevices.filter(function(d) { return d.online; }).length;\r\n                var countEl = document.getElementById('devCount');\r\n                if (countEl) countEl.textContent = allDevices.length;\r\n                var onlineEl = document.getElementById('devOnline');\r\n                if (onlineEl) onlineEl.textContent = online;\r\n                var totalEl = document.getElementById('devTotal');\r\n                if (totalEl) totalEl.textContent = allDevices.length;\r\n                // Update PTZ & advanced device dropdowns\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n            }).catch(function(e) {\r\n                console.warn('Failed to refresh devices:', e);\r\n            });\r\n        }\r\n        function renderDevices(devices) {\r\n            var tb = document.getElementById('deviceTable');\r\n            if (!tb) return;\r\n            if (!devices.length) {\r\n                tb.innerHTML = '<tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">暂无设备</td></tr>';\r\n                return;\r\n            }\r\n            var html = devices.map(function(d) {\r\n                var sourceBadge = d.source === 'sadp'\r\n                    ? '<span class=\"badge sadp\">SADP</span>'\r\n                    : '<span class=\"badge manual\">手动</span>';\r\n                var onlineBadge = d.online\r\n                    ? '<span class=\"badge online\">在线</span>'\r\n                    : '<span class=\"badge offline\">离线</span>';\r\n                var actions = buildDeviceActions(d);\r\n                return '<tr>'\r\n                    + '<td>' + sourceBadge + '</td>'\r\n                    + '<td>' + (d.mac || '--') + '</td>'\r\n                    + '<td>' + (d.ip || '--') + '</td>'\r\n                    + '<td>' + (d.gateway || '--') + '</td>'\r\n                    + '<td>' + (d.name || d.device_name || '--') + '</td>'\r\n                    + '<td>' + (d.model || '--') + '</td>'\r\n                    + '<td>' + onlineBadge + '</td>'\r\n                    + '<td>' + actions + '</td>'\r\n                    + '</tr>';\r\n            }).join('');\r\n            tb.innerHTML = html;\r\n        }\r\n        function buildDeviceActions(d) {\r\n            var btns = [];\r\n            var isConnected = window.connectedDevice && window.connectedDevice.ip === d.ip;\r\n            // v6.35: 连接开关（只有一个设备可连接）\r\n            var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\r\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\'' + d.ip + '\\', this.checked)\" /><span class=\"slider\"></span></label>';\r\n            btns.push(switchHtml);\r\n            // v6.35: 信息按钮（弹窗显示设备详情）\r\n            btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoModal(\\'' + d.ip + '\\')\">信息</button>');\r\n            // Add modify IP button for all devices\r\n            btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\'' + (d.mac || '') + '\\',\\'' + (d.ip || '') + '\\')\">修改IP</button>');\r\n            btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\')\">删除</button>');\r\n            return '<div class=\"actions\" style=\"display:flex;align-items:center;gap:8px\">' + btns.join('') + '</div>';\r\n        }\r\n        // v6.35: 切换设备连接状态\r\n        window.toggleDeviceConnect = function(ip, checked) {\r\n            if (checked) {\r\n                connectDevice(ip);\r\n            } else {\r\n                disconnectDevice(ip);\r\n            }\r\n        };\r\n        // v6.35: 显示设备信息弹窗\r\n        window.showDeviceInfoModal = function(ip) {\r\n            var d = allDevices.find(function(dev) { return dev.ip === ip; }) || {};\r\n            var info = '<div style=\"font-size:14px;line-height:1.8\">' +\r\n                '<p><b>IP:</b> ' + (d.ip || '--') + '</p>' +\r\n                '<p><b>MAC:</b> ' + (d.mac || '--') + '</p>' +\r\n                '<p><b>名称:</b> ' + (d.name || d.device_name || '--') + '</p>' +\r\n                '<p><b>型号:</b> ' + (d.model || '--') + '</p>' +\r\n                '<p><b>网关:</b> ' + (d.gateway || '--') + '</p>' +\r\n                '<p><b>子网掩码:</b> ' + (d.subnet || '--') + '</p>' +\r\n                '<p><b>端口:</b> ' + (d.port || 80) + '</p>' +\r\n                '</div>';\r\n            if (window.showModal) {\r\n                showModal('设备信息', info);\r\n            } else {\r\n                alert(info);\r\n            }\r\n        };\r\n        // v6.54: 连接/断开操作锁\r\n        var _connectionOperationInProgress = false;\r\n        \r\n        // Device Actions\r\n        function connectDevice(ip) {\r\n            // v6.54: 防止重复点击\r\n            if (_connectionOperationInProgress) {\r\n                showToast('warning', '请等待上一次操作完成');\r\n                return;\r\n            }\r\n            _connectionOperationInProgress = true;\r\n            \r\n            addLog('info', '正在连接设备: ' + ip);\r\n            showToast('info', '正在连接设备...');\r\n            \r\n            // 禁用连接按钮\r\n            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(false);\r\n            \r\n            // 先获取 credentials\r\n            apiGet('/api/v1/ptz/devices/' + ip + '/credentials').then(function(creds) {\r\n                var username = (creds && creds.success) ? creds.username : 'admin';\r\n                var password = (creds && creds.success) ? creds.password : '';\r\n                var port = (creds && creds.success) ? (creds.port || 80) : 80;\r\n\r\n                // 再调用 connect API\r\n                apiPost('/api/v1/devices/' + ip + '/connect', { username: username, password: password, port: port }).then(function(result) {\r\n                    if (result && result.success) {\r\n                        addLog('success', result.message || '连接成功');\r\n                        // Set connectedDevice BEFORE refreshDevices\r\n                        var dev = allDevices.find(function(d) { return d.ip === ip; }) || { ip: ip };\r\n                        window.connectedDevice = {\r\n                            ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\r\n                            mac: dev.mac || '', username: username, password: password, port: port, online: true\r\n                        };\r\n                        // Update button immediately\r\n                        if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                        // 动态加载设备图像参数（白平衡、快门、光圈、降噪、锐度、OSD）\r\n                        // v5.42: 增加延迟确保设备连接完成\r\n                        setTimeout(function() {\r\n                            console.log('[CONNECT] Calling loadDeviceImageParams for:', ip);\r\n                            if (typeof loadDeviceImageParams === 'function') {\r\n                                loadDeviceImageParams(ip);\r\n                                console.log('[CONNECT] loadDeviceImageParams called');\r\n                            } else {\r\n                                console.error('[CONNECT] loadDeviceImageParams not found');\r\n                            }\r\n                        }, 500);\r\n                        // WASM SDK login (with loading indicator)\r\n                        showToast('info', '正在初始化视频流...');\r\n                        if (window.clickLogin2) { window.clickLogin2(); }\r\n                        \r\n                        // v6.54: 等待视频播放后启用按钮\r[... 10249 more characters truncated]"}],"isError":false,"timestamp":1781400922730}}
{"type":"message","id":"0fb88d60","parentId":"8995fb00","timestamp":"2026-06-14T01:35:27.737Z","message":{"role":"assistant","content":[{"type":"text","text":"继续读取 PTZ 移动和 WASM 相关代码："},{"type":"toolCall","id":"call_a1f0b7564b22456dbc840697","name":"read","arguments":{"limit":500,"offset":1501,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":58325,"output":58,"cacheRead":0,"cacheWrite":0,"totalTokens":58383,"cost":{"input":0.058324999999999995,"output":0.0001856,"cacheRead":0,"cacheWrite":0,"total":0.058510599999999996}},"stopReason":"toolUse","timestamp":1781400922731,"responseId":"cht000d5126@dx19ec3c4f0f9ba5e412"}}
{"type":"message","id":"99a3638d","parentId":"0fb88d60","timestamp":"2026-06-14T01:35:27.745Z","message":{"role":"toolResult","toolCallId":"call_a1f0b7564b22456dbc840697","toolName":"read","content":[{"type":"text","text":"            if (!window._presetLoadedFor || window._presetLoadedFor !== ip) {\r\n                loadPresetList();\r\n                window._presetLoadedFor = ip;\r\n            }\r\n        }\r\n        // PTZ operation log display\r\n        function ptzLog(msg, type='info') {\r\n            const box = document.getElementById('ptzLogBox');\r\n            if (!box) { console.warn('[ptzLog] ptzLogBox not found'); return; }\r\n            const time = new Date().toLocaleTimeString();\r\n            const colors = {\r\n                'info': '#8b949e',\r\n                'success': '#3fb950',\r\n                'error': '#f85149',\r\n                'warning': '#d29922',\r\n                'debug': '#58a6ff'\r\n            }; \r\n            const icons = {\r\n                'info': '○',\r\n                'success': '●',\r\n                'error': '×',\r\n                'warning': '△',\r\n                'debug': '◇'\r\n            }; \r\n            const color = colors[type] || '#8b949e';\r\n            const icon = icons[type] || '○';\r\n            const entry = document.createElement('div');\r\n            entry.style.cssText = 'color:' + color + ';margin:2px 0;padding:2px 8px;font-size:13px;font-family:monospace';\r\n            entry.textContent = '[' + time + '] ' + icon + ' ' + msg;\r\n            box.insertBefore(entry, box.firstChild);\r\n            if (box.children.length > 50) box.removeChild(box.lastChild);\r\n            console.log('[ptzLog]', msg, type);\r\n            \r\n            // v6.40: 发送操作日志到后端\r\n            if (typeof apiPost === 'function') {\r\n                try {\r\n                    apiPost('/api/v1/log/operation', {\r\n                        level: type.toUpperCase(),\r\n                        module: 'web',\r\n                        action: 'ptz',\r\n                        detail: msg\r\n                    }).catch(function(e) { console.warn('[LOG] send failed:', e); });\r\n                } catch(e) {}\r\n            }\r\n        }\r\n        window.ptzLog = ptzLog;\r\n        // PTZ Controls\r\n        function ptzMove(dir) {\r\n            var dev = window.connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir, speed: speed\r\n            }).then(function(result) {\r\n                if (result && !result.success) {\r\n                    showToast('error', result.message || '移动失败');\r\n                    addLog('error', 'PTZ 移动失败: ' + (result.message || ''));\r\n                }\r\n            }).catch(function(e) {\r\n                addLog('info', 'PTZ 移动: ' + dir);\r\n            });\r\n        }\r\n        function ptzHome() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/home', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || '归位成功');\r\n                } else if (result) {\r\n                    showToast('error', result.message || '归位失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '归位异常: ' + e.message);\r\n            });\r\n        }\r\n        function ptzStop() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiPost('/api/v1/ptz/' + dev + '/stop', null).catch(function(e) {});\r\n        }\r\n        function getPtzPosition() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiGet('/api/v1/ptz/' + dev + '/position').then(function(result) {\r\n                var posEl = document.getElementById('ptzPosition');\r\n                if (result && result.success && result.data) {\r\n                    var p = result.data;\r\n                    posEl.innerHTML = 'Pan: ' + (p.pan || 0) + ' | Tilt: ' + (p.tilt || 0) + ' | Zoom: ' + (p.zoom || 0);\r\n                } else {\r\n                    posEl.innerHTML = 'Pan: -- | Tilt: -- | Zoom: --';\r\n                }\r\n            }).catch(function(e) {});\r\n        }\r\n        // Calibration (placeholder)\r\n        function calibrate(type) {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先连接设备'); return; }\r\n            var dev = window.connectedDevice.ip;\r\n            apiPost('/api/v1/calibration/' + dev + '/' + type, null).then(function(r) {\r\n                if (r.ok !== false) addLog('info', '开始 ' + type + ' 校准...');\r\n            }).catch(function(e) { addLog('error', '校准失败'); });\r\n        }\r\n        // ASCOM (placeholder)\r\n        function connectAscom(type) {\r\n            apiPost('/api/v1/ascom/' + type + '/connect', null).then(function(r) {\r\n                if (r && r.success !== false) {\r\n                    showToast('success', type + ' 连接成功');\r\n                    addLog('info', type + ' 连接成功');\r\n                }\r\n            }).catch(function(e) { addLog('error', type + ' 连接失败'); });\r\n        }\r\n        // Settings (placeholder)\r\n        function saveSettings() {\r\n            apiPost('/api/v1/settings', {\r\n                port: parseInt(document.getElementById('settingPort').value),\r\n                log_level: document.getElementById('settingLogLevel').value,\r\n                db_path: document.getElementById('settingDbPath').value\r\n            }).then(function() {\r\n                addLog('info', '设置已保存');\r\n                showToast('success', '设置已保存');\r\n            }).catch(function(e) { showToast('error', '保存失败'); });\r\n        }\r\n        // Stream / Storage Controls\r\n        function refreshStreamDeviceList() {\r\n            var online = (allDevices || []).filter(function(d) { return d.online; });\r\n            var sel = document.getElementById('advStreamDevice');\r\n            if (!sel) return;\r\n            var current = sel.value;\r\n            sel.innerHTML = '<option value=\"\">未连接设备</option>';\r\n            online.forEach(function(d) {\r\n                var option = document.createElement('option');\r\n                option.value = d.ip;\r\n                option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                sel.appendChild(option);\r\n            });\r\n            if (current) sel.value = current;\r\n        }\r\n        function onStreamDeviceChange() {\r\n            var ip = document.getElementById('advStreamDevice').value;\r\n            var noDevice = document.getElementById('streamNoDevice');\r\n            var controlArea = document.getElementById('streamControlArea');\r\n            var statusSpan = document.getElementById('streamDeviceStatus');\r\n            if (ip) {\r\n                var device = allDevices.find(function(d) { return d.ip === ip; });\r\n                noDevice.style.display = 'none';\r\n                controlArea.style.display = 'block';\r\n                statusSpan.textContent = device ? ('已连接: ' + ip) : ip;\r\n                resetStreamButtons();\r\n            } else {\r\n                noDevice.style.display = 'block';\r\n                controlArea.style.display = 'none';\r\n                statusSpan.textContent = '';\r\n            }\r\n        }\r\n        function resetStreamButtons() {\r\n            document.getElementById('btnStreamStart').disabled = false;\r\n            document.getElementById('btnStreamStop').disabled = true;\r\n            document.getElementById('btnRecordStart').disabled = false;\r\n            document.getElementById('btnRecordStop').disabled = true;\r\n            document.getElementById('streamStatusInfo').textContent = '状态: 未启动';\r\n            document.getElementById('recordStatusInfo').textContent = '状态: 未录制';\r\n        }\r\n        function streamStart() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceId = window.connectedDevice.ip;\r\n            var device = allDevices.find(function(d) { return d.ip === deviceId; });\r\n            document.getElementById('btnStreamStart').disabled = true;\r\n            document.getElementById('streamStatusInfo').textContent = '状态: 正在启动...';\r\n            var url = '/api/v1/streams/' + deviceId + '/start';\r\n            // Add query params for rtsp_url and stream_name\r\n            // The API accepts query parameters\r\n            apiPost(url + '?stream_name=' + encodeURIComponent((device && device.device_name) || device.ip), null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '推流已启动: ' + deviceId);\r\n                    addLog('success', result.message || '推流启动成功');\r\n                    document.getElementById('btnStreamStop').disabled = false;\r\n                    document.getElementById('streamStatusInfo').textContent = '状态: 推流中 (Stream: ' + (result.stream_id || deviceId) + ')';\r\n                    // Set HLS preview URL if available\r\n                    if (result.stream_id) {\r\n                        var video = document.getElementById('streamVideo');\r\n                        var preview = document.getElementById('streamPreview');\r\n                        if (video && preview) {\r\n                            // Try HLS source\r\n                            var hlsSrc = '/hls/' + result.stream_id + '/playlist.m3u8';\r\n                            video.src = hlsSrc;\r\n                            preview.style.display = 'block';\r\n                        }\r\n                    }\r\n                    resetAdvancedSelectors();\r\n                } else {\r\n                    showToast('error', result ? result.message : '推流启动失败');\r\n                    document.getElementById('btnStreamStart').disabled = false;\r\n                    document.getElementById('streamStatusInfo').textContent = '状态: 启动失败';\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '推流异常: ' + e.message);\r\n                document.getElementById('btnStreamStart').disabled = false;\r\n                document.getElementById('streamStatusInfo').textContent = '状态: 异常';\r\n            });\r\n        }\r\n        function streamStop() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceId = window.connectedDevice.ip;\r\n            apiPost('/api/v1/streams/' + deviceId + '/stop', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '推流已停止: ' + deviceId);\r\n                    addLog('info', '推流已停止');\r\n                    document.getElementById('btnStreamStart').disabled = false;\r\n                    document.getElementById('btnStreamStop').disabled = true;\r\n                    document.getElementById('streamStatusInfo').textContent = '状态: 未启动';\r\n                    document.getElementById('streamPreview').style.display = 'none';\r\n                } else {\r\n                    showToast('error', result ? result.message : '推流停止失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '推流异常: ' + e.message);\r\n            });\r\n        }\r\n        function recordStart() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceId = window.connectedDevice.ip;\r\n            var targetName = document.getElementById('recordTargetName').value.trim();\r\n            var body = targetName ? { target_name: targetName } : null;\r\n            document.getElementById('btnRecordStart').disabled = true;\r\n            document.getElementById('recordStatusInfo').textContent = '状态: 正在录制...';\r\n            apiPost('/api/v1/ptz/' + deviceId + '/record/start', body).then(function(result) {\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n            }\r\n            \r\n            if (liveStackMode === 'off') {\r\n                showToast('warning', '请先选择叠加档位');\r\n                return;\r\n            }\r\n            \r\n            var deviceIp = window.connectedDevice.ip;\r\n            var hardwareMs = parseFloat(document.getElementById('hardwareExposureMs').value) || 100;\r\n            \r\n            // 根据档位计算目标曝光\r\n            var exposureMap = {\r\n                '2s': 2, '5s': 5, '10s': 10, '30s': 30\r\n            };\r\n            var targetExposure = parseFloat(exposureMap[liveStackMode]) || 2;\r\n            \r\n            // 启动 Live Stack\r\n            apiPost('/api/v1/stack/start', {\r\n                device_ip: deviceIp,\r\n                target_exposure: targetExposure,\r\n                hardware_exposure_ms: hardwareMs,\r\n                mode: 'live'\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    liveStackRunning = true;\r\n                    liveStackTargetFrames = result.target_frames;\r\n                    liveStackFrameCount = 0;\r\n                    \r\n                    showToast('success', 'Live Stack 已启动: ' + result.target_frames + '帧');\r\n                    \r\n                    // 更新按钮状态\r\n                    document.getElementById('btnLiveStackStart').disabled = true;\r\n                    document.getElementById('btnLiveStackStop').disabled = false;\r\n                    document.getElementById('btnLiveStackSave').disabled = true;\r\n                    \r\n                    // 开始采集帧\r\n                    liveStackInterval = setInterval(captureAndSendFrame, hardwareMs);\r\n                } else {\r\n                    showToast('error', result ? result.message : '启动失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '启动异常: ' + e.message);\r\n            });\r\n        }\r\n        \r\n        function captureAndSendFrame() {\r\n            if (!liveStackRunning) return;\r\n            \r\n            // 从 WASM Canvas 截图\r\n            var canvas = document.querySelector('#divPlugin canvas');\r\n            if (!canvas) {\r\n                // 尝试其他方式\r\n                canvas = document.getElementById('divPlugin').querySelector('canvas');\r\n            }\r\n            \r\n            if (!canvas) {\r\n                console.warn('[LiveStack] Canvas not found');\r\n                return;\r\n            }\r\n            \r\n            try {\r\n                var imageData = canvas.toDataURL('image/jpeg', 0.85);\r\n                \r\n                // 发送到后端\r\n                apiPost('/api/v1/stack/frame', {\r\n                    device_ip: window.connectedDevice.ip,\r\n                    frame_data: imageData\r\n                }).then(function(result) {\r\n                    if (result && result.success) {\r\n                        liveStackFrameCount = result.frame_count;\r\n                        var progress = Math.round(liveStackFrameCount / liveStackTargetFrames * 100);\r\n                        \r\n                        // 更新状态\r\n                        document.getElementById('liveStackStatus').textContent =\r\n                            '叠加: ' + liveStackFrameCount + '/' + liveStackTargetFrames + ' (' + progress + '%)';\r\n                        \r\n                        // 更新预览\r\n                        if (result.preview_base64) {\r\n                            // 可以显示预览（可选）\r\n                        }\r\n                        \r\n                        // 检查是否完成\r\n                        if (liveStackFrameCount >= liveStackTargetFrames) {\r\n                            stopLiveStack();\r\n                            showToast('success', '叠加完成');\r\n                            document.getElementById('btnLiveStackSave').disabled = false;\r\n                        }\r\n                    }\r\n                }).catch(function(e) {\r\n                    console.warn('[LiveStack] Frame send error:', e.message);\r\n                });\r\n            } catch (e) {\r\n\n[835 more lines in file. Use offset=2001 to continue.][... 9799 more characters truncated]"}],"isError":false,"timestamp":1781400927745}}
{"type":"message","id":"d9be4244","parentId":"99a3638d","timestamp":"2026-06-14T01:35:37.733Z","message":{"role":"assistant","content":[{"type":"text","text":"让我继续读取 WASM 相关代码和 PTZ 速度相关的后端代码："},{"type":"toolCall","id":"call_7be07268557347d09414f757","name":"read","arguments":{"limit":500,"offset":2001,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}},{"type":"toolCall","id":"call_52d8e3f79fd34c078964f50b","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py","limit":200}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":64994,"output":100,"cacheRead":0,"cacheWrite":0,"totalTokens":65094,"cost":{"input":0.064994,"output":0.00032,"cacheRead":0,"cacheWrite":0,"total":0.065314}},"stopReason":"toolUse","timestamp":1781400927746,"responseId":"cht000e3653@dx19ec3c5126eb893102"}}
{"type":"message","id":"bd80428a","parentId":"d9be4244","timestamp":"2026-06-14T01:35:37.748Z","message":{"role":"toolResult","toolCallId":"call_7be07268557347d09414f757","toolName":"read","content":[{"type":"text","text":"                console.warn('[LiveStack] Capture error:', e.message);\r\n            }\r\n        }\r\n        \r\n        function stopLiveStack() {\r\n            liveStackRunning = false;\r\n            \r\n            if (liveStackInterval) {\r\n                clearInterval(liveStackInterval);\r\n                liveStackInterval = null;\r\n            }\r\n            \r\n            // 更新按钮状态\r\n            document.getElementById('btnLiveStackStart').disabled = false;\r\n            document.getElementById('btnLiveStackStop').disabled = true;\r\n            \r\n            document.getElementById('liveStackStatus').textContent =\r\n                '叠加: 已停止 (' + liveStackFrameCount + '帧)';\r\n        }\r\n        \r\n        function saveLiveStack() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n                showToast('warning', '设备未连接');\r\n                return;\r\n            }\r\n            \r\n            apiPost('/api/v1/stack/finish', {\r\n                device_ip: window.connectedDevice.ip,\r\n                save_output: true\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '已保存: ' + (result.fits_path || result.jpg_path));\r\n                    document.getElementById('btnLiveStackSave').disabled = true;\r\n                } else {\r\n                    showToast('error', result ? result.message : '保存失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '保存异常: ' + e.message);\r\n            });\r\n        }\r\n        \r\n        // 画面调节\r\n        function adjustImage(param, value) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            var labels = {brightness:'亮度',contrast:'对比度',saturation:'饱和度'};\r\n            var label = labels[param] || param;\r\n            \r\n            // 调用 API 更新\r\n            var body = {};\r\n            body[param] = parseInt(value);\r\n            apiPut('/api/v1/ptz/' + dev + '/image/settings', body).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', label + '已设置为 ' + value);\r\n                } else {\r\n                    showToast('error', result ? result.message : '设置失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '设置异常: ' + e.message);\r\n            });\r\n        }\r\n        function adjustImageStep(param, delta) {\r\n            var sliderId = 'console' + param.charAt(0).toUpperCase() + param.slice(1);\r\n            var slider = document.getElementById(sliderId);\r\n            if (!slider) return;\r\n            var newValue = Math.max(0, Math.min(100, parseInt(slider.value) + delta));\r\n            slider.value = newValue;\r\n            adjustImage(param, newValue);\r\n        }\r\n        // PTZ 坐标显示开关\r\n        function togglePtzOsd(enabled) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            // 更新按钮状态（v5.46: 使用正确的按钮 ID）\r\n            window.updatePtzOsdButtons(enabled);\r\n            apiPost('/api/v1/ptz/' + dev + '/osd/ptz', { enabled: enabled }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || 'PTZ OSD: ' + (enabled ? '显示' : '关闭'));\r\n                } else {\r\n                    showToast('error', result ? result.message : 'PTZ OSD 切换失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', 'PTZ OSD 切换异常: ' + e.message); });\r\n        }\r\n        // OSD 信息显示开关（用户自定义、日期时间等）\r\n        function toggleInfoOsd(enabled) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            // 更新按钮状态（v5.46: 使用正确的按钮 ID）\r\n            window.updateInfoOsdButtons(enabled);\r\n            apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || 'Info OSD: ' + (enabled ? '显示' : '关闭'));\r\n                } else {\r\n                    showToast('error', result ? result.message : 'OSD 切换失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', 'OSD 切换异常: ' + e.message); });\r\n        }\r\n        // 变焦控制\r\n        function ptzZoom(direction) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: direction === 'in' ? 'zoom-in' : 'zoom-out',\r\n                speed: speed\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', '变焦: ' + direction + ' (速度=' + speed + ')');\r\n                } else {\r\n                    showToast('error', result ? result.message : '变焦失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', '变焦异常: ' + e.message); });\r\n        }\r\n        // 对焦控制：直接发送移动指令，不强制切换模式\r\n        function ptzFocus(mode) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            \r\n            var dir = mode === 'near' ? 'focus-near' : mode === 'far' ? 'focus-far' : 'focus-auto';\r\n            // Focus 固定使用 speed=60，不使用滑块\r\n            var speed = 60;\r\n            \r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir,\r\n                speed: speed\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', '对焦: ' + mode);\r\n                } else {\r\n                    showToast('error', result ? result.message : '对焦失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', '对焦异常: ' + e.message); });\r\n        }\r\n        function setFocusMode(mode) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/focus/mode', { mode: mode }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '对焦模式: ' + mode);\r\n                } else {\r\n                    showToast('error', result ? result.message : '设置失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '设置异常: ' + e.message);\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  v6.54: 连接状态控制函数\r\n        // ================================================================\r\n        window.setConnectionButtonsEnabled = function(enabled) {\r\n            // 禁用/启用连接相关按钮\r\n            var quickSwitch = document.getElementById('quickConnectSwitch');\r\n            if (quickSwitch) {\r\n                quickSwitch.disabled = !enabled;\r\n                quickSwitch.style.opacity = enabled ? '1' : '0.5';\r\n            }\r\n        };\r\n        \r\n        window.disableAllControls = function(reason) {\r\n            // 禁用主控台控件\r\n            if (typeof disableImageControls === 'function') {\r\n                disableImageControls(reason);\r\n            }\r\n            // 禁用高级功能控件\r\n            var advButtons = ['btnConnectFuncRun', 'btnConnectLimitRun', 'btnConnectSpeedRun', 'btnStartDetection'];\r\n            advButtons.forEach(function(id) {\r\n                var btn = document.getElementById(id);\r\n                if (btn) {\r\n                    btn.disabled = true;\r\n                    btn.style.opacity = '0.5';\r\n                }\r\n            });\r\n        };\r\n        \r\n        window.enableAllControls = function() {\r\n            // 启用主控台控件\r\n            if (typeof enableImageControls === 'function') {\r\n                enableImageControls();\r\n            }\r\n            // 启用高级功能控件\r\n            var advButtons = ['btnConnectFuncRun', 'btnConnectLimitRun', 'btnConnectSpeedRun', 'btnStartDetection'];\r\n            advButtons.forEach(function(id) {\r\n                var btn = document.getElementById(id);\r\n                if (btn) {\r\n                    btn.disabled = false;\r\n                    btn.style.opacity = '1';\r\n                }\r\n            });\r\n        };\r\n        \r\n        // ================================================================\r\n        //  BUG-017 修复: 暴露函数到全局 window，使 HTML onclick 可调用\r\n        //  设备管理页面按钮（发现/添加/刷新）以及其他页面交互的\r\n        //  onclick 处理程序定义在 IIFE 内部，必须显式暴露到全局。\r\n        // ================================================================\r\n        var _expose = [\r\n            discoverDevices, refreshDevices,\r\n            connectDevice, disconnectDevice, deleteDevice,\r\n            ptzMove, ptzHome, ptzStop, getPtzPosition, onPtzDeviceChange,\r\n            calibrate, saveSettings,\r\n            funcDetectRun, funcDetectRestore,\r\n            limitTestRun, speedTestRun,\r\n            streamStart, streamStop, recordStart, recordStop, snapshotCapture,\r\n            onStreamDeviceChange, resetStreamButtons,\r\n            presetGoto, presetSet, startDetection,\r\n            connectFuncDetectRun, connectLimitTestRun, connectSpeedTestRun,\r\n            // 主控台新增 (修复6)\r\n            setTracking, consoleSnapshot, consoleRecordStart, consoleRecordStop,\r\n             adjustImage, adjustImageStep, togglePtzOsd, toggleInfoOsd,\r\n            ptzZoom, ptzFocus, setFocusMode,\r\n            // 预置点列表管理\r\n            loadPresetList, ptzGotoSelectedPreset, ptzSetSelectedPreset,\r\n            addDeviceInline, modifyIpPrompt, showDeviceInfoInline,\r\n            // WASM logout\r\n            wasmLogout,\r\n            // 工具函数\r\n            showToast, addLog,\r\n            // Live Stack 实时叠加\r\n            setLiveStackMode, startLiveStack, stopLiveStack, saveLiveStack,\r\n        ];\r\n        _expose.forEach(function(fn) { window[fn.name] = fn; });\r\n        // Go! - init() executes immediately for instant page interaction\r\n        init();\r\n        function loadWasmDevices() {\r\n            var sel = document.getElementById('device-select');\r\n            if (!sel) return;\r\n            var currentVal = sel.value;\r\n            apiGet('/api/v1/devices').then(function(resp) {\r\n                var devices = resp && resp.success ? (resp.data || resp.devices || []) : [];\r\n                // v6.16: 不要覆盖 allDevices，只用于下拉列表\r\n                // allDevices = devices;  // 删除这行\r\n                var ptzDevices = devices.filter(function(d) { return d.online && (d.type === 'ptz' || d.ptz === true); });\r\n                sel.innerHTML = '<option value=\"\">-- 选择 PTZ 设备 --</option>';\r\n                ptzDevices.forEach(function(d) {\r\n                    var opt = document.createElement('option');\r\n                    opt.value = d.ip;\r\n                    opt.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                    sel.appendChild(opt);\r\n                });\r\n                if (currentVal && sel.querySelector('option[value=\"' + currentVal + '\"]')) {\r\n                    sel.value = currentVal;\r\n                }\r\n            }).catch(function(e) {\r\n                console.warn('[WASM] Failed to load devices:', e);\r\n                sel.innerHTML = '<option value=\"\">-- 加载失败 --</option>';\r\n            });\r\n        }\r\n        function wasmLogout() {\r\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\r\n            try {\r\n                // Stop playback first\r\n                if (g_bPlaying2) {\r\n                    WebVideoCtrl.I_Stop();\r\n                    g_bPlaying2 = false;\r\n                }\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n    if (el) {\r\n        el.textContent = msg;\r\n        if (color) el.style.color = color;\r\n    }\r\n    console.log('[WASM] Status: ' + msg);\r\n}\r\nfunction clickLogin2() {\r\n    console.log('[CLICKLOGIN2] Called');\r\n    if (typeof ptzLog === 'function') ptzLog('WASM SDK 登录开始...', 'debug');\r\n    \r\n    // v6.43: 检查是否已播放成功，避免重复设置 connecting\r\n    if (g_bPlaying2) {\r\n        console.log('[CLICKLOGIN2] Already playing, skip');\r\n        return;\r\n    }\r\n    \r\n    // 更新 WASM 状态为连接中\r\n    if (window.updateWasmStatus) window.updateWasmStatus('connecting');\r\n    \r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        console.log('[WASM SDK] No device connected');\r\n        if (typeof ptzLog === 'function') ptzLog('未连接设备，无法登录', 'warning');\r\n        if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\r\n        return;\r\n    }\r\n    console.log('[CLICKLOGIN2] Device IP: ' + window.connectedDevice.ip);\r\n    if (typeof ptzLog === 'function') ptzLog('连接设备: ' + window.connectedDevice.ip, 'info');\r\n    var szIP = window.connectedDevice.ip;\r\n    var szPort = window.connectedDevice.port || 80;\r\n    var szUsername = window.connectedDevice.username || 'admin';\r\n    var szPassword = window.connectedDevice.password || '';\r\n    g_szDeviceIdentify2 = szIP + '_' + szPort;\r\n    console.log('[WASM SDK] Login: ' + szIP + ':' + szPort);\r\n    \r\n    // 博客方案：I_Login\r\n    WebVideoCtrl.I_Login(szIP, 1, szPort, szUsername, szPassword, {\r\n        success: function(xmlDoc) {\r\n            g_bLoggedIn2 = true;\r\n            g_szDeviceIdentify2 = szIP + '_' + szPort;\r\n            console.log('[WASM SDK] Login success: ' + g_szDeviceIdentify2);\r\n            if (typeof ptzLog === 'function') ptzLog(szIP + ' 登录成功！', 'success');\r\n            if (window.showToast) window.showToast('success', '设备已连接: ' + szIP);\r\n            \r\n            // 更新 WASM 状态为已连接\r\n            if (window.updateWasmStatus) window.updateWasmStatus('connected');\r\n            \r\n            // 博客方案：延迟500ms后执行 getDevicePort + getChannelInfo\r\n            setTimeout(() => {\r\n                // Step 1: getDevicePort\r\n                var oPort = WebVideoCtrl.I_GetDevicePort(g_szDeviceIdentify2);\r\n                console.log('[WASM SDK] GetDevicePort:', oPort);\r\n                if (oPort) {\r\n                    g_iRtspPort2 = oPort.iRtspPort || 554;\r\n                    g_iWebSocketPort = oPort.iWebSocketPort || 7681;\r\n                    if (typeof ptzLog === 'function') ptzLog('WebSocket端口: ' + g_iWebSocketPort, 'info');\r\n                    document.cookie = 'webVideoCtrlProxyWs=' + szIP + ':' + g_iWebSocketPort + '; path=/';\r\n                    document.cookie = 'webVideoCtrlProxyWsChannel=101; path=/';\r\n                }\r\n                \r\n                // Step 1.5: 异步获取 token 修复 szAuth（同步XHR被弃用）\r\n                var deviceSet = WebVideoCtrl.w_deviceSet;\r\n                var device = deviceSet && deviceSet.length > 0 ? deviceSet[0] : null;\r\n                var tokenPromise = Promise.resolve();\r\n                if (device && !device.szAuth) {\r\n                    console.log('[WASM SDK] szAuth empty, fetching token async...');\r\n                    tokenPromise = fetch('/ISAPI/Security/token?format=json', {credentials:'include'})\r\n                        .then(function(r) { return r.json(); })\r\n                        .then(function(data) {\r\n                            if (data && data.Token && data.Token.value) {\r\n                                device.szAuth = data.Token.value;\r\n                                console.log('[WASM SDK] szAuth set async:', device.szAuth.substring(0,16) + '...');\r\n                                if (typeof ptzLog === 'function') ptzLog('Token获取成功', 'success');\r\n                            }\r\n                        })\r\n                        .catch(function(e) { console.log('[WASM SDK] Token fetch failed:', e); });\r\n                }\r\n                \r\n\n[335 more lines in file. Use offset=2501 to continue.][... 7846 more characters truncated]"}],"isError":false,"timestamp":1781400937748}}
{"type":"message","id":"8d740d22","parentId":"bd80428a","timestamp":"2026-06-14T01:35:37.749Z","message":{"role":"toolResult","toolCallId":"call_52d8e3f79fd34c078964f50b","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nAstroHub v2.0 - 统一路由聚合\r\n\r\n整合 M1-M11 所有模块路由到 /api/v1/ 下:\r\n- /api/v1/health            - 全局健康检查\r\n- /api/v1/discovery/sadp    - SADP 设备发现\r\n- /api/v1/devices/*         - 设备管理（真实）\r\n- /api/v1/ptz/*             - PTZ 控制（真实）\r\n- /api/v1/streams/*         - 流服务\r\n- /api/v1/calibration/*     - 校准\r\n- /api/v1/ascom/*           - ASCOM 设备\r\n- /api/v1/settings          - 系统设置\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel\r\nfrom fastapi import APIRouter, FastAPI, Query\r\nfrom fastapi.responses import JSONResponse\r\n\r\n# v6.40: 操作日志\r\nfrom src.operation_logger import log_api, log_web, log_error, log_info\r\n\r\n# ================================================================ #\r\n#  核心模块导入\r\n# ================================================================ #\r\n\r\nfrom src.core.ptz_manager import PTZManager\r\nfrom src.core.device_manager import DeviceManager\r\nfrom src.core.stream_manager import StreamManager\r\nfrom src.core.calibration_manager import CalibrationManager\r\nfrom src.core.auth import AuthManager\r\nfrom src.core.ws_manager import WebSocketManager\r\nfrom src.core.ascom_manager import ASCOMManager\r\nfrom src.core.orchestrator import Orchestrator\r\nfrom src.core.health_monitor import HealthMonitor\r\n\r\n\r\n# ================================================================ #\r\n#  路由前缀定义\r\n# ================================================================ #\r\n\r\nAPI_V1_PREFIX = \"/api/v1\"\r\n\r\n# 主 API 路由器\r\napi_router = APIRouter(prefix=API_V1_PREFIX, tags=[\"API v1\"])\r\n\r\n# 健康检查路由器\r\nhealth_router = APIRouter(prefix=\"/api/v1\", tags=[\"System\"])\r\n\r\n\r\n# ================================================================ #\r\n#  v6.40: 操作日志 API\r\n# ================================================================ #\r\n\r\nclass OperationLogRequest(BaseModel):\r\n    \"\"\"操作日志请求.\"\"\"\r\n    level: str = \"INFO\"\r\n    module: str = \"web\"\r\n    action: str = \"\"\r\n    detail: str | dict = \"\"\r\n\r\n@health_router.post(\"/log/operation\", summary=\"记录操作日志\")\r\nasync def log_operation_api(req: OperationLogRequest) -> dict:\r\n    \"\"\"前端发送操作日志到后端.\"\"\"\r\n    from src.operation_logger import log_operation\r\n    log_operation(req.level, req.module, req.action, req.detail)\r\n    return {\"success\": True}\r\n\r\n\r\n# ================================================================ #\r\n#  Pydantic 请求模型\r\n# ================================================================ #\r\n\r\nclass AddDeviceRequest(BaseModel):\r\n    \"\"\"手动添加设备请求。\"\"\"\r\n    ip: str\r\n    port: int = 80\r\n    username: str = \"admin\"\r\n    password: str\r\n    name: str = \"\"\r\n    model: str = \"\"\r\n    mac: str = \"\"\r\n\r\nclass ConnectDeviceRequest(BaseModel):\r\n    \"\"\"连接设备请求。\"\"\"\r\n    username: str = \"admin\"\r\n    password: str\r\n    port: int = 80\r\n\r\nclass ModifyNetworkRequest(BaseModel):\r\n    \"\"\"修改网络配置请求。\"\"\"\r\n    ip: str\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str\r\n\r\nclass SADPIpModifyRequest(BaseModel):\r\n    \"\"\"SADP IP 修改请求 (含循环验证)。\"\"\"\r\n    mac: str\r\n    password: str\r\n    new_ip: str\r\n    original_ip: str = \"\"\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str = \"\"\r\n\r\nclass SystemInfoRequest(BaseModel):\r\n    \"\"\"系统信息请求（可选的绑定 ip）。\"\"\"\r\n    nic_index: int | None = None\r\n\r\nclass PTZMoveRequest(BaseModel):\r\n    \"\"\"PTZ 移动请求。\r\n    \r\n    speed: 1-7 档位，默认 4 档\r\n    档位映射: 1→14, 2→28, 3→43, 4→57, 5→71, 6→86, 7→100\r\n    \"\"\"\r\n    direction: str\r\n    speed: int = 4  # 默认 4 档\r\n\r\nclass PTZAbsoluteRequest(BaseModel):\r\n    \"\"\"PTZ 绝对移动请求。\r\n    \r\n    speed: 1-7 档位，默认 4 档\r\n    \"\"\"\r\n    pan: float\r\n    tilt: float\r\n    zoom: float | None = None\r\n    speed: int = 4  # 默认 4 档\r\n\r\nclass PTZPresetRequest(BaseModel):\r\n    \"\"\"PTZ 预置位请求。\"\"\"\r\n    preset_id: int\r\n\r\nclass SADPScanRequest(BaseModel):\r\n    \"\"\"SADP 发现请求。\"\"\"\r\n    bind_ip: str = \"0.0.0.0\"\r\n\r\nclass RemoveDeviceRequest(BaseModel):\r\n    \"\"\"移除设备请求。\"\"\"\r\n    ip: str = \"\"\r\n    mac: str = \"\"\r\n\r\n\r\nclass PTZCaptureRequest(BaseModel):\r\n    \"\"\"PTZ 截图请求。\"\"\"\r\n    stream_url: str = \"\"\r\n    stream_id: str = \"\"\r\n\r\n\r\nclass PTZRecordRequest(BaseModel):\r\n    \"\"\"PTZ 录像请求。\"\"\"\r\n    target_name: str = \"\"\r\n\r\n\r\nclass TelescopeSlewRequest(BaseModel):\r\n    \"\"\"望远镜 Slew 请求。\"\"\"\r\n    ra: float\r\n    dec: float\r\n\r\n\r\nclass TelescopeTrackingRequest(BaseModel):\r\n    \"\"\"望远镜跟踪模式请求。\"\"\"\r\n    mode: str  # trackSidereal / trackLunar / trackSolar / trackOff\r\n\r\n\r\n# ================================================================ #\r\n#  操作日志 (最多 10 条)\r\n# ================================================================ #\r\n\r\noperations_log: list[dict[str, str]] = []\r\nMAX_LOG_ENTRIES = 10\r\n\r\n\r\ndef operation_log(action: str, details: str) -> None:\r\n    \"\"\"追加操作到日志列表（环形缓冲区，最多 MAX_LOG_ENTRIES 条）。\"\"\"\r\n    entry = {\r\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\r\n        \"action\": action,\r\n        \"details\": details,\r\n    }\r\n    operations_log.append(entry)\r\n    if len(operations_log) > MAX_LOG_ENTRIES:\r\n        operations_log.pop(0)\r\n\r\n\r\n# ================================================================ #\r\n#  管理器注入\r\n# ================================================================ #\r\n\r\n_managers: dict[str, Any] = {}\r\n\r\n\r\ndef set_managers(**kwargs: Any) -> None:\r\n    \"\"\"注入所有管理器实例。\"\"\"\r\n    _managers.update(kwargs)\r\n\n[3134 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1781400937748}}
{"type":"message","id":"3b2e6d36","parentId":"8d740d22","timestamp":"2026-06-14T01:35:47.935Z","message":{"role":"assistant","content":[{"type":"text","text":"继续读取 router.py 中 PTZ 移动和速度映射的代码："},{"type":"toolCall","id":"tool-5fd629ff0c094c4ab04da775a0082cdf","name":"read","arguments":{"limit":300,"offset":401,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":64178,"output":61,"cacheRead":0,"cacheWrite":0,"totalTokens":64239,"cost":{"input":0.064178,"output":0.00019520000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0643732}},"stopReason":"toolUse","timestamp":1781400937749,"responseId":"cht000d41a1@dx19ec3c538f5b8ab282"}}
{"type":"message","id":"360146cc","parentId":"3b2e6d36","timestamp":"2026-06-14T01:35:47.944Z","message":{"role":"toolResult","toolCallId":"tool-5fd629ff0c094c4ab04da775a0082cdf","toolName":"read","content":[{"type":"text","text":"            existing[\"ip\"] = sadp.get(\"ip\") or existing[\"ip\"]\r\n            existing[\"model\"] = sadp.get(\"model\") or existing[\"model\"]\r\n            # name: 优先保留用户设置的名称，否则用 SADP 发现的\r\n            if not existing.get(\"name\"):\r\n                existing[\"name\"] = sadp.get(\"device_name\") or sadp.get(\"name\", \"\")\r\n            existing[\"activated\"] = sadp.get(\"activated\", False)\r\n            existing[\"gateway\"] = sadp.get(\"gateway\", \"\")\r\n            existing[\"subnet_mask\"] = sadp.get(\"subnet_mask\", \"\")\r\n            existing[\"source\"] = \"merged\"\r\n        elif sadp_mac:\r\n            # 新发现设备\r\n            keyed[sadp_mac] = {\r\n                \"mac\": sadp_mac,\r\n                \"ip\": sadp.get(\"ip\", \"\"),\r\n                \"name\": sadp.get(\"device_name\") or sadp.get(\"name\", \"\"),\r\n                \"model\": sadp.get(\"model\", \"\"),\r\n                \"source\": \"sadp\",\r\n                \"online\": False,\r\n                \"activated\": sadp.get(\"activated\", False),\r\n                \"has_credentials\": False,\r\n            }\r\n\r\n    # --- 构建最终列表 + 在线状态 ---\r\n    all_devices: list[dict[str, Any]] = list(keyed.values()) + no_mac\r\n    for dev in all_devices:\r\n        ip = dev.get(\"ip\", \"\")\r\n        dev[\"online\"] = ip in online_ips\r\n\r\n    return {\"success\": True, \"data\": all_devices, \"total\": len(all_devices)}\r\n\r\n\r\n@api_router.get(\"/devices/active\", summary=\"获取上次连接的设备\", tags=[\"Devices\"])\r\nasync def get_active_device() -> dict:\r\n    \"\"\"v6.30: 获取上次连接的设备（用于快速连接）。\"\"\"\r\n    from src.advanced.device_config import get_current_device\r\n    \r\n    device = get_current_device()\r\n    if device is None:\r\n        return {\r\n            \"success\": False,\r\n            \"active\": False,\r\n            \"device\": None,\r\n            \"message\": \"无上次连接设备\"\r\n        }\r\n    \r\n    return {\r\n        \"success\": True,\r\n        \"active\": True,\r\n        \"device\": device\r\n    }\r\n\r\n\r\n@api_router.post(\"/devices/active\", summary=\"设置上次连接的设备\", tags=[\"Devices\"])\r\nasync def set_active_device(mac: str) -> dict:\r\n    \"\"\"v6.30: 设置上次连接的设备（用于快速连接）。\"\"\"\r\n    from src.advanced.device_config import get_device_by_mac, load_config, save_config\r\n    \r\n    device = get_device_by_mac(mac)\r\n    if device is None:\r\n        return {\"success\": False, \"message\": f\"设备不存在: {mac}\"}\r\n    \r\n    config = load_config()\r\n    config[\"current_device\"] = mac\r\n    save_config(config)\r\n    \r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"上次连接设备已设置: {device.get('model', 'Unknown')} @ {device.get('ip')}\",\r\n        \"device\": device\r\n    }\r\n\r\n\r\n@api_router.post(\"/devices\", summary=\"注册设备\", tags=[\"Devices\"])\r\nasync def register_device(req: AddDeviceRequest) -> dict:\r\n    \"\"\"手动添加设备（IP + 凭据）并自动设为活跃。\"\"\"\r\n    from src.advanced.device_config import set_current_device\r\n    \r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    mgr.save_credentials(\r\n        ip=req.ip,\r\n        username=req.username,\r\n        password=req.password,\r\n        port=req.port,\r\n        mac=req.mac,\r\n        model=req.model,\r\n        name=req.name,\r\n    )\r\n\r\n    # 自动注册到 DeviceManager\r\n    dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n    if dm:\r\n        dm.register_device(\r\n            mac=req.mac or req.ip,\r\n            ip=req.ip,\r\n            name=req.name or f\"Hikvision-{req.ip}\",\r\n            model=req.model or \"Hikvision PTZ\",\r\n        )\r\n    \r\n    # 设为活跃设备\r\n    if req.mac:\r\n        set_current_device(req.mac, ip=req.ip, model=req.model, port=req.port)\r\n\r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"设备已保存并设为活跃: {req.ip}\",\r\n        \"device\": {\r\n            \"ip\": req.ip,\r\n            \"port\": req.port,\r\n            \"name\": req.name,\r\n            \"model\": req.model,\r\n            \"mac\": req.mac,\r\n        },\r\n    }\r\n\r\n\r\n@api_router.post(\"/devices/{device_id}/connect\", summary=\"连接设备\", tags=[\"Devices\"])\r\nasync def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\r\n    \"\"\"连接 PTZ 设备并认证。\r\n\r\n    device_id 可以是 IP 地址或 MAC 地址。如果是 MAC，自动解析为 IP。\r\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\r\n    \r\n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\r\n    \"\"\"\r\n    log_api(\"connect\", {\"mac\": device_id})\r\n    \r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        log_error(\"connect\", {\"mac\": device_id, \"error\": \"PTZManager 未初始化\"})\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # 解析 device_id: 如果看起来像 MAC，从发现缓存中解析 IP\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        log_error(\"connect\", {\"mac\": device_id, \"error\": \"无法解析设备标识\"})\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}，请提供 IP 地址或确保设备已通过 SADP 发现\"}\r\n\r\n    # 如果未提供凭据，尝试从存储获取\r\n    if req is None:\r\n        creds = mgr.get_credentials(target_ip)\r\n        if not creds:\r\n            log_error(\"connect\", {\"mac\": device_id, \"error\": \"设备未保存凭据\"})\r\n            return {\"success\": False, \"message\": \"设备未保存凭据，请先提供用户名和密码\"}\r\n        username = creds[\"username\"]\r\n        password = creds[\"password\"]\r\n        port = creds.get(\"port\", 80)\r\n    else:\r\n        username = req.username or \"admin\"\r\n        if not req.password:\r\n            return {\"success\": False, \"message\": \"请提供密码\"}\r\n        password = req.password\r\n        port = req.port\r\n\r\n    result = mgr.connect_device(target_ip, username, password, port)\r\n    if result and result.get(\"success\"):\r\n        log_info(\"connect\", {\"mac\": device_id, \"ip\": target_ip, \"status\": \"success\"})\r\n        # 更新 DeviceManager 状态（使用 device_id 保持前端一致）\r\n        dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n        if dm:\r\n            dm.update_status(device_id, \"online\")\r\n        return result\r\n    \r\n    log_error(\"connect\", {\"mac\": device_id, \"ip\": target_ip, \"status\": \"failed\"})\r\n    return result or {\"success\": False, \"message\": \"连接失败\"}\r\n\r\n\r\n@api_router.post(\"/devices/{device_id}/disconnect\", summary=\"断开设备\", tags=[\"Devices\"])\r\nasync def disconnect_device(device_id: str) -> dict:\r\n    \"\"\"断开 PTZ 设备连接.\"\"\"\r\n    log_api(\"disconnect\", {\"mac\": device_id})\r\n    \r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    mgr.disconnect_device(device_id)\r\n\r\n    dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n    if dm:\r\n        dm.update_status(device_id, \"offline\")\r\n\r\n    log_info(\"disconnect\", {\"mac\": device_id, \"status\": \"success\"})\r\n    return {\"success\": True, \"message\": f\"设备已断开: {device_id}\"}\r\n\r\n\r\n@api_router.delete(\"/devices/{device_id}\", summary=\"删除设备\", tags=[\"Devices\"])\r\nasync def delete_device(device_id: str) -> dict:\r\n    \"\"\"删除设备。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # 先断开\r\n    mgr.disconnect_device(device_id)\r\n\r\n    # 移除凭据\r\n    removed = mgr.remove_credentials(device_id)\r\n\r\n    dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n    if dm:\r\n        dm.unregister_device(device_id)\r\n\r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"设备已删除: {device_id}\",\r\n    }\r\n\r\n\r\n@api_router.get(\"/devices/{device_id}/info\", summary=\"设备详细信息\", tags=[\"Devices\"])\r\nasync def get_device_info(device_id: str) -> dict:\r\n    \"\"\"获取设备详细信息（通过 ISAPI）。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # 解析 device_id (MAC) 到 IP\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": \"无法解析设备标识: 请提供 IP 地址或确保设备已连接\"}\r\n\r\n    info = mgr.get_device_info(target_ip)\r\n    if \"error\" in info:\r\n        return {\"success\": False, \"message\": info[\"error\"]}\r\n\r\n    return {\"success\": True, \"data\": info}\r\n\r\n\r\n@api_router.put(\"/devices/{device_id}/network\", summary=\"修改设备网络配置\", tags=[\"Devices\"])\r\nasync def modify_network(device_id: str, req: ModifyNetworkRequest) -> dict:\r\n    \"\"\"修改设备网络配置（通过 SADP 协议）。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    result = mgr.modify_device_network(\r\n        ip=device_id,\r\n        new_ip=req.ip,\r\n        subnet_mask=req.subnet_mask,\r\n        gateway=req.gateway,\r\n    )\r\n    return result\r\n\r\n\r\n# ================================================================ #\r\n#  SADP IP 修改 & 系统信息端点\r\n# ================================================================ #\r\n\r\n\r\n@api_router.post(\"/sadp/{mac}/modify-ip\", summary=\"SADP 修改设备 IP (含自动验证循环)\", tags=[\"SADP\"])\r\nasync def sadp_modify_ip(mac: str, req: SADPIpModifyRequest) -> dict:\r\n    \"\"\"通过 SADP DLL 修改设备 IP，含自动重试和扫描确认循环。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    result = mgr.modify_reachable_with_retry(\r\n        mac=mac,\r\n        password=req.password,\r\n        original_ip=req.original_ip or \"\",\r\n        target_ip=req.new_ip,\r\n        subnet_mask=req.subnet_mask,\r\n        gateway=req.gateway,\r\n    )\r\n    return result\r\n\r\n\r\n@api_router.get(\"/sadp/error-codes\", summary=\"SADP 错误码参考表\", tags=[\"SADP\"])\r\nasync def sadp_error_codes() -> JSONResponse:\r\n    \"\"\"返回 SADP 错误码中文对照表。\"\"\"\r\n    try:\r\n        from src.core.sadp_discovery import SADP_ERROR_CODES\r\n        return JSONResponse(\r\n            content={\"success\": True, \"codes\": SADP_ERROR_CODES},\r\n            ensure_ascii=False,\r\n        )\r\n    except ImportError:\r\n        return JSONResponse(\r\n            content={\"success\": False, \"message\": \"SADP 模块未加载\"},\r\n            ensure_ascii=False,\r\n        )\r\n\r\n\r\n@api_router.post(\"/sadp/auto-reconnect\", summary=\"P2.7: 已知设备自动重连\", tags=[\"SADP\"])\r\nasync def sadp_auto_reconnect(req: AutoReconnectDevicesRequest | None = None) -> dict:\r\n    \"\"\"P2.7: 扫描 SADP 设备 -> MAC匹配已保存设备 -> IP不可达时自动修改 IP。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    bind_ip = \"0.0.0.0\"\r\n    target_ip = None\r\n    if req:\r\n        bind_ip = req.bind_ip or \"0.0.0.0\"\r\n        target_ip = req.target_ip or None\r\n\r\n    result = mgr.auto_reconnect_known_devices(bind_ip=bind_ip, target_ip=target_ip)\r\n    return result\r\n\n[2634 more lines in file. Use offset=701 to continue.]"}],"isError":false,"timestamp":1781400947944}}
{"type":"message","id":"0f0b88ca","parentId":"360146cc","timestamp":"2026-06-14T01:36:03.368Z","message":{"role":"assistant","content":[{"type":"text","text":"继续读取 PTZ 移动的实现："},{"type":"toolCall","id":"call_0afdd7b2d80844338d180c66","name":"read","arguments":{"limit":300,"offset":901,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":67288,"output":55,"cacheRead":0,"cacheWrite":0,"totalTokens":67343,"cost":{"input":0.067288,"output":0.00017600000000000002,"cacheRead":0,"cacheWrite":0,"total":0.067464}},"stopReason":"toolUse","timestamp":1781400947945,"responseId":"cht000d33b0@dx19ec3c576eaba5a412"}}
{"type":"message","id":"1ace4672","parentId":"0f0b88ca","timestamp":"2026-06-14T01:36:03.382Z","message":{"role":"toolResult","toolCallId":"call_0afdd7b2d80844338d180c66","toolName":"read","content":[{"type":"text","text":"\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    return mgr.ptz_list_presets(target_ip)\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/preset/{preset_id}\", summary=\"预置位\", tags=[\"PTZ\"])\r\nasync def ptz_preset(device_id: str, preset_id: int) -> dict:\r\n    \"\"\"移动到指定预置点。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # BUG-A 修复: 支持 MAC 地址作为 device_id\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    return mgr.ptz_preset(target_ip, preset_id=preset_id)\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/preset/{preset_id}/set\", summary=\"保存预置位\", tags=[\"PTZ\"])\r\nasync def ptz_set_preset(device_id: str, preset_id: int) -> dict:\r\n    \"\"\"设置当前位置为指定预置点。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    return mgr.set_preset(target_ip, preset_id=preset_id)\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/absolute\", summary=\"绝对位置\", tags=[\"PTZ\"])\r\nasync def ptz_absolute(device_id: str, req: PTZAbsoluteRequest) -> dict:\r\n    \"\"\"绝对坐标移动（Pan/Tilt/Zoom）。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # BUG-A 修复: 支持 MAC 地址作为 device_id\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    return mgr.ptz_absolute(\r\n        target_ip,\r\n        pan=req.pan,\r\n        tilt=req.tilt,\r\n        zoom=req.zoom,\r\n        speed=req.speed,\r\n    )\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/position\", summary=\"获取 PTZ 位置\", tags=[\"PTZ\"])\r\nasync def get_ptz_position(device_id: str) -> dict:\r\n    \"\"\"获取 PTZ 当前位置。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # BUG-A 修复: 支持 MAC 地址作为 device_id\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    # BUG-B 修复: 统一返回 response.data\r\n    return mgr.ptz_get_position(target_ip)\r\n\r\n\r\n# 海康 ISAPI PTZ OSD 显示端点常量\r\nISAPI_PTZ_OSD_TEMPLATE = \"/ISAPI/PTZCtrl/channels/{ch}/PTZOSDDisplay\"\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/osd/toggle\", summary=\"切换 PTZ 坐标 OSD 显示\", tags=[\"PTZ\"])\r\nasync def ptz_osd_toggle(device_id: str, enabled: bool = True) -> dict:\r\n    \"\"\"通过海康 ISAPI 控制 PTZ 坐标 OSD 显示开关。\r\n\r\n    使用: GET/PUT /ISAPI/PTZCtrl/channels/{ch}/PTZOSDDisplay\r\n    enabled=True  开启 PTZ 坐标OSD\r\n    enabled=False 关闭 PTZ 坐标OSD\r\n    \"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = mgr._clients.get(target_ip)\r\n    if not client:\r\n        return {\"success\": False, \"message\": f\"ISAPI client not found for {target_ip}\"}\r\n\r\n    try:\r\n        ch = getattr(client, 'channel', 1)\r\n        endpoint = f\"/PTZCtrl/channels/{ch}/PTZOSDDisplay\"\r\n\r\n        # 先 GET 获取当前 OSD 设置\r\n        get_resp = client.get(endpoint)\r\n        if get_resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"GET PTZOSDDisplay 失败: HTTP {get_resp.status_code}, {get_resp.xml[:200]}\"}\r\n\r\n        import xml.etree.ElementTree as ET\r\n        root = ET.fromstring(get_resp.xml)\r\n\r\n        # 根据ISAPI规范, PTZOSDDisplay XML 字段:\r\n        # azimuth: alwaysopen/alwaysclose → P/T 坐标\r\n        # zoomlable: alwaysopen/alwaysclose → Z 值\r\n        # presetlable: alwaysopen/alwaysclose → 预置点标签\r\n        # 全部统一开关\r\n        val = \"alwaysopen\" if enabled else \"alwaysclose\"\r\n        for tag_name in (\"azimuth\", \"zoomlable\", \"presetlable\"):\r\n            elem = root.find(tag_name)\r\n            if elem is not None:\r\n                elem.text = val\r\n            else:\r\n                # 带 namespace\r\n                elem = root.find(\".//{http://www.hikvision.com/ver20/XMLSchema}\" + tag_name)\r\n                if elem is not None:\r\n                    elem.text = val\r\n\r\n        # PUT 更新（移除 ns0: 命名空间前缀）\r\n        xml_str = ET.tostring(root, encoding=\"unicode\")\r\n        xml_str = xml_str.replace('ns0:', '')\r\n        xml_str = xml_str.replace('xmlns:ns0=', 'xmlns=')\r\n        new_xml = '<?xml version=\"1.0\" encoding=\"UTF-8\"?>' + xml_str\r\n        put_resp = client.put(endpoint, new_xml)\r\n        if put_resp.status_code == 200:\r\n            return {\r\n                \"success\": True,\r\n                \"message\": f\"PTZ 坐标 OSD 已{'开启' if enabled else '关闭'}\",\r\n                \"enabled\": enabled,\r\n            }\r\n        else:\r\n            return {\"success\": False, \"message\": f\"PUT PTZOSDDisplay 失败: HTTP {put_resp.status_code}, {put_resp.xml[:200]}\"}\r\n\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"OSD 切换异常: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/osd/ptz\", summary=\"切换 PTZ 坐标 OSD\", tags=[\"PTZ\"])\r\nasync def ptz_osd_ptz_toggle(device_id: str, body: dict = None) -> dict:\r\n    \"\"\"切换 PTZ 坐标（P/T/Z）OSD 显示。\"\"\"\r\n    enabled = (body or {}).get(\"enabled\", True) if body else True\r\n    \r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n\r\n    try:\r\n        ch = getattr(client, 'channel', 1)\r\n        endpoint = f\"/PTZCtrl/channels/{ch}/PTZOSDDisplay\"\r\n\r\n        # GET 获取当前 OSD 配置\r\n        get_resp = client.get(endpoint)\r\n        if get_resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"GET PTZOSDDisplay 失败: HTTP {get_resp.status_code}\"}\r\n\r\n        import xml.etree.ElementTree as ET\r\n        root = ET.fromstring(get_resp.xml)\r\n\r\n        # 只修改 PTZ 坐标相关字段: azimuth, zoomlable\r\n        val = \"alwaysopen\" if enabled else \"alwaysclose\"\r\n        for tag_name in (\"azimuth\", \"zoomlable\"):\r\n            elem = root.find(tag_name)\r\n            if elem is not None:\r\n                elem.text = val\r\n\r\n        # PUT 更新（移除 ns0: 命名空间前缀）\r\n        xml_str = ET.tostring(root, encoding='unicode')\r\n        xml_str = xml_str.replace('ns0:', '')\r\n        xml_str = xml_str.replace('xmlns:ns0=', 'xmlns=')\r\n        put_resp = client.put(endpoint, '<?xml version=\"1.0\" encoding=\"UTF-8\"?>' + xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": f\"PTZ 坐标 OSD 已{'开启' if enabled else '关闭'}\", \"enabled\": enabled}\r\n        else:\r\n            return {\"success\": False, \"message\": f\"PUT 失败: HTTP {put_resp.status_code}\"}\r\n\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"PTZ OSD 切换异常: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/osd/info\", summary=\"切换 OSD 信息显示\", tags=[\"PTZ\"])\r\nasync def ptz_osd_info_toggle(device_id: str, body: dict = None) -> dict:\r\n    \"\"\"切换 OSD 信息显示（用户自定义、日期时间等）。\"\"\"\r\n    enabled = (body or {}).get(\"enabled\", True) if body else True\r\n    \r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n\r\n    try:\r\n        # ISAPI 端点: /ISAPI/System/Video/inputs/channels/{ch}/overlays\r\n        ch = getattr(client, 'channel', 1)\r\n        endpoint = f\"/System/Video/inputs/channels/{ch}/overlays\"\r\n\r\n        # GET 获取当前 overlay 配置\r\n        get_resp = client.get(endpoint)\r\n        if get_resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"GET overlays 失败: HTTP {get_resp.status_code}\"}\r\n\r\n        import xml.etree.ElementTree as ET\r\n        root = ET.fromstring(get_resp.xml)\r\n\r\n        # 只修改 DateTimeOverlay 和 channelNameOverlay 的 enabled 字段\r\n        val = \"true\" if enabled else \"false\"\r\n        for target in [\"DateTimeOverlay\", \"channelNameOverlay\"]:\r\n            elem = root.find(target)\r\n            if elem is None:\r\n                elem = root.find(\".//{http://www.hikvision.com/ver20/XMLSchema}\" + target)\r\n            if elem is not None:\r\n                enabled_elem = elem.find(\"enabled\")\r\n                if enabled_elem is None:\r\n                    enabled_elem = elem.find(\"{http://www.hikvision.com/ver20/XMLSchema}enabled\")\r\n                if enabled_elem is not None:\r\n                    enabled_elem.text = val\r\n\r\n        # PUT 更新（带 XML 声明，移除 ns0: 命名空间前缀）\r\n        new_xml = '<?xml version=\"1.0\" encoding=\"UTF-8\"?>'\r\n        xml_str = ET.tostring(root, encoding='unicode')\r\n        # 移除 ns0: 前缀和 xmlns:ns0 声明\r\n        xml_str = xml_str.replace('ns0:', '')\r\n        xml_str = xml_str.replace('xmlns:ns0=', 'xmlns=')\r\n        new_xml += xml_str\r\n        put_resp = client.put(endpoint, new_xml)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": f\"OSD 信息显示已{'开启' if enabled else '关闭'}\", \"enabled\": enabled}\r\n        else:\r\n            return {\"success\": False, \"message\": f\"PUT 失败: HTTP {put_resp.status_code}\"}\r\n\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"OSD 信息切换异常: {e}\"}\r\n\r\n\r\n# ============================================================\r\n# 画面调整\r\n# ============================================================\r\n\r\nclass ImageAdjustRequest(BaseModel):\r\n    \"\"\"画面调整请求\"\"\"\r\n    brightness: int | None = None  # 0-100\r\n    contrast: int | None = None    # 0-100\r\n    saturation: int | None = None  # 0-100\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/settings\", summary=\"获取画面设置\", tags=[\"Image\"])\r\nasync def get_image_settings(device_id: str) -> dict:\r\n    \"\"\"获取当前画面参数（亮度/对比度/饱和度）。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    client = mgr._clients.get(target_ip)\r\n    if not client:\r\n        return {\"success\": False, \"message\": f\"ISAPI client not found for {target_ip}\"}\r\n\r\n    try:\r\n        resp = client.get(\"/Image/channels/1\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"获取画面设置失败: HTTP {resp.status_code}\"}\r\n\r\n        import xml.etree.ElementTree as ET\r\n        root = ET.fromstring(resp.xml)\r\n\r\n        # 查找 Color 节点\r\n        result = {\"success\": True, \"data\": {}}\r\n        for elem in root.iter():\r\n\n[2134 more lines in file. Use offset=1201 to continue.]"}],"isError":false,"timestamp":1781400963382}}
