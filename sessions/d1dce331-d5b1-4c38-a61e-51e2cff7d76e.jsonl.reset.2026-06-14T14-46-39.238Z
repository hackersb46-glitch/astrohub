{"type":"message","id":"b2655024","parentId":"5b028a46","timestamp":"2026-06-14T09:52:52.252Z","message":{"role":"assistant","content":[{"type":"text","text":"**关键发现**：\n\n1. **Shutter 端点返回 400** - 独立 Shutter 端点不接受 1/500（只接受特定值）\n2. **Iris 端点返回 200** - 但实际值没有改变（还是 200，不是 2000）\n\n这说明：\n- **Shutter**：独立端点只接受特定值，需要通过 Exposure 端点设置\n- **Iris**：独立端点可能也需要某种条件\n\n让我测试 Iris 端点是否需要先设置为手动模式："},{"type":"toolCall","id":"call_75adccf4a57e412eb9a716da","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n详细测试 Iris 端点\n\"\"\"\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\n\nBASE_URL = \"http://192.168.5.72\"\nAUTH = HTTPDigestAuth('admin', 'Nftw1357')\n\nprint(\"=\" * 60)\nprint(\"Iris 端点详细测试\")\nprint(\"=\" * 60)\n\n# 1. 确保手动模式\nprint(\"\\n1. 设置手动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\n# 2. 获取 Iris 完整响应\nprint(\"\\n2. GET Iris\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Iris', auth=AUTH, timeout=5)\nprint(f'响应:\\n{resp.text}')\n\n# 3. 尝试设置不同值\nprint(\"\\n3. 设置 IrisLevel=1600\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Iris version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <IrisLevel>1600</IrisLevel>\n</Iris>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/Iris', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'响应: {resp.text}')\n\ntime.sleep(1)\n\n# 4. 验证\nprint(\"\\n4. 验证 Iris\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Iris', auth=AUTH, timeout=5)\nprint(f'响应:\\n{resp.text}')\n\n# 5. 测试 Shutter 可接受的值\nprint(\"\\n5. 测试 Shutter 可接受的值\")\nacceptable_values = ['1/25', '1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000']\nfor sv in acceptable_values:\n    xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Shutter version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ShutterLevel>{sv}</ShutterLevel>\n</Shutter>'''\n    resp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', \n                       auth=AUTH, data=xml_str,\n                       headers={'Content-Type': 'application/xml'}, timeout=5)\n    print(f'  {sv}: HTTP {resp.status_code}')\n\n# 6. 恢复自动模式\nprint(\"\\n6. 恢复自动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_iris_detail.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":111608,"output":976,"cacheRead":0,"cacheWrite":0,"totalTokens":112584,"cost":{"input":0.111608,"output":0.0031232000000000005,"cacheRead":0,"cacheWrite":0,"total":0.1147312}},"stopReason":"toolUse","timestamp":1781430763932,"responseId":"cht000d043c@dx19ec58c4458b958232"}}
