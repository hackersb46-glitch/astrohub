{"type":"message","id":"e181ed8d","parentId":"50be7e87","timestamp":"2026-06-14T10:57:05.841Z","message":{"role":"assistant","content":[{"type":"text","text":"当前状态：已连接 192.168.5.72\n\n---\n\n## 步骤 3：创建 Playwright E2E 测试脚本"},{"type":"toolCall","id":"tool-27dcab359b64492a897ab03e49d2c93a","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nE2E 测试：快速连接关闭后 ISAPI 状态检查\n使用 Playwright 模拟用户操作\n\"\"\"\n\nimport asyncio\nimport requests\nfrom playwright.async_api import async_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\nasync def test_disconnect_e2e():\n    \"\"\"测试快速连接关闭功能\"\"\"\n    \n    print(\"=\" * 60)\n    print(\"E2E 测试：快速连接关闭后 ISAPI 状态\")\n    print(\"=\" * 60)\n    \n    # 1. 检查初始状态\n    print(\"\\n[步骤 1] 检查初始连接状态\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n    initial_state = resp.json()\n    print(f\"初始状态: {initial_state}\")\n    \n    if not initial_state.get('connected'):\n        print(\"设备未连接，先连接设备\")\n        # 连接设备\n        connect_resp = requests.post(\n            f\"{BASE_URL}/api/v1/ptz/192.168.5.72/connect\",\n            json={\"username\": \"admin\", \"password\": \"Nftw1357\", \"port\": 80}\n        )\n        print(f\"连接结果: {connect_resp.json()}\")\n        await asyncio.sleep(2)\n    \n    # 2. 使用 Playwright 打开页面并操作\n    print(\"\\n[步骤 2] 使用 Playwright 模拟用户操作\")\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False)  # 可见模式便于观察\n        page = await browser.new_page()\n        \n        # 打开主页\n        print(\"打开主页...\")\n        await page.goto(BASE_URL)\n        await asyncio.sleep(2)\n        \n        # 等待页面加载\n        await page.wait_for_selector('.status-bar', timeout=10000)\n        \n        # 检查状态栏显示\n        status_bar = await page.query_selector('.status-bar')\n        if status_bar:\n            status_text = await status_bar.inner_text()\n            print(f\"状态栏内容: {status_text}\")\n        \n        # 查找快速连接按钮区域\n        print(\"\\n查找快速连接区域...\")\n        \n        # 尝试多种可能的按钮选择器\n        possible_buttons = [\n            'button:has-text(\"断开\")',\n            'button:has-text(\"Disconnect\")',\n            '#quickDisconnectBtn',\n            '.disconnect-btn',\n            '[data-action=\"disconnect\"]',\n            'button.disconnect',\n        ]\n        \n        disconnect_btn = None\n        for selector in possible_buttons:\n            try:\n                disconnect_btn = await page.query_selector(selector)\n                if disconnect_btn:\n                    print(f\"找到断开按钮: {selector}\")\n                    break\n            except Exception as e:\n                pass\n        \n        # 如果找不到按钮，打印页面结构帮助诊断\n        if not disconnect_btn:\n            print(\"\\n未找到断开按钮，打印页面结构...\")\n            \n            # 查找所有按钮\n            buttons = await page.query_selector_all('button')\n            print(f\"\\n页面上的所有按钮 ({len(buttons)} 个):\")\n            for i, btn in enumerate(buttons[:10]):  # 只显示前 10 个\n                try:\n                    text = await btn.inner_text()\n                    id_attr = await btn.get_attribute('id')\n                    class_attr = await btn.get_attribute('class')\n                    print(f\"  [{i}] text='{text.strip()}' id='{id_attr}' class='{class_attr}'\")\n                except Exception as e:\n                    print(f\"  [{i}] 无法读取: {e}\")\n            \n            # 截图保存\n            await page.screenshot(path='screenshot_disconnect_issue.png')\n            print(\"截图已保存: screenshot_disconnect_issue.png\")\n        \n        # 3. 执行断开操作\n        print(\"\\n[步骤 3] 执行断开操作\")\n        \n        if disconnect_btn:\n            # 点击断开按钮\n            await disconnect_btn.click()\n            print(\"点击断开按钮\")\n            await asyncio.sleep(1)\n            \n            # 检查是否有确认对话框\n            try:\n                dialog = await page.wait_for_selector('.modal, .dialog, .confirm', timeout=2000)\n                if dialog:\n                    print(\"出现确认对话框\")\n                    confirm_btn = await dialog.query_selector('button:has-text(\"确认\"), button:has-text(\"OK\")')\n                    if confirm_btn:\n                        await confirm_btn.click()\n                        print(\"确认断开\")\n            except Exception:\n                pass\n            \n            await asyncio.sleep(2)\n        else:\n            # 使用 API 直接断开\n            print(\"使用 API 断开\")\n            disconnect_resp = requests.delete(f\"{BASE_URL}/api/v1/ptz/192.168.5.72/disconnect\")\n            print(f\"API 断开结果: {disconnect_resp.json()}\")\n            await asyncio.sleep(2)\n        \n        # 4. 检查断开后的状态\n        print(\"\\n[步骤 4] 检查断开后的状态\")\n        \n        # API 状态\n        resp = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n        final_state = resp.json()\n        print(f\"API 状态: {final_state}\")\n        \n        # 页面状态\n        if status_bar:\n            new_status_text = await status_bar.inner_text()\n            print(f\"页面状态栏: {new_status_text}\")\n        \n        # 检查是否有 ISAPI 请求仍在发送\n        print(\"\\n[步骤 5] 检查服务日志中的 ISAPI 活动\")\n        \n        await asyncio.sleep(3)  # 等待观察\n        \n        # 关闭浏览器\n        await browser.close()\n    \n    # 5. 结论\n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试结论:\")\n    print(\"=\" * 60)\n    \n    if final_state.get('connected'):\n        print(\"❌ 问题确认: 断开后 API 状态仍显示已连接\")\n        print(\"可能原因: 断开操作未生效，或状态未更新\")\n    else:\n        print(\"✅ 断开成功: API 状态显示未连接\")\n    \n    return {\n        \"initial\": initial_state,\n        \"final\": final_state,\n        \"disconnect_success\": not final_state.get('connected')\n    }\n\nif __name__ == \"__main__\":\n    result = asyncio.run(test_disconnect_e2e())\n    print(f\"\\n测试结果: {result}\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\e2e_test_disconnect.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":47404,"output":1432,"cacheRead":0,"cacheWrite":0,"totalTokens":48836,"cost":{"input":0.047403999999999995,"output":0.0045824,"cacheRead":0,"cacheWrite":0,"total":0.051986399999999995}},"stopReason":"toolUse","timestamp":1781434593770,"responseId":"cht000db01c@dx19ec5c6b41fb8ab282"}}
