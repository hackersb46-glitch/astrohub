息</label>\n                                        <div style=\"display:flex;gap:16px\">\n                                            <div style=\"display:flex;align-items:center;gap:6px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">OSD</span>\n                                                <label class=\"toggle-switch\">\n                                                    <input type=\"checkbox\" id=\"infoOsdSwitch\" onchange=\"toggleInfoOsdSwitch(this.checked)\">\n                                                    <span class=\"toggle-slider\"></span>\n                                                </label>\n                                            </div>\n                                            <div style=\"display:flex;align-items:center;gap:6px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">PTZ</span>\n                                                <label class=\"toggle-switch\">\n                                                    <input type=\"checkbox\" id=\"ptzOsdSwitch\" onchange=\"togglePtzOsdSwitch(this.checked)\">\n                                                    <span class=\"toggle-slider\"></span>\n                                                </label>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n<style>\n/* v6.02: 拨杆开关样式 */\n.toggle-switch {\n    position: relative;\n    display: inline-block;\n\n[942 more lines in file. Use offset=270 to continue.]"}],"isError":false,"timestamp":1781401303097}}
