{"type":"message","id":"a5e8544e","parentId":"1b3ffb5a","timestamp":"2026-06-14T01:44:11.930Z","message":{"role":"toolResult","toolCallId":"call_fd496696acaa4ed792819e09","toolName":"read","content":[{"type":"text","text":"        function wasmLogout() {\r\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\r\n            try {\r\n                // Stop playback first\r\n                if (g_bPlaying2) {\r\n                    WebVideoCtrl.I_Stop();\r\n                    g_bPlaying2 = false;\r\n                }\r\n                // Logout from device\r\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\r\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\r\n                }\r\n                // v5.47: Clear video window content\r\n                var container = document.getElementById('divPlugin');\r\n                if (container && window.WebVideoCtrl) {\r\n                    try {\r\n                        // 尝试清空视频窗口\r\n                        WebVideoCtrl.I_ClearWindowContent(0);\r\n                    } catch(e2) { console.warn('ClearWindow error:', e2); }\r\n                }\r\n                // v6.12: 显示断开提示\r\n                if (container) {\r\n                    container.style.background = '#0d1117';\r\n                    container.innerHTML = '<div style=\"display:flex;align-items:center;justify-content:center;height:100%;color:#6e7681;font-size:14px\">画面已断开</div>';\r\n                }\r\n            } catch(e) { console.warn('WASM logout error:', e); }\r\n            g_bLoggedIn2 = false;\r\n            g_szDeviceIdentify2 = ''; \r\n            g_bPlaying2 = false;\r\n            setLoginStatus('已登出', '#8b949e');\r\n            var loginBtn = document.getElementById('login-btn');\r\n            if (loginBtn) loginBtn.textContent = '登录';\r\n            \r\n            // v6.12: 更新 WASM 状态\r\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\r\n        }\r\n        // Inline helpers (no modal)\r\n        function addDeviceInline() {\r\n            var ip = prompt(\"\\u8bbe\\u5907 IP:\");\r\n            if (!ip) return;\r\n            apiPost(\"/api/v1/devices\", { ip: ip }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"\\u5df2\\u6dfb\\u52a0\"); refreshDevices(); }\r\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\r\n            }).catch(function(e) { showToast(\"error\", e.message); });\r\n        }\r\n        function modifyIpPrompt(mac, oldIp) {\r\n            var newIp = prompt(\"IP (MAC: \" + mac + \")\", oldIp);\r\n            if (!newIp || newIp === oldIp) return;\r\n            apiPost(\"/api/v1/devices/\" + oldIp, { ip: newIp, mac: mac }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"IP \\u5df2\\u4fee\\u6539\"); refreshDevices(); }\r\n\n[540 more lines in file. Use offset=2298 to continue.]"}],"isError":false,"timestamp":1781401451930}}
{"type":"message","id":"b6192566","parentId":"a5e8544e","timestamp":"2026-06-14T01:44:21.701Z","message":{"role":"assistant","content":[{"type":"text","text":"问题是 wasmLogout 中调用了 `container.innerHTML = '...'` 来替换 WASM 容器内容。这会破坏 WASM SDK 的 DOM 结构，导致重连失败。\n\n**修复方案**：断开时只显示灰色覆盖层，不销毁 WASM 容器。"},{"type":"toolCall","id":"call_9e37412eddae45019ab17539","name":"edit","arguments":{"edits":[{"newText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v7.0: 不销毁 WASM 容器，只显示灰色覆盖层\n                var container = document.getElementById('divPlugin');\n                if (container) {\n                    // 移除旧的覆盖层\n                    var oldOverlay = document.getElementById('wasm-disconnected-overlay');\n                    if (oldOverlay) oldOverlay.remove();\n                    // 创建灰色覆盖层（不破坏 WASM 容器）\n                    var overlay = document.createElement('div');\n                    overlay.id = 'wasm-disconnected-overlay';\n                    overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px;z-index:10';\n                    overlay.innerHTML = '设备已断开';\n                    container.style.position = 'relative';\n                    container.appendChild(overlay);\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = '';\n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n            \n            // v6.12: 更新 WASM 状态\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }","oldText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v5.47: Clear video window content\n                var container = document.getElementById('divPlugin');\n                if (container && window.WebVideoCtrl) {\n                    try {\n                        // 尝试清空视频窗口\n                        WebVideoCtrl.I_ClearWindowContent(0);\n                    } catch(e2) { console.warn('ClearWindow error:', e2); }\n                }\n                // v6.12: 显示断开提示\n                if (container) {\n                    container.style.background = '#0d1117';\n                    container.innerHTML = '<div style=\"display:flex;align-items:center;justify-content:center;height:100%;color:#6e7681;font-size:14px\">画面已断开</div>';\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = ''; \n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n            \n            // v6.12: 更新 WASM 状态\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src