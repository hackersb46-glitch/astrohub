{"type":"message","id":"491d8b83","parentId":"0b00cbea","timestamp":"2026-06-14T01:43:38.216Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tool-6f5d6f4bc70e461fac6315aa70cd11e4","name":"edit","arguments":{"edits":[{"newText":"// v6.20 + v7.0: 启用所有控制区域\nfunction enableImageControls() {\n    // 启用画面控制控件\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = false;\n            el.style.opacity = '1';\n            el.style.cursor = 'pointer';\n        }\n    });\n    \n    // v7.0: 启用 PTZ 控制按钮\n    var ptzSection = document.getElementById('ptzControlSection');\n    if (ptzSection) {\n        var ptzBtns = ptzSection.querySelectorAll('.btn, .ptz-btn');\n        ptzBtns.forEach(function(btn) {\n            if (btn.id !== 'ptzSpeed') {\n                btn.disabled = false;\n                btn.style.opacity = '1';\n                btn.style.cursor = 'pointer';\n            }\n        });\n    }\n    \n    // v7.0: 启用媒体操作按钮\n    var mediaButtons = ['btnConsoleSnapshot', 'btnConsoleRecordStart', 'btnConsoleRecordStop', 'btnLiveStackStart', 'btnLiveStackStop', 'btnLiveStackSave'];\n    mediaButtons.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = false;\n            el.style.opacity = '1';\n            el.style.cursor = 'pointer';\n        }\n    });\n    \n    // v7.0: 启用跟踪控制按钮\n    var trackButtons = ['btnTrackSidereal', 'btnTrackLunar', 'btnTrackSolar', 'btnTrackOff'];\n    trackButtons.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = false;\n            el.style.opacity = '1';\n            el.style.cursor = 'pointer';\n        }\n    });\n    \n    // 移除警告\n    var warning = document.getElementById('functionCacheWarning');\n    if (warning) warning.remove();\n    \n    // v7.0: 启动 PTZ 坐标刷新\n    if (window.startPtzImagePoll) window.startPtzImagePoll();\n}","oldText":"// v6.20: 启用画面控制\nfunction enableImageControls() {\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = false;\n            el.style.opacity = '1';\n            el.style.cursor = 'pointer';\n        }\n    });\n    \n    // 移除警告\n    var warning = document.getElementById('functionCacheWarning');\n    if (warning) warning.remove();\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":41003,"output":855,"cacheRead":0,"cacheWrite":0,"totalTokens":41858,"cost":{"input":0.041003,"output":0.002736,"cacheRead":0,"cacheWrite":0,"total":0.043739}},"stopReason":"toolUse","timestamp":1781401394050,"responseId":"cht000df3c4@dx19ec3cc2ce0b828232"}}
