{"type":"message","id":"91baf520","parentId":"3accdc44","timestamp":"2026-06-14T12:42:20.142Z","message":{"role":"assistant","content":[{"type":"text","text":"服务启动成功。现在用 Playwright 测试断开后的控件状态："},{"type":"toolCall","id":"call_859f938910b74ebca8eceda5","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"测试断开连接后控件禁用状态\"\"\"\nimport asyncio\nfrom playwright.async_api import async_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\nasync def test_controls_disabled():\n    \"\"\"测试断开后增益、OSD、PTZ 控件是否禁用\"\"\"\n    \n    print(\"=\" * 60)\n    print(\"测试：断开连接后控件禁用状态\")\n    print(\"=\" * 60)\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        page = await browser.new_page()\n        \n        # 打开主页\n        await page.goto(BASE_URL)\n        await asyncio.sleep(2)\n        \n        # 切换到主控台页面\n        await page.click('[data-page=\"console\"]')\n        await asyncio.sleep(1)\n        \n        # 检查初始状态\n        print(\"\\n[检查] 初始控件状态\")\n        \n        # 检查增益控件\n        gain_el = await page.query_selector('#gainLevel')\n        if gain_el:\n            gain_disabled = await gain_el.get_attribute('disabled')\n            print(f\"增益控件 disabled: {gain_disabled}\")\n        else:\n            print(\"增益控件未找到\")\n        \n        # 检查 OSD 控件\n        info_osd = await page.query_selector('#infoOsdSwitch')\n        if info_osd:\n            osd_disabled = await info_osd.get_attribute('disabled')\n            print(f\"OSD 控件 disabled: {osd_disabled}\")\n        \n        # 检查 PTZ 按钮\n        ptz_btn = await page.query_selector('.ptz-btn')\n        if ptz_btn:\n            ptz_disabled = await ptz_btn.get_attribute('disabled')\n            print(f\"PTZ 按钮 disabled: {ptz_disabled}\")\n        \n        # 截图\n        await page.screenshot(path='test_controls_initial.png')\n        print(\"截图: test_controls_initial.png\")\n        \n        await browser.close()\n\nif __name__ == \"__main__\":\n    asyncio.run(test_controls_disabled())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_controls_disabled.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":80646,"output":486,"cacheRead":0,"cacheWrite":0,"totalTokens":81132,"cost":{"input":0.080646,"output":0.0015552,"cacheRead":0,"cacheWrite":0,"total":0.0822012}},"stopReason":"toolUse","timestamp":1781440932251,"responseId":"cht000d70ae@dx19ec6276f74b85e102"}}
