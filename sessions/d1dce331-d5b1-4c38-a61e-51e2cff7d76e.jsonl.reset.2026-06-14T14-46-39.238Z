{"type":"message","id":"0bb8836d","parentId":"91392ac5","timestamp":"2026-06-14T02:43:39.203Z","message":{"role":"toolResult","toolCallId":"call_60721c4d8f1c47a58082e448","toolName":"read","content":[{"type":"text","text":"                              if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                    }\r\n                } else {\r\n                    showToast('error', result ? result.message : '连接失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '连接异常: ' + e.message);\r\n            });\r\n        }\r\n        function disconnectDevice(ip) {\r\n            // v6.54: 防止重复点击\r\n            if (_connectionOperationInProgress) {\r\n                showToast('warning', '请等待上一次操作完成');\r\n                return;\r\n            }\r\n            _connectionOperationInProgress = true;\r\n\r\n            // 禁用连接按钮\r\n            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(false);\r\n\r\n            showToast('info', '正在断开设备...');\r\n            // --- Stop PTZ position polling ---\r\n            if (window.stopPtzPositionPoll) window.stopPtzPositionPoll();\r\n            // --- Stop WASM video stream ---\r\n            if (window.wasmLogout) window.wasmLogout();\r\n            // v6.16: 清除 WASM 状态\r\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\r\n\r\n            // v6.54: 禁用主控台和高级功能\r\n            if (window.disableAllControls) window.disableAllControls('请先连接设备');\r\n\r\n            apiPost('/api/v1/devices/' + ip + '/disconnect', null).then(function() {\r\n                showToast('success', '设备已断开: ' + ip);\r\n                addLog('info', '设备已断开: ' + ip);\r\n                // --- Clear global window.connectedDevice first, before refresh ---\r\n                if (window.connectedDevice && window.connectedDevice.ip === ip) {\r\n                    window.connectedDevice = null;\r\n                    addLog('info', '已清除连接设备状态');\r\n                }\r\n                if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                refreshDevices();\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n                var panel = document.getElementById('deviceInfoPanel');\r\n                if (panel) panel.style.display = 'none';\r\n\r\n                _connectionOperationInProgress = false;\r\n                if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n            }).catch(function(e) {\r\n                _connectionOperationInProgress = false;\r\n\n[1413 more lines in file. Use offset=1454 to continue.]"}],"isError":false,"timestamp":1781405019203}}
{"type":"message","id":"9cabcc26","parentId":"0bb8836d","timestamp":"2026-06-14T02:43:54.069Z","message":{"role":"assistant","content":[{"type":"text","text":"代码正确调用了 `window.wasmLogout()`。问题可能是 `divPlugin` 在 WASM SDK 初始化时被替换了。让我检查 WASM 初始化代码中是否在 `cbInitPluginComplete` 中正确处理了容器："},{"type":"toolCall","id":"call_0dbdd490d8c143d3805821a7","name":"read","arguments":{"limit":50,"offset":2360,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":97442,"output":96,"cacheRead":0,"cacheWrite":0,"totalTokens":97538,"cost":{"input":0.097442,"output":0.00030720000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0977492}},"stopReason":"toolUse","timestamp":1781405019205,"responseId":"cht000df82c@dx19ec4038b38b87f702"}}
{"type":"message","id":"e3b24953","parentId":"9cabcc26","timestamp":"2026-06-14T02:43:54.076Z","message":{"role":"toolResult","toolCallId":"call_0dbdd490d8c143d3805821a7","toolName":"read","content":[{"type":"text","text":"                    WebVideoCtrl.I_Stop();\r\n                },\r\n                cbSelWnd: function(xmlDoc) {\r\n                    g_iWndIndex = parseInt($(xmlDoc).find(\"SelectWnd\").eq(0).text(), 10);\r\n                },\r\n                cbInitPluginComplete: function() {\r\n                    console.log('[WASM] cbInitPluginComplete - inserting plugin');\r\n                    WebVideoCtrl.I_InsertOBJECTPlugin(\"divPlugin\");\r\n                    \r\n                    // v7.0: 初始显示灰色覆盖层\r\n                    var container = document.getElementById('divPlugin');\r\n                    if (container && !document.getElementById('wasm-disconnected-overlay')) {\r\n                        var overlay = document.createElement('div');\r\n                        overlay.id = 'wasm-disconnected-overlay';\r\n                        overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px;z-index:10';\r\n                        overlay.innerHTML = '请连接设备';\r\n                        container.style.position = 'relative';\r\n                        container.appendChild(overlay);\r\n                    }\r\n\r\n                    // Patch: fix oStreamClient.openStream URL parsing\r\n                    // SDK adds ?deviceIdentify=... to WS URL, but openStream's\r\n                    // parser can't handle query params in the path segment\r\n                    var _origOpenStream = null;\r\n                    try {\r\n                        var ds = WebVideoCtrl.w_deviceSet;\r\n                        if (ds && ds.length > 0) {\r\n                            // Will be patched after login when oStreamClient is available\r\n                        }\r\n                    } catch(e) {}\r\n\r\n                    // WASM SDK ready - trigger login if device already connected\r\n                    if (window.connectedDevice && window.connectedDevice.ip && window.clickLogin2) {\r\n                        console.log('[WASM] Device already connected, triggering login');\r\n                        window.clickLogin2();\r\n                    }\r\n                    // Update device status display\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                },\r\n                cbPluginErrorHandler: function(iWndIndex, iErrorCode, oError) {\r\n                    console.error('[WASM] Plugin error:', iWndIndex, iErrorCode);\r\n                },\r\n                cbPerformanceLack: function() {\r\n                    console.error('[WASM] Performance issue');\r\n                }\r\n            });\r\n            console.log('[WASM] I_InitPlugin called');\r\n        }\r\n        if (document.readyState === 'loading') {\r\n            document.addEventListener('DOMContentLoaded', initWasm);\r\n\n[457 more lines in file. Use offset=2410 to continue.]"}],"isError":false,"timestamp":1781405034076}}
{"type":"message","id":"fc90f0d1","parentId":"e3b24953","timestamp":"2026-06-14T02:44:21.492Z","message":{"role":"assistant","content":[{"type":"text","text":"问题找到了！`I_InsertOBJECTPlugin(\"divPlugin\")` 会替换 `divPlugin` 的内容，所以覆盖层在 WASM SDK 初始化后被清除了。\n\n需要在 `I_InsertOBJECTPlugin` 之后再添加覆盖层，但当前代码已经是这样做的。问题可能是 WASM SDK 插入了自己的 DOM 结构覆盖了我们的覆盖层。\n\n让我修改 wasmLogout 函数，确保它能在 WASM SDK 的 DOM 结构之上添加覆盖层："},{"type":"toolCall","id":"tool-96ec326004a74f5e98b590b916a40864","name":"edit","arguments":{"edits":[{"newText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v7.01: 确保 WASM 容器存在并添加覆盖层\n                var container = document.getElementById('divPlugin');\n                if (container) {\n                    // 移除旧的覆盖层\n                    var oldOverlay = document.getElementById('wasm-disconnected-overlay');\n                    if (oldOverlay) oldOverlay.remove();\n                    \n                    // v7.01: 先确保容器可见\n                    container.style.display = 'block';\n                    container.style.position = 'relative';\n                    \n                    // 创建灰色覆盖层(使用更高的 z-index 覆盖 WASM 内容)\n                    var overlay = document.createElement('div');\n                    overlay.id = 'wasm-disconnected-overlay';\n                    overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;z-index:9999;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px';\n                    overlay.innerHTML = '设备已断开';\n                    container.appendChild(overlay);\n                    console.log('[WASM] Overlay created on disconnect');\n                } else {\n                    console.warn('[WASM] divPlugin container not found');\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = '';\n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n\n            // v6.12: 更新 WASM 状态\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }","oldText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v7.0: 不销毁 WASM 容器，只显示灰色覆盖层\n                var container = document.getElementById('divPlugin');\n                if (container) {\n                    // 移除旧的覆盖层\n                    var oldOverlay = document.getElementById('wasm-disconnected-overlay');\n                    if (oldOverlay) oldOverlay.remove();\n                    // 创建灰色覆盖层(不破坏 WASM 容器)\n                    var overlay = document.createElement('div');\n                    overlay.id = 'wasm-disconnected-overlay';\n                    overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px;z-index:10';\n                    overlay.innerHTML = '设备已断开';\n                    container.style.position = 'relative';\n                    container.appendChild(overlay);\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = ''; \n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n\n            // v6.12: 更新 WASM 状态\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":91117,"output":1100,"cacheRead":0,"cacheWrite":0,"totalTokens":92217,"cost":{"input":0.09111699999999999,"output":0.00352,"cacheRead":0,"cacheWrite":0,"total":0.09463699999999999}},"stopReason":"toolUse","timestamp":1781405034078,"responseId":"cht000d80c8@dx19ec403b73cba5a412"}}
