{"type":"message","id":"73c02f66","parentId":"8408c7b6","timestamp":"2026-06-14T01:44:06.144Z","message":{"role":"toolResult","toolCallId":"call_07c34f82664646de851efcf5","toolName":"read","content":[{"type":"text","text":"        function disconnectDevice(ip) {\r\n            // v6.54: 防止重复点击\r\n            if (_connectionOperationInProgress) {\r\n                showToast('warning', '请等待上一次操作完成');\r\n                return;\r\n            }\r\n            _connectionOperationInProgress = true;\r\n            \r\n            // 禁用连接按钮\r\n            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(false);\r\n            \r\n            showToast('info', '正在断开设备...');\r\n            // --- Stop PTZ position polling ---\r\n            if (window.stopPtzPositionPoll) window.stopPtzPositionPoll();\r\n            // --- Stop WASM video stream ---\r\n            if (window.wasmLogout) window.wasmLogout();\r\n            // v6.16: 清除 WASM 状态\r\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\r\n            \r\n            // v6.54: 禁用主控台和高级功能\r\n            if (window.disableAllControls) window.disableAllControls('请先连接设备');\r\n            \r\n            apiPost('/api/v1/devices/' + ip + '/disconnect', null).then(function() {\r\n                showToast('success', '设备已断开: ' + ip);\r\n                addLog('info', '设备已断开: ' + ip);\r\n                // --- Clear global window.connectedDevice first, before refresh ---\r\n                if (window.connectedDevice && window.connectedDevice.ip === ip) {\r\n                    window.connectedDevice = null;\r\n                    addLog('info', '已清除连接设备状态');\r\n                }\r\n                if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                refreshDevices();\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n                var panel = document.getElementById('deviceInfoPanel');\r\n                if (panel) panel.style.display = 'none';\r\n                \r\n                _connectionOperationInProgress = false;\r\n                if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n            }).catch(function(e) {\r\n                _connectionOperationInProgress = false;\r\n                if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                showToast('error', '断开异常: ' + e.message);\r\n            });\r\n        }\r\n        function deleteDevice(identifier) {\r\n            if (!confirm('确定删除设备 ' + identifier + '？')) return;\r\n            apiDelete('/api/v1/devices/' + identifier).then(function() {\r\n                showToast('success', '设备已删除');\r\n                addLog('info', '设备已删除: ' + identifier);\r\n                refreshDevices();\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n            }).catch(function(e) {\r\n                showToast('error', '删除异常: ' + e.message);\r\n            });\r\n        }\r\n        // Show modify IP modal for SADP device\r\n        // Submit modify IP\r\n        // Add Device Modal\r\n\n[1374 more lines in file. Use offset=1464 to continue.]"}],"isError":false,"timestamp":1781401446144}}
