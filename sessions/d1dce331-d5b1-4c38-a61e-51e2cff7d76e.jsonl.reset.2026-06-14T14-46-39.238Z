{"type":"message","id":"eee49198","parentId":"c0356a6d","timestamp":"2026-06-14T03:01:54.663Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了！手动模式下有三个独立的端点：\n- `/ISAPI/Image/channels/1/Shutter` - 快门\n- `/ISAPI/Image/channels/1/Iris` - 光圈\n- `/ISAPI/Image/channels/1/Gain` - 增益\n\n现在测试设置它们："},{"type":"toolCall","id":"call_401d77cefb824178b83a5750","name":"write","arguments":{"content":"import requests\nfrom requests.auth import HTTPDigestAuth\n\n# 测试设置快门\nxml_shutter = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Shutter version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ShutterLevel>1/60</ShutterLevel>\n</Shutter>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/Shutter', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_shutter,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint(f'Set Shutter to 1/60: {resp.status_code}')\n\n# 验证\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Shutter', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nprint(f'Current Shutter: {resp.text}')\n\n# 测试设置光圈\nxml_iris = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Iris version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <IrisLevel>1600</IrisLevel>\n</Iris>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/Iris', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_iris,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint(f'\\nSet Iris to 1600: {resp.status_code}')\n\n# 验证\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Iris', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nprint(f'Current Iris: {resp.text}')\n\n# 测试设置增益\nxml_gain = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Gain version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <GainLevel>50</GainLevel>\n</Gain>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/Gain', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_gain,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint(f'\\nSet Gain to 50: {resp.status_code}')\n\n# 验证\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Gain', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nprint(f'Current Gain: {resp.text}')\n\n# 恢复自动模式\nxml_auto = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_auto,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint(f'\\nRestored to auto: {resp.status_code}')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_manual_exposure.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":119662,"output":875,"cacheRead":0,"cacheWrite":0,"totalTokens":120537,"cost":{"input":0.11966199999999999,"output":0.0028000000000000004,"cacheRead":0,"cacheWrite":0,"total":0.12246199999999999}},"stopReason":"toolUse","timestamp":1781406075387,"responseId":"cht000d2a87@dx19ec413d86eba5b442"}}
