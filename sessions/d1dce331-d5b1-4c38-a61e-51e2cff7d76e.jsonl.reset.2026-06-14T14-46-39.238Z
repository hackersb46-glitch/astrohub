{"type":"message","id":"5c9865cb","parentId":"aefca32a","timestamp":"2026-06-14T14:38:05.531Z","message":{"role":"assistant","content":[{"type":"text","text":"**服务启动成功！**\n\n---\n\n## 步骤 4：E2E 完整验证"},{"type":"toolCall","id":"call_6b51f41abdbd4d8dbf6fb2b0","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nE2E 完整验证 - 清理后功能测试\n\"\"\"\nimport asyncio\nimport requests\nfrom playwright.async_api import async_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\nasync def e2e_full_test():\n    \"\"\"完整 E2E 测试\"\"\"\n    \n    print(\"=\" * 60)\n    print(\"E2E 完整验证 - 清理后\")\n    print(\"=\" * 60)\n    \n    results = []\n    \n    # 1. 健康检查\n    print(\"\\n[测试 1] 健康检查\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/health\")\n    health = resp.json()\n    status = \"PASS\" if health.get('status') in ['ok', 'degraded'] else \"FAIL\"\n    print(f\"  状态: {health.get('status')} - {status}\")\n    results.append((\"健康检查\", status))\n    \n    # 2. 设备发现\n    print(\"\\n[测试 2] 设备发现\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/discovery/sadp\")\n    devices = resp.json()\n    found = devices.get('total', 0) > 0\n    status = \"PASS\" if found else \"FAIL\"\n    print(f\"  发现设备: {devices.get('total', 0)} - {status}\")\n    results.append((\"设备发现\", status))\n    \n    # 3. 连接设备\n    print(\"\\n[测试 3] 连接设备\")\n    device_ip = \"192.168.5.72\"\n    resp = requests.post(\n        f\"{BASE_URL}/api/v1/devices/{device_ip}/connect\",\n        json={\"username\": \"admin\", \"password\": \"Nftw1357\", \"port\": 80}\n    )\n    connect = resp.json()\n    status = \"PASS\" if connect.get('success') else \"FAIL\"\n    print(f\"  连接: {connect.get('message', '')} - {status}\")\n    results.append((\"连接设备\", status))\n    \n    # 4. PTZ 控制\n    print(\"\\n[测试 4] PTZ 控制\")\n    await asyncio.sleep(1)\n    resp = requests.get(f\"{BASE_URL}/api/v1/ptz/{device_ip}/position\")\n    pos = resp.json()\n    status = \"PASS\" if pos.get('success') else \"FAIL\"\n    print(f\"  PTZ 位置: {pos.get('pan', 0):.1f}, {pos.get('tilt', 0):.1f} - {status}\")\n    results.append((\"PTZ 控制\", status))\n    \n    # 5. 图像参数\n    print(\"\\n[测试 5] 图像参数\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/ptz/{device_ip}/image/shutter\")\n    shutter = resp.json()\n    status = \"PASS\" if shutter.get('success') else \"FAIL\"\n    print(f\"  快门: {shutter.get('current_level', '')} - {status}\")\n    results.append((\"图像参数\", status))\n    \n    # 6. 断开设备\n    print(\"\\n[测试 6] 断开设备\")\n    resp = requests.post(f\"{BASE_URL}/api/v1/devices/{device_ip}/disconnect\")\n    disconnect = resp.json()\n    status = \"PASS\" if disconnect.get('success') else \"FAIL\"\n    print(f\"  断开: {disconnect.get('message', '')} - {status}\")\n    results.append((\"断开设备\", status))\n    \n    # 7. 快速连接状态\n    print(\"\\n[测试 7] 快速连接状态\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n    conn = resp.json()\n    has_device = conn.get('device') is not None\n    status = \"PASS\" if has_device else \"FAIL\"\n    print(f\"  有上次设备: {has_device} - {status}\")\n    results.append((\"快速连接\", status))\n    \n    # 8. Playwright UI 测试\n    print(\"\\n[测试 8] UI 测试\")\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        page = await browser.new_page()\n        \n        # 打开主页\n        await page.goto(BASE_URL)\n        await asyncio.sleep(2)\n        \n        # 检查版本号\n        version_el = await page.query_selector('.version')\n        version = await version_el.inner_text() if version_el else \"\"\n        status = \"PASS\" if \"v7.12\" in version else \"FAIL\"\n        print(f\"  版本: {version} - {status}\")\n        results.append((\"UI 版本\", status))\n        \n        # 检查页面加载\n        title = await page.title()\n        status = \"PASS\" if title else \"FAIL\"\n        print(f\"  页面标题: {title} - {status}\")\n        results.append((\"页面加载\", status))\n        \n        await browser.close()\n    \n    # 总结\n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试总结\")\n    print(\"=\" * 60)\n    \n    passed = sum(1 for _, s in results if s == \"PASS\")\n    total = len(results)\n    \n    for name, status in results:\n        mark = \"✓\" if status == \"PASS\" else \"✗\"\n        print(f\"  {mark} {name}\")\n    \n    print(f\"\\n通过: {passed}/{total}\")\n    \n    return passed == total\n\nif __name__ == \"__main__\":\n    result = asyncio.run(e2e_full_test())\n    exit(0 if result else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\e2e_full_test.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":133548,"output":1280,"cacheRead":0,"cacheWrite":0,"totalTokens":134828,"cost":{"input":0.133548,"output":0.004096000000000001,"cacheRead":0,"cacheWrite":0,"total":0.137644}},"stopReason":"toolUse","timestamp":1781447848003,"responseId":"cht000d59d5@dx19ec6910a66b958232"}}
