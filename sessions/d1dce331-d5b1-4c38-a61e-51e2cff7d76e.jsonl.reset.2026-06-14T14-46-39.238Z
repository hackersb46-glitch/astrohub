Level>'''\n        \n        xml_str += f'''\n  <IrisLevel>{level}</IrisLevel>\n</Exposure>'''\n\n        put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": f\"光圈已设置\"}\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置光圈异常: {e}\"}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":124772,"output":701,"cacheRead":0,"cacheWrite":0,"totalTokens":125473,"cost":{"input":0.124772,"output":0.0022432000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1270152}},"stopReason":"toolUse","timestamp":1781406541860,"responseId":"cht000d5f89@dx19ec41ab186b958232"}}
