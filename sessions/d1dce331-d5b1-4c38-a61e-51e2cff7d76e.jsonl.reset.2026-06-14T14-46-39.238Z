ImageParams(window.connectedDevice.ip);\n}\n\n// v6.50: 重置画面控制到系统默认值\nfunction resetImageControls() {\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\n        console.warn('[IMAGE] No device connected');\n        return;\n    }\n    \n    // 弹出确认对话框\n    if (!confirm('确认重置画面控制到系统默认值？')) {\n        return;\n    }\n    \n\n[744 more lines in file. Use offset=468 to continue.]"}],"isError":false,"timestamp":1781401382324}}
