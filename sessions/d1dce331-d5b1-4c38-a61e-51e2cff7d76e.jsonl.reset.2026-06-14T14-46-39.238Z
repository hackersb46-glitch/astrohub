{"type":"message","id":"9412b733","parentId":"32f28b8e","timestamp":"2026-06-14T02:47:56.717Z","message":{"role":"assistant","content":[{"type":"text","text":"奇怪，单独测试时覆盖层创建了（count=1），但在完整测试中却说没有创建。让我检查完整测试中的时序问题："},{"type":"toolCall","id":"tool-9632fcb5422c47a7aceda55d7477a519","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_v701():\n    results = []\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        page.on('console', lambda msg: print(f'[Browser] {msg.text}'))\n        page.goto('http://localhost:10280')\n        time.sleep(3)\n        \n        print('\\n=== 1. Version Check ===')\n        version = page.locator('.version').text_content()\n        results.append(('Version', version == 'v7.01', version))\n        \n        print('\\n=== 2. Console Page ===')\n        page.click('text=主控台')\n        time.sleep(1)\n        \n        warning = page.locator('#consoleWarning')\n        warning_visible = warning.evaluate('el => el.style.display !== \"none\"')\n        print(f'Console Warning display: {warning.evaluate(\"el => el.style.display\")}')\n        \n        # 由于设备自动连接，warning 应该隐藏\n        results.append(('Console Warning Hidden (auto-connect)', not warning_visible, f'display={warning.evaluate(\"el => el.style.display\")}'))\n        \n        wasm_overlay = page.locator('#wasm-disconnected-overlay')\n        print(f'WASM Overlay count: {wasm_overlay.count()}')\n        \n        # 由于设备自动连接，overlay 应该不存在\n        results.append(('WASM Overlay Not Exists (auto-connect)', wasm_overlay.count() == 0, f'count={wasm_overlay.count()}'))\n        \n        print('\\n=== 3. Disconnect Device ===')\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", false)')\n        time.sleep(4)\n        \n        # 检查断开后状态\n        warning_visible_after = warning.evaluate('el => el.style.display !== \"none\"')\n        print(f'Console Warning display after disconnect: {warning.evaluate(\"el => el.style.display\")}')\n        results.append(('Warning Visible After Disconnect', warning_visible_after, f'display={warning.evaluate(\"el => el.style.display\")}'))\n        \n        # 等待一下让 wasmLogout 执行完成\n        time.sleep(1)\n        \n        wasm_overlay_after = page.locator('#wasm-disconnected-overlay')\n        print(f'WASM Overlay count after disconnect: {wasm_overlay_after.count()}')\n        results.append(('WASM Overlay Created After Disconnect', wasm_overlay_after.count() > 0, f'count={wasm_overlay_after.count()}'))\n        \n        # 检查控件是否禁用\n        ptz_btn = page.locator('#ptzControlSection .ptz-btn').first\n        if ptz_btn.count() > 0:\n            is_disabled = ptz_btn.evaluate('el => el.disabled')\n            print(f'PTZ button disabled: {is_disabled}')\n            results.append(('PTZ Buttons Disabled After Disconnect', is_disabled, f'disabled={is_disabled}'))\n        else:\n            results.append(('PTZ Buttons Disabled After Disconnect', False, 'buttons not found'))\n        \n        print('\\n=== 4. Reconnect Device ===')\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", true)')\n        time.sleep(5)\n        \n        page.click('text=主控台')\n        time.sleep(3)\n        \n        wasm_overlay_reconnect = page.locator('#wasm-disconnected-overlay')\n        print(f'WASM Overlay count after reconnect: {wasm_overlay_reconnect.count()}')\n        results.append(('WASM Overlay Removed After Reconnect', wasm_overlay_reconnect.count() == 0, f'count={wasm_overlay_reconnect.count()}'))\n        \n        wasm_container = page.locator('#divPlugin')\n        results.append(('WASM Container Exists', wasm_container.count() > 0, f'count={wasm_container.count()}'))\n        \n        # OSD 开关\n        time.sleep(2)\n        ptz_switch = page.locator('#ptzOsdSwitch')\n        info_switch = page.locator('#infoOsdSwitch')\n        if ptz_switch.count() > 0:\n            ptz_checked = ptz_switch.evaluate('el => el.checked')\n            results.append(('PTZ OSD Switch', True, f'checked={ptz_checked}'))\n        if info_switch.count() > 0:\n            info_checked = info_switch.evaluate('el => el.checked')\n            results.append(('Info OSD Switch', True, f'checked={info_checked}'))\n        \n        browser.close()\n    \n    # 输出结果\n    print('\\n' + '='*60)\n    print('v7.01 E2E Test Results')\n    print('='*60)\n    passed = 0\n    failed = 0\n    for name, success, detail in results:\n        status = 'PASS' if success else 'FAIL'\n        if success:\n            passed += 1\n        else:\n            failed += 1\n        print(f'[{status}] {name}: {detail}')\n    \n    print('='*60)\n    print(f'Total: {passed} passed, {failed} failed')\n    print('='*60)\n    \n    return failed == 0\n\nif __name__ == '__main__':\n    success = test_v701()\n    exit(0 if success else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_v701_final.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":94879,"output":1174,"cacheRead":0,"cacheWrite":0,"totalTokens":96053,"cost":{"input":0.09487899999999999,"output":0.0037568000000000002,"cacheRead":0,"cacheWrite":0,"total":0.0986358}},"stopReason":"toolUse","timestamp":1781405242166,"responseId":"cht000dae71@dx19ec406fa61b8ab282"}}
