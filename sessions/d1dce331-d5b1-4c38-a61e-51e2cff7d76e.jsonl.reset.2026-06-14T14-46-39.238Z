{"type":"message","id":"a46012c9","parentId":"ff07f0db","timestamp":"2026-06-14T02:46:02.277Z","message":{"role":"assistant","content":[{"type":"text","text":"问题依然存在。初始测试时设备已经自动连接了（通过 `restoreConnectionState`），所以前 3 项失败是正常的。主要问题是 **断开后 WASM Overlay 没有重新创建**。\n\n让我检查浏览器控制台日志，看看是否有错误。先写一个更详细的测试："},{"type":"toolCall","id":"call_5fd84396b605408b92413ad0","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_wasm_overlay():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        \n        # 监听控制台日志\n        page.on('console', lambda msg: print(f'[Browser] {msg.text}'))\n        \n        page.goto('http://localhost:10280')\n        time.sleep(3)\n        \n        print('\\n=== Initial State ===')\n        print(f'Connected device: {page.evaluate(\"window.connectedDevice\")}')\n        \n        # 进入主控台\n        page.click('text=主控台')\n        time.sleep(1)\n        \n        # 检查 divPlugin 内容\n        div_plugin_content = page.evaluate('document.getElementById(\"divPlugin\").innerHTML.substring(0, 200)')\n        print(f'divPlugin innerHTML: {div_plugin_content}...')\n        \n        # 检查覆盖层\n        overlay_count = page.locator('#wasm-disconnected-overlay').count()\n        print(f'WASM overlay count: {overlay_count}')\n        \n        # 断开设备\n        print('\\n=== Disconnecting ===')\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", false)')\n        time.sleep(3)\n        \n        # 检查 divPlugin 内容\n        div_plugin_content_after = page.evaluate('document.getElementById(\"divPlugin\").innerHTML.substring(0, 300)')\n        print(f'divPlugin innerHTML after disconnect: {div_plugin_content_after}...')\n        \n        # 检查覆盖层\n        overlay_count_after = page.locator('#wasm-disconnected-overlay').count()\n        print(f'WASM overlay count after disconnect: {overlay_count_after}')\n        \n        # 检查 wasmLogout 是否被调用\n        print(f'g_bLoggedIn2: {page.evaluate(\"typeof g_bLoggedIn2 !== \\\"undefined\\\" ? g_bLoggedIn2 : \\\"undefined\\\"\")}')\n        print(f'g_bPlaying2: {page.evaluate(\"typeof g_bPlaying2 !== \\\"undefined\\\" ? g_bPlaying2 : \\\"undefined\\\"\")}')\n        \n        time.sleep(2)\n        browser.close()\n\nif __name__ == '__main__':\n    test_wasm_overlay()","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_wasm_debug.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":93293,"output":578,"cacheRead":0,"cacheWrite":0,"totalTokens":93871,"cost":{"input":0.093293,"output":0.0018496,"cacheRead":0,"cacheWrite":0,"total":0.09514260000000001}},"stopReason":"toolUse","timestamp":1781405135045,"responseId":"cht000d0644@dx19ec4057e7bba5d322"}}
