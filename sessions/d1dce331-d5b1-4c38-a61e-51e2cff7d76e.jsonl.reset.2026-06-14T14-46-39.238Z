e>\r\r\n<isSupportLaserSpotManual>false</isSupportLaserSpotManual>\r\r\n<isSupportDOFAdjust>false</isSupportDOFAdjust>\r\r\n</ImageChannel>"}],"details":{"status":"completed","exitCode":0,"durationMs":883,"aggregated":"C:\\Python\\Lib\\site-packages\\requests\\__init__.py:113: RequestsDependencyWarning: urllib3 (2.1.0) or chardet (7.2.0)/charset_normalizer (3.4.6) doesn't match a supported version!\r\n  warnings.warn(\r\n============================================================\r\n��ȡ Image Channel ���� capabilities\r\n============================================================\r\n״̬: 200\r\n������Ӧ:\r\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\r\n<ImageChannel version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\r\n<id>1</id>\r\r\n<enabled>true</enabled>\r\r\n<videoInputID>1</videoInputID>\r\r\n<WDR>\r\r\n<mode opt=\"close,open\">close</mode>\r\r\n<WDRLevel min=\"0\" max=\"100\">50</WDRLevel>\r\r\n</WDR>\r\r\n<BLC>\r\r\n<enabled opt=\"true,false\">false</enabled>\r\r\n<BLCMode opt=\"CLOSE,UP,DOWN,LEFT,RIGHT,CENTER,AUTO\">CLOSE</BLCMode>\r\r\n</BLC>\r\r\n<IrcutFilter>\r\r\n<IrcutFilterType opt=\"day,night,auto,schedule\">auto</IrcutFilterType>\r\r\n<Schedule>\r\r\n<scheduleType opt=\"day,night\">day</scheduleType>\r\r\n<TimeRange>\r\r\n<beginTime>07:00:00</beginTime>\r\r\n<endTime>18:00:00</endTime>\r\r\n</TimeRange>\r\r\n</Schedule>\r\r\n</IrcutFilter>\r\r\n<WhiteBalance>\r\r\n<WhiteBalanceStyle opt=\"manual,locked,outdoor,indoor,daylightLamp,sodiumlight,autotrace,auto\">auto</WhiteBalanceStyle>\r\r\n<WhiteBalanceRed min=\"0\" max=\"255\">166</WhiteBalanceRed>\r\r\n<WhiteBalanceBlue min=\"0\" max=\"255\">61</WhiteBalanceBlue>\r\r\n</WhiteBalance>\r\r\n<Exposure>\r\r\n<ExposureType opt=\"manual,auto,IrisFirst,ShutterFirst\">manual</ExposureType>\r\r\n<OverexposeSuppress>\r\r\n<enabled opt=\"true,false\">false</enabled>\r\r\n</OverexposeSuppress>\r\r\n</Exposure>\r\r\n<Iris>\r\r\n<IrisLevel opt=\"160,200,240,280,340,400,480,560,680,960,1100,14