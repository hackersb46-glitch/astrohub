{"type":"message","id":"5e707aa1","parentId":"e2d7cbd3","timestamp":"2026-06-14T03:15:00.759Z","message":{"role":"toolResult","toolCallId":"call_1f321f68ceef4d38993c13e1","toolName":"read","content":[{"type":"text","text":"function updateShutterIrisState() {\n    var exposureMode = document.getElementById('exposureMode');\n    var shutterSelect = document.getElementById('shutterSpeed');\n    var irisSelect = document.getElementById('irisLevel');\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\n    \n    var isManual = exposureMode.value === 'manual';\n    shutterSelect.disabled = !isManual;\n    irisSelect.disabled = !isManual;\n    \n    // 禁用时灰色样式\n    if (!isManual) {\n        shutterSelect.style.opacity = '0.5';\n        irisSelect.style.opacity = '0.5';\n    } else {\n        shutterSelect.style.opacity = '1';\n        irisSelect.style.opacity = '1';\n    }\n}\n\n// 设置快门\nfunction setShutterSpeed(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '快门: ' + value);\n        });\n}\n\n\n[233 more lines in file. Use offset=1113 to continue.]"}],"isError":false,"timestamp":1781406900759}}
{"type":"message","id":"2e6a3ed4","parentId":"5e707aa1","timestamp":"2026-06-14T03:15:19.039Z","message":{"role":"assistant","content":[{"type":"text","text":"..."},{"type":"toolCall","id":"call_35b5a01ba9e84e48b02f3b31","name":"edit","arguments":{"edits":[{"newText":"function updateShutterIrisState() {\n    var exposureMode = document.getElementById('exposureMode');\n    var shutterSelect = document.getElementById('shutterSpeed');\n    var irisSelect = document.getElementById('irisLevel');\n    var gainSlider = document.getElementById('gainLevel');\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\n    \n    var isManual = exposureMode.value === 'manual';\n    shutterSelect.disabled = !isManual;\n    irisSelect.disabled = !isManual;\n    if (gainSlider) gainSlider.disabled = !isManual;\n    \n    // 禁用时灰色样式\n    if (!isManual) {\n        shutterSelect.style.opacity = '0.5';\n        irisSelect.style.opacity = '0.5';\n        if (gainSlider) gainSlider.style.opacity = '0.5';\n    } else {\n        shutterSelect.style.opacity = '1';\n        irisSelect.style.opacity = '1';\n        if (gainSlider) gainSlider.style.opacity = '1';\n    }\n}","oldText":"function updateShutterIrisState() {\n    var exposureMode = document.getElementById('exposureMode');\n    var shutterSelect = document.getElementById('shutterSpeed');\n    var irisSelect = document.getElementById('irisLevel');\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\n    \n    var isManual = exposureMode.value === 'manual';\n    shutterSelect.disabled = !isManual;\n    irisSelect.disabled = !isManual;\n    \n    // 禁用时灰色样式\n    if (!isManual) {\n        shutterSelect.style.opacity = '0.5';\n        irisSelect.style.opacity = '0.5';\n    } else {\n        shutterSelect.style.opacity = '1';\n        irisSelect.style.opacity = '1';\n    }\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider"