{"type":"message","id":"30e399a9","parentId":"11a47d91","timestamp":"2026-06-14T11:00:05.773Z","message":{"role":"assistant","content":[{"type":"text","text":"**修复成功！** 断开后 `connected: false`\n\n---\n\n## 步骤 7：E2E 完整测试 - Playwright 模拟用户操作"},{"type":"toolCall","id":"call_5540a035c7ba4bb7899130ef","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nE2E 完整测试：快速连接关闭后 ISAPI 状态检查 v2\n使用 Playwright 模拟用户操作\n\"\"\"\n\nimport asyncio\nimport requests\nfrom playwright.async_api import async_playwright\n\nBASE_URL = \"http://localhost:10280\"\n\nasync def test_disconnect_e2e_v2():\n    \"\"\"测试快速连接关闭功能 v2\"\"\"\n    \n    print(\"=\" * 60)\n    print(\"E2E Test: Quick Connect/Disconnect\")\n    print(\"=\" * 60)\n    \n    # 1. 初始状态检查\n    print(\"\\n[Step 1] Check initial state\")\n    resp = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n    initial_state = resp.json()\n    print(f\"Initial: connected={initial_state.get('connected')}\")\n    \n    # 2. 如果未连接，先连接\n    if not initial_state.get('connected'):\n        print(\"\\n[Step 1.1] Connecting device...\")\n        connect_resp = requests.post(\n            f\"{BASE_URL}/api/v1/ptz/192.168.5.72/connect\",\n            json={\"username\": \"admin\", \"password\": \"Nftw1357\", \"port\": 80}\n        )\n        print(f\"Connect result: {connect_resp.json()}\")\n        await asyncio.sleep(2)\n    \n    # 3. Playwright 打开页面\n    print(\"\\n[Step 2] Open browser and check UI\")\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)  # headless for speed\n        page = await browser.new_page()\n        \n        # 打开主页\n        await page.goto(BASE_URL)\n        await asyncio.sleep(2)\n        \n        # 等待状态栏\n        await page.wait_for_selector('.status-bar', timeout=10000)\n        \n        # 截图 - 连接状态\n        await page.screenshot(path='screenshot_before_disconnect.png')\n        print(\"Screenshot saved: screenshot_before_disconnect.png\")\n        \n        # 检查状态栏\n        status_bar = await page.query_selector('.status-bar')\n        if status_bar:\n            text = await status_bar.inner_text()\n            print(f\"Status bar: {text[:100]}...\")\n        \n        # 4. API 断开\n        print(\"\\n[Step 3] Disconnect via API\")\n        disconnect_resp = requests.post(f\"{BASE_URL}/api/v1/devices/192.168.5.72/disconnect\")\n        print(f\"Disconnect result: {disconnect_resp.json()}\")\n        \n        await asyncio.sleep(1)\n        \n        # 5. 检查 API 状态\n        print(\"\\n[Step 4] Check API state after disconnect\")\n        resp = requests.get(f\"{BASE_URL}/api/v1/ptz/connected\")\n        after_state = resp.json()\n        print(f\"After disconnect: connected={after_state.get('connected')}\")\n        \n        # 6. 刷新页面检查 UI 状态\n        print(\"\\n[Step 5] Refresh page and check UI\")\n        await page.reload()\n        await asyncio.sleep(2)\n        \n        # 截图 - 断开后\n        await page.screenshot(path='screenshot_after_disconnect.png')\n        print(\"Screenshot saved: screenshot_after_disconnect.png\")\n        \n        # 检查状态栏\n        if status_bar:\n            new_text = await status_bar.inner_text()\n            print(f\"Status bar after: {new_text[:100]}...\")\n        \n        await browser.close()\n    \n    # 7. 结论\n    print(\"\\n\" + \"=\" * 60)\n    print(\"TEST RESULT\")\n    print(\"=\" * 60)\n    \n    if after_state.get('connected'):\n        print(\"FAIL: Still connected after disconnect\")\n        return False\n    else:\n        print(\"PASS: Correctly disconnected\")\n        return True\n\nif __name__ == \"__main__\":\n    result = asyncio.run(test_disconnect_e2e_v2())\n    exit(0 if result else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\e2e_test_disconnect_v2.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":58396,"output":924,"cacheRead":0,"cacheWrite":0,"totalTokens":59320,"cost":{"input"