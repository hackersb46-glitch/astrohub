{"type":"message","id":"eee5f6a5","parentId":"9df0807a","timestamp":"2026-06-14T09:08:21.845Z","message":{"role":"assistant","content":[{"type":"text","text":"降噪 ISAPI 工作正常，值已更新。\n\n现在检查 **问题 2：手动曝光模式下快门设置不生效**\n\n---\n\n## 步骤 2：测试手动曝光快门设置"},{"type":"toolCall","id":"call_01364e50f5e94d0581e5d99c","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"测试手动曝光快门设置\"\"\"\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\n\nBASE_URL = \"http://192.168.5.72\"\nAUTH = HTTPDigestAuth('admin', 'Nftw1357')\n\nprint(\"=\" * 60)\nprint(\"手动曝光快门设置测试\")\nprint(\"=\" * 60)\n\n# 1. 获取当前曝光模式\nprint(\"\\n1. 获取当前曝光模式\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', auth=AUTH, timeout=5)\nprint(f'响应: {resp.text}')\n\n# 2. 设置为自动模式\nprint(\"\\n2. 设置为自动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\n# 3. 设置为手动模式\nprint(\"\\n3. 设置为手动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\n# 4. 获取当前快门值\nprint(\"\\n4. 获取当前快门值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 5. 尝试设置快门 1/1000\nprint(\"\\n5. 设置快门 1/1000 (通过 Exposure 端点)\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>1/1000</ShutterLevel>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'响应: {resp.text[:200]}')\n\ntime.sleep(1)\n\n# 6. 验证快门值\nprint(\"\\n6. 验证快门值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 7. 再次设置为手动模式（不设置快门）\nprint(\"\\n7. 再次设置为手动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\n# 8. 验证快门值是否保留\nprint(\"\\n8. 验证快门值是否保留\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 9. 设置快门 1/60\nprint(\"\\n9. 设置快门 1/60\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>1/60</ShutterLevel>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 10. 恢复自动模式\nprint(\"\\n10. 恢复自动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"测试完成\")\nprint(\"=\" * 60)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_exposure_shutter.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":96801,"output":1335,"cacheRead":0,"cacheWrite":0,"totalTokens":98136,"cost":{"input":0.096801,"output":0.004272000000000001,"cacheRead":0,"cacheWrite":0,"total":0.101073}},"stopReason":"toolUse","timestamp":1781428091526,"responseId":"cht000d87d9@dx19ec5637ee4ba5c342"}}
