{"type":"message","id":"11e13dd9","parentId":"454e37b0","timestamp":"2026-06-14T01:41:47.948Z","message":{"role":"toolResult","toolCallId":"call_78a82b8859504bf0a67fb93f","toolName":"read","content":[{"type":"text","text":"(function() {\n    // 检查 apiGet 是否已定义\n    if (typeof apiGet === 'undefined') {\n        console.warn('[CONSOLE] apiGet not yet defined, will retry on DOMContentLoaded');\n        document.addEventListener('DOMContentLoaded', function() {\n            // DOM 加载完成后重新执行\n            if (typeof apiGet !== 'undefined') {\n                console.log('[CONSOLE] apiGet now available');\n            }\n        });\n    }\n})();\n\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\nvar deviceFunctionData = null; // v5.42: 存储function.json数据\n\n// v6.20: 功能支持状态\nvar deviceFunctionData = null;\nvar functionCacheLoaded = false;\n\n// v6.20: 禁用画面控制所有控件\nfunction disableImageControls(reason) {\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // 显示提示文字\n    var section = document.getElementById('imageControlSection');\n    if (section) {\n        var content = section.querySelector('.collapsible-content');\n        if (content && !document.getElementById('functionCacheWarning')) {\n            var warning = document.createElement('div');\n            warning.id = 'functio