reams/*         - 流服务\r\n- /api/v1/calibration/*     - 校准\r\n- /api/v1/ascom/*           - ASCOM 设备\r\n- /api/v1/settings          - 系统设置\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel\r\nfrom fastapi import APIRouter, FastAPI, Query\r\nfrom fastapi.responses import JSONResponse\r\n\r\n# v6.40: 操作日志\r\nfrom src.operation_logger import log_api, log_web, log_error, log_info\r\n\r\n# ================================================================ #\r\n#  \n... (truncated)"},"isError":false,"timestamp":1781428215756}}
{"type":"message","id":"cf82c79f","parentId":"22f45526","timestamp":"2026-06-14T09:10:39.522Z","message":{"role":"assistant","content":[{"type":"text","text":"文件内容被截断显示。让我使用 Python 脚本修复："},{"type":"toolCall","id":"tool-04552e10b2de409ead72d251012ddf9f","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n修复 router.py 中的 set_shutter 函数\n\"\"\"\n\n# 读取文件\nwith open('src/api/router.py', 'r', encoding='utf-8') as f:\n    content = f.read()\n\n# 找到并替换 set_shutter 函数\nold_code = '''async def set_shutter(device_id: str, data: dict) -> dict:\n    \"\"\"设置快门参数 - v7.04: 使用 Exposure 端点设置 ShutterLevel\"\"\"\n    import xml.etree.ElementTree as ET\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    try:\n        level = data.get(\"level\", \"1/60\")\n        \n        # v7.04: 快门必须通过 Exposure 端点设置\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>{level}</ShutterLevel>\n</Exposure>'''\n\n        put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": f\"快门已设置为 {level}\"}'''\n\nnew_code = '''async def set_shutter(device_id: str, data: dict) -> dict:\n    \"\"\"设置快门参数 - v7.06: 保持当前曝光模式\"\"\"\n    import xml.etree.ElementTree as ET\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    try:\n        level = data.get(\"level\", \"1/60\")\n        \n        # v7.06: 先获取当前曝光模式\n        get_resp = client.get(\"/Image/channels/1/exposure\")\n        current_mode = \"manual\"\n        if get_resp.status_code == 200:\n            root = ET.fromstring(get_resp.xml)\n            for elem in root.iter():\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n                if tag in (\"ExposureType\", \"exposureType\"):\n                    current_mode = elem.text or \"manual\"\n        \n        # v7.06: 保持当前曝光模式\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>{current_mode}</ExposureType>\n  <ShutterLevel>{level}</ShutterLevel>\n</Exposure>'''\n\n        put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": f\"快门已设置为 {level}\"}'''\n\ncontent = content.replace(old_code, new_code)\n\n# 写回文件\nwith open('src/api/router.py', 'w', encoding='utf-8') as f:\n    f.write(content)\n\nprint(\"Done\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\fix_shutter.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":104377,"output":913,"cacheRead":0,"cacheWrite":0,"totalTokens":105290,"cost":{"input":0.104377,"output":0.0029216000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1072986}},"stopReason":"toolUse","timestamp":1781428215758,"responseId":"cht000d9304@dx19ec5656b0eb9ca102"}}
