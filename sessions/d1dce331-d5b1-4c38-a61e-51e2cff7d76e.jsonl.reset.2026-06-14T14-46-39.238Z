{"type":"message","id":"247cfccf","parentId":"072a23e1","timestamp":"2026-06-14T02:18:19.347Z","message":{"role":"toolResult","toolCallId":"call_dee801b458c74aeb8a88ae24","toolName":"read","content":[{"type":"text","text":"    console.log('[IMAGE] Refreshing image controls...');\n    loadDeviceImageParams(window.connectedDevice.ip);\n}\n\n// v6.50: 重置画面控制到系统默认值\nfunction resetImageControls() {\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\n        console.warn('[IMAGE] No device connected');\n        return;\n    }\n    \n    // 弹出确认对话框\n    if (!confirm('确认重置画面控制到系统默认值？')) {\n        return;\n    }\n    \n    var dev = window.connectedDevice.ip;\n    console.log('[IMAGE] Resetting image controls to defaults...');\n    \n    // 系统默认值\n    var defaults = {\n        brightness: 50,\n        contrast: 50,\n        saturation: 50,\n        sharpness: 50,\n        wbRed: 100,\n        wbBlue: 100,\n        dnrSpatial: 50,\n        dnrTemporal: 50,\n        exposureMode: 'auto',\n        shutterSpeed: '1/100',\n        irisLevel: 1600\n    };\n    \n    // 更新 UI\n    document.getElementById('consoleBrightness').value = defaults.brightness;\n    document.getElementById('brightnessVal').textContent = defaults.brightness;\n    document.getElementById('consoleContrast').value = defaults.contrast;\n    document.getElementById('contrastVal').textContent = defaults.contrast;\n    document.getElementById('consoleSaturation').value = defaults.saturation;\n    document.getElementById('saturationVal').textContent = defaults.saturation;\n    document.getElementById('consoleSharpness').value = defaults.sharpness;\n    document.getElementById('sharpnessVal').textContent = defaults.sharpness;\n    document.getElementById('wbRed').value = defaults.wbRed;\n    document.getElementById('wbRedVal').textContent = defaults.wbRed;\n    document.getElementById('wbBlue').value = defaults.wbBlue;\n    document.getElementById('wbBlueVal').textContent = defaults.wbBlue;\n    document.getElementById('dnrSpatial').value = defaults.dnrSpatial;\n    document.getElementById('dnrSpatialVal').textContent = defaults.dnrSpatial;\n    document.getElementById('dnrTemporal').value = defaults.dnrTemporal;\n\n[713 more lines in file. Use offset=580 to continue.]"}],"isError":false,"timestamp":1781403499347}}
