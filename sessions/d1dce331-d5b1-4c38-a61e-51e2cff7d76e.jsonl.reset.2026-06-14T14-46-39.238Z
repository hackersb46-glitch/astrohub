{"type":"message","id":"49c2addd","parentId":"6923c201","timestamp":"2026-06-14T09:52:32.165Z","message":{"role":"assistant","content":[{"type":"text","text":"---\n\n## 步骤 1：先验证 Shutter/Iris 端点是否可用"},{"type":"toolCall","id":"tool-6f0f9b72b4b94e2ca4a065ff43c68eae","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n验证手动模式下 Shutter/Iris 端点独立设置\n\"\"\"\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\n\nBASE_URL = \"http://192.168.5.72\"\nAUTH = HTTPDigestAuth('admin', 'Nftw1357')\n\nprint(\"=\" * 60)\nprint(\"验证 Shutter/Iris 端点独立设置\")\nprint(\"=\" * 60)\n\n# 1. 设置为手动模式（只设置 ExposureType）\nprint(\"\\n1. 设置手动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\n# 2. 获取当前快门值\nprint(\"\\n2. 获取当前快门值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 3. 独立设置快门（不带 Exposure）\nprint(\"\\n3. 独立设置快门 1/500\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Shutter version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ShutterLevel>1/500</ShutterLevel>\n</Shutter>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'响应: {resp.text[:200]}')\n\ntime.sleep(1)\n\n# 4. 验证快门值\nprint(\"\\n4. 验证快门值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 5. 获取当前光圈值\nprint(\"\\n5. 获取当前光圈值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Iris', auth=AUTH, timeout=5)\nprint(f'光圈: {resp.text}')\n\n# 6. 独立设置光圈\nprint(\"\\n6. 独立设置光圈 2000\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Iris version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <IrisLevel>2000</IrisLevel>\n</Iris>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/Iris', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\n# 7. 验证光圈值\nprint(\"\\n7. 验证光圈值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Iris', auth=AUTH, timeout=5)\nprint(f'光圈: {resp.text}')\n\n# 8. 恢复自动模式\nprint(\"\\n8. 恢复自动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"测试完成\")\nprint(\"=\" * 60)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_shutter_iris_independent.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":109906,"output":995,"cacheRead":0,"cacheWrite":0,"totalTokens":110901,"cost":{"input":0.10990599999999999,"output":0.003184,"cacheRead":0,"cacheWrite":0,"total":0.11309}},"stopReason":"toolUse","timestamp":1781430720935,"responseId":"cht000daa89@dx19ec58b9bc0b87f702"}}
