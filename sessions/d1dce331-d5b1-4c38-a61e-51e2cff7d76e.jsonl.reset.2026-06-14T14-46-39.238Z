/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_set_shutter,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint('Set shutter in exposure status:', resp.status_code)\nprint('Response:', resp.text[:500] if resp.text else 'No response')\n\ntime.sleep(1)\n\n# Step 4: Verify\nprint('\\n=== Step 4: Verify ShutterLevel ===')\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nroot = ET.fromstring(resp.text)\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if tag == 'ShutterLevel' and elem.text:\n        print(f'ShutterLevel: {elem.text}')\n\n# Also check Shutter endpoint\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Shutter', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nprint('Shutter endpoint:', resp.text)\n\n# Step 5: Try Gain\nprint('\\n=== Step 5: Check for Gain field ===')\nxml_set_gain = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <Gain>50</Gain>\n</Exposure>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_set_gain,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint('Set gain status:', resp.status_code)\nprint('Response:', resp.text[:500] if resp.text else 'No response')\n\ntime.sleep(1)\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nroot = ET.fromstring(resp.text)\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if 'Gain' in tag and elem.text:\n        print(f'{tag}: {elem.text}')\n\n# Check Gain endpoint\nresp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Gain', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   timeout=5)\nprint('Gain endpoint:', resp.text)\n\n# Step 6: Reset to auto\nprint('\\n=== Step 6: Reset to Auto ===')\nxml_auto = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\n\nresp = requests.put('http://192.168.5.72/ISAPI/Image/channels/1/exposure', \n                   auth=HTTPDigestAuth('admin', 'Nftw1357'),\n                   data=xml_auto,\n                   headers={'Content-Type': 'application/xml'},\n                   timeout=5)\nprint('Reset to auto status:', resp.status_code)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_exposure_detail.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":125596,"output":1276,"cacheRead":0,"cacheWrite":0,"totalTokens":126872,"cost":{"input":0.12559599999999999,"output":0.0040832,"cacheRead":0,"cacheWrite":0,"total":0.1296792}},"stopReason":"toolUse","timestamp":1781406242949,"responseId":"cht000d42ad@dx19ec416a83db8ab282"}}
