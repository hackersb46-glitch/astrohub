{"type":"message","id":"2629234e","parentId":"1c06a892","timestamp":"2026-06-14T03:12:11.804Z","message":{"role":"assistant","content":[{"type":"text","text":"需要修改曝光模式设置，使用 `ExposureType` 而不是 `ExposureMode`："},{"type":"toolCall","id":"call_0c701b026d1c471eb9d786c6","name":"edit","arguments":{"edits":[{"newText":"@api_router.post(\"/ptz/{device_id}/image/exposure\", summary=\"设置曝光模式\", tags=[\"Image\"])\nasync def set_exposure(device_id: str, data: dict) -> dict:\n    \"\"\"设置曝光模式 - v7.03: 使用 ExposureType 字段\"\"\"\n    import xml.etree.ElementTree as ET\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    try:\n        mode = data.get(\"mode\", \"manual\")\n        # v7.03: 使用 ExposureType 而不是 ExposureMode\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>{mode}</ExposureType>\n</Exposure>'''\n\n        put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": f\"曝光模式已设置为 {mode}\"}\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置曝光模式异常: {e}\"}","oldText":"@api_router.post(\"/ptz/{device_id}/image/exposure\", summary=\"设置曝光模式\", tags=[\"Image\"])\nasync def set_exposure(device_id: str, data: dict) -> dict:\n    \"\"\"设置曝光模式。\"\"\"\n    import xml.etree.ElementTree as ET\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    try:\n        mode = data.get(\"mode\", \"manual\")\n        # mode: auto, manual, shutter-priority, iris-priority\n        \n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureMode>{mode}</ExposureMode>\n</Exposure>'''\n\n        put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": f\"曝光模式已设置为 {mode}\"}\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置曝光模式异常: {e}\"}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":136774,"output":912,"cacheRead":0,"cacheWrite":0,"totalTokens":137686,"cost":{"input":0.136774,"output":0.0029184000000000002,"cacheRead":0,"cacheWrite":0,"total":0.1396924}},"stopReason":"toolUse","timestamp":1781406643251,"responseId":"cht000d7ce4@dx19ec41c4a40b91a742"}}
