{"type":"message","id":"7e37d48d","parentId":"b4b81535","timestamp":"2026-06-14T02:20:46.937Z","message":{"role":"assistant","content":[{"type":"text","text":"现在修改 `disableImageControls` 和 `enableImageControls` 函数来控制提示框："},{"type":"toolCall","id":"call_1f612e8f377b4fb8a1ec2b5d","name":"edit","arguments":{"edits":[{"newText":"function disableImageControls(reason) {\n    // 禁用画面控制控件\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // v7.0: 禁用 PTZ 控制按钮\n    var ptzSection = document.getElementById('ptzControlSection');\n    if (ptzSection) {\n        var ptzBtns = ptzSection.querySelectorAll('.btn, .ptz-btn');\n        ptzBtns.forEach(function(btn) {\n            if (btn.id !== 'ptzSpeed') {\n                btn.disabled = true;\n                btn.style.opacity = '0.5';\n                btn.style.cursor = 'not-allowed';\n            }\n        });\n    }\n    \n    // v7.0: 禁用媒体操作按钮\n    var mediaButtons = ['btnConsoleSnapshot', 'btnConsoleRecordStart', 'btnConsoleRecordStop', 'btnLiveStackStart', 'btnLiveStackStop', 'btnLiveStackSave'];\n    mediaButtons.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // v7.0: 禁用跟踪控制按钮\n    var trackButtons = ['btnTrackSidereal', 'btnTrackLunar', 'btnTrackSolar', 'btnTrackOff'];\n    trackButtons.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // v7.01: 显示主控台提示框，移除画面控制区的提示\n    var consoleWarning = document.getElementById('consoleWarning');\n    if (consoleWarning) {\n        consoleWarning.style.display = 'block';\n    }\n    \n    // 移除画面控制区的旧提示（如果存在）\n    var oldWarning = document.getElementById('functionCacheWarning');\n    if (oldWarning) oldWarning.remove();\n    \n    // v7.0: 停止 PTZ 坐标刷新\n    if (window.stopPtzImagePoll) window.stopPtzImagePoll();\n}","oldText":"function disableImageControls(reason) {\n    // 禁用画面控制控件\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // v7.0: 禁用 PTZ 控制按钮\n    var ptzSection = document.getElementById('ptzControlSection');\n    if (ptzSection) {\n        var ptzBtns = ptzSection.querySelectorAll('.btn, .ptz-btn');\n        ptzBtns.forEach(function(btn) {\n            if (btn.id !== 'ptzSpeed') {\n                btn.disabled = true;\n                btn.style.opacity = '0.5';\n                btn.style.cursor = 'not-allowed';\n            }\n        });\n    }\n    \n    // v7.0: 禁用媒体操作按钮\n    var mediaButtons = ['btnConsoleSnapshot', 'btnConsoleRecordStart', 'btnConsoleRecordStop', 'btnLiveStackStart', 'btnLiveStackStop', 'btnLiveStackSave'];\n    mediaButtons.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // v7.0: 禁用跟踪控制按钮\n    var trackButtons = ['btnTrackSidereal', 'btnTrackLunar', 'btnTrackSolar', 'btnTrackOff'];\n    trackButtons.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // 显示提示文字（在画面控制区）\n    var section = document.getElementById('imageControlSection');\n    if (section) {\n        var content = section.querySelector('.collapsible-content');\n        if (content && !document.getElementById('functionCacheWarning')) {\n            var warning = document.createElement('div');\n            warning.id = 'functionCacheWarning';\n            warning.style.cssText = 'background:#4a3a1a;border:1px solid #d29922;border-radius:6px;padding:12px;margin:8px 0;color:#d29922;font-size:12px;text-align:center';\n            warning.innerHTML = '<strong>⚠️ 请连接设备</strong><br><span style=\"color:#8b949e\">在设备管理页面连接设备后可操作</span>';\n            content.insertBefore(warning, content.firstChild);\n        }\n    }\n    \n    // v7.0: 停止 PTZ 坐标刷新\n    if (window.stopPtzImagePoll) window.stopPtzImagePoll();\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":68675,"output":1522,"cacheRead":0,"cacheWrite":0,"totalTokens":70197,"cost":{"input":0.068675,"output":0.0048704,"cacheRead":0,"cacheWrite":0,"total":0.0735454}},"stopReason":"toolUse","timestamp":1781403630279,"responseId":"cht000d2a1a@dx19ec3ee3e12ba5d322"}}
