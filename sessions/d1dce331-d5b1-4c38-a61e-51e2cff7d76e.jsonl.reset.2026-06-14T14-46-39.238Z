{"type":"message","id":"3323769b","parentId":"b0a5906f","timestamp":"2026-06-14T09:11:46.309Z","message":{"role":"toolResult","toolCallId":"call_de9673991b914f06a31decfb","toolName":"exec","content":[{"type":"text","text":"{\"success\":true,\"data\":[{\"mac\":\"240f9b764193\",\"ip\":\"192.168.5.72\",\"name\":\"4k 32X DC\",\"model\":\"iDS-2DF8C832IXS-A\",\"gateway\":\"192.168.5.1\",\"subnet_mask\":\"255.255.255.0\",\"source\":\"manual\",\"online\":true,\"activated\":false,\"has_credentials\":true}],\"total\":1}"}],"details":{"status":"completed","exitCode":0,"durationMs":5660,"aggregated":"{\"success\":true,\"data\":[{\"mac\":\"240f9b764193\",\"ip\":\"192.168.5.72\",\"name\":\"4k 32X DC\",\"model\":\"iDS-2DF8C832IXS-A\",\"gateway\":\"192.168.5.1\",\"subnet_mask\":\"255.255.255.0\",\"source\":\"manual\",\"online\":true,\"activated\":false,\"has_credentials\":true}],\"total\":1}","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781428306309}}
{"type":"message","id":"471aa8b6","parentId":"3323769b","timestamp":"2026-06-14T09:12:12.761Z","message":{"role":"assistant","content":[{"type":"text","text":"创建 E2E 测试："},{"type":"toolCall","id":"call_9ba8e871501140a486cd02c5","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nv7.06 E2E 测试\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\nimport requests\n\ndef test_v706():\n    results = []\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        page.goto('http://localhost:10280')\n        time.sleep(4)\n        \n        # 1. 版本检查\n        print('\\n=== 1. Version Check ===')\n        version = page.locator('.version').text_content()\n        results.append(('Version v7.06', version == 'v7.06', version))\n        \n        # 2. 进入主控台\n        print('\\n=== 2. Console Page ===')\n        page.click('text=主控台')\n        time.sleep(2)\n        \n        # 3. 展开\"画面控制\"\n        print('\\n=== 3. Image Control ===')\n        page.click('#imageControlSection .collapsible-header')\n        time.sleep(1)\n        \n        # 4. 检查降噪滑块\n        print('\\n=== 4. Noise Reduction Controls ===')\n        dnr_spatial = page.locator('#dnrSpatial')\n        dnr_temporal = page.locator('#dnrTemporal')\n        results.append(('DNR Spatial Exists', dnr_spatial.count() > 0, f'count={dnr_spatial.count()}'))\n        results.append(('DNR Temporal Exists', dnr_temporal.count() > 0, f'count={dnr_temporal.count()}'))\n        \n        # 5. 设置降噪值\n        print('\\n=== 5. Set Noise Reduction ===')\n        dnr_spatial.fill('50')\n        time.sleep(1)\n        \n        # 通过 API 验证\n        resp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/noiseReduce',\n                           auth=requests.auth.HTTPDigestAuth('admin', 'Nftw1357'), timeout=5)\n        import xml.etree.ElementTree as ET\n        root = ET.fromstring(resp.text)\n        for elem in root.iter():\n            tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n            if tag == 'FrameNoiseReduceLevel':\n                spatial_val = elem.text\n                print(f'ISAPI Spatial: {spatial_val}')\n        \n        # 6. 曝光模式测试\n        print('\\n=== 6. Exposure Mode Test ===')\n        exposure_select = page.locator('#exposureMode')\n        \n        # 先设置为自动\n        exposure_select.select_option('auto')\n        time.sleep(2)\n        \n        # 验证 ISAPI\n        resp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/exposure',\n                           auth=requests.auth.HTTPDigestAuth('admin', 'Nftw1357'), timeout=5)\n        root = ET.fromstring(resp.text)\n        for elem in root.iter():\n            tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n            if tag == 'ExposureType':\n                mode_val = elem.text\n                print(f'ISAPI Exposure: {mode_val}')\n                results.append(('Auto Mode Set', mode_val == 'auto', f'mode={mode_val}'))\n        \n        # 设置为手动\n        exposure_select.select_option('manual')\n        time.sleep(2)\n        \n        # 检查快门/光圈/增益是否启用\n        shutter_disabled = page.locator('#shutterSpeed').evaluate('el => el.disabled')\n        iris_disabled = page.locator('#irisLevel').evaluate('el => el.disabled')\n        gain_disabled = page.locator('#gainLevel').evaluate('el => el.disabled')\n        \n        results.append(('Shutter Enabled in Manual', not shutter_disabled, f'disabled={shutter_disabled}'))\n        results.append(('Iris Enabled in Manual', not iris_disabled, f'disabled={iris_disabled}'))\n        results.append(('Gain Enabled in Manual', not gain_disabled, f'disabled={gain_disabled}'))\n        \n        # 7. 快门设置测试\n        print('\\n=== 7. Shutter Setting Test ===')\n        shutter_select = page.locator('#shutterSpeed')\n        \n        # 获取可用选项\n        options = shutter_select.locator('option').all()\n        print(f'Shutter options: {len(options)}')\n        \n        if len(options) > 1:\n            # 选择一个值\n            shutter_select.select_option('1/1000')\n            time.sleep(2)\n            \n            # 验证 ISAPI\n            resp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Shutter',\n                               auth=requests.auth.HTTPDigestAuth('admin', 'Nftw1357'), timeout=5)\n            root = ET.fromstring(resp.text)\n            for elem in root.iter():\n                tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n                if tag == 'ShutterLevel':\n                    shutter_val = elem.text\n                    print(f'ISAPI Shutter: {shutter_val}')\n                    results.append(('Shutter Set to 1/1000', '1/1000' in shutter_val, f'shutter={shutter_val}'))\n        \n        # 8. 恢复自动模式\n        print('\\n=== 8. Restore Auto Mode ===')\n        exposure_select.select_option('auto')\n        time.sleep(2)\n        \n        browser.close()\n    \n    # 输出结果\n    print('\\n' + '='*60)\n    print('v7.06 E2E Test Results')\n    print('='*60)\n    passed = 0\n    failed = 0\n    for name, success, detail in results:\n        status = 'PASS' if success else 'FAIL'\n        if success:\n            passed += 1\n        else:\n            failed += 1\n        print(f'[{status}] {name}: {detail}')\n    \n    print('='*60)\n    print(f'Total: {passed} passed, {failed} failed')\n    print('='*60)\n    \n    return failed == 0\n\nif __name__ == '__main__':\n    success = test_v706()\n    exit(0 if success else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_v706.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":106722,"output":1394,"cacheRead":0,"cacheWrite":0,"totalTokens":108116,"cost":{"input":0.106722,"output":0.0044608,"cacheRead":0,"cacheWrite":0,"total":0.1111828}},"stopReason":"toolUse","timestamp":1781428306312,"responseId":"cht000d9e3d@dx19ec566d42