{"type":"message","id":"f63bf876","parentId":"69c05ee9","timestamp":"2026-06-14T02:42:34.253Z","message":{"role":"assistant","content":[{"type":"text","text":"元素被分离了，说明页面刷新了。让我使用更稳定的选择器，并使用 JavaScript 执行来点击开关："},{"type":"toolCall","id":"tool-e0893bb5b8ec4c67ac0fa8a1151b4c7e","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_v701():\n    results = []\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        page.goto('http://localhost:10280')\n        time.sleep(3)\n        \n        # 1. 检查版本号\n        version = page.locator('.version').text_content()\n        results.append(('Version', version == 'v7.01', version))\n        \n        # 2. 进入主控台\n        page.click('text=主控台')\n        time.sleep(1)\n        \n        # 3. 检查主控台提示框\n        warning = page.locator('#consoleWarning')\n        warning_visible = warning.evaluate('el => el.style.display !== \"none\"')\n        results.append(('Console Warning Visible', warning_visible, f'display={warning.evaluate(\"el => el.style.display\")}'))\n        \n        # 4. 检查 WASM 覆盖层\n        wasm_overlay = page.locator('#wasm-disconnected-overlay')\n        results.append(('WASM Overlay Exists', wasm_overlay.count() > 0, f'count={wasm_overlay.count()}'))\n        \n        # 5. 检查控件是否禁用\n        ptz_btn = page.locator('#ptzControlSection .ptz-btn').first\n        if ptz_btn.count() > 0:\n            is_disabled = ptz_btn.evaluate('el => el.disabled')\n            results.append(('PTZ Buttons Disabled', is_disabled, f'disabled={is_disabled}'))\n        else:\n            results.append(('PTZ Buttons Disabled', True, 'buttons not found'))\n        \n        # 6. 连接设备 - 使用 JavaScript 直接调用\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", true)')\n        time.sleep(5)\n        \n        # 7. 等待页面刷新后回到主控台\n        time.sleep(2)\n        page.click('text=主控台')\n        time.sleep(3)\n        \n        # 8. 检查提示框是否隐藏\n        warning_hidden = warning.evaluate('el => el.style.display === \"none\"')\n        results.append(('Warning Hidden After Connect', warning_hidden, f'display={warning.evaluate(\"el => el.style.display\")}'))\n        \n        # 9. 检查 WASM 覆盖层是否移除\n        wasm_overlay_gone = page.locator('#wasm-disconnected-overlay').count() == 0\n        results.append(('WASM Overlay Removed', wasm_overlay_gone, f'count={page.locator(\"#wasm-disconnected-overlay\").count()}'))\n        \n        # 10. 检查 OSD 开关状态\n        time.sleep(3)\n        ptz_switch = page.locator('#ptzOsdSwitch')\n        info_switch = page.locator('#infoOsdSwitch')\n        if ptz_switch.count() > 0:\n            ptz_checked = ptz_switch.evaluate('el => el.checked')\n            results.append(('PTZ OSD Switch', True, f'checked={ptz_checked}'))\n        else:\n            results.append(('PTZ OSD Switch', False, 'switch not found'))\n        \n        if info_switch.count() > 0:\n            info_checked = info_switch.evaluate('el => el.checked')\n            results.append(('Info OSD Switch', True, f'checked={info_checked}'))\n        else:\n            results.append(('Info OSD Switch', False, 'switch not found'))\n        \n        # 11. 检查降噪显示\n        dnr_spatial_el = page.locator('#ptzDnrSpatial')\n        dnr_temporal_el = page.locator('#ptzDnrTemporal')\n        if dnr_spatial_el.count() > 0:\n            dnr_spatial = dnr_spatial_el.text_content()\n            spatial_val = dnr_spatial.split(':')[-1].strip() if ':' in dnr_spatial else dnr_spatial\n            results.append(('Spatial DNR', True, spatial_val))\n        else:\n            results.append(('Spatial DNR', False, 'element not found'))\n        \n        if dnr_temporal_el.count() > 0:\n            dnr_temporal = dnr_temporal_el.text_content()\n            temporal_val = dnr_temporal.split(':')[-1].strip() if ':' in dnr_temporal else dnr_temporal\n            results.append(('Temporal DNR', True, temporal_val))\n        else:\n            results.append(('Temporal DNR', False, 'element not found'))\n        \n        # 12. 断开设备 - 使用 JavaScript 直接调用\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", false)')\n        time.sleep(3)\n        \n        # 13. 再次检查提示框和 WASM 覆盖层\n        time.sleep(2)\n        \n        warning_visible_after = warning.evaluate('el => el.style.display !== \"none\"')\n        results.append(('Warning Visible After Disconnect', warning_visible_after, f'display={warning.evaluate(\"el => el.style.display\")}'))\n        \n        wasm_overlay_exists = page.locator('#wasm-disconnected-overlay').count() > 0\n        results.append(('WASM Overlay Re-created', wasm_overlay_exists, f'count={page.locator(\"#wasm-disconnected-overlay\").count()}'))\n        \n        # 14. 再次连接设备\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", true)')\n        time.sleep(5)\n        \n        time.sleep(2)\n        page.click('text=主控台')\n        time.sleep(3)\n        \n        wasm_container_ok = page.locator('#divPlugin').count() > 0\n        results.append(('WASM Container Exists', wasm_container_ok, f'count={page.locator(\"#divPlugin\").count()}'))\n        \n        # 15. 检查 WASM 是否正在播放\n        wasm_playing = page.locator('#wasm-disconnected-overlay').count() == 0\n        results.append(('WASM Playing After Reconnect', wasm_playing, f'overlay_count={page.locator(\"#wasm-disconnected-overlay\").count()}'))\n        \n        browser.close()\n    \n    # 输出结果\n    print('\\n' + '='*60)\n    print('v7.01 E2E Test Results')\n    print('='*60)\n    passed = 0\n    failed = 0\n    for name, success, detail in results:\n        status = 'PASS' if success else 'FAIL'\n        if success:\n            passed += 1\n        else:\n            failed += 1\n        print(f'[{status}] {name}: {detail}')\n    \n    print('='*60)\n    print(f'Total: {passed} passed, {failed} failed')\n    print('='*60)\n    \n    return failed == 0\n\nif __name__ == '__main__':\n    success = test_v701()\n    exit(0 if success else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_v701_full.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":87494,"output":1546,"cacheRead":0,"cacheWrite":0,"totalTokens":89040,"cost":{"input":0.087494,"output":0.0049472000000000006,"cacheRead":0,"cacheWrite":0,"total":0.0924412}},"stopReason":"toolUse","timestamp":1781404909345,"responseId":"cht000d7078@dx19ec401ea85ba5a412"}}
