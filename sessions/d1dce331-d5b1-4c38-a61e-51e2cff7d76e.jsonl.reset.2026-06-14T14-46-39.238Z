=============================\r\n\r\n1. �����ֶ�ģʽ\r\n״̬: 200\r\n\r\n2. GET Iris\r\n��Ӧ:\r\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\r\n<Iris version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\r\n<IrisLevel>200</IrisLevel>\r\r\n</Iris>\r\r\n\r\n\r\n3. ���� IrisLevel=1600\r\n״̬: 200\r\n��Ӧ: <?xml version=\"1.0\" encoding=\"UTF-8\"?><ResponseStatus version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n<requestURL></requestURL>\r\n<statusCode>1</statusCode>\r\n<statusString>OK</statusString>\r\n<subStatusCode>ok</subStatusCode>\r\n</ResponseStatus>\r\n\r\n\r\n4. ��֤ Iris\r\n��Ӧ:\r\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\r\n<Iris version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\r\n<IrisLevel>1600</IrisLevel>\r\r\n</Iris>\r\r\n\r\n\r\n5. ���� Shutter �ɽ��ܵ�ֵ\r\n  1/25: HTTP 200\r\n  1/30: HTTP 400\r\n  1/60: HTTP 400\r\n  1/125: HTTP 400\r\n  1/250: HTTP 200\r\n  1/500: HTTP 400\r\n  1/1000: HTTP 200\r\n  1/2000: HTTP 400\r\n  1/4000: HTTP 400\r\n\r\n6. �ָ��Զ�ģʽ\r\n״̬: 200","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781430784427}}
{"type":"message","id":"de827eee","parentId":"4c1dc08a","timestamp":"2026-06-14T09:53:12.611Z","message":{"role":"assistant","content":[{"type":"text","text":"**关键发现**：\n\n1. **Iris 端点工作正常** - 设置 1600 成功，验证也是 1600\n2. **Shutter 端点只接受特定值**：`1/25`, `1/250`, `1/1000` 返回 200，其他返回 400\n\n所以正确逻辑应该是：\n- **Iris**：使用独立 Iris 端点\n- **Shutter**：使用 Exposure 端点设置（因为独立端点只接受特定值）\n\n但老板说的是\"单独传递光圈和快门端点\"。让我再测试通过 Exposure 端点设置快门是否成功："},{"type":"toolCall","id":"call_4e2891738d7f41ffb7a94816","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n测试通过 Exposure 端点设置快门\n\"\"\"\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\n\nBASE_URL = \"http://192.168.5.72\"\nAUTH = HTTPDigestAuth('admin', 'Nftw1357')\n\nprint(\"=\" * 60)\nprint(\"测试通过 Exposure 端点设置快门\")\nprint(\"=\" * 60)\n\n# 1. 设置手动模式\nprint(\"\\n1. 设置手动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\n# 2. 通过 Exposure 设置快门 1/60\nprint(\"\\n2. 通过 Exposure 设置快门 1/60\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>1/60</ShutterLevel>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'响应: {resp.text[:200]}')\n\ntime.sleep(1)\n\n# 3. 验证快门值\nprint(\"\\n3. 验证快门值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 4. 再设置快门 1/500（不改变曝光模式）\nprint(\"\\n4. 再通过 Exposure 设置快门 1/500\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>manual</ExposureType>\n  <ShutterLevel>1/500</ShutterLevel>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\ntime.sleep(1)\n\n# 5. 验证快门值\nprint(\"\\n5. 验证快门值\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/Shutter', auth=AUTH, timeout=5)\nprint(f'快门: {resp.text}')\n\n# 6. 恢复自动模式\nprint(\"\\n6. 恢复自动模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>auto</ExposureType>\n</Exposure>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/exposure', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_exposure_shutter2.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":113104,"output":994,"cacheRead":0,"cacheWrite":0,"totalTokens":114098,"cost":{"input":0.113104,"output":0.0031808,"cacheRead":0,"cacheWrite":0,"total":0.1162848}},"stopReason":"toolUse","timestamp":1781430784430,"responseId":"cht000d579b@dx19ec58c9501b85f582"}}
