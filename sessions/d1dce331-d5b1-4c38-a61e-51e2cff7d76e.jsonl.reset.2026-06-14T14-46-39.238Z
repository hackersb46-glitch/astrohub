{"type":"message","id":"7141172d","parentId":"e110517d","timestamp":"2026-06-14T11:29:40.652Z","message":{"role":"assistant","content":[{"type":"text","text":"现在修改 `get_connected_device()` 方法，让它返回 `last_connected` 的设备信息（即使当前未连接）："},{"type":"toolCall","id":"call_639b6ab1f8cf4b1a8eaff455","name":"edit","arguments":{"edits":[{"newText":"    def get_connected_device(self) -> dict | None:\n        \"\"\"v7.10: 返回 last_connected 设备信息（用于快速连接）。\n        \n        注意：此方法返回的是\"上次连接的设备\"，不一定是\"当前连接的设备\"。\n        前端应该通过检查 IP 是否在 _controllers 中判断是否实际连接。\n        \"\"\"\n        import json\n        from src.config_paths import REGISTRY_FILE, DEVICES_DIR\n        \n        try:\n            # v7.10: 读取 last_connected（用于快速连接）\n            if REGISTRY_FILE.exists():\n                registry = json.loads(REGISTRY_FILE.read_text(encoding='utf-8'))\n                last_mac = registry.get('last_connected', '').strip()\n                \n                # last_connected 为空表示从未连接过\n                if not last_mac:\n                    return None\n                \n                # 从 devices/{mac}/info.json 读取设备详情\n                info_file = DEVICES_DIR / last_mac / 'info.json'\n                if info_file.exists():\n                    info = json.loads(info_file.read_text(encoding='utf-8'))\n                    creds = info.get('credentials', {})\n                    return {\n                        'ip': info.get('ip'),\n                        'mac': last_mac,\n                        'name': info.get('name'),\n                        'model': info.get('model'),\n                        'username': creds.get('username') or info.get('username'),\n                        'password': creds.get('password') or info.get('password'),\n                        'port': info.get('port', 80),\n                        'device_name': info.get('device_name'),\n                    }\n        except Exception as e:\n            print(f'[PTZManager] get_connected_device error: {e}')\n        \n        return None","oldText":"    def get_connected_device(self) -> dict | None:\n        \"\"\"v7.09: 从 registry.json 读取 active_device，检查是否实际连接。\"\"\"\n        import json\n        from src.config_paths import REGISTRY_FILE, DEVICES_DIR\n        \n        try:\n            # v7.09: 优先检查 active_device\n            if REGISTRY_FILE.exists():\n                registry = json.loads(REGISTRY_FILE.read_text(encoding='utf-8'))\n                active_mac = registry.get('active_device', '').strip()\n                \n                # v7.09: active_device 为空表示没有连接\n                if not active_mac:\n                    return None\n                \n                # 从 devices/{mac}/info.json 读取设备详情\n                info_file = DEVICES_DIR / active_mac / 'info.json'\n                if info_file.exists():\n                    info = json.loads(info_file.read_text(encoding='utf-8'))\n                    # v6.17: 兼容 credentials 对象和根级别字段\n                    creds = info.get('credentials', {})\n                    return {\n                        'ip': info.get('ip'),\n                        'mac': active_mac,\n                        'name': info.get('name'),\n                        'model': info.get('model'),\n                        'username': creds.get('username') or info.get('username'),\n                        'password': creds.get('password') or info.get('password'),\n                        'port': info.get('port', 80),\n                        'device_name': info.get('device_name'),\n                    }\n        except Exception as e:\n            print(f'[PTZManager] get_connected_device error: {e}')\n        \n        return None"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":72671,"output":858,"cacheRead":0,"cacheWrite":0,"totalTokens":73529,"cost":{"input":0.072671,"output":0.0027456000000000004,"cacheRead":0,"cacheWrite":