{"type":"message","id":"ec65ff0b","parentId":"99358fff","timestamp":"2026-06-14T09:03:39.126Z","message":{"role":"assistant","content":[{"type":"text","text":"---\n\n## 步骤 1：测试降噪 ISAPI 端点"},{"type":"toolCall","id":"call_62e776a27c114ccdad88897b","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n测试降噪 ISAPI 端点\n\"\"\"\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport xml.etree.ElementTree as ET\n\nBASE_URL = \"http://192.168.5.72\"\nAUTH = HTTPDigestAuth('admin', 'Nftw1357')\n\nprint(\"=\" * 60)\nprint(\"降噪 ISAPI 端点测试\")\nprint(\"=\" * 60)\n\n# 1. 获取当前降噪设置\nprint(\"\\n1. GET /ISAPI/Image/channels/1/noiseReduce\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/noiseReduce', auth=AUTH, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'响应:\\n{resp.text}')\n\n# 解析\nroot = ET.fromstring(resp.text)\nprint(\"\\n解析字段:\")\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if elem.text and elem.text.strip():\n        print(f'  {tag}: {elem.text}')\n\n# 2. 尝试设置降噪 - advanced 模式\nprint(\"\\n2. 设置降噪 - advanced 模式 (spatial=20, temporal=15)\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <mode>advanced</mode>\n  <AdvancedMode>\n    <spatialLevel>20</spatialLevel>\n    <temporalLevel>15</temporalLevel>\n  </AdvancedMode>\n</NoiseReduce>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/noiseReduce', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\nprint(f'响应: {resp.text[:300]}')\n\n# 3. 验证\nprint(\"\\n3. 验证设置\")\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/noiseReduce', auth=AUTH, timeout=5)\nroot = ET.fromstring(resp.text)\nfor elem in root.iter():\n    tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n    if 'Level' in tag or 'mode' in tag.lower():\n        print(f'  {tag}: {elem.text}')\n\n# 4. 尝试 general 模式\nprint(\"\\n4. 设置降噪 - general 模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <mode>general</mode>\n  <GeneralMode>\n    <generalLevel>50</generalLevel>\n  </GeneralMode>\n</NoiseReduce>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/noiseReduce', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\n# 验证\nresp = requests.get(f'{BASE_URL}/ISAPI/Image/channels/1/noiseReduce', auth=AUTH, timeout=5)\nprint(f'当前设置:\\n{resp.text}')\n\n# 5. 恢复 advanced 模式\nprint(\"\\n5. 恢复 advanced 模式\")\nxml_str = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <mode>advanced</mode>\n  <AdvancedMode>\n    <spatialLevel>14</spatialLevel>\n    <temporalLevel>0</temporalLevel>\n  </AdvancedMode>\n</NoiseReduce>'''\nresp = requests.put(f'{BASE_URL}/ISAPI/Image/channels/1/noiseReduce', \n                   auth=AUTH, data=xml_str,\n                   headers={'Content-Type': 'application/xml'}, timeout=5)\nprint(f'状态: {resp.status_code}')\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"测试完成\")\nprint(\"=\" * 60)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_noise_isapi.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":96015,"output":975,"cacheRead":0,"cacheWrite":0,"totalTokens":96990,"cost":{"input":0.09601499999999999,"output":0.0031200000000000004,"cacheRead":0,"cacheWrite":0,"total":0.09913499999999999}},"stopReason":"toolUse","timestamp":1781427796147,"responseId":"cht000d521b@dx19ec55f0182ba5c342"}}
