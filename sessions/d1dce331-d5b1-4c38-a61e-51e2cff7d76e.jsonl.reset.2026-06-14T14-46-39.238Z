{"type":"message","id":"0dd7b757","parentId":"56b3ef4f","timestamp":"2026-06-14T02:51:51.757Z","message":{"role":"assistant","content":[{"type":"text","text":"找到问题了！\n\n**第二次断开后 `g_bPlaying2: True`**，说明 `wasmLogout` 没有正确停止播放。\n\n问题在于 `wasmLogout` 中检查 `if (g_bPlaying2)`，但 WASM SDK 内部状态可能不一致。让我修复："},{"type":"toolCall","id":"call_d7c88396595c44ccab4c3673","name":"edit","arguments":{"edits":[{"newText":"        function wasmLogout() {\n            // v7.01: 强制停止播放和登出，不依赖状态变量\n            try {\n                // v7.01: 强制停止播放，不管状态\n                try {\n                    WebVideoCtrl.I_Stop();\n                } catch(stopErr) { \n                    console.warn('[WASM] I_Stop error:', stopErr);\n                }\n                \n                // 强制登出\n                if (g_szDeviceIdentify2) {\n                    try {\n                        WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                    } catch(logoutErr) {\n                        console.warn('[WASM] I_Logout error:', logoutErr);\n                    }\n                }\n                \n                // v7.01: 确保 WASM 容器存在并添加覆盖层\n                var container = document.getElementById('divPlugin');\n                if (container) {\n                    // 移除旧的覆盖层\n                    var oldOverlay = document.getElementById('wasm-disconnected-overlay');\n                    if (oldOverlay) oldOverlay.remove();\n                    \n                    // v7.01: 先确保容器可见\n                    container.style.display = 'block';\n                    container.style.position = 'relative';\n                    \n                    // 创建灰色覆盖层(使用更高的 z-index 覆盖 WASM 内容)\n                    var overlay = document.createElement('div');\n                    overlay.id = 'wasm-disconnected-overlay';\n                    overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;z-index:9999;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px';\n                    overlay.innerHTML = '设备已断开';\n                    container.appendChild(overlay);\n                    console.log('[WASM] Overlay created on disconnect');\n                } else {\n                    console.warn('[WASM] divPlugin container not found');\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            \n            // v7.01: 强制重置状态\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = '';\n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n\n            // v6.12: 更新 WASM 状态\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }","oldText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v7.01: 确保 WASM 容器存在并添加覆盖层\n                var container = document.getElementById('divPlugin');\n                if (container) {\n                    // 移除旧的覆盖层\n                    var oldOverlay = document.getElementById('wasm-disconnected-overlay');\n                    if (oldOverlay) oldOverlay.remove();\n                    \n                    // v7.01: 先确保容器可见\n                    container.style.display = 'block';\n                    container.style.position = 'relative';\n                    \n                    // 创建灰色覆盖层(使用更高的 z-index 覆盖 WASM 内容)\n                    var overlay = document.createElement('div');\n                    overlay.id = 'wasm-disconnected-overlay';\n                    overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:#0d1117;z-index:9999;display:flex;align-items:center;justify-content:center;color:#6e7681;font-size:14px';\n                    overlay.innerHTML = '设备已断开';\n                    container.appendChild(overlay);\n                    console.log('[WASM] Overlay created on disconnect');\n                } else {\n                    console.warn('[WASM] divPlugin container not found');\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = '';\n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n\n            // v6.12: 更新 WASM 状态\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":110373,"output":1203,"cacheRead":0,"cacheWrite":0,"totalTokens":111576,"cost":{"input":0.110373,"output":0.0038496000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1142226}},"stopReason":"toolUse","timestamp":1781405482817,"responseId":"cht000dda15@dx19ec40a90a7b9ca102"}}
