{"type":"message","id":"ea2b02c6","parentId":"99a81283","timestamp":"2026-06-14T10:50:48.085Z","message":{"role":"toolResult","toolCallId":"call_8f323a6b36cd411e9494ba65","toolName":"read","content":[{"type":"text","text":"        }\r\n    });\r\n}\r\n\r\n// 加载光圈\r\nfunction loadIris(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var ir = r.data;\r\n            deviceImageParams.iris = ir;\r\n            \r\n            var irisSelect = document.getElementById('irisLevel');\r\n            if (irisSelect) {\r\n                irisSelect.innerHTML = '';\r\n                \r\n                // v5.42: 从 function.json 获取光圈范围\r\n                var minIris = 160;\r\n                var maxIris = 2200;\r\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.iris) {\r\n                    minIris = deviceFunctionData.functions.iris.min || 160;\r\n                    maxIris = deviceFunctionData.functions.iris.max || 2200;\r\n                }\r\n                \r\n                var current = ir.current_level || minIris;\r\n                \r\n                // F 值映射（标准海康光圈值）\r\n                var fValues = [\r\n                    {val: 160, label: 'F1.6'},\r\n                    {val: 200, label: 'F2.0'},\r\n                    {val: 280, label: 'F2.8'},\r\n                    {val: 400, label: 'F4.0'},\r\n                    {val: 560, label: 'F5.6'},\r\n                    {val: 800, label: 'F8.0'},\r\n                    {val: 1100, label: 'F11'},\r\n                    {val: 1600, label: 'F16'},\r\n                    {val: 2200, label: 'F22'}\r\n                ];\r\n                \r\n                fValues.forEach(function(f) {\r\n                    if (f.val >= minIris && f.val <= maxIris) {\r\n                        var opt = document.createElement('option');\r\n                        opt.value = f.val;\r\n                        opt.textContent = f.label;\r\n                        if (f.val === current) opt.selected = true;\r\n                        irisSelect.appendChild(opt);\r\n                    }\r\n                });\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n\n[424 more lines in file. Use offset=919 to continue.]"}],"isError":false,"timestamp":1781434248085}}
{"type":"message","id":"f1d09c95","parentId":"ea2b02c6","timestamp":"2026-06-14T10:51:12.112Z","message":{"role":"assistant","content":[{"type":"text","text":"修改光圈加载函数："},{"type":"toolCall","id":"call_e824d8f33f2c4e5283b9d20d","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n修改 console.html - 修改光圈加载函数使用 opt_values\n\"\"\"\n\n# 读取文件\nwith open('src/web/includes/console.html', 'r', encoding='utf-8') as f:\n    content = f.read()\n\n# 修改 loadIris 函数\nold_loadIris = '''// 加载光圈\nfunction loadIris(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\n        if (r && r.success && r.data) {\n            var ir = r.data;\n            deviceImageParams.iris = ir;\n            \n            var irisSelect = document.getElementById('irisLevel');\n            if (irisSelect) {\n                irisSelect.innerHTML = '';\n                \n                // v5.42: 从 function.json 获取光圈范围\n                var minIris = 160;\n                var maxIris = 2200;\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.iris) {\n                    minIris = deviceFunctionData.functions.iris.min || 160;\n                    maxIris = deviceFunctionData.functions.iris.max || 2200;\n                }\n                \n                var current = ir.current_level || minIris;\n                \n                // F 值映射（标准海康光圈值）\n                var fValues = [\n                    {val: 160, label: 'F1.6'},\n                    {val: 200, label: 'F2.0'},\n                    {val: 280, label: 'F2.8'},\n                    {val: 400, label: 'F4.0'},\n                    {val: 560, label: 'F5.6'},\n                    {val: 800, label: 'F8.0'},\n                    {val: 1100, label: 'F11'},\n                    {val: 1600, label: 'F16'},\n                    {val: 2200, label: 'F22'}\n                ];\n                \n                fValues.forEach(function(f) {\n                    if (f.val >= minIris && f.val <= maxIris) {\n                        var opt = document.createElement('option');\n                        opt.value = f.val;\n                        opt.textContent = f.label;\n                        if (f.val === current) opt.selected = true;\n                        irisSelect.appendChild(opt);\n                    }\n                });\n            }\n        }\n    }).catch(function(e) {'''\n\nnew_loadIris = '''// 加载光圈\nfunction loadIris(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\n        if (r && r.success && r.data) {\n            var ir = r.data;\n            deviceImageParams.iris = ir;\n            \n            var irisSelect = document.getElementById('irisLevel');\n            if (irisSelect) {\n                irisSelect.innerHTML = '';\n                \n                var current = ir.current_level || 160;\n                \n                // v7.08: 从 function.json 获取 opt_values\n                var irisValues = null;\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.iris) {\n                    irisValues = deviceFunctionData.functions.iris.opt_values;\n                }\n                \n                if (irisValues && Array.isArray(irisValues)) {\n                    // 使用设备返回的 opt_values\n                    irisValues.forEach(function(val) {\n                        var numVal = parseInt(val);\n                        var opt = document.createElement('option');\n                        opt.value = numVal;\n                        // 计算 F 值\n                        var fNum = numVal / 100;\n                        opt.textContent = 'F' + fNum.toFixed(1);\n                        if (numVal === current) opt.selected = true;\n                        irisSelect.appendChild(opt);\n                    });\n                } else {\n                    // 回退到默认 F 值映射\n                    var fValues = [\n                        {val: 160, label: 'F1.6'},\n                        {val: 200, label: 'F2.0'},\n                        {val: 280, label: 'F2.8'},\n                        {val: 400, label: 'F4.0'},\n                        {val: 560, label: 'F5.6'},\n                        {val: 800, label: 'F8.0'},\n                        {val: 1100, label: 'F11'},\n                        {val: 1600, label: 'F16'},\n                        {val: 2200, label: 'F22'}\n                    ];\n                    \n                    fValues.forEach(function(f) {\n                        var opt = document.createElement('option');\n                        opt.value = f.val;\n                        opt.textContent = f.label;\n                        if (f.val === current) opt.selected = true;\n                        irisSelect.appendChild(opt);\n                    });\n                }\n            }\n        }\n    }).catch(function(e) {'''\n\ncontent = content.replace(old_loadIris, new_loadIris)\n\n# 写回文件\nwith open('src/web/includes/console.html', 'w', encoding='utf-8') as f:\n    f.write(content)\n\nprint(\"Done\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\fix_console_v708_iris.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":159841,"output":1105,"cacheRead":0,"cacheWrite":0,"totalTokens":160946,"cost":{"input":0.15984099999999998,"output":0.0035360000000000005,"cacheRead":0,"cacheWrite":0,"total":0.163377}},"stopReason":"toolUse","timestamp":1781434248092,"responseId":"cht000d8ad0@dx19ec5c16d2eba5e412"}}
