{"type":"message","id":"1bba01e7","parentId":"9a98b637","timestamp":"2026-06-14T03:25:46.039Z","message":{"role":"assistant","content":[{"type":"text","text":"---\n\n## 步骤 3：创建 E2E 测试"},{"type":"toolCall","id":"tool-8ef809bd55884fe2a2a6287ec3575880","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nv7.04 E2E 测试\n测试项：\n1. 降噪显示 0 时显示数值 0\n2. 手动模式下快门/光圈/增益设置生效\n3. 提示框居中显示\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\nimport re\n\ndef test_v704():\n    results = []\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        page.goto('http://localhost:10280')\n        time.sleep(4)\n        \n        # 1. 版本检查\n        print('\\n=== 1. Version Check ===')\n        version = page.locator('.version').text_content()\n        results.append(('Version', version == 'v7.04', version))\n        \n        # 2. 进入主控台\n        print('\\n=== 2. Console Page ===')\n        page.click('text=主控台')\n        time.sleep(2)\n        \n        # 3. 检查降噪显示\n        print('\\n=== 3. Noise Reduction Display ===')\n        dnr_temporal = page.locator('#ptzDnrTemporal').text_content()\n        print(f'DNR Temporal text: {dnr_temporal}')\n        \n        # 提取数值\n        match = re.search(r'时域[:\\s]+(\\d+|--)', dnr_temporal)\n        if match:\n            temporal_val = match.group(1)\n            print(f'Temporal value: {temporal_val}')\n            # 应该显示数值（0 或其他数字），不应该显示 \"--\"\n            results.append(('DNR Shows Numeric', temporal_val.isdigit(), f'value={temporal_val}'))\n        else:\n            results.append(('DNR Shows Numeric', False, f'raw={dnr_temporal}'))\n        \n        # 4. 检查提示框位置\n        print('\\n=== 4. Warning Box Position ===')\n        warning = page.locator('#consoleWarning')\n        if warning.count() > 0:\n            warning_style = warning.evaluate('el => el.style.position')\n            warning_width = warning.evaluate('el => el.style.width')\n            results.append(('Warning Fixed Position', warning_style == 'fixed', f'position={warning_style}'))\n            results.append(('Warning Box Width', warning_width == '300px', f'width={warning_width}'))\n        \n        # 5. 展开\"画面控制\"\n        print('\\n=== 5. Image Control Section ===')\n        page.click('#imageControlSection .collapsible-header')\n        time.sleep(1)\n        \n        # 6. 设置手动曝光模式\n        print('\\n=== 6. Set Manual Exposure ===')\n        exposure_select = page.locator('#exposureMode')\n        exposure_select.select_option('manual')\n        time.sleep(2)\n        \n        # 检查快门/光圈/增益是否启用\n        shutter_disabled = page.locator('#shutterSpeed').evaluate('el => el.disabled')\n        iris_disabled = page.locator('#irisLevel').evaluate('el => el.disabled')\n        gain_disabled = page.locator('#gainLevel').evaluate('el => el.disabled')\n        \n        results.append(('Shutter Enabled', not shutter_disabled, f'disabled={shutter_disabled}'))\n        results.append(('Iris Enabled', not iris_disabled, f'disabled={iris_disabled}'))\n        results.append(('Gain Enabled', not gain_disabled, f'disabled={gain_disabled}'))\n        \n        # 7. 设置快门\n        print('\\n=== 7. Set Shutter ===')\n        shutter_select = page.locator('#shutterSpeed')\n        # 获取可用选项\n        options = shutter_select.locator('option').all()\n        print(f'Available shutter options: {len(options)}')\n        \n        # 选择一个有效值\n        shutter_select.select_option('1/60')\n        time.sleep(2)\n        \n        # 验证快门值是否改变（通过 API）\n        shutter_val = shutter_select.evaluate('el => el.value')\n        results.append(('Shutter Set to 1/60', shutter_val == '1/60', f'value={shutter_val}'))\n        \n        # 8. 设置光圈\n        print('\\n=== 8. Set Iris ===')\n        iris_select = page.locator('#irisLevel')\n        iris_select.select_option('1600')\n        time.sleep(2)\n        \n        iris_val = iris_select.evaluate('el => el.value')\n        results.append(('Iris Set to 1600', iris_val == '1600', f'value={iris_val}'))\n        \n        # 9. 设置增益\n        print('\\n=== 9. Set Gain ===')\n        gain_slider = page.locator('#gainLevel')\n        gain_slider.fill('50')\n        time.sleep(2)\n        \n        gain_val = gain_slider.evaluate('el => el.value')\n        gain_display = page.locator('#gainVal').text_content()\n        results.append(('Gain Set to 50', gain_val == '50', f'slider={gain_val}, display={gain_display}'))\n        \n        # 10. 验证 ISAPI 设置生效\n        print('\\n=== 10. Verify ISAPI Settings ===')\n        \n        # 通过 API 验证快门\n        import requests\n        resp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Shutter', \n                           auth=requests.auth.HTTPDigestAuth('admin', 'Nftw1357'), timeout=5)\n        import xml.etree.ElementTree as ET\n        root = ET.fromstring(resp.text)\n        for elem in root.iter():\n            tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n            if tag == 'ShutterLevel':\n                actual_shutter = elem.text\n                print(f'ISAPI Shutter: {actual_shutter}')\n                # 注意：ISAPI 可能返回不同的值，取决于设备支持的值\n        \n        # 验证光圈\n        resp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Iris', \n                           auth=requests.auth.HTTPDigestAuth('admin', 'Nftw1357'), timeout=5)\n        root = ET.fromstring(resp.text)\n        for elem in root.iter():\n            tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n            if tag == 'IrisLevel':\n                actual_iris = elem.text\n                print(f'ISAPI Iris: {actual_iris}')\n                results.append(('ISAPI Iris Changed', True, f'iris={actual_iris}'))\n        \n        # 验证增益\n        resp = requests.get('http://192.168.5.72/ISAPI/Image/channels/1/Gain', \n                           auth=requests.auth.HTTPDigestAuth('admin', 'Nftw1357'), timeout=5)\n        root = ET.fromstring(resp.text)\n        for elem in root.iter():\n            tag = elem.tag.split('}')[-1] if '}' in elem.tag else elem.tag\n            if tag == 'GainLevel':\n                actual_gain = elem.text\n                print(f'ISAPI Gain: {actual_gain}')\n                results.append(('ISAPI Gain Changed', actual_gain == '50', f'gain={actual_gain}'))\n        \n        # 11. 恢复自动模式\n        print('\\n=== 11. Restore Auto Mode ===')\n        exposure_select.select_option('auto')\n        time.sleep(2)\n        \n        shutter_disabled_auto = page.locator('#shutterSpeed').evaluate('el => el.disabled')\n        iris_disabled_auto = page.locator('#irisLevel').evaluate('el => el.disabled')\n        gain_disabled_auto = page.locator('#gainLevel').evaluate('el => el.disabled')\n        \n        results.append(('Shutter Disabled in Auto', shutter_disabled_auto, f'disabled={shutter_disabled_auto}'))\n        results.append(('Iris Disabled in Auto', iris_disabled_auto, f'disabled={iris_disabled_auto}'))\n        results.append(('Gain Disabled in Auto', gain_disabled_auto, f'disabled={gain_disabled_auto}'))\n        \n        browser.close()\n    \n    # 输出结果\n    print('\\n' + '='*60)\n    print('v7.04 E2E Test Results')\n    print('='*60)\n    passed = 0\n    failed = 0\n    for name, success, detail in results:\n        status = 'PASS' if success else 'FAIL'\n        if success:\n            passed += 1\n        else:\n            failed += 1\n        print(f'[{status}] {name}: {detail}')\n    \n    print('='*60)\n    print(f'Total: {passed} passed, {failed} failed')\n    print('='*60)\n    \n    return failed == 0\n\nif __name__ == '__main__':\n    success = test_v704()\n    exit(0 if success else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_v704.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":59724,"output":1948,"cacheRead":0,"cacheWrite":0,"totalTokens":61672,"cost":{"input":0.059724,"output":0.006233600000000001,"cacheRead":0,"cacheWrite":0,"total":0.0659576}},"stopReason":"toolUse","timestamp":1781407496059,"responseId":"cht000e0434@dx19ec4295669b893102"}}
