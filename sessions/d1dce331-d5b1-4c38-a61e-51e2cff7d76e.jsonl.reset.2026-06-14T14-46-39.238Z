{"type":"message","id":"c8b52f2d","parentId":"f8a06cd9","timestamp":"2026-06-14T02:50:47.410Z","message":{"role":"assistant","content":[{"type":"text","text":"第二次断开时覆盖层没有创建。这说明问题 4（多次连接断开后 WASM 渲染框丢失）确实存在。\n\n让我检查 `wasmLogout` 是否在第二次断开时被正确调用："},{"type":"toolCall","id":"call_543a7fe660bd4dcea3061664","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_wasm_debug():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        page.on('console', lambda msg: print(f'[Browser] {msg.text}'))\n        page.goto('http://localhost:10280')\n        time.sleep(4)\n        \n        print('\\n=== Initial State ===')\n        print(f'g_bLoggedIn2: {page.evaluate(\"typeof g_bLoggedIn2 !== \\\"undefined\\\" ? g_bLoggedIn2 : \\\"undefined\\\"\")}')\n        print(f'g_bPlaying2: {page.evaluate(\"typeof g_bPlaying2 !== \\\"undefined\\\" ? g_bPlaying2 : \\\"undefined\\\"\")}')\n        \n        print('\\n=== First Disconnect ===')\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", false)')\n        time.sleep(4)\n        \n        print(f'After 1st disconnect - g_bLoggedIn2: {page.evaluate(\"typeof g_bLoggedIn2 !== \\\"undefined\\\" ? g_bLoggedIn2 : \\\"undefined\\\"\")}')\n        print(f'After 1st disconnect - g_bPlaying2: {page.evaluate(\"typeof g_bPlaying2 !== \\\"undefined\\\" ? g_bPlaying2 : \\\"undefined\\\"\")}')\n        print(f'Overlay count: {page.locator(\"#wasm-disconnected-overlay\").count()}')\n        \n        print('\\n=== First Reconnect ===')\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", true)')\n        time.sleep(6)\n        \n        print(f'After 1st reconnect - g_bLoggedIn2: {page.evaluate(\"typeof g_bLoggedIn2 !== \\\"undefined\\\" ? g_bLoggedIn2 : \\\"undefined\\\"\")}')\n        print(f'After 1st reconnect - g_bPlaying2: {page.evaluate(\"typeof g_bPlaying2 !== \\\"undefined\\\" ? g_bPlaying2 : \\\"undefined\\\"\")}')\n        print(f'Overlay count: {page.locator(\"#wasm-disconnected-overlay\").count()}')\n        \n        print('\\n=== Second Disconnect ===')\n        page.evaluate('toggleDeviceConnect(\"192.168.5.72\", false)')\n        time.sleep(4)\n        \n        print(f'After 2nd disconnect - g_bLoggedIn2: {page.evaluate(\"typeof g_bLoggedIn2 !== \\\"undefined\\\" ? g_bLoggedIn2 : \\\"undefined\\\"\")}')\n        print(f'After 2nd disconnect - g_bPlaying2: {page.evaluate(\"typeof g_bPlaying2 !== \\\"undefined\\\" ? g_bPlaying2 : \\\"undefined\\\"\")}')\n        print(f'Overlay count: {page.locator(\"#wasm-disconnected-overlay\").count()}')\n        \n        time.sleep(2)\n        browser.close()\n\nif __name__ == '__main__':\n    test_wasm_debug()","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\test_wasm_debug2.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":108706,"output":677,"cacheRead":0,"cacheWrite":0,"totalTokens":109383,"cost":{"input":0.108706,"output":0.0021664,"cacheRead":0,"cacheWrite":0,"total":0.1108724}},"stopReason":"toolUse","timestamp":1781405426980,"responseId":"cht000ec316@dx19ec409b966b893102"}}
