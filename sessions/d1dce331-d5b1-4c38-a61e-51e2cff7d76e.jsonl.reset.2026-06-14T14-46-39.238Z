{"type":"message","id":"97377362","parentId":"b9747739","timestamp":"2026-06-14T01:39:13.707Z","message":{"role":"toolResult","toolCallId":"call_1f08e917358547dd9c95e28f","toolName":"read","content":[{"type":"text","text":"    }).catch(function(e) {\n        console.warn('[WB] Load failed:', e);\n    });\n}\n\n// 加载降噪\nfunction loadNoiseReduce(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/noisereduce').then(function(r) {\n        if (r && r.success && r.data) {\n            var nr = r.data;\n            deviceImageParams.noiseReduce = nr;\n            \n            var dnrSpatial = document.getElementById('dnrSpatial');\n            var dnrTemporal = document.getElementById('dnrTemporal');\n            var dnrSpatialVal = document.getElementById('dnrSpatialVal');\n            var dnrTemporalVal = document.getElementById('dnrTemporalVal');\n            \n            if (dnrSpatial && nr.spatial_level !== undefined) {\n                dnrSpatial.value = nr.spatial_level;\n                if (dnrSpatialVal) dnrSpatialVal.textContent = nr.spatial_level;\n            }\n            if (dnrTemporal && nr.temporal_level !== undefined) {\n                dnrTemporal.value = nr.temporal_level;\n                if (dnrTemporalVal) dnrTemporalVal.textContent = nr.temporal_level;\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[DNR] Load failed:', e);\n    });\n}\n\n// 加载快门\nfunction loadShutter(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/shutter').then(function(r) {\n        if (r && r.success && r.data) {\n            var sh = r.data;\n            deviceImageParams.shutter = sh;\n            \n            var shutterSelect = document.getElementById('shutterSpeed');\n            if (shutterSelect) {\n                shutterSelect.innerHTML = '';\n                \n                // 自动选项\n                var autoOpt = document.createElement('option');\n                autoOpt.value = 'auto';\n                autoOpt.textContent = '自动';\n                shutterSelect.appendChild(autoOpt);\n                \n                // v5.42: 从 function.json 获取快门范围\n                var minShutter = '1/30000';\n                var maxShutter = '1/25';\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.shutter) {\n                    minShutter = deviceFunctionData.functions.shutter.min || '1/30000';\n                    maxShutter = deviceFunctionData.functions.shutter.max || '1/25';\n                }\n                \n                // 常用快门值（在范围内）\n                var shutterPresets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000', '1/30000', '1/25'];\n                shutterPresets.forEach(function(p) {\n                    var opt = document.createElement('option');\n                    opt.value = p;\n                    opt.textContent = p;\n                    if (p === sh.current_level) opt.selected = true;\n                    shutterSelect.appendChild(opt);\n                });\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Shutter] Load failed:', e);\n        // 设置默认选项\n        var shutterSelect = document.getElementById('shutterSpeed');\n        if (shutterSelect) {\n            shutterSelect.innerHTML = '<option value=\"auto\">自动</option>';\n            var presets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000'];\n            presets.forEach(function(p) {\n                shutterSelect.innerHTML += '<option value=\"' + p + '\">' + p + '</option>';\n            });\n        }\n    });\n}\n\n// 加载光圈\nfunction loadIris(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\n        if (r && r.success && r.data) {\n            var ir = r.data;\n            deviceImageParams.iris = ir;\n            \n            var irisSelect = document.getElementById('irisLevel');\n            if (irisSelect) {\n                irisSelect.innerHTML = '';\n                \n                // v5.42: 从 function.json 获取光圈范围\n                var minIris = 160;\n                var maxIris = 2200;\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.iris) {\n                    minIris = deviceFunctionData.functions.iris.min || 160;\n                    maxIris = deviceFunctionData.functions.iris.max || 2200;\n                }\n                \n\n[338 more lines in file. Use offset=800 to continue.]"}],"isError":false,"timestamp":1781401153707}}
{"type":"message","id":"3f2d46d2","parentId":"97377362","timestamp":"2026-06-14T01:39:32.588Z","message":{"role":"assistant","content":[{"type":"text","text":"让我找到脚本末尾添加刷新函数："},{"type":"toolCall","id":"tool-fbfa996bab294da3b3a46d1ceb161a49","name":"read","arguments":{"limit":50,"offset":1130,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":92299,"output":55,"cacheRead":0,"cacheWrite":0,"totalTokens":92354,"cost":{"input":0.09229899999999999,"output":0.00017600000000000002,"cacheRead":0,"cacheWrite":0,"total":0.09247499999999999}},"stopReason":"toolUse","timestamp":1781401153709,"responseId":"cht000dc4c8@dx19ec3c8960cba5d322"}}
{"type":"message","id":"c4723682","parentId":"3f2d46d2","timestamp":"2026-06-14T01:39:32.601Z","message":{"role":"toolResult","toolCallId":"tool-fbfa996bab294da3b3a46d1ceb161a49","toolName":"read","content":[{"type":"text","text":"window.setShutterSpeed = setShutterSpeed;\nwindow.setIris = setIris;\nwindow.setExposureMode = setExposureMode;\nwindow.togglePtzOsd = togglePtzOsd;\nwindow.toggleInfoOsd = toggleInfoOsd;\nwindow.updatePtzOsdButtons = updatePtzOsdButtons;\nwindow.updateInfoOsdButtons = updateInfoOsdButtons;\n</script>"}],"isError":false,"timestamp":1781401172601}}
{"type":"message","id":"19f379e6","parentId":"c4723682","timestamp":"2026-06-14T01:40:01.636Z","message":{"role":"assistant","content":[{"type":"text","text":"让我在脚本末尾添加实时刷新函数："},{"type":"toolCall","id":"tool-cf22d12c026a484598f79a1f9354a24e","name":"edit","arguments":{"edits":[{"newText":"// ==================== v7.0: PTZ 坐标 + 图像参数实时刷新 ====================\nvar _ptzImagePollInterval = null;\n\nfunction startPtzImagePoll() {\n    if (_ptzImagePollInterval) return; // 已在运行\n    \n    _ptzImagePollInterval = setInterval(function() {\n        if (!window.connectedDevice || !window.connectedDevice.ip) return;\n        \n        var dev = window.connectedDevice.ip;\n        \n        // 1. PTZ 坐标\n        apiGet('/api/v1/ptz/' + dev + '/position').then(function(r) {\n            if (r && r.success && r.data) {\n                var posEl = document.getElementById('ptzPosition');\n                if (posEl) {\n                    posEl.innerHTML = 'Pan: ' + (r.data.pan || 0) + ' | Tilt: ' + (r.data.tilt || 0) + ' | Zoom: ' + (r.data.zoom || 0);\n                }\n            }\n        }).catch(function(e) {});\n        \n        // 2. 白平衡 R/B\n        apiGet('/api/v1/ptz/' + dev + '/image/whitebalance').then(function(r) {\n            if (r && r.success && r.data) {\n                var wb = r.data;\n                var rEl = document.getElementById('ptzWbR');\n                var bEl = document.getElementById('ptzWbB');\n                if (rEl) rEl.textContent = 'R: ' + (wb.red_gain || '--');\n                if (bEl) bEl.textContent = 'B: ' + (wb.blue_gain || '--');\n            }\n        }).catch(function(e) {});\n        \n        // 3. 降噪空域/时域\n        apiGet('/api/v1/ptz/' + dev + '/image/noisereduce').then(function(r) {\n            if (r && r.success && r.data) {\n                var nr = r.data;\n                var sEl = document.getElementById('ptzDnrSpatial');\n                var tEl = document.getElementById('ptzDnrTemporal');\n                if (sEl) sEl.textContent = '空域: ' + (nr.spatial_level || '--');\n                if (tEl) tEl.textContent = '时域: ' + (nr.temporal_level || '--');\n            }\n        }).catch(function(e) {});\n        \n        // 4. 光圈\n        apiGet('/api/v1/ptz/' + dev + '/image/iris').then(function(r) {\n            if (r && r.success && r.data) {\n                var ir = r.data;\n                var iEl = document.getElementById('ptzIris');\n                if (iEl) iEl.textContent = '光圈: ' + (ir.current_level || '--');\n            }\n        }).catch(function(e) {});\n        \n        // 5. 快门\n        apiGet('/api/v1/ptz/' + dev + '/image/shutter').then(function(r) {\n            if (r && r.success && r.data) {\n                var sh = r.data;\n                var sEl = document.getElementById('ptzShutter');\n                if (sEl) sEl.textContent = '快门: ' + (sh.current_level || '--');\n            }\n        }).catch(function(e) {});\n    }, 1000);\n}\n\nfunction stopPtzImagePoll() {\n    if (_ptzImagePollInterval) {\n        clearInterval(_ptzImagePollInterval);\n        _ptzImagePollInterval = null;\n    }\n}\n\n// 暴露到全局\nwindow.startPtzImagePoll = startPtzImagePoll;\nwindow.stopPtzImagePoll = stopPtzImagePoll;\n\n// ==================== 暴露到全局 ====================\nwindow.toggleSection = toggleSection;\nwindow.loadDeviceImageParams = loadDeviceImageParams;\nwindow.setSharpness = setSharpness;\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\nwindow.setWhiteBalanceGain = setWhiteBalanceGain;\nwindow.setNoiseReduce = setNoiseReduce;\nwindow.setShutterSpeed = setShutterSpeed;\nwindow.setIris = setIris;\nwindow.setExposureMode = setExposureMode;\nwindow.togglePtzOsd = togglePtzOsd;\nwindow.toggleInfoOsd = toggleInfoOsd;\nwindow.updatePtzOsdButtons = updatePtzOsdButtons;\nwindow.updateInfoOsdButtons = updateInfoOsdButtons;\n</script>","oldText":"// ==================== 暴露到全局 ====================\nwindow.toggleSection = toggleSection;\nwindow.loadDeviceImageParams = loadDeviceImageParams;\nwindow.setSharpness = setSharpness;\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\nwindow.setWhiteBalanceGain = setWhiteBalanceGain;\nwindow.setNoiseReduce = setNoiseReduce;\nwindow.setShutterSpeed = setShutterSpeed;\nwindow.setIris = setIris;\nwindow.setExposureMode = setExposureMode;\nwindow.togglePtzOsd = togglePtzOsd;\nwindow.toggleInfoOsd = toggleInfoOsd;\nwindow.updatePtzOsdButtons = updatePtzOsdButtons;\nwindow.updateInfoOsdButtons = updateInfoOsdButtons;\n</script>"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":92445,"output":1268,"cacheRead":0,"cacheWrite":0,"totalTokens":93713,"cost":{"input":0.092445,"output":0.004057600000000001,"cacheRead":0,"cacheWrite":0,"total":0.0965026}},"stopReason":"toolUse","timestamp":1781401172602,"responseId":"cht000d6758@dx19ec3c8cfe6ba5b442"}}
