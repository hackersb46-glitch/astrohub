          sadp_info = self._discovered.get(mac)\r\n            entry = {\r\n                \"mac\": mac,\r\n                \"ip\": ip,\r\n                \"name\": info.get(\"name\", \"\"),\r\n                \"model\": info.get(\"model\", \"\"),\r\n                \"gateway\": info.get(\"gateway\", \"\"),  # v6.02\r\n                \"subnet_mask\": info.get(\"subnet_mask\", \"\"),  # v6.02\r\n                \"port\": info.get(\"port\", 80),\r\n                \"connected\": is_connected,\r\n                \"online\": is_connected,\r\n                \"source\": \"manual\",\r\n            }\r\n            if sadp_info:\r\n\n[1358 more lines in file. Use offset=1550 to continue.]"}],"isError":false,"timestamp":1781434705539}}
