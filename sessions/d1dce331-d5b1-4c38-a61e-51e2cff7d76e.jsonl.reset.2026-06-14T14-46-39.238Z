{"type":"message","id":"38173120","parentId":"04d5bce5","timestamp":"2026-06-14T09:56:08.824Z","message":{"role":"toolResult","toolCallId":"call_9792cb26f90248c681934fb8","toolName":"read","content":[{"type":"text","text":"@api_router.post(\"/ptz/{device_id}/image/shutter\", summary=\"设置快门\", tags=[\"Image\"])\r\nasync def set_shutter(device_id: str, data: dict) -> dict:\r\n    \"\"\"设置快门参数 - v7.04: 使用 Exposure 端点设置 ShutterLevel\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        level = data.get(\"level\", \"1/60\")\r\n        \r\n        # v7.06: 先获取当前曝光模式\r\n        get_resp = client.get(\"/Image/channels/1/exposure\")\r\n        current_mode = \"manual\"\r\n        if get_resp.status_code == 200:\r\n            root = ET.fromstring(get_resp.xml)\r\n            for elem in root.iter():\r\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n                if tag in (\"ExposureType\", \"exposureType\"):\r\n                    current_mode = elem.text or \"manual\"\r\n        \r\n        # v7.06: 保持当前曝光模式\r\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <ExposureType>{current_mode}</ExposureType>\r\n  <ShutterLevel>{level}</ShutterLevel>\r\n</Exposure>'''\r\n\r\n        put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": f\"快门已设置为 {level}\"}\r\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置快门异常: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/iris\", summary=\"获取光圈设置\", tags=[\"Image\"])\r\nasync def get_iris(device_id: str) -> dict:\r\n    \"\"\"获取设备光圈当前设置。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n\n[351 more lines in file. Use offset=3068 to continue.]"}],"isError":false,"timestamp":1781430968824}}
{"type":"message","id":"d6104001","parentId":"38173120","timestamp":"2026-06-14T09:56:31.840Z","message":{"role":"assistant","content":[{"type":"text","text":"现在用 Python 精确替换整个函数："},{"type":"toolCall","id":"tool-daefb5ad841948e988b6bf45d52a6dd3","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n精确替换 set_shutter 函数\n\"\"\"\n\n# 读取文件\nwith open('src/api/router.py', 'r', encoding='utf-8') as f:\n    content = f.read()\n\n# 旧函数\nold_func = '''@api_router.post(\"/ptz/{device_id}/image/shutter\", summary=\"设置快门\", tags=[\"Image\"])\nasync def set_shutter(device_id: str, data: dict) -> dict:\n    \"\"\"设置快门参数 - v7.04: 使用 Exposure 端点设置 ShutterLevel\"\"\"\n    import xml.etree.ElementTree as ET\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    try:\n        level = data.get(\"level\", \"1/60\")\n        \n        # v7.06: 先获取当前曝光模式\n        get_resp = client.get(\"/Image/channels/1/exposure\")\n        current_mode = \"manual\"\n        if get_resp.status_code == 200:\n            root = ET.fromstring(get_resp.xml)\n            for elem in root.iter():\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n                if tag in (\"ExposureType\", \"exposureType\"):\n                    current_mode = elem.text or \"manual\"\n        \n        # v7.06: 保持当前曝光模式\n        xml_str = f\\'\\'\\'<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ExposureType>{current_mode}</ExposureType>\n  <ShutterLevel>{level}</ShutterLevel>\n</Exposure>\\'\\'\\'\n\n        put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": f\"快门已设置为 {level}\"}\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置快门异常: {e}\"}'''\n\n# 新函数\nnew_func = '''@api_router.post(\"/ptz/{device_id}/image/shutter\", summary=\"设置快门\", tags=[\"Image\"])\nasync def set_shutter(device_id: str, data: dict) -> dict:\n    \"\"\"设置快门参数 - v7.07: 使用独立 Shutter 端点\"\"\"\n    import xml.etree.ElementTree as ET\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    try:\n        level = data.get(\"level\", \"1/60\")\n        \n        # v7.07: 使用独立 Shutter 端点\n        xml_str = f\\'\\'\\'<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Shutter version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ShutterLevel>{level}</ShutterLevel>\n</Shutter>\\'\\'\\'\n\n        put_resp = client.put(\"/Image/channels/1/Shutter\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": f\"快门已设置为 {level}\"}\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置快门异常: {e}\"}'''\n\ncontent = content.replace(old_func, new_func)\n\n# 写回文件\nwith open('src/api/router.py', 'w', encoding='utf-8') as f:\n    f.write(content)\n\nprint(\"Done\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\fix_shutter_final.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":121938,"output":1054,"cacheRead":0,"cacheWrite":0,"totalTokens":122992,"cost":{"input":0.12193799999999999,"output":0.0033728000000000005,"cacheRead":0,"cacheWrite":0,"total":0.1253108}},"stopReason":"toolUse","timestamp":1781430968828,"responseId":"cht000e581b@dx19ec58f63aab893102"}}
