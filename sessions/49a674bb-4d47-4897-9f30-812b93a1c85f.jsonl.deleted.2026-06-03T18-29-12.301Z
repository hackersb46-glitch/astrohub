/ WASM SDK login\r\n                            if (window.clickLogin2) { window.clickLogin2(); }\r\n                        }\r\n                    } else if (result && result.message && result.message.indexOf('еЗ≠иѓБ') >= 0) {\r\n                        // credentials йФЩиѓѓпЉМжПРз§ЇзФ®жИЈиЊУеЕ•\r\n                        var username2 = prompt(\"иѓЈиЊУеЕ•зФ®жИЈеРН:\", \"admin\");\r\n                        if (!username2) return;\r\n                        var password2 = prompt(\"иѓЈиЊУеЕ•еѓЖз†Б:\");\r\n                        if (!password2) return;\r\n                        connectDeviceWithCreds(ip, username2, password2, 80);\r\n                    } else {\r\n                        showToast('error', result ? result.message : 'ињЮжО•е§±иі•');\r\n                        addLog('error', result ? result.message : 'ињЮжО•е§±иі•');\r\n                    }\r\n                }).catch(function(e) {\r\n                    showToast('error', 'ињЮжО•еЉВеЄЄ: ' + e.message);\r\n                    addLog('error', 'ињЮжО•еЉВеЄЄ: ' + e.message);\r\n                });\r\n            }).catch(function(e) {\r\n                // credentials API е§±иі•пЉМе∞ЭиѓХжЧ†еѓЖз†БињЮжО•\r\n                apiPost('/api/v1/devices/' + ip + '/connect', null).then(function(result) {\r\n                    if (result && result.success) {\r\n                        showToast('success', 'иЃЊе§ЗеЈ≤ињЮжО•: ' + ip);\r\n                        refreshDevices();\r\n                        refreshPtzDeviceList();\r\n                        refreshAdvancedDeviceSelectors();\r\n                        var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n                        if (dev) {\r\n                            window.connectedDevice = {\r\n                                ip: dev.ip, model: dev.model || '', name: dev.name || dev.device_name || '',\r\n                                mac: dev.mac || '', username: 'admin', password: '', port: 80, online: true\r\n               