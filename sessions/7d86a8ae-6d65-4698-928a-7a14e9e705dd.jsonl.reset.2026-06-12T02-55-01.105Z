{"type":"message","id":"04c83bf0","parentId":"25b7150a","timestamp":"2026-06-12T00:29:46.791Z","message":{"role":"toolResult","toolCallId":"call_d7fb0832d1c74fd0a14f5144","toolName":"read","content":[{"type":"text","text":"                                        <label style=\"font-size:12px\">锐度 <span id=\"sharpnessRange\" style=\"color:#6e7681\"></span></label>\n                                        <input type=\"range\" id=\"consoleSharpness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setSharpness(this.value)\">\n                                    </div>\n                                    <!-- 白平衡 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">白平衡模式</label>\n                                        <select id=\"wbMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setWhiteBalanceMode(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <div style=\"display:flex;gap:8px;margin-bottom:8px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#f85149\">R <span id=\"wbRedVal\">--</span></label>\n                                            <input type=\"range\" id=\"wbRed\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" onchange=\"setWhiteBalanceGain('red', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#58a6ff\">B <span id=\"wbBlueVal\">--</span></label>\n                                            <input type=\"range\" id=\"wbBlue\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" onchange=\"setWhiteBalanceGain('blue', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 降噪 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:8px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">空域降噪 <span id=\"dnrSpatialVal\">--</span></label>\n                                            <input type=\"range\" id=\"dnrSpatial\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setNoiseReduce('spatial', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">时域降噪 <span id=\"dnrTemporalVal\">--</span></label>\n                                            <input type=\"range\" id=\"dnrTemporal\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setNoiseReduce('temporal', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 快门 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">快门速度</label>\n                                        <select id=\"shutterSpeed\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setShutterSpeed(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- 光圈 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">光圈控制</label>\n                                        <select id=\"irisLevel\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setIris(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- OSD 控制 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\n                                        <label style=\"font-size:12px\">PTZ 坐标显示</label>\n                                        <div class=\"btn-group\">\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnPtzOsdOn\" onclick=\"togglePtzOsd(true)\">显示</button>\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnPtzOsdOff\" onclick=\"togglePtzOsd(false)\">关闭</button>\n                                        </div>\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:0\">\n                                        <label style=\"font-size:12px\">OSD 信息显示</label>\n                                        <div class=\"btn-group\">\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnInfoOsdOn\" onclick=\"toggleInfoOsd(true)\">显示</button>\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnInfoOsdOff\" onclick=\"toggleInfoOsd(false)\">关闭</button>\n                                        </div>\n                                    </div>\n\n[520 more lines in file. Use offset=235 to continue.]"}],"isError":f