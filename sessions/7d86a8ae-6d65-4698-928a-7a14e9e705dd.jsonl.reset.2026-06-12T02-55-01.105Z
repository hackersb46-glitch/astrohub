count() > 0:\n            opts = el.locator('option').all_inner_texts()\n            val = el.evaluate('e => e.value')\n            print(f'{label}: value={val}, options={opts}')\n\n    # 检查 OSD 开关按钮\n    print('=== OSD 开关 ===')\n    ptz_btn = page.locator('#btnPtzOsd')\n    info_btn = page.locator('#btnInfoOsd')\n    if ptz_btn.count() > 0:\n        txt = ptz_btn.evaluate('e => e.textContent')\n        print(f'PTZ OSD button: {txt}')\n    if info_btn.count() > 0:\n        txt = info_btn.evaluate('e => e.textContent')\n        print(f'Info OSD button: {txt}')\n\n    page.screenshot(path='C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/v5.42_final.png')\n    print('Screenshot saved: tests/v5.42_final.png')\n    browser.close()","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_v5.42_final.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":136069,"output":692,"cacheRead":0,"cacheWrite":0,"totalTokens":136761,"cost":{"input":0.136069,"output":0.0022144,"cacheRead":0,"cacheWrite":0,"total":0.1382834}},"stopReason":"toolUse","timestamp":1781230366732,"responseId":"cht000d382a@dx19eb99a784fba60352"}}
