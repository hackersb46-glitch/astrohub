{"type":"message","id":"82f54896","parentId":"ca3c5cd5","timestamp":"2026-06-11T23:24:34.725Z","message":{"role":"assistant","content":[{"type":"text","text":"备份完成。现在修改 `console.html`："},{"type":"toolCall","id":"call_b63dc2974eb94066aca2a55f","name":"write","arguments":{"content":"        <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">未连接</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\n                <div class=\"console-layout\">\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\n                    <div class=\"console-left\">\n                        <!-- PTZ控制（折叠） -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- 指向控制 -->\n                                <div class=\"section-subtitle\">指向</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\n                                    <button class=\"ptz-btn center\">●</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>速度:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                                    <span id=\"ptzSpeedVal\">50</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- 预置点 -->\n                                <div class=\"section-subtitle\">预置点</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">选择预置点</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- 变焦/对焦 -->\n                                <div class=\"section-subtitle\">变焦/对焦</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">近</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">远</button>\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                                        <option value=\"manual\">手动</option>\n                                        <option value=\"auto\">自动</option>\n                                        <option value=\"semiauto\">半自动</option>\n                                    </select>\n                                </div>\n                                <!-- 码流选择 -->\n                                <div class=\"section-subtitle\">码流</div>\n                                <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\n                                    <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                                        <option value=\"1\">主码流</option>\n                                        <option value=\"2\" selected>子码流</option>\n                                        <option value=\"3\">第三码流</option>\n                                    </select>\n                                </div>\n                            </div>\n                        </div>\n                        <!-- 跟踪控制 -->\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 中: 实时画面 + 媒体操作 -->\n                    <div class=\"console-center\">\n                        <!-- 实时画面 -->\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                        </div>\n                        <!-- 媒体操作（折叠，整合Live Stack） -->\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\n                                    <!-- 截图/录像 -->\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                                    </div>\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\n                                    <!-- Live Stack -->\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\n                                    </div>\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\n                                    </div>\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\n                                        <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\n                                    </div>\n                                    <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">叠加: 关闭</div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 右: 操作日志 + 画面控制 -->\n                    <div class=\"console-right\">\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto;max-height:200px\">\n                            <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\n                                <div style=\"color:#6e7681\">等待连接...</div>\n                            </div>\n                        </div>\n                        <!-- 画面控制（折叠，移到右侧） -->\n                        <div class=\"collapsible-section collapsed\" id=\"imageControlSection\" style=\"margin-top:12px\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('imageControlSection')\">\n                                <h3 style=\"font-size:15px;color:#d29922;margin:0\">🎨 画面控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div class=\"card\">\n                                    <!-- 基础调节 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">亮度</label>\n                                        <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('brightness', this.value)\">\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">对比度</label>\n                                        <input type=\"range\" id=\"consoleContrast\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('contrast', this.value)\">\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">饱和度</label>\n                                        <input type=\"range\" id=\"consoleSaturation\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('saturation', this.value)\">\n                                    </div>\n                                    <!-- 锐度 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">锐度 <span id=\"sharpnessRange\" style=\"color:#6e7681\"></span></label>\n                                        <input type=\"range\" id=\"consoleSharpness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImageEx('sharpness', this.value)\">\n                                    </div>\n                                    <!-- 白平衡 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">白平衡模式</label>\n                                        <select id=\"wbMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setWhiteBalanceMode(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <div style=\"display:flex;gap:8px;margin-bottom:8px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#f85149\">R <span id=\"wbRedVal\">50</span></label>\n                                            <input type=\"range\" id=\"wbRed\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" onchange=\"setWhiteBalanceRB('red', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#58a6ff\">B <span id=\"wbBlueVal\">50</span></label>\n                                            <input type=\"range\" id=\"wbBlue\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" onchange=\"setWhiteBalanceRB('blue', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 降噪 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:8px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">空域降噪</label>\n                                            <input type=\"range\" id=\"dnrSpatial\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setDNR('spatial', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">时域降噪</label>\n                                            <input type=\"range\" id=\"dnrTemporal\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setDNR('temporal', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 快门 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">快门速度</label>\n                                        <select id=\"shutterMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setShutter(this.value)\">\n                                            <option value=\"auto\">自动</option>\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- 曝光时间 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">曝光时间</label>\n                                        <select id=\"exposureTime\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setExposureTime(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- 光圈 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">光圈控制 <span id=\"irisRange\" style=\"color:#6e7681\"></span></label>\n                                        <select id=\"irisLevel\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setIris(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- OSD 控制 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\n                                        <label style=\"font-size:12px\">PTZ 坐标显示</label>\n                                        <div class=\"btn-group\">\n                                            <button class=\"btn btn-sm btn-primary\" id=\"btnPtzOsdOn\" onclick=\"togglePtzOsd(true)\">显示</button>\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnPtzOsdOff\" onclick=\"togglePtzOsd(false)\">关闭</button>\n                                        </div>\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:0\">\n                                        <label style=\"font-size:12px\">OSD 信息显示</label>\n                                        <div class=\"btn-group\">\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnInfoOsdOn\" onclick=\"toggleInfoOsd(true)\">显示</button>\n                                            <button class=\"btn btn-sm btn-primary\" id=\"btnInfoOsdOff\" onclick=\"toggleInfoOsd(false)\">关闭</button>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n<style>\n/* 折叠面板样式 */\n.collapsible-section {\n    background: #161b22;\n    border: 1px solid #21262d;\n    border-radius: 8px;\n    margin-bottom: 12px;\n    overflow: hidden;\n}\n.collapsible-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 10px 12px;\n    cursor: pointer;\n    background: #0d1117;\n    transition: background 0.2s;\n}\n.collapsible-header:hover {\n    background: #161b22;\n}\n.collapse-icon {\n    color: #8b949e;\n    font-size: 12px;\n    transition: transform 0.2s;\n}\n.collapsible-section.collapsed .collapse-icon {\n    transform: rotate(-90deg);\n}\n.collapsible-content {\n    padding: 12px;\n    max-height: 1000px;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out, padding 0.3s;\n}\n.collapsible-section.collapsed .collapsible-content {\n    max-height: 0;\n    padding: 0 12px;\n}\n.section-subtitle {\n    font-size: 12px;\n    color: #6e7681;\n    margin: 8px 0 4px;\n    padding-top: 8px;\n    border-top: 1px solid #21262d;\n}\n.section-subtitle:first-child {\n    border-top: none;\n    padding-top: 0;\n}\n</style>\n\n<script>\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// 设备功能数据（动态加载）\nvar deviceFunctionData = null;\n\n// 连接设备时加载功能数据\nfunction loadDeviceFunctions(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 尝试从本地存储加载\n    var cacheKey = 'func_' + deviceIp.replace(/\\./g, '_');\n    var cached = localStorage.getItem(cacheKey);\n    if (cached) {\n        try {\n            deviceFunctionData = JSON.parse(cached);\n            applyFunctionData(deviceFunctionData);\n            console.log('[FUNC] Loaded from cache:', deviceIp);\n            return;\n        } catch(e) {}\n    }\n    \n    // 从服务器加载\n    fetch('/api/v1/ptz/' + deviceIp + '/function')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (data && data.success && data.functions) {\n                deviceFunctionData = data.functions;\n                localStorage.setItem(cacheKey, JSON.stringify(deviceFunctionData));\n                applyFunctionData(deviceFunctionData);\n                console.log('[FUNC] Loaded from server:', deviceIp);\n            }\n        })\n        .catch(function(e) {\n            console.warn('[FUNC] Load failed:', e);\n        });\n}\n\n// 应用功能数据到UI\nfunction applyFunctionData(funcs) {\n    if (!funcs) return;\n    \n    // 锐度\n    if (funcs.sharpness) {\n        var s = funcs.sharpness;\n        var slider = document.getElementById('consoleSharpness');\n        if (slider && s.min !== undefined && s.max !== undefined) {\n            slider.min = s.min;\n            slider.max = s.max;\n            slider.value = s.current_values?.SharpnessLevel || 50;\n        }\n        var range = document.getElementById('sharpnessRange');\n        if (range) range.textContent = '(' + s.min + '~' + s.max + ')';\n    }\n    \n    // 白平衡\n    if (funcs.white_balance) {\n        var wb = funcs.white_balance;\n        var wbModeSelect = document.getElementById('wbMode');\n        if (wbModeSelect) {\n            wbModeSelect.innerHTML = '<option value=\"auto\">自动</option><option value=\"manual\">手动</option><option value=\"lock\">锁定</option>';\n        }\n        var wbRed = document.getElementById('wbRed');\n        var wbBlue = document.getElementById('wbBlue');\n        if (wbRed && wb.min !== undefined && wb.max !== undefined) {\n            wbRed.min = wb.min;\n            wbRed.max = wb.max;\n            wbRed.value = wb.current_values?.WhiteBalanceRed || 50;\n        }\n        if (wbBlue) {\n            wbBlue.min = wb.min;\n            wbBlue.max = wb.max;\n            wbBlue.value = wb.current_values?.WhiteBalanceBlue || 50;\n        }\n    }\n    \n    // 降噪\n    if (funcs.dnr_spatial || funcs.dnr_temporal) {\n        var dnrSpatial = document.getElementById('dnrSpatial');\n        var dnrTemporal = document.getElementById('dnrTemporal');\n        if (funcs.dnr_spatial && dnrSpatial) {\n            dnrSpatial.value = funcs.dnr_spatial.current_values?.generalLevel || 50;\n        }\n        if (funcs.dnr_temporal && dnrTemporal) {\n            dnrTemporal.value = funcs.dnr_temporal.current_values?.generalLevel || 50;\n        }\n    }\n    \n    // 快门\n    if (funcs.shutter) {\n        var s = funcs.shutter;\n        var shutterSelect = document.getElementById('shutterMode');\n        if (shutterSelect && s.min && s.max) {\n            // 解析快门值（如 1/30000 ~ 1/25）\n            var shutterOptions = generateShutterOptions(s.min, s.max);\n            shutterSelect.innerHTML = '<option value=\"auto\">自动</option>' + shutterOptions;\n        }\n    }\n    \n    // 曝光时间（复用快门数据）\n    if (funcs.shutter) {\n        var expSelect = document.getElementById('exposureTime');\n        if (expSelect && funcs.shutter.min && funcs.shutter.max) {\n            var expOptions = generateShutterOptions(funcs.shutter.min, funcs.shutter.max);\n            expSelect.innerHTML = '<option value=\"\">-- 选择 --</option>' + expOptions;\n        }\n    }\n    \n    // 光圈\n    if (funcs.iris) {\n        var iris = funcs.iris;\n        var irisSelect = document.getElementById('irisLevel');\n        var irisRange = document.getElementById('irisRange');\n        if (irisSelect && iris.min !== undefined && iris.max !== undefined) {\n            var irisOptions = generateIrisOptions(iris.min, iris.max);\n            irisSelect.innerHTML = irisOptions;\n        }\n        if (irisRange) {\n            irisRange.textContent = '(' + iris.min + '~' + iris.max + ')';\n        }\n    }\n}\n\n// 生成快门选项\nfunction generateShutterOptions(min, max) {\n    // 常用快门值\n    var presets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000', '1/16000'];\n    var html = '';\n    presets.forEach(function(p) {\n        html += '<option value=\"' + p + '\">' + p + '</option>';\n    });\n    // 如果设备返回范围，添加边界值\n    if (min) html += '<option value=\"' + min + '\">' + min + ' (最慢)</option>';\n    if (max) html += '<option value=\"' + max + '\">' + max + ' (最快)</option>';\n    return html;\n}\n\n// 生成光圈选项\nfunction generateIrisOptions(min, max) {\n    // 光圈值映射到 F 值\n    var fValues = [\n        {val: 160, label: 'F1.6'},\n        {val: 200, label: 'F2.0'},\n        {val: 280, label: 'F2.8'},\n        {val: 400, label: 'F4.0'},\n        {val: 560, label: 'F5.6'},\n        {val: 800, label: 'F8.0'},\n        {val: 1100, label: 'F11'},\n        {val: 1600, label: 'F16'},\n        {val: 2200, label: 'F22'}\n    ];\n    var html = '<option value=\"\">-- 选择 --</option>';\n    fValues.forEach(function(f) {\n        if (f.val >= min && f.val <= max) {\n            html += '<option value=\"' + f.val + '\">' + f.label + '</option>';\n        }\n    });\n    return html;\n}\n\n// 扩展图像调节（带范围）\nfunction adjustImageEx(param, value) {\n    adjustImage(param, value);\n}\n\n// 白平衡模式\nfunction setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) { showToast('warning', '请先选择设备'); return; }\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '白平衡模式: ' + mode);\n            else showToast('error', r ? r.message : '设置失败');\n        }).catch(function(e) { showToast('error', '设置异常: ' + e.message); });\n}\n\n// 白平衡 R/B\nfunction setWhiteBalanceRB(channel, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // 更新显示\n    if (channel === 'red') {\n        document.getElementById('wbRedVal').textContent = value;\n    } else {\n        document.getElementById('wbBlueVal').textContent = value;\n    }\n    \n    // 发送请求\n    var body = {};\n    body['wb_' + channel] = parseInt(value);\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', body)\n        .then(function(r) {\n            if (r && r.success) {\n                // 静默成功\n            }\n        }).catch(function(e) {});\n}\n\n// 降噪\nfunction setDNR(type, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    var body = {};\n    body['dnr_' + type] = parseInt(value);\n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', body)\n        .then(function(r) {\n            if (r && r.success) {\n                // 静默成功\n            }\n        }).catch(function(e) {});\n}\n\n// 快门\nfunction setShutter(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    if (value === 'auto') {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { auto: true })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: 自动');\n            }).catch(function(e) {});\n    } else {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: ' + value);\n                else showToast('error', r ? r.message : '设置失败');\n            }).catch(function(e) { showToast('error', '设置异常: ' + e.message); });\n    }\n}\n\n// 曝光时间\nfunction setExposureTime(value) {\n    if (!value) return;\n    setShutter(value);\n}\n\n// 光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                // 找到对应的 F 值显示\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            } else {\n                showToast('error', r ? r.message : '设置失败');\n            }\n        }).catch(function(e) { showToast('error', '设置异常: ' + e.message); });\n}\n\n// 暴露到全局\nwindow.toggleSection = toggleSection;\nwindow.loadDeviceFunctions = loadDeviceFunctions;\nwindow.adjustImageEx = adjustImageEx;\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\nwindow.setWhiteBalanceRB = setWhiteBalanceRB;\nwindow.setDNR = setDNR;\nwindow.setShutter = setShutter;\nwindow.setExposureTime = setExposureTime;\nwindow.setIris = setIris;\n</script>\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":74421,"output":7272,"cacheRead":0,"cacheWrite":0,"totalTokens":81693,"cost":{"input":0.074421,"output":0.023270400000000004,"cacheRead":0,"cacheWrite":0,"total":0.09769140000000001}},"stopReason":"toolUse","timestamp":1781220161068,"responseId":"cht000d418c@dx19eb8feb639ba5e412"}}
