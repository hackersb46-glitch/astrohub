{"type":"message","id":"3e321117","parentId":"8b9559be","timestamp":"2026-06-11T23:49:09.369Z","message":{"role":"assistant","content":[{"type":"text","text":"Playwright 已安装。创建测试脚本："},{"type":"toolCall","id":"call_99374371c7db4a90a8069d18","name":"write","arguments":{"content":"\"\"\"\nPlaywright E2E Test - AstroHub v5.48 Console UI\n测试内容:\n1. 加载主控台页面\n2. 验证折叠面板\n3. 验证图像参数动态加载\n4. 验证 OSD 状态\n\"\"\"\n\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_console_ui():\n    with sync_playwright() as p:\n        # 启动浏览器\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        results = []\n        \n        # 1. 加载主控台页面\n        print(\"[TEST 1] 加载主控台页面...\")\n        page.goto(\"http://localhost:10280\", timeout=30000)\n        page.wait_for_load_state(\"networkidle\")\n        \n        # 切换到主控台标签\n        nav_btns = page.locator(\".nav-btn\")\n        count = nav_btns.count()\n        for i in range(count):\n            text = nav_btns.nth(i).text_content()\n            if \"主控台\" in text or \"控制台\" in text:\n                nav_btns.nth(i).click()\n                break\n        \n        time.sleep(1)\n        results.append((\"加载主控台页面\", True, \"\"))\n        \n        # 2. 验证 PTZ 控制折叠面板\n        print(\"[TEST 2] 验证 PTZ 控制折叠面板...\")\n        ptz_section = page.locator(\"#ptzControlSection\")\n        if ptz_section.count() > 0:\n            # 检查是否默认折叠\n            is_collapsed = \"collapsed\" in ptz_section.get_attribute(\"class\")\n            results.append((\"PTZ控制折叠面板\", is_collapsed, f\"collapsed={is_collapsed}\"))\n            \n            # 点击展开\n            header = ptz_section.locator(\".collapsible-header\")\n            header.click()\n            time.sleep(0.5)\n            \n            # 检查是否展开\n            is_expanded = \"collapsed\" not in ptz_section.get_attribute(\"class\")\n            results.append((\"PTZ控制展开\", is_expanded, f\"expanded={is_expanded}\"))\n        else:\n            results.append((\"PTZ控制折叠面板\", False, \"未找到元素\"))\n        \n        # 3. 验证媒体操作折叠面板（码流应在其中）\n        print(\"[TEST 3] 验证媒体操作折叠面板...\")\n        media_section = page.locator(\"#mediaControlSection\")\n        if media_section.count() > 0:\n            is_collapsed = \"collapsed\" in media_section.get_attribute(\"class\")\n            results.append((\"媒体操作折叠面板\", is_collapsed, f\"collapsed={is_collapsed}\"))\n            \n            # 检查码流是否在媒体操作中\n            header.click() if header else None\n            time.sleep(0.5)\n            \n            # 展开媒体操作\n            media_header = media_section.locator(\".collapsible-header\")\n            media_header.click()\n            time.sleep(0.5)\n            \n            stream_select = page.locator(\"#streamType\")\n            in_media = stream_select.count() > 0\n            results.append((\"码流在媒体操作中\", in_media, f\"found={in_media}\"))\n        else:\n            results.append((\"媒体操作折叠面板\", False, \"未找到元素\"))\n        \n        # 4. 验证画面控制折叠面板（在右侧）\n        print(\"[TEST 4] 验证画面控制折叠面板...\")\n        image_section = page.locator(\"#imageControlSection\")\n        if image_section.count() > 0:\n            is_collapsed = \"collapsed\" in image_section.get_attribute(\"class\")\n            results.append((\"画面控制折叠面板\", is_collapsed, f\"collapsed={is_collapsed}\"))\n            \n            # 检查是否在 console-right 中\n            parent = image_section.evaluate(\"el => el.parentElement?.id\")\n            in_right = parent == \"console-right\" if parent else False\n            results.append((\"画面控制在右侧\", in_right, f\"parent={parent}\"))\n        else:\n            results.append((\"画面控制折叠面板\", False, \"未找到元素\"))\n        \n        # 5. 验证新增控制项\n        print(\"[TEST 5] 验证新增控制项...\")\n        \n        # 展开画面控制\n        image_header = image_section.locator(\".collapsible-header\")\n        image_header.click()\n        time.sleep(0.5)\n        \n        # 检查锐度\n        sharpness = page.locator(\"#consoleSharpness\")\n        results.append((\"锐度滑动条\", sharpness.count() > 0, f\"found={sharpness.count() > 0}\"))\n        \n        # 检查白平衡模式\n        wb_mode = page.locator(\"#wbMode\")\n        results.append((\"白平衡模式下拉\", wb_mode.count() > 0, f\"found={wb_mode.count() > 0}\"))\n        \n        # 检查白平衡 R/B\n        wb_red = page.locator(\"#wbRed\")\n        wb_blue = page.locator(\"#wbBlue\")\n        results.append((\"白平衡R滑动条\", wb_red.count() > 0, f\"found={wb_red.count() > 0}\"))\n        results.append((\"白平衡B滑动条\", wb_blue.count() > 0, f\"found={wb_blue.count() > 0}\"))\n        \n        # 检查降噪\n        dnr_spatial = page.locator(\"#dnrSpatial\")\n        dnr_temporal = page.locator(\"#dnrTemporal\")\n        results.append((\"空域降噪滑动条\", dnr_spatial.count() > 0, f\"found={dnr_spatial.count() > 0}\"))\n        results.append((\"时域降噪滑动条\", dnr_temporal.count() > 0, f\"found={dnr_temporal.count() > 0}\"))\n        \n        # 检查快门\n        shutter = page.locator(\"#shutterSpeed\")\n        results.append((\"快门速度下拉\", shutter.count() > 0, f\"found={shutter.count() > 0}\"))\n        \n        # 检查光圈\n        iris = page.locator(\"#irisLevel\")\n        results.append((\"光圈下拉\", iris.count() > 0, f\"found={iris.count() > 0}\"))\n        \n        # 6. 截图\n        print(\"[TEST 6] 保存截图...\")\n        page.screenshot(path=\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_console_v5.48.png\")\n        results.append((\"截图保存\", True, \"e2e_console_v5.48.png\"))\n        \n        browser.close()\n        \n        # 输出结果\n        print(\"\\n\" + \"=\" * 60)\n        print(\"E2E 测试结果\")\n        print(\"=\" * 60)\n        \n        passed = 0\n        failed = 0\n        for name, success, detail in results:\n            status = \"✅ PASS\" if success else \"❌ FAIL\"\n            print(f\"{status} | {name}: {detail}\")\n            if success:\n                passed += 1\n            else:\n                failed += 1\n        \n        print(\"=\" * 60)\n        print(f\"总计: {passed} 通过, {failed} 失败\")\n        print(\"=\" * 60)\n        \n        return failed == 0\n\nif __name__ == \"__main__\":\n    success = test_console_ui()\n    exit(0 if success else 1)\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_console_v5.48.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":132568,"output":1643,"cacheRead":0,"cacheWrite":0,"totalTokens":134211,"cost":{"input":0.132568,"output":0.0052576,"cacheRead":0,"cacheWrite":0,"total":0.1378256}},"stopReason":"toolUse","timestamp":1781221716724,"responseId":"cht000d59a7@dx19eb916744db828232"}}
