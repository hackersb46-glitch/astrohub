{"type":"message","id":"ca2a4086","parentId":"60628ad3","timestamp":"2026-06-12T00:55:15.878Z","message":{"role":"assistant","content":[{"type":"text","text":"`apiGet` 和 `apiPost` 在 index.html 第 310-320 行定义。\n\n**最小修复：** 在 console.html 的脚本开头，等待 `apiGet` 可用："},{"type":"toolCall","id":"call_09cad14a54e54d91a2f31fbc","name":"edit","arguments":{"edits":[{"newText":"</style>\n\n<script>\n// 等待 apiGet/apiPost 可用后再定义函数\n(function() {\n    // 检查 apiGet 是否已定义\n    if (typeof apiGet === 'undefined') {\n        console.warn('[CONSOLE] apiGet not yet defined, will retry on DOMContentLoaded');\n        document.addEventListener('DOMContentLoaded', function() {\n            // DOM 加载完成后重新执行\n            if (typeof apiGet !== 'undefined') {\n                console.log('[CONSOLE] apiGet now available');\n            }\n        });\n    }\n})();\n\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\n\n// 连接设备时加载图像参数（从设备实时读取）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 检查 apiGet 是否可用\n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined, cannot load image params');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);","oldText":"</style>\n\n<script>\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\n\n// 连接设备时加载图像参数（从设备实时读取）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohu