{"type":"message","id":"9f3f612a","parentId":"ac877148","timestamp":"2026-06-11T23:21:41.865Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tool-d447f165b2f84ea7b79835e01c0ba4f6","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\advanced.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":20651,"output":33,"cacheRead":0,"cacheWrite":0,"totalTokens":20684,"cost":{"input":0.020651,"output":0.0001056,"cacheRead":0,"cacheWrite":0,"total":0.0207566}},"stopReason":"toolUse","timestamp":1781220099833,"responseId":"cht000d596c@dx19eb8fdc690ba5d322"}}
{"type":"message","id":"83d161c4","parentId":"9f3f612a","timestamp":"2026-06-11T23:21:41.873Z","message":{"role":"toolResult","toolCallId":"tool-d447f165b2f84ea7b79835e01c0ba4f6","toolName":"read","content":[{"type":"text","text":"<!-- 高级功能页面 - v5.31 左中右布局 -->\n<div class=\"page\" id=\"page-advanced\">\n    <div class=\"adv-layout\">\n        <!-- 左侧：测试项目 (25%) -->\n        <div class=\"adv-left\">\n            <div class=\"adv-section-title\">测试项目</div>\n            <div class=\"adv-menu\">\n                <button class=\"adv-menu-item active\" data-test=\"function\" onclick=\"selectAdvTest('function')\">\n                    <span class=\"menu-icon\">🔍</span>\n                    <span>功能测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"limit\" onclick=\"selectAdvTest('limit')\">\n                    <span class=\"menu-icon\">📐</span>\n                    <span>限位测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"speed\" onclick=\"selectAdvTest('speed')\">\n                    <span class=\"menu-icon\">⚡</span>\n                    <span>速度测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"stream\" onclick=\"selectAdvTest('stream')\">\n                    <span class=\"menu-icon\">📡</span>\n                    <span>推流/存储</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"astrocal\" onclick=\"selectAdvTest('astrocal')\">\n                    <span class=\"menu-icon\">🌟</span>\n                    <span>天文校准</span>\n                </button>\n            </div>\n            <div class=\"adv-section-title\" style=\"margin-top:16px\">操作</div>\n            <div class=\"adv-actions\">\n                <button class=\"btn btn-primary btn-block\" id=\"btnAdvRun\" onclick=\"runAdvTest()\">▶ 开始测试</button>\n                <button class=\"btn btn-secondary btn-block\" id=\"btnAdvStop\" onclick=\"stopAdvTest()\" disabled>⏹ 停止</button>\n            </div>\n        </div>\n\n        <!-- 中间：实时画面 (55%) -->\n        <div class=\"adv-center\">\n            <div class=\"adv-section-title\">实时画面</div>\n            <div class=\"adv-video-box\" id=\"advVideoBox\">\n                <div id=\"advVideoPlaceholder\">\n                    <div style=\"color:#6e7681;text-align:center;padding:40px\">\n                        <div style=\"font-size:48px;margin-bottom:16px\">📹</div>\n                        <div id=\"advVideoStatus\">连接设备后显示实时画面</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 右侧：测试输出 (20%) -->\n        <div class=\"adv-right\">\n            <div class=\"adv-section-title\">测试输出</div>\n            <div class=\"adv-output\" id=\"advOutput\">\n                <div class=\"output-line info\">系统就绪</div>\n            </div>\n            <div class=\"adv-section-title\" style=\"margin-top:8px\">测试结果</div>\n            <div class=\"adv-result\" id=\"advResult\">\n                <div style=\"color:#6e7681;text-align:center;padding:20px\">\n                    测试结果将在此显示\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n<style>\n/* 高级功能 v5.31 布局 */\n.adv-layout {\n    display: flex;\n    gap: 0;\n    min-height: calc(100vh - 120px);\n    background: #0d1117;\n}\n\n.adv-left {\n    width: 25%;\n    min-width: 200px;\n    background: #161b22;\n    border-right: 1px solid #21262d;\n    padding: 12px;\n}\n\n.adv-center {\n    width: 55%;\n    padding: 12px;\n    display: flex;\n    flex-direction: column;\n}\n\n.adv-right {\n    width: 20%;\n    min-width: 240px;\n    background: #161b22;\n    border-left: 1px solid #21262d;\n    padding: 12px;\n    display: flex;\n    flex-direction: column;\n}\n\n.adv-section-title {\n    font-size: 13px;\n    font-weight: 600;\n    color: #8b949e;\n    padding: 8px 0;\n    border-bottom: 1px solid #21262d;\n    margin-bottom: 8px;\n}\n\n.adv-menu-item {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    width: 100%;\n    padding: 10px 12px;\n    margin: 4px 0;\n    border-radius: 6px;\n    background: #0d1117;\n    border: 1px solid #21262d;\n    color: #8b949e;\n    cursor: pointer;\n    transition: all 0.2s;\n    font-size: 13px;\n}\n\n.adv-menu-item:hover {\n    border-color: #30363d;\n    color: #e6edf3;\n}\n\n.adv-menu-item.active {\n    background: #238636;\n    border-color: #238636;\n    color: #fff;\n}\n\n.menu-icon {\n    font-size: 16px;\n}\n\n.adv-actions {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    margin-top: 8px;\n}\n\n.btn-block {\n    width: 100%;\n}\n\n.adv-video-box {\n    flex: 1;\n    background: #161b22;\n    border-radius: 8px;\n    border: 1px solid #21262d;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 400px;\n}\n\n.adv-output {\n    flex: 1;\n    background: #0d1117;\n    border-radius: 6px;\n    border: 1px solid #21262d;\n    padding: 8px;\n    overflow-y: auto;\n    max-height: 300px;\n    font-family: 'Consolas', monospace;\n    font-size: 12px;\n}\n\n.output-line {\n    padding: 2px 0;\n    line-height: 1.5;\n}\n\n.output-line.info { color: #8b949e; }\n.output-line.success { color: #3fb950; }\n.output-line.error { color: #f85149; }\n.output-line.warn { color: #d29922; }\n.output-line.test { color: #58a6ff; }\n\n.adv-result {\n    flex: 1;\n    background: #21262d;\n    border-radius: 6px;\n    border: 1px solid #30363d;\n    padding: 12px;\n    overflow-y: auto;\n    font-size: 12px;\n}\n</style>\n\n<script>\n// 高级功能页面控制\nlet currentAdvTest = 'function';\n\nfunction selectAdvTest(test) {\n    currentAdvTest = test;\n    document.querySelectorAll('.adv-menu-item').forEach(el => el.classList.remove('active'));\n    document.querySelector(`[data-test=\"${test}\"]`).classList.add('active');\n    addAdvOutput('info', '选择测试: ' + test);\n}\n\nfunction addAdvOutput(type, text) {\n    const output = document.getElementById('advOutput');\n    const line = document.createElement('div');\n    line.className = 'output-line ' + type;\n    const time = new Date().toLocaleTimeString();\n    line.textContent = '[' + time + '] ' + text;\n    output.appendChild(line);\n    output.scrollTop = output.scrollHeight;\n}\n\nfunction runAdvTest() {\n    // 尝试从全局 connectedDevice 或下拉框获取设备\n    var deviceIp = '';\n    var username = 'admin';\n    var password = '';\n\n    if (window.connectedDevice && window.connectedDevice.ip) {\n        deviceIp = window.connectedDevice.ip;\n        username = window.connectedDevice.username || 'admin';\n        password = window.connectedDevice.password || '';\n    } else {\n        // 从下拉框获取\n        var deviceSelect = document.getElementById('advConnectDevice');\n        if (deviceSelect && deviceSelect.value) {\n            deviceIp = deviceSelect.value;\n        } else {\n            addAdvOutput('error', '请先连接设备');\n            return;\n        }\n    }\n\n    const btnRun = document.getElementById('btnAdvRun');\n    const btnStop = document.getElementById('btnAdvStop');\n    btnRun.disabled = true;\n    btnStop.disabled = false;\n\n    addAdvOutput('info', '开始测试: ' + currentAdvTest);\n    addAdvOutput('info', '设备: ' + deviceIp);\n\n    const apiMap = {\n        'function': '/api/v1/advanced/function/run',\n        'limit': '/api/v1/advanced/limit/run',\n        'speed': '/api/v1/advanced/speed/run',\n        'astrocal': '/api/v1/calibrate/start'\n    };\n\n    if (currentAdvTest === 'stream') {\n        addAdvOutput('info', '推流控制，请使用主控台');\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        return;\n    }\n\n    if (currentAdvTest === 'astrocal') {\n        // 天文校准 - 跳转到校准页面\n        startAstroCalibration(deviceIp, username, password);\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        return;\n    }\n\n    const apiUrl = apiMap[currentAdvTest];\n    if (!apiUrl) {\n        addAdvOutput('error', '未知测试类型');\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        return;\n    }\n\n    fetch(apiUrl, {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: deviceIp,\n            username: username,\n            password: password\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n\n        if (data.success || data.status) {\n            addAdvOutput('success', '测试完成');\n            renderAdvResult(data);\n        } else {\n            addAdvOutput('error', data.message || '测试失败');\n        }\n    })\n    .catch(e => {\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        addAdvOutput('error', '请求异常: ' + e.message);\n    });\n}\n\nfunction stopAdvTest() {\n    addAdvOutput('warn', '停止测试');\n    document.getElementById('btnAdvRun').disabled = false;\n    document.getElementById('btnAdvStop').disabled = true;\n}\n\nfunction renderAdvResult(data) {\n    const resultEl = document.getElementById('advResult');\n    const results = data.results || data;\n\n    // 检测结果类型\n    if (results.pan_min !== undefined || results.tilt_min !== undefined) {\n        // 限位测试结果\n        let html = '<table style=\"width:100%;font-size:11px;border-collapse:collapse\">';\n        html += '<tr style=\"border-bottom:1px solid #30363d\"><th style=\"text-align:left;padding:4px\">轴</th><th style=\"text-align:center;padding:4px\">下限</th><th style=\"text-align:right;padding:4px\">上限</th></tr>';\n\n        if (results.pan_min !== undefined) {\n            html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">P轴</td><td style=\"text-align:center;padding:4px\">' + results.pan_min + '</td><td style=\"text-align:right;padding:4px\">' + results.pan_max + '</td></tr>';\n        }\n        if (results.tilt_min !== undefined) {\n            html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">T轴</td><td style=\"text-align:center;padding:4px\">' + results.tilt_min + '</td><td style=\"text-align:right;padding:4px\">' + results.tilt_max + '</td></tr>';\n        }\n        if (results.zoom_min !== undefined) {\n            html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">Z轴</td><td style=\"text-align:center;padding:4px\">' + results.zoom_min + '</td><td style=\"text-align:right;padding:4px\">' + results.zoom_max + '</td></tr>';\n        }\n\n        html += '</table>';\n\n        // 翻转状态\n        if (results.has_flip !== undefined) {\n            html += '<div style=\"margin-top:8px;padding:8px;background:#161b22;border-radius:4px\">';\n            html += '<span style=\"color:#8b949e\">翻转支持:</span> ';\n            html += results.has_flip ? '<span style=\"color:#3fb950\">✓ 是</span>' : '<span style=\"color:#f85149\">✗ 否</span>';\n            html += '</div>';\n        }\n\n        // 稳定性验证\n        if (results.stability_check !== undefined) {\n            html += '<div style=\"margin-top:4px;padding:8px;background:#161b22;border-radius:4px\">';\n            html += '<span style=\"color:#8b949e\">稳定性:</span> ';\n            html += results.stability_check ? '<span style=\"color:#3fb950\">✓ 通过</span>' : '<span style=\"color:#f85149\">✗ 失败</span>';\n            html += '</div>';\n        }\n\n        resultEl.innerHTML = html;\n    } else {\n        // 功能测试结果\n        let html = '<table style=\"width:100%;font-size:11px;border-collapse:collapse\">';\n        html += '<tr style=\"border-bottom:1px solid #30363d\"><th style=\"text-align:left;padding:4px\">项目</th><th style=\"text-align:center;padding:4px\">支持</th><th style=\"text-align:right;padding:4px\">范围</th></tr>';\n\n        for (const [key, val] of Object.entries(results)) {\n            if (typeof val === 'object' && val !== null) {\n                const label = val.label || key;\n                const supported = val.supported ? 'Y' : 'N';\n                const range = (val.min_val || '-') + '~' + (val.max_val || '-');\n                html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">' + label + '</td><td style=\"text-align:center;padding:4px\">' + supported + '</td><td style=\"text-align:right;padding:4px\">' + range + '</td></tr>';\n            }\n        }\n\n        html += '</table>';\n        resultEl.innerHTML = html;\n    }\n}\n\n// 更新视频状态\nfunction updateAdvVideoStatus() {\n    const statusEl = document.getElementById('advVideoStatus');\n    if (window.connectedDevice && window.connectedDevice.ip) {\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n            addAdvOutput('error', data.message || '选择失败');\n            return;\n        }\n        \n        // 获取当前PTZ位置并记录\n        const pan = window.connectedDevice.lastPan || 0;\n        const tilt = window.connectedDevice.lastTilt || 0;\n        \n        return fetch('/api/v1/calibrate/record', {\n            method: 'POST',\n            headers: {'Content-Type': 'application/json'},\n            body: JSON.stringify({\n                device_ip: astroCalSession,\n                pan: pan,\n                tilt: tilt\n            })\n        });\n    })\n    .then(r => r && r.json())\n    .then(data => {\n        if (data && data.success) {\n            addAdvOutput('success', '记录校准点 #' + data.point_index);\n            updateAstroCalStatus(data.coverage);\n        } else if (data) {\n            addAdvOutput('error', data.message || '记录失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction captureAndSolve() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    addAdvOutput('info', '拍摄并解析中...');\n    \n    const pan = window.connectedDevice?.lastPan || 0;\n    const tilt = window.connectedDevice?.lastTilt || 0;\n    \n    fetch('/api/v1/calibrate/capture', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: astroCalSession,\n            pan: pan,\n            tilt: tilt\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '解析成功: RA=' + data.ra.toFixed(2) + 'h, DEC=' + data.dec.toFixed(2) + '°');\n            updateAstroCalStatus(data.coverage);\n        } else {\n            addAdvOutput('error', data.message || '解析失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction updateAstroCalStatus(coverage) {\n    const statusEl = document.getElementById('astroCalStatus');\n    if (!statusEl || !coverage) return;\n    \n    let html = '校准点: ' + (coverage.total_points || 0) + ' | ';\n    html += 'Az覆盖: ' + coverage.az_spread.toFixed(0) + '° | ';\n    html += 'Alt覆盖: ' + coverage.alt_spread.toFixed(0) + '°';\n    \n    if (coverage.needs_more) {\n        html += '<br><span style=\"color:#d29922\">需要更多校准点</span>';\n    } else {\n        html += '<br><span style=\"color:#3fb950\">可以计算参数</span>';\n    }\n    \n    statusEl.innerHTML = html;\n}\n\nfunction computeAstroCal() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    addAdvOutput('info', '计算校准参数...');\n    \n    fetch('/api/v1/calibrate/compute', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({device_ip: astroCalSession})\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '计算成功!');\n            if (data.params) {\n                addAdvOutput('info', 'IA=' + data.params.IA?.toFixed(3) + '°, IH=' + data.params.IH?.toFixed(3) + '°');\n            }\n            if (data.rms) {\n                addAdvOutput('info', 'RMS: Az=' + (data.rms.az || 0).toFixed(3) + '°, Alt=' + (data.rms.alt || 0).toFixed(3) + '°');\n            }\n        } else {\n            addAdvOutput('error', data.message || '计算失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction saveAstroCal() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先完成校准计算');\n        return;\n    }\n    \n    fetch('/api/v1/calibrate/save', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({device_ip: astroCalSession})\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '校准结果已保存');\n        } else {\n            addAdvOutput('error', data.message || '保存失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n</script>\n[... 5309 more characters truncated]"}],"isError":false,"timestamp":1781220101873}}
{"type":"message","id":"2e95b56a","parentId":"83d161c4","timestamp":"2026-06-11T23:21:49.231Z","message":{"role":"assistant","content":[{"type":"text","text":"..."},{"type":"toolCall","id":"tool-a932970bc7da4a898c8b5c6bbf002149","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":26448,"output":34,"cacheRead":0,"cacheWrite":0,"totalTokens":26482,"cost":{"input":0.026448,"output":0.00010880000000000002,"cacheRead":0,"cacheWrite":0,"total":0.0265568}},"stopReason":"toolUse","timestamp":1781220101874,"responseId":"cht000d2ca7@dx19eb8fdcec7ba5b442"}}
{"type":"message","id":"beb3973d","parentId":"2e95b56a","timestamp":"2026-06-11T23:21:49.240Z","message":{"role":"toolResult","toolCallId":"tool-a932970bc7da4a898c8b5c6bbf002149","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\r\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\r\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\r\n                <div class=\"status-item\">\r\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\r\n                    <span id=\"deviceStatus\">未连接</span>\r\n                </div>\r\n            </div>\r\n            <div id=\"ptzControlArea\">\r\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志 -->\r\n                <div class=\"console-layout\">\r\n                    <!-- 左: 摇杆控制 -->\r\n                    <div class=\"console-left\">\r\n                        <!-- 指向控制 -->\r\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">🎯 指向控制</h3>\r\n                        <div class=\"ptz-controls\">\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\r\n                            <button class=\"ptz-btn center\">●</button>\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\r\n                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\r\n                        </div>\r\n                        <div class=\"ptz-speed\">\r\n                            <label>速度:</label>\r\n                            <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\r\n                            <span id=\"ptzSpeedVal\">50</span>\r\n                        </div>\r\n                        <div style=\"display:flex;gap:8px;align-items:center;justify-content:center;margin-top:8px\">\r\n                            <label style=\"font-size:12px;color:#8b949e\">码流:</label>\r\n                            <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\r\n                                <option value=\"1\">主码流</option>\r\n                                <option value=\"2\" selected>子码流</option>\r\n                                <option value=\"3\">第三码流</option>\r\n                            </select>\r\n                        </div>\r\n                        <div style=\"display:flex;gap:8px;justify-content:center;margin-top:12px\">\r\n                            <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\r\n                            <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\r\n                        </div>\r\n                        <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:12px\">\r\n                            Pan: -- | Tilt: -- | Zoom: --\r\n                        </div>\r\n                        <!-- 预置点 -->\r\n                        <h3 style=\"font-size:15px;color:#d29922;margin:20px 0 8px\">⭐ 预置点</h3>\r\n                        <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                            <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\r\n                                <option value=\"\">选择预置点</option>\r\n                            </select>\r\n                            <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\r\n                            <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存当前位置</button>\r\n                        </div>\r\n                        <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\r\n                        <!-- 跟踪控制 -->\r\n                        <h3 style=\"font-size:15px;color:#f0883e;margin:20px 0 8px\">🛤 跟踪控制</h3>\r\n                        <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:16px\">\r\n                            <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\r\n                            <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\r\n                            <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\r\n                            <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\r\n                        </div>\r\n                        <!-- 变焦/对焦 -->\r\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:20px 0 8px\">🔍 变焦/对焦</h3>\r\n                        <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:12px\">\r\n                            <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+ 焦距+</button>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍- 焦距-</button>\r\n                        </div>\r\n                        <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:12px\">\r\n                            <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">🔧- 前移</button>\r\n                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">🔧+ 后移</button>\r\n                            <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\r\n                                <option value=\"manual\">手动</option>\r\n                                <option value=\"auto\">自动</option>\r\n                                <option value=\"semiauto\">半自动</option>\r\n                            </select>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 中: 实时画面 + 媒体 -->\r\n                    <div class=\"console-center\">\r\n                        <!-- 实时画面 -->\r\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\r\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\r\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\r\n                        </div>\r\n                        <!-- 媒体操作 -->\r\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📷 媒体操作</h3>\r\n                        <div style=\"display:flex;flex-direction:column;gap:12px;margin-bottom:16px\">\r\n                            <!-- 截图 -->\r\n                            <div class=\"card\" style=\"text-align:center\">\r\n                                <div class=\"card-title\">截图</div>\r\n                                <p style=\"color:#8b949e;font-size:12px;margin:4px 0\">抓取当前帧</p>\r\n                                <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\r\n                                <div id=\"consoleSnapshotPreview\" style=\"margin-top:8px;display:none\">\r\n                                    <img id=\"consoleSnapshotImg\" style=\"width:100%;border-radius:6px\">\r\n                                </div>\r\n                            </div>\r\n                            <!-- 录像 -->\r\n                            <div class=\"card\" style=\"text-align:center\">\r\n                                <div class=\"card-title\">录像</div>\r\n                                <p style=\"color:#8b949e;font-size:12px;margin:4px 0\">开始/停止录像</p>\r\n                                <div class=\"btn-group\" style=\"justify-content:center\">\r\n                                    <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\r\n                                </div>\r\n                                <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;margin-top:6px\">未录像</div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- Live Stack 实时叠加 -->\r\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:20px 0 8px\">🌟 Live Stack</h3>\r\n                        <div class=\"card\" style=\"text-align:center\">\r\n                            <div class=\"card-title\">实时叠加</div>\r\n                            <p style=\"color:#8b949e;font-size:11px;margin:4px 0\">边采集边叠加，降噪增亮</p>\r\n                            <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\r\n                                <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\r\n                                <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\r\n                                <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\r\n                                <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\r\n                                <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\r\n                            </div>\r\n                            <div style=\"font-size:12px;color:#8b949e;margin-bottom:8px\">\r\n                                硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\r\n                            </div>\r\n                            <div class=\"btn-group\" style=\"justify-content:center\">\r\n                                <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\r\n                                <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\r\n                                <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\r\n                            </div>\r\n                            <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;margin-top:6px\">叠加: 关闭</div>\r\n                        </div>\r\n                        <!-- 画面调整 -->\r\n                        <h3 style=\"font-size:15px;color:#d29922;margin:20px 0 8px\">🎨 画面调整</h3>\r\n                        <div class=\"card\">\r\n                            <div class=\"form-group\" style=\"margin-bottom:8px\">\r\n                                <label style=\"font-size:12px\">亮度</label>\r\n                                <div style=\"display:flex;align-items:center;gap:4px\">\r\n                                    <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('brightness', -1)\">-</button>\r\n                                    <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"flex:1\" onchange=\"adjustImage('brightness', this.value)\">\r\n                                    <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('brightness', 1)\">+</button>\r\n                                </div>\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"margin-bottom:8px\">\r\n                                <label style=\"font-size:12px\">对比度</label>\r\n                                <div style=\"display:flex;align-items:center;gap:4px\">\r\n                                    <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('contrast', -1)\">-</button>\r\n                                    <input type=\"range\" id=\"consoleContrast\" min=\"0\" max=\"100\" value=\"50\" style=\"flex:1\" onchange=\"adjustImage('contrast', this.value)\">\r\n                                    <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('contrast', 1)\">+</button>\r\n                                </div>\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"margin-bottom:8px\">\r\n                                <label style=\"font-size:12px\">饱和度</label>\r\n                                <div style=\"display:flex;align-items:center;gap:4px\">\r\n                                    <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('saturation', -1)\">-</button>\r\n                                    <input type=\"range\" id=\"consoleSaturation\" min=\"0\" max=\"100\" value=\"50\" style=\"flex:1\" onchange=\"adjustImage('saturation', this.value)\">\r\n                                    <button class=\"btn btn-sm\" style=\"padding:2px 6px;font-size:10px\" onclick=\"adjustImageStep('saturation', 1)\">+</button>\r\n                                </div>\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"margin-bottom:8px\">\r\n                                <label style=\"font-size:12px\">PTZ 坐标显示</label>\r\n                                <div class=\"btn-group\">\r\n                                    <button class=\"btn btn-sm btn-primary\" id=\"btnPtzOsdOn\" onclick=\"togglePtzOsd(true)\">显示</button>\r\n                                    <button class=\"btn btn-sm btn-secondary\" id=\"btnPtzOsdOff\" onclick=\"togglePtzOsd(false)\">关闭</button>\r\n                                </div>\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"margin-bottom:0\">\r\n                                <label style=\"font-size:12px\">OSD 信息显示</label>\r\n                                <div class=\"btn-group\">\r\n                                    <button class=\"btn btn-sm btn-secondary\" id=\"btnInfoOsdOn\" onclick=\"toggleInfoOsd(true)\">显示</button>\r\n                                    <button class=\"btn btn-sm btn-primary\" id=\"btnInfoOsdOff\" onclick=\"toggleInfoOsd(false)\">关闭</button>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 右: 操作日志 -->\r\n                    <div class=\"console-right\">\r\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\r\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto\">\r\n                            <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\r[... 235 more characters truncated]"}],"isError":false,"timestamp":1781220109240}}
