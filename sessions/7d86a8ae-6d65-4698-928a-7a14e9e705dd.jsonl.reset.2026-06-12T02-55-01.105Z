{"type":"message","id":"6d8470cc","parentId":"3a0178f8","timestamp":"2026-06-12T01:59:17.752Z","message":{"role":"assistant","content":[{"type":"text","text":"API 成功返回 function.json 数据：\n- **shutter**: `min: \"1/30000\"`, `max: \"1/25\"`\n- **iris**: `min: 160`, `max: 2200`\n\n现在运行 E2E 测试验证："},{"type":"toolCall","id":"tool-c6a85be18a704d1f820a882322982e7d","name":"exec","arguments":{"command":"cd \"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\"; python -c \"\nfrom playwright.sync_api import sync_playwright\nimport time\n\nwith sync_playwright() as p:\n    browser = p.chromium.launch(headless=True)\n    page = browser.new_page()\n    page.goto('http://localhost:10280', timeout=30000)\n    page.wait_for_load_state('networkidle')\n    time.sleep(1)\n\n    # 切换到主控台\n    nav = page.locator('.nav-btn')\n    for i in range(nav.count()):\n        txt = nav.nth(i).text_content()\n        if '主控台' in txt or '控制台' in txt:\n            nav.nth(i).click()\n            break\n    time.sleep(1)\n\n    # 连接设备\n    page.evaluate('''\n        (async () => {\n            await fetch('/api/v1/devices/192.168.5.72/connect', {\n                method: 'POST',\n                headers: {'Content-Type': 'application/json'},\n                body: JSON.stringify({username:'admin',password:'Nftw1357',port:80})\n            });\n            window.connectedDevice = {ip:'192.168.5.72',online:true};\n            if (typeof loadDeviceImageParams === 'function') loadDeviceImageParams('192.168.5.72');\n        })()\n    ''')\n    time.sleep(4)\n\n    # 展开画面控制\n    img_sec = page.locator('#imageControlSection')\n    if img_sec.count() > 0 and 'collapsed' in img_sec.evaluate('el => el.className'):\n        img_sec.locator('.collapsible-header').click(force=True)\n        time.sleep(0.5)\n\n    # 读取所有下拉菜单\n    print('=== v5.42 画面控制下拉菜单 ===')\n    for label, sel in [('白平衡模式','#wbMode'),('快门速度','#shutterSpeed'),('光圈控制','#irisLevel')]:\n        el = page.locator(sel)\n        if el.count() > 0:\n            opts = el.locator('option').all_inner_texts()\n            val = el.evaluate('e => e.value')\n            print(f'{label}: 当前={val}, 选项={opts}')\n\n    page.screenshot(path='C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/v5.42_function.png')\n    print('截图已保存')\n    browser.close()\n\"","timeout":60}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":126008,"output":587,"cacheRead":0,"cacheWrite":0,"totalTokens":126595,"cost":{"input":0.12600799999999998,"output":0.0018784000000000001,"cacheRead":0,"cacheWrite":0,"total":0.12788639999999998}},"stopReason":"toolUse","timestamp":1781229535377,"responseId":"cht000db092@dx19eb98dc467ba5d322"}}
