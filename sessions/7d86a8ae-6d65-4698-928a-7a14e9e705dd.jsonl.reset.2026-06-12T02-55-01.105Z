l h3 { margin-bottom:16px; font-size:18px; }\r\n        .modal .btn-group { justify-content:flex-end; margin-top:20px; }\r\n        /* Loading spinner */\r\n        .spinner { display:inline-block; width:16px; height:16px; border:2px solid #30363d; border-top-color:#58a6ff; border-radius:50%; animation:spin 0.8s linear infinite; }\r\n        @keyframes spin { to { transform:rotate(360deg); } }\r\n        .loading { pointer-events:none; opacity:0.7; }\r\n        /* Device actions */\r\n        .actions { display:flex; gap:4px; flex-wrap:wrap; }\r\n        /* PTZ status panel */\r\n        .ptz-position { text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0; font-family:monospace; font-size:14px; }\r\n        .toolbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap; }\r\n        .toolbar-actions { display:flex; gap:8px; }\r\n        .device-info-panel { background:#0d1117; border-radius:8px; padding:16px; margin-top:12px; font-size:13px; }\r\n        .device-info-panel .info-row { display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid #21262d; }\r\n        .device-info-panel .info-row:last-child { border-bottom:none; }\r\n        .device-info-panel .info-label { color:#8b949e; }\r\n        .device-info-panel .info-value { color:#e0e6f0; font-family:monospace; }\r\n        @media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-center, .console-right { width:100% !important; } }\r\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\r\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\r\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; }\r\n        .console-center { flex:1; min-width:0; display:flex; flex-direction:column; }\r\n        .console-right { flex:0 0 25%; max-width:300px; display:flex; flex-direction:column; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"header\">\r\n        <div class=\"logo\">Astro<span>Hub</span></div>\r\n        <div class=\"status-bar\">\r\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wsDot\"></span><span id=\"wsStatus\">未连接</span></div>\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n            addDetectionLog('info', '开始一键检测: ' + deviceIp);\r\n            runDetectionStep();\r\n        }\r\n        function runDetectionStep() {\r\n            var state = detectionState;\r\n            if (!state.running) return;\r\n            var steps = [\r\n                { name: '功能检测', url: '/api/v1/advanced/function/run', key: 'function' },\r\n                { name: '限位检测', url: '/api/v1/advanced/limit/run', key: 'limit' },\r\n                { name: '速度检测', url: '/api/v1/advanced/speed/run', key: 'speed' }\r\n            ];\r\n            if (state.step >= steps.length) {\r\n                finishDetection();\r\n                return;\r\n            }\r\n            var stepInfo = steps[state.step];\r\n            var pct = Math.round(((state.step) / state.totalSteps) * 100);\r\n            document.getElementById('detectionProgressText').textContent = '步骤 ' + (state.step + 1) + '/' + state.totalSteps + ': ' + stepInfo.name;\r\n            document.getElementById('detectionProgressBar').style.width = pct + '%';\r\n            addDetectionLog('info', '▶ 运行 ' + stepInfo.name + '...');\r\n            apiPost(stepInfo.url, {\r\n                device_ip: state.deviceIp,\r\n                username: (state.device && state.device.username) || 'admin',\r\n                password: (state.device && state.device.password) || '',\r\n                port: (state.device && state.device.port) || 80\r\n            }).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    state.results[stepInfo.key] = resp.results || {};\r\n                    addDetectionLog('success', '✅ ' + stepInfo.name + ' 完成');\r\n                } else {\r\n                    addDetectionLog('error', '❌ ' + stepInfo.name + ' 失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n                state.step++;\r\n                var newPct = Math.round((state.step / state.totalSteps) * 100);\r\n                document.getElementById('detectionProgressBar').style.width = newPct + '%';\r\n                runDetectionStep();\r\n            }).catch(function(e) {\r\n                addDetectionLog('error', '❌ ' + stepInfo.name + ' 异常: ' + e.message);\r\n                state.step++;\r\n                runDetectionStep();\r\n            });\r\n        }\r\n        function finishDetection() {\r\n            var btn = document.getElementById('btnStartDetection');\r\n            btn.disabled = false;\r\n            btn.innerHTML = '▶ 开始检测（全部）';\r\n            document.getElementById('detectionProgressText').textContent = '检测完成！';\r\n            document.getElementById('detectionProgressBar').style.width = '100%';\r\n            document.getElementById('detectionProgressBar').className = 'progress-fill green';\r\n            var state = detectionState;\r\n            var completed = Object.keys(state.results).length;\r\n            addDetectionLog('info', '=== 检测完成: ' + completed + '/' + state.totalSteps + ' 项通过 ===');\r\n            // 显示完整结果\r\n            if (completed > 0) {\r\n                var allResults = {};\r\n                Object.keys(state.results).forEach(function(k) {\r\n                    Object.keys(state.results[k]).forEach(function(rk) { allResults[rk] = state.results[k][rk]; });\r\n                });\r\n                if (state.results.function) renderConnectFullResults(state.results.function, 'function');\r\n                if (state.results.limit) renderConnectFullResults(state.results.limit, 'limit');\r\n          