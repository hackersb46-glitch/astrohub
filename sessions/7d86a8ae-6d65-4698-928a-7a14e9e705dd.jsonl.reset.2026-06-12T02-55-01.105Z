   return {\"success\": True, \"data\": func_data}\n+2536                 except Exception:\n+2537                     continue\n+2538     \n+2539     return {\"success\": False, \"message\": \"未找到该设备的 function.json\", \"data\": None}\n+2540 \n+2541 \n 2508 @api_router.get(\"/ptz/{device_id}/image/whitebalance\", summary=\"获取白平衡设置\", tags=[\"Image\"])\n 2509 async def get_whitebalance(device_id: str) -> dict:\n 2510     \"\"\"获取设备白平衡当前设置。\"\"\"\n 2511     import xml.etree.ElementTree as ET\n      ...","firstChangedLine":2508},"isError":false,"timestamp":1781229341772}}
{"type":"message","id":"3a70d3ff","parentId":"639b586f","timestamp":"2026-06-12T01:55:50.146Z","message":{"role":"assistant","content":[{"type":"text","text":"现在修改前端 console.html，从 function.json 读取参数范围："},{"type":"toolCall","id":"tool-8d6ea3e5cc4a415ba6ea0bf3b2dd4418","name":"read","arguments":{"limit":30,"offset":308,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":120337,"output":59,"cacheRead":0,"cacheWrite":0,"totalTokens":120396,"cost":{"input":0.120337,"output":0.0001888,"cacheRead":0,"cacheWrite":0,"total":0.1205258}},"stopReason":"toolUse","timestamp":1781229341775,"responseId":"cht000d8f01@dx19eb98ad01cb958232"}}
{"type":"message","id":"b7b42415","parentId":"3a70d3ff","timestamp":"2026-06-12T01:55:50.157Z","message":{"role":"toolResult","toolCallId":"tool-8d6ea3e5cc4a415ba6ea0bf3b2dd4418","toolName":"read","content":[{"type":"text","text":"})();\n\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\n\n// 连接设备时加载图像参数（从设备实时读取）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 检查 apiGet 是否可用\n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined, cannot load image params');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // 加载 OSD 状态\n    loadOsdStatus(deviceIp);\n    \n    // 加载白平衡\n    loadWhiteBalance(deviceIp);\n\n[482 more lines in file. Use offset=338 to continue.]"}],"isError":false,"timestamp":1781229350157}}
{"type":"message","id":"59e0c9ce","parentId":"b7b42415","timestamp":"2026-06-12T01:57:02.567Z","message":{"role":"assistant","content":[{"type":"text","text":"修改 `loadDeviceImageParams`，先从 function.json 获取参数范围："},{"type":"toolCall","id":"tool-4122352714f14b0fa69d07a2ed26ff48","name":"edit","arguments":{"edits":[{"newText":"// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\nvar deviceFunctionData = null; // v5.42: 存储function.json数据\n\n// 连接设备时加载图像参数（从function.json读取范围，从ISAPI读取当前值）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 检查 apiGet 是否可用\n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined, cannot load image params');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // v5.42: 先加载 function.json 获取参数范围\n    apiGet('/api/v1/ptz/' + deviceIp + '/function').then(function(r) {\n        if (r && r.success && r.data) {\n            deviceFunctionData = r.data;\n            console.log('[IMAGE] function.json loaded:', r.data.functions);\n        }\n    }).catch(function(e) {\n        console.warn('[IMAGE] function.json load failed:', e);\n    });\n    \n    // 加载 OSD 状态\n    loadOsdStatus(deviceIp);\n    \n    // 加载白平衡\n    loadWhiteBalance(deviceIp);","oldText":"// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\n\n// 连接设备时加载图像参数（从设备实时读取）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 检查 apiGet 是否可用\n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined, cannot load image params');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // 加载 OSD 状态\n    loadOsdStatus(deviceIp);\n    \n    // 加载白平衡\n    loadWhiteBalance(deviceIp);"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":120598,"output":533,"cacheRead":0,"cacheWrite":0,"totalTokens":121131,"cost":{"input":0.120598,"output":0.0017056,"cacheRead":0,"cacheWrite":0,"total":0.1223036}},"stopReason":"toolUse","timestamp":1781229350160,"responseId":"cht000d9b71@dx19eb98bb801ba5d322"}}
