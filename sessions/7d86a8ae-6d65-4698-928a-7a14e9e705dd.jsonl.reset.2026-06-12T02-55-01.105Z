{"type":"message","id":"c6e06909","parentId":"21cd83c5","timestamp":"2026-06-11T23:24:39.410Z","message":{"role":"toolResult","toolCallId":"call_aa0a0cef8d07441fb1abd51e","toolName":"read","content":[{"type":"text","text":"        function connectFuncDetectRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectFuncRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 探测中...';\r\n            document.getElementById('connectFuncProgress').style.display = 'block';\r\n            document.getElementById('connectFuncResultMini').innerHTML = '';\r\n            addLog('info', '功能检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/function/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '功能检测完成');\r\n                    addLog('success', '功能检测完成: ' + (resp.message || ''));\r\n                    renderConnectFuncResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'function');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '探测失败');\r\n                    addLog('error', '功能检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectFuncResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '探测失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                showToast('error', '探测异常: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectFuncDetectRun\r\n        }\r\n        function renderConnectFuncResultMini(results) {\r\n            var area = document.getElementById('connectFuncResultMini');\r\n            var keys = Object.keys(results);\r\n            var supported = 0, total = keys.length;\r\n            keys.forEach(function(k) { if (results[k] && results[k].supported) supported++; });\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#3fb950\">✅ 支持 ' + supported + '/' + total + ' 项功能</span>';\r\n        }\r\n        // 限位检测（连接设备页面版）\r\n        function connectLimitTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectLimitRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('connectLimitProgress').style.display = 'block';\r\n            document.getElementById('connectLimitResultMini').innerHTML = '';\r\n            addLog('info', '限位检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/limit/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '限位检测完成');\r\n                    addLog('success', '限位检测完成: ' + (resp.message || ''));\r\n                    renderConnectLimitResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'limit');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '限位检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectLimitResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '测试失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectLimitTestRun\r\n        }\r\n        function renderConnectLimitResultMini(results) {\r\n            var area = document.getElementById('connectLimitResultMini');\r\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#d29922\">P: ' + pLimit[0] + '~' + pLimit[1] + ' | T: ' + tLimit[0] + '~' + tLimit[1] + '</span>';\r\n        }\r\n        // 速度检测（连接设备页面版）\r\n        function connectSpeedTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('connectSpeedProgress').style.display = 'block';\r\n            document.getElementById('connectSpeedResultMini').innerHTML = '';\r\n            addLog('info', '速度检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectSpeedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '速度检测完成');\r\n                    addLog('success', '速度检测完成: ' + (resp.message || ''));\r\n                    renderConnectSpeedResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'speed');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '速度检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectSpeedResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '测试失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectSpeedProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectSpeedTestRun (was hardcoded: 速度档位 1, 50, 100)\r\n        }\r\n        function renderConnectSpeedResultMini(results) {\r\n            var area = document.getElementById('connectSpeedResultMini');\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            var count = Object.keys(speedMap).length;\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#f0883e\">✅ 已测试 ' + count + ' 个速度档位</span>';\r\n        }\r\n        // 一键检测（全部）\r\n        var detectionState = { running: false, step: 0, totalSteps: 3, results: {} };\r\n        function startDetection() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnStartDetection');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 检测中...';\r\n            document.getElementById('detectionProgress').style.display = 'block';\r\n            document.getElementById('detectionLog').innerHTML = '';\r\n            detectionState = { running: true, step: 0, totalSteps: 3, results: {}, deviceIp: deviceIp, device: device };\r\n            addDetectionLog('info', '开始一键检测: ' + deviceIp);\r\n            runDetectionStep();\r\n        }\r\n        function runDetectionStep() {\r\n            var state = detectionState;\r\n            if (!state.running) return;\r\n            var steps = [\r\n                { name: '功能检测', url: '/api/v1/advanced/function/run', key: 'function' },\r\n                { name: '限位检测', url: '/api/v1/advanced/limit/run', key: 'limit' },\r\n                { name: '速度检测', url: '/api/v1/advanced/speed/run', key: 'speed' }\r\n            ];\r\n            if (state.step >= steps.length) {\r\n                finishDetection();\r\n                return;\r\n            }\r\n            var stepInfo = steps[state.step];\r\n            var pct = Math.round(((state.step) / state.totalSteps) * 100);\r\n            document.getElementById('detectionProgressText').textContent = '步骤 ' + (state.step + 1) + '/' + state.totalSteps + ': ' + stepInfo.name;\r\n            document.getElementById('detectionProgressBar').style.width = pct + '%';\r\n            addDetectionLog('info', '▶ 运行 ' + stepInfo.name + '...');\r\n            apiPost(stepInfo.url, {\r\n                device_ip: state.deviceIp,\r\n                username: (state.device && state.device.username) || 'admin',\r\n                password: (state.device && state.device.password) || '',\r\n                port: (state.device && state.device.port) || 80\r\n            }).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    state.results[stepInfo.key] = resp.results || {};\r\n                    addDetectionLog('success', '✅ ' + stepInfo.name + ' 完成');\r\n                } else {\r\n                    addDetectionLog('error', '❌ ' + stepInfo.name + ' 失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n                state.step++;\r\n                var newPct = Math.round((state.step / state.totalSteps) * 100);\r\n                document.getElementById('detectionProgressBar').style.width = newPct + '%';\r\n                runDetectionStep();\r\n            }).catch(function(e) {\r\n                addDetectionLog('error', '❌ ' + stepInfo.name + ' 异常: ' + e.message);\r\n                state.step++;\r\n                runDetectionStep();\r\n            });\r\n        }\r\n        function finishDetection() {\r\n            var btn = document.getElementById('btnStartDetection');\r\n            btn.disabled = false;\r\n            btn.innerHTML = '▶ 开始检测（全部）';\r\n   