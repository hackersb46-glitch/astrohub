{"type":"message","id":"38f6c571","parentId":"fb9941df","timestamp":"2026-06-12T02:11:53.941Z","message":{"role":"assistant","content":[{"type":"text","text":"添加新的开关切换函数："},{"type":"toolCall","id":"call_3a3f91ab14fa4b76a7e04b6c","name":"edit","arguments":{"edits":[{"newText":"function toggleInfoOsd(enabled) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    updateInfoOsdButtons(enabled);\n    localStorage.setItem('osd_info_' + dev, enabled ? '1' : '0');\n    \n    apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'Info OSD: ' + (enabled ? '显示' : '关闭'));\n        });\n}\n\n// v5.42: 开关式 OSD 切换\nvar ptzOsdEnabled = false;\nvar infoOsdEnabled = false;\n\nfunction togglePtzOsdToggle() {\n    ptzOsdEnabled = !ptzOsdEnabled;\n    var btn = document.getElementById('btnPtzOsd');\n    if (btn) {\n        btn.textContent = ptzOsdEnabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (ptzOsdEnabled ? 'btn-primary' : 'btn-secondary');\n    }\n    togglePtzOsd(ptzOsdEnabled);\n}\n\nfunction toggleInfoOsdToggle() {\n    infoOsdEnabled = !infoOsdEnabled;\n    var btn = document.getElementById('btnInfoOsd');\n    if (btn) {\n        btn.textContent = infoOsdEnabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (infoOsdEnabled ? 'btn-primary' : 'btn-secondary');\n    }\n    toggleInfoOsd(infoOsdEnabled);\n}\n\n// 更新按钮状态\nfunction updatePtzOsdButtons(enabled) {\n    ptzOsdEnabled = enabled;\n    var btn = document.getElementById('btnPtzOsd');\n    if (btn) {\n        btn.textContent = enabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (enabled ? 'btn-primary' : 'btn-secondary');\n    }\n}\n\nfunction updateInfoOsdButtons(enabled) {\n    infoOsdEnabled = enabled;\n    var btn = document.getElementById('btnInfoOsd');\n    if (btn) {\n        btn.textContent = enabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (enabled ? 'btn-primary' : 'btn-secondary');\n    }\n}","oldText":"function toggleInfoOsd(enabled) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    updateInfoOsdButtons(enabled);\n    localStorage.setItem('osd_info_' + dev, enabled ? '1' : '0');\n    \n    apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'Info OSD: ' + (enabled ? '显示' : '关闭'));\n        });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":143035,"output":768,"cacheRead":0,"cacheWrite":0,"totalTokens":143803,"cost":{"input":0.143035,"output":0.0024576000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1454926}},"stopReason":"toolUse","timestamp":1781230292557,"responseId":"cht000d0445@dx19eb9995668b85f582"}}
