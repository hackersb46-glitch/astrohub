{"type":"message","id":"dd048428","parentId":"2e5d4b4a","timestamp":"2026-06-12T01:57:09.631Z","message":{"role":"toolResult","toolCallId":"tool-115ac19e014f4e2b8363611484476eeb","toolName":"read","content":[{"type":"text","text":"        if (r && r.success && r.data) {\n            var sh = r.data;\n            deviceImageParams.shutter = sh;\n            \n            var shutterSelect = document.getElementById('shutterSpeed');\n            if (shutterSelect) {\n                shutterSelect.innerHTML = '';\n                \n                // 自动选项\n                var autoOpt = document.createElement('option');\n                autoOpt.value = 'auto';\n                autoOpt.textContent = '自动';\n                if (sh.mode === 'auto') autoOpt.selected = true;\n                shutterSelect.appendChild(autoOpt);\n                \n                // 设备支持的快门值\n                var levels = sh.supported_levels || [];\n                levels.forEach(function(l) {\n                    var opt = document.createElement('option');\n                    opt.value = l;\n                    opt.textContent = l;\n                    if (l === sh.current_level) opt.selected = true;\n                    shutterSelect.appendChild(opt);\n                });\n                \n                // 如果没有返回支持值，添加常用值\n                if (levels.length === 0) {\n                    var presets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000'];\n                    presets.forEach(function(p) {\n                        var opt = document.createElement('option');\n                        opt.value = p;\n                        opt.textContent = p;\n                        shutterSelect.appendChild(opt);\n                    });\n                }\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Shutter] Load failed:', e);\n        // 设置默认选项\n\n[261 more lines in file. Use offset=570 to continue.]"}],"isError":false,"timestamp":1781229429631}}
