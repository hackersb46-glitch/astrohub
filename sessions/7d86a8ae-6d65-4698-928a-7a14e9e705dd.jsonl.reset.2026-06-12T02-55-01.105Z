{"type":"message","id":"48f18976","parentId":"3bb441d0","timestamp":"2026-06-11T23:29:48.615Z","message":{"role":"toolResult","toolCallId":"call_3b21c07b6da54c1491e06570","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">未连接</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\n                <div class=\"console-layout\">\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\n                    <div class=\"console-left\">\n                        <!-- PTZ控制（折叠） -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- 指向控制 -->\n                                <div class=\"section-subtitle\">指向</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\n                                    <button class=\"ptz-btn center\">●</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>速度:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                                    <span id=\"ptzSpeedVal\">50</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- 预置点 -->\n                                <div class=\"section-subtitle\">预置点</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">选择预置点</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- 变焦/对焦 -->\n                                <div class=\"section-subtitle\">变焦/对焦</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">近</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">远</button>\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                                        <option value=\"manual\">手动</option>\n                                        <option value=\"auto\">自动</option>\n                                        <option value=\"semiauto\">半自动</option>\n                                    </select>\n                                </div>\n                                <!-- 码流选择 -->\n                                <div class=\"section-subtitle\">码流</div>\n                                <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\n                                    <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                                        <option value=\"1\">主码流</option>\n                                        <option value=\"2\" selected>子码流</option>\n                                        <option value=\"3\">第三码流</option>\n                                    </select>\n                                </div>\n                            </div>\n                        </div>\n                        <!-- 跟踪控制 -->\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 中: 实时画面 + 媒体操作 -->\n                    <div class=\"console-center\">\n                        <!-- 实时画面 -->\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                        </div>\n                        <!-- 媒体操作（折叠，整合Live Stack） -->\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\n                                    <!-- 截图/录像 -->\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                                    </div>\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\n                                    <!-- Live Stack -->\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\n                                    </div>\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\n                                    </div>\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n        {val: 200, label: 'F2.0'},\n        {val: 280, label: 'F2.8'},\n        {val: 400, label: 'F4.0'},\n        {val: 560, label: 'F5.6'},\n        {val: 800, label: 'F8.0'},\n        {val: 1100, label: 'F11'},\n        {val: 1600, label: 'F16'},\n        {val: 2200, label: 'F22'}\n    ];\n    var html = '<option value=\"\">-- 选择 --</option>';\n    fValues.forEach(function(f) {\n        if (f.val >= min && f.val <= max) {\n            html += '<option value=\"' + f.val + '\">' + f.label + '</option>';\n        }\n    });\n    return html;\n}\n\n// 扩展图像调节（带范围）\nfunction adjustImageEx(param, value) {\n    adjustImage(param, value);\n}\n\n// 白平衡模式\nfunction setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) { showToast('warning', '请先选择设备'); return; }\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '白平衡模式: ' + mode);\n            else showToast('error', r ? r.message : '设置失败');\n        }).catch(function(e) { showToast('error', '设置异常: ' + e.message); });\n}\n\n// 白平衡 R/B\nfunction setWhiteBalanceRB(channel, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // 更新显示\n    if (channel === 'red') {\n        document.getElementById('wbRedVal').textContent = value;\n    } else {\n        document.getElementById('wbBlueVal').textContent = value;\n    }\n    \n    // 发送请求\n    var body = {};\n    body['wb_' + channel] = parseInt(value);\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', body)\n        .then(function(r) {\n            if (r && r.success) {\n                // 静默成功\n            }\n        }).catch(function(e) {});\n}\n\n// 降噪\nfunction setDNR(type, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    var body = {};\n    body['dnr_' + type] = parseInt(value);\n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', body)\n        .then(function(r) {\n            if (r && r.success) {\n                // 静默成功\n            }\n        }).catch(function(e) {});\n}\n\n// 快门\nfunction setShutter(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    if (value === 'auto') {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { auto: true })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: 自动');\n            }).catch(function(e) {});\n    } else {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: ' + value);\n                else showToast('error', r ? r.message : '设置失败');\n            }).catch(function(e) { showToast('error', '设置异常: ' + e.message); });\n    }\n}\n\n// 曝光时间\nfunction setExposureTime(value) {\n    if (!value) return;\n    setShutter(value);\n}\n\n// 光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                // 找到对应的 F 值显示\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            } else {\n                showToast('error', r ? r.message : '设置失败');\n            }\n        }).catch(function(e) { showToast('error', '设置异常: ' + e.message); });\n}\n\n// 暴露到全局\nwindow.toggleSection = toggleSection;\nwindow.loadDeviceFunctions = loadDeviceFunctions;\nwindow.adjustImageEx = adjustImageEx;\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\nwindow.setWhiteBalanceRB = setWhiteBalanceRB;\nwindow.setDNR = setDNR;\nwindow.setShutter = setShutter;\nwindow.setExposureTime = setExposureTime;\nwindow.setIris = setIris;\n</script>\n[... 15686 more characters truncated]"}],"isError":false,"timestamp":1781220588615}}
{"type":"message","id":"8a14727e","parentId":"48f18976","timestamp":"2026-06-11T23:32:03.872Z","message":{"role":"assistant","content":[{"type":"text","text":"现在我需要重写 `console.html`，修复以下问题：\n\n1. **PTZ OSD显示** - 记住上一次设置，需要读取实际状态\n2. **白平衡、快门、曝光、光圈** - 下拉菜单没有实际数值（需要从设备实时读取）\n3. **白平衡R/B、降噪** - 滑动条无效果（API 调用错误）\n4. **码流** - 移动到媒体操作中"},{"type":"toolCall","id":"tool-442a650c5ee84f3c9e61bc6a3e779595","name":"write","arguments":{"content":"        <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">未连接</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\n                <div class=\"console-layout\">\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\n                    <div class=\"console-left\">\n                        <!-- PTZ控制（折叠） -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- 指向控制 -->\n                                <div class=\"section-subtitle\">指向</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\n                                    <button class=\"ptz-btn center\">●</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>速度:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                                    <span id=\"ptzSpeedVal\">50</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- 预置点 -->\n                                <div class=\"section-subtitle\">预置点</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">选择预置点</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- 变焦/对焦 -->\n                                <div class=\"section-subtitle\">变焦/对焦</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">近</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">远</button>\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                                        <option value=\"manual\">手动</option>\n                                        <option value=\"auto\">自动</option>\n                                        <option value=\"semiauto\">半自动</option>\n                                    </select>\n                                </div>\n                            </div>\n                        </div>\n                        <!-- 跟踪控制 -->\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 中: 实时画面 + 媒体操作 -->\n                    <div class=\"console-center\">\n                        <!-- 实时画面 -->\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                        </div>\n                        <!-- 媒体操作（折叠，整合Live Stack + 码流） -->\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\n                                    <!-- 码流选择 -->\n                                    <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\n                                        <span style=\"color:#8b949e;font-size:13px\">码流:</span>\n                                        <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                                            <option value=\"1\">主码流</option>\n                                            <option value=\"2\" selected>子码流</option>\n                                            <option value=\"3\">第三码流</option>\n                                        </select>\n                                    </div>\n                                    <!-- 截图/录像 -->\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                                    </div>\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\n                                    <!-- Live Stack -->\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\n                                    </div>\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\n                                    </div>\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\n                                        <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\n                                    </div>\n                                    <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">叠加: 关闭</div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 右: 操作日志 + 画面控制 -->\n                    <div class=\"console-right\">\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto;max-height:200px\">\n                            <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\n                                <div style=\"color:#6e7681\">等待连接...</div>\n                            </div>\n                        </div>\n                        <!-- 画面控制（折叠，移到右侧） -->\n                        <div class=\"collapsible-section collapsed\" id=\"imageControlSection\" style=\"margin-top:12px\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('imageControlSection')\">\n                                <h3 style=\"font-size:15px;color:#d29922;margin:0\">🎨 画面控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div class=\"card\">\n                                    <!-- 基础调节 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">亮度</label>\n                                        <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('brightness', this.value)\">\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">对比度</label>\n                                        <input type=\"range\" id=\"consoleContrast\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('contrast', this.value)\">\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">饱和度</label>\n                                        <input type=\"range\" id=\"consoleSaturation\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('saturation', this.value)\">\n                                    </div>\n                                    <!-- 锐度 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">锐度 <span id=\"sharpnessRange\" style=\"color:#6e7681\"></span></label>\n                                        <input type=\"range\" id=\"consoleSharpness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setSharpness(this.value)\">\n                                    </div>\n                                    <!-- 白平衡 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">白平衡模式</label>\n                                        <select id=\"wbMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setWhiteBalanceMode(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <div style=\"display:flex;gap:8px;margin-bottom:8px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#f85149\">R <span id=\"wbRedVal\">--</span></label>\n                                            <input type=\"range\" id=\"wbRed\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" onchange=\"setWhiteBalanceGain('red', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#58a6ff\">B <span id=\"wbBlueVal\">--</span></label>\n                                            <input type=\"range\" id=\"wbBlue\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" onchange=\"setWhiteBalanceGain('blue', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 降噪 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:8px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">空域降噪 <span id=\"dnrSpatialVal\">--</span></label>\n                                            <input type=\"range\" id=\"dnrSpatial\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setNoiseReduce('spatial', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">时域降噪 <span id=\"dnrTemporalVal\">--</span></label>\n                                            <input type=\"range\" id=\"dnrTemporal\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setNoiseReduce('temporal', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 快门 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">快门速度</label>\n                                        <select id=\"shutterSpeed\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setShutterSpeed(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- 光圈 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">光圈控制</label>\n                                        <select id=\"irisLevel\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setIris(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- OSD 控制 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\n                                        <label style=\"font-size:12px\">PTZ 坐标显示</label>\n                                        <div class=\"btn-group\">\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnPtzOsdOn\" onclick=\"togglePtzOsd(true)\">显示</button>\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnPtzOsdOff\" onclick=\"togglePtzOsd(false)\">关闭</button>\n                                        </div>\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:0\">\n                                        <label style=\"font-size:12px\">OSD 信息显示</label>\n                                        <div class=\"btn-group\">\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnInfoOsdOn\" onclick=\"toggleInfoOsd(true)\">显示</button>\n                                            <button class=\"btn btn-sm btn-secondary\" id=\"btnInfoOsdOff\" onclick=\"toggleInfoOsd(false)\">关闭</button>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n<style>\n/* 折叠面板样式 */\n.collapsible-section {\n    background: #161b22;\n    border: 1px solid #21262d;\n    border-radius: 8px;\n    margin-bottom: 12px;\n    overflow: hidden;\n}\n.collapsible-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 10px 12px;\n    cursor: pointer;\n    background: #0d1117;\n    transition: background 0.2s;\n}\n.collapsible-header:hover {\n    background: #161b22;\n}\n.collapse-icon {\n    color: #8b949e;\n    font-size: 12px;\n    transition: transform 0.2s;\n}\n.collapsible-section.collapsed .collapse-icon {\n    transform: rotate(-90deg);\n}\n.collapsible-content {\n    padding: 12px;\n    max-height: 1000px;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out, padding 0.3s;\n}\n.collapsible-section.collapsed .collapsible-content {\n    max-height: 0;\n    padding: 0 12px;\n}\n.section-subtitle {\n    font-size: 12px;\n    color: #6e7681;\n    margin: 8px 0 4px;\n    padding-top: 8px;\n    border-top: 1px solid #21262d;\n}\n.section-subtitle:first-child {\n    border-top: none;\n    padding-top: 0;\n}\n</style>\n\n<script>\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\n\n// 连接设备时加载图像参数（从设备实时读取）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // 加载 OSD 状态\n    loadOsdStatus(deviceIp);\n    \n    // 加载白平衡\n    loadWhiteBalance(deviceIp);\n    \n    // 加载降噪\n    loadNoiseReduce(deviceIp);\n    \n    // 加载快门\n    loadShutter(deviceIp);\n    \n    // 加载光圈\n    loadIris(deviceIp);\n    \n    // 加载锐度\n    loadSharpness(deviceIp);\n    \n    // 加载亮度/对比度/饱和度\n    loadColorParams(deviceIp);\n}\n\n// 加载 OSD 状态\nfunction loadOsdStatus(deviceIp) {\n    // PTZ OSD\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/ptz').then(function(r) {\n        if (r && r.success) {\n            var enabled = r.enabled || r.data?.enabled || false;\n            updatePtzOsdButtons(enabled);\n            // 保存到 localStorage\n            localStorage.setItem('osd_ptz_' + deviceIp, enabled ? '1' : '0');\n        } else {\n            // 从 localStorage 读取上次设置\n            var saved = localStorage.getItem('osd_ptz_' + deviceIp);\n            if (saved !== null) {\n                updatePtzOsdButtons(saved === '1');\n            }\n        }\n    }).catch(function(e) {\n        var saved = localStorage.getItem('osd_ptz_' + deviceIp);\n        if (saved !== null) {\n            updatePtzOsdButtons(saved === '1');\n        }\n    });\n    \n    // Info OSD\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/info').then(function(r) {\n        if (r && r.success) {\n            var enabled = r.enabled || r.data?.enabled || false;\n            updateInfoOsdButtons(enabled);\n            localStorage.setItem('osd_info_' + deviceIp, enabled ? '1' : '0');\n        } else {\n            var saved = localStorage.getItem('osd_info_' + deviceIp);\n            if (saved !== null) {\n                updateInfoOsdButtons(saved === '1');\n            }\n        }\n    }).catch(function(e) {\n        var saved = localStorage.getItem('osd_info_' + deviceIp);\n        if (saved !== null) {\n            updateInfoOsdButtons(saved === '1');\n        }\n    });\n}\n\nfunction updatePtzOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnPtzOsdOn');\n    var btnOff = document.getElementById('btnPtzOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n}\n\nfunction updateInfoOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnInfoOsdOn');\n    var btnOff = document.getElementById('btnInfoOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n}\n\n// 加载白平衡\nfunction loadWhiteBalance(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/whitebalance').then(function(r) {\n        if (r && r.success && r.data) {\n            var wb = r.data;\n            deviceImageParams.whiteBalance = wb;\n            \n            // 更新模式下拉\n            var wbModeSelect = document.getElementById('wbMode');\n            if (wbModeSelect) {\n                // 清空并填充设备实际支持的模式\n                wbModeSelect.innerHTML = '';\n                var modes = wb.supported_modes || ['manual', 'auto'];\n                modes.forEach(function(m) {\n                    var opt = document.createElement('option');\n                    opt.value = m;\n                    opt.textContent = m === 'manual' ? '手动' : (m === 'auto' ? '自动' : m);\n                    if (m === wb.mode) opt.selected = true;\n                    wbModeSelect.appendChild(opt);\n                });\n            }\n            \n            // 更新 R/B 滑动条\n            var wbRed = document.getElementById('wbRed');\n            var wbBlue = document.getElementById('wbBlue');\n            var wbRedVal = document.getElementById('wbRedVal');\n            var wbBlueVal = document.getElementById('wbBlueVal');\n            \n            if (wbRed && wb.red_gain !== undefined) {\n                wbRed.value = wb.red_gain;\n                if (wbRedVal) wbRedVal.textContent = wb.red_gain;\n            }\n            if (wbBlue && wb.blue_gain !== undefined) {\n                wbBlue.value = wb.blue_gain;\n                if (wbBlueVal) wbBlueVal.textContent = wb.blue_gain;\n            }\n            \n            // 设置范围\n            if (wb.min !== undefined && wb.max !== undefined) {\n                if (wbRed) { wbRed.min = wb.min; wbRed.max = wb.max; }\n                if (wbBlue) { wbBlue.min = wb.min; wbBlue.max = wb.max; }\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[WB] Load failed:', e);\n    });\n}\n\n// 加载降噪\nfunction loadNoiseReduce(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/noisereduce').then(function(r) {\n        if (r && r.success && r.data) {\n            var nr = r.data;\n            deviceImageParams.noiseReduce = nr;\n            \n            var dnrSpatial = document.getElementById('dnrSpatial');\n            var dnrTemporal = document.getElementById('dnrTemporal');\n            var dnrSpatialVal = document.getElementById('dnrSpatialVal');\n            var dnrTemporalVal = document.getElementById('dnrTemporalVal');\n            \n            if (dnrSpatial && nr.spatial_level !== undefined) {\n                dnrSpatial.value = nr.spatial_level;\n                if (dnrSpatialVal) dnrSpatialVal.textContent = nr.spatial_level;\n            }\n            if (dnrTemporal && nr.temporal_level !== undefined) {\n                dnrTemporal.value = nr.temporal_level;\n                if (dnrTemporalVal) dnrTemporalVal.textContent = nr.temporal_level;\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[DNR] Load failed:', e);\n    });\n}\n\n// 加载快门\nfunction loadShutter(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/shutter').then(function(r) {\n        if (r && r.success && r.data) {\n            var sh = r.data;\n            deviceImageParams.shutter = sh;\n            \n            var shutterSelect = document.getElementById('shutterSpeed');\n            if (shutterSelect) {\n                shutterSelect.innerHTML = '';\n                \n                // 自动选项\n                var autoOpt = document.createElement('option');\n                autoOpt.value = 'auto';\n                autoOpt.textContent = '自动';\n                if (sh.mode === 'auto') autoOpt.selected = true;\n                shutterSelect.appendChild(autoOpt);\n                \n                // 设备支持的快门值\n                var levels = sh.supported_levels || [];\n                levels.forEach(function(l) {\n                    var opt = document.createElement('option');\n                    opt.value = l;\n                    opt.textContent = l;\n                    if (l === sh.current_level) opt.selected = true;\n                    shutterSelect.appendChild(opt);\n                });\n                \n                // 如果没有返回支持值，添加常用值\n                if (levels.length === 0) {\n                    var presets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000'];\n                    presets.forEach(function(p) {\n                        var opt = document.createElement('option');\n                        opt.value = p;\n                        opt.textContent = p;\n                        shutterSelect.appendChild(opt);\n                    });\n                }\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Shutter] Load failed:', e);\n        // 设置默认选项\n        var shutterSelect = document.getElementById('shutterSpeed');\n        if (shutterSelect) {\n            shutterSelect.innerHTML = '<option value=\"auto\">自动</option>';\n            var presets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000'];\n            presets.forEach(function(p) {\n                shutterSelect.innerHTML += '<option value=\"' + p + '\">' + p + '</option>';\n            });\n        }\n    });\n}\n\n// 加载光圈\nfunction loadIris(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\n        if (r && r.success && r.data) {\n            var ir = r.data;\n            deviceImageParams.iris = ir;\n            \n            var irisSelect = document.getElementById('irisLevel');\n            if (irisSelect) {\n                irisSelect.innerHTML = '<option value=\"\">-- 选择 --</option>';\n                \n                // F 值映射\n                var fValues = [\n                    {val: 160, label: 'F1.6'},\n                    {val: 200, label: 'F2.0'},\n                    {val: 280, label: 'F2.8'},\n                    {val: 400, label: 'F4.0'},\n                    {val: 560, label: 'F5.6'},\n                    {val: 800, label: 'F8.0'},\n                    {val: 1100, label: 'F11'},\n                    {val: 1600, label: 'F16'},\n                    {val: 2200, label: 'F22'}\n                ];\n                \n                var min = ir.min || 160;\n                var max = ir.max || 2200;\n                var current = ir.current_level || 160;\n                \n                fValues.forEach(function(f) {\n                    if (f.val >= min && f.val <= max) {\n                        var opt = document.createElement('option');\n                        opt.value = f.val;\n                        opt.textContent = f.label;\n                        if (f.val === current) opt.selected = true;\n                        irisSelect.appendChild(opt);\n                    }\n                });\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Iris] Load failed:', e);\n        // 设置默认选项\n        var irisSelect = document.getElementById('irisLevel');\n        if (irisSelect) {\n            irisSelect.innerHTML = '<option value=\"\">-- 选择 --</option>';\n            var fValues = ['F1.6', 'F2.0', 'F2.8', 'F4.0', 'F5.6', 'F8.0', 'F11', 'F16', 'F22'];\n            fValues.forEach(function(f) {\n                irisSelect.innerHTML += '<option value=\"' + f + '\">' + f + '</option>';\n            });\n        }\n    });\n}\n\n// 加载锐度\nfunction loadSharpness(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/sharpness').then(function(r) {\n        if (r && r.success && r.data) {\n            var sp = r.data;\n            deviceImageParams.sharpness = sp;\n            \n            var slider = document.getElementById('consoleSharpness');\n            var range = document.getElementById('sharpnessRange');\n            \n            if (slider) {\n                slider.min = sp.min || 0;\n                slider.max = sp.max || 100;\n                slider.value = sp.current_level || 50;\n            }\n            if (range) {\n                range.textContent = '(' + (sp.min || 0) + '~' + (sp.max || 100) + ')';\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Sharpness] Load failed:', e);\n    });\n}\n\n// 加载亮度/对比度/饱和度\nfunction loadColorParams(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/color').then(function(r) {\n        if (r && r.success && r.data) {\n            var c = r.data;\n            deviceImageParams.color = c;\n            \n            var brightness = document.getElementById('consoleBrightness');\n            var contrast = document.getElementById('consoleContrast');\n            var saturation = document.getElementById('consoleSaturation');\n            \n            if (brightness && c.brightness !== undefined) brightness.value = c.brightness;\n            if (contrast && c.contrast !== undefined) contrast.value = c.contrast;\n            if (saturation && c.saturation !== undefined) saturation.value = c.saturation;\n        }\n    }).catch(function(e) {\n        console.warn('[Color] Load failed:', e);\n    });\n}\n\n// ==================== 设置函数 ====================\n\n// 设置锐度\nfunction setSharpness(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/sharpness', { level: parseInt(value) });\n}\n\n// 设置白平衡模式\nfunction setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '白平衡: ' + mode);\n        });\n}\n\n// 设置白平衡增益 R/B\nfunction setWhiteBalanceGain(channel, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // 更新显示\n    if (channel === 'red') {\n        var el = document.getElementById('wbRedVal');\n        if (el) el.textContent = value;\n    } else {\n        var el = document.getElementById('wbBlueVal');\n        if (el) el.textContent = value;\n    }\n    \n    // 发送请求\n    var key = channel === 'red' ? 'red_gain' : 'blue_gain';\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) });\n}\n\n// 设置降噪\nfunction setNoiseReduce(type, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // 更新显示\n    var el = document.getElementById(type === 'spatial' ? 'dnrSpatialVal' : 'dnrTemporalVal');\n    if (el) el.textContent = value;\n    \n    // 发送请求\n    var key = type === 'spatial' ? 'spatial_level' : 'temporal_level';\n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', { [key]: parseInt(value) });\n}\n\n// 设置快门\nfunction setShutterSpeed(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    if (value === 'auto') {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { mode: 'auto' });\n    } else {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: ' + value);\n            });\n    }\n}\n\n// 设置光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev || !value) return;\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            }\n        });\n}\n\n// 切换 PTZ OSD\nfunction togglePtzOsd(enabled) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    updatePtzOsdButtons(enabled);\n    localStorage.setItem('osd_ptz_' + dev, enabled ? '1' : '0');\n    \n    apiPost('/api/v1/ptz/' + dev + '/osd/ptz', { enabled: enabled })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'PTZ OSD: ' + (enabled ? '显示' : '关闭'));\n        });\n}\n\n// 切换 Info OSD\nfunction toggleInfoOsd(enabled) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    updateInfoOsdButtons(enabled);\n    localStorage.setItem('osd_info_' + dev, enabled ? '1' : '0');\n    \n    apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'Info OSD: ' + (enabled ? '显示' : '关闭'));\n        });\n}\n\n// ==================== 暴露到全局 ====================\nwindow.toggleSection = toggleSection;\nwindow.loadDeviceImageParams = loadDeviceImageParams;\nwindow.setSharpness = setSharpness;\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\nwindow.setWhiteBalanceGain = setWhiteBalanceGain;\nwindow.setNoiseReduce = setNoiseReduce;\nwindow.setShutterSpeed = setShutterSpeed;\nwindow.setIris = setIris;\nwindow.togglePtzOsd = togglePtzOsd;\nwindow.toggleInfoOsd = toggleInfoOsd;\nwindow.updatePtzOsdButtons = updatePtzOsdButtons;\nwindow.updateInfoOsdButtons = updateInfoOsdButtons;\n</script>","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":69908,"output":8818,"cacheRead":0,"cacheWrite":0,"totalTokens":78726,"cost":{"input":0.069908,"output":0.028217600000000002,"cacheRead":0,"cacheWrite":0,"total":0.09812560000000001}},"stopReason":"toolUse","timestamp":1781220588616,"responseId":"cht000d71c8@dx19eb9053eb5b85e102"}}
