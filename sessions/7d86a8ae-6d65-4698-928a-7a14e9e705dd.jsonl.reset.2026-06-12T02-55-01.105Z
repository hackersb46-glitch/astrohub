{"type":"message","id":"0adc6bb8","parentId":"a83f3f3f","timestamp":"2026-06-12T02:12:46.245Z","message":{"role":"assistant","content":[{"type":"text","text":"运行 E2E 测试，模拟用户完整操作："},{"type":"toolCall","id":"call_54dc38c529644051a09651a9","name":"exec","arguments":{"command":"cd \"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\"; python -c \"\nfrom playwright.sync_api import sync_playwright\nimport time\n\nwith sync_playwright() as p:\n    browser = p.chromium.launch(headless=True)\n    page = browser.new_page()\n    page.goto('http://localhost:10280', timeout=30000)\n    page.wait_for_load_state('networkidle')\n    time.sleep(2)\n\n    # 切换到主控台\n    nav = page.locator('.nav-btn')\n    for i in range(nav.count()):\n        txt = nav.nth(i).text_content()\n        if '主控台' in txt or '控制台' in txt:\n            nav.nth(i).click()\n            print('Clicked console tab')\n            break\n    time.sleep(1)\n\n    # 模拟用户点击设备连接按钮\n    # 找到设备列表中的连接按钮\n    connect_btns = page.locator('button:has-text(\\\"连接\\\")')\n    if connect_btns.count() > 0:\n        connect_btns.first.click()\n        print('Clicked connect button')\n        time.sleep(3)\n    else:\n        # 手动调用连接\n        page.evaluate('''\n            (async () => {\n                await fetch('/api/v1/devices/192.168.5.72/connect', {\n                    method: 'POST',\n                    headers: {'Content-Type': 'application/json'},\n                    body: JSON.stringify({username:'admin',password:'Nftw1357',port:80})\n                });\n                window.connectedDevice = {ip:'192.168.5.72',online:true};\n            })()\n        ''')\n        time.sleep(2)\n        \n        # 手动调用 loadDeviceImageParams\n        page.evaluate('loadDeviceImageParams(\\\"192.168.5.72\\\")')\n        print('Called loadDeviceImageParams manually')\n        time.sleep(3)\n\n    # 展开画面控制\n    img_sec = page.locator('#imageControlSection')\n    if img_sec.count() > 0:\n        cls = img_sec.evaluate('el => el.className')\n        if 'collapsed' in cls:\n            img_sec.locator('.collapsible-header').click(force=True)\n            time.sleep(0.5)\n            print('Expanded image control')\n\n    # 读取所有下拉菜单\n    print('=== v5.42 下拉菜单 ===')\n    for label, sel in [('白平衡模式','#wbMode'),('快门速度','#shutterSpeed'),('光圈控制','#irisLevel')]:\n        el = page.locator(sel)\n        if el.count() > 0:\n            opts = el.locator('option').all_inner_texts()\n            val = el.evaluate('e => e.value')\n            print(f'{label}: value={val}, options={opts}')\n\n    # 检查 OSD 开关按钮\n    print('=== OSD 开关 ===')\n    ptz_btn = page.locator('#btnPtzOsd')\n    info_btn = page.locator('#btnInfoOsd')\n    if ptz_btn.count() > 0:\n        print(f'PTZ OSD button: text={ptz_btn.evaluate(\\\"e => e.textContent\\\")}')\n    if info_btn.count() > 0:\n        print(f'Info OSD button: text={info_btn.evaluate(\\\"e => e.textContent\\\")}')\n\n    page.screenshot(path='C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/v5.42_final.png')\n    print('Screenshot saved')\n    browser.close()\n\"","timeout":60}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":144592,"output":765,"cacheRead":0,"cacheWrite":0,"totalTokens":145357,"cost":{"input":0.144592,"output":0.002448,"cacheRead":0,"cacheWrite":0,"total":0.14704}},"stopReason":"toolUse","timestamp":1781230344903,"responseId":"cht000d0adc@dx19eb99a1dc1ba5c342"}}
