{"type":"message","id":"8d9db384","parentId":"5908b59f","timestamp":"2026-06-12T00:30:48.981Z","message":{"role":"assistant","content":[{"type":"text","text":"现在修改 `setWhiteBalanceMode` 函数："},{"type":"toolCall","id":"call_4d5b87bf811a48dab3377759","name":"edit","arguments":{"edits":[{"newText":"function setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // v5.40: 处理三种模式\n    var actualMode = mode;\n    if (mode === 'auto_official') {\n        actualMode = 'auto';\n    } else if (mode === 'auto_astrohub') {\n        // 暂未实现\n        showToast('warning', '自动暂未实现');\n        return;\n    }\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: actualMode })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', '白平衡: ' + (actualMode === 'auto' ? '自动（官方）' : '手动'));\n                // v5.40: 更新 R/B 滑动条状态\n                var wbRed = document.getElementById('wbRed');\n                var wbBlue = document.getElementById('wbBlue');\n                if (wbRed) wbRed.disabled = actualMode !== 'manual';\n                if (wbBlue) wbBlue.disabled = actualMode !== 'manual';\n            }\n        });\n}","oldText":"function setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '白平衡: ' + mode);\n        });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":76205,"output":447,"cacheRead":0,"cacheWrite":0,"totalTokens":76652,"cost":{"input":0.076205,"output":0.0014304,"cacheRead":0,"cacheWrite":0,"total":0.0776354}},"stopReason":"toolUse","timestamp":1781224237640,"re