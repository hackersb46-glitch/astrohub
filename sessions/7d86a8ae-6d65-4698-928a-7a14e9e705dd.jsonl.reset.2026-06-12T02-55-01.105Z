{"type":"message","id":"fdcff9dc","parentId":"51908660","timestamp":"2026-06-12T01:55:41.751Z","message":{"role":"assistant","content":[{"type":"text","text":"添加 API 读取 function.json："},{"type":"toolCall","id":"tool-fceef0b6d1674247bc8a049d125f4d18","name":"edit","arguments":{"edits":[{"newText":"@api_router.get(\"/ptz/{device_id}/function\", summary=\"获取设备function.json\", tags=[\"Image\"])\nasync def get_device_function(device_id: str) -> dict:\n    \"\"\"从 data/{device_model}/*/function.json 读取设备功能参数范围。\"\"\"\n    import json\n    from pathlib import Path\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n    \n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n    \n    # 从 data 目录查找 function.json\n    data_dir = Path(__file__).resolve().parent.parent.parent / \"data\"\n    if not data_dir.exists():\n        return {\"success\": False, \"message\": \"data 目录不存在\", \"data\": None}\n    \n    # 遍历所有子目录查找 function.json\n    for subdir in data_dir.iterdir():\n        if subdir.is_dir():\n            for f in subdir.rglob(\"function.json\"):\n                try:\n                    with open(f, \"r\", encoding=\"utf-8\") as fh:\n                        func_data = json.load(fh)\n                    # 检查 IP 是否匹配\n                    if func_data.get(\"device_info\", {}).get(\"ip\") == target_ip:\n                        return {\"success\": True, \"data\": func_data}\n                except Exception:\n                    continue\n    \n    return {\"success\": False, \"message\": \"未找到该设备的 function.json\", \"data\": None}\n\n\n@api_router.get(\"/ptz/{device_id}/image/whitebalance\", summary=\"获取白平衡设置\", tags=[\"Image\"])","oldText":"@api_router.get(\"/ptz/{device_id}/image/whitebalance\", summary=\"获取白平衡设置\", tags=[\"Image\"])"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":119788,"output":511,"cacheRead":0,"cacheWrite":0,"totalTokens":120299,"cost":{"input":0.11978799999999999,"output":0.0016352,"cacheRead":0,"cacheWrite":0,"total":0.1214232}},"stopReason":"toolUse","timestamp":1781229316221,"responseId":"cht000d54bd@dx19eb98a79acb85e102"}}
