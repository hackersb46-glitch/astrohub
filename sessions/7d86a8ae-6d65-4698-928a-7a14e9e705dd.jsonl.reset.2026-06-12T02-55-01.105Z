{"type":"message","id":"ee2f1b1c","parentId":"78651eee","timestamp":"2026-06-12T00:56:07.823Z","message":{"role":"assistant","content":[{"type":"text","text":"现在写 E2E 测试验证："},{"type":"toolCall","id":"tool-a2dbef3457854accafaecf6cca0ddd4b","name":"write","arguments":{"content":"\"\"\"\nE2E Test - v5.40 White Balance Mode\n1. Check dropdown shows: 自动（官方）/ 自动 / 手动\n2. Check R/B sliders disabled when auto\n3. Check R/B sliders enabled when manual\n\"\"\"\n\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_white_balance():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        results = []\n        \n        # 1. Load page\n        print(\"[TEST 1] Loading page...\")\n        page.goto(\"http://localhost:10280\", timeout=30000)\n        page.wait_for_load_state(\"networkidle\")\n        results.append((\"Page load\", True, \"\"))\n        \n        # 2. Navigate to console tab\n        print(\"[TEST 2] Navigate to console...\")\n        nav_btns = page.locator(\".nav-btn\")\n        for i in range(nav_btns.count()):\n            text = nav_btns.nth(i).text_content()\n            if \"主控台\" in text or \"控制台\" in text or \"Console\" in text:\n                nav_btns.nth(i).click()\n                break\n        time.sleep(1)\n        \n        # 3. Connect device (simulate connection)\n        print(\"[TEST 3] Connect device...\")\n        # Use page.evaluate to call the connect function\n        page.evaluate(\"\"\"\n            (async () => {\n                const ip = '192.168.5.72';\n                const username = 'admin';\n                const password = 'Nftw1357';\n                const port = 80;\n                \n                // Get credentials first\n                let credsResp = await fetch('/api/v1/devices/' + ip + '/credentials');\n                let creds = await credsResp.json();\n                \n                // Connect\n                let connectResp = await fetch('/api/v1/devices/' + ip + '/connect', {\n                    method: 'POST',\n                    headers: {'Content-Type': 'application/json'},\n                    body: JSON.stringify({username, password, port})\n                });\n                let result = await connectResp.json();\n                \n                // Set connectedDevice\n                window.connectedDevice = {ip: ip, username: username, password: password, port: port, online: true};\n                \n                // Call loadDeviceImageParams\n                if (typeof loadDeviceImageParams === 'function') {\n                    loadDeviceImageParams(ip);\n                }\n                \n                return result;\n            })()\n        \"\"\")\n        \n        # Wait for API calls to complete\n        time.sleep(3)\n        \n        # 4. Expand image control section\n        print(\"[TEST 4] Expand image Control...\")\n        image_section = page.locator(\"#imageControlSection\")\n        if image_section.count() > 0:\n            header = image_section.locator(\".collapsible-header\")\n            header.click()\n            time.sleep(0.5)\n            results.append((\"Expand Image Control\", True, \"\"))\n        else:\n            results.append((\"Expand Image Control\", False, \"section not found\"))\n        \n        # 5. Check wbMode dropdown options\n        print(\"[TEST 5] Check wbMode options...\")\n        wb_mode = page.locator(\"#wbMode\")\n        if wb_mode.count() > 0:\n            options = wb_mode.locator(\"option\").all_inner_texts()\n            print(f\"  Options: {options}\")\n            \n            # Check expected options\n            expected = [\"自动（官方）\", \"自动\", \"手动\"]\n            has_official = \"自动（官方）\" in options or \"自动(官方)\" in options\n            has_astrohub = \"自动\" in options\n            has_manual = \"手动\" in options\n            \n            results.append((\"Option: 自动（官方）\", has_official, f\"options={options}\"))\n            results.append((\"Option: 自动\", has_astrohub, f\"options={options}\"))\n            results.append((\"Option: 手动\", has_manual, f\"options={options}\"))\n        else:\n            results.append((\"wbMode dropdown\", False, \"not found\"))\n        \n        # 6. Check R/B sliders state (should be disabled when auto)\n        print(\"[TEST 6] Check R/B sliders state...\")\n        wb_red = page.locator(\"#wbRed\")\n        wb_blue = page.locator(\"#wbBlue\")\n        \n        if wb_red.count() > 0 and wb_blue.count() > 0:\n            red_disabled = wb_red.evaluate(\"el => el.disabled\")\n            blue_disabled = wb_blue.evaluate(\"el => el.disabled\")\n            \n            # When auto mode, sliders should be disabled\n            current_mode = wb_mode.evaluate(\"el => el.value\")\n            print(f\"  Current mode: {current_mode}\")\n            print(f\"  Red disabled: {red_disabled}, Blue disabled: {blue_disabled}\")\n            \n            if current_mode == \"auto_official\":\n                results.append((\"R slider disabled (auto)\", red_disabled, f\"mode={current_mode}\"))\n                results.append((\"B slider disabled (auto)\", blue_disabled, f\"mode={current_mode}\"))\n            else:\n                results.append((\"R slider state\", True, f\"disabled={red_disabled}\"))\n                results.append((\"B slider state\", True, f\"disabled={blue_disabled}\"))\n        else:\n            results.append((\"R/B sliders\", False, \"not found\"))\n        \n        # 7. Switch to manual mode and verify sliders enabled\n        print(\"[TEST 7] Switch to manual mode...\")\n        if wb_mode.count() > 0:\n            wb_mode.select_option(\"manual\")\n            time.sleep(1)\n            \n            red_disabled = wb_red.evaluate(\"el => el.disabled\")\n            blue_disabled = wb_blue.evaluate(\"el => el.disabled\")\n            \n            print(f\"  After manual: Red disabled={red_disabled}, Blue disabled={blue_disabled}\")\n            \n            results.append((\"R slider enabled (manual)\", not red_disabled, f\"disabled={red_disabled}\"))\n            results.append((\"B slider enabled (manual)\", not blue_disabled, f\"disabled={blue_disabled}\"))\n        \n        # 8. Take screenshot\n        print(\"[TEST 8] Take screenshot...\")\n        page.screenshot(path=\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/e2e_v5.40_wb.png\")\n        results.append((\"Screenshot\", True, \"e2e_v5.40_wb.png\"))\n        \n        browser.close()\n        \n        # Output results\n        print(\"\\n\" + \"=\" * 60)\n        print(\"E2E Test Results - v5.40 White Balance\")\n        print(\"=\" * 60)\n        \n        passed = sum(1 for _, s, _ in results if s)\n        failed = sum(1 for _, s, _ in results if not s)\n        \n        for name, success, detail in results:\n            status = \"PASS\" if success else \"FAIL\"\n            print(f\"[{status}] {name}: {detail}\")\n        \n        print(\"=\" * 60)\n        print(f\"Total: {passed} passed, {failed} failed\")\n        print(\"=\" * 60)\n        \n        return failed == 0\n\nif __name__ == \"__main__\":\n    import sys\n    success = test_white_balance()\n    sys.exit(0 if success else 1)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_v5.40_wb.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":77185,"output":1550,"cacheRead":0,"cacheWrite":0,"totalTokens":78735,"cost":{"input":0.07718499999999999,"output":0.00496,"cacheRead":0,"cacheWrite":0,"total":0.082145}},"stopReason":"toolUse","timestamp":1781225731699,"responseId":"cht000d58c1@dx19eb953b9b3ba5b442"}}
