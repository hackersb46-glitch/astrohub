{"type":"message","id":"0492eca4","parentId":"9ed4cd2b","timestamp":"2026-06-12T01:43:49.324Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_cb031244252f4bccb65cccb1","name":"write","arguments":{"content":"from playwright.sync_api import sync_playwright\nimport time\n\nwith sync_playwright() as p:\n    browser = p.chromium.launch(headless=True)\n    page = browser.new_page()\n    page.goto(\"http://localhost:10280\", timeout=30000)\n    page.wait_for_load_state(\"networkidle\")\n    time.sleep(1)\n\n    # 连接设备\n    page.evaluate(\"\"\"\n        (async () => {\n            await fetch('/api/v1/devices/192.168.5.72/connect', {\n                method: 'POST',\n                headers: {'Content-Type': 'application/json'},\n                body: JSON.stringify({username:'admin',password:'Nftw1357',port:80})\n            });\n            window.connectedDevice = {ip:'192.168.5.72',username:'admin',password:'Nftw1357',port:80,online:true};\n            if (typeof loadDeviceImageParams === 'function') loadDeviceImageParams('192.168.5.72');\n        })()\n    \"\"\")\n    time.sleep(3)\n\n    # 展开画面控制\n    sec = page.locator(\"#imageControlSection\")\n    if sec.count() > 0:\n        sec.locator(\".collapsible-header\").click()\n        time.sleep(0.5)\n\n    # 读取所有下拉菜单\n    selects = [\n        (\"白平衡模式\", \"#wbMode\"),\n        (\"快门速度\", \"#shutterSpeed\"),\n        (\"光圈控制\", \"#irisLevel\"),\n    ]\n\n    for label, sel in selects:\n        el = page.locator(sel)\n        if el.count() > 0:\n            opts = el.locator(\"option\").all_inner_texts()\n            val = el.evaluate(\"e => e.value\")\n            print(f\"{label}: value={val}, options={opts}\")\n        else:\n            print(f\"{label}: NOT FOUND\")\n\n    # OSD\n    ptz_osd = page.locator(\"#btnPtzOsdOn\")\n    info_osd = page.locator(\"#btnInfoOsdOn\")\n    print(f\"PTZ OSD button: count={ptz_osd.count()}\")\n    print(f\"Info OSD button: count={info_osd.count()}\")\n\n    # 截图\n    page.screenshot(path=\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/tests/check_dropdowns.png\")\n    print(\"Screenshot saved\")\n\n    browser.close()\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\check_dropdowns.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":103882,"output":537,"cacheRead":0,"cacheWrite":0,"totalTokens":104419,"cost":{"input":0.103882,"output":0.0017184000000000001,"cacheRead":0,"cacheWrite":0,"total":0.1056004}},"stopReason":"toolUse","timestamp":1781228606515,"responseId":"cht000def85@dx19eb97fb088b894142"}}
