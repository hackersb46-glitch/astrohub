{"type":"message","id":"5d1cf99f","parentId":"322b42df","timestamp":"2026-06-30T22:08:40.235Z","message":{"role":"toolResult","toolCallId":"toolu_db8f359ef0954a37933e7145","toolName":"read","content":[{"type":"text","text":"\"\"\"\nPTZ_ASTRO v1.1 - PTZ设备管理模块\nHikvision PTZ camera discovery, authentication, capability detection, and motion control.\n\nAuthor: 开发团队@天文台\n\"\"\"\n\n__version__ = \"1.1\"\n__author__ = \"开发团队@天文台\"\n"}],"isError":false,"timestamp":1782857320234}}
{"type":"message","id":"b49ea690","parentId":"5d1cf99f","timestamp":"2026-06-30T22:08:40.235Z","message":{"role":"toolResult","toolCallId":"toolu_5eea7bb8c85e40b3a41f3078","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nM12 Unified Integration v1.0 - 全局常量定义\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nfrom enum import Enum\r\nfrom pathlib import Path\r\n\r\n# === 版本与作者 ===\r\nVERSION = \"v7.122\"\r\nVERSION_NUM = \"7.122\"\r\nAUTHOR = \"雅痞张@南方天文\"\r\nPROJECT_NAME = \"MAIN\"\r\n\r\n# === 路径 ===\r\nBASE_DIR = Path(__file__).resolve().parent\r\n\r\n# === M1-M11 模块初始化顺序 ===\r\n# v7.12: 精简后保留的模块\r\n# 注意: device 模块已整合到 src/core/device_manager.py\r\nMODULE_ORDER = [\r\n    \"ptz\",\r\n    \"stream\",\r\n    \"calibration\",\r\n    \"database\",\r\n    \"websocket\",\r\n    \"ascom\",\r\n]\r\n\r\n\r\n# === 健康状态枚举 ===\r\nclass HealthStatus(Enum):\r\n    \"\"\"模块健康状态。\"\"\"\r\n    HEALTHY = \"healthy\"\r\n    DEGRADED = \"degraded\"\r\n    UNHEALTHY = \"unhealthy\"\r\n    UNKNOWN = \"unknown\"\r\n"}],"isError":false,"timestamp":1782857320234}}
