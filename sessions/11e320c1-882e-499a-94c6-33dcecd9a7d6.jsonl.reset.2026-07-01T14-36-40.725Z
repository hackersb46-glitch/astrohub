{"type":"message","id":"1d00eebf","parentId":"a378535d","timestamp":"2026-06-30T21:51:02.659Z","message":{"role":"toolResult","toolCallId":"toolu_058fa86cdafa4e5d8fbe1698","toolName":"read","content":[{"type":"text","text":"            return default\r\n\r\n    def get_xml_float(self, root: ET.Element, tag: str, default: float = 0.0) -> float:\r\n        \"\"\"从 XML 元素中安全提取浮点数。\"\"\"\r\n        text = self.get_xml_text(root, tag, str(default))\r\n        try:\r\n            return float(text)\r\n        except (ValueError, TypeError):\r\n            return default\r\n\r\n    def _get_binary(self, endpoint: str, timeout: int = 15) -> bytes | None:\r\n        \"\"\"从 ISAPI 端点获取二进制数据（截图、录像等）。\r\n\r\n        Args:\r\n            endpoint: ISAPI 端点路径\r\n            timeout: 超时秒数\r\n\r\n        Returns:\r\n            二进制数据，失败返回 None\r\n        \"\"\"\r\n        url = f\"{self.base_url}{endpoint}\"\r\n        LOG.log(\"info\", f\"ISAPI binary GET: {endpoint}\")\r\n        try:\r\n            response = self.session.get(url, timeout=timeout)\r\n            if response.status_code == 200:\r\n                LOG.log(\"done\", f\"ISAPI binary GET 成功: {endpoint} ({len(response.content)} bytes)\")\r\n                return response.content\r\n            else:\r\n                LOG.log(\"error\", f\"ISAPI binary GET 失败: {endpoint} (HTTP {response.status_code})\")\r\n                return None\r\n        except requests.exceptions.Timeout:\r\n            LOG.log(\"error\", f\"ISAPI binary GET 超时: {endpoint}\")\r\n            return None\r\n        except requests.exceptions.ConnectionError as e:\r\n            LOG.log(\"error\", f\"ISAPI binary GET 连接失败: {endpoint} - {e}\")\r\n            return None\r\n        except Exception as e:\r\n            LOG.log(\"error\", f\"ISAPI binary GET 异常: {endpoint} - {e}\")\r\n            return None\r\n\r\n    def capture_picture(self, channel: int = 1) -> bytes | None:\r\n        \"\"\"从摄像头抓取 JPEG 图片。\r\n\r\n        Args:\r\n            channel: 通道号，默认 1\r\n\r\n        Returns:\r\n            JPEG 图片二进制数据，失败返回 None\r\n        \"\"\"\r\n        endpoint = f\"/Streaming/channels/{channel}01/picture\"\r\n        return self._get_binary(endpoint)\r\n\r\n    # ================================================================\r\n    #  二进制响应（截图 / 录像下载）— v8.01 从 ptz_controller.py 迁移\r\n    # ================================================================\r\n\r\n    def _get_binary(self, endpoint: str) -> bytes | None:\r\n        \"\"\"从 ISAPI 端点获取二进制响应（用于图片 / 视频文件）。\"\"\"\r\n        url = f\"{self.base_url}{endpoint}\"\r\n        LOG.log(\"info\", f\"ISAPI BINARY GET: {endpoint}\")\r\n        try:\r\n            response = self.session.get(url, timeout=15)\r\n            if response.status_code == 200:\r\n                return response.content\r\n            LOG.log(\"error\", f\"ISAPI binary GET 失败: {endpoint} (status={response.status_code})\")\r\n            return None\r\n        except requests.exceptions.Timeout:\r\n            LOG.log(\"error\", f\"ISAPI binary GET 超时: {endpoint}\")\r\n            return None\r\n        except Exception as e:\r\n            LOG.log(\"error\", f\"ISAPI binary GET 错误: {endpoint}: {e}\")\r\n            return None\r\n\r\n    def capture_picture(self, channel: int = 1) -> bytes | None:\r\n        \"\"\"通过 ISAPI 直接从摄像头抓取 JPEG 图片。\r\n\r\n        使用: GET /Streaming/Channels/{channel}/picture\r\n        \"\"\"\r\n        endpoint = f\"/Streaming/Channels/{channel}/picture\"\r\n        return self._get_binary(endpoint)\r\n\n[1 more lines in file. Use offset=328 to continue.]"}],"isError":false,"timestamp":1782856262659}}
