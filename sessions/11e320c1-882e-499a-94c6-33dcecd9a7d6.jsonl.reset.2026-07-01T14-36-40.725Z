    if level_lower not in _ACCEPTED_LEVELS:\n- 119             raise ValueError(f\"未知日志级别 '{level}'\")\n- 120         timestamp = datetime.now().strftime(\"%Y%m%d-%H%M%S.%f\")[:19]\n- 121         line = f\"[{level_lower}] {timestamp} - {message}\"\n- 122         with open(self.log_file, \"a\", encoding=\"utf-8\") as f:\n- 123             f.write(line + \"\\n\")\n- 124         print(line)\n- 125 \n- 126 LOG = Logger()\n- 127 \n  128 # ============================================================\n  129 # ConfigManager\n  130 # ============================================================\n  131 \n      ...","firstChangedLine":86},"isError":false,"timestamp":1782856014996}}
{"type":"message","id":"124ca0e1","parentId":"e6132392","timestamp":"2026-06-30T21:47:00.723Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me verify the ISAPIClient compatibility between ptz_controller.py's embedded version and src/ptz/isapi/client.py. Let me check the client.py file.","thinkingSignature":""},{"type":"text","text":"Logger 替换完成。现在验证 ISAPIClient 兼容性：\n\n"},{"type":"toolCall","id":"toolu_559b7473e8834d67bf5f05c3","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\ptz\\isapi\\client.py"}}],"api":"anthropic-messages","provider":"HP","model":"qwen-3.7-max","usage":{"input":6,"output":104,"cacheRead":89609,"cacheWrite":29430,"totalTokens":119149,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1782856014998,"responseId":"msg_c58bc578-12f6-428f-ac62-d138c93e7549"}}
{"type":"message","id":"add0162b","parentId":"124ca0e1","timestamp":"2026-06-30T21:47:00.758Z","message":{"role":"toolResult","toolCallId":"toolu_559b7473e8834d67bf5f05c3","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nPTZ_ASTRO v1.1 - ISAPI HTTP 客户端\r\nHikvision ISAPI Digest Auth HTTP 客户端，支持 GET/PUT 请求、XML 解析、错误码处理。\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nimport os\r\nimport re\r\nimport xml.etree.ElementTree as ET\r\nfrom dataclasses import dataclass\r\n\r\ntry:\r\n    import requests\r\n    from requests.auth import HTTPDigestAuth\r\nexcept ImportError:\r\n    raise ImportError(\"需要安装 requests 库: pip install requests\")\r\n\r\nfrom src.ptz.core.logger import LOG\r\n\r\n\r\n@dataclass\r\nclass ISAPIResponse:\r\n    \"\"\"ISAPI 响应封装。\"\"\"\r\n    status_code: int\r\n    xml: str = \"\"\r\n    error_code: int = 0\r\n    error_string: str = \"\"\r\n    sub_status_code: str = \"\"\r\n\r\n\r\nclass ISAPIClient:\r\n    \"\"\"ISAPI HTTP 客户端，使用 Digest Auth。\"\"\"\r\n\r\n    def __init__(self, ip: str, username: str, password: str, port: int = 80) -> None:\r\n        self.ip = ip\r\n        self.username = username\r\n        self.password = password\r\n        self.port = port\r\n        self.base_url = f\"http://{ip}:{port}/ISAPI\"\r\n        self.session = requests.Session()\r\n        self.session.auth = HTTPDigestAuth(username, password)\r\n        self.session.headers.update({\r\n            \"Content-Type\": \"application/xml; charset=UTF-8\",\r\n        })\r\n        # BUG-014: 全局连接超时 5 秒，避免设备不可达时挂起\r\n        self.session.timeout = 5\r\n        self.authenticated = False\r\n\r\n    def _log_response(self, method: str, url: str, response) -> None:\r\n        \"\"\"记录响应详情。\"\"\"\r\n        if response.status_code == 200:\r\n            LOG.log(\"done\", f\"ISAPI {method} {url} → {response.status_code}\")\r\n        elif response.status_code == 401:\r\n            LOG.log(\"error\", f\"ISAPI {method} {url} → {response.status_code} (认证失败)\")\r\n        else:\r\n            LOG.log(\"warning\", f\"ISAPI {method} {url} → {response.status_code}\")\r\n\r\n    def _parse_error_response(self, response_text: str) -> tuple[int, str, str]:\r\n        \"\"\"从 XML 响应中解析错误码。\r\n\r\n        返回 (status_code, status_string, sub_status_code)\r\n        \"\"\"\r\n        try:\r\n            root = ET.fromstring(response_text)\r\n            ns = {\"hv\": \"http://www.hikvision.com/ver20/XMLSchema\"}\r\n\r\n            def find_text(tag: str) -> str:\r\n                elem = root.find(tag)\r\n                if elem is not None and elem.text:\r\n                    return elem.text.strip()\r\n                elem = root.find(f\"hv:{tag}\", ns)\r\n                if elem is not None and elem.text:\r\n                    return elem.text.strip()\r\n                # Namespace-free search\r\n                for child in root.iter():\r\n                    if child.tag.endswith(tag):\r\n                        return (child.text or \"\").strip()\r\n                return \"\"\r\n\r\n            code_str = find_text(\"statusCode\")\r\n            string_val = find_text(\"statusString\")\r\n            sub_code = find_text(\"subStatusCode\")\r\n\r\n            try:\r\n                code = int(code_str)\r\n            except (ValueError, TypeError):\r\n                code = 0\r\n\r\n            return code, string_val, sub_code\r\n        except ET.ParseError:\r\n            return 0, \"\", \"\"\r\n\r\n    def get(self, endpoint: str) -> ISAPIResponse:\r\n        \"\"\"发送 GET 请求。\r\n\r\n        参数:\r\n            endpoint: ISAPI 端点路径，如 \"/System/deviceInfo\"\r\n\r\n        返回:\r\n            ISAPIResponse 对象\r\n        \"\"\"\r\n        url = f\"{self.base_url}{endpoint}\"\r\n        LOG.log(\"info\", f\"ISAPI GET: {endpoint}\")\r\n\r\n        try:\r\n            response = self.session.get(url, timeout=5)\r\n            self._log_response(\"GET\", endpoint, response)\r\n\r\n            result = ISAPIResponse(status_code=response.status_code)\r\n\r\n            if response.status_code == 200:\r\n                result.xml = response.text\r\n            else:\r\n                result.error_code, result.error_string, result.sub_status_code = (\r\n                    self._parse_error_response(response.text)\r\n                )\r\n\r\n            return result\r\n\r\n        except requests.exceptions.Timeout:\r\n            LOG.log(\"error\", f\"ISAPI GET 超时: {endpoint}\")\r\n            return ISAPIResponse(status_code=0, error_string=\"Timeout\")\r\n        except requests.exceptions.ConnectionError as e:\r\n            LOG.log(\"error\", f\"ISAPI GET 连接失败: {endpoint} - {e}\")\r\n            return ISAPIResponse(status_code=0, error_string=str(e))\r\n        except Exception as e:\r\n            LOG.log(\"error\", f\"ISAPI GET 异常: {endpoint} - {e}\")\r\n            return ISAPIResponse(status_code=0, error_string=str(e))\r\n\r\n    def put(self, endpoint: str, xml_body: str) -> ISAPIResponse:\r\n        \"\"\"发送 PUT 请求。\r\n\r\n        参数:\r\n            endpoint: ISAPI 端点路径\r\n            xml_body: XML 请求体（原始字符串，非 ElementTree）\r\n\r\n        返回:\r\n            ISAPIResponse 对象\r\n        \"\"\"\r\n        url = f\"{self.base_url}{endpoint}\"\r\n        LOG.log(\"info\", f\"ISAPI PUT: {endpoint}\")\r\n\r\n        try:\r\n            response = self.session.put(\r\n                url,\r\n                data=xml_body.encode(\"utf-8\"),\r\n                headers={\"Content-Type\": \"application/xml; charset=UTF-8\"},\r\n                timeout=5,\r\n            )\r\n            self._log_response(\"PUT\", endpoint, response)\r\n\r\n            result = ISAPIResponse(status_code=response.status_code)\r\n\r\n            if response.status_code == 200:\r\n                result.xml = response.text\r\n            else:\r\n                result.error_code, result.error_string, result.sub_status_code = (\r\n                    self._parse_error_response(response.text)\r\n                )\r\n\r\n            return result\r\n\r\n        except requests.exceptions.Timeout:\r\n            LOG.log(\"error\", f\"ISAPI PUT 超时: {endpoint}\")\r\n            return ISAPIResponse(status_code=0, error_string=\"Timeout\")\r\n        except requests.exceptions.ConnectionError as e:\r\n            LOG.log(\"error\", f\"ISAPI PUT 连接失败: {endpoint} - {e}\")\r\n            return ISAPIResponse(status_code=0, error_string=str(e))\r\n        except Exception as e:\r\n            LOG.log(\"error\", f\"ISAPI PUT 异常: {endpoint} - {e}\")\r\n            return ISAPIResponse(status_code=0, error_string=str(e))\r\n\r\n    def verify_credentials(self) -> bool:\r\n        \"\"\"验证账号密码是否正确。\r\n\r\n        通过多端点 GET 验证账号密码是否正确 (P3.2)。\r\n\r\n        返回:\r\n            True = 认证成功，False = 认证失败\r\n        \"\"\"\r\n        LOG.log(\"info\", f\"验证 ISAPI 凭证: {self.username}@{self.ip}\")\r\n\r\n        # 使用独立 Session 用于认证验证\r\n        auth_session = requests.Session()\r\n        auth_session.trust_env = False\r\n        auth_session.auth = HTTPDigestAuth(self.username, self.password)\r\n        auth_session.headers.update({\r\n            \"Content-Type\": \"application/xml; charset=UTF-8\",\r\n        })\r\n\r\n        # 多端点尝试列表（按顺序）\r\n        endpoints = [\r\n            \"/System/deviceInfo\",         # 标准路径\r\n            \"/System/DeviceInfo\",         # PascalCase 变体\r\n            \"/System/status/deviceInfo\",   # 带 status 前缀（PTZ 球机）\r\n            \"/System/capabilities\",        # 设备能力端点\r\n            \"/DeviceManagement/DeviceInfo\", # ISAPI v2.0\r\n            \"/System/network/interfaces\",   # 网络设备信息端点\r\n        ]\r\n\r\n        for endpoint in endpoints:\r\n            url = f\"{self.base_url}{endpoint}\"\r\n            try:\r\n                response = auth_session.get(url, timeout=5)\r\n\r\n                if response.status_code == 200:\r\n                    self.authenticated = True\r\n                    LOG.log(\"done\", f\"ISAPI 认证成功 (端点: {endpoint})\")\r\n                    auth_session.close()\r\n                    return True\r\n\r\n                elif response.status_code == 401:\r\n                    LOG.log(\"failed\", \"ISAPI 认证失败 (HTTP 401) - 密码错误，端点存在但认证不通过\")\r\n                    auth_session.close()\r\n                    return False\r\n\r\n                # 404 或其他状态码继续尝试下一个端点\r\n                LOG.log(\"info\", f\"端点 {endpoint} 返回 {response.status_code}, 继续尝试...\")\r\n\r\n            except requests.exceptions.Timeout:\r\n                LOG.log(\"info\", f\"端点 {endpoint} 超时, 继续尝试下一个...\")\r\n                continue\r\n            except requests.exceptions.ConnectionError as e:\r\n                LOG.log(\"info\", f\"端点 {endpoint} 连接失败 ({e}), 继续尝试下一个...\")\r\n                continue\r\n            except Exception as e:\r\n                LOG.log(\"info\", f\"端点 {endpoint} 异常 ({e}), 继续尝试下一个...\")\r\n                continue\r\n\r\n        LOG.log(\"failed\", \"ISAPI 凭证验证失败: 所有端点均失败\")\r\n        auth_session.close()\r\n        return False\r\n\r\n    def get_xml_text(self, root: ET.Element, tag: str, default: str = \"\") -> str:\r\n        \"\"\"从 XML 元素中安全提取文本（忽略命名空间）。\"\"\"\r\n        for child in root.iter():\r\n            if child.tag.endswith(tag):\r\n                return (child.text or default).strip()\r\n        return default\r\n\r\n    def get_xml_int(self, root: ET.Element, tag: str, default: int = 0) -> int:\r\n        \"\"\"从 XML 元素中安全提取整数。\"\"\"\r\n        text = self.get_xml_text(root, tag, str(default))\r\n        try:\r\n            return int(text)\r\n        except (ValueError, TypeError):\r\n            return default\r\n\r\n    def get_xml_float(self, root: ET.Element, tag: str, default: float = 0.0) -> float:\r\n        \"\"\"从 XML 元素中安全提取浮点数。\"\"\"\r\n        text = self.get_xml_text(root, tag, str(default))\r\n        try:\r\n            return float(text)\r\n        except (ValueError, TypeError):\r\n            return default\r\n"}],"isError":false,"timestamp":1782856020758}}
{"type":"message","id":"0e1c63eb","parentId":"add0162b","timestamp":"2026-06-30T21:47:39.035Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to compare the `ISAPIClient` in `src/ptz/isapi/client.py` with the one embedded in `src/core/ptz_controller.py`.\n\n**src/ptz/isapi/client.py** has:\n- `ISAPIResponse` (dataclass)\n- `ISAPIClient` with methods: `__init__`, `_log_response`, `_parse_error_response`, `get`, `put`, `verify_credentials`, `get_xml_text`, `get_xml_int`, `get_xml_float`\n\n**src/core/ptz_controller.py** embedded version has:\n- `ISAPIResponse` (dataclass) - same structure\n- `ISAPIClient` with methods: `__init__`, `_parse_error_response`, `get`, `put`, `post`, `post_binary`, `verify_credentials`, `get_xml_text`, `get_xml_int`, `get_xml_float`, `_get_binary`, `capture_picture`\n\n**Differences:**\n1. Embedded version has `post()`, `post_binary()`, `_get_binary()`, `capture_picture()` methods that the standalone doesn't have\n2. Standalone version has `_log_response()` method and session timeout\n3. Both have the same core: `get()`, `put()`, `verify_credentials()`, `get_xml_text/int/float`\n\nThe embedded version has MORE methods (post, post_binary, capture_picture) that are used by `PTZDeviceController` for recording and screenshots.\n\nSo I can't simply replace the embedded `ISAPIClient` with the standalone one because the embedded has additional methods needed by `PTZDeviceController`.\n\n**Options:**\n1. Add the missing methods (`post`, `post_binary`, `_get_binary`, `capture_picture`) to the standalone `ISAPIClient` in `src/ptz/isapi/client.py`\n2. Keep the embedded version (but that defeats the purpose of slimming)\n\nOption 1 is the right approach - it follows the \"reuse and inheritance\" principle. I should add the missing methods to the standalone `ISAPIClient`, then replace the embedded version with an import.\n\nBut wait - the user said \"禁止过度开发引入新的冗余文件\" and \"尽可能实现复用和继承\". Adding methods to the standalone to replace the embedded is exactly that - reuse.\n\nHowever, this is getting complex. The embedded `ISAPIClient` has `post()` and `post_binary()` which are used for recording functions in `PTZDeviceController`. Let me check if these methods are actually called...\n\nLooking at `ptz_controller.py`:\n- `start_recording()` uses `client.put()` - covered by standalone\n- `stop_recording()` uses `client.put()` - covered by standalone\n- `_get_isapi_client()` creates an `ISAPIClient` - covered by standalone\n- `capture_picture()` is defined in the embedded `ISAPIClient` but... let me check if it's called\n\nActually, looking more carefully at `PTZDeviceController`:\n- It uses `self._clients[ip]` which stores `ISAPIClient` instances\n- `connect_device()` creates `ISAPIClient(ip=..., username=..., password=..., port=...)`\n- `get_device_info()` uses `client.get()` and `client.get_xml_text()`\n- `modify_device_network()` uses `client.put()`\n- `start_recording()` and `stop_recording()` use `client.put()`\n- `_get_isapi_client()` creates `ISAPIClient` and calls `verify_credentials()`\n\nThe embedded `ISAPIClient` also has `post()`, `post_binary()`, `capture_picture()`, `_get_binary()` - but are these actually called by `PTZDeviceController`?\n\nLooking at the code:\n- `capture_picture()` is defined in the embedded `ISAPIClient` but I don't see `PTZDeviceController` calling it\n- `post()` is defined but not called by `PTZDeviceController`\n- `post_binary()` is defined but not called by `PTZDeviceController`\n- `_get_binary()` is defined and called by `capture_picture()` (which is itself not called)\n\nSo the methods that ARE actually used by `PTZDeviceController` from `ISAPIClient`:\n- `__init__(ip, username, password, port)` ✓\n- `verify_credentials()` ✓\n- `get(endpoint)` ✓\n- `put(endpoint, xml_body)` ✓\n- `get_xml_text(root, tag, default)` ✓\n- `session.close()` (via `disconnect_device`) ✓\n\nThe standalone `ISAPIClient` has ALL of these methods! The extra methods in the embedded version (`post`, `post_binary`, `capture_picture`, `_get_binary`) appear to be unused by `PTZDeviceController`.\n\nWait, but `disconnect_device` calls `client.session.close()` - the standalone has `self.session` too, so that works.\n\n**Conclusion: The standalone `ISAPIClient` from `src/ptz/isapi/client.py` is fully compatible with what `PTZDeviceController` needs.** The embedded version has extra methods that aren't used.\n\nSo I can safely replace the embedded `ISAPIResponse` and `ISAPIClient` in `ptz_controller.py` with imports from `src/ptz/isapi/client.py`.\n\nThis will remove a large chunk of duplicate code from the 98KB file.\n\nLet me now do this replacement. The embedded ISAPIResponse and ISAPIClient span from approximately line 573 to line 762 (about 190 lines of code).\n\nBut I need to be careful - the `PTZDeviceController` class methods use `ISAPIClient` and `ISAPIResponse` directly. If I import them from `src/ptz/isapi/client.py`, everything should work because the interfaces are compatible.\n\nLet me also check: does `src/ptz/isapi/client.py`'s `ISAPIClient` have `post()` method? No, it doesn't. But `PTZDeviceController` doesn't call `post()` on its `ISAPIClient` instances... let me double-check.\n\nLooking at `PTZDeviceController` methods that use `ISAPIClient`:\n- `connect_device()`: `client = ISAPIClient(...)`, `client.verify_credentials()`\n- `disconnect_device()`: `client.session.close()`\n- `get_device_info()`: `client.get(...)`, `client.get_xml_text(...)`\n- `modify_device_network()`: `client.put(...)`\n- `start_recording()`: `client.put(...)`\n- `stop_recording()`: `client.put(...)`\n- `_get_isapi_client()`: `ISAPIClient(...)`, `client.verify_credentials()`\n- `_get_controller()`: `ISAPIClient(...)`, `client.verify_credentials()`\n\nNone of these use `post()`, `post_binary()`, `capture_picture()`, or `_get_binary()`. So it's safe to replace.\n\nNow let me do the replacement. I need to:\n1. Add `from src.ptz.isapi.client import ISAPIClient, ISAPIResponse` to the imports\n2. Remove the embedded `ISAPIResponse` dataclass and `ISAPIClient` class\n\nBut wait - there's a subtlety. The `src/ptz/isapi/client.py`'s `ISAPIClient` already imports `LOG` from `src.ptz.core.logger`. And now `ptz_controller.py` also imports `LOG` from the same place. That's fine, no conflict.\n\nLet me also check if `ISAPI_CHANNEL` constant is used in `PTZDeviceController` methods... Yes, `ISAPI_CHANNEL = 1` is used in `start_recording` and `stop_recording`. That constant is defined at the top of `ptz_controller.py` and is not part of the ISAPIClient class, so it stays.\n\nOK, let me do the replacement now. I need to remove the embedded `ISAPIResponse` and `ISAPIClient` classes and add the import.\nISAPIClient 对比：\n- `src/ptz/isapi/client.py` 有 `get`, `put`, `verify_credentials`, `get_xml_text/int/float` ✅\n- `ptz_controller.py` 内嵌版额外有 `post`, `post_binary`, `capture_picture` — 但 PTZDeviceController **未调用这些方法**\n\n**结论**：可用 `src/ptz/isapi/client.py` 替换内嵌版。继续：\n## 任务1续：删除 ptz_controller.py 内嵌 ISAPIResponse + ISAPIClient，复用独立模块\n\n","thinkingSignature":""},{"type":"toolCall","id":"toolu_92edef555670433988eddd85","name":"read","arguments":{"limit":10,"offset":25,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_controller.py"}}],"api":"anthropic-messages","provider":"HP","model":"qwen-3.7-max","usage":{"input":6,"output":1915,"cacheRead":119039,"cacheWrite":2391,"totalTokens":123351,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1782856020760,"responseId":"msg_54f312de-0359-4c88-836c-44f8f4085853"}}
