{"type":"message","id":"d10b0ba3","parentId":"0978a660","timestamp":"2026-06-30T21:55:20.778Z","message":{"role":"toolResult","toolCallId":"toolu_a7ff37ccca5b4cd1969e7c50","toolName":"read","content":[{"type":"text","text":"\r\n    def capture_picture(self, channel: int = ISAPI_CHANNEL) -> bytes | None:\r\n        \"\"\"通过 ISAPI 直接从摄像头抓取 JPEG 图片。\r\n\r\n        使用: GET /Streaming/Channels/{channel}/picture\r\n        \"\"\"\r\n        endpoint = f\"/Streaming/Channels/{channel}/picture\"\r\n        return self._get_binary(endpoint)\r\n\r\n# ============================================================\r\nclass PTZDeviceController:\r\n    \"\"\"PTZ 设备管理器（高层包装）。\r\n\r\n    整合 SADP 发现、ISAPI 连接、PTZ 控制能力。\r\n    \"\"\"\r\n\r\n    # 方向映射: 前端 direction -> (pan, tilt) values\r\n    DIRECTION_MAP = {\r\n        \"up\":       (0, 1),\r\n        \"down\":     (0, -1),\r\n        \"left\":     (-1, 0),\r\n        \"right\":    (1, 0),\r\n        \"up-left\":  (-1, 1),\r\n        \"up-right\": (1, 1),\r\n        \"down-left\": (-1, -1),\r\n        \"down-right\": (1, -1),\r\n    }\r\n\r\n    def __init__(self) -> None:\r\n        LOG.log(\"info\", \"PTZDeviceController 初始化完成\")\r\n\n[1403 more lines in file. Use offset=880 to continue.]"}],"isError":false,"timestamp":1782856520778}}
