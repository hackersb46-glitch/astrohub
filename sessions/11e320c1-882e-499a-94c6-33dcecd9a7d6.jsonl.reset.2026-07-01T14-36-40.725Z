{"type":"message","id":"03bb9871","parentId":"42ff8e2b","timestamp":"2026-07-01T01:44:42.550Z","message":{"role":"toolResult","toolCallId":"toolu_94d711725e51407780443cbf","toolName":"exec","content":[{"type":"text","text":"\"\"\"\r\nAstroHub v2.0 - �豸������\r\n\r\n�豸ע�ᡢ״̬׷�١�������������ñ���/�ָ���\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport json\r\nimport threading\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom pathlib import Path\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel, Field\r\n\r\nfrom src.config import CONFIG_DIR\r\nfrom src.config_paths import DEVICES_DIR, REGISTRY_FILE\r\nfrom src.logger import get_logger\r\n\r\nlog = get_logger(\"device_manager\")\r\n\r\n# Time constants\r\nHEARTBEAT_TIMEOUT = 60  # �룬������ʱ������������Ϊ����\r\nCONFIG_BACKUP_DIR = CONFIG_DIR / \"device_backups\"\r\n\r\n\r\n# ============================================================\r\n# Data Models\r\n# ============================================================\r\n\r\n\r\nclass Device(BaseModel):\r\n    \"\"\"�豸��Ϣģ�͡�\"\"\"\r\n\r\n    mac: str\r\n    ip: str = \"\"\r\n    name: str = \"\"\r\n    model: str = \"\"\r\n    status: str = \"offline\"  # online | offline | error\r\n    registered_at: str = Field(default_factory=lambda: _now_iso())\r\n    last_heartbeat: str = Field(default_factory=lambda: _now_iso())\r\n    metadata: dict[str, Any] = Field(default_factory=dict)\r\n\r\n    def mark_online(self) -> None:\r\n        \"\"\"���Ϊ���ߣ���������ʱ�䡣\"\"\"\r\n        self.status = \"online\"\r\n        self.last_heartbeat = _now_iso()\r\n\r\n    def mark_offline(self) -> None:\r\n        \"\"\"���Ϊ���ߡ�\"\"\"\r\n        self.status = \"offline\"\r\n\r\n    def mark_error(self) -> None:\r\n        \"\"\"���Ϊ�쳣��\"\"\"\r\n        self.status = \"error\"\r\n\r\n\r\nclass DeviceGroup(BaseModel):\r\n    \"\"\"�豸����ģ�͡�\"\"\"\r\n\r\n    name: str\r\n    description: str = \"\"\r\n    mac_addresses: set[str] = Field(default_factory=set)\r\n    created_at: str = Field(default_factory=lambda: _now_iso())\r\n\r\n\r\n# ============================================================\r\n# Helpers\r\n# ============================================================\r\n\r\n\r\ndef _now_iso() -> str:\r\n    \"\"\"���ص�ǰ UTC ʱ��� ISO �ַ�����\"\"\"\r\n    return datetime.now(timezone.utc).replace(tzinfo=None).isoformat()\r\n\r\n\r\ndef _normalize_mac(mac: str) -> str:\r\n    \"\"\"ͳһ MAC ��ʽ���޷ָ���Сд��\"\"\"\r\n    return mac.strip().replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n\r\n\r\n# ============================================================\r\n# DeviceManager\r\n# ============================================================\r\n\r\n\r\nclass DeviceManager:\r\n    \"\"\"�豸��������"}],"details":{"status":"completed","exitCode":0,"durationMs":470,"aggregated":"\"\"\"\r\nAstroHub v2.0 - �豸������\r\n\r\n�豸ע�ᡢ״̬׷�١�������������ñ���/�ָ���\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport json\r\nimport threading\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom pathlib import Path\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel, Field\r\n\r\nfrom src.config import CONFIG_DIR\r\nfrom src.config_paths import DEVICES_DIR, REGISTRY_FILE\r\nfrom src.logger import get_logger\r\n\r\nlog = get_logger(\"device_manager\")\r\n\r\n# Time constants\r\nHEARTBEAT_TIMEOUT = 60  # �룬������ʱ������������Ϊ����\r\nCONFIG_BACKUP_DIR = CONFIG_DIR / \"device_backups\"\r\n\r\n\r\n# ============================================================\r\n# Data Models\r\n# ============================================================\r\n\r\n\r\nclass Device(BaseModel):\r\n    \"\"\"�豸��Ϣģ�͡�\"\"\"\r\n\r\n    mac: str\r\n    ip: str = \"\"\r\n    name: str = \"\"\r\n    model: str = \"\"\r\n    status: str = \"offline\"  # online | offline | error\r\n    registered_at: str = Field(default_factory=lambda: _now_iso())\r\n    last_heartbeat: str = Field(default_factory=lambda: _now_iso())