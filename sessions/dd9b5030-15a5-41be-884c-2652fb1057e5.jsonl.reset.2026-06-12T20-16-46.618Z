{"type":"message","id":"4586776d","parentId":"a6f962c9","timestamp":"2026-06-12T18:43:01.338Z","message":{"role":"assistant","content":[{"type":"text","text":"**现在快速连接不需要从 API 加载了，恢复简单逻辑：**"},{"type":"toolCall","id":"call_33094e1243c348d0b5657589","name":"edit","arguments":{"edits":[{"newText":"    // 快速连接函数（连接上次设备）\n    var _quickConnectSkipNext = false;\n    window.quickConnect = function(checked) {\n        // 防止程序化修改 checked 时触发循环\n        if (_quickConnectSkipNext) {\n            _quickConnectSkipNext = false;\n            return;\n        }\n        if (checked) {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                console.log('[QUICK] Already connected');\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            console.log('[QUICK] lastMac:', lastMac, 'allDevices:', window.allDevices ? window.allDevices.length : 'undefined');\n            \n            if (lastMac && window.allDevices && window.allDevices.length > 0) {\n                var normalizeMac = function(mac) {\n                    return (mac || '').replace(/[-:]/g, '').toLowerCase();\n                };\n                var targetMac = normalizeMac(lastMac);\n                \n                var dev = window.allDevices.find(function(d) {\n                    return normalizeMac(d.mac) === targetMac;\n                });\n                \n                if (dev && dev.ip) {\n                    console.log('[QUICK] Connecting to:', dev.ip);\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    _quickConnectSkipNext = true;\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', lastMac ? '设备列表为空' : '无上次连接记录');\n                _quickConnectSkipNext = true;\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };","oldText":"    // 快速连接函数（连接上次设备）\r\n    var _quickConnectSkipNext = false;\r\n    window.quickConnect = function(checked) {\r\n        // 防止程序化修改 checked 时触发循环\r\n        if (_quickConnectSkipNext) {\r\n            _quickConnectSkipNext = false;\r\n            return;\r\n        }\r\n        if (checked) {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                console.log('[QUICK] Already connected');\r\n                return;\r\n            }\r\n            \r\n            var lastMac = localStorage.getItem('lastConnectedMac');\r\n            console.log('[QUICK] lastMac:', lastMac, 'allDevices:', window.allDevices ? window.allDevices.length : 'undefined');\r\n            \r\n            // v6.16: 如果 allDevices 为空，先加载设备列表\r\n            if (!window.allDevices || window.allDevices.length === 0) {\r\n                console.log('[QUICK] allDevices empty, fetching...');\r\n                apiGet('/api/v1/devices').then(function(result) {\r\n                    if (result && result.success && result.data) {\r\n                        window.allDevices = result.data;\r\n                        console.log('[QUICK] loaded allDevices:', window.allDevices.length);\r\n                        // 递归调用，但跳过下一次 checked 修改\r\n                        _quickConnectSkipNext = true;\r\n                        document.getElementById('quickConnectSwitch').checked = true;\r\n                        window.quickConnect(true);\r\n                    } else {\r\n                        showToast('error', '无法加载设备列表');\r\n                        _quickConnectSkipNext = true;\r\n                        document.getElementById('quickConnectSwitch').checked = false;\r\n                    }\r\n                }).catch(function(e) {\r\n                    showToast('error', '加载设备列表失败');\r\n                    _quickConnectSkipNext = true;\r\n                    document.getElementById('quickConnectSwitch').checked = false;\r\n                });\r\n                return;\r\n            }\r\n            \r\n            if (lastMac) {\r\n                // v6.16: MAC 格式统一（去除分隔符）\r\n                var normalizeMac = function(mac) {\r\n                    return (mac || '').replace(/[-:]/g, '').toLowerCase();\r\n                };\r\n                var targetMac = normalizeMac(lastMac);\r\n                console.log('[QUICK] targetMac:', targetMac);\r\n                console.log('[QUICK] allDevices[0].mac:', window.allDevices[0] ? window.allDevices[0].mac : 'N/A');\r\n                \r\n                var dev = window.allDevices.find(function(d) {\r\n                    return normalizeMac(d.mac) === targetMac;\r\n                });\r\n                \r\n                console.log('[QUICK] found dev:', dev ? dev.ip : 'null');\r\n                \r\n                if (dev && dev.ip) {\r\n                    if (window.connectDevice) {\r\n                        window.connectDevice(dev.ip);\r\n                    }\r\n                } else {\r\n                    showToast('warning', '上次设备不在列表中');\r\n                    _quickConnectSkipNext = true;\r\n                    document.getElementById('quickConnectSwitch').checked = false;\r\n                }\r\n            } else {\r\n                showToast('warning', '无上次连接记录');\r\n                _quickConnectSkipNext = true;\r\n                document.getElementById('quickConnectSwitch').checked = false;\r\n            }\r\n        } else {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                disconnectDevice(window.connectedDevice.ip);\r\n            }\r\n        }\r\n    };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":143287,"output":1337,"cacheRead":0,"cacheWrite":0,"totalTokens":144624,"cost":{"input":0.143287,"output":0.004278400000000001,"cacheRead":0,"cacheWrite":0,"total":0.14756539999999999}},"stopReason":"toolUse","timestamp":1781289755812,"responseId":"cht000def85@dx19ebd24a69aba5d322"}}
