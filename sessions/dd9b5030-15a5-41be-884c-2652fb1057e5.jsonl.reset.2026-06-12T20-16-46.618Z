{"type":"message","id":"2dc635cb","parentId":"0bca4c3b","timestamp":"2026-06-12T15:51:51.118Z","message":{"role":"toolResult","toolCallId":"call_6a58e3fc0f7c441aabb1b629","toolName":"read","content":[{"type":"text","text":"        }\r\n        function wasmLogout() {\r\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\r\n            try {\r\n                // Stop playback first\r\n                if (g_bPlaying2) {\r\n                    WebVideoCtrl.I_Stop();\r\n                    g_bPlaying2 = false;\r\n                }\r\n                // Logout from device\r\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\r\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\r\n                }\r\n                // v5.47: Clear video window content\r\n                var container = document.getElementById('divPlugin');\r\n                if (container && window.WebVideoCtrl) {\r\n                    try {\r\n                        // 尝试清空视频窗口\r\n                        WebVideoCtrl.I_ClearWindowContent(0);\r\n                    } catch(e2) { console.warn('ClearWindow error:', e2); }\r\n                }\r\n            } catch(e) { console.warn('WASM logout error:', e); }\r\n            g_bLoggedIn2 = false;\r\n            g_szDeviceIdentify2 = ''; \r\n            g_bPlaying2 = false;\r\n            setLoginStatus('已登出', '#8b949e');\r\n            var loginBtn = document.getElementById('login-btn');\r\n            if (loginBtn) loginBtn.textContent = '登录';\r\n        }\r\n        // Inline helpers (no modal)\r\n        function addDeviceInline() {\r\n            var ip = prompt(\"\\u8bbe\\u5907 IP:\");\r\n            if (!ip) return;\r\n            apiPost(\"/api/v1/devices\", { ip: ip }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"\\u5df2\\u6dfb\\u52a0\"); refreshDevices(); }\r\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\r\n            }).catch(function(e) { showToast(\"error\", e.message); });\r\n        }\r\n        function modifyIpPrompt(mac, oldIp) {\r\n            var newIp = prompt(\"IP (MAC: \" + mac + \")\", oldIp);\r\n\n[465 more lines in file. Use offset=2160 to continue.]"}],"isError":false,"timestamp":1781279511118}}
{"type":"message","id":"cb29671c","parentId":"2dc635cb","timestamp":"2026-06-12T15:52:18.060Z","message":{"role":"assistant","content":[{"type":"text","text":"`wasmLogout` 已调用 `I_ClearWindowContent`，但可能需要更彻底的清理。添加背景色重置："},{"type":"toolCall","id":"call_1248e3a5f5db43c0b368715e","name":"edit","arguments":{"edits":[{"newText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v5.47: Clear video window content\n                var container = document.getElementById('divPlugin');\n                if (container && window.WebVideoCtrl) {\n                    try {\n                        // 尝试清空视频窗口\n                        WebVideoCtrl.I_ClearWindowContent(0);\n                    } catch(e2) { console.warn('ClearWindow error:', e2); }\n                }\n                // v6.12: 显示断开提示\n                if (container) {\n                    container.style.background = '#0d1117';\n                    container.innerHTML = '<div style=\"display:flex;align-items:center;justify-content:center;height:100%;color:#6e7681;font-size:14px\">画面已断开</div>';\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = ''; \n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n            \n            // v6.12: 更新 WASM 状态\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\n        }","oldText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v5.47: Clear video window content\n                var container = document.getElementById('divPlugin');\n                if (container && window.WebVideoCtrl) {\n                    try {\n                        // 尝试清空视频窗口\n                        WebVideoCtrl.I_ClearWindowContent(0);\n                    } catch(e2) { console.warn('ClearWindow error:', e2); }\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = ''; \n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n        }"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":118185,"output":770,"cacheRead":0,"cacheWrite":0,"totalTokens":118955,"cost":{"input":0.118185,"output":0.002464,"cacheRead":0,"cacheWrite":0,"total":0.12064899999999999}},"stopReason":"toolUse","timestamp":1781279511123,"responseId":"cht000ddf58@dx19ebc88747dba5b442"}}
