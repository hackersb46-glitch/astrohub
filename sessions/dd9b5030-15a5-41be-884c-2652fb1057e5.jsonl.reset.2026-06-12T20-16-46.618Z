egistry_file, \"w\", encoding=\"utf-8\") as f:\n+590                 json.dump(registry, f, indent=2, ensure_ascii=False)\n+591             \n 567             log.info(f\"设备数据已保存: {len(self._devices)} 台设备\")\n 568 \n 569     def _load(self) -> None:\n 570         \"\"\"从 JSON 文件加载设备数据。\n     ...","firstChangedLine":533},"isError":false,"timestamp":1781260763865}}
{"type":"message","id":"9e8a2d6e","parentId":"704766c0","timestamp":"2026-06-12T10:39:47.079Z","message":{"role":"assistant","content":[{"type":"text","text":"修改 `_load` 方法："},{"type":"toolCall","id":"call_e7e3ea8fc7e444318dbde4b4","name":"edit","arguments":{"edits":[{"newText":"    def _load(self) -> None:\n        \"\"\"v6.10: 从 devices/{mac}/info.json 加载设备数据。\"\"\"\n        if not self._devices_dir.exists():\n            log.info(f\"设备目录不存在，初始化空状态: {self._devices_dir}\")\n            return\n\n        try:\n            # 遍历所有设备目录\n            for info_file in self._devices_dir.rglob(\"info.json\"):\n                try:\n                    with open(info_file, \"r\", encoding=\"utf-8\") as f:\n                        dev_data = json.load(f)\n                    \n                    mac = _normalize_mac(dev_data.get(\"mac\", \"\"))\n                    if not mac:\n                        continue\n                    \n                    # 提取 metadata 字段\n                    metadata = {}\n                    for key in [\"username\", \"password\", \"port\", \"serial_number\", \"serial\", \"firmware_version\", \"connected\", \"last_updated\", \"network\", \"credentials\"]:\n                        if key in dev_data:\n                            metadata[key] = dev_data[key]\n\n                    # 构建 Device 对象\n                    dev = Device(\n                        mac=mac,\n                        ip=dev_data.get(\"ip\", \"\"),\n                        name=dev_data.get(\"name\", \"\"),\n                        model=dev_data.get(\"model\", \"\"),\n                        status=dev_data.get(\"status\", \"offline\"),\n                        metadata=metadata\n                    )\n                    self._devices[mac] = dev\n                except Exception as e:\n                    log.warning(f\"加载设备文件失败 {info_file}: {e}\")\n                    continue\n            \n            log.info(f\"加载设备数据: {len(self._devices)} 台设备\")\n\n        except Exception as e:\n            log.warning(f\"加载设备数据失败，使用空状态: {e}\")","oldText":"    def _load(self) -> None:\n        \"\"\"从 JSON 文件加载设备数据。\n\n        ptz_config.json 格式:\n        {\n            \"devices\": {\n                \"MAC\": {ip, username, password, port, model, ...}\n            }\n        }\n        \"\"\"\n        if not self._storage_path.exists():\n            log.info(f\"设备存储文件不存在，初始化空状态: {self._storage_path}\")\n            return\n\n        try:\n            with open(self._storage_path, \"r\", encoding=\"utf-8\") as f:\n                data = json.load(f)\n\n            # ptz_config.json 格式: devices 是 dict\n            devices_data = data.get(\"devices\", {})\n            if isinstance(devices_data, dict):\n                for mac, dev_data in devices_data.items():\n                    norm_mac = _normalize_mac(mac)\n                    # 提取 metadata 字段\n                    metadata = {}\n                    for key in [\"username\", \"password\", \"port\", \"serial_number\", \"serial\", \"firmware_version\", \"connected\", \"last_updated\"]:\n                        if key in dev_data:\n                            metadata[key] = dev_data[key]\n\n                    # 构建 Device 对象\n                    dev = Device(\n                        mac=norm_mac,\n                        ip=dev_data.get(\"ip\", \"\"),\n                        name=dev_data.get(\"name\", \"\"),\n                        model=dev_data.get(\"model\", \"\"),\n                        status=dev_data.get(\"status\", \"offline\"),\n                        metadata=metadata\n                    )\n                    self._devices[norm_mac] = dev\n                log.info(f\"加载设备数据: {len(self._devices)} 台设备\")\n            else:\n                # 旧格式兼容: devices 是数组\n                for d in devices_data:\n                    mac = _normalize_mac(d.get(\"mac\", \"\"))\n                    if mac:\n                        self._devices[mac] = Device(**d)\n                log.info(f\"加载设备数据(旧格式): {len(self._devices)} 台设备\")\n\n        except Exception as e:\n            log.warning(f\"加载设备数据失败，使用空状态: {e}\")"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\device_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":124350,"output":967,"cacheRead":0,"cacheWrite":0,"totalTokens":125317,"cost":{"input":0.12434999999999999,"output":0.0030944,"cacheRead":0,"cacheWrite":0,"total":0.12744439999999999}},"stopReason":"toolUse","timestamp":1781260763868,"responseId":"cht000d3eab@dx19ebb6a44aeba5a412"}}
