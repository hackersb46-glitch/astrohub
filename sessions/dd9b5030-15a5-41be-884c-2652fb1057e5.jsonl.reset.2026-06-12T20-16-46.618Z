{"type":"message","id":"1a6c58b5","parentId":"dd8c524c","timestamp":"2026-06-12T08:49:07.892Z","message":{"role":"toolResult","toolCallId":"tool-ef476281d14a46b582638dc4bc00c074","toolName":"read","content":[{"type":"text","text":"    log.info(\"=== AstroHub 所有管理器初始化完成 ===\")\r\n\r\n    # v5.48: 启动时执行一次 SADP 发现\r\n    try:\r\n        log.info(\"启动时 SADP 设备发现...\")\r\n        from src.core.sadp_discovery import SADPManager\r\n        sadp_mgr = SADPManager()\r\n        raw_devices = sadp_mgr.discover_devices(timeout=10)\r\n        if raw_devices:\r\n            log.info(f\"SADP 发现 {len(raw_devices)} 台设备\")\r\n        else:\r\n            log.info(\"SADP 未发现新设备\")\r\n    except Exception as e:\r\n        log.warning(f\"启动时 SADP 发现失败: {e}\")\r\n\r\n    yield\r\n\r\n    # ---- 关闭阶段 ----\r\n    log.info(\"=== AstroHub 关闭中 ===\")\r\n\r\n\n[385 more lines in file. Use offset=187 to continue.]"}],"isError":false,"timestamp":1781254147892}}
{"type":"message","id":"02476358","parentId":"1a6c58b5","timestamp":"2026-06-12T08:49:33.134Z","message":{"role":"assistant","content":[{"type":"text","text":"修改 SADP 发现逻辑，将网关信息合并到 ptz_config："},{"type":"toolCall","id":"tool-481c08984497482eb2610b2a0dcaf69a","name":"edit","arguments":{"edits":[{"newText":"    log.info(\"=== AstroHub 所有管理器初始化完成 ===\")\n\n    # v6.01: 启动时执行一次 SADP 发现，合并网关信息到 ptz_config\n    try:\n        log.info(\"启动时 SADP 设备发现...\")\n        from src.core.sadp_discovery import SADPManager\n        sadp_mgr = SADPManager()\n        raw_devices = sadp_mgr.discover_devices(timeout=10)\n        if raw_devices:\n            log.info(f\"SADP 发现 {len(raw_devices)} 台设备\")\n            # 合并网关信息到 ptz_config\n            ptz_cfg = ptz_mgr.config.load_ptz_config()\n            for d in raw_devices:\n                mac = d.get(\"mac\", \"\")\n                if mac and mac in ptz_cfg.get(\"devices\", {}):\n                    ptz_cfg[\"devices\"][mac][\"gateway\"] = d.get(\"gateway\", \"\")\n                    ptz_cfg[\"devices\"][mac][\"subnet_mask\"] = d.get(\"subnet_mask\", \"\")\n            ptz_mgr.config.save_ptz_config(ptz_cfg)\n            log.info(\"网关信息已合并到 ptz_config.json\")\n        else:\n            log.info(\"SADP 未发现新设备\")\n    except Exception as e:\n        log.warning(f\"启动时 SADP 发现失败: {e}\")\n\n    yield","oldText":"    log.info(\"=== AstroHub 所有管理器初始化完成 ===\")\n\n    # v5.48: 启动时执行一次 SADP 发现\n    try:\n        log.info(\"启动时 SADP 设备发现...\")\n        from src.core.sadp_discovery import SADPManager\n        sadp_mgr = SADPManager()\n        raw_devices = sadp_mgr.discover_devices(timeout=10)\n        if raw_devices:\n            log.info(f\"SADP 发现 {len(raw_devices)} 台设备\")\n        else:\n            log.info(\"SADP 未发现新设备\")\n    except Exception as e:\n        log.warning(f\"启动时 SADP 发现失败: {e}\")\n\n    yield"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\main.py"}}],"api":"openai-completions","provider":"zai"