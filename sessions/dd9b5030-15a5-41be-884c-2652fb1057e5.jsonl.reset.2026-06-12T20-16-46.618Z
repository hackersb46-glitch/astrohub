        apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: 'shutter-priority' });\n+799     }\n+800     \n 768     if (value === 'auto') {\n 769         apiPost('/api/v1/ptz/' + dev + '/image/shutter', { mode: 'auto' });\n 770     } else {\n 771         apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n     ...\n 779 function setIris(value) {\n 780     var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n 781     if (!dev || !value) return;\n 782     \n+816     // v5.46: 设置光圈前先确保曝光模式为 iris-priority 或 manual\n+817     var exposureSelect = document.getElementById('exposureMode');\n+818     var currentExposure = exposureSelect ? exposureSelect.value : 'auto';\n+819     if (currentExposure === 'auto') {\n+820         // 自动模式下切到光圈优先\n+821         if (exposureSelect) exposureSelect.value = 'iris-priority';\n+822         apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: 'iris-priority' });\n+823     }\n+824     \n 783     apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n 784         .then(function(r) {\n 785             if (r && r.success) {\n 786                 var select = document.getElementById('irisLevel');\n     ...","firstChangedLine":763},"isError":false,"timestamp":1781235118025}}
{"type":"message","id":"3ea35cad","parentId":"e3aa58bd","timestamp":"2026-06-12T03:32:05.743Z","message":{"role":"assistant","content":[{"type":"text","text":"添加曝光模式下拉菜单到 HTML："},{"type":"toolCall","id":"call_fddd27577c4046379ee3a8af","name":"edit","arguments":{"edits":[{"newText":"<!-- 曝光模式 (v5.46) -->\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\n                                        <label style=\"font-size:11px;color:#8b949e\">曝光模式</label>\n                                        <select id=\"exposureMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setExposureMode(this.value)\">\n                                            <option value=\"auto\">自动</option>\n                                            <option value=\"manual\">手动</option>\n                                            <option value=\"shutter-priority\">快门优先</option>\n                                            <option value=\"iris-priority\">光圈优先</option>\n                                        </select>\n                                    </div>\n                                    <!-- 快门 -->","oldText":"<!-- 快门 -->"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":94615,"output":257,"cacheRead":0,"cacheWrite":0,"totalTokens":94872,"cost":{"input":0.09461499999999999,"output":0.0008224,"cacheRead":0,"cacheWrite":0,"total":0.09543739999999999}},"stopReason":"toolUse","timestamp":1781235118029,"responseId":"cht000df5d0@dx19eb9e2fe4dba5e412"}}
