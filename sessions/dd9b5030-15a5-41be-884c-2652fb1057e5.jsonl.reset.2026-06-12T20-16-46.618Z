{"type":"message","id":"5461d510","parentId":"c7108586","timestamp":"2026-06-12T08:11:38.433Z","message":{"role":"assistant","content":[{"type":"text","text":"WASM 登录使用 `WebVideoCtrl.I_Login`，这是浏览器端 SDK，无法在后端执行。但可以：\n1. 登录凭据从后端获取\n2. 登录状态在后端同步\n\n**修改策略：**\n- WASM 登录仍在前端（浏览器端 SDK）\n- 登录成功后通知后端\n- 刷新时从后端获取凭据自动登录\n\n检查 `restoreConnectionState` 是否已经返回凭据："},{"type":"toolCall","id":"call_183fb7420f214b0dab256899","name":"read","arguments":{"limit":30,"offset":235,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":69081,"output":147,"cacheRead":0,"cacheWrite":0,"totalTokens":69228,"cost":{"input":0.069081,"output":0.00047040000000000005,"cacheRead":0,"cacheWrite":0,"total":0.0695514}},"stopReason":"toolUse","timestamp":1781251889109,"responseId":"cht000d6c90@dx19ebae2e269ba5b442"}}
{"type":"message","id":"107067a3","parentId":"5461d510","timestamp":"2026-06-12T08:11:38.441Z","message":{"role":"toolResult","toolCallId":"call_183fb7420f214b0dab256899","toolName":"read","content":[{"type":"text","text":"        // v6.0: 从后端恢复连接状态\r\n        function restoreConnectionState() {\r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.connected && r.device) {\r\n                    window.connectedDevice = r.device;\r\n                    console.log('[v6.0] 已恢复连接:', r.device.ip);\r\n                }\r\n            }).catch(function(e) {\r\n                console.warn('[v6.0] 获取连接状态失败:', e);\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  Navigation\r\n        // ================================================================\r\n        function initNav() {\r\n            document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n                btn.addEventListener('click', function() {\r\n                    document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n                    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n                    btn.classList.add('active');\r\n                    document.getElementById('page-' + btn.getAttribute('data-page')).classList.add('active');\r\n                    if (btn.getAttribute('data-page') === 'devices') { refreshDevices(); }\r\n                    if (btn.getAttribute('data-page') === 'console') {\r\n                        refreshPtzDeviceList();\r\n                        loadWasmDevices();\r\n                        // Resize WASM player when console becomes visible\r\n                        setTimeout(function() {\r\n                            var container = document.getElementById('divPlugin');\r\n                            if (container && window.WebVideoCtrl) {\r\n                                try { WebVideoCtrl.I_Resize(container.offsetWidth, container.offsetHeight); console.log('[WASM] Resized to', container.offsetWidth, container.offsetHeight); } catch(e) { console.warn('Resize error:', e); }\r\n\n[2309 more lines in file. Use offset=265 to continue.]"}],"isError":false,"timestamp":1781251898441}}
{"type":"message","id":"79136809","parentId":"107067a3","timestamp":"2026-06-12T08:12:01.453Z","message":{"role":"assistant","content":[{"type":"text","text":"后端 `/api/v1/ptz/connected` 已返回 `username/password/port`，可以在前端恢复连接后自动触发 WASM 登录："},{"type":"toolCall","id":"tool-c1f8145abd3d43ec803f96bd8f0b27ca","name":"edit","arguments":{"edits":[{"newText":"        // v6.0: 从后端恢复连接状态\n        function restoreConnectionState() {\n            apiGet('/api/v1/ptz/connected').then(function(r) {\n                if (r && r.success && r.connected && r.device) {\n                    window.connectedDevice = r.device;\n                    console.log('[v6.0] 已恢复连接:', r.device.ip);\n                    // v6.0: 自动触发 WASM 登录（凭据已从后端获取）\n                    if (window.clickLogin2 && r.device.username && r.device.password) {\n                        setTimeout(function() { window.clickLogin2(); }, 500);\n                    }\n                }\n            }).catch(function(e) {\n                console.warn('[v6.0] 获取连接状态失败:', e);\n            });\n        }","oldText":"        // v6.0: 从后端恢复连接状态\n        function restoreConnectionState() {\n            apiGet('/api/v1/ptz/connected').then(function(r) {\n                if (r && r.success && r.connected && r.device) {\n                    window.connectedDevice = r.device;\n                    console.log('[v6.0] 已恢复连接:', r.device.ip);\n                }\n            }).catch(function(e) {\n                console.warn('[v6.0] 获取连接状态失败:', e);\n            });\n        }"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":65718,"output":383,"cacheRead":0,"cacheWrite":0,"totalTokens":66101,"cost":{"input":0.065718,"output":0.0012256,"cacheRead":0,"cacheWrite":0,"total":0.06694359999999999}},"stopReason":"toolUse","timestamp":1781251898442,"responseId":"cht000d7a05@dx19ebae31108ba5c342"}}
{"type":"message","id":"9fed24c8","parentId":"79136809","timestamp":"2026-06-12T08:12:01.479Z","message":{"role":"toolResult","toolCallId":"tool-c1f8145abd3d43ec803f96bd8f0b27ca","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 1 block(s) in C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html."}],"details":{"diff":"      ...\n  237             apiGet('/api/v1/ptz/connected').then(function(r) {\n  238                 if (r && r.success && r.connected && r.device) {\n  239                     window.connectedDevice = r.device;\n  240                     console.log('[v6.0] 已恢复连接:', r.device.ip);\n+ 241                     // v6.0: 自动触发 WASM 登录（凭据已从后端获取）\n+ 242                     if (window.clickLogin2 && r.device.username && r.device.password) {\n+ 243                         setTimeout(function() { window.clickLogin2(); }, 500);\n+ 244                     }\n  241                 }\n  242             }).catch(function(e) {\n  243                 console.warn('[v6.0] 获取连接状态失败:', e);\n  244             });\n      ...","firstChangedLine":241},"isError":false,"timestamp":1781251921479}}
{"type":"message","id":"906a4151","parentId":"9fed24c8","timestamp":"2026-06-12T08:12:25.814Z","message":{"role":"assistant","content":[{"type":"text","text":"**Step 2：创建 E2E 测试**"},{"type":"toolCall","id":"call_2b57ec9cca4b475d94b66326","name":"write","arguments":{"content":"\"\"\"\nAstroHub v6.0 E2E 测试 - Playwright\n验证连接状态持久化和图像参数缓存功能\n\"\"\"\n\nimport asyncio\nfrom playwright.async_api import async_playwright\nimport time\n\nASTROHUB_URL = \"http://localhost:10280\"\n\nasync def test_v6_connection_state():\n    \"\"\"测试 v6.0 连接状态持久化\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print(\"[TEST] 1. 打开 AstroHub...\")\n        await page.goto(ASTROHUB_URL)\n        await page.wait_for_timeout(2000)\n        \n        # 检查版本号\n        version = await page.locator(\".version\").text_content()\n        print(f\"[TEST] 版本: {version}\")\n        assert version == \"v6.0\", f\"版本号错误: {version}\"\n        \n        # 检查设备列表是否加载\n        print(\"[TEST] 2. 检查设备列表...\")\n        await page.wait_for_selector(\"#deviceTableBody\", timeout=10000)\n        \n        # 刷新页面\n        print(\"[TEST] 3. 刷新页面...\")\n        await page.reload()\n        await page.wait_for_timeout(2000)\n        \n        # 检查连接状态是否恢复\n        print(\"[TEST] 4. 检查连接状态恢复...\")\n        connected = await page.evaluate(\"window.connectedDevice\")\n        print(f\"[TEST] 连接状态: {connected}\")\n        \n        # 截图\n        await page.screenshot(path=\"test_results/v6_screenshot.png\")\n        print(\"[TEST] 截图已保存: test_results/v6_screenshot.png\")\n        \n        await browser.close()\n        print(\"[TEST] 测试完成\")\n\nasync def test_api_connected():\n    \"\"\"测试 /api/v1/ptz/connected API\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        # 直接调用 API\n        print(\"[API TEST] 测试 /api/v1/ptz/connected...\")\n        response = await page.request.get(f\"{ASTROHUB_URL}/api/v1/ptz/connected\")\n        data = await response.json()\n        print(f\"[API TEST] 响应: {data}\")\n        \n        assert \"success\" in data\n        assert \"connected\" in data\n        \n        await browser.close()\n        print(\"[API TEST] API 测试完成\")\n\nasync def test_api_image_params():\n    \"\"\"测试 /api/v1/ptz/image-params API\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print(\"[API TEST] 测试 /api/v1/ptz/image-params...\")\n        response = await page.request.get(f\"{ASTROHUB_URL}/api/v1/ptz/image-params\")\n        data = await response.json()\n        print(f\"[API TEST] 响应: {data}\")\n        \n        await browser.close()\n        print(\"[API TEST] 图像参数 API 测试完成\")\n\nasync def main():\n    \"\"\"运行所有测试\"\"\"\n    import os\n    os.makedirs(\"test_results\", exist_ok=True)\n    \n    print(\"=\" * 50)\n    print(\"AstroHub v6.0 E2E 测试\")\n    print(\"=\" * 50)\n    \n    try:\n        await test_api_connected()\n        await test_api_image_params()\n        await test_v6_connection_state()\n        print(\"\\n[SUCCESS] 所有测试通过!\")\n    except Exception as e:\n        print(f\"\\n[FAILED] 测试失败: {e}\")\n        raise\n\nif __name__ == \"__main__\":\n    asyncio.run(main())\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_v6.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":70100,"output":877,"cacheRead":0,"cacheWrite":0,"totalTokens":70977,"cost":{"input":0.0701,"output":0.0028064,"cacheRead":0,"cacheWrite":0,"total":0.0729064}},"stopReason":"toolUse","timestamp":1781251921481,"responseId":"cht000d7d45@dx19ebae35addba5c342"}}
