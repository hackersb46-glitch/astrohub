{"type":"message","id":"e1c3cb86","parentId":"a7a1df21","timestamp":"2026-06-12T03:15:15.394Z","message":{"role":"toolResult","toolCallId":"tool-3ee3b56428e14684892ff21d2fee032b","toolName":"read","content":[{"type":"text","text":"        function renderFuncResults(results) {\r\n            var area = document.getElementById('funcResultArea');\r\n            var html = '<table class=\"result-table\"><thead><tr><th>功能</th><th>支持</th><th>最小值</th><th>最大值</th><th>当前值</th><th>状态</th></tr></thead><tbody>';\r\n            var keys = Object.keys(results);\r\n            if (keys.length === 0) {\r\n                html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">暂无结果</td></tr>';\r\n            } else {\r\n                keys.forEach(function(key) {\r\n                    var item = results[key];\r\n                    var supported = item.supported ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>';\r\n                    var status = item.status || '完成';\r\n                    html += '<tr>';\r\n                    html += '<td>' + key + '</td>';\r\n                    html += '<td>' + supported + '</td>';\r\n                    html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\r\n                    html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\r\n                    html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\r\n                    html += '<td><span class=\"badge yes\">' + status + '</span></td>';\r\n                    html += '</tr>';\r\n                });\r\n            }\r\n            html += '</tbody></table>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Limit Test (P6.0-P6.4)\r\n        // ================================================================\r\n        function limitTestRun() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnLimitRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('limitProgress').style.display = 'block';\r\n            document.getElementById('limitDirection').style.display = 'block';\r\n            document.getElementById('limitResultArea').innerHTML = '';\r\n            addLog('info', '限位测试开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/limit/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '限位测试完成');\r\n                    addLog('success', '限位测试完成: ' + (resp.message || ''));\r\n                    renderLimitResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '限位测试失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded simulation)\r\n            var limitProgText = document.getElementById('limitProgressText');\r\n            var limitProgBar = document.getElementById('limitProgressBar');\r\n            var limitDirEl = document.getElementById('limitDirection');\r\n            if (limitProgText) limitProgText.textContent = '测试中... 等待设备响应';\r\n            if (limitProgBar) limitProgBar.style.width = '30%';\r\n            if (limitDirEl) { limitDirEl.textContent = '当前方向: 初始化...'; limitDirEl.style.display = 'block'; }\r\n            // simulateProgress/simulateDirections REMOVED - hardcoded fake progress\r\n        }\r\n        function renderLimitResults(results) {\r\n            var area = document.getElementById('limitResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>限位测试结果</h4>';\r\n            // P axis\r\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">P轴限位</span><span class=\"status-value\">' + pLimit[0] + ' ~ ' + pLimit[1] + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">T轴限位</span><span class=\"status-value\">' + tLimit[0] + ' ~ ' + tLimit[1] + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">翻转</span><span class=\"status-value\">' + (results.flip ? '有' : '无') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">稳定性</span><span class=\"status-value\">' + (results.stable ? '<span class=\"badge yes\">✅ 稳定</span>' : '<span class=\"badge no\">❌ 不稳定</span>') + '</span></div>';\r\n            if (results.csv_path) {\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">CSV 路径</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\r\n            }\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Speed Test (P5.4 + M4 P3)\r\n        // ================================================================\r\n        function speedTestRun() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('speedProgress').style.display = 'block';\r\n            document.getElementById('speedResultArea').innerHTML = '';\r\n            addLog('info', '速度测试开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '速度测试完成');\r\n                    addLog('success', '速度测试完成: ' + (resp.message || ''));\r\n                    renderSpeedResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '速度测试失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded speed labels)\r\n            var speedProgText = document.getElementById('speedProgressText');\r\n            var speedProgBar = document.getElementById('speedProgressBar');\r\n            if (speedProgText) speedProgText.textContent = '测试中... 等待设备响应';\r\n            if (speedProgBar) speedProgBar.style.width = '30%';\r\n            // REMOVED simulateProgress (was hardcoded: '速度档位 1', '50', '100')\r\n            // Speed results now display actual values returned from backend\r\n        }\r\n        function renderSpeedResults(results) {\r\n            var area = document.getElementById('speedResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>速度测试结果</h4>';\r\n            // Speed mapping table\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            var mapKeys = Object.keys(speedMap);\r\n            if (mapKeys.length > 0) {\r\n                html += '<table class=\"result-table\" style=\"margin:12px 0\"><thead><tr><th>速度档位</th><th>实际速率 (°/s)</th></tr></thead><tbody>';\r\n                mapKeys.forEach(function(k) {\r\n                    html += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\r\n                });\r\n                html += '</tbody></table>';\r\n            }\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">拟合曲线 R²</span><span class=\"status-value\">' + (results.r_squared || results.r2 || '--') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">精度</span><span class=\"status-value\">' + (results.accuracy || '--') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">通过</span><span class=\"status-value\">' + (results.passed ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>') + '</span></div>';\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Progress Simulation\r\n        // ================================================================\r\n        function simulateProgress(textId, barId, totalSteps, labels) {\r\n            var current = 0;\r\n            var interval = setInterval(function() {\r\n                current++;\r\n                if (current > totalSteps) { clearInterval(interval); return; }\r\n                var pct = Math.round((current / totalSteps) * 100);\r\n                var textEl = document.getElementById(textId);\r\n                var barEl = document.getElementById(barId);\r\n                if (textEl) textEl.textContent = labels ? labels[current-1] : '处理中... ' + current + '/' + totalSteps;\r\n                if (barEl) barEl.style.width = pct + '%';\r\n            }, 2000);\r\n        }\r\n        function simulateDirections() {\r\n            var dirs = ['P+ 移动中...', 'P- 移动中...', 'T+ 移动中...', 'T- 移动中...'];\r\n            var i = 0;\r\n            var interval = setInterval(function() {\r\n                var el = document.getElementById('limitDirection');\r\n                if (!el) { clearInterval(interval); return; }\r\n                if (i >= dirs.length) { clearInterval(interval); el.textContent = '测试完成 ✓'; el.style.color = '#3fb950'; return; }\r\n                el.textContent = '当前方向: ' + dirs[i];\r\n                i++;\r\n            }, 3000);\r\n        }\r\n        // ================================================================\r\n        //  Connect Device Page (高级功能 -> 连接设备)\r\n        // ================================================================\r\n        function onConnectDeviceChange() {\r\n            var ip = document.getElementById('advConnectDevice').value;\r\n            var noDevice = document.getElementById('connectNoDevice');\r\n            var controlArea = document.getElementById('connectControlArea');\r\n            var statusSpan = document.getElementById('connectDeviceStatus');\r\n            if (ip) {\r\n                var device = allDevices.find(function(d) { return d.ip === ip; });\r\n                noDevice.style.display = 'none';\r\n                controlArea.style.display = 'block';\r\n                statusSpan.textContent = device ? ('已连接: ' + ip) : ip;\r\n            } else {\r\n                noDevice.style.display = 'block';\r\n\n[1950 more lines in file. Use offset=600 to continue.]"}],"isError":false,"timestamp":1781234115394}}
