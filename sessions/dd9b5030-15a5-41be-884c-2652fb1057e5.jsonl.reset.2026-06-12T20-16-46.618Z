{"type":"message","id":"64f4ceae","parentId":"c96a7b4a","timestamp":"2026-06-12T16:18:32.152Z","message":{"role":"assistant","content":[{"type":"text","text":"修改 `quickConnect` 函数，复用 `connectDevice`："},{"type":"toolCall","id":"call_3a9de34a4f734008972d6bcc","name":"edit","arguments":{"edits":[{"newText":"    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            // 如果已连接，无需操作\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            if (lastMac) {\n                // 查找设备 IP\n                var dev = (window.allDevices || []).find(function(d) { return d.mac === lastMac; });\n                if (dev && dev.ip) {\n                    // 复用 connectDevice 函数\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            // 断开连接\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };","oldText":"    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            var lastMac = localStorage.getItem('lastConnectedMac');\n            if (lastMac && window.connectedDevice && window.connectedDevice.ip) {\n                // 已连接，无需操作\n                return;\n            }\n            if (lastMac) {\n                // 尝试连接上次设备\n                showToast('info', '正在连接上次设备...');\n                apiPost('/api/v1/devices/' + lastMac + '/connect', null).then(function(r) {\n                    if (r && r.success) {\n                        showToast('success', '设备已连接: ' + r.ip);\n                        if (window.refreshDevices) refreshDevices();\n                    } else {\n                        showToast('error', r ? r.message : '连接失败');\n                        document.getElementById('quickConnectSwitch').checked = false;\n                    }\n                }).catch(function(e) {\n                    showToast('error', '连接异常: ' + e.message);\n                    document.getElementById('quickConnectSwitch').checked = false;\n                });\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            // 断开连接\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":149613,"output":662,"cacheRead":0,"cacheWrite":0,"totalTokens":150275,"cost":{"input":0.149613,"output":0.0021184000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1517314}},"stopReason":"toolUse","timestamp":1781281084209,"responseId":"cht000dfe70@dx19ebca08363ba5d322"}}
