{"type":"message","id":"63685aaf","parentId":"7571046a","timestamp":"2026-06-12T03:41:56.129Z","message":{"role":"assistant","content":[{"type":"text","text":"添加更新快门光圈状态的函数："},{"type":"toolCall","id":"tool-3470daf4c50f48f7b8995014a2959af5","name":"edit","arguments":{"edits":[{"newText":"// 设置曝光模式\nfunction setExposureMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '曝光模式: ' + (mode === 'manual' ? '手动' : '自动'));\n        });\n    // v5.47: 自动模式下禁用快门光圈\n    updateShutterIrisState();\n}\n\n// v5.47: 更新快门光圈禁用状态\nfunction updateShutterIrisState() {\n    var exposureMode = document.getElementById('exposureMode');\n    var shutterSelect = document.getElementById('shutterSpeed');\n    var irisSelect = document.getElementById('irisLevel');\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\n    \n    var isManual = exposureMode.value === 'manual';\n    shutterSelect.disabled = !isManual;\n    irisSelect.disabled = !isManual;\n    \n    // 禁用时灰色样式\n    if (!isManual) {\n        shutterSelect.style.opacity = '0.5';\n        irisSelect.style.opacity = '0.5';\n    } else {\n        shutterSelect.style.opacity = '1';\n        irisSelect.style.opacity = '1';\n    }\n}","oldText":"// 设置曝光模式\nfunction setExposureMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '曝光模式: ' + mode);\n        });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":98537,"output":495,"cacheRead":0,"cacheWrite":0,"totalTokens":99032,"cost":{"input":0.098537,"output":0.0015840000000000001,"cacheRead":0,"cacheWrite":0,"total":0.100121}},"stopReason":"toolUse","timestamp":1781235696951,"responseId":"cht000d4178@dx19eb9ebd14bb8ab282"}}
