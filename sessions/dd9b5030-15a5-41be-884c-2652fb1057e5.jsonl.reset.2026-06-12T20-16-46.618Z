{"type":"message","id":"35855843","parentId":"a8e89c3d","timestamp":"2026-06-12T03:15:28.652Z","message":{"role":"toolResult","toolCallId":"tool-1544132d7386417899603b9af780169f","toolName":"read","content":[{"type":"text","text":"                sel.innerHTML = '<option value=\"\">-- 加载失败 --</option>';\r\n            });\r\n        }\r\n        function wasmLogout() {\r\n            if (!g_bLoggedIn2) return;\r\n            try {\r\n                // Stop playback and clear video window\r\n                if (g_bPlaying2) {\r\n                    WebVideoCtrl.I_Stop();\r\n                    g_bPlaying2 = false;\r\n                }\r\n                WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\r\n            } catch(e) { console.warn('WASM logout error:', e); }\r\n            g_bLoggedIn2 = false;\r\n            g_szDeviceIdentify2 = '';\r\n            g_bPlaying2 = false;\r\n            setLoginStatus('已登出', '#8b949e');\r\n            var loginBtn = document.getElementById('login-btn');\r\n            if (loginBtn) loginBtn.textContent = '登录';\r\n        }\r\n        // Inline helpers (no modal)\r\n        function addDeviceInline() {\r\n            var ip = prompt(\"\\u8bbe\\u5907 IP:\");\r\n            if (!ip) return;\r\n            apiPost(\"/api/v1/devices\", { ip: ip }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"\\u5df2\\u6dfb\\u52a0\"); refreshDevices(); }\r\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\r\n            }).catch(function(e) { showToast(\"error\", e.message); });\r\n        }\r\n        function modifyIpPrompt(mac, oldIp) {\r\n            var newIp = prompt(\"IP (MAC: \" + mac + \")\", oldIp);\r\n            if (!newIp || newIp === oldIp) return;\r\n            apiPost(\"/api/v1/devices/\" + oldIp, { ip: newIp, mac: mac }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"IP \\u5df2\\u4fee\\u6539\"); refreshDevices(); }\r\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\r\n            }).catch(function(e) { showToast(\"error\", e.message); });\r\n        }\r\n        function showDeviceInfoInline(ip) {\r\n            var el = document.getElementById(\"deviceInfoPanel\");\r\n            if (!el) return;\r\n            el.style.display = \"block\";\r\n            el.innerHTML = \"\\u83b7\\u53d6\\u4e2d...\";\r\n            apiGet(\"/api/v1/devices/\" + ip + \"/info\").then(function(info) {\r\n                if (info && info.success) {\r\n                    var d = info.data || {};\r\n                    el.innerHTML = Object.keys(d).map(function(k) { return \"<div><b>\" + k + \":</b> \" + d[k] + \"</div>\"; }).join(\"\");\r\n                } else el.innerHTML = \"\\u65e0\\u6cd5\\u83b7\\u53d6\";\r\n            }).catch(function() { el.innerHTML = \"\\u5931\\u8d25\"; });\r\n        }\r\n    })();\r\n</script>\r\n    <!-- WASM SDK Scripts -->\r\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js\"></script>\r\n<script>\r\n// MD5 shim for WASM SDK (after CryptoJS loaded)\r\nwindow.MD5 = function(str) { return CryptoJS.MD5(str).toString(); };\r\nconsole.log('[WASM] MD5 shim installed');\r\n</script>\r\n    <script src=\"static/websdk/wasm/jquery.min.js\"></script>\r\n    <script src=\"static/websdk/wasm/webVideoCtrl.js\"></script>\r\n    <script src=\"static/websdk/wasm/jsPlugin-3.0.0.min.js\"></script>\r\n    <script>\r\n    // WASM SDK Initialization (GLOBAL scope)\r\n    (function() {\r\n        function initWasm() {\r\n            var iRet = window.WebVideoCtrl.I_SupportNoPlugin();\r\n            console.log('[WASM] I_SupportNoPlugin:', iRet);\r\n            if (!iRet) {\r\n                console.error('[WASM] Browser does not support noPlugin mode');\r\n                return;\r\n            }\r\n            WebVideoCtrl.I_InitPlugin(\"100%\", \"100%\", {\r\n                szId: \"divPlugin\",\r\n                bWndFull: true,\r\n                iPackageType: 2,\r\n                iWndowType: 1,\r\n                bNoPlugin: true,\r\n                proxyAddress: {\r\n                    ip: window.location.hostname,\r\n                    port: parseInt(window.location.port) || 80\r\n                },\r\n                proxyAddress: {\r\n                    ip: window.location.hostname,\r\n                    port: parseInt(window.location.port) || 80\r\n                },\r\n                cbEvent: function(iEventType, iParam1, iParam2) {\r\n                    console.log(\"[WASM] Event:\", iEventType, iParam1, iParam2);\r\n                },\r\n                cbDoubleClickWnd: function(iWndIndex, bFullScreen) {\r\n                    WebVideoCtrl.I_Stop();\r\n                },\r\n                cbSelWnd: function(xmlDoc) {\r\n                    g_iWndIndex = parseInt($(xmlDoc).find(\"SelectWnd\").eq(0).text(), 10);\r\n                },\r\n                cbInitPluginComplete: function() {\r\n                    console.log('[WASM] cbInitPluginComplete - inserting plugin');\r\n                    WebVideoCtrl.I_InsertOBJECTPlugin(\"divPlugin\");\r\n                    \r\n                    // Patch: fix oStreamClient.openStream URL parsing\r\n                    // SDK adds ?deviceIdentify=... to WS URL, but openStream's\r\n                    // parser can't handle query params in the path segment\r\n                    var _origOpenStream = null;\r\n                    try {\r\n                        var ds = WebVideoCtrl.w_deviceSet;\r\n                        if (ds && ds.length > 0) {\r\n                            // Will be patched after login when oStreamClient is available\r\n                        }\r\n                    } catch(e) {}\r\n                    \r\n                    // WASM SDK ready - trigger login if device already connected\r\n                    if (window.connectedDevice && window.connectedDevice.ip && window.clickLogin2) {\r\n                        console.log('[WASM] Device already connected, triggering login');\r\n                        window.clickLogin2();\r\n                    }\r\n                    // Update device status display\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                },\r\n                cbPluginErrorHandler: function(iWndIndex, iErrorCode, oError) {\r\n                    console.error('[WASM] Plugin error:', iWndIndex, iErrorCode);\r\n                },\r\n                cbPerformanceLack: function() {\r\n                    console.error('[WASM] Performance issue');\r\n                }\r\n            });\r\n            console.log('[WASM] I_InitPlugin called');\r\n        }\r\n        if (document.readyState === 'loading') {\r\n            document.addEventListener('DOMContentLoaded', initWasm);\r\n        } else {\r\n            initWasm();\r\n        }\r\n    })();\r\n</script>\r\n    <script>\r\n// WASM SDK global variables\r\nvar g_szDeviceIdentify = '';\r\nvar g_bLoggedIn = false;\r\nvar g_bPlaying = false;\r\nvar g_iRtspPort = 554;\r\nvar g_szDeviceIdentify2 = \"\";\r\nvar g_bLoggedIn2 = false;\r\nvar g_bPlaying2 = false;\r\nvar g_iRtspPort2 = 554;\r\nvar g_iWndIndex2 = 0;\r\nvar g_iWebSocketPort = 7681;\r\nvar g_iWndIndex = 0;\r\nvar g_iChannelList = [];\r\nvar g_iChannelID = 1;\r\nvar g_iChannelID = 1;\r\n// var connectedDevice = null; // Removed: conflicts with window.connectedDevice\r\n// WASM SDK global functions (simple version)\r\nfunction setLoginStatus(msg, color) {\r\n    var el = document.getElementById('login-status');\r\n    if (el) {\r\n        el.textContent = msg;\r\n        if (color) el.style.color = color;\r\n    }\r\n    console.log('[WASM] Status: ' + msg);\r\n}\r\nfunction clickLogin2() {\r\n    console.log('[CLICKLOGIN2] Called');\r\n    if (typeof ptzLog === 'function') ptzLog('WASM SDK 登录开始...', 'debug');\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        console.log('[WASM SDK] No device connected');\r\n        if (typeof ptzLog === 'function') ptzLog('未连接设备，无法登录', 'warning');\r\n        return;\r\n    }\r\n    console.log('[CLICKLOGIN2] Device IP: ' + window.connectedDevice.ip);\r\n    if (typeof ptzLog === 'function') ptzLog('连接设备: ' + window.connectedDevice.ip, 'info');\r\n    var szIP = window.connectedDevice.ip;\r\n    var szPort = window.connectedDevice.port || 80;\r\n    var szUsername = window.connectedDevice.username || 'admin';\r\n    var szPassword = window.connectedDevice.password || '';\r\n    g_szDeviceIdentify2 = szIP + '_' + szPort;\r\n    console.log('[WASM SDK] Login: ' + szIP + ':' + szPort);\r\n    \r\n    // 博客方案：I_Login\r\n    WebVideoCtrl.I_Login(szIP, 1, szPort, szUsername, szPassword, {\r\n        success: function(xmlDoc) {\r\n            g_bLoggedIn2 = true;\r\n            g_szDeviceIdentify2 = szIP + '_' + szPort;\r\n            console.log('[WASM SDK] Login success: ' + g_szDeviceIdentify2);\r\n            if (typeof ptzLog === 'function') ptzLog(szIP + ' 登录成功！', 'success');\r\n            if (window.showToast) window.showToast('success', '设备已连接: ' + szIP);\r\n            \r\n            // 博客方案：延迟500ms后执行 getDevicePort + getChannelInfo\r\n            setTimeout(() => {\r\n                // Step 1: getDevicePort\r\n                var oPort = WebVideoCtrl.I_GetDevicePort(g_szDeviceIdentify2);\r\n                console.log('[WASM SDK] GetDevicePort:', oPort);\r\n                if (oPort) {\r\n                    g_iRtspPort2 = oPort.iRtspPort || 554;\r\n                    g_iWebSocketPort = oPort.iWebSocketPort || 7681;\r\n                    if (typeof ptzLog === 'function') ptzLog('WebSocket端口: ' + g_iWebSocketPort, 'info');\r\n                    document.cookie = 'webVideoCtrlProxyWs=' + szIP + ':' + g_iWebSocketPort + '; path=/';\r\n                    document.cookie = 'webVideoCtrlProxyWsChannel=101; path=/';\r\n                }\r\n                \r\n                // Step 1.5: 异步获取 token 修复 szAuth（同步XHR被弃用）\r\n                var deviceSet = WebVideoCtrl.w_deviceSet;\r\n\n[250 more lines in file. Use offset=2300 to continue.]"}],"isError":false,"timestamp":1781234128651}}
