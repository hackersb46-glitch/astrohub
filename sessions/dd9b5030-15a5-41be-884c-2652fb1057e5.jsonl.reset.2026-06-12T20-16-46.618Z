{"type":"message","id":"e3be71e4","parentId":"9ad708d6","timestamp":"2026-06-12T15:53:06.276Z","message":{"role":"toolResult","toolCallId":"call_9b5eaccf928e42ab88de619b","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 1 block(s) in C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html."}],"details":{"diff":"      ...\n   16         .status-dot { width:8px; height:8px; border-radius:50%; }\n   17         .status-dot.green { background:#3fb950; box-shadow:0 0 6px #3fb950; }\n   18         .status-dot.yellow { background:#d29922; box-shadow:0 0 6px #d29922; }\n   19         .status-dot.red { background:#f85149; box-shadow:0 0 6px #f85149; }\n+  20         /* 开关样式 */\n+  21         .switch { position:relative; display:inline-block; width:36px; height:18px; }\n+  22         .switch input { opacity:0; width:0; height:0; }\n+  23         .slider { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background-color:#30363d; transition:.2s; border-radius:18px; }\n+  24         .slider:before { position:absolute; content:\"\"; height:12px; width:12px; left:3px; bottom:3px; background-color:#8b949e; transition:.2s; border-radius:50%; }\n+  25         input:checked + .slider { background-color:#238636; }\n+  26         input:checked + .slider:before { transform:translateX(18px); background-color:#fff; }\n   20         .nav { background:#161b22; padding:8px 24px; display:flex; gap:4px; align-items:center; border-bottom:1px solid #21262d; flex-wrap:wrap; }\n   21         .nav-btn { background:none; border:none; color:#8b949e; padding:8px 16px; cursor:pointer; border-radius:6px; font-size:14px; transition:all 0.2s; }\n   22         .nav-btn:hover { background:#21262d; color:#e0e6f0; }\n   23         .nav-btn.active { background:#238636; color:#fff; }\n      ...","firstChangedLine":20},"isError":false,"timestamp":1781279586276}}
{"type":"message","id":"3857161a","parentId":"e3be71e4","timestamp":"2026-06-12T15:53:33.610Z","message":{"role":"assistant","content":[{"type":"text","text":"添加快速连接和重启函数："},{"type":"toolCall","id":"call_658e65f6125f454ab648bcd9","name":"edit","arguments":{"edits":[{"newText":"    // WASM 状态更新函数\n    window.updateWasmStatus = function(state, text) {\n        var wasmDot = document.getElementById('wasmDot');\n        var wasmStatus = document.getElementById('wasmStatus');\n        if (!wasmDot || !wasmStatus) return;\n        \n        if (state === 'connecting') {\n            wasmDot.className = 'status-dot yellow';\n            wasmStatus.textContent = 'WASM: 连接中...';\n        } else if (state === 'connected') {\n            wasmDot.className = 'status-dot green';\n            wasmStatus.textContent = 'WASM: 已连接';\n        } else if (state === 'disconnected') {\n            wasmDot.className = 'status-dot red';\n            wasmStatus.textContent = 'WASM: 未连接';\n        }\n    };\n    \n    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            var lastMac = localStorage.getItem('lastConnectedMac');\n            if (lastMac && window.connectedDevice && window.connectedDevice.ip) {\n                // 已连接，无需操作\n                return;\n            }\n            if (lastMac) {\n                // 尝试连接上次设备\n                showToast('info', '正在连接上次设备...');\n                apiPost('/api/v1/devices/' + lastMac + '/connect', null).then(function(r) {\n                    if (r && r.success) {\n                        showToast('success', '设备已连接: ' + r.ip);\n                        if (window.refreshDevices) refreshDevices();\n                    } else {\n                        showToast('error', r ? r.message : '连接失败');\n                        document.getElementById('quickConnectSwitch').checked = false;\n                    }\n                }).catch(function(e) {\n                    showToast('error', '连接异常: ' + e.message);\n                    document.getElementById('quickConnectSwitch').checked = false;\n                });\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            // 断开连接\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };\n    \n    // 确认重启\n    window.confirmRestart = function() {\n        if (!confirm('确定要重启 AstroHub 吗？\\n重启期间服务将暂时不可用。')) return;\n        \n        showToast('info', '正在重启 AstroHub...');\n        \n        // 调用重启 API\n        apiPost('/api/v1/system/restart', null).then(function(r) {\n            if (r && r.success) {\n                showToast('success', '重启中，10秒后自动刷新页面...');\n                setTimeout(function() {\n                    location.reload();\n                }, 10000);\n            } else {\n                showToast('error', r ? r.message : '重启失败');\n            }\n        }).catch(function(e) {\n            // 即使请求失败，也假设重启成功（服务已停止）\n            showToast('warning', '重启中，10秒后自动刷新页面...');\n            setTimeout(function() {\n                location.reload();\n            }, 10000);\n        });\n    };","oldText":"    // WASM 状态更新函数\n    window.updateWasmStatus = function(state, text) {\n        var wasmDot = document.getElementById('wasmDot');\n        var wasmStatus = document.getElementById('wasmStatus');\n        if (!wasmDot || !wasmStatus) return;\n        \n        if (state === 'connecting') {\n            wasmDot.className = 'status-dot yellow';\n            wasmStatus.textContent = 'WASM: 连接中...';\n        } else if (state === 'connected') {\n            wasmDot.className = 'status-dot green';\n            wasmStatus.textContent = 'WASM: 已连接';\n        } else if (state === 'disconnected') {\n            wasmDot.className = 'status-dot red';\n            wasmStatus.textContent = 'WASM: 未连接';\n        }\n    };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":119838,"output":1004,"cacheRead":0,"cacheWrite":0,"totalTokens":120842,"cost":{"input":0.119838,"output":0.0032128000000000005,"cacheRead":0,"cacheWrite":0,"total":0.1230508}},"stopReason":"toolUse","timestamp":1781279586280,"responseId":"cht000df3b5@dx19ebc8987a4b85f582"}}
