{"type":"message","id":"c2414e02","parentId":"0184aaac","timestamp":"2026-06-12T17:43:29.508Z","message":{"role":"assistant","content":[{"type":"text","text":"**问题根源：`ptz_config.json` 和 `registry.json` 是两个不同的文件！**\n\n按文档规范：\n- `registry.json` 有 `active_device` 字段\n- `get_connected_device` 却读 `ptz_config.json`\n\n**修复：改为读 registry.json：**"},{"type":"toolCall","id":"call_3a3e815a17f54355aaba135f","name":"edit","arguments":{"edits":[{"newText":"    def get_connected_device(self) -> dict | None:\n        \"\"\"v6.15: 从 registry.json 读取活跃设备信息。\"\"\"\n        import json\n        from src.config_paths import REGISTRY_FILE, DEVICES_DIR\n        \n        try:\n            # 读取 registry.json\n            if REGISTRY_FILE.exists():\n                registry = json.loads(REGISTRY_FILE.read_text(encoding='utf-8'))\n                active_mac = registry.get('active_device')\n                if not active_mac:\n                    return None\n                \n                # 从 devices/{mac}/info.json 读取设备详情\n                info_file = DEVICES_DIR / active_mac / 'info.json'\n                if info_file.exists():\n                    info = json.loads(info_file.read_text(encoding='utf-8'))\n                    return {\n                        'ip': info.get('ip'),\n                        'mac': active_mac,\n                        'name': info.get('name'),\n                        'model': info.get('model'),\n                        'username': info.get('credentials', {}).get('username'),\n                        'password': info.get('credentials', {}).get('password'),\n                        'port': info.get('port', 80),\n                        'device_name': info.get('device_name'),\n                    }\n        except Exception as e:\n            print(f'[PTZManager] get_connected_device error: {e}')\n        \n        return None","oldText":"    def get_connected_device(self) -> dict | None:\n        \"\"\"v6.0: 获取当前连接的设备信息（从 ptz_config.json）。\"\"\"\n        ptz_cfg = self.config.load_ptz_config()\n        devices = ptz_cfg.get(\"devices\", {})\n        for mac, dev in devices.items():\n            if dev.get(\"connected\"):\n                return {\n                    \"ip\": dev.get(\"ip\"),\n                    \"mac\": mac,\n                    \"name\": dev.get(\"name\"),\n                    \"model\": dev.get(\"model\"),\n                    \"username\": dev.get(\"username\"),\n                    \"password\": dev.get(\"password\"),\n                    \"port\": dev.get(\"port\", 80),\n                }\n        return None"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":63876,"output":605,"cacheRead":0,"cacheWrite":0,"totalTokens":64481,"cost":{"input":0.063876,"output":0.0019360000000000002,"cacheRead":0,"cacheWrite":0,"total":0.06581200000000001}},"stopReason":"toolUse","timestamp":1781286180686,"responseId":"cht000daba6@dx19ebcee1d12ba5b442"}}
