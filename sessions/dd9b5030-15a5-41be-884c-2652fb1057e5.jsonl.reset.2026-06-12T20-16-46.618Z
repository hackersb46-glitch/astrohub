{"type":"message","id":"e838d5da","parentId":"ea5acaad","timestamp":"2026-06-12T18:12:56.309Z","message":{"role":"assistant","content":[{"type":"text","text":"**问题根源：`quickConnect` 在 `allDevices` 为空时递归调用自己，但 `refreshDevices` 是异步的，可能在递归期间重复调用。**\n\n**修复：添加重试计数器，避免无限循环：**"},{"type":"toolCall","id":"call_9a57cbf471494625b44c89fb","name":"edit","arguments":{"edits":[{"newText":"    // 快速连接函数（连接上次设备）\n    window._quickConnectRetries = 0;\n    window.quickConnect = function(checked) {\n        if (checked) {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                console.log('[QUICK] Already connected');\n                window._quickConnectRetries = 0;\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            console.log('[QUICK] lastMac:', lastMac);\n            \n            if (lastMac) {\n                // 等待设备列表加载（最多重试3次）\n                if (!window.allDevices || window.allDevices.length === 0) {\n                    window._quickConnectRetries++;\n                    if (window._quickConnectRetries > 3) {\n                        showToast('error', '设备列表加载超时');\n                        document.getElementById('quickConnectSwitch').checked = false;\n                        window._quickConnectRetries = 0;\n                        return;\n                    }\n                    showToast('info', '等待设备列表加载...');\n                    setTimeout(function() { window.quickConnect(true); }, 500);\n                    return;\n                }\n                \n                window._quickConnectRetries = 0;\n                \n                // v6.16: MAC 格式统一（去除分隔符）\n                var normalizeMac = function(mac) {\n                    return (mac || '').replace(/[-:]/g, '').toLowerCase();\n                };\n                var targetMac = normalizeMac(lastMac);\n                \n                var dev = (window.allDevices || []).find(function(d) {\n                    return normalizeMac(d.mac) === targetMac;\n                });\n                \n                if (dev && dev.ip) {\n                    console.log('[QUICK] Found device:', dev.ip);\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            window._quickConnectRetries = 0;\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };","oldText":"    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                console.log('[QUICK] Already connected');\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            console.log('[QUICK] lastMac:', lastMac);\n            \n            if (lastMac) {\n                // 等待设备列表加载\n                if (!window.allDevices || window.allDevices.length === 0) {\n                    showToast('info', '等待设备列表加载...');\n                    setTimeout(function() { window.quickConnect(true); }, 500);\n                    return;\n                }\n                \n                // v6.15: MAC 格式统一（去除分隔符）\n                var normalizeMac = function(mac) {\n                    return (mac || '').replace(/[-:]/g, '').toLowerCase();\n                };\n                var targetMac = normalizeMac(lastMac);\n                \n                var dev = (window.allDevices || []).find(function(d) {\n                    return normalizeMac(d.mac) === targetMac;\n                });\n                \n                if (dev && dev.ip) {\n                    console.log('[QUICK] Found device:', dev.ip);\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":115507,"output":1074,"cacheRead":0,"cacheWrite":0,"totalTokens":116581,"cost":{"input":0.115507,"output":0.0034368000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1189438}},"stopReason":"toolUse","timestamp":1781287950754,"responseId":"cht000ea42b@dx19ebd09364cb893102"}}
