{"type":"message","id":"17c178f6","parentId":"9f73f177","timestamp":"2026-06-12T09:02:34.804Z","message":{"role":"assistant","content":[{"type":"text","text":"MAC 格式：ptz_config 用冒号大写，SADP 用横杠小写。修改合并逻辑："},{"type":"toolCall","id":"call_4f4a496630a84bb5aaf9f228","name":"edit","arguments":{"edits":[{"newText":"    # v6.01: 启动时执行一次 SADP 发现，合并网关信息到 ptz_config\n    try:\n        log.info(\"启动时 SADP 设备发现...\")\n        from src.core.sadp_discovery import SADPManager\n        sadp_mgr = SADPManager()\n        raw_devices = sadp_mgr.discover_devices(timeout=10)\n        ptz_mgr = _orchestrator.get_module(\"ptz\")\n        if raw_devices and ptz_mgr:\n            log.info(f\"SADP 发现 {len(raw_devices)} 台设备\")\n            ptz_cfg = ptz_mgr.config.load_ptz_config()\n            for d in raw_devices:\n                # 统一 MAC 格式为冒号大写\n                mac = d.get(\"mac\", \"\").replace(\"-\", \":\").upper()\n                if mac and mac in ptz_cfg.get(\"devices\", {}):\n                    ptz_cfg[\"devices\"][mac][\"gateway\"] = d.get(\"gateway\", \"\")\n                    ptz_cfg[\"devices\"][mac][\"subnet_mask\"] = d.get(\"subnet_mask\", \"\")\n            ptz_mgr.config.save_ptz_config(ptz_cfg)\n            log.info(\"网关信息已合并到 ptz_config.json\")\n        else:\n            log.info(\"SADP 未发现新设备\")\n    except Exception as e:\n        log.warning(f\"启动时 SADP 发现失败: {e}\")","oldText":"    # v6.01: 启动时执行一次 SADP 发现，合并网关信息到 ptz_config\n    try:\n        log.info(\"启动时 SADP 设备发现...\")\n        from src.core.sadp_discovery import SADPManager\n        sadp_mgr = SADPManager()\n        raw_devices = sadp_mgr.discover_devices(timeout=10)\n        ptz_mgr = _orchestrator.get_module(\"ptz\")\n        if raw_devices and ptz_mgr:\n            log.info(f\"SADP 发现 {len(raw_devices)} 台设备\")\n            ptz_cfg = ptz_mgr.config.load_ptz_config()\n            for d in raw_devices:\n                mac = d.get(\"mac\", \"\")\n                if mac and mac in ptz_cfg.get(\"devices\", {}):\n                    ptz_cfg[\"devices\"][mac][\"gateway\"] = d.get(\"gateway\", \"\")\n                    ptz_cfg[\"devices\"][mac][\"subnet_mask\"] = d.get(\"subnet_mask\", \"\")\n            ptz_mgr.config.save_ptz_config(ptz_cfg)\n            log.info(\"网关信息已合并到 ptz_config.json\")\n        else:\n            log.info(\"SADP 未发现新设备\")\n    except Exception as e:\n        log.warning(f\"启动时 SADP 发现失败: {e}\")"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\main\\main.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":110184,"output":719,"cacheRead":0,"cacheWrite":0,"totalTokens":110903,"cost":{"input":0.11018399999999999,"output":0.0023008000000000004,"cacheRead":0,"cacheWrite":0,"total":0.1124848}},"stopReason":"toolUse","timestamp":1781254905977,"responseId":"cht000da48e@dx19ebb111270ba60352"}}
