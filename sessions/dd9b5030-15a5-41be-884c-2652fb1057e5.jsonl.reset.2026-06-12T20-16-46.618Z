{"type":"message","id":"f77f2ac5","parentId":"836a1fd1","timestamp":"2026-06-12T08:26:37.582Z","message":{"role":"assistant","content":[{"type":"text","text":"API 正常工作！现在运行 E2E 测试："},{"type":"toolCall","id":"tool-bee5aa6cd30547d48b44c348b7b2a358","name":"edit","arguments":{"edits":[{"newText":"\"\"\"\nAstroHub v6.0 E2E 测试 - Playwright\n验证连接状态持久化功能\n\"\"\"\n\nimport asyncio\nfrom playwright.async_api import async_playwright\nimport os\n\nASTROHUB_URL = \"http://localhost:10280\"\n\ndefault_device = {\n    \"ip\": \"192.168.5.72\",\n    \"mac\": \"24:0F:9B:76:41:93\",\n    \"name\": \"4k 32X DC\",\n    \"model\": \"iDS-2DF8C832IXS-A\",\n    \"username\": \"admin\",\n    \"password\": \"Nftw1357\",\n    \"port\": 80\n}\n\nasync def test_api_connected():\n    \"\"\"测试 /api/v1/ptz/connected API\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print(\"[API TEST] 测试 /api/v1/ptz/connected...\")\n        response = await page.request.get(f\"{ASTROHUB_URL}/api/v1/ptz/connected\")\n        data = await response.json()\n        print(f\"[API TEST] 响应: {data}\")\n        \n        assert data.get(\"success\") == True\n        assert data.get(\"connected\") == True\n        assert data.get(\"device\") is not None\n        device = data[\"device\"]\n        assert device.get(\"ip\") == default_device[\"ip\"]\n        assert device.get(\"username\") == default_device[\"username\"]\n        print(\"[API TEST] ✓ API 测试通过\")\n        \n        await browser.close()\n\nasync def test_version():\n    \"\"\"测试版本号\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        page = await browser.new_page()\n        \n        print(\"[VERSION TEST] 打开 AstroHub...\")\n        await page.goto(ASTROHUB_URL)\n        await page.wait_for_timeout(2000)\n        \n        version = await page.locator(\".version\").text_content()\n        print(f\"[VERSION TEST] 版本: {version}\")\n        assert version == \"v6.0\"\n        print(\"[VERSION TEST] ✓ 版本测试通过\")\n        \n        await browser.close()\n\nasync def test_page_load():\n    \"\"\"测试页面加载\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False)\n        page = await browser.new_page()\n        \n        print(\"[PAGE TEST] 打开 AstroHub...\")\n        await page.goto(ASTROHUB_URL)\n        await page.wait_for_timeout(3000)\n        \n        # 截图\n        os.makedirs(\"test_results\", exist_ok=True)\n        await page.screenshot(path=\"test_results/v6_home.png\")\n        print(\"[PAGE TEST] 截图: test_results/v6_home.png\")\n        \n        await browser.close()\n        print(\"[PAGE TEST] ✓ 页面测试通过\")\n\nasync def main():\n    \"\"\"运行所有测试\"\"\"\n    print(\"=\" * 50)\n    print(\"AstroHub v6.0 E2E 测试\")\n    print(\"=\" * 50)\n    \n    try:\n        await test_api_connected()\n        await test_version()\n        await test_page_load()\n        print(\"\\n[SUCCESS] ✓ 所有测试通过!\")\n    except Exception as e:\n        print(f\"\\n[FAILED] ✗ 测试失败: {e}\")\n        raise\n\nif __name__ == \"__main__\":\n    asyncio.run(main())","oldText":"\"\"\"\nAstroHub v6.0 E2E 测试 - Playwright\n验证连接状态持久化和图像参数缓存功能\n\"\"\"\n\nimport asyncio\nfrom playwright.async_api import async_playwright\nimport time\n\nASTROHUB_URL = \"http://localhost:10280\"\n\nasync def test_v6_connection_state():\n    \"\"\"测试 v6.0 连接状态持久化\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print(\"[TEST] 1. 打开 AstroHub...\")\n        await page.goto(ASTROHUB_URL)\n        await page.wait_for_timeout(2000)\n        \n        # 检查版本号\n        version = await page.locator(\".version\").text_content()\n        print(f\"[TEST] 版本: {version}\")\n        assert version == \"v6.0\", f\"版本号错误: {version}\""}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_v6.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":85945,"output":1205,"cacheRead":0,"cacheWrite":0,"totalTokens":87150,"cost":{"input":0.085945,"output":0.0038560000000000005,"cacheRead":0,"cacheWrite":0,"total":0.08980099999999999}},"stopReason":"toolUse","timestamp":1781252753772,"responseId":"cht000d3e70@dx19ebaf01b87ba60352"}}
