{"type":"message","id":"cadf436f","parentId":"f1cd7703","timestamp":"2026-06-12T08:16:02.479Z","message":{"role":"assistant","content":[{"type":"text","text":"删除 router.py 中错误的缓存 API："},{"type":"toolCall","id":"tool-d2c042351688459b8bdee5a80a9e146c","name":"edit","arguments":{"edits":[{"newText":"# ================================================================\n#  v6.0 连接状态 API\n# ================================================================\n\n@api_router.get(\"/ptz/connected\", summary=\"获取已连接设备状态 (v6.0)\", tags=[\"PTZ\"])\nasync def get_connected_device() -> dict:\n    \"\"\"v6.0: 从 ptz_config.json 获取当前连接的设备信息。\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\", \"connected\": False}\n    device = mgr.get_connected_device()\n    if not device:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    return {\"success\": True, \"connected\": True, \"device\": device}\n","oldText":"# ================================================================\n#  v6.0 连接状态 API\n# ================================================================\n\n@api_router.get(\"/ptz/connected\", summary=\"获取已连接设备状态 (v6.0)\", tags=[\"PTZ\"])\nasync def get_connected_device() -> dict:\n    \"\"\"v6.0: 获取当前连接的设备信息和缓存的图像参数。\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\", \"connected\": False}\n    device = mgr.get_connected_device()\n    if not device:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    return {\"success\": True, \"connected\": True, \"device\": device}\n\n\n@api_router.get(\"/ptz/image-params\", summary=\"获取缓存图像参数 (v6.0)\", tags=[\"PTZ\"])\nasync def get_cached_image_params() -> dict:\n    \"\"\"v6.0: 获取缓存的图像参数，避免刷新后重新读取设备。\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n    device = mgr.get_connected_device()\n    if not device:\n        return {\"success\": False, \"message\": \"无已连接设备\"}\n    params = mgr.get_cached_image_params(device[\"ip\"])\n    return {\"success\": True, \"ip\": device[\"ip\"], \"params\": params}\n\n"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":76371,"output":658,"cacheRead":0,"cacheWrite":0,"totalTokens":77029,"cost":{"input":0.076371,"output":0.0021056,"cacheRead":0,"cacheWrite":0,"total":0.0784766}},"stopReason":"toolUse","timestamp":1781252140913,"responseId":"cht000dcff5@dx19ebae6c5f0b87f702"}}
