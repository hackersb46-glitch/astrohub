{"type":"message","id":"72114f2d","parentId":"ba3e2baf","timestamp":"2026-06-12T17:25:21.033Z","message":{"role":"toolResult","toolCallId":"tool-e573d4f76ba74d0585e1659966a19d28","toolName":"read","content":[{"type":"text","text":"function loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 检查 apiGet 是否可用\n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined, cannot load image params');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // v5.42: 先加载 function.json 获取参数范围\n    apiGet('/api/v1/ptz/' + deviceIp + '/function').then(function(r) {\n        if (r && r.success && r.data) {\n            deviceFunctionData = r.data;\n            console.log('[IMAGE] function.json loaded:', r.data.functions);\n        }\n    }).catch(function(e) {\n        console.warn('[IMAGE] function.json load failed:', e);\n    });\n    \n    // 加载曝光模式\n    loadExposure(deviceIp);\n    \n    // 加载 OSD 状态\n    loadOsdStatus(deviceIp);\n    \n    // 加载白平衡\n    loadWhiteBalance(deviceIp);\n    \n    // 加载降噪\n    loadNoiseReduce(deviceIp);\n    \n    // 加载快门\n    loadShutter(deviceIp);\n    \n    // 加载光圈\n    loadIris(deviceIp);\n    \n    // 加载锐度\n\n[580 more lines in file. Use offset=422 to continue.]"}],"isError":false,"timestamp":1781285121033}}
