{"type":"message","id":"93ed6ce8","parentId":"caa63ac1","timestamp":"2026-06-12T03:16:59.932Z","message":{"role":"toolResult","toolCallId":"call_0bbccffd1e4842e4b01da456","toolName":"read","content":[{"type":"text","text":"                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">时域降噪 <span id=\"dnrTemporalVal\">--</span></label>\n                                            <input type=\"range\" id=\"dnrTemporal\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setNoiseReduce('temporal', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 快门 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">快门速度</label>\n                                        <select id=\"shutterSpeed\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setShutterSpeed(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- 光圈 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">光圈控制</label>\n                                        <select id=\"irisLevel\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setIris(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <!-- OSD 控制 - v5.42: 合并为开关样式 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px;display:flex;justify-content:space-between;align-items:center\">\n                                        <label style=\"font-size:12px;margin:0\">OSD</label>\n                                        <div style=\"display:flex;gap:16px\">\n                                            <div style=\"display:flex;align-items:center;gap:4px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">PTZ</span>\n                                                <button class=\"btn btn-sm\" id=\"btnPtzOsd\" onclick=\"togglePtzOsdToggle()\" style=\"min-width:50px;padding:2px 8px\">关闭</button>\n                                            </div>\n                                            <div style=\"display:flex;align-items:center;gap:4px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">信息</span>\n                                                <button class=\"btn btn-sm\" id=\"btnInfoOsd\" onclick=\"toggleInfoOsdToggle()\" style=\"min-width:50px;padding:2px 8px\">关闭</button>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n<style>\n/* 折叠面板样式 */\n.collapsible-section {\n    background: #161b22;\n    border: 1px solid #21262d;\n    border-radius: 8px;\n    margin-bottom: 12px;\n    overflow: hidden;\n}\n.collapsible-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 10px 12px;\n    cursor: pointer;\n    background: #0d1117;\n    transition: background 0.2s;\n}\n.collapsible-header:hover {\n    background: #161b22;\n}\n.collapse-icon {\n    color: #8b949e;\n    font-size: 12px;\n    transition: transform 0.2s;\n}\n.collapsible-section.collapsed .collapse-icon {\n    transform: rotate(-90deg);\n}\n.collapsible-content {\n    padding: 12px;\n    max-height: 1000px;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out, padding 0.3s;\n}\n.collapsible-section.collapsed .collapsible-content {\n    max-height: 0;\n    padding: 0 12px;\n}\n.section-subtitle {\n    font-size: 12px;\n    color: #6e7681;\n    margin: 8px 0 4px;\n    padding-top: 8px;\n    border-top: 1px solid #21262d;\n}\n.section-subtitle:first-child {\n    border-top: none;\n    padding-top: 0;\n}\n</style>\n\n<script>\n// 等待 apiGet/apiPost 可用后再定义函数\n(function() {\n    // 检查 apiGet 是否已定义\n    if (typeof apiGet === 'undefined') {\n        console.warn('[CONSOLE] apiGet not yet defined, will retry on DOMContentLoaded');\n        document.addEventListener('DOMContentLoaded', function() {\n            // DOM 加载完成后重新执行\n            if (typeof apiGet !== 'undefined') {\n                console.log('[CONSOLE] apiGet now available');\n            }\n        });\n    }\n})();\n\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\nvar deviceFunctionData = null; // v5.42: 存储function.json数据\n\n// 连接设备时加载图像参数（从function.json读取范围，从ISAPI读取当前值）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 检查 apiGet 是否可用\n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined, cannot load image params');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // v5.42: 先加载 function.json 获取参数范围\n    apiGet('/api/v1/ptz/' + deviceIp + '/function').then(function(r) {\n        if (r && r.success && r.data) {\n            deviceFunctionData = r.data;\n            console.log('[IMAGE] function.json loaded:', r.data.functions);\n        }\n    }).catch(function(e) {\n        console.warn('[IMAGE] function.json load failed:', e);\n    });\n    \n    // 加载 OSD 状态\n    loadOsdStatus(deviceIp);\n    \n    // 加载白平衡\n    loadWhiteBalance(deviceIp);\n    \n    // 加载降噪\n    loadNoiseReduce(deviceIp);\n    \n    // 加载快门\n    loadShutter(deviceIp);\n    \n    // 加载光圈\n    loadIris(deviceIp);\n    \n    // 加载锐度\n    loadSharpness(deviceIp);\n    \n    // 加载亮度/对比度/饱和度\n    loadColorParams(deviceIp);\n}\n\n// 加载 OSD 状态\nfunction loadOsdStatus(deviceIp) {\n    // PTZ OSD\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/ptz').then(function(r) {\n        if (r && r.success) {\n            var enabled = r.enabled || r.data?.enabled || false;\n            updatePtzOsdButtons(enabled);\n            // 保存到 localStorage\n            localStorage.setItem('osd_ptz_' + deviceIp, enabled ? '1' : '0');\n        } else {\n            // 从 localStorage 读取上次设置\n            var saved = localStorage.getItem('osd_ptz_' + deviceIp);\n            if (saved !== null) {\n                updatePtzOsdButtons(saved === '1');\n            }\n        }\n    }).catch(function(e) {\n        var saved = localStorage.getItem('osd_ptz_' + deviceIp);\n        if (saved !== null) {\n            updatePtzOsdButtons(saved === '1');\n        }\n    });\n    \n    // Info OSD\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/info').then(function(r) {\n        if (r && r.success) {\n            var enabled = r.enabled || r.data?.enabled || false;\n            updateInfoOsdButtons(enabled);\n            localStorage.setItem('osd_info_' + deviceIp, enabled ? '1' : '0');\n        } else {\n            var saved = localStorage.getItem('osd_info_' + deviceIp);\n            if (saved !== null) {\n                updateInfoOsdButtons(saved === '1');\n            }\n        }\n\n[464 more lines in file. Use offset=400 to continue.]"}],"isError":false,"timestamp":1781234219932}}
