{"type":"message","id":"99466933","parentId":"588547c2","timestamp":"2026-06-12T08:46:11.016Z","message":{"role":"toolResult","toolCallId":"call_35e012b4c6bd4b4489e78d84","toolName":"exec","content":[{"type":"text","text":"{\"success\":true,\"message\":\"���� 1 ̨�豸 (��ʱ 7.5s)\",\"devices\":[{\"mac\":\"24-0f-9b-76-41-93\",\"ip\":\"192.168.5.72\",\"subnet_mask\":\"255.255.255.0\",\"gateway\":\"192.168.5.1\",\"model\":\"iDS-2DF8C832IXS-A\",\"serial_number\":\"iDS-2DF8C832IXS-A20211211CCCHJ22538548\",\"device_name\":\"iDS-2DF8C832IXS-A\",\"firmware_version\":\"V5.8.0build 230208\",\"activated\":true,\"is_hikvision\":false,\"source\":\"sadp\"}],\"count\":1}"}],"details":{"status":"completed","exitCode":0,"durationMs":9946,"aggregated":"{\"success\":true,\"message\":\"���� 1 ̨�豸 (��ʱ 7.5s)\",\"devices\":[{\"mac\":\"24-0f-9b-76-41-93\",\"ip\":\"192.168.5.72\",\"subnet_mask\":\"255.255.255.0\",\"gateway\":\"192.168.5.1\",\"model\":\"iDS-2DF8C832IXS-A\",\"serial_number\":\"iDS-2DF8C832IXS-A20211211CCCHJ22538548\",\"device_name\":\"iDS-2DF8C832IXS-A\",\"firmware_version\":\"V5.8.0build 230208\",\"activated\":true,\"is_hikvision\":false,\"source\":\"sadp\"}],\"count\":1}","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781253971016}}
{"type":"message","id":"f11a8e31","parentId":"99466933","timestamp":"2026-06-12T08:46:27.724Z","message":{"role":"assistant","content":[{"type":"text","text":"SADP 发现返回了 `gateway`。问题是 `/api/v1/devices` 没有合并 SADP 数据。\n\n检查 `/api/v1/devices` 的实现："},{"type":"toolCall","id":"tool-68f5a556e90b4d6e863494c5b5c5adf0","name":"read","arguments":{"limit":80,"offset":260,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":99511,"output":81,"cacheRead":0,"cacheWrite":0,"totalTokens":99592,"cost":{"input":0.099511,"output":0.0002592,"cacheRead":0,"cacheWrite":0,"total":0.0997702}},"stopReason":"toolUse","timestamp":1781253971019,"responseId":"cht000d006c@dx19ebb02b08eb87f702"}}
{"type":"message","id":"9f1c4b09","parentId":"f11a8e31","timestamp":"2026-06-12T08:46:27.736Z","message":{"role":"toolResult","toolCallId":"tool-68f5a556e90b4d6e863494c5b5c5adf0","toolName":"read","content":[{"type":"text","text":"    if mgr:\r\n        devices = mgr.discover_devices(bind_ip=bind_ip)\r\n    else:\r\n        # 直接使用 SADPManager 不依赖 PTZManager\r\n        try:\r\n            from src.core.sadp_discovery import SADPManager\r\n            sadp_mgr = SADPManager()\r\n            raw_devices = sadp_mgr.discover_devices(timeout=10, bind_ip=bind_ip)\r\n            # 转换为 SADP 标准格式\r\n            devices = []\r\n            for d in raw_devices:\r\n                devices.append({\r\n                    \"mac\": d.get(\"mac\", \"\"),\r\n                    \"ip\": d.get(\"ip\", \"\"),\r\n                    \"subnet_mask\": d.get(\"subnet_mask\", \"\"),\r\n                    \"gateway\": d.get(\"gateway\", \"\"),\r\n                    \"model\": d.get(\"model\", \"\"),\r\n                    \"serial_number\": d.get(\"serial_number\", \"\"),\r\n                    \"device_name\": d.get(\"device_name\", \"\"),\r\n                    \"firmware_version\": d.get(\"firmware_version\", \"\"),\r\n                    \"activated\": d.get(\"activated\", False),\r\n                    \"is_hikvision\": d.get(\"is_hikvision\", False),\r\n                    \"source\": \"sadp\",\r\n                })\r\n        except Exception as e:\r\n            return {\"success\": False, \"message\": f\"SADP 发现异常: {e}\", \"devices\": []}\r\n    \r\n    elapsed = round(time.time() - start, 1)\r\n\r\n    # BUG-015 修复: 统一 MAC 地址格式为横杠小写 (24-0f-9b-76-41-93)\r\n    for dev in devices:\r\n        mac = dev.get(\"mac\", \"\")\r\n        if mac:\r\n            clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if len(clean) == 12:\r\n                dev[\"mac\"] = \"-\".join(clean[i:i+2] for i in range(0, 12, 2))\r\n\r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"发现 {len(devices)} 台设备 (耗时 {elapsed}s)\",\r\n        \"devices\": devices,\r\n        \"count\": len(devices),\r\n    }\r\n\r\n\r\n# ================================================================ #\r\n#  设备管理端点\r\n# ================================================================ #\r\n\r\n\r\n@api_router.get(\"/devices\", summary=\"设备列表\", tags=[\"Devices\"])\r\nasync def list_devices() -> dict:\r\n    \"\"\"获取设备列表（MAC 去重合并 SADP 发现 + 手动存储）.\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"data\": [], \"total\": 0}\r\n\r\n    def _normalize_mac(mac: str) -> str:\r\n        \"\"\"统一 MAC 为横杠小写格式 (aa-bb-cc-dd-ee-ff).\r\n\r\n        BUG-016 修复: 增强 MAC 格式校验，拒绝假 MAC 地址（如 IP 地址填入 MAC 字段）。\r\n        \"\"\"\r\n        import re\r\n        clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n        # 验证: 必须是恰好12位十六进制字符\r\n        if len(clean) != 12 or not re.match(r'^[0-9a-f]{12}$', clean):\r\n            return \"\"\r\n        return \"-\".join(clean[i:i + 2] for i in range(0, 12, 2))\r\n\r\n    def _has_device_mac(dev: dict) -> bool:\r\n        \"\"\"判断设备是否有有效 MAC.\"\"\"\r\n        return bool(_normalize_mac(dev.get(\"mac\", \"\") or \"\"))\r\n\r\n    stored = mgr.list_stored_devices()\r\n    discovered = mgr.get_discovered_devices()\r\n    online_ips = mgr.list_controllers()\r\n\r\n    # --- Pass 1: 存储设备按 MAC 建索引 ---\r\n    keyed: dict[str, dict[str, Any]] = {}  # normalized_mac -> merged_record\r\n    no_mac: list[dict[str, Any]] = []      # manual entry without MAC\r\n\n[2785 more lines in file. Use offset=340 to continue.]"}],"isError":false,"timestamp":1781253987736}}
{"type":"message","id":"1203bf29","parentId":"9f1c4b09","timestamp":"2026-06-12T08:46:45.225Z","message":{"role":"assistant","content":[{"type":"text","text":"检查 list_devices 如何合并数据："},{"type":"toolCall","id":"call_9a8755f505de400795ebfd04","name":"read","arguments":{"limit":80,"offset":340,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":107946,"output":52,"cacheRead":0,"cacheWrite":0,"totalTokens":107998,"cost":{"input":0.107946,"output":0.0001664,"cacheRead":0,"cacheWrite":0,"total":0.1081124}},"stopReason":"toolUse","timestamp":1781253987739,"responseId":"cht000dc127@dx19ebb02fc56b85e102"}}
{"type":"message","id":"58e27729","parentId":"1203bf29","timestamp":"2026-06-12T08:46:45.231Z","message":{"role":"toolResult","toolCallId":"call_9a8755f505de400795ebfd04","toolName":"read","content":[{"type":"text","text":"\r\n    for dev in stored:\r\n        mac_norm = _normalize_mac(dev.get(\"mac\", \"\") or \"\")\r\n        if mac_norm:\r\n            keyed[mac_norm] = {\r\n                \"mac\": mac_norm,\r\n                \"ip\": dev.get(\"ip\", \"\"),\r\n                \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),  # 用户设置的名称\r\n                \"model\": dev.get(\"model\", \"\"),  # 设备型号\r\n                \"source\": \"manual\",\r\n                \"online\": False,  # updated later\r\n                \"activated\": False,\r\n                \"has_credentials\": True,\r\n            }\r\n        else:\r\n            no_mac.append({\r\n                \"mac\": \"\",\r\n                \"ip\": dev.get(\"ip\", \"\"),\r\n                \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),\r\n                \"model\": dev.get(\"model\", \"\"),\r\n                \"source\": \"manual\",\r\n                \"online\": False,\r\n                \"activated\": False,\r\n                \"has_credentials\": True,\r\n            })\r\n\r\n    # --- Pass 2: 合并 SADP 发现设备 ---\r\n    for sadp in discovered:\r\n        sadp_mac = _normalize_mac(sadp.get(\"mac\", \"\") or \"\")\r\n        if sadp_mac and sadp_mac in keyed:\r\n            # 匹配到存储设备 → 合并\r\n            existing = keyed[sadp_mac]\r\n            existing[\"ip\"] = sadp.get(\"ip\") or existing[\"ip\"]\r\n            existing[\"model\"] = sadp.get(\"model\") or existing[\"model\"]\r\n            # name: 优先保留用户设置的名称，否则用 SADP 发现的\r\n            if not existing.get(\"name\"):\r\n                existing[\"name\"] = sadp.get(\"device_name\") or sadp.get(\"name\", \"\")\r\n            existing[\"activated\"] = sadp.get(\"activated\", False)\r\n            existing[\"gateway\"] = sadp.get(\"gateway\", \"\")\r\n            existing[\"subnet_mask\"] = sadp.get(\"subnet_mask\", \"\")\r\n            existing[\"source\"] = \"merged\"\r\n        elif sadp_mac:\r\n            # 新发现设备\r\n            keyed[sadp_mac] = {\r\n                \"mac\": sadp_mac,\r\n                \"ip\": sadp.get(\"ip\", \"\"),\r\n                \"name\": sadp.get(\"device_name\") or sadp.get(\"name\", \"\"),\r\n                \"model\": sadp.get(\"model\", \"\"),\r\n                \"source\": \"sadp\",\r\n                \"online\": False,\r\n                \"activated\": sadp.get(\"activated\", False),\r\n                \"has_credentials\": False,\r\n            }\r\n\r\n    # --- 构建最终列表 + 在线状态 ---\r\n    all_devices: list[dict[str, Any]] = list(keyed.values()) + no_mac\r\n    for dev in all_devices:\r\n        ip = dev.get(\"ip\", \"\")\r\n        dev[\"online\"] = ip in online_ips\r\n\r\n    return {\"success\": True, \"data\": all_devices, \"total\": len(all_devices)}\r\n\r\n\r\n@api_router.get(\"/devices/active\", summary=\"获取活跃设备\", tags=[\"Devices\"])\r\nasync def get_active_device() -> dict:\r\n    \"\"\"获取当前活跃设备（程序实例当前连接的设备）。\"\"\"\r\n    from src.advanced.device_config import get_current_device\r\n    \r\n    device = get_current_device()\r\n    if device is None:\r\n        return {\r\n            \"success\": False,\r\n            \"active\": False,\r\n            \"device\": None,\r\n            \"message\": \"未设置活跃设备\"\r\n        }\r\n    \r\n    return {\r\n        \"success\": True,\r\n        \"active\": True,\r\n\n[2705 more lines in file. Use offset=420 to continue.]"}],"isError":false,"timestamp":1781254005231}}
