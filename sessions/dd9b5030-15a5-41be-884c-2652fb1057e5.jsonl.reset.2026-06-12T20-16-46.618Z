{"type":"message","id":"851e5bbb","parentId":"9d7c3314","timestamp":"2026-06-12T15:46:01.323Z","message":{"role":"toolResult","toolCallId":"call_a64bb238b5fa403aa5e85e42","toolName":"read","content":[{"type":"text","text":"    window.updateDeviceStatus = function() {\r\n        var dot = document.getElementById('deviceDot');\r\n        var status = document.getElementById('deviceStatus');\r\n        var wsDot = document.getElementById('wsDot');\r\n        var wsStatus = document.getElementById('wsStatus');\r\n        \r\n        var connected = window.connectedDevice;\r\n        \r\n        // 获取显示名称：优先用户自定义名称，其次型号，最后 IP\r\n        function getDisplayName(dev) {\r\n            if (!dev) return '未知设备';\r\n            // name 是用户自定义名称\r\n            if (dev.name && dev.name.trim()) return dev.name.trim();\r\n            // device_name 是设备返回的名称\r\n            if (dev.device_name && dev.device_name.trim()) return dev.device_name.trim();\r\n            // 最后用 IP\r\n            return dev.ip || '未知设备';\r\n        }\r\n        \r\n        // 更新左侧设备状态\r\n        if (dot && status) {\r\n            if (connected) {\r\n                dot.className = 'status-dot green';\r\n                status.textContent = getDisplayName(connected);\r\n            } else {\r\n                dot.className = 'status-dot red';\r\n                status.textContent = '未连接';\r\n            }\r\n        }\r\n        \r\n        // 更新右上角状态\r\n        if (wsDot && wsStatus) {\r\n            if (connected) {\r\n                wsDot.className = 'status-dot green';\r\n                wsStatus.textContent = getDisplayName(connected);\r\n            } else {\r\n                wsDot.className = 'status-dot red';\r\n                wsStatus.textContent = '未连接';\r\n            }\r\n        }\r\n        \r\n        console.log('[UI] Status updated:', connected ? getDisplayName(connected) : 'none');\r\n    };\r\n    \r\n    // 页面切换函数\r\n    window.switchPage = function(page) {\r\n        document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n        document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n        document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\r\n        document.getElementById('page-' + page).classList.add('active');\r\n    };\r\n    \r\n    console.log('[GLOBAL v5.27] Functions ready');\r\n    </script>\r\n</body>\r\n</html>\r\n\r\n\r\n\r\n\r\n\n[3 more lines in file. Use offset=2576 to continue.]"}],"isError":false,"timestamp":1781279161323}}
{"type":"message","id":"4e4412b1","parentId":"851e5bbb","timestamp":"2026-06-12T15:46:57.280Z","message":{"role":"assistant","content":[{"type":"text","text":"添加 WASM 状态更新："},{"type":"toolCall","id":"call_5481d67bc5a744f6b5558eb3","name":"edit","arguments":{"edits":[{"newText":"    window.updateDeviceStatus = function() {\n        var dot = document.getElementById('deviceDot');\n        var status = document.getElementById('deviceStatus');\n        var wsDot = document.getElementById('wsDot');\n        var wsStatus = document.getElementById('wsStatus');\n        var wasmDot = document.getElementById('wasmDot');\n        var wasmStatus = document.getElementById('wasmStatus');\n        \n        var connected = window.connectedDevice;\n        \n        // 获取显示名称：优先用户自定义名称，其次型号，最后 IP\n        function getDisplayName(dev) {\n            if (!dev) return '未知设备';\n            if (dev.name && dev.name.trim()) return dev.name.trim();\n            if (dev.device_name && dev.device_name.trim()) return dev.device_name.trim();\n            return dev.ip || '未知设备';\n        }\n        \n        // 更新左侧设备状态\n        if (dot && status) {\n            if (connected) {\n                dot.className = 'status-dot green';\n                status.textContent = getDisplayName(connected);\n            } else {\n                dot.className = 'status-dot red';\n                status.textContent = '未连接';\n            }\n        }\n        \n        // 更新右上角状态\n        if (wsDot && wsStatus) {\n            if (connected) {\n                wsDot.className = 'status-dot green';\n                wsStatus.textContent = getDisplayName(connected);\n            } else {\n                wsDot.className = 'status-dot red';\n                wsStatus.textContent = '未连接';\n            }\n        }\n        \n        // WASM 状态（默认未连接，由 WASM 登录成功后更新）\n        if (wasmDot && wasmStatus) {\n            if (!connected) {\n                wasmDot.className = 'status-dot red';\n                wasmStatus.textContent = 'WASM: 未连接';\n            }\n        }\n        \n        console.log('[UI] Status updated:', connected ? getDisplayName(connected) : 'none');\n    };\n    \n    // WASM 状态更新函数\n    window.updateWasmStatus = function(state, text) {\n        var wasmDot = document.getElementById('wasmDot');\n        var wasmStatus = document.getElementById('wasmStatus');\n        if (!wasmDot || !wasmStatus) return;\n        \n        if (state === 'connecting') {\n            wasmDot.className = 'status-dot yellow';\n            wasmStatus.textContent = 'WASM: 连接中...';\n        } else if (state === 'connected') {\n            wasmDot.className = 'status-dot green';\n            wasmStatus.textContent = 'WASM: 已连接';\n        } else if (state === 'disconnected') {\n            wasmDot.className = 'status-dot red';\n            wasmStatus.textContent = 'WASM: 未连接';\n        }\n    };","oldText":"    window.updateDeviceStatus = function() {\n        var dot = document.getElementById('deviceDot');\n        var status = document.getElementById('deviceStatus');\n        var wsDot = document.getElementById('wsDot');\n        var wsStatus = document.getElementById('wsStatus');\n        \n        var connected = window.connectedDevice;\n        \n        // 获取显示名称：优先用户自定义名称，其次型号，最后 IP\n        function getDisplayName(dev) {\n            if (!dev) return '未知设备';\n            // name 是用户自定义名称\n            if (dev.name && dev.name.trim()) return dev.name.trim();\n            // device_name 是设备返回的名称\n            if (dev.device_name && dev.device_name.trim()) return dev.device_name.trim();\n            // 最后用 IP\n            return dev.ip || '未知设备';\n        }\n        \n        // 更新左侧设备状态\n        if (dot && status) {\n            if (connected) {\n                dot.className = 'status-dot green';\n                status.textContent = getDisplayName(connected);\n            } else {\n                dot.className = 'status-dot red';\n                status.textContent = '未连接';\n            }\n        }\n        \n        // 更新右上角状态\n        if (wsDot && wsStatus) {\n            if (connected) {\n                wsDot.className = 'status-dot green';\n                wsStatus.textContent = getDisplayName(connected);\n            } else {\n                wsDot.className = 'status-dot red';\n                wsStatus.textContent = '未连接';\n            }\n        }\n        \n        console.log('[UI] Status updated:', connected ? getDisplayName(connected) : 'none');\n    };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":105694,"output":1096,"cacheRead":0,"cacheWrite":0,"totalTokens":106790,"cost":{"input":0.105694,"output":0.0035072000000000002,"cacheRead":0,"cacheWrite":0,"total":0.1092012}},"stopReason":"toolUse","timestamp":1781279161327,"responseId":"cht000da2a2@dx19ebc83055bb91a742"}}
