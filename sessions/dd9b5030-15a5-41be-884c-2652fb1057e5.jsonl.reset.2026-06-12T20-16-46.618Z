{"type":"message","id":"ff99fecc","parentId":"1d343bfe","timestamp":"2026-06-12T11:07:32.065Z","message":{"role":"assistant","content":[{"type":"text","text":"创建简单的 Playwright 测试脚本："},{"type":"toolCall","id":"call_bd5f6a48fbaf4b50ab5cca6f","name":"exec","arguments":{"command":"cd C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub && python -c \"\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_astrohub():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        errors = []\n        \n        try:\n            # 1. 打开主页\n            print('[TEST] 打开主页...')\n            page.goto('http://localhost:10280/', timeout=10000)\n            page.wait_for_load_state('networkidle', timeout=15000)\n            print('[PASS] 主页加载成功')\n            \n            # 2. 检查版本号\n            version = page.locator('.version').text_content()\n            print(f'[INFO] 版本: {version}')\n            \n            # 3. 检查设备列表\n            print('[TEST] 切换到设备管理...')\n            page.click('button[data-page=\\\"devices\\\"]')\n            page.wait_for_timeout(1000)\n            \n            # 检查设备表格\n            rows = page.locator('#deviceTable tr').count()\n            print(f'[INFO] 设备行数: {rows}')\n            \n            if rows > 1:\n                print('[PASS] 设备列表显示正常')\n            else:\n                errors.append('设备列表为空')\n            \n            # 4. 连接设备\n            print('[TEST] 连接设备...')\n            # 找到连接按钮\n            connect_btn = page.locator('#deviceTable button:has-text(\\\"连接\\\")').first\n            if connect_btn.count() > 0:\n                connect_btn.click()\n                page.wait_for_timeout(3000)\n                \n                # 检查状态\n                status = page.locator('.status-dot').first.get_attribute('class')\n                print(f'[INFO] 连接状态: {status}')\n            else:\n                print('[WARN] 未找到连接按钮')\n  