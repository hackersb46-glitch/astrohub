                               window.connectedDevice = {\r\n                                    ip: targetDev.ip,\r\n                                    model: targetDev.model || '',\r\n                                    name: targetDev.name || '',\r\n                                    device_name: targetDev.device_name || '',\r\n                                    mac: targetDev.mac || '',\r\n                                    username: creds.username || 'admin',\r\n                                    password: creds.password || '',\r\n                                    port: creds.port || 80,\r\n                                    online: true\r\n                                };\r\n                                if (targetDev.mac) localStorage.setItem('lastConnectedMac', targetDev.mac);\r\n                                // Connect to backend\r\n                                apiPost('/api/v1/devices/' + targetDev.ip + '/connect', {\r\n                                    username: creds.username || 'admin',\r\n                                    password: creds.password || '',\r\n                                    port: creds.port || 80\r\n                                }).then(function(connResult) {\r\n                                    if (connResult && connResult.success) {\r\n                                        addLog('info', '自动恢复连接: ' + targetDev.ip);\r\n                                        refreshDevices();\r\n                                        refreshPtzDeviceList();\r\n                                    }\r\n                                }).catch(function(e) { console.warn('Auto-connect failed:', e); });\r\n                                if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                            }\r\n                        }).catch(function(e) { console.warn('Failed to fetch credentials:', e); });\r\n                    }\r\n                }\r\n                } // end if (!window._autoConnectDone)\r\n            }).catch(function(e) {\r\n                console.warn('Failed to refresh devices:', e);\r\n            });\r\n        }\r\n        function renderDevices(devices) {\r\n            var tb = document.getElementById('deviceTable');\r\n            if (!tb) return;\r\n            if (!devices.length) {\r\n                tb.innerHTML = '<tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">暂无设备</td></tr>';\r\n\n[1496 more lines in file. Use offset=1240 to continue.]"}],"isError":false,"timestamp":1781292612966}}
