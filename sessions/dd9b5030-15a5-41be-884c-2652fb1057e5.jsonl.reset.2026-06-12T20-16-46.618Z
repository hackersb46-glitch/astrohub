{"type":"message","id":"15217660","parentId":"4a80c4dd","timestamp":"2026-06-12T03:17:24.890Z","message":{"role":"toolResult","toolCallId":"call_28c545f44e0749819a9fcb9e","toolName":"read","content":[{"type":"text","text":"    \n    apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'Info OSD: ' + (enabled ? '显示' : '关闭'));\n        });\n}\n\n// v5.42: 开关式 OSD 切换\nvar ptzOsdEnabled = false;\nvar infoOsdEnabled = false;\n\nfunction togglePtzOsdToggle() {\n    ptzOsdEnabled = !ptzOsdEnabled;\n    var btn = document.getElementById('btnPtzOsd');\n    if (btn) {\n        btn.textContent = ptzOsdEnabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (ptzOsdEnabled ? 'btn-primary' : 'btn-secondary');\n    }\n    togglePtzOsd(ptzOsdEnabled);\n}\n\nfunction toggleInfoOsdToggle() {\n    infoOsdEnabled = !infoOsdEnabled;\n    var btn = document.getElementById('btnInfoOsd');\n    if (btn) {\n        btn.textContent = infoOsdEnabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (infoOsdEnabled ? 'btn-primary' : 'btn-secondary');\n    }\n    toggleInfoOsd(infoOsdEnabled);\n}\n\n// 更新按钮状态\nfunction updatePtzOsdButtons(enabled) {\n    ptzOsdEnabled = enabled;\n    var btn = document.getElementById('btnPtzOsd');\n    if (btn) {\n        btn.textContent = enabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (enabled ? 'btn-primary' : 'btn-secondary');\n    }\n}\n\nfunction updateInfoOsdButtons(enabled) {\n    infoOsdEnabled = enabled;\n    var btn = document.getElementById('btnInfoOsd');\n    if (btn) {\n        btn.textContent = enabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (enabled ? 'btn-primary' : 'btn-secondary');\n    }\n}\n\n// ==================== 暴露到全局 ====================\nwindow.toggleSection = toggleSection;\nwindow.loadDeviceImageParams = loadDeviceImageParams;\nwindow.setSharpness = setSharpness;\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\nwindow.setWhiteBalanceGain = setWhiteBalanceGain;\nwindow.setNoiseReduce = setNoiseReduce;\nwindow.setShutterSpeed = setShutterSpeed;\nwindow.setIris = setIris;\nwindow.togglePtzOsd = togglePtzOsd;\nwindow.toggleInfoOsd = toggleInfoOsd;\nwindow.updatePtzOsdButtons = updatePtzOsdButtons;\nwindow.updateInfoOsdButtons = updateInfoOsdButtons;\n</script>"}],"isError":false,"timestamp":1781234244890}}
