{"type":"message","id":"7d184768","parentId":"c9533dd7","timestamp":"2026-06-12T15:54:30.272Z","message":{"role":"assistant","content":[{"type":"text","text":"添加重启端点："},{"type":"toolCall","id":"call_4b574cd18fc0425d8172e0b5","name":"edit","arguments":{"edits":[{"newText":"        return {\"success\": True, \"enabled\": enabled}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"获取OSD异常: {e}\"}\n\n\n# ================================================================ #\n#  系统管理端点\n# ================================================================ #\n\n@api_router.post(\"/system/restart\", summary=\"重启 AstroHub\", tags=[\"System\"])\nasync def restart_astrohub() -> dict:\n    \"\"\"重启 AstroHub 服务。\"\"\"\n    import subprocess\n    import sys\n    import os\n    \n    try:\n        # 获取当前进程 PID\n        import psutil\n        current_pid = os.getpid()\n        \n        # 创建重启脚本\n        restart_cmd = f'''sleep 2 && cd \"{os.getcwd()}\" && python -m uvicorn src.main.main:app --host 0.0.0.0 --port 10280'''\n        \n        # 使用 subprocess 启动新进程\n        subprocess.Popen(restart_cmd, shell=True, cwd=os.getcwd())\n        \n        # 延迟后退出当前进程\n        import threading\n        def delayed_exit():\n            time.sleep(1)\n            os._exit(0)\n        threading.Thread(target=delayed_exit, daemon=True).start()\n        \n        return {\"success\": True, \"message\": \"重启中...\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"重启失败: {e}\"}","oldText":"        return {\"success\": True, \"enabled\": enabled}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"获取OSD异常: {e}\"}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":121981,"output":441,"cacheRead":0,"cacheWrite":0,"totalTokens":122422,"cost":{"input":0.12198099999999999,"output":0.0014112,"cacheRead":0,"cacheWrite":0,"total":0.1233922}},"stopReason":"toolUse","timestamp":1781279653780,"responseId":"cht000d2f86@dx19ebc8a90c1b87f702"}}
