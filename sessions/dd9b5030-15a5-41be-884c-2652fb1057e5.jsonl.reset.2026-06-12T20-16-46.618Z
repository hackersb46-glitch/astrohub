{"type":"message","id":"a04bf849","parentId":"676826a6","timestamp":"2026-06-12T10:54:43.797Z","message":{"role":"assistant","content":[{"type":"text","text":"修改 `_resolve_device_id_to_ip` 支持无分隔符 MAC："},{"type":"toolCall","id":"call_1bc321b99cfa48809f9838e4","name":"edit","arguments":{"edits":[{"newText":"def _resolve_device_id_to_ip(mgr: \"PTZManager\", device_id: str) -> str | None:\n    \"\"\"解析 device_id 为实际 IP 地址。\n\n    device_id 可能是 IP 地址或 MAC 地址。\n    - 如果是 IP: 直接返回\n    - 如果是 MAC: 从 SADP 发现缓存或已存储设备中查找 IP\n    \"\"\"\n    import re\n    # 判断是否为 MAC 地址格式 (冒号、横杠分隔或无分隔符)\n    mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\n    # 无分隔符12位十六进制 = MAC\n    if len(mac_clean) == 12 and re.match(r'^[0-9a-f]{12}$', mac_clean):\n        # 是 MAC 地址，尝试从发现缓存中查找\n        discovered = mgr.get_discovered_devices()\n        for dev in discovered:\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\n            if dev_mac == mac_clean:\n                return dev.get(\"ip\")\n        # 从已存储设备中查找\n        stored = mgr.list_stored_devices()\n        for dev in stored:\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\n            if dev_mac == mac_clean:\n                ip = dev.get(\"ip\", \"\")\n                if ip:\n                    return ip\n        return None\n    # 看起来像 IP 地址，直接返回\n    return device_id","oldText":"def _resolve_device_id_to_ip(mgr: \"PTZManager\", device_id: str) -> str | None:\n    \"\"\"解析 device_id 为实际 IP 地址。\n\n    device_id 可能是 IP 地址或 MAC 地址。\n    - 如果是 IP: 直接返回\n    - 如果是 MAC: 从 SADP 发现缓存或已存储设备中查找 IP\n    \"\"\"\n    import re\n    # 判断是否为 MAC 地址格式 (冒号或横杠分隔的6组十六进制)\n    mac_pattern = re.compile(r\"^([0-9a-fA-F]{2}[:-]){5}[0-9a-fA-F]{2}$\")\n    if mac_pattern.match(device_id):\n        # BUG-016 修复: 额外验证 MAC 长度必须为12位十六进制\n        mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\n        if len(mac_clean) == 12 and re.match(r'^[0-9a-f]{12}$', mac_clean):\n            # 是 MAC 地址，尝试从发现缓存中查找\n            discovered = mgr.get_discovered_devices()\n            for dev in discovered:\n                dev_mac = dev.get(\"mac\", \"\").lower().replace(\":\", \"-\")\n                if dev_mac == device_id.lower().replace(\":\", \"-\"):\n                    return dev.get(\"ip\")\n            # 从已存储设备中查找\n            stored = mgr.list_stored_devices()\n            for dev in stored:\n                dev_mac = dev.get(\"mac\", \"\").lower().replace(\":\", \"-\")\n                if dev_mac == device_id.lower().replace(\":\", \"-\"):\n                    ip = dev.get(\"ip\", \"\")\n                    if ip:\n                        return ip\n        return None\n    # 看起来像 IP 地址，直接返回\n    return device_id"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":76929,"output":852,"cacheRead":0,"cacheWrite":0,"totalTokens":77781,"cost":{"input":0.076929,"output":0.0027264000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0796554}},"stopReason":"toolUse","timestamp":1781261662099,"responseId":"cht000de386@dx19ebb7802bdba5a412"}}
