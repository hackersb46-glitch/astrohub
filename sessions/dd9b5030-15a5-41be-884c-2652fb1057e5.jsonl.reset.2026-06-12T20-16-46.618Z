{"type":"message","id":"67f09186","parentId":"e44be7c2","timestamp":"2026-06-12T03:16:55.046Z","message":{"role":"toolResult","toolCallId":"call_bc651426d42b47a38cd8398a","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">未连接</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\n                <div class=\"console-layout\">\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\n                    <div class=\"console-left\">\n                        <!-- PTZ控制（折叠） -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- 指向控制 -->\n                                <div class=\"section-subtitle\">指向</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\n                                    <button class=\"ptz-btn center\">●</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>速度:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                                    <span id=\"ptzSpeedVal\">50</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- 预置点 -->\n                                <div class=\"section-subtitle\">预置点</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">选择预置点</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- 变焦/对焦 -->\n                                <div class=\"section-subtitle\">变焦/对焦</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">近</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">远</button>\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                                        <option value=\"manual\">手动</option>\n                                        <option value=\"auto\">自动</option>\n                                        <option value=\"semiauto\">半自动</option>\n                                    </select>\n                                </div>\n                            </div>\n                        </div>\n                        <!-- 跟踪控制 -->\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 中: 实时画面 + 媒体操作 -->\n                    <div class=\"console-center\">\n                        <!-- 实时画面 -->\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                        </div>\n                        <!-- 媒体操作（折叠，整合Live Stack + 码流） -->\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\n                                    <!-- 码流选择 -->\n                                    <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\n                                        <span style=\"color:#8b949e;font-size:13px\">码流:</span>\n                                        <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                                            <option value=\"1\">主码流</option>\n                                            <option value=\"2\" selected>子码流</option>\n                                            <option value=\"3\">第三码流</option>\n                                        </select>\n                                    </div>\n                                    <!-- 截图/录像 -->\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                                    </div>\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\n                                    <!-- Live Stack -->\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\n                                    </div>\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\n                                    </div>\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\n                                        <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\n                                    </div>\n                                    <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">叠加: 关闭</div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 右: 操作日志 + 画面控制 -->\n                    <div class=\"console-right\">\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto;max-height:200px\">\n                            <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\n                                <div style=\"color:#6e7681\">等待连接...</div>\n                            </div>\n                        </div>\n                        <!-- 画面控制（折叠，移到右侧） -->\n                        <div class=\"collapsible-section collapsed\" id=\"imageControlSection\" style=\"margin-top:12px\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('imageControlSection')\">\n                                <h3 style=\"font-size:15px;color:#d29922;margin:0\">🎨 画面控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div class=\"card\">\n                                    <!-- 基础调节 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">亮度</label>\n                                        <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('brightness', this.value)\">\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">对比度</label>\n                                        <input type=\"range\" id=\"consoleContrast\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('contrast', this.value)\">\n                                    </div>\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">饱和度</label>\n                                        <input type=\"range\" id=\"consoleSaturation\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"adjustImage('saturation', this.value)\">\n                                    </div>\n                                    <!-- 锐度 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">锐度 <span id=\"sharpnessRange\" style=\"color:#6e7681\"></span></label>\n                                        <input type=\"range\" id=\"consoleSharpness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" onchange=\"setSharpness(this.value)\">\n                                    </div>\n                                    <!-- 白平衡 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px\">\n                                        <label style=\"font-size:12px\">白平衡模式</label>[... 1968 more characters truncated]"}],"isError":false,"timestamp":1781234215046}}
