{"type":"message","id":"95a1a799","parentId":"d7b7db4b","timestamp":"2026-06-12T08:05:08.586Z","message":{"role":"toolResult","toolCallId":"tool-3a4fd870024a47dc9fed2241f87afb63","toolName":"read","content":[{"type":"text","text":"async def get_system_info() -> dict:\r\n    \"\"\"获取本机系统硬件信息 (hostname/CPU/RAM/GPU/VRAM)。\"\"\"\r\n    try:\r\n        from src.ptz.core.system_info import collect_system_info\r\n        info = collect_system_info()\r\n        return {\"success\": True, \"data\": info}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": str(e)}\r\n\r\n\r\n@api_router.get(\"/system/nics\", summary=\"网络接口列表 (P1.2)\", tags=[\"System\"])\r\nasync def get_nics() -> dict:\r\n    \"\"\"获取所有网络接口列表，按优先级排序。\"\"\"\r\n    try:\r\n        from src.core.net_detector import get_all_nics\r\n        nics = get_all_nics()\r\n        return {\"success\": True, \"data\": nics, \"total\": len(nics)}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": str(e)}\r\n\r\n\r\n@api_router.get(\"/system/default-ip\", summary=\"推荐目标 IP (P1.3)\", tags=[\"System\"])\r\nasync def get_default_ip() -> dict:\r\n    \"\"\"获取推荐的目标 IP 地址。\"\"\"\r\n    try:\r\n        from src.core.net_detector import suggest_target_ip\r\n        ip = suggest_target_ip()\r\n        return {\"success\": True, \"data\": {\"ip\": ip}}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": str(e)}\r\n\n[2410 more lines in file. Use offset=700 to continue.]"}],"isError":false,"timestamp":1781251508586}}
{"type":"message","id":"276895f6","parentId":"95a1a799","timestamp":"2026-06-12T08:05:23.778Z","message":{"role":"assistant","content":[{"type":"text","text":"在 `/system/info` 前添加连接状态 API："},{"type":"toolCall","id":"call_fe898243b10b41baac03a723","name":"edit","arguments":{"edits":[{"newText":"# ================================================================\n#  v6.0 连接状态 API\n# ================================================================\n\n@api_router.get(\"/ptz/connected\", summary=\"获取已连接设备状态 (v6.0)\", tags=[\"PTZ\"])\nasync def get_connected_device() -> dict:\n    \"\"\"v6.0: 获取当前连接的设备信息和缓存的图像参数。\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\", \"connected\": False}\n    device = mgr.get_connected_device()\n    if not device:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    return {\"success\": True, \"connected\": True, \"device\": device}\n\n\n@api_router.get(\"/ptz/image-params\", summary=\"获取缓存图像参数 (v6.0)\", tags=[\"PTZ\"])\nasync def get_cached_image_params() -> dict:\n    \"\"\"v6.0: 获取缓存的图像参数，避免刷新后重新读取设备。\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n    device = mgr.get_connected_device()\n    if not device:\n        return {\"success\": False, \"message\": \"无已连接设备\"}\n    params = mgr.get_cached_image_params(device[\"ip\"])\n    return {\"success\": True, \"ip\": device[\"ip\"], \"params\": params}\n\n\n@api_router.get(\"/system/info\", summary=\"系统硬件信息 (P1.1)\", tags=[\"System\"])\nasync def get_system_info() -> dict:","oldText":"@api_router.get(\"/system/info\", summary=\"系统硬件信息 (P1.1)\", tags=[\"System\"])\nasync def get_system_info() -> dict:"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"o