{"type":"message","id":"04f8877c","parentId":"622002b6","timestamp":"2026-06-12T10:43:34.344Z","message":{"role":"toolResult","toolCallId":"call_abf4fcfe36ed49f5a68b92d2","toolName":"exec","content":[{"type":"text","text":"media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-center, .console-right { width:100% !important; } }\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; }\n        .console-center { flex:1; min-width:0; display:flex; flex-direction:column; }\n        .console-right { flex:0 0 25%; max-width:300px; display:flex; flex-direction:column; }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <div class=\"logo\">Astro<span>Hub</span></div>\n        <div class=\"status-bar\">\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wsDot\"></span><span id=\"wsStatus\">未连接</span></div>\n            <div class=\"status-item\" id=\"clock\"></div>\n            <span class=\"version\">v6.10</span>\n        </div>\n    </div>\n    <div class=\"nav\">\n        <button class=\"nav-btn active\" data-page=\"dashboard\">仪表盘</button>\n        <button class=\"nav-btn\" data-page=\"devices\">设备管理</button>\n        <button class=\"nav-btn\" data-page=\"console\">主控台</button>\n        <button class=\"nav-btn\" data-page=\"observation\">观测计划</button>\n        <!-- Advanced Features: 校准 功能测试 限位测试 速度测试 推流/存储 -->\n        <button class=\"nav-btn\" data-page=\"advanced\">高级功能</button>\n        <button class=\"nav-btn\" data-page=\"replay\">回放</button>\n    </div>\n    <div class=\"main\">\n        <!-- ==================== 仪表盘 ==================== -->\n\n        <!-- ==================== Page Modules ==================== -->\n                <div class=\"page active\" id=\"page-dashboard\">\n            <div class=\"grid\">\n                <div class=\"card\">\n                    <div class=\"card-title\">PTZ 设备</div>\n                    <div class=\"card-value\" id=\"devCount\">0</div>\n                    <div class=\"card-sub\"><span id=\"devOnline\" style=\"font-size:16px;color:#3fb950\">0</span> 在线 / <span id=\"devTotal\" style=\"font-size:16px\">0</span> 总计</div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-title\">视频流</div>\n                    <div class=\"card-value\" id=\"streamCount\">0</div>\n                    <div class=\"card-sub\" id=\"streamStatus\">无活跃流</div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-title\">校准状态</div>\n                    <div class=\"card-value green\" id=\"calStatus\">就绪</div>\n                    <div class=\"card-sub\" id=\"calDetail\">上次校准: --</div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-title\">ASCOM</div>\n                    <div class=\"card-value\" id=\"ascomStatus\">未连接</div>\n                    <div class=\"card-sub\" id=\"ascomDetail\">0 个设备</div>\n                </div>\n            </div>\n            <div class=\"grid\">\n                <div class=\"card\"><div class=\"card-title\">CPU 使用率</div><div class=\"progress-bar\"><div class=\"progress-fill green\" id=\"cpuBar\" style=\"width:0%\"></div></div><div class=\"card-sub\" id=\"cpuVal\">0%</div></div>\n                <div class=\"card\"><div class=\"card-title\">内存使用率</div><div class=\"progress-bar\"><div class=\"progress-fill green\" id=\"memBar\" style=\"width:0%\"></div></div><div class=\"card-sub\" id=\"memVal\">0%</div></div>\n                <div class=\"card\"><div class=\"card-title\">磁盘使用率</div><div class=\"progress-bar\"><div class=\"progress-fill green\" id=\"diskBar\" style=\"width:0%\"></div></div><div class=\"card-sub\" id=\"diskVal\">0%</div></div>\n            </div>\n            <div style=\"font-size:18px;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid #21262d\">系统日志</div>\n            <div id=\"logContainer\" style=\"max-height:200px;overflow-y:auto\"><div class=\"log-entry info\">系统已就绪</div></div>\n        </div>\n        <!-- ==================== 设备管理 ==================== -->\n                <div class=\"page\" id=\"page-devices\">\n            <div class=\"toolbar\">\n                <h2 style=\"font-size:18px;margin:0\">设备列表</h2>\n                <div class=\"toolbar-actions\">\n                    <button class=\"btn btn-secondary\" id=\"btnDiscover\" onclick=\"discoverDevices()\">\n                        <span id=\"discoverSpinner\" class=\"spinner\" style=\"display:none\"></span>\n                        🔍 发现设备\n                    </button>\n                    <button class=\"btn btn-primary\" onclick=\"addDeviceInline()\">➕ 添加设备</button>\n                    <button class=\"btn btn-secondary\" onclick=\"refreshDevices()\">刷新</button>\n                </div>\n            </div>\n            <table>\n                <thead>\n                    <tr>\n                        <th>来源</th>\n                        <th>MAC</th>\n                        <th>IP</th>\n                        <th>网关</th>\n                        <th>名称</th>\n                        <th>型号</th>\n                        <th>状态</th>\n                        <th>操作</th>\n                    </tr>\n                </thead>\n                <tbody id=\"deviceTable\">\n                    <tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">暂无设备</td></tr>\n                </tbody>\n            </table>\n            <!-- 设备详细信息面板 -->\n            <div id=\"deviceInfoPanel\" class=\"device-info-panel\" style=\"display:none\"></div>\n        </div>\n        <!-- ==================== 主控台 ==================== -->\n                <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">未连接</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\n                <div class=\"console-layout\">\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\n                    <div class=\"console-left\">\n                        <!-- PTZ控制（折叠） -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- 指向控制 -->\n                                <div class=\"section-subtitle\">指向</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\n                                    <button class=\"ptz-btn center\">●</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>速度:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                                    <span id=\"ptzSpeedVal\">50</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- 预置点 -->\n                                <div class=\"section-subtitle\">预置点</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">选择预置点</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- 变焦/对焦 -->\n                                <div class=\"section-subtitle\">变焦/对焦</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">远</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">近</button>\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                                        <option value=\"manual\">手动</option>\n                                        <option value=\"auto\">自动</option>\n                                        <option value=\"semiauto\">半自动</option>\n                                    </select>\n                                </div>\n                            </div>\n                        </div>\n                        <!-- 跟踪控制 -->\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 中: 实时画面 + 媒体操作 -->\n                    <div class=\"console-center\">\n                        <!-- 实时画面 -->\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                        </div>\n                        <!-- 媒体操作（折叠，整合Live Stack + 码流） -->\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\n                                    <!-- 码流选择 -->\n                                    <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\n                                        <span style=\"color:#8b949e;font-size:13px\">码流:</span>\n                                        <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                                            <option value=\"1\">主码流</option>\n                                            <option value=\"2\" selected>子码流</option>\n                                            <option value=\"3\">第三码流</option>\n                                        </select>\n                                    </div>\n                                    <!-- 截图/录像 -->\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                                    </div>\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\n                                    <!-- Live Stack -->[... 184066 more characters truncated]"}],"details":{"status":"completed","exitCode":0,"durationMs":586,"aggregated":"media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-center, .console-right { width:100% !important; } }\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; }\n        .console-center { flex:1; min-width:0; display:flex; flex-direction:column; }\n        .console-right { flex:0 0 25%; max-width:300px; display:flex; flex-direction:column; }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <div class=\"logo\">Astro<span>Hub</span></div>\n        <div class=\"status-bar\">\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wsDot\"></span><span id=\"wsStatus\">未连接</span></div>\n            <div class=\"status-item\" id=\"clock\"></div>\n            <span class=\"version\">v6.10</span>\n        </div>\n    </div>\n    <div class=\"nav\">\n        <button class=\"nav-btn active\" data-page=\"dashboard\">仪表盘</button>\n        <button class=\"nav-btn\" data-page=\"devices\">设备管理</button>\n        <button class=\"nav-btn\" data-page=\"console\">主控台</button>\n        <button class=\"nav-btn\" data-page=\"observation\">观测计划</button>\n        <!-- Advanced Features: 校准 功能测试 限位测试 速度测试 推流/存储 -->\n        <button class=\"nav-btn\" data-page=\"advanced\">高级功能</button>\n        <button class=\"nav-btn\" data-page=\"replay\">回放</button>\n    </div>\n    <div class=\"main\">\n        <!-- ==================== 仪表盘 ==================== -->\n\n        <!-- ==================== Page Modules ==================== -->\n                <div class=\"page active\" id=\"page-dashboard\">\n            <div class=\"grid\">\n                <div class=\"card\">\n                    <div class=\"card-title\">PTZ 设备</div>\n                    <div class=\"card-value\" id=\"devCount\">0</div>\n                    <div class=\"card-sub\"><span id=\"devOnline\" style=\"font-size:16px;color:#3fb950\">0</span> 在线 / <span id=\"devTotal\" style=\"font-size:16px\">0</span> 总计</div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-title\">视频流</div>\n                    <div class=\"card-value\" id=\"streamCount\">0</div>\n                    <div class=\"card-sub\" id=\"streamStatus\">无活跃流</div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-title\">校准状态</div>\n                    <div class=\"card-value green\" id=\"calStatus\">就绪</div>\n                    <div class=\"card-sub\" id=\"calDetail\">上次校准: --</div>\n                </div>\n                <div class=\"card\">\n                    <div class=\"card-title\">ASCOM</div>\n                    <div class=\"card-value\" id=\"ascomStatus\">未连接</div>\n                    <div class=\"card-sub\" id=\"ascomDetail\">0 个设备</div>\n                </div>\n            </div>\n            <div class=\"grid\">\n                <div class=\"card\"><div class=\"card-title\">CPU 使用率</div><div class=\"progress-bar\"><div class=\"progress-fill green\" id=\"cpuBar\" style=\"width:0%\"></div></div><div class=\"card-sub\" id=\"cpuVal\">0%</div></div>\n                <div class=\"card\"><div class=\"card-title\">内存使用率</div><div class=\"progress-bar\"><div class=\"progress-fill green\" id=\"memBar\" style=\"width:0%\"></div></div><div class=\"card-sub\" id=\"memVal\">0%</div></div>\n                <div class=\"card\"><div class=\"card-title\">磁盘使用率</div><div class=\"progress-bar\"><div class=\"progress-fill green\" id=\"diskBar\" style=\"width:0%\"></div></div><div class=\"card-sub\" id=\"diskVal\">0%</div></div>\n            </div>\n            <div style=\"font-size:18px;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid #21262d\">系统日志</div>\n            <div id=\"logContainer\" style=\"max-height:200px;overflow-y:auto\"><div class=\"log-entry info\">系统已就绪</div></div>\n        </div>\n        <!-- ==================== 设备管理 ==================== -->\n                <div class=\"page\" id=\"page-devices\">\n            <div class=\"toolbar\">\n                <h2 style=\"font-size:18px;margin:0\">设备列表</h2>\n                <div class=\"toolbar-actions\">\n                    <button class=\"btn btn-secondary\" id=\"btnDiscover\" onclick=\"discoverDevices()\">\n                        <span id=\"discoverSpinner\" class=\"spinner\" style=\"display:none\"></span>\n                        🔍 发现设备\n                    </button>\n                    <button class=\"btn btn-primary\" onclick=\"addDeviceInline()\">➕ 添加设备</button>\n                    <button class=\"btn btn-secondary\" onclick=\"refreshDevices()\">刷新</button>\n                </div>\n            </div>\n            <table>\n                <thead>\n                    <tr>\n                        <th>来源</th>\n                        <th>MAC</th>\n                        <th>IP</th>\n                        <th>网关</th>\n                        <th>名称</th>\n                        <th>型号</th>\n                        <th>状态</th>\n                        <th>操作</th>\n                    </tr>\n                </thead>\n                <tbody id=\"deviceTable\">\n                    <tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">暂无设备</td></tr>\n                </tbody>\n            </table>\n            <!-- 设备详细信息面板 -->\n            <div id=\"deviceInfoPanel\" class=\"device-info-panel\" style=\"display:none\"></div>\n        </div>\n        <!-- ==================== 主控台 ==================== -->\n                <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">主控台</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">未连接</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\n                <div class=\"console-layout\">\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\n                    <div class=\"console-left\">\n                        <!-- PTZ控制（折叠） -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- 指向控制 -->\n                                <div class=\"section-subtitle\">指向</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\n                                    <button class=\"ptz-btn center\">●</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>速度:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                                    <span id=\"ptzSpeedVal\">50</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">归位</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">停止</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- 预置点 -->\n                                <div class=\"section-subtitle\">预置点</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">选择预置点</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- 变焦/对焦 -->\n                                <div class=\"section-subtitle\">变焦/对焦</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">远</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">近</button>\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\n                                        <option value=\"manual\">手动</option>\n                                        <option value=\"auto\">自动</option>\n                                        <option value=\"semiauto\">半自动</option>\n                                    </select>\n                                </div>\n                            </div>\n                        </div>\n                        <!-- 跟踪控制 -->\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 中: 实时画面 + 媒体操作 -->\n                    <div class=\"console-center\">\n                        <!-- 实时画面 -->\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\n                        </div>\n                        <!-- 媒体操作（折叠，整合Live Stack + 码流） -->\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\n                                    <!-- 码流选择 -->\n                                    <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\n                                        <span style=\"color:#8b949e;font-size:13px\">码流:</span>\n                                        <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\n                                            <option value=\"1\">主码流</option>\n                                            <option value=\"2\" selected>子码流</option>\n                                            <option value=\"3\">第三码流</option>\n                                        </select>\n                                    </div>\n                                    <!-- 截图/录像 -->\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\n                                    </div>\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\n                                    <!-- Live Stack -->\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\n                                    </div>\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\n                                    </div>\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\n                                        <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\n                                    </div>\n                                    <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">叠加: 关闭</div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <!-- 右: 操作日志 + 画面控制 -->\n                    <div class=\"console-right\">\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto;max-height:200px\">\n                            <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\n                                <div style=\"color:#6e7681\">等待连接...</div>\n                            </div>\n                        </div>\n                        <!-- 画面控制（折叠，移到右侧） -->\n                        <div class=\"collapsible-section collapsed\" id=\"imageControlSection\" style=\"margin-top:12px\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('imageControlSection')\">\n                                <h3 style=\"font-size:15px;color:#d29922;margin:0\">🎨 画面控制</h3>\n                                <span class=\"collapse-icon\">▼</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <div class=\"card\">\n                                    <!-- 基础调节 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">亮度 <span id=\"brightnessVal\" style=\"color:#58a6ff\">50</span></label>\n                                            <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('brightnessVal').textContent=this.value\" onchange=\"adjustImage('brightness', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">对比度 <span id=\"contrastVal\" style=\"color:#58a6ff\">50</span></label>\n                                            <input type=\"range\" id=\"consoleContrast\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('contrastVal').textContent=this.value\" onchange=\"adjustImage('contrast', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 饱和度 + 锐度 - v6.02: 合并同一行 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">饱和度 <span id=\"saturationVal\" style=\"color:#58a6ff\">50</span></label>\n                                            <input type=\"range\" id=\"consoleSaturation\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('saturationVal').textContent=this.value\" onchange=\"adjustImage('saturation', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">锐度 <span id=\"sharpnessVal\" style=\"color:#58a6ff\">50</span></label>\n                                            <input type=\"range\" id=\"consoleSharpness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('sharpnessVal').textContent=this.value\" onchange=\"setSharpness(this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 白平衡 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\n                                        <label style=\"font-size:11px;color:#8b949e\">白平衡模式</label>\n                                        <select id=\"wbMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setWhiteBalanceMode(this.value)\">\n                                            <option value=\"\">-- 加载中 --</option>\n                                        </select>\n                                    </div>\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#f85149\">R <span id=\"wbRedVal\" style=\"color:#f85149\">--</span></label>\n                                            <input type=\"range\" id=\"wbRed\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('wbRedVal').textContent=this.value\" onchange=\"setWhiteBalanceGain('red', this.value)\" disabled>\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#58a6ff\">B <span id=\"wbBlueVal\" style=\"color:#58a6ff\">--</span></label>\n                                            <input type=\"range\" id=\"wbBlue\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('wbBlueVal').textContent=this.value\" onchange=\"setWhiteBalanceGain('blue', this.value)\" disabled>\n                                        </div>\n                                    </div>\n                                    <!-- 降噪 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">空域降噪 <span id=\"dnrSpatialVal\" style=\"color:#58a6ff\">--</span></label>\n                                            <input type=\"range\" id=\"dnrSpatial\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('dnrSpatialVal').textContent=this.value\" onchange=\"setNoiseReduce('spatial', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">时域降噪 <span id=\"dnrTemporalVal\" style=\"color:#58a6ff\">--</span></label>\n                                            <input type=\"range\" id=\"dnrTemporal\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('dnrTemporalVal').textContent=this.value\" onchange=\"setNoiseReduce('temporal', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- 曝光模式 + 快门/光圈 (v5.47: 整合到一行) -->\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\n                                        <label style=\"font-size:11px;color:#8b949e\">曝光模式</label>\n                                        <select id=\"exposureMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setExposureMode(this.value);updateShutterIrisState()\">\n                                            <option value=\"auto\">自动</option>\n                                            <option value=\"manual\">手动</option>\n                                        </select>\n                                    </div>\n                                    <!-- 快门/光圈整合一行 -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">快门</label>\n                                            <select id=\"shutterSpeed\" style=\"width:100%;padding:3px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\" onchange=\"setShutterSpeed(this.value)\" disabled>\n                                                <option value=\"\">--</option>\n                                            </select>\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">光圈</label>\n                                            <select id=\"irisLevel\" style=\"width:100%;padding:3px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\" onchange=\"setIris(this.value)\" disabled>\n                                                <option value=\"\">--</option>\n                                            </select>\n                                        </div>\n                                    </div>\n                                    <!-- OSD 控制 - v6.02: 拨杆开关样式 -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px;display:flex;justify-content:space-between;align-items:center\">\n                                        <label style=\"font-size:12px;margin:0\">OSD</label>\n                                        <div style=\"display:flex;gap:16px\">\n                                            <div style=\"display:flex;align-items:center;gap:6px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">PTZ</span>\n                                                <label class=\"toggle-switch\">\n                                                    <input type=\"checkbox\" id=\"ptzOsdSwitch\" onchange=\"togglePtzOsdSwitch(this.checked)\">\n                                                    <span class=\"toggle-slider\"></span>\n                                                </label>\n                                            </div>\n                                            <div style=\"display:flex;align-items:center;gap:6px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">信息</span>\n                                                <label class=\"toggle-switch\">\n                                                    <input type=\"checkbox\" id=\"infoOsdSwitch\" onchange=\"toggleInfoOsdSwitch(this.checked)\">\n                                                    <span class=\"toggle-slider\"></span>\n                                                </label>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n<style>\n/* v6.02: 拨杆开关样式 */\n.toggle-switch {\n    position: relative;\n    display: inline-block;\n    width: 40px;\n    height: 22px;\n}\n.toggle-switch input {\n    opacity: 0;\n    width: 0;\n    height: 0;\n}\n.toggle-slider {\n    position: absolute;\n    cursor: pointer;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background-color: #30363d;\n    transition: 0.3s;\n    border-radius: 22px;\n}\n.toggle-slider:before {\n    position: absolute;\n    content: \"\";\n    height: 16px;\n    width: 16px;\n    left: 3px;\n    bottom: 3px;\n    background-color: #e0e6f0;\n    transition: 0.3s;\n    border-radius: 50%;\n}\ninput:checked + .toggle-slider {\n    background-color: #238636;\n}\ninput:checked + .toggle-slider:before {\n    transform: translateX(18px);\n}\n\n/* 折叠面板样式 */\n.collapsible-section {\n    background: #161b22;\n    border: 1px solid #21262d;\n    border-radius: 8px;\n    margin-bottom: 12px;\n    overflow: hidden;\n}\n.collapsible-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 10px 12px;\n    cursor: pointer;\n    background: #0d1117;\n    transition: background 0.2s;\n}\n.collapsible-header:hover {\n    background: #161b22;\n}\n.collapse-icon {\n    color: #8b949e;\n    font-size: 12px;\n    transition: transform 0.2s;\n}\n.collapsible-section.collapsed .collapse-icon {\n    transform: rotate(-90deg);\n}\n.collapsible-content {\n    padding: 12px;\n    max-height: 1000px;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out, padding 0.3s;\n}\n.collapsible-section.collapsed .collapsible-content {\n    max-height: 0;\n    padding: 0 12px;\n}\n.section-subtitle {\n    font-size: 12px;\n    color: #6e7681;\n    margin: 8px 0 4px;\n    padding-top: 8px;\n    border-top: 1px solid #21262d;\n}\n.section-subtitle:first-child {\n    border-top: none;\n    padding-top: 0;\n}\n</style>\n\n<script>\n// 等待 apiGet/apiPost 可用后再定义函数\n(function() {\n    // 检查 apiGet 是否已定义\n    if (typeof apiGet === 'undefined') {\n        console.warn('[CONSOLE] apiGet not yet defined, will retry on DOMContentLoaded');\n        document.addEventListener('DOMContentLoaded', function() {\n            // DOM 加载完成后重新执行\n            if (typeof apiGet !== 'undefined') {\n                console.log('[CONSOLE] apiGet now available');\n            }\n        });\n    }\n})();\n\n// 折叠/展开控制\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== 动态加载设备图像参数 ====================\nvar deviceImageParams = {};\nvar deviceFunctionData = null; // v5.42: 存储function.json数据\n\n// 连接设备时加载图像参数（从function.json读取范围，从ISAPI读取当前值）\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    // 检查 apiGet 是否可用\n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined, cannot load image params');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // v5.42: 先加载 function.json 获取参数范围\n    apiGet('/api/v1/ptz/' + deviceIp + '/function').then(function(r) {\n        if (r && r.success && r.data) {\n            deviceFunctionData = r.data;\n            console.log('[IMAGE] function.json loaded:', r.data.functions);\n        }\n    }).catch(function(e) {\n        console.warn('[IMAGE] function.json load failed:', e);\n    });\n    \n    // 加载曝光模式\n    loadExposure(deviceIp);\n    \n    // 加载 OSD 状态\n    loadOsdStatus(deviceIp);\n    \n    // 加载白平衡\n    loadWhiteBalance(deviceIp);\n    \n    // 加载降噪\n    loadNoiseReduce(deviceIp);\n    \n    // 加载快门\n    loadShutter(deviceIp);\n    \n    // 加载光圈\n    loadIris(deviceIp);\n    \n    // 加载锐度\n    loadSharpness(deviceIp);\n    \n    // 加载亮度/对比度/饱和度\n    loadColorParams(deviceIp);\n}\n\n// 加载 OSD 状态\nfunction loadOsdStatus(deviceIp) {\n    // PTZ OSD\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/ptz').then(function(r) {\n        if (r && r.success) {\n            var enabled = r.enabled || r.data?.enabled || false;\n            updatePtzOsdButtons(enabled);\n            // 保存到 localStorage\n            localStorage.setItem('osd_ptz_' + deviceIp, enabled ? '1' : '0');\n        } else {\n            // 从 localStorage 读取上次设置\n            var saved = localStorage.getItem('osd_ptz_' + deviceIp);\n            if (saved !== null) {\n                updatePtzOsdButtons(saved === '1');\n            }\n        }\n    }).catch(function(e) {\n        var saved = localStorage.getItem('osd_ptz_' + deviceIp);\n        if (saved !== null) {\n            updatePtzOsdButtons(saved === '1');\n        }\n    });\n    \n    // Info OSD\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/info').then(function(r) {\n        if (r && r.success) {\n            var enabled = r.enabled || r.data?.enabled || false;\n            updateInfoOsdButtons(enabled);\n            localStorage.setItem('osd_info_' + deviceIp, enabled ? '1' : '0');\n        } else {\n            var saved = localStorage.getItem('osd_info_' + deviceIp);\n            if (saved !== null) {\n                updateInfoOsdButtons(saved === '1');\n            }\n        }\n    }).catch(function(e) {\n        var saved = localStorage.getItem('osd_info_' + deviceIp);\n        if (saved !== null) {\n            updateInfoOsdButtons(saved === '1');\n        }\n    });\n}\n\nfunction updatePtzOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnPtzOsdOn');\n    var btnOff = document.getElementById('btnPtzOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n}\n\nfunction updateInfoOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnInfoOsdOn');\n    var btnOff = document.getElementById('btnInfoOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n}\n\n// 加载白平衡\nfunction loadWhiteBalance(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/whitebalance').then(function(r) {\n        if (r && r.success && r.data) {\n            var wb = r.data;\n            deviceImageParams.whiteBalance = wb;\n            \n            // 更新模式下拉 - v5.40: 自动(官方)/自动(Astrohub)/手动\n            var wbModeSelect = document.getElementById('wbMode');\n            if (wbModeSelect) {\n                wbModeSelect.innerHTML = '';\n                \n                // 选项1: 自动（官方）\n                var opt1 = document.createElement('option');\n                opt1.value = 'auto_official';\n                opt1.textContent = '自动（官方）';\n                if (wb.mode === 'auto') opt1.selected = true;\n                wbModeSelect.appendChild(opt1);\n                \n                // 选项2: 自动\n                var opt2 = document.createElement('option');\n                opt2.value = 'auto_astrohub';\n                opt2.textContent = '自动';\n                wbModeSelect.appendChild(opt2);\n                \n                // 选项3: 手动\n                var opt3 = document.createElement('option');\n                opt3.value = 'manual';\n                opt3.textContent = '手动';\n                if (wb.mode === 'manual') opt3.selected = true;\n                wbModeSelect.appendChild(opt3);\n            }\n            \n            // 更新 R/B 滑动条\n            var wbRed = document.getElementById('wbRed');\n            var wbBlue = document.getElementById('wbBlue');\n            var wbRedVal = document.getElementById('wbRedVal');\n            var wbBlueVal = document.getElementById('wbBlueVal');\n            \n            if (wbRed && wb.red_gain !== undefined) {\n                wbRed.value = wb.red_gain;\n                if (wbRedVal) wbRedVal.textContent = wb.red_gain;\n            }\n            if (wbBlue && wb.blue_gain !== undefined) {\n                wbBlue.value = wb.blue_gain;\n                if (wbBlueVal) wbBlueVal.textContent = wb.blue_gain;\n            }\n            \n            // 设置范围\n            if (wb.min !== undefined && wb.max !== undefined) {\n                if (wbRed) { wbRed.min = wb.min; wbRed.max = wb.max; }\n                if (wbBlue) { wbBlue.min = wb.min; wbBlue.max = wb.max; }\n            }\n            \n            // v5.40: 只有手动模式时 R/B 滑动条才可用\n            var isManual = wb.mode === 'manual';\n            if (wbRed) wbRed.disabled = !isManual;\n            if (wbBlue) wbBlue.disabled = !isManual;\n        }\n    }).catch(function(e) {\n        console.warn('[WB] Load failed:', e);\n    });\n}\n\n// 加载降噪\nfunction loadNoiseReduce(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/noisereduce').then(function(r) {\n        if (r && r.success && r.data) {\n            var nr = r.data;\n            deviceImageParams.noiseReduce = nr;\n            \n            var dnrSpatial = document.getElementById('dnrSpatial');\n            var dnrTemporal = document.getElementById('dnrTemporal');\n            var dnrSpatialVal = document.getElementById('dnrSpatialVal');\n            var dnrTemporalVal = document.getElementById('dnrTemporalVal');\n            \n            if (dnrSpatial && nr.spatial_level !== undefined) {\n                dnrSpatial.value = nr.spatial_level;\n                if (dnrSpatialVal) dnrSpatialVal.textContent = nr.spatial_level;\n            }\n            if (dnrTemporal && nr.temporal_level !== undefined) {\n                dnrTemporal.value = nr.temporal_level;\n                if (dnrTemporalVal) dnrTemporalVal.textContent = nr.temporal_level;\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[DNR] Load failed:', e);\n    });\n}\n\n// 加载快门\nfunction loadShutter(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/shutter').then(function(r) {\n        if (r && r.success && r.data) {\n            var sh = r.data;\n            deviceImageParams.shutter = sh;\n            \n            var shutterSelect = document.getElementById('shutterSpeed');\n            if (shutterSelect) {\n                shutterSelect.innerHTML = '';\n                \n                // 自动选项\n                var autoOpt = document.createElement('option');\n                autoOpt.value = 'auto';\n                autoOpt.textContent = '自动';\n                shutterSelect.appendChild(autoOpt);\n                \n                // v5.42: 从 function.json 获取快门范围\n                var minShutter = '1/30000';\n                var maxShutter = '1/25';\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.shutter) {\n                    minShutter = deviceFunctionData.functions.shutter.min || '1/30000';\n                    maxShutter = deviceFunctionData.functions.shutter.max || '1/25';\n                }\n                \n                // 常用快门值（在范围内）\n                var shutterPresets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000', '1/30000', '1/25'];\n                shutterPresets.forEach(function(p) {\n                    var opt = document.createElement('option');\n                    opt.value = p;\n                    opt.textContent = p;\n                    if (p === sh.current_level) opt.selected = true;\n                    shutterSelect.appendChild(opt);\n                });\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Shutter] Load failed:', e);\n        // 设置默认选项\n        var shutterSelect = document.getElementById('shutterSpeed');\n        if (shutterSelect) {\n            shutterSelect.innerHTML = '<option value=\"auto\">自动</option>';\n            var presets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000'];\n            presets.forEach(function(p) {\n                shutterSelect.innerHTML += '<option value=\"' + p + '\">' + p + '</option>';\n            });\n        }\n    });\n}\n\n// 加载光圈\nfunction loadIris(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\n        if (r && r.success && r.data) {\n            var ir = r.data;\n            deviceImageParams.iris = ir;\n            \n            var irisSelect = document.getElementById('irisLevel');\n            if (irisSelect) {\n                irisSelect.innerHTML = '';\n                \n                // v5.42: 从 function.json 获取光圈范围\n                var minIris = 160;\n                var maxIris = 2200;\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.iris) {\n                    minIris = deviceFunctionData.functions.iris.min || 160;\n                    maxIris = deviceFunctionData.functions.iris.max || 2200;\n                }\n                \n                var current = ir.current_level || minIris;\n                \n                // F 值映射（标准海康光圈值）\n                var fValues = [\n                    {val: 160, label: 'F1.6'},\n                    {val: 200, label: 'F2.0'},\n                    {val: 280, label: 'F2.8'},\n                    {val: 400, label: 'F4.0'},\n                    {val: 560, label: 'F5.6'},\n                    {val: 800, label: 'F8.0'},\n                    {val: 1100, label: 'F11'},\n                    {val: 1600, label: 'F16'},\n                    {val: 2200, label: 'F22'}\n                ];\n                \n                fValues.forEach(function(f) {\n                    if (f.val >= minIris && f.val <= maxIris) {\n                        var opt = document.createElement('option');\n                        opt.value = f.val;\n                        opt.textContent = f.label;\n                        if (f.val === current) opt.selected = true;\n                        irisSelect.appendChild(opt);\n                    }\n                });\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Iris] Load failed:', e);\n        // 设置默认选项\n        var irisSelect = document.getElementById('irisLevel');\n        if (irisSelect) {\n            irisSelect.innerHTML = '<option value=\"\">-- 选择 --</option>';\n            var fValues = ['F1.6', 'F2.0', 'F2.8', 'F4.0', 'F5.6', 'F8.0', 'F11', 'F16', 'F22'];\n            fValues.forEach(function(f) {\n                irisSelect.innerHTML += '<option value=\"' + f + '\">' + f + '</option>';\n            });\n        }\n    });\n}\n\n// 加载锐度\nfunction loadSharpness(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/sharpness').then(function(r) {\n        if (r && r.success && r.data) {\n            var sp = r.data;\n            deviceImageParams.sharpness = sp;\n            \n            var slider = document.getElementById('consoleSharpness');\n            var range = document.getElementById('sharpnessRange');\n            \n            if (slider) {\n                slider.min = sp.min || 0;\n                slider.max = sp.max || 100;\n                slider.value = sp.current_level || 50;\n            }\n            if (range) {\n                range.textContent = '(' + (sp.min || 0) + '~' + (sp.max || 100) + ')';\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Sharpness] Load failed:', e);\n    });\n}\n\n// 加载亮度/对比度/饱和度\nfunction loadColorParams(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/color').then(function(r) {\n        if (r && r.success && r.data) {\n            var c = r.data;\n            deviceImageParams.color = c;\n            \n            var brightness = document.getElementById('consoleBrightness');\n            var contrast = document.getElementById('consoleContrast');\n            var saturation = document.getElementById('consoleSaturation');\n            \n            if (brightness && c.brightness !== undefined) brightness.value = c.brightness;\n            if (contrast && c.contrast !== undefined) contrast.value = c.contrast;\n            if (saturation && c.saturation !== undefined) saturation.value = c.saturation;\n        }\n    }).catch(function(e) {\n        console.warn('[Color] Load failed:', e);\n    });\n}\n\n// ==================== 设置函数 ====================\n\n// 设置锐度\nfunction setSharpness(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/sharpness', { level: parseInt(value) });\n}\n\n// 设置白平衡模式\nfunction setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // v5.40: 处理三种模式\n    var actualMode = mode;\n    if (mode === 'auto_official') {\n        actualMode = 'auto';\n    } else if (mode === 'auto_astrohub') {\n        // 暂未实现\n        showToast('warning', '自动暂未实现');\n        return;\n    }\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: actualMode })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', '白平衡: ' + (actualMode === 'auto' ? '自动（官方）' : '手动'));\n                // v5.40: 更新 R/B 滑动条状态\n                var wbRed = document.getElementById('wbRed');\n                var wbBlue = document.getElementById('wbBlue');\n                if (wbRed) wbRed.disabled = actualMode !== 'manual';\n                if (wbBlue) wbBlue.disabled = actualMode !== 'manual';\n            }\n        });\n}\n\n// 设置白平衡增益 R/B\nfunction setWhiteBalanceGain(channel, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // v5.46: 先切换到手动模式再调整增益\n    var wbModeSelect = document.getElementById('wbMode');\n    if (wbModeSelect && wbModeSelect.value !== 'manual') {\n        wbModeSelect.value = 'manual';\n        apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: 'manual' });\n        // 启用滑动条\n        var wbRed = document.getElementById('wbRed');\n        var wbBlue = document.getElementById('wbBlue');\n        if (wbRed) wbRed.disabled = false;\n        if (wbBlue) wbBlue.disabled = false;\n    }\n    \n    // 更新显示\n    if (channel === 'red') {\n        var el = document.getElementById('wbRedVal');\n        if (el) el.textContent = value;\n    } else {\n        var el = document.getElementById('wbBlueVal');\n        if (el) el.textContent = value;\n    }\n    \n    // 发送请求\n    var key = channel === 'red' ? 'red_gain' : 'blue_gain';\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) });\n}\n\n// 设置降噪\nfunction setNoiseReduce(type, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // 更新显示\n    var el = document.getElementById(type === 'spatial' ? 'dnrSpatialVal' : 'dnrTemporalVal');\n    if (el) el.textContent = value;\n    \n    // 发送请求\n    var key = type === 'spatial' ? 'spatial_level' : 'temporal_level';\n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', { [key]: parseInt(value) });\n}\n\n// 加载曝光模式\nfunction loadExposure(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\n        if (r && r.success && r.data) {\n            var select = document.getElementById('exposureMode');\n            if (select && r.data.mode) {\n                // v5.47: 只支持 auto/manual，其他模式统一为 manual\n                select.value = (r.data.mode === 'auto') ? 'auto' : 'manual';\n                // 更新快门光圈禁用状态\n                updateShutterIrisState();\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Exposure] Load failed:', e);\n    });\n}\n\n// 设置曝光模式\nfunction setExposureMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '曝光模式: ' + (mode === 'manual' ? '手动' : '自动'));\n        });\n    // v5.47: 自动模式下禁用快门光圈\n    updateShutterIrisState();\n}\n\n// v5.47: 更新快门光圈禁用状态\nfunction updateShutterIrisState() {\n    var exposureMode = document.getElementById('exposureMode');\n    var shutterSelect = document.getElementById('shutterSpeed');\n    var irisSelect = document.getElementById('irisLevel');\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\n    \n    var isManual = exposureMode.value === 'manual';\n    shutterSelect.disabled = !isManual;\n    irisSelect.disabled = !isManual;\n    \n    // 禁用时灰色样式\n    if (!isManual) {\n        shutterSelect.style.opacity = '0.5';\n        irisSelect.style.opacity = '0.5';\n    } else {\n        shutterSelect.style.opacity = '1';\n        irisSelect.style.opacity = '1';\n    }\n}\n\n// 设置快门\nfunction setShutterSpeed(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '快门: ' + value);\n        });\n}\n\n// 设置光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev || !value) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            }\n        });\n}\n\n// v6.02: PTZ OSD 开关\nfunction togglePtzOsdSwitch(enabled) {\n    ptzOsdEnabled = enabled;\n    togglePtzOsd(enabled);\n}\n\n// v6.02: Info OSD 开关\nfunction toggleInfoOsdSwitch(enabled) {\n    infoOsdEnabled = enabled;\n    toggleInfoOsd(enabled);\n}\n\n// 切换 PTZ OSD\nfunction togglePtzOsd(enabled) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    updatePtzOsdButtons(enabled);\n    localStorage.setItem('osd_ptz_' + dev, enabled ? '1' : '0');\n    \n    apiPost('/api/v1/ptz/' + dev + '/osd/ptz', { enabled: enabled })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'PTZ OSD: ' + (enabled ? '显示' : '关闭'));\n        });\n}\n\n// 切换 Info OSD\nfunction toggleInfoOsd(enabled) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    updateInfoOsdButtons(enabled);\n    localStorage.setItem('osd_info_' + dev, enabled ? '1' : '0');\n    \n    apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'Info OSD: ' + (enabled ? '显示' : '关闭'));\n        });\n}\n\n// v5.42: 开关式 OSD 切换\nvar ptzOsdEnabled = false;\nvar infoOsdEnabled = false;\n\nfunction togglePtzOsdToggle() {\n    ptzOsdEnabled = !ptzOsdEnabled;\n    var btn = document.getElementById('btnPtzOsd');\n    if (btn) {\n        btn.textContent = ptzOsdEnabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (ptzOsdEnabled ? 'btn-primary' : 'btn-secondary');\n    }\n    togglePtzOsd(ptzOsdEnabled);\n}\n\nfunction toggleInfoOsdToggle() {\n    infoOsdEnabled = !infoOsdEnabled;\n    var btn = document.getElementById('btnInfoOsd');\n    if (btn) {\n        btn.textContent = infoOsdEnabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (infoOsdEnabled ? 'btn-primary' : 'btn-secondary');\n    }\n    toggleInfoOsd(infoOsdEnabled);\n}\n\n// 更新按钮状态\nfunction updatePtzOsdButtons(enabled) {\n    ptzOsdEnabled = enabled;\n    var btn = document.getElementById('btnPtzOsd');\n    if (btn) {\n        btn.textContent = enabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (enabled ? 'btn-primary' : 'btn-secondary');\n    }\n}\n\nfunction updateInfoOsdButtons(enabled) {\n    infoOsdEnabled = enabled;\n    var btn = document.getElementById('btnInfoOsd');\n    if (btn) {\n        btn.textContent = enabled ? '显示' : '关闭';\n        btn.className = 'btn btn-sm ' + (enabled ? 'btn-primary' : 'btn-secondary');\n    }\n}\n\n// ==================== 暴露到全局 ====================\nwindow.toggleSection = toggleSection;\nwindow.loadDeviceImageParams = loadDeviceImageParams;\nwindow.setSharpness = setSharpness;\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\nwindow.setWhiteBalanceGain = setWhiteBalanceGain;\nwindow.setNoiseReduce = setNoiseReduce;\nwindow.setShutterSpeed = setShutterSpeed;\nwindow.setIris = setIris;\nwindow.setExposureMode = setExposureMode;\nwindow.togglePtzOsd = togglePtzOsd;\nwindow.toggleInfoOsd = toggleInfoOsd;\nwindow.updatePtzOsdButtons = updatePtzOsdButtons;\nwindow.updateInfoOsdButtons = updateInfoOsdButtons;\n</script>\n                <div class=\"page\" id=\"page-observation\">\n            <h2 style=\"font-size:18px;margin-bottom:16px\">观测计划</h2>\n            <div class=\"observation-layout\">\n                <!-- 左侧：目标推荐 -->\n                <div class=\"obs-card\">\n                    <h3>🌟 目标推荐</h3>\n                    <h4 style=\"font-size:13px;color:#8b949e;margin-bottom:8px\">太阳系天体</h4>\n                    <div class=\"obs-placeholder\">太阳系天体推荐开发中...</div>\n                    <h4 style=\"font-size:13px;color:#8b949e;margin:16px 0 8px\">深空天体</h4>\n                    <div class=\"obs-placeholder\">深空天体推荐开发中...</div>\n                </div>\n                <!-- 右侧：观测计划 -->\n                <div class=\"obs-card\">\n                    <h3>📋 观测计划</h3>\n                    <h4 style=\"font-size:13px;color:#8b949e;margin-bottom:8px\">多目标序列</h4>\n                    <div class=\"obs-placeholder\">多目标序列编排开发中...</div>\n                    <h4 style=\"font-size:13px;color:#8b949e;margin:16px 0 8px\">定时开关</h4>\n                    <div class=\"obs-placeholder\">定时观测计划开发中...</div>\n                    <!-- 启动/停止 -->\n                    <div class=\"obs-actions\">\n                        <button class=\"btn btn-primary\" id=\"btnObsStart\" disabled>▶ 启动观测</button>\n                        <button class=\"btn btn-danger\" id=\"btnObsStop\" disabled>⏹ 停止观测</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n        <!-- ==================== 高级功能页面（左侧展开） ==================== -->\n        <!-- 高级功能页面 - v5.31 左中右布局 -->\n<div class=\"page\" id=\"page-advanced\">\n    <div class=\"adv-layout\">\n        <!-- 左侧：测试项目 (25%) -->\n        <div class=\"adv-left\">\n            <div class=\"adv-section-title\">测试项目</div>\n            <div class=\"adv-menu\">\n                <button class=\"adv-menu-item active\" data-test=\"function\" onclick=\"selectAdvTest('function')\">\n                    <span class=\"menu-icon\">🔍</span>\n                    <span>功能测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"limit\" onclick=\"selectAdvTest('limit')\">\n                    <span class=\"menu-icon\">📐</span>\n                    <span>限位测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"speed\" onclick=\"selectAdvTest('speed')\">\n                    <span class=\"menu-icon\">⚡</span>\n                    <span>速度测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"stream\" onclick=\"selectAdvTest('stream')\">\n                    <span class=\"menu-icon\">📡</span>\n                    <span>推流/存储</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"astrocal\" onclick=\"selectAdvTest('astrocal')\">\n                    <span class=\"menu-icon\">🌟</span>\n                    <span>天文校准</span>\n                </button>\n            </div>\n            <div class=\"adv-section-title\" style=\"margin-top:16px\">操作</div>\n            <div class=\"adv-actions\">\n                <button class=\"btn btn-primary btn-block\" id=\"btnAdvRun\" onclick=\"runAdvTest()\">▶ 开始测试</button>\n                <button class=\"btn btn-secondary btn-block\" id=\"btnAdvStop\" onclick=\"stopAdvTest()\" disabled>⏹ 停止</button>\n            </div>\n        </div>\n\n        <!-- 中间：实时画面 (55%) -->\n        <div class=\"adv-center\">\n            <div class=\"adv-section-title\">实时画面</div>\n            <div class=\"adv-video-box\" id=\"advVideoBox\">\n                <div id=\"advVideoPlaceholder\">\n                    <div style=\"color:#6e7681;text-align:center;padding:40px\">\n                        <div style=\"font-size:48px;margin-bottom:16px\">📹</div>\n                        <div id=\"advVideoStatus\">连接设备后显示实时画面</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 右侧：测试输出 (20%) -->\n        <div class=\"adv-right\">\n            <div class=\"adv-section-title\">测试输出</div>\n            <div class=\"adv-output\" id=\"advOutput\">\n                <div class=\"output-line info\">系统就绪</div>\n            </div>\n            <div class=\"adv-section-title\" style=\"margin-top:8px\">测试结果</div>\n            <div class=\"adv-result\" id=\"advResult\">\n                <div style=\"color:#6e7681;text-align:center;padding:20px\">\n                    测试结果将在此显示\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n<style>\n/* 高级功能 v5.31 布局 */\n.adv-layout {\n    display: flex;\n    gap: 0;\n    min-height: calc(100vh - 120px);\n    background: #0d1117;\n}\n\n.adv-left {\n    width: 25%;\n    min-width: 200px;\n    background: #161b22;\n    border-right: 1px solid #21262d;\n    padding: 12px;\n}\n\n.adv-center {\n    width: 55%;\n    padding: 12px;\n    display: flex;\n    flex-direction: column;\n}\n\n.adv-right {\n    width: 20%;\n    min-width: 240px;\n    background: #161b22;\n    border-left: 1px solid #21262d;\n    padding: 12px;\n    display: flex;\n    flex-direction: column;\n}\n\n.adv-section-title {\n    font-size: 13px;\n    font-weight: 600;\n    color: #8b949e;\n    padding: 8px 0;\n    border-bottom: 1px solid #21262d;\n    margin-bottom: 8px;\n}\n\n.adv-menu-item {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    width: 100%;\n    padding: 10px 12px;\n    margin: 4px 0;\n    border-radius: 6px;\n    background: #0d1117;\n    border: 1px solid #21262d;\n    color: #8b949e;\n    cursor: pointer;\n    transition: all 0.2s;\n    font-size: 13px;\n}\n\n.adv-menu-item:hover {\n    border-color: #30363d;\n    color: #e6edf3;\n}\n\n.adv-menu-item.active {\n    background: #238636;\n    border-color: #238636;\n    color: #fff;\n}\n\n.menu-icon {\n    font-size: 16px;\n}\n\n.adv-actions {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    margin-top: 8px;\n}\n\n.btn-block {\n    width: 100%;\n}\n\n.adv-video-box {\n    flex: 1;\n    background: #161b22;\n    border-radius: 8px;\n    border: 1px solid #21262d;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 400px;\n}\n\n.adv-output {\n    flex: 1;\n    background: #0d1117;\n    border-radius: 6px;\n    border: 1px solid #21262d;\n    padding: 8px;\n    overflow-y: auto;\n    max-height: 300px;\n    font-family: 'Consolas', monospace;\n    font-size: 12px;\n}\n\n.output-line {\n    padding: 2px 0;\n    line-height: 1.5;\n}\n\n.output-line.info { color: #8b949e; }\n.output-line.success { color: #3fb950; }\n.output-line.error { color: #f85149; }\n.output-line.warn { color: #d29922; }\n.output-line.test { color: #58a6ff; }\n\n.adv-result {\n    flex: 1;\n    background: #21262d;\n    border-radius: 6px;\n    border: 1px solid #30363d;\n    padding: 12px;\n    overflow-y: auto;\n    font-size: 12px;\n}\n</style>\n\n<script>\n// 高级功能页面控制\nlet currentAdvTest = 'function';\n\nfunction selectAdvTest(test) {\n    currentAdvTest = test;\n    document.querySelectorAll('.adv-menu-item').forEach(el => el.classList.remove('active'));\n    document.querySelector(`[data-test=\"${test}\"]`).classList.add('active');\n    addAdvOutput('info', '选择测试: ' + test);\n}\n\nfunction addAdvOutput(type, text) {\n    const output = document.getElementById('advOutput');\n    const line = document.createElement('div');\n    line.className = 'output-line ' + type;\n    const time = new Date().toLocaleTimeString();\n    line.textContent = '[' + time + '] ' + text;\n    output.appendChild(line);\n    output.scrollTop = output.scrollHeight;\n}\n\nfunction runAdvTest() {\n    // 尝试从全局 connectedDevice 或下拉框获取设备\n    var deviceIp = '';\n    var username = 'admin';\n    var password = '';\n\n    if (window.connectedDevice && window.connectedDevice.ip) {\n        deviceIp = window.connectedDevice.ip;\n        username = window.connectedDevice.username || 'admin';\n        password = window.connectedDevice.password || '';\n    } else {\n        // 从下拉框获取\n        var deviceSelect = document.getElementById('advConnectDevice');\n        if (deviceSelect && deviceSelect.value) {\n            deviceIp = deviceSelect.value;\n        } else {\n            addAdvOutput('error', '请先连接设备');\n            return;\n        }\n    }\n\n    const btnRun = document.getElementById('btnAdvRun');\n    const btnStop = document.getElementById('btnAdvStop');\n    btnRun.disabled = true;\n    btnStop.disabled = false;\n\n    addAdvOutput('info', '开始测试: ' + currentAdvTest);\n    addAdvOutput('info', '设备: ' + deviceIp);\n\n    const apiMap = {\n        'function': '/api/v1/advanced/function/run',\n        'limit': '/api/v1/advanced/limit/run',\n        'speed': '/api/v1/advanced/speed/run',\n        'astrocal': '/api/v1/calibrate/start'\n    };\n\n    if (currentAdvTest === 'stream') {\n        addAdvOutput('info', '推流控制，请使用主控台');\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        return;\n    }\n\n    if (currentAdvTest === 'astrocal') {\n        // 天文校准 - 跳转到校准页面\n        startAstroCalibration(deviceIp, username, password);\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        return;\n    }\n\n    const apiUrl = apiMap[currentAdvTest];\n    if (!apiUrl) {\n        addAdvOutput('error', '未知测试类型');\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        return;\n    }\n\n    fetch(apiUrl, {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: deviceIp,\n            username: username,\n            password: password\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n\n        if (data.success || data.status) {\n            addAdvOutput('success', '测试完成');\n            renderAdvResult(data);\n        } else {\n            addAdvOutput('error', data.message || '测试失败');\n        }\n    })\n    .catch(e => {\n        btnRun.disabled = false;\n        btnStop.disabled = true;\n        addAdvOutput('error', '请求异常: ' + e.message);\n    });\n}\n\nfunction stopAdvTest() {\n    addAdvOutput('warn', '停止测试');\n    document.getElementById('btnAdvRun').disabled = false;\n    document.getElementById('btnAdvStop').disabled = true;\n}\n\nfunction renderAdvResult(data) {\n    const resultEl = document.getElementById('advResult');\n    const results = data.results || data;\n\n    // 检测结果类型\n    if (results.pan_min !== undefined || results.tilt_min !== undefined) {\n        // 限位测试结果\n        let html = '<table style=\"width:100%;font-size:11px;border-collapse:collapse\">';\n        html += '<tr style=\"border-bottom:1px solid #30363d\"><th style=\"text-align:left;padding:4px\">轴</th><th style=\"text-align:center;padding:4px\">下限</th><th style=\"text-align:right;padding:4px\">上限</th></tr>';\n\n        if (results.pan_min !== undefined) {\n            html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">P轴</td><td style=\"text-align:center;padding:4px\">' + results.pan_min + '</td><td style=\"text-align:right;padding:4px\">' + results.pan_max + '</td></tr>';\n        }\n        if (results.tilt_min !== undefined) {\n            html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">T轴</td><td style=\"text-align:center;padding:4px\">' + results.tilt_min + '</td><td style=\"text-align:right;padding:4px\">' + results.tilt_max + '</td></tr>';\n        }\n        if (results.zoom_min !== undefined) {\n            html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">Z轴</td><td style=\"text-align:center;padding:4px\">' + results.zoom_min + '</td><td style=\"text-align:right;padding:4px\">' + results.zoom_max + '</td></tr>';\n        }\n\n        html += '</table>';\n\n        // 翻转状态\n        if (results.has_flip !== undefined) {\n            html += '<div style=\"margin-top:8px;padding:8px;background:#161b22;border-radius:4px\">';\n            html += '<span style=\"color:#8b949e\">翻转支持:</span> ';\n            html += results.has_flip ? '<span style=\"color:#3fb950\">✓ 是</span>' : '<span style=\"color:#f85149\">✗ 否</span>';\n            html += '</div>';\n        }\n\n        // 稳定性验证\n        if (results.stability_check !== undefined) {\n            html += '<div style=\"margin-top:4px;padding:8px;background:#161b22;border-radius:4px\">';\n            html += '<span style=\"color:#8b949e\">稳定性:</span> ';\n            html += results.stability_check ? '<span style=\"color:#3fb950\">✓ 通过</span>' : '<span style=\"color:#f85149\">✗ 失败</span>';\n            html += '</div>';\n        }\n\n        resultEl.innerHTML = html;\n    } else {\n        // 功能测试结果\n        let html = '<table style=\"width:100%;font-size:11px;border-collapse:collapse\">';\n        html += '<tr style=\"border-bottom:1px solid #30363d\"><th style=\"text-align:left;padding:4px\">项目</th><th style=\"text-align:center;padding:4px\">支持</th><th style=\"text-align:right;padding:4px\">范围</th></tr>';\n\n        for (const [key, val] of Object.entries(results)) {\n            if (typeof val === 'object' && val !== null) {\n                const label = val.label || key;\n                const supported = val.supported ? 'Y' : 'N';\n                const range = (val.min_val || '-') + '~' + (val.max_val || '-');\n                html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">' + label + '</td><td style=\"text-align:center;padding:4px\">' + supported + '</td><td style=\"text-align:right;padding:4px\">' + range + '</td></tr>';\n            }\n        }\n\n        html += '</table>';\n        resultEl.innerHTML = html;\n    }\n}\n\n// 更新视频状态\nfunction updateAdvVideoStatus() {\n    const statusEl = document.getElementById('advVideoStatus');\n    if (window.connectedDevice && window.connectedDevice.ip) {\n        if (statusEl) statusEl.textContent = '已连接: ' + window.connectedDevice.ip;\n    } else {\n        if (statusEl) statusEl.textContent = '连接设备后显示实时画面';\n    }\n}\n\n// 天文校准功能\nlet astroCalSession = null;\nlet astroCalMethod = 'manual'; // 'manual' or 'auto'\n\nfunction startAstroCalibration(deviceIp, username, password) {\n    addAdvOutput('info', '启动天文校准...');\n    \n    // 获取观测站位置（从配置或默认值）\n    const obsLat = window.astroCalConfig?.obs_lat || 29.45;\n    const obsLon = window.astroCalConfig?.obs_lon || 100.33;\n    \n    fetch('/api/v1/calibrate/start', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: deviceIp,\n            obs_lat: obsLat,\n            obs_lon: obsLon,\n            method: astroCalMethod\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            astroCalSession = deviceIp;\n            addAdvOutput('success', '校准会话已创建');\n            \n            if (astroCalMethod === 'manual' && data.recommended_stars) {\n                showAstroCalStars(data.recommended_stars);\n            } else {\n                addAdvOutput('info', '请拍摄天空进行星图解析');\n            }\n            \n            renderAstroCalPanel();\n        } else {\n            addAdvOutput('error', data.message || '启动失败');\n        }\n    })\n    .catch(e => {\n        addAdvOutput('error', '请求异常: ' + e.message);\n    });\n}\n\nfunction showAstroCalStars(stars) {\n    addAdvOutput('info', '推荐校准星:');\n    stars.forEach((star, i) => {\n        addAdvOutput('test', (i+1) + '. ' + star.name + ' (Az=' + star.az.toFixed(1) + ', Alt=' + star.alt.toFixed(1) + ')');\n    });\n}\n\nfunction renderAstroCalPanel() {\n    const resultEl = document.getElementById('advResult');\n    \n    let html = '<div style=\"font-size:12px\">';\n    html += '<div style=\"margin-bottom:8px;font-weight:600;color:#58a6ff\">🌟 天文校准</div>';\n    \n    // 校准方法选择\n    html += '<div style=\"margin-bottom:12px\">';\n    html += '<label style=\"color:#8b949e;margin-right:12px\"><input type=\"radio\" name=\"calMethod\" value=\"manual\" ' + (astroCalMethod === 'manual' ? 'checked' : '') + ' onchange=\"setAstroCalMethod(\\'manual\\')\"> 手动对准</label>';\n    html += '<label style=\"color:#8b949e\"><input type=\"radio\" name=\"calMethod\" value=\"auto\" ' + (astroCalMethod === 'auto' ? 'checked' : '') + ' onchange=\"setAstroCalMethod(\\'auto\\')\"> 自动解析</label>';\n    html += '</div>';\n    \n    // 操作区域\n    if (astroCalMethod === 'manual') {\n        html += '<div style=\"margin-bottom:8px\">';\n        html += '<select id=\"astroCalStar\" style=\"width:100%;padding:6px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0\">';\n        html += '<option value=\"\">选择恒星</option>';\n        html += '</select>';\n        html += '</div>';\n        html += '<button class=\"btn btn-primary btn-sm\" style=\"width:100%\" onclick=\"recordAstroCalPoint()\">📍 记录当前位置</button>';\n    } else {\n        html += '<button class=\"btn btn-primary btn-sm\" style=\"width:100%;margin-bottom:8px\" onclick=\"captureAndSolve()\">📷 拍摄并解析</button>';\n    }\n    \n    // 状态显示\n    html += '<div id=\"astroCalStatus\" style=\"margin-top:12px;padding:8px;background:#0d1117;border-radius:4px;color:#8b949e\">';\n    html += '等待操作...';\n    html += '</div>';\n    \n    // 计算按钮\n    html += '<div style=\"margin-top:12px;display:flex;gap:8px\">';\n    html += '<button class=\"btn btn-warning btn-sm\" style=\"flex:1\" onclick=\"computeAstroCal()\">计算参数</button>';\n    html += '<button class=\"btn btn-secondary btn-sm\" style=\"flex:1\" onclick=\"saveAstroCal()\">保存</button>';\n    html += '</div>';\n    \n    html += '</div>';\n    resultEl.innerHTML = html;\n    \n    // 加载推荐星\n    if (astroCalMethod === 'manual') {\n        loadAstroCalStars();\n    }\n}\n\nfunction setAstroCalMethod(method) {\n    astroCalMethod = method;\n    renderAstroCalPanel();\n}\n\nfunction loadAstroCalStars() {\n    if (!window.connectedDevice) return;\n    \n    const obsLat = window.astroCalConfig?.obs_lat || 29.45;\n    const obsLon = window.astroCalConfig?.obs_lon || 100.33;\n    \n    fetch('/api/v1/calibrate/stars/recommended?lat=' + obsLat + '&lon=' + obsLon + '&count=5')\n    .then(r => r.json())\n    .then(data => {\n        if (data.success && data.recommended_stars) {\n            const select = document.getElementById('astroCalStar');\n            if (select) {\n                select.innerHTML = '<option value=\"\">选择恒星</option>';\n                data.recommended_stars.forEach(star => {\n                    select.innerHTML += '<option value=\"' + star.name + '\">' + star.name + ' (Az=' + star.az.toFixed(1) + ', Alt=' + star.alt.toFixed(1) + ')</option>';\n                });\n            }\n        }\n    });\n}\n\nfunction recordAstroCalPoint() {\n    if (!astroCalSession || !window.connectedDevice) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    const starSelect = document.getElementById('astroCalStar');\n    const starName = starSelect ? starSelect.value : '';\n    \n    if (!starName) {\n        addAdvOutput('warn', '请先选择恒星');\n        return;\n    }\n    \n    // 先选择恒星\n    fetch('/api/v1/calibrate/select_star', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: astroCalSession,\n            star_name: starName\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (!data.success) {\n            addAdvOutput('error', data.message || '选择失败');\n            return;\n        }\n        \n        // 获取当前PTZ位置并记录\n        const pan = window.connectedDevice.lastPan || 0;\n        const tilt = window.connectedDevice.lastTilt || 0;\n        \n        return fetch('/api/v1/calibrate/record', {\n            method: 'POST',\n            headers: {'Content-Type': 'application/json'},\n            body: JSON.stringify({\n                device_ip: astroCalSession,\n                pan: pan,\n                tilt: tilt\n            })\n        });\n    })\n    .then(r => r && r.json())\n    .then(data => {\n        if (data && data.success) {\n            addAdvOutput('success', '记录校准点 #' + data.point_index);\n            updateAstroCalStatus(data.coverage);\n        } else if (data) {\n            addAdvOutput('error', data.message || '记录失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction captureAndSolve() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    addAdvOutput('info', '拍摄并解析中...');\n    \n    const pan = window.connectedDevice?.lastPan || 0;\n    const tilt = window.connectedDevice?.lastTilt || 0;\n    \n    fetch('/api/v1/calibrate/capture', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: astroCalSession,\n            pan: pan,\n            tilt: tilt\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '解析成功: RA=' + data.ra.toFixed(2) + 'h, DEC=' + data.dec.toFixed(2) + '°');\n            updateAstroCalStatus(data.coverage);\n        } else {\n            addAdvOutput('error', data.message || '解析失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction updateAstroCalStatus(coverage) {\n    const statusEl = document.getElementById('astroCalStatus');\n    if (!statusEl || !coverage) return;\n    \n    let html = '校准点: ' + (coverage.total_points || 0) + ' | ';\n    html += 'Az覆盖: ' + coverage.az_spread.toFixed(0) + '° | ';\n    html += 'Alt覆盖: ' + coverage.alt_spread.toFixed(0) + '°';\n    \n    if (coverage.needs_more) {\n        html += '<br><span style=\"color:#d29922\">需要更多校准点</span>';\n    } else {\n        html += '<br><span style=\"color:#3fb950\">可以计算参数</span>';\n    }\n    \n    statusEl.innerHTML = html;\n}\n\nfunction computeAstroCal() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    addAdvOutput('info', '计算校准参数...');\n    \n    fetch('/api/v1/calibrate/compute', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({device_ip: astroCalSession})\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '计算成功!');\n            if (data.params) {\n                addAdvOutput('info', 'IA=' + data.params.IA?.toFixed(3) + '°, IH=' + data.params.IH?.toFixed(3) + '°');\n            }\n            if (data.rms) {\n                addAdvOutput('info', 'RMS: Az=' + (data.rms.az || 0).toFixed(3) + '°, Alt=' + (data.rms.alt || 0).toFixed(3) + '°');\n            }\n        } else {\n            addAdvOutput('error', data.message || '计算失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction saveAstroCal() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先完成校准计算');\n        return;\n    }\n    \n    fetch('/api/v1/calibrate/save', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({device_ip: astroCalSession})\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '校准结果已保存');\n        } else {\n            addAdvOutput('error', data.message || '保存失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n</script>\n                <div class=\"page\" id=\"page-replay\">\n            <h2 style=\"font-size:18px;margin-bottom:16px\">回放</h2>\n            <p style=\"color:#8b949e;font-size:14px\">回放历史观测录像。</p>\n            <div class=\"card\" style=\"text-align:center;padding:40px\">\n                <div style=\"font-size:48px;margin-bottom:16px\">🎬</div>\n                <div style=\"font-size:16px;color:#8b949e\">回放功能开发中...</div>\n            </div>\n        </div>\n        <!-- ==================== 首次连接引导向导 ==================== -->\n    </div>\n    </div>\n    <!-- Toast 容器 -->\n    <div class=\"toast-container\" id=\"toastContainer\"></div>\n    <!-- Modal 容器 -->\n    <div id=\"modalContainer\"></div>\n    <!-- WASM SDK Plugin Container is in console.html -->\n    <script>\n        console.log(\"[MAIN SCRIPT] Starting script execution\");\n        // WASM SDK global variables (before IIFE)\n        var g_szDeviceIdentify = '';\n        var g_bLoggedIn = false;\n        var g_bPlaying = false;\n        var g_iRtspPort = 554;\nvar g_szDeviceIdentify2 = \"\";\nvar g_bLoggedIn2 = false;\nvar g_bPlaying2 = false;\nvar g_iRtspPort2 = 554;\nvar g_iWndIndex2 = 0;\nvar g_iWebSocketPort = 7681;\n        var g_iWndIndex = 0;\nvar g_iChannelList = [];\nvar g_iChannelID = 1;\n        var g_iChannelID = 1;\n// Global functions\n    (function() {\n        'use strict';\n        // ================================================================\n        //  Configuration\n        // ================================================================\n        var API_BASE = window.location.origin;\n        var WS_URL = (window.location.protocol === 'https:' ? 'wss' : 'ws') + '://' + window.location.host + '/ws';\n        // Cached device data\n        var allDevices = [];\n        var currentModal = null;\n        // --- v3: Global connected device state ---\n        // Advanced menu state (now sidebar)\n        var advMenuActive = false;\n        var advCurrentSub = 'calibration';\n        // Onboarding wizard state\n        var wizardState = {\n            step: 0,\n            totalSteps: 5,\n            mac: '',\n            deviceIP: '',\n            runningTest: false,\n            testResults: { function: null, limit: null, speed: null }\n        };\n        // ================================================================\n        //  Initialization\n        // ================================================================\n        function init() {\n            console.log('[INIT] init() called');\n            updateClock();\n            setInterval(updateClock, 1000);\n            initNav();\n            initPtzSpeed();\n            initMouseUp();\n            refreshDevices();\n            // v6.0: 从后端获取连接状态\n            restoreConnectionState();\n            addLog('info', 'AstroHub 已启动');\n            connectWS();\n        }\n        // v6.0: 从后端恢复连接状态\n        function restoreConnectionState() {\n            apiGet('/api/v1/ptz/connected').then(function(r) {\n                if (r && r.success && r.connected && r.device) {\n                    window.connectedDevice = r.device;\n                    console.log('[v6.0] 已恢复连接:', r.device.ip);\n                    // v6.0: 自动触发 WASM 登录（凭据已从后端获取）\n                    if (window.clickLogin2 && r.device.username && r.device.password) {\n                        setTimeout(function() { window.clickLogin2(); }, 500);\n                    }\n                }\n            }).catch(function(e) {\n                console.warn('[v6.0] 获取连接状态失败:', e);\n            });\n        }\n        // ================================================================\n        //  Navigation\n        // ================================================================\n        function initNav() {\n            document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\n                btn.addEventListener('click', function() {\n                    document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\n                    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\n                    btn.classList.add('active');\n                    document.getElementById('page-' + btn.getAttribute('data-page')).classList.add('active');\n                    if (btn.getAttribute('data-page') === 'devices') { refreshDevices(); }\n                    if (btn.getAttribute('data-page') === 'console') {\n                        refreshPtzDeviceList();\n                        loadWasmDevices();\n                        // Resize WASM player when console becomes visible\n                        setTimeout(function() {\n                            var container = document.getElementById('divPlugin');\n                            if (container && window.WebVideoCtrl) {\n                                try { WebVideoCtrl.I_Resize(container.offsetWidth, container.offsetHeight); console.log('[WASM] Resized to', container.offsetWidth, container.offsetHeight); } catch(e) { console.warn('Resize error:', e); }\n                            }\n                        }, 100);\n                        // WASM login if already connected\n                        if (window.connectedDevice && window.clickLogin2) {\n                            window.clickLogin2();\n                        }\n                    }\n                    if (btn.getAttribute('data-page') === 'advanced') initAdvSidebar();\n                    if (btn.getAttribute('data-page')) refreshAdvancedDeviceSelectors();\n                });\n            });\n        }\n        // Sidebar click handlers for advanced page sub-items\n        function initAdvSidebar() {\n            document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(item) {\n                item.onclick = function() {\n                    var subPage = item.getAttribute('data-sub');\n                    // Update sidebar active state\n                    document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(b) { b.classList.remove('active'); });\n                    item.classList.add('active');\n                    // Show sub-page\n                    document.querySelectorAll('#advContent .page').forEach(function(p) { p.classList.remove('active'); });\n                    var target = document.getElementById('page-' + subPage);\n                    if (target) target.classList.add('active');\n                    advCurrentSub = subPage;\n                };\n            });\n        }\n        // ================================================================\n        //  Device Selectors for Advanced Pages\n        // ================================================================\n        function refreshAdvancedDeviceSelectors() {\n            var online = (allDevices || []).filter(function(d) { return d.online; });\n            var selectors = ['advFuncDevice', 'advLimitDevice', 'advSpeedDevice', 'calDevice', 'advStreamDevice'];\n            selectors.forEach(function(id) {\n                var sel = document.getElementById(id);\n                if (!sel) return;\n                var current = sel.value;\n                // Rebuild options\n                sel.innerHTML = '';\n                if (id === 'calDevice' || id === 'advConnectDevice') {\n                    var defaultOpt = document.createElement('option');\n                    defaultOpt.textContent = '未选择设备';\n                    defaultOpt.value = '';\n                    sel.appendChild(defaultOpt);\n                }\n                online.forEach(function(d) {\n                    var option = document.createElement('option');\n                    option.value = d.ip;\n                    option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\n                    sel.appendChild(option);\n                });\n                if (current) sel.value = current;\n            });\n        }\n        // ================================================================\n        //  API helpers - exposed to global scope for console.html\n        // ================================================================\n        async function apiGet(path) {\n            var r = await fetch(API_BASE + path);\n            if (!r.ok) throw new Error('HTTP ' + r.status);\n            return r.json();\n        }\n        async function apiPost(path, body) {\n            var opts = { method: 'POST', headers: {'Content-Type': 'application/json'} };\n            if (body) opts.body = JSON.stringify(body);\n            var r = await fetch(API_BASE + path, opts);\n            if (!r.ok) throw new Error('HTTP ' + r.status);\n            return r.json();\n        }\n        // Expose to global scope\n        window.apiGet = apiGet;\n        window.apiPost = apiPost;\n        async function apiDelete(path) {\n            var r = await fetch(API_BASE + path, { method: 'DELETE' });\n            if (!r.ok) throw new Error('HTTP ' + r.status);\n            return r.json();\n        }\n        async function apiPut(path, body) {\n            var r = await fetch(API_BASE + path, {\n                method: 'PUT',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify(body)\n            });\n            if (!r.ok) throw new Error('HTTP ' + r.status);\n            return r.json();\n        }\n        window.apiDelete = apiDelete;\n        window.apiPut = apiPut;\n        // ================================================================\n        //  Function Detection (P4.1-P4.21)\n        // ================================================================\n        function funcDetectRun() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceIp = window.connectedDevice.ip;\n            var device = window.connectedDevice;\n            var btn = document.getElementById('btnFuncRun');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 探测中...';\n            document.getElementById('funcProgress').style.display = 'block';\n            document.getElementById('funcResultArea').innerHTML = '';\n            addLog('info', '功能探测开始: ' + deviceIp);\n            apiPost('/api/v1/advanced/function/run', {\n                device_ip: deviceIp,\n                username: (device && device.username) || 'admin',\n                password: (device && device.password) || '',\n                port: (device && device.port) || 80\n            }).then(function(resp) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始探测';\n                document.getElementById('funcProgress').style.display = 'none';\n                if (resp && resp.success) {\n                    showToast('success', '功能探测完成');\n                    addLog('success', '功能探测完成: ' + (resp.message || ''));\n                    renderFuncResults(resp.results || {});\n                } else {\n                    showToast('error', resp ? resp.message : '探测失败');\n                    addLog('error', '功能探测失败: ' + (resp ? resp.message : '未知'));\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始探测';\n                document.getElementById('funcProgress').style.display = 'none';\n                showToast('error', '探测异常: ' + e.message);\n            });\n            // Simulate progress (REMOVED - hardcoded fake progress)\n            // Progress bar now: 0% on start → \"执行中...\" → 100% on real API response\n        }\n        function funcDetectRestore() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceIp = window.connectedDevice.ip;\n            var btn = document.getElementById('btnFuncRestore');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 恢复中...';\n            apiPost('/api/v1/advanced/function/restore?device_ip=' + deviceIp + '&username=admin&password=&port=80', null).then(function(resp) {\n                btn.disabled = false;\n                btn.innerHTML = '⟳ 恢复默认值';\n                if (resp && resp.success) {\n                    showToast('success', '参数已恢复默认值');\n                } else {\n                    showToast('error', resp ? resp.message : '恢复失败');\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.innerHTML = '⟳ 恢复默认值';\n                showToast('error', '恢复异常: ' + e.message);\n            });\n        }\n        function renderFuncResults(results) {\n            var area = document.getElementById('funcResultArea');\n            var html = '<table class=\"result-table\"><thead><tr><th>功能</th><th>支持</th><th>最小值</th><th>最大值</th><th>当前值</th><th>状态</th></tr></thead><tbody>';\n            var keys = Object.keys(results);\n            if (keys.length === 0) {\n                html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">暂无结果</td></tr>';\n            } else {\n                keys.forEach(function(key) {\n                    var item = results[key];\n                    var supported = item.supported ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>';\n                    var status = item.status || '完成';\n                    html += '<tr>';\n                    html += '<td>' + key + '</td>';\n                    html += '<td>' + supported + '</td>';\n                    html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\n                    html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\n                    html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\n                    html += '<td><span class=\"badge yes\">' + status + '</span></td>';\n                    html += '</tr>';\n                });\n            }\n            html += '</tbody></table>';\n            area.innerHTML = html;\n        }\n        // ================================================================\n        //  Limit Test (P6.0-P6.4)\n        // ================================================================\n        function limitTestRun() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceIp = window.connectedDevice.ip;\n            var device = window.connectedDevice;\n            var btn = document.getElementById('btnLimitRun');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\n            document.getElementById('limitProgress').style.display = 'block';\n            document.getElementById('limitDirection').style.display = 'block';\n            document.getElementById('limitResultArea').innerHTML = '';\n            addLog('info', '限位测试开始: ' + deviceIp);\n            apiPost('/api/v1/advanced/limit/run', {\n                device_ip: deviceIp,\n                username: (device && device.username) || 'admin',\n                password: (device && device.password) || '',\n                port: (device && device.port) || 80\n            }).then(function(resp) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始测试';\n                document.getElementById('limitProgress').style.display = 'none';\n                document.getElementById('limitDirection').style.display = 'none';\n                if (resp && resp.success) {\n                    showToast('success', '限位测试完成');\n                    addLog('success', '限位测试完成: ' + (resp.message || ''));\n                    renderLimitResults(resp.results || {});\n                } else {\n                    showToast('error', resp ? resp.message : '测试失败');\n                    addLog('error', '限位测试失败: ' + (resp ? resp.message : '未知'));\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始测试';\n                document.getElementById('limitProgress').style.display = 'none';\n                document.getElementById('limitDirection').style.display = 'none';\n                showToast('error', '测试异常: ' + e.message);\n            });\n            // Progress bar: real status (no hardcoded simulation)\n            var limitProgText = document.getElementById('limitProgressText');\n            var limitProgBar = document.getElementById('limitProgressBar');\n            var limitDirEl = document.getElementById('limitDirection');\n            if (limitProgText) limitProgText.textContent = '测试中... 等待设备响应';\n            if (limitProgBar) limitProgBar.style.width = '30%';\n            if (limitDirEl) { limitDirEl.textContent = '当前方向: 初始化...'; limitDirEl.style.display = 'block'; }\n            // simulateProgress/simulateDirections REMOVED - hardcoded fake progress\n        }\n        function renderLimitResults(results) {\n            var area = document.getElementById('limitResultArea');\n            if (!results || Object.keys(results).length === 0) {\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\n                return;\n            }\n            var html = '<div class=\"advanced-status-panel\"><h4>限位测试结果</h4>';\n            // P axis\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\n            html += '<div class=\"status-row\"><span class=\"status-label\">P轴限位</span><span class=\"status-value\">' + pLimit[0] + ' ~ ' + pLimit[1] + '</span></div>';\n            html += '<div class=\"status-row\"><span class=\"status-label\">T轴限位</span><span class=\"status-value\">' + tLimit[0] + ' ~ ' + tLimit[1] + '</span></div>';\n            html += '<div class=\"status-row\"><span class=\"status-label\">翻转</span><span class=\"status-value\">' + (results.flip ? '有' : '无') + '</span></div>';\n            html += '<div class=\"status-row\"><span class=\"status-label\">稳定性</span><span class=\"status-value\">' + (results.stable ? '<span class=\"badge yes\">✅ 稳定</span>' : '<span class=\"badge no\">❌ 不稳定</span>') + '</span></div>';\n            if (results.csv_path) {\n                html += '<div class=\"status-row\"><span class=\"status-label\">CSV 路径</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\n            }\n            html += '</div>';\n            area.innerHTML = html;\n        }\n        // ================================================================\n        //  Speed Test (P5.4 + M4 P3)\n        // ================================================================\n        function speedTestRun() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceIp = window.connectedDevice.ip;\n            var device = window.connectedDevice;\n            var btn = document.getElementById('btnSpeedRun');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\n            document.getElementById('speedProgress').style.display = 'block';\n            document.getElementById('speedResultArea').innerHTML = '';\n            addLog('info', '速度测试开始: ' + deviceIp);\n            apiPost('/api/v1/advanced/speed/run', {\n                device_ip: deviceIp,\n                username: (device && device.username) || 'admin',\n                password: (device && device.password) || '',\n                port: (device && device.port) || 80\n            }).then(function(resp) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始测试';\n                document.getElementById('speedProgress').style.display = 'none';\n                if (resp && resp.success) {\n                    showToast('success', '速度测试完成');\n                    addLog('success', '速度测试完成: ' + (resp.message || ''));\n                    renderSpeedResults(resp.results || {});\n                } else {\n                    showToast('error', resp ? resp.message : '测试失败');\n                    addLog('error', '速度测试失败: ' + (resp ? resp.message : '未知'));\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始测试';\n                document.getElementById('speedProgress').style.display = 'none';\n                showToast('error', '测试异常: ' + e.message);\n            });\n            // Progress bar: real status (no hardcoded speed labels)\n            var speedProgText = document.getElementById('speedProgressText');\n            var speedProgBar = document.getElementById('speedProgressBar');\n            if (speedProgText) speedProgText.textContent = '测试中... 等待设备响应';\n            if (speedProgBar) speedProgBar.style.width = '30%';\n            // REMOVED simulateProgress (was hardcoded: '速度档位 1', '50', '100')\n            // Speed results now display actual values returned from backend\n        }\n        function renderSpeedResults(results) {\n            var area = document.getElementById('speedResultArea');\n            if (!results || Object.keys(results).length === 0) {\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\n                return;\n            }\n            var html = '<div class=\"advanced-status-panel\"><h4>速度测试结果</h4>';\n            // Speed mapping table\n            var speedMap = results.speed_map || results.speed_mapping || {};\n            var mapKeys = Object.keys(speedMap);\n            if (mapKeys.length > 0) {\n                html += '<table class=\"result-table\" style=\"margin:12px 0\"><thead><tr><th>速度档位</th><th>实际速率 (°/s)</th></tr></thead><tbody>';\n                mapKeys.forEach(function(k) {\n                    html += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\n                });\n                html += '</tbody></table>';\n            }\n            html += '<div class=\"status-row\"><span class=\"status-label\">拟合曲线 R²</span><span class=\"status-value\">' + (results.r_squared || results.r2 || '--') + '</span></div>';\n            html += '<div class=\"status-row\"><span class=\"status-label\">精度</span><span class=\"status-value\">' + (results.accuracy || '--') + '</span></div>';\n            html += '<div class=\"status-row\"><span class=\"status-label\">通过</span><span class=\"status-value\">' + (results.passed ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>') + '</span></div>';\n            html += '</div>';\n            area.innerHTML = html;\n        }\n        // ================================================================\n        //  Progress Simulation\n        // ================================================================\n        function simulateProgress(textId, barId, totalSteps, labels) {\n            var current = 0;\n            var interval = setInterval(function() {\n                current++;\n                if (current > totalSteps) { clearInterval(interval); return; }\n                var pct = Math.round((current / totalSteps) * 100);\n                var textEl = document.getElementById(textId);\n                var barEl = document.getElementById(barId);\n                if (textEl) textEl.textContent = labels ? labels[current-1] : '处理中... ' + current + '/' + totalSteps;\n                if (barEl) barEl.style.width = pct + '%';\n            }, 2000);\n        }\n        function simulateDirections() {\n            var dirs = ['P+ 移动中...', 'P- 移动中...', 'T+ 移动中...', 'T- 移动中...'];\n            var i = 0;\n            var interval = setInterval(function() {\n                var el = document.getElementById('limitDirection');\n                if (!el) { clearInterval(interval); return; }\n                if (i >= dirs.length) { clearInterval(interval); el.textContent = '测试完成 ✓'; el.style.color = '#3fb950'; return; }\n                el.textContent = '当前方向: ' + dirs[i];\n                i++;\n            }, 3000);\n        }\n        // ================================================================\n        //  Connect Device Page (高级功能 -> 连接设备)\n        // ================================================================\n        function onConnectDeviceChange() {\n            var ip = document.getElementById('advConnectDevice').value;\n            var noDevice = document.getElementById('connectNoDevice');\n            var controlArea = document.getElementById('connectControlArea');\n            var statusSpan = document.getElementById('connectDeviceStatus');\n            if (ip) {\n                var device = allDevices.find(function(d) { return d.ip === ip; });\n                noDevice.style.display = 'none';\n                controlArea.style.display = 'block';\n                statusSpan.textContent = device ? ('已连接: ' + ip) : ip;\n            } else {\n                noDevice.style.display = 'block';\n                controlArea.style.display = 'none';\n                statusSpan.textContent = '';\n            }\n        }\n        // 功能检测（连接设备页面版）\n        function connectFuncDetectRun() {\n            var deviceIp = document.getElementById('advConnectDevice').value;\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\n            var btn = document.getElementById('btnConnectFuncRun');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 探测中...';\n            document.getElementById('connectFuncProgress').style.display = 'block';\n            document.getElementById('connectFuncResultMini').innerHTML = '';\n            addLog('info', '功能检测开始: ' + deviceIp);\n            apiPost('/api/v1/advanced/function/run', {\n                device_ip: deviceIp,\n                username: (device && device.username) || 'admin',\n                password: (device && device.password) || '',\n                port: (device && device.port) || 80\n            }).then(function(resp) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始检测';\n                document.getElementById('connectFuncProgress').style.display = 'none';\n                if (resp && resp.success) {\n                    showToast('success', '功能检测完成');\n                    addLog('success', '功能检测完成: ' + (resp.message || ''));\n                    renderConnectFuncResultMini(resp.results || {});\n                    renderConnectFullResults(resp.results || {}, 'function');\n                } else {\n                    showToast('error', resp ? resp.message : '探测失败');\n                    addLog('error', '功能检测失败: ' + (resp ? resp.message : '未知'));\n                    document.getElementById('connectFuncResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '探测失败') + '</span>';\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始检测';\n                document.getElementById('connectFuncProgress').style.display = 'none';\n                showToast('error', '探测异常: ' + e.message);\n            });\n            // REMOVED simulateProgress for connectFuncDetectRun\n        }\n        function renderConnectFuncResultMini(results) {\n            var area = document.getElementById('connectFuncResultMini');\n            var keys = Object.keys(results);\n            var supported = 0, total = keys.length;\n            keys.forEach(function(k) { if (results[k] && results[k].supported) supported++; });\n            area.innerHTML = '<span style=\"font-size:12px;color:#3fb950\">✅ 支持 ' + supported + '/' + total + ' 项功能</span>';\n        }\n        // 限位检测（连接设备页面版）\n        function connectLimitTestRun() {\n            var deviceIp = document.getElementById('advConnectDevice').value;\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\n            var btn = document.getElementById('btnConnectLimitRun');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\n            document.getElementById('connectLimitProgress').style.display = 'block';\n            document.getElementById('connectLimitResultMini').innerHTML = '';\n            addLog('info', '限位检测开始: ' + deviceIp);\n            apiPost('/api/v1/advanced/limit/run', {\n                device_ip: deviceIp,\n                username: (device && device.username) || 'admin',\n                password: (device && device.password) || '',\n                port: (device && device.port) || 80\n            }).then(function(resp) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始检测';\n                document.getElementById('connectLimitProgress').style.display = 'none';\n                if (resp && resp.success) {\n                    showToast('success', '限位检测完成');\n                    addLog('success', '限位检测完成: ' + (resp.message || ''));\n                    renderConnectLimitResultMini(resp.results || {});\n                    renderConnectFullResults(resp.results || {}, 'limit');\n                } else {\n                    showToast('error', resp ? resp.message : '测试失败');\n                    addLog('error', '限位检测失败: ' + (resp ? resp.message : '未知'));\n                    document.getElementById('connectLimitResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '测试失败') + '</span>';\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始检测';\n                document.getElementById('connectLimitProgress').style.display = 'none';\n                showToast('error', '测试异常: ' + e.message);\n            });\n            // REMOVED simulateProgress for connectLimitTestRun\n        }\n        function renderConnectLimitResultMini(results) {\n            var area = document.getElementById('connectLimitResultMini');\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\n            area.innerHTML = '<span style=\"font-size:12px;color:#d29922\">P: ' + pLimit[0] + '~' + pLimit[1] + ' | T: ' + tLimit[0] + '~' + tLimit[1] + '</span>';\n        }\n        // 速度检测（连接设备页面版）\n        function connectSpeedTestRun() {\n            var deviceIp = document.getElementById('advConnectDevice').value;\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\n            var btn = document.getElementById('btnConnectSpeedRun');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\n            document.getElementById('connectSpeedProgress').style.display = 'block';\n            document.getElementById('connectSpeedResultMini').innerHTML = '';\n            addLog('info', '速度检测开始: ' + deviceIp);\n            apiPost('/api/v1/advanced/speed/run', {\n                device_ip: deviceIp,\n                username: (device && device.username) || 'admin',\n                password: (device && device.password) || '',\n                port: (device && device.port) || 80\n            }).then(function(resp) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始检测';\n                document.getElementById('connectSpeedProgress').style.display = 'none';\n                if (resp && resp.success) {\n                    showToast('success', '速度检测完成');\n                    addLog('success', '速度检测完成: ' + (resp.message || ''));\n                    renderConnectSpeedResultMini(resp.results || {});\n                    renderConnectFullResults(resp.results || {}, 'speed');\n                } else {\n                    showToast('error', resp ? resp.message : '测试失败');\n                    addLog('error', '速度检测失败: ' + (resp ? resp.message : '未知'));\n                    document.getElementById('connectSpeedResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '测试失败') + '</span>';\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.innerHTML = '▶ 开始检测';\n                document.getElementById('connectSpeedProgress').style.display = 'none';\n                showToast('error', '测试异常: ' + e.message);\n            });\n            // REMOVED simulateProgress for connectSpeedTestRun (was hardcoded: 速度档位 1, 50, 100)\n        }\n        function renderConnectSpeedResultMini(results) {\n            var area = document.getElementById('connectSpeedResultMini');\n            var speedMap = results.speed_map || results.speed_mapping || {};\n            var count = Object.keys(speedMap).length;\n            area.innerHTML = '<span style=\"font-size:12px;color:#f0883e\">✅ 已测试 ' + count + ' 个速度档位</span>';\n        }\n        // 一键检测（全部）\n        var detectionState = { running: false, step: 0, totalSteps: 3, results: {} };\n        function startDetection() {\n            var deviceIp = document.getElementById('advConnectDevice').value;\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\n            var btn = document.getElementById('btnStartDetection');\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 检测中...';\n            document.getElementById('detectionProgress').style.display = 'block';\n            document.getElementById('detectionLog').innerHTML = '';\n            detectionState = { running: true, step: 0, totalSteps: 3, results: {}, deviceIp: deviceIp, device: device };\n            addDetectionLog('info', '开始一键检测: ' + deviceIp);\n            runDetectionStep();\n        }\n        function runDetectionStep() {\n            var state = detectionState;\n            if (!state.running) return;\n            var steps = [\n                { name: '功能检测', url: '/api/v1/advanced/function/run', key: 'function' },\n                { name: '限位检测', url: '/api/v1/advanced/limit/run', key: 'limit' },\n                { name: '速度检测', url: '/api/v1/advanced/speed/run', key: 'speed' }\n            ];\n            if (state.step >= steps.length) {\n                finishDetection();\n                return;\n            }\n            var stepInfo = steps[state.step];\n            var pct = Math.round(((state.step) / state.totalSteps) * 100);\n            document.getElementById('detectionProgressText').textContent = '步骤 ' + (state.step + 1) + '/' + state.totalSteps + ': ' + stepInfo.name;\n            document.getElementById('detectionProgressBar').style.width = pct + '%';\n            addDetectionLog('info', '▶ 运行 ' + stepInfo.name + '...');\n            apiPost(stepInfo.url, {\n                device_ip: state.deviceIp,\n                username: (state.device && state.device.username) || 'admin',\n                password: (state.device && state.device.password) || '',\n                port: (state.device && state.device.port) || 80\n            }).then(function(resp) {\n                if (resp && resp.success) {\n                    state.results[stepInfo.key] = resp.results || {};\n                    addDetectionLog('success', '✅ ' + stepInfo.name + ' 完成');\n                } else {\n                    addDetectionLog('error', '❌ ' + stepInfo.name + ' 失败: ' + (resp ? resp.message : '未知'));\n                }\n                state.step++;\n                var newPct = Math.round((state.step / state.totalSteps) * 100);\n                document.getElementById('detectionProgressBar').style.width = newPct + '%';\n                runDetectionStep();\n            }).catch(function(e) {\n                addDetectionLog('error', '❌ ' + stepInfo.name + ' 异常: ' + e.message);\n                state.step++;\n                runDetectionStep();\n            });\n        }\n        function finishDetection() {\n            var btn = document.getElementById('btnStartDetection');\n            btn.disabled = false;\n            btn.innerHTML = '▶ 开始检测（全部）';\n            document.getElementById('detectionProgressText').textContent = '检测完成！';\n            document.getElementById('detectionProgressBar').style.width = '100%';\n            document.getElementById('detectionProgressBar').className = 'progress-fill green';\n            var state = detectionState;\n            var completed = Object.keys(state.results).length;\n            addDetectionLog('info', '=== 检测完成: ' + completed + '/' + state.totalSteps + ' 项通过 ===');\n            // 显示完整结果\n            if (completed > 0) {\n                var allResults = {};\n                Object.keys(state.results).forEach(function(k) {\n                    Object.keys(state.results[k]).forEach(function(rk) { allResults[rk] = state.results[k][rk]; });\n                });\n                if (state.results.function) renderConnectFullResults(state.results.function, 'function');\n                if (state.results.limit) renderConnectFullResults(state.results.limit, 'limit');\n                if (state.results.speed) renderConnectFullResults(state.results.speed, 'speed');\n            }\n            detectionState.running = false;\n        }\n        function addDetectionLog(level, msg) {\n            var log = document.getElementById('detectionLog');\n            if (!log) return;\n            var entry = document.createElement('div');\n            entry.className = 'log-entry ' + level;\n            entry.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\n            log.insertBefore(entry, log.firstChild);\n        }\n        // 预置点管理\n        function presetGoto() {\n            var deviceIp = document.getElementById('advConnectDevice').value;\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\n            var resultDiv = document.getElementById('presetResult');\n            resultDiv.textContent = '调用预置点 ' + presetId + '...';\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId, null).then(function(resp) {\n                if (resp && resp.success !== false) {\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已调用预置点 ' + presetId + '</span>';\n                } else {\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 调用失败: ' + (resp ? resp.message : '未知') + '</span>';\n                }\n            }).catch(function(e) {\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\n            });\n        }\n        function presetSet() {\n            var deviceIp = document.getElementById('advConnectDevice').value;\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\n            var resultDiv = document.getElementById('presetResult');\n            resultDiv.textContent = '设置预置点 ' + presetId + '...';\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId + '/set', null).then(function(resp) {\n                if (resp && resp.success) {\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已设置预置点 ' + presetId + '</span>';\n                } else {\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 设置失败: ' + (resp ? resp.message : '��知') + '</span>';\n                }\n            }).catch(function(e) {\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\n            });\n        }\n        // 渲染完整检测结果到连接设备页面\n        function renderConnectFullResults(results, type) {\n            var area = document.getElementById('connectFullResultArea');\n            var noResult = document.getElementById('connectNoResult');\n            if (!area) return;\n            area.style.display = 'block';\n            noResult.style.display = 'none';\n            var html = '<div style=\"margin-top:16px\">';\n            html += '<h4 style=\"font-size:15px;color:#e0e6f0;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #21262d\">';\n            if (type === 'function') html += '🔍 功能检测完整结果';\n            else if (type === 'limit') html += '📐 限位检测完整结果';\n            else if (type === 'speed') html += '⚡ 速度检测完整结果';\n            else html += '检测结果';\n            html += '</h4>';\n            if (type === 'function') {\n                html += '<table class=\"result-table\"><thead><tr><th>功能</th><th>支持</th><th>最小值</th><th>最大值</th><th>当前值</th><th>状态</th></tr></thead><tbody>';\n                var keys = Object.keys(results);\n                if (keys.length === 0) {\n                    html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">暂无结果</td></tr>';\n                } else {\n                    keys.forEach(function(key) {\n                        var item = results[key];\n                        var supported = item.supported ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>';\n                        var status = item.status || '完成';\n                        html += '<tr>';\n                        html += '<td>' + key + '</td>';\n                        html += '<td>' + supported + '</td>';\n                        html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\n                        html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\n                        html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\n                        html += '<td><span class=\"badge yes\">' + status + '</span></td>';\n                        html += '</tr>';\n                    });\n                }\n                html += '</tbody></table>';\n            } else if (type === 'limit') {\n                var pLimit = results.pan_range || results.p_limit || [0, 3600];\n                var tLimit = results.tilt_range || results.t_limit || [-200, 900];\n                html += '<div class=\"advanced-status-panel\">';\n                html += '<div class=\"status-row\"><span class=\"status-label\">P轴限位</span><span class=\"status-value\">' + pLimit[0] + ' ~ ' + pLimit[1] + '</span></div>';\n                html += '<div class=\"status-row\"><span class=\"status-label\">T轴限位</span><span class=\"status-value\">' + tLimit[0] + ' ~ ' + tLimit[1] + '</span></div>';\n                html += '<div class=\"status-row\"><span class=\"status-label\">翻转</span><span class=\"status-value\">' + (results.flip ? '有' : '无') + '</span></div>';\n                html += '<div class=\"status-row\"><span class=\"status-label\">稳定性</span><span class=\"status-value\">' + (results.stable ? '<span class=\"badge yes\">✅ 稳定</span>' : '<span class=\"badge no\">❌ 不稳定</span>') + '</span></div>';\n                if (results.csv_path) html += '<div class=\"status-row\"><span class=\"status-label\">CSV 路径</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\n                html += '</div>';\n            } else if (type === 'speed') {\n                var speedMap = results.speed_map || results.speed_mapping || {};\n                var mapKeys = Object.keys(speedMap);\n                if (mapKeys.length > 0) {\n                    html += '<table class=\"result-table\" style=\"margin:12px 0\"><thead><tr><th>速度档位</th><th>实际速率 (°/s)</th></tr></thead><tbody>';\n                    mapKeys.forEach(function(k) {\n                        html += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\n                    });\n                    html += '</tbody></table>';\n                }\n                html += '<div class=\"advanced-status-panel\">';\n                html += '<div class=\"status-row\"><span class=\"status-label\">拟合曲线 R²</span><span class=\"status-value\">' + (results.r_squared || results.r2 || '--') + '</span></div>';\n                html += '<div class=\"status-row\"><span class=\"status-label\">通过</span><span class=\"status-value\">' + (results.passed ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>') + '</span></div>';\n                html += '</div>';\n            }\n            html += '</div>';\n            // Append rather than replace to show all test results\n            area.innerHTML += html;\n        }\n        // ================================================================\n        // ================================================================\n        //  预置点列表管理 (主控台版)\n        // ================================================================\n        function loadPresetList() {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) return;\n            var resultDiv = document.getElementById('ptzPresetResult');\n            var sel = document.getElementById('ptzPresetSelect');\n            if (!sel) return;  // Not on console page\n            if (resultDiv) resultDiv.textContent = '正在获取预置点列表...';\n            apiGet('/api/v1/ptz/' + dev + '/presets').then(function(resp) {\n                sel.innerHTML = '<option value=\"\">选择预置点</option>';\n                if (resp && resp.success && resp.presets && resp.presets.length > 0) {\n                    resp.presets.forEach(function(p) {\n                        var opt = document.createElement('option');\n                        opt.value = p.id;\n                        opt.textContent = p.name ? ('P' + p.id + ' - ' + p.name) : '预置点 ' + p.id;\n                        sel.appendChild(opt);\n                    });\n                    if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#3fb950\">已加载 ' + resp.presets.length + ' 个预置点</span>';\n                } else {\n                    if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#d29922\">未获取到预置点</span>';\n                }\n            }).catch(function(e) {\n                if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#f85149\">获取失败: ' + e.message + '</span>';\n            });\n        }\n        function ptzGotoSelectedPreset() {\n            var dev = window.connectedDevice.ip;\n            var sel = document.getElementById('ptzPresetSelect');\n            var presetId = parseInt(sel.value);\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            if (!presetId) { showToast('warning', '请先选择预置点'); return; }\n            var resultDiv = document.getElementById('ptzPresetResult');\n            resultDiv.textContent = '跳转到预置点 ' + presetId + '...';\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId, null).then(function(resp) {\n                if (resp && resp.success !== false) {\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已前往预置点 ' + presetId + '</span>';\n                } else {\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 跳转失败: ' + (resp ? resp.message : '未知') + '</span>';\n                }\n            }).catch(function(e) {\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\n            });\n        }\n        function ptzSetSelectedPreset() {\n            var dev = window.connectedDevice.ip;\n            var sel = document.getElementById('ptzPresetSelect');\n            var presetId = parseInt(sel.value);\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            if (!presetId) { showToast('warning', '请先选择预置点编号'); return; }\n            var resultDiv = document.getElementById('ptzPresetResult');\n            resultDiv.textContent = '保存当前位置为预置点 ' + presetId + '...';\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId + '/set', null).then(function(resp) {\n                if (resp && resp.success) {\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已保存预置点 ' + presetId + '</span>';\n                    loadPresetList(); // refresh\n                } else {\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 保存失败: ' + (resp ? resp.message : '未知') + '</span>';\n                }\n            }).catch(function(e) {\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\n            });\n        }\n        function findMacByIP(ip) {\n            var dev = allDevices.find(function(d) { return d.ip === ip; });\n            return dev ? dev.mac : '';\n        }\n        // PTZ Speed Slider\n        function initPtzSpeed() {\n            var slider = document.getElementById('ptzSpeed');\n            if (slider) {\n                slider.addEventListener('input', function(e) {\n                    document.getElementById('ptzSpeedVal').textContent = e.target.value;\n                });\n            }\n        }\n        // Mouse/Touch Up - stop PTZ\n        function initMouseUp() {\n            document.addEventListener('mouseup', function() { ptzStop(); });\n            document.addEventListener('touchend', function() { ptzStop(); });\n        }\n        // Clock\n        function updateClock() {\n            var clock = document.getElementById('clock');\n            if (clock) clock.textContent = new Date().toLocaleTimeString('zh-CN');\n        }\n        // Toast Notifications\n        function showToast(type, message) {\n            var container = document.getElementById('toastContainer');\n            var toast = document.createElement('div');\n            toast.className = 'toast ' + type;\n            toast.textContent = message;\n            container.appendChild(toast);\n            setTimeout(function() {\n                if (toast.parentNode) toast.parentNode.removeChild(toast);\n            }, 4000);\n        }\n        // Logging\n        function addLog(level, msg) {\n            var c = document.getElementById('logContainer');\n            if (!c) return;\n            var d = document.createElement('div');\n            d.className = 'log-entry ' + level;\n            d.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\n            c.insertBefore(d, c.firstChild);\n            if (c.children.length > 50) c.removeChild(c.lastChild);\n        }\n        // WebSocket\n        function connectWS() {\n            try {\n                var ws = new WebSocket(WS_URL);\n                ws.onopen = function() {\n                    addLog('info', 'WebSocket 已连接');\n                };\n                ws.onclose = function() {\n                    setTimeout(connectWS, 3000);\n                };\n                ws.onmessage = function(e) {\n                    try {\n                        var data = JSON.parse(e.data);\n                        if (data.type === 'health') updateHealth(data);\n                    } catch(err) {}\n                };\n            } catch(e) {\n                addLog('warn', 'WebSocket 连接失败');\n            }\n        }\n        function updateHealth(data) {\n            var s = data.system || {};\n            if (s.cpu !== undefined) {\n                var bar = document.getElementById('cpuBar');\n                bar.style.width = s.cpu + '%';\n                bar.className = 'progress-fill ' + (s.cpu < 60 ? 'green' : s.cpu < 85 ? 'yellow' : 'red');\n                document.getElementById('cpuVal').textContent = s.cpu + '%';\n            }\n            if (s.memory !== undefined) {\n                var bar = document.getElementById('memBar');\n                bar.style.width = s.memory + '%';\n                bar.className = 'progress-fill ' + (s.memory < 60 ? 'green' : s.memory < 85 ? 'yellow' : 'red');\n                document.getElementById('memVal').textContent = s.memory + '%';\n            }\n            if (s.disk !== undefined) {\n                var bar = document.getElementById('diskBar');\n                bar.style.width = s.disk + '%';\n                bar.className = 'progress-fill ' + (s.disk < 70 ? 'green' : s.disk < 90 ? 'yellow' : 'red');\n                document.getElementById('diskVal').textContent = s.disk + '%';\n            }\n        }\n        // SADP Discovery\n        function discoverDevices() {\n            var btn = document.getElementById('btnDiscover');\n            var spinner = document.getElementById('discoverSpinner');\n            btn.disabled = true;\n            spinner.style.display = 'inline-block';\n            addLog('info', 'SADP 设备发现开始...');\n            showToast('info', '正在扫描局域网设备 (10s)...');\n            apiGet('/api/v1/discovery/sadp').then(function(data) {\n                if (data.success) {\n                    addLog('success', 'SADP 发现 ' + data.count + ' 台设备: ' + data.message);\n                    showToast('success', data.message);\n                    refreshDevices();\n                } else {\n                    addLog('error', '发现失败: ' + (data.message || '未知错误'));\n                    showToast('error', data.message || '发现失败');\n                }\n            }).catch(function(e) {\n                addLog('error', 'SADP 发现异常: ' + e.message);\n                showToast('error', 'SADP 发现异常: ' + e.message);\n            }).finally(function() {\n                spinner.style.display = 'none';\n                btn.disabled = false;\n            });\n        }\n        // Device List\n        var _sadpAutoRunning = false;\n        function autoSadpDiscover() {\n            if (_sadpAutoRunning) return;\n            _sadpAutoRunning = true;\n            apiGet('/api/v1/discovery/sadp').then(function(result) {\n                if (result && result.success) {\n                    addLog('info', 'SADP 发现 ' + (result.count || 0) + ' 台设备');\n                }\n                refreshDevices();  // 刷新设备列表（含网关信息）\n                _sadpAutoRunning = false;\n            }).catch(function(e) {\n                _sadpAutoRunning = false;\n            });\n        }\n        function refreshDevices() {\n            console.log('[REFRESH] refreshDevices called');\n            return apiGet('/api/v1/devices').then(function(result) {\n                console.log('[REFRESH] API response:', result);\n                if (!result.success) {\n                    allDevices = [];\n                    renderDevices([]);\n                    return;\n                }\n                allDevices = result.data || [];\n                renderDevices(allDevices);\n                // Update dashboard counters\n                var online = allDevices.filter(function(d) { return d.online; }).length;\n                var countEl = document.getElementById('devCount');\n                if (countEl) countEl.textContent = allDevices.length;\n                var onlineEl = document.getElementById('devOnline');\n                if (onlineEl) onlineEl.textContent = online;\n                var totalEl = document.getElementById('devTotal');\n                if (totalEl) totalEl.textContent = allDevices.length;\n                // Update PTZ & advanced device dropdowns\n                refreshPtzDeviceList();\n                refreshAdvancedDeviceSelectors();\n                // v1: Auto-connect with MAC memory (only on first load)\n                if (!window._autoConnectDone) {\n                    window._autoConnectDone = true;\n                    console.log('[AUTO] Checking auto-connect: allDevices.length=' + allDevices.length + ', connectedDevice=' + !!window.connectedDevice);\n                var lastMac = localStorage.getItem('lastConnectedMac') || '';\n                console.log('[AUTO] lastMac=' + lastMac);\n                if (!window.connectedDevice && allDevices && allDevices.length > 0) {\n                    // Priority: 1) last connected MAC, 2) first device with credentials\n                    var targetDev = lastMac ? allDevices.find(function(d) { return d.mac === lastMac; }) : null;\n                    console.log('[AUTO] targetDev from lastMac: ' + (targetDev ? targetDev.ip : 'null'));\n                    if (!targetDev) targetDev = allDevices.find(function(d) { return d.has_credentials; });\n                    console.log('[AUTO] targetDev from has_credentials: ' + (targetDev ? targetDev.ip + ', has_credentials=' + targetDev.has_credentials : 'null'));\n                    if (targetDev && targetDev.has_credentials) {\n                        // Auto-connect to this device\n                        apiGet('/api/v1/ptz/devices/' + targetDev.ip + '/credentials').then(function(creds) {\n                            if (creds && creds.success) {\n                                window.connectedDevice = {\n                                    ip: targetDev.ip,\n                                    model: targetDev.model || '',\n                                    name: targetDev.name || '',\n                                    device_name: targetDev.device_name || '',\n                                    mac: targetDev.mac || '',\n                                    username: creds.username || 'admin',\n                                    password: creds.password || '',\n                                    port: creds.port || 80,\n                                    online: true\n                                };\n                                if (targetDev.mac) localStorage.setItem('lastConnectedMac', targetDev.mac);\n                                // Connect to backend\n                                apiPost('/api/v1/devices/' + targetDev.ip + '/connect', {\n                                    username: creds.username || 'admin',\n                                    password: creds.password || '',\n                                    port: creds.port || 80\n                                }).then(function(connResult) {\n                                    if (connResult && connResult.success) {\n                                        addLog('info', '自动恢复连接: ' + targetDev.ip);\n                                        refreshDevices();\n                                        refreshPtzDeviceList();\n                                    }\n                                }).catch(function(e) { console.warn('Auto-connect failed:', e); });\n                                if (window.updateDeviceStatus) window.updateDeviceStatus();\n                            }\n                        }).catch(function(e) { console.warn('Failed to fetch credentials:', e); });\n                    }\n                }\n                } // end if (!window._autoConnectDone)\n            }).catch(function(e) {\n                console.warn('Failed to refresh devices:', e);\n            });\n        }\n        function renderDevices(devices) {\n            var tb = document.getElementById('deviceTable');\n            if (!tb) return;\n            if (!devices.length) {\n                tb.innerHTML = '<tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">暂无设备</td></tr>';\n                return;\n            }\n            var html = devices.map(function(d) {\n                var sourceBadge = d.source === 'sadp'\n                    ? '<span class=\"badge sadp\">SADP</span>'\n                    : '<span class=\"badge manual\">手动</span>';\n                var onlineBadge = d.online\n                    ? '<span class=\"badge online\">在线</span>'\n                    : '<span class=\"badge offline\">离线</span>';\n                var actions = buildDeviceActions(d);\n                return '<tr>'\n                    + '<td>' + sourceBadge + '</td>'\n                    + '<td>' + (d.mac || '--') + '</td>'\n                    + '<td>' + (d.ip || '--') + '</td>'\n                    + '<td>' + (d.gateway || '--') + '</td>'\n                    + '<td>' + (d.name || d.device_name || '--') + '</td>'\n                    + '<td>' + (d.model || '--') + '</td>'\n                    + '<td>' + onlineBadge + '</td>'\n                    + '<td>' + actions + '</td>'\n                    + '</tr>';\n            }).join('');\n            tb.innerHTML = html;\n        }\n        function buildDeviceActions(d) {\n            var btns = [];\n            if (d.online) {\n                btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"disconnectDevice(\\'' + d.ip + '\\')\">断开</button>');\n                btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoInline(\\'' + d.ip + '\\')\">信息</button>');\n                // Add \"引导\" button for new devices\n            } else {\n                btns.push('<button class=\"btn btn-primary btn-sm\" onclick=\"connectDevice(\\'' + d.ip + '\\')\">连接</button>');\n            }\n            // Add modify IP button for all devices\n            btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\'' + (d.mac || '') + '\\',\\'' + (d.ip || '') + '\\')\">修改IP</button>');\n            btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\')\">删除</button>');\n            return '<div class=\"actions\">' + btns.join('') + '</div>';\n        }\n        // Device Actions\n        function connectDevice(ip) {\n            addLog('info', '正在连接设备: ' + ip);\n            showToast('info', '正在连接设备...');\n            // 先获取 credentials\n            apiGet('/api/v1/ptz/devices/' + ip + '/credentials').then(function(creds) {\n                var username = (creds && creds.success) ? creds.username : 'admin';\n                var password = (creds && creds.success) ? creds.password : '';\n                var port = (creds && creds.success) ? (creds.port || 80) : 80;\n\n                // 再调用 connect API\n                apiPost('/api/v1/devices/' + ip + '/connect', { username: username, password: password, port: port }).then(function(result) {\n                    if (result && result.success) {\n                        addLog('success', result.message || '连接成功');\n                        // Set connectedDevice BEFORE refreshDevices\n                        var dev = allDevices.find(function(d) { return d.ip === ip; }) || { ip: ip };\n                        window.connectedDevice = {\n                            ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\n                            mac: dev.mac || '', username: username, password: password, port: port, online: true\n                        };\n                        if (dev.mac) localStorage.setItem('lastConnectedMac', dev.mac);\n                        // Update button immediately\n                        if (window.updateDeviceStatus) window.updateDeviceStatus();\n                        // 动态加载设备图像参数（白平衡、快门、光圈、降噪、锐度、OSD）\n                        // v5.42: 增加延迟确保设备连接完成\n                        setTimeout(function() {\n                            console.log('[CONNECT] Calling loadDeviceImageParams for:', ip);\n                            if (typeof loadDeviceImageParams === 'function') {\n                                loadDeviceImageParams(ip);\n                                console.log('[CONNECT] loadDeviceImageParams called');\n                            } else {\n                                console.error('[CONNECT] loadDeviceImageParams not found');\n                            }\n                        }, 500);\n                        // WASM SDK login (with loading indicator)\n                        showToast('info', '正在初始化视频流...');\n                        if (window.clickLogin2) { window.clickLogin2(); }\n                    } else if (result && result.message && result.message.indexOf('凭证') >= 0) {\n                        // credentials 错误，提示用户输入\n                        var username2 = prompt(\"请输入用户名:\", \"admin\");\n                        if (!username2) return;\n                        var password2 = prompt(\"请输入密码:\");\n                        if (!password2) return;\n                        connectDeviceWithCreds(ip, username2, password2, 80);\n                    } else {\n                        showToast('error', result ? result.message : '连接失败');\n                        addLog('error', result ? result.message : '连接失败');\n                    }\n                }).catch(function(e) {\n                    showToast('error', '连接异常: ' + e.message);\n                    addLog('error', '连接异常: ' + e.message);\n                });\n            }).catch(function(e) {\n                // credentials API 失败，尝试无密码连接\n                apiPost('/api/v1/devices/' + ip + '/connect', null).then(function(result) {\n                    if (result && result.success) {\n                        showToast('success', '设备已连接: ' + ip);\n                        refreshDevices();\n                        refreshPtzDeviceList();\n                        refreshAdvancedDeviceSelectors();\n                        var dev = allDevices.find(function(d) { return d.ip === ip; });\n                        if (dev) {\n                            window.connectedDevice = {\n                                ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\n                                mac: dev.mac || '', username: 'admin', password: '', port: 80, online: true\n                            };\n                            if (window.clickLogin2) { window.clickLogin2(); }\n                              if (window.updateDeviceStatus) window.updateDeviceStatus();\n                        }\n                    } else {\n                        showToast('error', result ? result.message : '连接失败');\n                    }\n                });\n            });\n        }\n\n        function connectDeviceWithCreds(ip, username, password, port) {\n            apiPost('/api/v1/devices/' + ip + '/connect', {\n                username: username, password: password, port: port\n            }).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '设备已连接: ' + ip);\n                    addLog('success', result.message || '连接成功');\n                    refreshDevices();\n                    refreshPtzDeviceList();\n                    refreshAdvancedDeviceSelectors();\n                    // --- v3: Update global window.connectedDevice ---\n                    var dev = allDevices.find(function(d) { return d.ip === ip; });\n                    if (dev) {\n                        window.connectedDevice = window.connectedDevice = {\n                            ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\n                            mac: dev.mac || '', username: username, password: password, port: port, online: true\n                        };\n                        // Save MAC to localStorage for memory\n                        if (dev.mac) localStorage.setItem('lastConnectedMac', dev.mac);\n                        addLog('info', '已记住连接设备: ' + window.connectedDevice.ip);\n                        // 动态加载设备图像参数\n                        setTimeout(function() {\n                            console.log('[CONNECT2] Calling loadDeviceImageParams for:', ip);\n                            if (typeof loadDeviceImageParams === 'function') {\n                                loadDeviceImageParams(ip);\n                            }\n                        }, 500);\n                        // WASM SDK login - user clicked Connect\n                        if (window.clickLogin2) { window.clickLogin2(); }\n                              if (window.updateDeviceStatus) window.updateDeviceStatus();\n                    }\n                } else {\n                    showToast('error', result ? result.message : '连接失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '连接异常: ' + e.message);\n            });\n        }\n        function disconnectDevice(ip) {\n            showToast('info', '正在断开设备...');\n            // --- Stop PTZ position polling ---\n            if (window.stopPtzPositionPoll) window.stopPtzPositionPoll();\n            // --- Stop WASM video stream ---\n            if (window.wasmLogout) window.wasmLogout();\n            \n            apiPost('/api/v1/devices/' + ip + '/disconnect', null).then(function() {\n                showToast('success', '设备已断开: ' + ip);\n                addLog('info', '设备已断开: ' + ip);\n                // --- Clear global window.connectedDevice first, before refresh ---\n                if (window.connectedDevice && window.connectedDevice.ip === ip) {\n                    window.connectedDevice = null;\n                    addLog('info', '已清除连接设备状态');\n                }\n                if (window.updateDeviceStatus) window.updateDeviceStatus();\n                refreshDevices();\n                refreshPtzDeviceList();\n                refreshAdvancedDeviceSelectors();\n                var panel = document.getElementById('deviceInfoPanel');\n                if (panel) panel.style.display = 'none';\n            }).catch(function(e) {\n                showToast('error', '断开异常: ' + e.message);\n            });\n        }\n        function deleteDevice(identifier) {\n            if (!confirm('确定删除设备 ' + identifier + '？')) return;\n            apiDelete('/api/v1/devices/' + identifier).then(function() {\n                showToast('success', '设备已删除');\n                addLog('info', '设备已删除: ' + identifier);\n                refreshDevices();\n                refreshPtzDeviceList();\n                refreshAdvancedDeviceSelectors();\n            }).catch(function(e) {\n                showToast('error', '删除异常: ' + e.message);\n            });\n        }\n        // Show modify IP modal for SADP device\n        // Submit modify IP\n        // Add Device Modal\n        // Connect Device Modal (credentials input)\n        // PTZ Device List Update\n        function refreshPtzDeviceList() {\n            var online = (allDevices || []).filter(function(d) { return d.online; });\n            var select = document.getElementById('ptzDevice');\n            if (select) {\n                select.innerHTML = '<option value=\"\">未选择设备</option>';\n                online.forEach(function(d) {\n                    var option = document.createElement('option');\n                    option.value = d.ip;\n                    option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\n                    select.appendChild(option);\n                });\n                if (window.connectedDevice && select.querySelector('option[value=\"' + window.connectedDevice.ip + '\"]')) {\n                    select.value = window.connectedDevice.ip;\n                }\n            }\n            // Trigger onPtzDeviceChange if connectedDevice exists (regardless of select)\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                onPtzDeviceChange();\n            }\n        }\n        function onPtzDeviceChange() {\n            var ip = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!ip) return;\n            var controlArea = document.getElementById('ptzControlArea');\n            var noDevice = document.getElementById('ptzNoDevice');\n            var connInfo = document.getElementById('ptzConnectedInfo');\n            // Only update UI if elements exist (user is on console page)\n            if (controlArea && noDevice && connInfo) {\n                controlArea.style.display = 'block';\n                noDevice.style.display = 'none';\n                connInfo.style.display = 'block';\n                document.getElementById('ptzSelectedInfo').textContent = ip;\n            }\n            // Fetch position always, but presets only once per connection\n            getPtzPosition();\n            if (!window._presetLoadedFor || window._presetLoadedFor !== ip) {\n                loadPresetList();\n                window._presetLoadedFor = ip;\n            }\n        }\n        // PTZ operation log display\n        function ptzLog(msg, type='info') {\n            const box = document.getElementById('ptzLogBox');\n            if (!box) { console.warn('[ptzLog] ptzLogBox not found'); return; }\n            const time = new Date().toLocaleTimeString();\n            const colors = {\n                'info': '#8b949e',\n                'success': '#3fb950',\n                'error': '#f85149',\n                'warning': '#d29922',\n                'debug': '#58a6ff'\n            }; \n            const icons = {\n                'info': '○',\n                'success': '●',\n                'error': '×',\n                'warning': '△',\n                'debug': '◇'\n            }; \n            const color = colors[type] || '#8b949e';\n            const icon = icons[type] || '○';\n            const entry = document.createElement('div');\n            entry.style.cssText = 'color:' + color + ';margin:2px 0;padding:2px 8px;font-size:13px;font-family:monospace';\n            entry.textContent = '[' + time + '] ' + icon + ' ' + msg;\n            box.insertBefore(entry, box.firstChild);\n            if (box.children.length > 50) box.removeChild(box.lastChild);\n            console.log('[ptzLog]', msg, type);\n        }\n        window.ptzLog = ptzLog;\n        // PTZ Controls\n        function ptzMove(dir) {\n            var dev = window.connectedDevice.ip;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\n            apiPost('/api/v1/ptz/' + dev + '/move', {\n                direction: dir, speed: speed\n            }).then(function(result) {\n                if (result && !result.success) {\n                    showToast('error', result.message || '移动失败');\n                    addLog('error', 'PTZ 移动失败: ' + (result.message || ''));\n                }\n            }).catch(function(e) {\n                addLog('info', 'PTZ 移动: ' + dir);\n            });\n        }\n        function ptzHome() {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            apiPost('/api/v1/ptz/' + dev + '/home', null).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', result.message || '归位成功');\n                } else if (result) {\n                    showToast('error', result.message || '归位失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '归位异常: ' + e.message);\n            });\n        }\n        function ptzStop() {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) return;\n            apiPost('/api/v1/ptz/' + dev + '/stop', null).catch(function(e) {});\n        }\n        function getPtzPosition() {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) return;\n            apiGet('/api/v1/ptz/' + dev + '/position').then(function(result) {\n                var posEl = document.getElementById('ptzPosition');\n                if (result && result.success && result.data) {\n                    var p = result.data;\n                    posEl.innerHTML = 'Pan: ' + (p.pan || 0) + ' | Tilt: ' + (p.tilt || 0) + ' | Zoom: ' + (p.zoom || 0);\n                } else {\n                    posEl.innerHTML = 'Pan: -- | Tilt: -- | Zoom: --';\n                }\n            }).catch(function(e) {});\n        }\n        // Calibration (placeholder)\n        function calibrate(type) {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先连接设备'); return; }\n            var dev = window.connectedDevice.ip;\n            apiPost('/api/v1/calibration/' + dev + '/' + type, null).then(function(r) {\n                if (r.ok !== false) addLog('info', '开始 ' + type + ' 校准...');\n            }).catch(function(e) { addLog('error', '校准失败'); });\n        }\n        // ASCOM (placeholder)\n        function connectAscom(type) {\n            apiPost('/api/v1/ascom/' + type + '/connect', null).then(function(r) {\n                if (r && r.success !== false) {\n                    showToast('success', type + ' 连接成功');\n                    addLog('info', type + ' 连接成功');\n                }\n            }).catch(function(e) { addLog('error', type + ' 连接失败'); });\n        }\n        // Settings (placeholder)\n        function saveSettings() {\n            apiPost('/api/v1/settings', {\n                port: parseInt(document.getElementById('settingPort').value),\n                log_level: document.getElementById('settingLogLevel').value,\n                db_path: document.getElementById('settingDbPath').value\n            }).then(function() {\n                addLog('info', '设置已保存');\n                showToast('success', '设置已保存');\n            }).catch(function(e) { showToast('error', '保存失败'); });\n        }\n        // Stream / Storage Controls\n        function refreshStreamDeviceList() {\n            var online = (allDevices || []).filter(function(d) { return d.online; });\n            var sel = document.getElementById('advStreamDevice');\n            if (!sel) return;\n            var current = sel.value;\n            sel.innerHTML = '<option value=\"\">未连接设备</option>';\n            online.forEach(function(d) {\n                var option = document.createElement('option');\n                option.value = d.ip;\n                option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\n                sel.appendChild(option);\n            });\n            if (current) sel.value = current;\n        }\n        function onStreamDeviceChange() {\n            var ip = document.getElementById('advStreamDevice').value;\n            var noDevice = document.getElementById('streamNoDevice');\n            var controlArea = document.getElementById('streamControlArea');\n            var statusSpan = document.getElementById('streamDeviceStatus');\n            if (ip) {\n                var device = allDevices.find(function(d) { return d.ip === ip; });\n                noDevice.style.display = 'none';\n                controlArea.style.display = 'block';\n                statusSpan.textContent = device ? ('已连接: ' + ip) : ip;\n                resetStreamButtons();\n            } else {\n                noDevice.style.display = 'block';\n                controlArea.style.display = 'none';\n                statusSpan.textContent = '';\n            }\n        }\n        function resetStreamButtons() {\n            document.getElementById('btnStreamStart').disabled = false;\n            document.getElementById('btnStreamStop').disabled = true;\n            document.getElementById('btnRecordStart').disabled = false;\n            document.getElementById('btnRecordStop').disabled = true;\n            document.getElementById('streamStatusInfo').textContent = '状态: 未启动';\n            document.getElementById('recordStatusInfo').textContent = '状态: 未录制';\n        }\n        function streamStart() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceId = window.connectedDevice.ip;\n            var device = allDevices.find(function(d) { return d.ip === deviceId; });\n            document.getElementById('btnStreamStart').disabled = true;\n            document.getElementById('streamStatusInfo').textContent = '状态: 正在启动...';\n            var url = '/api/v1/streams/' + deviceId + '/start';\n            // Add query params for rtsp_url and stream_name\n            // The API accepts query parameters\n            apiPost(url + '?stream_name=' + encodeURIComponent((device && device.device_name) || device.ip), null).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '推流已启动: ' + deviceId);\n                    addLog('success', result.message || '推流启动成功');\n                    document.getElementById('btnStreamStop').disabled = false;\n                    document.getElementById('streamStatusInfo').textContent = '状态: 推流中 (Stream: ' + (result.stream_id || deviceId) + ')';\n                    // Set HLS preview URL if available\n                    if (result.stream_id) {\n                        var video = document.getElementById('streamVideo');\n                        var preview = document.getElementById('streamPreview');\n                        if (video && preview) {\n                            // Try HLS source\n                            var hlsSrc = '/hls/' + result.stream_id + '/playlist.m3u8';\n                            video.src = hlsSrc;\n                            preview.style.display = 'block';\n                        }\n                    }\n                    resetAdvancedSelectors();\n                } else {\n                    showToast('error', result ? result.message : '推流启动失败');\n                    document.getElementById('btnStreamStart').disabled = false;\n                    document.getElementById('streamStatusInfo').textContent = '状态: 启动失败';\n                }\n            }).catch(function(e) {\n                showToast('error', '推流异常: ' + e.message);\n                document.getElementById('btnStreamStart').disabled = false;\n                document.getElementById('streamStatusInfo').textContent = '状态: 异常';\n            });\n        }\n        function streamStop() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceId = window.connectedDevice.ip;\n            apiPost('/api/v1/streams/' + deviceId + '/stop', null).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '推流已停止: ' + deviceId);\n                    addLog('info', '推流已停止');\n                    document.getElementById('btnStreamStart').disabled = false;\n                    document.getElementById('btnStreamStop').disabled = true;\n                    document.getElementById('streamStatusInfo').textContent = '状态: 未启动';\n                    document.getElementById('streamPreview').style.display = 'none';\n                } else {\n                    showToast('error', result ? result.message : '推流停止失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '推流异常: ' + e.message);\n            });\n        }\n        function recordStart() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceId = window.connectedDevice.ip;\n            var targetName = document.getElementById('recordTargetName').value.trim();\n            var body = targetName ? { target_name: targetName } : null;\n            document.getElementById('btnRecordStart').disabled = true;\n            document.getElementById('recordStatusInfo').textContent = '状态: 正在录制...';\n            apiPost('/api/v1/ptz/' + deviceId + '/record/start', body).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '录像已启动: ' + deviceId);\n                    addLog('success', result.message || '录像启动成功');\n                    document.getElementById('btnRecordStop').disabled = false;\n                    document.getElementById('recordStatusInfo').textContent = '状态: 录制中';\n                } else {\n                    showToast('error', result ? result.message : '录像启动失败');\n                    document.getElementById('btnRecordStart').disabled = false;\n                }\n            }).catch(function(e) {\n                showToast('error', '录像异常: ' + e.message);\n                document.getElementById('btnRecordStart').disabled = false;\n            });\n        }\n        function recordStop() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceId = window.connectedDevice.ip;\n            apiPost('/api/v1/ptz/' + deviceId + '/record/stop', null).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '录像已停止');\n                    addLog('info', '录像已停止: ' + (result.message || ''));\n                    document.getElementById('btnRecordStart').disabled = false;\n                    document.getElementById('btnRecordStop').disabled = true;\n                    document.getElementById('recordStatusInfo').textContent = '状态: 未录制';\n                } else {\n                    showToast('error', result ? result.message : '录像停止失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '录像异常: ' + e.message);\n            });\n        }\n        function snapshotCapture() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\n            var deviceId = window.connectedDevice.ip;\n            var btn = document.getElementById('btnSnapshot');\n            btn.disabled = true;\n            btn.textContent = '抓取中...';\n            apiGet('/api/v1/streams/' + deviceId + '/snapshot').then(function(result) {\n                btn.disabled = false;\n                btn.textContent = '📸 抓取快照';\n                if (result && result.success) {\n                    showToast('success', '快照抓取成功');\n                    addLog('success', result.message || '快照抓取成功');\n                    // Try to show snapshot using the data URL or preview URL\n                    if (result.data && result.data.preview_url) {\n                        // Open in new tab or show in preview\n                        var preview = document.getElementById('snapshotPreview');\n                        var img = document.getElementById('snapshotImg');\n                        if (preview && img) {\n                            img.src = result.data.preview_url;\n                            preview.style.display = 'block';\n                        }\n                    }\n                } else {\n                    showToast('error', result ? result.message : '快照抓取失败');\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.textContent = '📸 抓取快照';\n                showToast('error', '快照异常: ' + e.message);\n            });\n        }\n        // Auto refresh\n        setInterval(refreshDevices, 15000);\n        // ================================================================\n        //  主控台新增功能函数 (修复6)\n        // ================================================================\n        // 跟踪控制\n        function setTracking(mode) {\n            var dev = window.connectedDevice.ip;\n            if (!dev) { showToast('warning', '请先在上方选择已连接设备'); return; }\n            // 重置按钮状态\n            ['btnTrackSidereal','btnTrackLunar','btnTrackSolar','btnTrackOff'].forEach(function(id) {\n                var b = document.getElementById(id);\n                if(b) { b.className = 'btn btn-secondary'; b.style.opacity = '1'; }\n            });\n            apiPost('/api/v1/ascom/telescope/tracking?mode=' + mode, null).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', result.message || '跟踪模式已设置');\n                    // 高亮当前按钮\n                    var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\n                    var activeBtn = document.getElementById(btnMap[mode]);\n                    if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\n                } else {\n                    // 对于非ASCOM望远镜，给UI反馈\n                    showToast('info', '跟踪模式: ' + mode + ' (设备响应: ' + (result ? result.message : '无') + ')');\n                    var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\n                    var activeBtn = document.getElementById(btnMap[mode]);\n                    if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\n                }\n            }).catch(function(e) {\n                showToast('info', '跟踪模式: ' + mode + ' (API未响应)');\n                var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\n                var activeBtn = document.getElementById(btnMap[mode]);\n                if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\n            });\n        }\n        // 截图 (主控台版)\n        function consoleSnapshot() {\n            var dev = window.connectedDevice.ip;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            var btn = document.getElementById('btnConsoleSnapshot');\n            btn.disabled = true;\n            btn.textContent = '抓取中...';\n            apiPost('/api/v1/ptz/' + dev + '/capture', null).then(function(result) {\n                btn.disabled = false;\n                btn.textContent = '📸 截图';\n                if (result && result.success) {\n                    showToast('success', '截图成功: ' + (result.data ? result.data.filename : ''));\n                    if (result.data && result.data.image_path) {\n                        var preview = document.getElementById('consoleSnapshotPreview');\n                        var img = document.getElementById('consoleSnapshotImg');\n                        if (preview && img) {\n                            img.alt = '截图: ' + result.data.filename;\n                            preview.style.display = 'block';\n                        }\n                    }\n                } else {\n                    showToast('error', result ? result.message : '截图失败');\n                }\n            }).catch(function(e) {\n                btn.disabled = false;\n                btn.textContent = '📸 截图';\n                showToast('error', '截图异常: ' + e.message);\n            });\n        }\n        // 录像 (主控台版)\n        function consoleRecordStart() {\n            var dev = window.connectedDevice.ip;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            apiPost('/api/v1/ptz/' + dev + '/record/start', null).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '录像已启动');\n                    document.getElementById('btnConsoleRecordStart').disabled = true;\n                    document.getElementById('btnConsoleRecordStop').disabled = false;\n                    document.getElementById('consoleRecordStatus').textContent = '录制中';\n                    document.getElementById('consoleRecordStatus').style.color = '#f85149';\n                } else {\n                    showToast('error', result ? result.message : '录像启动失败');\n                }\n            }).catch(function(e) { showToast('error', '录像异常: ' + e.message); });\n        }\n        function consoleRecordStop() {\n            var dev = window.connectedDevice.ip;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            apiPost('/api/v1/ptz/' + dev + '/record/stop', null).then(function(result) {\n                showToast('info', '录像已停止');\n                document.getElementById('btnConsoleRecordStart').disabled = false;\n                document.getElementById('btnConsoleRecordStop').disabled = true;\n                document.getElementById('consoleRecordStatus').textContent = '未录制';\n                document.getElementById('consoleRecordStatus').style.color = '#8b949e';\n            }).catch(function(e) { showToast('error', '录像停止异常: ' + e.message); });\n        }\n        \n        // ============== Live Stack 实时叠加 ==============\n        var liveStackMode = 'off';\n        var liveStackRunning = false;\n        var liveStackFrameCount = 0;\n        var liveStackTargetFrames = 0;\n        var liveStackInterval = null;\n        \n        function setLiveStackMode(mode) {\n            liveStackMode = mode;\n            // 更新按钮状态\n            document.querySelectorAll('[data-stack]').forEach(function(btn) {\n                btn.classList.remove('btn-primary');\n                btn.classList.add('btn-secondary');\n            });\n            var activeBtn = document.querySelector('[data-stack=\"' + mode + '\"]');\n            if (activeBtn) {\n                activeBtn.classList.remove('btn-secondary');\n                activeBtn.classList.add('btn-primary');\n            }\n            \n            // 更新状态显示\n            var statusText = '叠加: ' + (mode === 'off' ? '关闭' : mode);\n            document.getElementById('liveStackStatus').textContent = statusText;\n        }\n        \n        function startLiveStack() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) {\n                showToast('warning', '请先连接设备');\n                return;\n            }\n            \n            if (liveStackMode === 'off') {\n                showToast('warning', '请先选择叠加档位');\n                return;\n            }\n            \n            var deviceIp = window.connectedDevice.ip;\n            var hardwareMs = parseFloat(document.getElementById('hardwareExposureMs').value) || 100;\n            \n            // 根据档位计算目标曝光\n            var exposureMap = {\n                '2s': 2, '5s': 5, '10s': 10, '30s': 30\n            };\n            var targetExposure = parseFloat(exposureMap[liveStackMode]) || 2;\n            \n            // 启动 Live Stack\n            apiPost('/api/v1/stack/start', {\n                device_ip: deviceIp,\n                target_exposure: targetExposure,\n                hardware_exposure_ms: hardwareMs,\n                mode: 'live'\n            }).then(function(result) {\n                if (result && result.success) {\n                    liveStackRunning = true;\n                    liveStackTargetFrames = result.target_frames;\n                    liveStackFrameCount = 0;\n                    \n                    showToast('success', 'Live Stack 已启动: ' + result.target_frames + '帧');\n                    \n                    // 更新按钮状态\n                    document.getElementById('btnLiveStackStart').disabled = true;\n                    document.getElementById('btnLiveStackStop').disabled = false;\n                    document.getElementById('btnLiveStackSave').disabled = true;\n                    \n                    // 开始采集帧\n                    liveStackInterval = setInterval(captureAndSendFrame, hardwareMs);\n                } else {\n                    showToast('error', result ? result.message : '启动失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '启动异常: ' + e.message);\n            });\n        }\n        \n        function captureAndSendFrame() {\n            if (!liveStackRunning) return;\n            \n            // 从 WASM Canvas 截图\n            var canvas = document.querySelector('#divPlugin canvas');\n            if (!canvas) {\n                // 尝试其他方式\n                canvas = document.getElementById('divPlugin').querySelector('canvas');\n            }\n            \n            if (!canvas) {\n                console.warn('[LiveStack] Canvas not found');\n                return;\n            }\n            \n            try {\n                var imageData = canvas.toDataURL('image/jpeg', 0.85);\n                \n                // 发送到后端\n                apiPost('/api/v1/stack/frame', {\n                    device_ip: window.connectedDevice.ip,\n                    frame_data: imageData\n                }).then(function(result) {\n                    if (result && result.success) {\n                        liveStackFrameCount = result.frame_count;\n                        var progress = Math.round(liveStackFrameCount / liveStackTargetFrames * 100);\n                        \n                        // 更新状态\n                        document.getElementById('liveStackStatus').textContent =\n                            '叠加: ' + liveStackFrameCount + '/' + liveStackTargetFrames + ' (' + progress + '%)';\n                        \n                        // 更新预览\n                        if (result.preview_base64) {\n                            // 可以显示预览（可选）\n                        }\n                        \n                        // 检查是否完成\n                        if (liveStackFrameCount >= liveStackTargetFrames) {\n                            stopLiveStack();\n                            showToast('success', '叠加完成');\n                            document.getElementById('btnLiveStackSave').disabled = false;\n                        }\n                    }\n                }).catch(function(e) {\n                    console.warn('[LiveStack] Frame send error:', e.message);\n                });\n            } catch (e) {\n                console.warn('[LiveStack] Capture error:', e.message);\n            }\n        }\n        \n        function stopLiveStack() {\n            liveStackRunning = false;\n            \n            if (liveStackInterval) {\n                clearInterval(liveStackInterval);\n                liveStackInterval = null;\n            }\n            \n            // 更新按钮状态\n            document.getElementById('btnLiveStackStart').disabled = false;\n            document.getElementById('btnLiveStackStop').disabled = true;\n            \n            document.getElementById('liveStackStatus').textContent =\n                '叠加: 已停止 (' + liveStackFrameCount + '帧)';\n        }\n        \n        function saveLiveStack() {\n            if (!window.connectedDevice || !window.connectedDevice.ip) {\n                showToast('warning', '设备未连接');\n                return;\n            }\n            \n            apiPost('/api/v1/stack/finish', {\n                device_ip: window.connectedDevice.ip,\n                save_output: true\n            }).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '已保存: ' + (result.fits_path || result.jpg_path));\n                    document.getElementById('btnLiveStackSave').disabled = true;\n                } else {\n                    showToast('error', result ? result.message : '保存失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '保存异常: ' + e.message);\n            });\n        }\n        \n        // 画面调节\n        function adjustImage(param, value) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            var labels = {brightness:'亮度',contrast:'对比度',saturation:'饱和度'};\n            var label = labels[param] || param;\n            \n            // 调用 API 更新\n            var body = {};\n            body[param] = parseInt(value);\n            apiPut('/api/v1/ptz/' + dev + '/image/settings', body).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', label + '已设置为 ' + value);\n                } else {\n                    showToast('error', result ? result.message : '设置失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '设置异常: ' + e.message);\n            });\n        }\n        function adjustImageStep(param, delta) {\n            var sliderId = 'console' + param.charAt(0).toUpperCase() + param.slice(1);\n            var slider = document.getElementById(sliderId);\n            if (!slider) return;\n            var newValue = Math.max(0, Math.min(100, parseInt(slider.value) + delta));\n            slider.value = newValue;\n            adjustImage(param, newValue);\n        }\n        // PTZ 坐标显示开关\n        function togglePtzOsd(enabled) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            // 更新按钮状态（v5.46: 使用正确的按钮 ID）\n            window.updatePtzOsdButtons(enabled);\n            apiPost('/api/v1/ptz/' + dev + '/osd/ptz', { enabled: enabled }).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', result.message || 'PTZ OSD: ' + (enabled ? '显示' : '关闭'));\n                } else {\n                    showToast('error', result ? result.message : 'PTZ OSD 切换失败');\n                }\n            }).catch(function(e) { showToast('error', 'PTZ OSD 切换异常: ' + e.message); });\n        }\n        // OSD 信息显示开关（用户自定义、日期时间等）\n        function toggleInfoOsd(enabled) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            // 更新按钮状态（v5.46: 使用正确的按钮 ID）\n            window.updateInfoOsdButtons(enabled);\n            apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled }).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', result.message || 'Info OSD: ' + (enabled ? '显示' : '关闭'));\n                } else {\n                    showToast('error', result ? result.message : 'OSD 切换失败');\n                }\n            }).catch(function(e) { showToast('error', 'OSD 切换异常: ' + e.message); });\n        }\n        // 变焦控制\n        function ptzZoom(direction) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\n            apiPost('/api/v1/ptz/' + dev + '/move', {\n                direction: direction === 'in' ? 'zoom-in' : 'zoom-out',\n                speed: speed\n            }).then(function(result) {\n                if (result && result.success) {\n                    addLog('info', '变焦: ' + direction + ' (速度=' + speed + ')');\n                } else {\n                    showToast('error', result ? result.message : '变焦失败');\n                }\n            }).catch(function(e) { showToast('error', '变焦异常: ' + e.message); });\n        }\n        // 对焦控制：直接发送移动指令，不强制切换模式\n        function ptzFocus(mode) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            \n            var dir = mode === 'near' ? 'focus-near' : mode === 'far' ? 'focus-far' : 'focus-auto';\n            // Focus 固定使用 speed=60，不使用滑块\n            var speed = 60;\n            \n            apiPost('/api/v1/ptz/' + dev + '/move', {\n                direction: dir,\n                speed: speed\n            }).then(function(result) {\n                if (result && result.success) {\n                    addLog('info', '对焦: ' + mode);\n                } else {\n                    showToast('error', result ? result.message : '对焦失败');\n                }\n            }).catch(function(e) { showToast('error', '对焦异常: ' + e.message); });\n        }\n        function setFocusMode(mode) {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            apiPost('/api/v1/ptz/' + dev + '/focus/mode', { mode: mode }).then(function(result) {\n                if (result && result.success) {\n                    showToast('success', '对焦模式: ' + mode);\n                } else {\n                    showToast('error', result ? result.message : '设置失败');\n                }\n            }).catch(function(e) {\n                showToast('error', '设置异常: ' + e.message);\n            });\n        }\n        // ================================================================\n        //  BUG-017 修复: 暴露函数到全局 window，使 HTML onclick 可调用\n        //  设备管理页面按钮（发现/添加/刷新）以及其他页面交互的\n        //  onclick 处理程序定义在 IIFE 内部，必须显式暴露到全局。\n        // ================================================================\n        var _expose = [\n            discoverDevices, refreshDevices,\n            connectDevice, disconnectDevice, deleteDevice,\n            ptzMove, ptzHome, ptzStop, getPtzPosition, onPtzDeviceChange,\n            calibrate, saveSettings,\n            funcDetectRun, funcDetectRestore,\n            limitTestRun, speedTestRun,\n            streamStart, streamStop, recordStart, recordStop, snapshotCapture,\n            onStreamDeviceChange, resetStreamButtons,\n            presetGoto, presetSet, startDetection,\n            connectFuncDetectRun, connectLimitTestRun, connectSpeedTestRun,\n            // 主控台新增 (修复6)\n            setTracking, consoleSnapshot, consoleRecordStart, consoleRecordStop,\n             adjustImage, adjustImageStep, togglePtzOsd, toggleInfoOsd,\n            ptzZoom, ptzFocus, setFocusMode,\n            // 预置点列表管理\n            loadPresetList, ptzGotoSelectedPreset, ptzSetSelectedPreset,\n            addDeviceInline, modifyIpPrompt, showDeviceInfoInline,\n            // WASM logout\n            wasmLogout,\n            // 工具函数\n            showToast, addLog,\n            // Live Stack 实时叠加\n            setLiveStackMode, startLiveStack, stopLiveStack, saveLiveStack,\n        ];\n        _expose.forEach(function(fn) { window[fn.name] = fn; });\n        // Go! - init() executes immediately for instant page interaction\n        init();\n        function loadWasmDevices() {\n            var sel = document.getElementById('device-select');\n            if (!sel) return;\n            var currentVal = sel.value;\n            apiGet('/api/v1/devices').then(function(resp) {\n                var devices = resp && resp.success ? (resp.data || resp.devices || []) : [];\n                allDevices = devices;\n                var ptzDevices = devices.filter(function(d) { return d.online && (d.type === 'ptz' || d.ptz === true); });\n                sel.innerHTML = '<option value=\"\">-- 选择 PTZ 设备 --</option>';\n                ptzDevices.forEach(function(d) {\n                    var opt = document.createElement('option');\n                    opt.value = d.ip;\n                    opt.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\n                    sel.appendChild(opt);\n                });\n                if (currentVal && sel.querySelector('option[value=\"' + currentVal + '\"]')) {\n                    sel.value = currentVal;\n                }\n            }).catch(function(e) {\n                console.warn('[WASM] Failed to load devices:', e);\n                sel.innerHTML = '<option value=\"\">-- 加载失败 --</option>';\n            });\n        }\n        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v5.47: Clear video window content\n                var container = document.getElementById('divPlugin');\n                if (container && window.WebVideoCtrl) {\n                    try {\n                        // 尝试清空视频窗口\n                        WebVideoCtrl.I_ClearWindowContent(0);\n                    } catch(e2) { console.warn('ClearWindow error:', e2); }\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = ''; \n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n        }\n        // Inline helpers (no modal)\n        function addDeviceInline() {\n            var ip = prompt(\"\\u8bbe\\u5907 IP:\");\n            if (!ip) return;\n            apiPost(\"/api/v1/devices\", { ip: ip }).then(function(r) {\n                if (r && r.success) { showToast(\"success\", \"\\u5df2\\u6dfb\\u52a0\"); refreshDevices(); }\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\n            }).catch(function(e) { showToast(\"error\", e.message); });\n        }\n        function modifyIpPrompt(mac, oldIp) {\n            var newIp = prompt(\"IP (MAC: \" + mac + \")\", oldIp);\n            if (!newIp || newIp === oldIp) return;\n            apiPost(\"/api/v1/devices/\" + oldIp, { ip: newIp, mac: mac }).then(function(r) {\n                if (r && r.success) { showToast(\"success\", \"IP \\u5df2\\u4fee\\u6539\"); refreshDevices(); }\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\n            }).catch(function(e) { showToast(\"error\", e.message); });\n        }\n        function showDeviceInfoInline(ip) {\n            var el = document.getElementById(\"deviceInfoPanel\");\n            if (!el) return;\n            el.style.display = \"block\";\n            el.innerHTML = \"\\u83b7\\u53d6\\u4e2d...\";\n            apiGet(\"/api/v1/devices/\" + ip + \"/info\").then(function(info) {\n                if (info && info.success) {\n                    var d = info.data || {};\n                    el.innerHTML = Object.keys(d).map(function(k) { return \"<div><b>\" + k + \":</b> \" + d[k] + \"</div>\"; }).join(\"\");\n                } else el.innerHTML = \"\\u65e0\\u6cd5\\u83b7\\u53d6\";\n            }).catch(function() { el.innerHTML = \"\\u5931\\u8d25\"; });\n        }\n    })();\n</script>\n    <!-- WASM SDK Scripts -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js\"></script>\n<script>\n// MD5 shim for WASM SDK (after CryptoJS loaded)\nwindow.MD5 = function(str) { return CryptoJS.MD5(str).toString(); };\nconsole.log('[WASM] MD5 shim installed');\n</script>\n    <script src=\"static/websdk/wasm/jquery.min.js\"></script>\n    <script src=\"static/websdk/wasm/webVideoCtrl.js\"></script>\n    <script src=\"static/websdk/wasm/jsPlugin-3.0.0.min.js\"></script>\n    <script>\n    // WASM SDK Initialization (GLOBAL scope)\n    (function() {\n        function initWasm() {\n            var iRet = window.WebVideoCtrl.I_SupportNoPlugin();\n            console.log('[WASM] I_SupportNoPlugin:', iRet);\n            if (!iRet) {\n                console.error('[WASM] Browser does not support noPlugin mode');\n                return;\n            }\n            WebVideoCtrl.I_InitPlugin(\"100%\", \"100%\", {\n                szId: \"divPlugin\",\n                bWndFull: true,\n                iPackageType: 2,\n                iWndowType: 1,\n                bNoPlugin: true,\n                proxyAddress: {\n                    ip: window.location.hostname,\n                    port: parseInt(window.location.port) || 80\n                },\n                proxyAddress: {\n                    ip: window.location.hostname,\n                    port: parseInt(window.location.port) || 80\n                },\n                cbEvent: function(iEventType, iParam1, iParam2) {\n                    console.log(\"[WASM] Event:\", iEventType, iParam1, iParam2);\n                },\n                cbDoubleClickWnd: function(iWndIndex, bFullScreen) {\n                    WebVideoCtrl.I_Stop();\n                },\n                cbSelWnd: function(xmlDoc) {\n                    g_iWndIndex = parseInt($(xmlDoc).find(\"SelectWnd\").eq(0).text(), 10);\n                },\n                cbInitPluginComplete: function() {\n                    console.log('[WASM] cbInitPluginComplete - inserting plugin');\n                    WebVideoCtrl.I_InsertOBJECTPlugin(\"divPlugin\");\n                    \n                    // Patch: fix oStreamClient.openStream URL parsing\n                    // SDK adds ?deviceIdentify=... to WS URL, but openStream's\n                    // parser can't handle query params in the path segment\n                    var _origOpenStream = null;\n                    try {\n                        var ds = WebVideoCtrl.w_deviceSet;\n                        if (ds && ds.length > 0) {\n                            // Will be patched after login when oStreamClient is available\n                        }\n                    } catch(e) {}\n                    \n                    // WASM SDK ready - trigger login if device already connected\n                    if (window.connectedDevice && window.connectedDevice.ip && window.clickLogin2) {\n                        console.log('[WASM] Device already connected, triggering login');\n                        window.clickLogin2();\n                    }\n                    // Update device status display\n                    if (window.updateDeviceStatus) window.updateDeviceStatus();\n                },\n                cbPluginErrorHandler: function(iWndIndex, iErrorCode, oError) {\n                    console.error('[WASM] Plugin error:', iWndIndex, iErrorCode);\n                },\n                cbPerformanceLack: function() {\n                    console.error('[WASM] Performance issue');\n                }\n            });\n            console.log('[WASM] I_InitPlugin called');\n        }\n        if (document.readyState === 'loading') {\n            document.addEventListener('DOMContentLoaded', initWasm);\n        } else {\n            initWasm();\n        }\n    })();\n</script>\n    <script>\n// WASM SDK global variables\nvar g_szDeviceIdentify = '';\nvar g_bLoggedIn = false;\nvar g_bPlaying = false;\nvar g_iRtspPort = 554;\nvar g_szDeviceIdentify2 = \"\";\nvar g_bLoggedIn2 = false;\nvar g_bPlaying2 = false;\nvar g_iRtspPort2 = 554;\nvar g_iWndIndex2 = 0;\nvar g_iWebSocketPort = 7681;\nvar g_iWndIndex = 0;\nvar g_iChannelList = [];\nvar g_iChannelID = 1;\nvar g_iChannelID = 1;\n// var connectedDevice = null; // Removed: conflicts with window.connectedDevice\n// WASM SDK global functions (simple version)\nfunction setLoginStatus(msg, color) {\n    var el = document.getElementById('login-status');\n    if (el) {\n        el.textContent = msg;\n        if (color) el.style.color = color;\n    }\n    console.log('[WASM] Status: ' + msg);\n}\nfunction clickLogin2() {\n    console.log('[CLICKLOGIN2] Called');\n    if (typeof ptzLog === 'function') ptzLog('WASM SDK 登录开始...', 'debug');\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\n        console.log('[WASM SDK] No device connected');\n        if (typeof ptzLog === 'function') ptzLog('未连接设备，无法登录', 'warning');\n        return;\n    }\n    console.log('[CLICKLOGIN2] Device IP: ' + window.connectedDevice.ip);\n    if (typeof ptzLog === 'function') ptzLog('连接设备: ' + window.connectedDevice.ip, 'info');\n    var szIP = window.connectedDevice.ip;\n    var szPort = window.connectedDevice.port || 80;\n    var szUsername = window.connectedDevice.username || 'admin';\n    var szPassword = window.connectedDevice.password || '';\n    g_szDeviceIdentify2 = szIP + '_' + szPort;\n    console.log('[WASM SDK] Login: ' + szIP + ':' + szPort);\n    \n    // 博客方案：I_Login\n    WebVideoCtrl.I_Login(szIP, 1, szPort, szUsername, szPassword, {\n        success: function(xmlDoc) {\n            g_bLoggedIn2 = true;\n            g_szDeviceIdentify2 = szIP + '_' + szPort;\n            console.log('[WASM SDK] Login success: ' + g_szDeviceIdentify2);\n            if (typeof ptzLog === 'function') ptzLog(szIP + ' 登录成功！', 'success');\n            if (window.showToast) window.showToast('success', '设备已连接: ' + szIP);\n            \n            // 博客方案：延迟500ms后执行 getDevicePort + getChannelInfo\n            setTimeout(() => {\n                // Step 1: getDevicePort\n                var oPort = WebVideoCtrl.I_GetDevicePort(g_szDeviceIdentify2);\n                console.log('[WASM SDK] GetDevicePort:', oPort);\n                if (oPort) {\n                    g_iRtspPort2 = oPort.iRtspPort || 554;\n                    g_iWebSocketPort = oPort.iWebSocketPort || 7681;\n                    if (typeof ptzLog === 'function') ptzLog('WebSocket端口: ' + g_iWebSocketPort, 'info');\n                    document.cookie = 'webVideoCtrlProxyWs=' + szIP + ':' + g_iWebSocketPort + '; path=/';\n                    document.cookie = 'webVideoCtrlProxyWsChannel=101; path=/';\n                }\n                \n                // Step 1.5: 异步获取 token 修复 szAuth（同步XHR被弃用）\n                var deviceSet = WebVideoCtrl.w_deviceSet;\n                var device = deviceSet && deviceSet.length > 0 ? deviceSet[0] : null;\n                var tokenPromise = Promise.resolve();\n                if (device && !device.szAuth) {\n                    console.log('[WASM SDK] szAuth empty, fetching token async...');\n                    tokenPromise = fetch('/ISAPI/Security/token?format=json', {credentials:'include'})\n                        .then(function(r) { return r.json(); })\n                        .then(function(data) {\n                            if (data && data.Token && data.Token.value) {\n                                device.szAuth = data.Token.value;\n                                console.log('[WASM SDK] szAuth set async:', device.szAuth.substring(0,16) + '...');\n                                if (typeof ptzLog === 'function') ptzLog('Token获取成功', 'success');\n                            }\n                        })\n                        .catch(function(e) { console.log('[WASM SDK] Token fetch failed:', e); });\n                }\n                \n                tokenPromise.then(function() {\n                getChannelInfo().then(function() {\n                    console.log('[WASM SDK] 获取通道结束');\n                    clickStartRealPlay({ iStreamType: 2 });\n                }).catch(function(err) {\n                    console.log('[WASM SDK] 获取通道失败: ' + err);\n                    g_iChannelID = 1;\n                    clickStartRealPlay({ iStreamType: 2 });\n                });\n                }); // end tokenPromise.then\n            }, 500);\n        },\n        error: function(status, xmlDoc) {\n            console.error('[WASM SDK] Login failed:', status);\n            g_bLoggedIn2 = false;\n            if (typeof ptzLog === 'function') ptzLog('登录失败: ' + status, 'error');\n        }\n    });\n}\n\n// 博客方案：getChannelInfo 返回 Promise\nfunction getChannelInfo() {\n    var szDeviceIdentify = g_szDeviceIdentify2;\n    console.log('[WASM SDK] getChannelInfo', szDeviceIdentify);\n    \n    var promise1 = new Promise((resolve) => {\n        WebVideoCtrl.I_GetAnalogChannelInfo(szDeviceIdentify, {\n            async: true,\n            success: function(xmlDoc) {\n                console.log('[WASM SDK] 获取模拟通道成功');\n                if (typeof ptzLog === 'function') ptzLog(szDeviceIdentify + ' 获取模拟通道成功！', 'info');\n                var channels = [];\n                var nodeList = xmlDoc.getElementsByTagName('VideoInputChannel');\n                for (var i = 0; i < nodeList.length; i++) {\n                    var id = nodeList[i].getElementsByTagName('id')[0]?.textContent || (i + 1);\n                    var name = nodeList[i].getElementsByTagName('name')[0]?.textContent || ('通道' + id);\n                    channels.push({ id: parseInt(id), name: name });\n                }\n                g_iChannelList = channels;\n                g_iChannelID = channels.length > 0 ? channels[0].id : 1;\n                console.log('[WASM SDK] Channels:', channels, 'Using ID:', g_iChannelID);\n                resolve();\n            },\n            error: function(status, xmlDoc) {\n                console.log('[WASM SDK] 获取模拟通道失败:', status);\n                if (typeof ptzLog === 'function') ptzLog(szDeviceIdentify + ' 获取模拟通道失败！', 'warning');\n                g_iChannelID = 1;\n                resolve();\n            }\n        });\n    });\n    \n    var promise2 = new Promise((resolve) => {\n        WebVideoCtrl.I_GetDigitalChannelInfo(szDeviceIdentify, {\n            async: true,\n            success: function(xmlDoc) {\n                console.log('[WASM SDK] 获取数字通道成功');\n                if (typeof ptzLog === 'function') ptzLog(szDeviceIdentify + ' 获取数字通道成功！', 'info');\n                resolve();\n            },\n            error: function(status, xmlDoc) {\n                console.log('[WASM SDK] 获取数字通道失败:', status);\n                resolve();\n            }\n        });\n    });\n    \n    var promise3 = new Promise((resolve) => {\n        WebVideoCtrl.I_GetZeroChannelInfo(szDeviceIdentify, {\n            async: true,\n            success: function(xmlDoc) {\n                console.log('[WASM SDK] 获取零通道成功');\n                resolve();\n            },\n            error: function(status, xmlDoc) {\n                console.log('[WASM SDK] 获取零通道失败:', status);\n                resolve();\n            }\n        });\n    });\n    \n    return Promise.all([promise1, promise2, promise3]);\n}\n\n// 切换码流\nfunction changeStreamType(streamType) {\n    console.log('[changeStreamType] streamType=' + streamType);\n    var parsedType = parseInt(streamType, 10);\n    \n    // 先停止当前播放\n    if (g_bPlaying2 && g_szDeviceIdentify2) {\n        try {\n            WebVideoCtrl.I_Stop({\n                iWndIndex: 0,\n                success: function() {\n                    console.log('[changeStreamType] stopped, starting new stream');\n                    g_bPlaying2 = false;\n                    clickStartRealPlay({ iStreamType: parsedType });\n                },\n                error: function() {\n                    console.warn('[changeStreamType] stop failed, try play anyway');\n                    g_bPlaying2 = false;\n                    clickStartRealPlay({ iStreamType: parsedType });\n                }\n            });\n        } catch(e) {\n            console.warn('[changeStreamType] I_Stop exception:', e);\n            g_bPlaying2 = false;\n            clickStartRealPlay({ iStreamType: parsedType });\n        }\n    } else {\n        clickStartRealPlay({ iStreamType: parsedType });\n    }\n}\nwindow.changeStreamType = changeStreamType;\n\n// 博客方案：clickStartRealPlay\nfunction clickStartRealPlay(options) {\n    console.log('[WASM SDK] clickStartRealPlay', options);\n    var iStreamType = options.iStreamType || 2;\n    var iChannelID = g_iChannelID || 1;\n    \n    if (typeof ptzLog === 'function') ptzLog('开始播放: 码流=' + iStreamType + ', 通道=' + iChannelID, 'info');\n    \n    WebVideoCtrl.I_StartRealPlay(g_szDeviceIdentify2, {\n        iStreamType: iStreamType,\n        iChannelID: iChannelID,\n        bZeroChannel: false,\n        success: function() {\n            g_bPlaying2 = true;\n            console.log('[WASM SDK] 播放成功');\n            if (typeof ptzLog === 'function') ptzLog('视频播放中', 'success');\n            // 启动 PTZ 位置自动刷新\n            if (window.startPtzPositionPoll) window.startPtzPositionPoll();\n        },\n        error: function(status, xmlDoc) {\n            console.error('[WASM SDK] 播放失败:', status);\n            if (typeof ptzLog === 'function') ptzLog('播放失败: ' + status, 'error');\n        }\n    });\n}\n\nwindow.clickLogin2 = clickLogin2;\nwindow.getChannelInfo = getChannelInfo;\nwindow.clickStartRealPlay = clickStartRealPlay;\n\n// PTZ 位置自动刷新\nvar _ptzPosTimer = null;\nfunction startPtzPositionPoll() {\n    if (_ptzPosTimer) return;\n    _ptzPosTimer = setInterval(function() {\n        if (window.connectedDevice && window.connectedDevice.ip) {\n            getPtzPosition();\n        }\n    }, 1000);\n}\nfunction stopPtzPositionPoll() {\n    if (_ptzPosTimer) {\n        clearInterval(_ptzPosTimer);\n        _ptzPosTimer = null;\n    }\n}\nwindow.startPtzPositionPoll = startPtzPositionPoll;\nwindow.stopPtzPositionPoll = stopPtzPositionPoll;\n</script>\n\n\n\n    <!-- Global Functions (v5.22) -->\n    <script>\n    // 设备状态指示器更新函数\n    window.updateDeviceStatus = function() {\n        var dot = document.getElementById('deviceDot');\n        var status = document.getElementById('deviceStatus');\n        var wsDot = document.getElementById('wsDot');\n        var wsStatus = document.getElementById('wsStatus');\n        \n        var connected = window.connectedDevice;\n        \n        // 获取显示名称：优先用户自定义名称，其次型号，最后 IP\n        function getDisplayName(dev) {\n            if (!dev) return '未知设备';\n            // name 是用户自定义名称\n            if (dev.name && dev.name.trim()) return dev.name.trim();\n            // device_name 是设备返回的名称\n            if (dev.device_name && dev.device_name.trim()) return dev.device_name.trim();\n            // 最后用 IP\n            return dev.ip || '未知设备';\n        }\n        \n        // 更新左侧设备状态\n        if (dot && status) {\n            if (connected) {\n                dot.className = 'status-dot green';\n                status.textContent = getDisplayName(connected);\n            } else {\n                dot.className = 'status-dot red';\n                status.textContent = '未连接';\n            }\n        }\n        \n        // 更新右上角状态\n        if (wsDot && wsStatus) {\n            if (connected) {\n                wsDot.className = 'status-dot green';\n                wsStatus.textContent = getDisplayName(connected);\n            } else {\n                wsDot.className = 'status-dot red';\n                wsStatus.textContent = '未连接';\n            }\n        }\n        \n        console.log('[UI] Status updated:', connected ? getDisplayName(connected) : 'none');\n    };\n    \n    // 页面切换函数\n    window.switchPage = function(page) {\n        document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\n        document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\n        document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\n        document.getElementById('page-' + page).classList.add('active');\n    };\n    \n    console.log('[GLOBAL v5.27] Functions ready');\n    </script>\n</body>\n</html>","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781261014344}}
