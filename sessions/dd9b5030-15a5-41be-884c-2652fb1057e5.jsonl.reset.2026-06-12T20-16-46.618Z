{"type":"message","id":"e8997c81","parentId":"ce9a1415","timestamp":"2026-06-12T03:45:31.192Z","message":{"role":"toolResult","toolCallId":"call_49fe6bfe69634df8993ca61f","toolName":"read","content":[{"type":"text","text":"                sel.innerHTML = '<option value=\"\">-- 加载失败 --</option>';\r\n            });\r\n        }\r\n        function wasmLogout() {\r\n            if (!g_bLoggedIn2) return;\r\n            try {\r\n                // Stop playback and clear video window\r\n                if (g_bPlaying2) {\r\n                    WebVideoCtrl.I_Stop();\r\n                    g_bPlaying2 = false;\r\n                }\r\n                WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\r\n            } catch(e) { console.warn('WASM logout error:', e); }\r\n            g_bLoggedIn2 = false;\r\n            g_szDeviceIdentify2 = '';\r\n            g_bPlaying2 = false;\r\n            setLoginStatus('已登出', '#8b949e');\r\n            var loginBtn = document.getElementById('login-btn');\r\n            if (loginBtn) loginBtn.textContent = '登录';\r\n        }\r\n        // Inline helpers (no modal)\r\n        function addDeviceInline() {\r\n            var ip = prompt(\"\\u8bbe\\u5907 IP:\");\r\n            if (!ip) return;\r\n            apiPost(\"/api/v1/devices\", { ip: ip }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"\\u5df2\\u6dfb\\u52a0\"); refreshDevices(); }\r\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\r\n            }).catch(function(e) { showToast(\"error\", e.message); });\r\n        }\r\n        function modifyIpPrompt(mac, oldIp) {\r\n\n[420 more lines in file. Use offset=2130 to continue.]"}],"isError":false,"timestamp":1781235931192}}
{"type":"message","id":"d5d2f68e","parentId":"e8997c81","timestamp":"2026-06-12T03:45:57.217Z","message":{"role":"assistant","content":[{"type":"text","text":"`wasmLogout` 调用了 `WebVideoCtrl.I_Stop()` 和 `WebVideoCtrl.I_Logout()`，但可能还需要清理视频窗口。检查 WASM SDK 是否有清理方法："},{"type":"toolCall","id":"tool-9db410c687d844b7884916b48b3b0263","name":"edit","arguments":{"edits":[{"newText":"        function wasmLogout() {\n            // v5.47: 即使未登录也尝试停止播放，确保画面清理\n            try {\n                // Stop playback first\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                // Logout from device\n                if (g_bLoggedIn2 && g_szDeviceIdentify2) {\n                    WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n                }\n                // v5.47: Clear video window content\n                var container = document.getElementById('divPlugin');\n                if (container && window.WebVideoCtrl) {\n                    try {\n                        // 尝试清空视频窗口\n                        WebVideoCtrl.I_ClearWindowContent(0);\n                    } catch(e2) { console.warn('ClearWindow error:', e2); }\n                }\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = ''; \n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n        }","oldText":"        function wasmLogout() {\n            if (!g_bLoggedIn2) return;\n            try {\n                // Stop playback and clear video window\n                if (g_bPlaying2) {\n                    WebVideoCtrl.I_Stop();\n                    g_bPlaying2 = false;\n                }\n                WebVideoCtrl.I_Logout(g_szDeviceIdentify2);\n            } catch(e) { console.warn('WASM logout error:', e); }\n            g_bLoggedIn2 = false;\n            g_szDeviceIdentify2 = '';\n            g_bPlaying2 = false;\n            setLoginStatus('已登出', '#8b949e');\n            var loginBtn = document.getElementById('login-btn');\n            if (loginBtn) loginBtn.textContent = '登录';\n        }"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":109368,"output":552,"cacheRead":0,"cacheWrite":0,"totalTokens":109920,"cost":{"input":0.10936799999999999,"output":0.0017664000000000002,"cacheRead":0,"cacheWrite":0,"total":0.1111344}},"stopReason":"toolUse","timestamp":1781235931195,"responseId":"cht000da472@dx19eb9ef780bba60352"}}
