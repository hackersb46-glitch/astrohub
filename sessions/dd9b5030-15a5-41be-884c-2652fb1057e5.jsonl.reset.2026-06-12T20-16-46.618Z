ata\"][\"mode\"] = \"auto\"\n+2740         return result\n+2741     except Exception as e:\n+2742         return {\"success\": False, \"message\": f\"获取曝光模式异常: {e}\"}\n+2743 \n+2744 \n+2745 @api_router.post(\"/ptz/{device_id}/image/exposure\", summary=\"设置曝光模式\", tags=[\"Image\"])\n+2746 async def set_exposure(device_id: str, data: dict) -> dict:\n+2747     \"\"\"设置曝光模式。\"\"\"\n+2748     import xml.etree.ElementTree as ET\n+2749     mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n+2750     if not mgr:\n+2751         return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n+2752 \n+2753     target_ip = _resolve_device_id_to_ip(mgr, device_id)\n+2754     if not target_ip:\n+2755         return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n+2756 \n+2757     ctrl, err = mgr._get_controller(target_ip)\n+2758     if err:\n+2759         return {\"success\": False, \"message\": err}\n+2760 \n+2761     client = ctrl.client\n+2762     try:\n+2763         mode = data.get(\"mode\", \"manual\")\n+2764         # mode: auto, manual, shutter-priority, iris-priority\n+2765         \n+2766         xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n+2767 <Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n+2768   <ExposureMode>{mode}</ExposureMode>\n+2769 </Exposure>'''\n+2770 \n+2771         put_resp = client.put(\"/Image/channels/1/exposure\", xml_str)\n+2772         if put_resp.status_code == 200:\n+2773             return {\"success\": True, \"message\": f\"曝光模式已设置为 {mode}\"}\n+2774         return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n+2775     except Exception as e:\n+2776         return {\"success\": False, \"message\": f\"设置曝光模式异常: {e}\"}\n+2777 \n+2778 \n 2708 @api_router.get(\"/ptz/{device_id}/image/shutter\", summary=\"获取快门设置\", tags=[\"Image\"])\n 2709 async def get_shutter(device_id: str) -> dict:\n 2710     \"\"\"获取设备快门当前设置。\"\"\"\n 2711     import xml.etree.ElementTree as ET\n      ...","firstChangedLine":2708},"isError":false,"timestamp":1781235086993}}
{"type":"message","id":"f6ab33d7","parentId":"6522f6cd","timestamp":"2026-06-12T03:31:58.006Z","message":{"role":"assistant","content":[{"type":"text","text":"现在修改前端，在设置快门/光圈前先切换曝光模式："},{"type":"toolCall","id":"call_cdeb28fb7b7d465f80a0533e","name":"edit","arguments":{"edits":[{"newText":"// 加载曝光模式\nfunction loadExposure(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\n        if (r && r.success && r.data) {\n            var select = document.getElementById('exposureMode');\n            if (select && r.data.mode) {\n                select.value = r.data.mode;\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Exposure] Load failed:', e);\n    });\n}\n\n// 设置曝光模式\nfunction setExposureMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '曝光模式: ' + mode);\n        });\n}\n\n// 设置快门\nfunction setShutterSpeed(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // v5.46: 设置快门前先确保曝光模式为 shutter-priority 或 manual\n    var exposureSelect = document.getElementById('exposureMode');\n    var currentExposure = exposureSelect ? exposureSelect.value : 'auto';\n    if (currentExposure === 'auto') {\n        // 自动模式下切到快门优先\n        if (exposureSelect) exposureSelect.value = 'shutter-priority';\n        apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: 'shutter-priority' });\n    }\n    \n    if (value === 'auto') {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { mode: 'auto' });\n    } else {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: ' + value);\n            });\n    }\n}\n\n// 设置光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev || !value) return;\n    \n    // v5.46: 设置光圈前先确保曝光模式为 iris-priority 或 manual\n    var exposureSelect = document.getElementById('exposureMode');\n    var currentExposure = exposureSelect ? exposureSelect.value : 'auto';\n    if (currentExposure === 'auto') {\n        // 自动模式下切到光圈优先\n        if (exposureSelect) exposureSelect.value = 'iris-priority';\n        apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: 'iris-priority' });\n    }\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            }\n        });\n}","oldText":"// 设置快门\nfunction setShutterSpeed(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    if (value === 'auto') {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { mode: 'auto' });\n    } else {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: ' + value);\n            });\n    }\n}\n\n// 设置光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev || !value) return;\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            }\n        });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":93077,"output":1120,"cacheRead":0,"cacheWrite":0,"totalTokens":94197,"cost":{"input":0.093077,"output":0.0035840000000000004,"cacheRead":0,"cacheWrite":0,"total":0.096661}},"stopReason":"toolUse","timestamp":1781235086995,"responseId":"cht000de3c1@dx19eb9e27d52ba5b442"}}
