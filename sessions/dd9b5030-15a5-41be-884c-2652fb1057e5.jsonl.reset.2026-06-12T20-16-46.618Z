{"type":"message","id":"9dc7945a","parentId":"6031a4ae","timestamp":"2026-06-12T17:46:01.003Z","message":{"role":"assistant","content":[{"type":"text","text":"**API 返回的 MAC 格式是 `24-0f-9b-76-41-93`（带横杠），但 registry 中是 `240f9b764193`（无分隔符）。**\n\n**修复 quickConnect：匹配 MAC 格式：**"},{"type":"toolCall","id":"call_b0591c8e321b4c909f84cfab","name":"edit","arguments":{"edits":[{"newText":"    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                console.log('[QUICK] Already connected');\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            console.log('[QUICK] lastMac:', lastMac);\n            \n            if (lastMac) {\n                // 等待设备列表加载\n                if (!window.allDevices || window.allDevices.length === 0) {\n                    showToast('info', '等待设备列表加载...');\n                    setTimeout(function() { window.quickConnect(true); }, 500);\n                    return;\n                }\n                \n                // v6.15: MAC 格式统一（去除分隔符）\n                var normalizeMac = function(mac) {\n                    return (mac || '').replace(/[-:]/g, '').toLowerCase();\n                };\n                var targetMac = normalizeMac(lastMac);\n                \n                var dev = (window.allDevices || []).find(function(d) {\n                    return normalizeMac(d.mac) === targetMac;\n                });\n                \n                if (dev && dev.ip) {\n                    console.log('[QUICK] Found device:', dev.ip);\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };","oldText":"    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            // 如果已连接，无需操作\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                console.log('[QUICK] Already connected');\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            console.log('[QUICK] lastMac:', lastMac, 'allDevices:', window.allDevices ? window.allDevices.length : 0);\n            \n            if (lastMac) {\n                // 等待设备列表加载\n                if (!window.allDevices || window.allDevices.length === 0) {\n                    showToast('info', '等待设备列表加载...');\n                    // 500ms 后重试\n                    setTimeout(function() { window.quickConnect(true); }, 500);\n                    return;\n                }\n                \n                var dev = (window.allDevices || []).find(function(d) { return d.mac === lastMac; });\n                if (dev && dev.ip) {\n                    console.log('[QUICK] Found device:', dev.ip);\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            // 断开连接\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":79581,"output":919,"cacheRead":0,"cacheWrite":0,"totalTokens":80500,"cost":{"input":0.079581,"output":0.0029408000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0825218}},"stopReason":"toolUse","timestamp":1781286334681,"responseId":"cht000daffe@dx19ebcf08975ba5a412"}}
