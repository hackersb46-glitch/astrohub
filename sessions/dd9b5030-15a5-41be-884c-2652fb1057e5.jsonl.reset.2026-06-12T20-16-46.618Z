{"type":"message","id":"decf1eb1","parentId":"c21967b2","timestamp":"2026-06-12T18:10:49.467Z","message":{"role":"assistant","content":[{"type":"text","text":"**从备份恢复 e2e_test.py：**"},{"type":"toolCall","id":"tool-b198683e31324f4ebfcdef5322ac6961","name":"write","arguments":{"content":"\"\"\"AstroHub E2E 测试\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_astrohub():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        errors = []\n        \n        try:\n            # 1. 打开主页\n            print('[TEST] 打开主页...')\n            page.goto('http://localhost:10280/', timeout=10000)\n            page.wait_for_load_state('networkidle', timeout=15000)\n            print('[PASS] 主页加载成功')\n            \n            # 2. 检查版本号\n            version = page.locator('.version').text_content()\n            print(f'[INFO] 版本: {version}')\n            \n            # 3. 检查设备列表\n            print('[TEST] 切换到设备管理...')\n            page.click('button[data-page=\"devices\"]')\n            page.wait_for_timeout(3000)\n            \n            device_rows = page.locator('#deviceTable tr').count()\n            print(f'[INFO] 设备数量: {device_rows}')\n            \n            if device_rows > 0:\n                first_row = page.locator('#deviceTable tr').first\n                row_text = first_row.text_content()\n                print(f'[DEBUG] 第一行: {row_text[:80]}...')\n                print('[PASS] 设备列表渲染正常')\n            else:\n                errors.append('设备列表为空')\n            \n            # 4. 检查设备状态\n            print('[TEST] 检查设备连接按钮...')\n            disconnect_btn = page.locator('button.disconnect-btn').count()\n            if disconnect_btn > 0:\n                print('[PASS] 设备在线，显示断开按钮')\n            else:\n                print('[INFO] 设备离线')\n            \n            # 5. 截图\n            page.screenshot(path='tests/screenshots/e2e_final.png')\n            print('[INFO] 截图已保存')\n            \n        except Exception as e:\n            errors.append(str(e))\n            page.screenshot(path='tests/screenshots/error.png')\n        \n        finally:\n            browser.close()\n        \n        if errors:\n            print('[FAILED] 错误:', errors)\n            return False\n        else:\n            print('[PASS] 所有测试通过')\n            return True\n\nif __name__ == '__main__':\n    test_astrohub()","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_test.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":105763,"output":547,"cacheRead":0,"cacheWrite":0,"totalTokens":106310,"cost":{"input":0.105763,"output":0.0017504,"cacheRead":0,"cacheWrite":0,"total":0.1075134}},"stopReason":"toolUse","timestamp":1781287825821,"responseId":"cht000ddfe7@dx19ebd073b6cba5d322"}}
