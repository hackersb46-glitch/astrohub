{"type":"message","id":"67a9f0b3","parentId":"a1c01a04","timestamp":"2026-06-12T03:14:45.607Z","message":{"role":"assistant","content":[{"type":"text","text":"让我查看完整的相关代码段："},{"type":"toolCall","id":"call_84c05d5607d1494e8a22350e","name":"read","arguments":{"limit":100,"offset":1940,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}},{"type":"toolCall","id":"call_e22f2b8b7ed940edbfe67bea","name":"read","arguments":{"limit":50,"offset":1960,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":31621,"output":97,"cacheRead":0,"cacheWrite":0,"totalTokens":31718,"cost":{"input":0.031620999999999996,"output":0.0003104,"cacheRead":0,"cacheWrite":0,"total":0.0319314}},"stopReason":"toolUse","timestamp":1781234080670,"responseId":"cht000d4e4d@dx19eb9d32187ba5e412"}}
{"type":"message","id":"1c68b665","parentId":"67a9f0b3","timestamp":"2026-06-12T03:14:45.617Z","message":{"role":"toolResult","toolCallId":"call_84c05d5607d1494e8a22350e","toolName":"read","content":[{"type":"text","text":"        }\r\n        \r\n        // 画面调节\r\n        function adjustImage(param, value) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            var labels = {brightness:'亮度',contrast:'对比度',saturation:'饱和度'};\r\n            var label = labels[param] || param;\r\n            \r\n            // 调用 API 更新\r\n            var body = {};\r\n            body[param] = parseInt(value);\r\n            apiPut('/api/v1/ptz/' + dev + '/image/settings', body).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', label + '已设置为 ' + value);\r\n                } else {\r\n                    showToast('error', result ? result.message : '设置失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '设置异常: ' + e.message);\r\n            });\r\n        }\r\n        function adjustImageStep(param, delta) {\r\n            var sliderId = 'console' + param.charAt(0).toUpperCase() + param.slice(1);\r\n            var slider = document.getElementById(sliderId);\r\n            if (!slider) return;\r\n            var newValue = Math.max(0, Math.min(100, parseInt(slider.value) + delta));\r\n            slider.value = newValue;\r\n            adjustImage(param, newValue);\r\n        }\r\n        // PTZ 坐标显示开关\r\n        function togglePtzOsd(enabled) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/osd/ptz?enabled=' + enabled, null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message);\r\n                    document.getElementById('btnPtzOsdOn').className = enabled ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-secondary';\r\n                    document.getElementById('btnPtzOsdOff').className = enabled ? 'btn btn-sm btn-secondary' : 'btn btn-sm btn-primary';\r\n                } else {\r\n                    showToast('error', result ? result.message : 'PTZ OSD 切换失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', 'PTZ OSD 切换异常: ' + e.message); });\r\n        }\r\n        // OSD 信息显示开关（用户自定义、日期时间等）\r\n        function toggleInfoOsd(enabled) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/osd/info?enabled=' + enabled, null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message);\r\n                    document.getElementById('btnInfoOsdOn').className = enabled ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-secondary';\r\n                    document.getElementById('btnInfoOsdOff').className = enabled ? 'btn btn-sm btn-secondary' : 'btn btn-sm btn-primary';\r\n                } else {\r\n                    showToast('error', result ? result.message : 'OSD 切换失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', 'OSD 切换异常: ' + e.message); });\r\n        }\r\n        // 变焦控制\r\n        function ptzZoom(direction) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: direction === 'in' ? 'zoom-in' : 'zoom-out',\r\n                speed: speed\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', '变焦: ' + direction + ' (速度=' + speed + ')');\r\n                } else {\r\n                    showToast('error', result ? result.message : '变焦失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', '变焦异常: ' + e.message); });\r\n        }\r\n        // 对焦控制：直接发送移动指令，不强制切换模式\r\n        function ptzFocus(mode) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            \r\n            var dir = mode === 'near' ? 'focus-near' : mode === 'far' ? 'focus-far' : 'focus-auto';\r\n            // Focus 固定使用 speed=60，不使用滑块\r\n            var speed = 60;\r\n            \r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir,\r\n                speed: speed\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', '对焦: ' + mode);\r\n                } else {\r\n                    showToast('error', result ? result.message : '对焦失败');\r\n                }\r\n            }).catch(function(e) { showToast('error', '对焦异常: ' + e.message); });\r\n        }\r\n        function setFocusMode(mode) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/focus/mode', { mode: mode }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '对焦模式: ' + mode);\r\n\n[510 more lines in file. Use offset=2040 to continue.]"}],"isError":false,"timestamp":1781234085617}}
