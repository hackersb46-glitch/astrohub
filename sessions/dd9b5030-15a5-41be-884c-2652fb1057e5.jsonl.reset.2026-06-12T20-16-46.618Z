{"type":"message","id":"14ecafa7","parentId":"7893cb50","timestamp":"2026-06-12T17:34:26.233Z","message":{"role":"toolResult","toolCallId":"call_e4103d57d21d4eb1b8fa09b4","toolName":"read","content":[{"type":"text","text":"        }\r\n    };\r\n    \r\n    // 快速连接函数（连接上次设备）\r\n    window.quickConnect = function(checked) {\r\n        if (checked) {\r\n            // 如果已连接，无需操作\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                return;\r\n            }\r\n            \r\n            var lastMac = localStorage.getItem('lastConnectedMac');\r\n            if (lastMac) {\r\n                // 查找设备 IP\r\n                var dev = (window.allDevices || []).find(function(d) { return d.mac === lastMac; });\r\n                if (dev && dev.ip) {\r\n                    // 复用 connectDevice 函数\r\n                    if (window.connectDevice) {\r\n                        window.connectDevice(dev.ip);\r\n                    }\r\n                } else {\r\n                    showToast('warning', '上次设备不在列表中');\r\n                    document.getElementById('quickConnectSwitch').checked = false;\r\n                }\r\n            } else {\r\n                showToast('warning', '无上次连接记录');\r\n                document.getElementById('quickConnectSwitch').checked = false;\r\n            }\r\n        } else {\r\n            // 断开连接\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                disconnectDevice(window.connectedDevice.ip);\r\n            }\r\n        }\r\n    };\r\n    \r\n    // 确认重启\r\n    window.confirmRestart = function() {\r\n        if (!confirm('确定要重启 AstroHub 吗？\\n重启期间服务将暂时不可用。')) return;\r\n        \r\n\n[40 more lines in file. Use offset=2683 to continue.]"}],"isError":false,"timestamp":1781285666233}}
{"type":"message","id":"bbf10222","parentId":"14ecafa7","timestamp":"2026-06-12T17:34:44.456Z","message":{"role":"assistant","content":[{"type":"text","text":"逻辑正确。问题可能是 `window.allDevices` 未加载。添加等待逻辑："},{"type":"toolCall","id":"tool-a5e02a7d3d64497e8bd85236dfe55150","name":"edit","arguments":{"edits":[{"newText":"    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            // 如果已连接，无需操作\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                console.log('[QUICK] Already connected');\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            console.log('[QUICK] lastMac:', lastMac, 'allDevices:', window.allDevices ? window.allDevices.length : 0);\n            \n            if (lastMac) {\n                // 等待设备列表加载\n                if (!window.allDevices || window.allDevices.length === 0) {\n                    showToast('info', '等待设备列表加载...');\n                    // 500ms 后重试\n                    setTimeout(function() { window.quickConnect(true); }, 500);\n                    return;\n                }\n                \n                var dev = (window.allDevices || []).find(function(d) { return d.mac === lastMac; });\n                if (dev && dev.ip) {\n                    console.log('[QUICK] Found device:', dev.ip);\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            // 断开连接\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };","oldText":"    // 快速连接函数（连接上次设备）\n    window.quickConnect = function(checked) {\n        if (checked) {\n            // 如果已连接，无需操作\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                return;\n            }\n            \n            var lastMac = localStorage.getItem('lastConnectedMac');\n            if (lastMac) {\n                // 查找设备 IP\n                var dev = (window.allDevices || []).find(function(d) { return d.mac === lastMac; });\n                if (dev && dev.ip) {\n                    // 复用 connectDevice 函数\n                    if (window.connectDevice) {\n                        window.connectDevice(dev.ip);\n                    }\n                } else {\n                    showToast('warning', '上次设备不在列表中');\n                    document.getElementById('quickConnectSwitch').checked = false;\n                }\n            } else {\n                showToast('warning', '无上次连接记录');\n                document.getElementById('quickConnectSwitch').checked = false;\n            }\n        } else {\n            // 断开连接\n            if (window.connectedDevice && window.connectedDevice.ip) {\n                disconnectDevice(window.connectedDevice.ip);\n            }\n        }\n    };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":56337,"output":726,"cacheRead":0,"cacheWrite":0,"totalTokens":57063,"cost":{"input":0.056337,"output":0.0023232,"cacheRead":0,"cacheWrite":0,"total":0.058660199999999996}},"stopReason":"toolUse","timestamp":1781285666234,"responseId":"cht000d5f1d@dx19ebce64b00ba5b442"}}
