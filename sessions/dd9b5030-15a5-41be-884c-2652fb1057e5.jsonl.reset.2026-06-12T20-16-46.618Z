{"type":"message","id":"2c798117","parentId":"65d64606","timestamp":"2026-06-12T03:42:19.935Z","message":{"role":"assistant","content":[{"type":"text","text":"简化快门光圈设置函数（去掉自动切换曝光模式的逻辑）："},{"type":"toolCall","id":"tool-7ae0b8233329400f9de9decf056921a6","name":"edit","arguments":{"edits":[{"newText":"// 设置快门\nfunction setShutterSpeed(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n        .then(function(r) {\n            if (r && r.success) showToast('success', '快门: ' + value);\n        });\n}\n\n// 设置光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev || !value) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            }\n        });\n}","oldText":"// 设置快门\nfunction setShutterSpeed(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // v5.46: 设置快门前先确保曝光模式为 shutter-priority 或 manual\n    var exposureSelect = document.getElementById('exposureMode');\n    var currentExposure = exposureSelect ? exposureSelect.value : 'auto';\n    if (currentExposure === 'auto') {\n        // 自动模式下切到快门优先\n        if (exposureSelect) exposureSelect.value = 'shutter-priority';\n        apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: 'shutter-priority' });\n    }\n    \n    if (value === 'auto') {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { mode: 'auto' });\n    } else {\n        apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\n            .then(function(r) {\n                if (r && r.success) showToast('success', '快门: ' + value);\n            });\n    }\n}\n\n// 设置光圈\nfunction setIris(value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev || !value) return;\n    \n    // v5.46: 设置光圈前先确保曝光模式为 iris-priority 或 manual\n    var exposureSelect = document.getElementById('exposureMode');\n    var currentExposure = exposureSelect ? exposureSelect.value : 'auto';\n    if (currentExposure === 'auto') {\n        // 自动模式下切到光圈优先\n        if (exposureSelect) exposureSelect.value = 'iris-priority';\n        apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: 'iris-priority' });\n    }\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                var select = document.getElementById('irisLevel');\n                var label = select.options[select.selectedIndex].text;\n                showToast('success', '光圈: ' + label);\n            }\n        });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":99071,"output":844,"cacheRead":0,"cacheWrite":0,"totalTokens":99915,"cost":{"input":0.09907099999999999,"output":0.0027008,"cacheRead":0,"cacheWrite":0,"total":0.1017718}},"stopReason":"toolUse","timestamp":1781235716143,"responseId":"cht000d7f6d@dx19eb9ec1375ba60352"}}
