{"type":"message","id":"d8b41cd5","parentId":"146d2d8a","timestamp":"2026-06-12T03:15:50.406Z","message":{"role":"toolResult","toolCallId":"call_37a02afc3af643a6bc31b8da","toolName":"read","content":[{"type":"text","text":"        {% include \"includes/advanced.html\" %}\r\n        {% include \"includes/replay.html\" %}\r\n    </div>\r\n    <!-- Toast 容器 -->\r\n    <div class=\"toast-container\" id=\"toastContainer\"></div>\r\n    <!-- Modal 容器 -->\r\n    <div id=\"modalContainer\"></div>\r\n    <!-- WASM SDK Plugin Container is in console.html -->\r\n    <script>\r\n        console.log(\"[MAIN SCRIPT] Starting script execution\");\r\n        // WASM SDK global variables (before IIFE)\r\n        var g_szDeviceIdentify = '';\r\n        var g_bLoggedIn = false;\r\n        var g_bPlaying = false;\r\n        var g_iRtspPort = 554;\r\nvar g_szDeviceIdentify2 = \"\";\r\nvar g_bLoggedIn2 = false;\r\nvar g_bPlaying2 = false;\r\nvar g_iRtspPort2 = 554;\r\nvar g_iWndIndex2 = 0;\r\nvar g_iWebSocketPort = 7681;\r\n        var g_iWndIndex = 0;\r\nvar g_iChannelList = [];\r\nvar g_iChannelID = 1;\r\n        var g_iChannelID = 1;\r\n// Global functions\r\n    (function() {\r\n        'use strict';\r\n        // ================================================================\r\n        //  Configuration\r\n        // ================================================================\r\n        var API_BASE = window.location.origin;\r\n        var WS_URL = (window.location.protocol === 'https:' ? 'wss' : 'ws') + '://' + window.location.host + '/ws';\r\n        // Cached device data\r\n        var allDevices = [];\r\n        var currentModal = null;\r\n        // --- v3: Global connected device state ---\r\n        // Advanced menu state (now sidebar)\r\n        var advMenuActive = false;\r\n        var advCurrentSub = 'calibration';\r\n        // Onboarding wizard state\r\n        var wizardState = {\r\n            step: 0,\r\n            totalSteps: 5,\r\n            mac: '',\r\n            deviceIP: '',\r\n            runningTest: false,\r\n            testResults: { function: null, limit: null, speed: null }\r\n        };\r\n        // ================================================================\r\n        //  Initialization\r\n        // ================================================================\r\n        function init() {\r\n            console.log('[INIT] init() called');\r\n            updateClock();\r\n            setInterval(updateClock, 1000);\r\n            initNav();\r\n            initPtzSpeed();\r\n            initMouseUp();\r\n            refreshDevices();\r\n            addLog('info', 'AstroHub 已启动');\r\n            connectWS();\r\n        }\r\n        // ================================================================\r\n        //  Navigation\r\n        // ================================================================\r\n        function initNav() {\r\n            document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n                btn.addEventListener('click', function() {\r\n                    document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n                    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n                    btn.classList.add('active');\r\n                    document.getElementById('page-' + btn.getAttribute('data-page')).classList.add('active');\r\n                    if (btn.getAttribute('data-page') === 'devices') { refreshDevices(); autoSadpDiscover(); }\r\n                    if (btn.getAttribute('data-page') === 'console') {\r\n                        refreshPtzDeviceList();\r\n                        loadWasmDevices();\r\n                        // Resize WASM player when console becomes visible\r\n                        setTimeout(function() {\r\n                            var container = document.getElementById('divPlugin');\r\n                            if (container && window.WebVideoCtrl) {\r\n                                try { WebVideoCtrl.I_Resize(container.offsetWidth, container.offsetHeight); console.log('[WASM] Resized to', container.offsetWidth, container.offsetHeight); } catch(e) { console.warn('Resize error:', e); }\r\n                            }\r\n                        }, 100);\r\n                        // WASM login if already connected\r\n                        if (window.connectedDevice && window.clickLogin2) {\r\n                            window.clickLogin2();\r\n                        }\r\n                    }\r\n                    if (btn.getAttribute('data-page') === 'advanced') initAdvSidebar();\r\n                    if (btn.getAttribute('data-page')) refreshAdvancedDeviceSelectors();\r\n                });\r\n            });\r\n        }\r\n        // Sidebar click handlers for advanced page sub-items\r\n        function initAdvSidebar() {\r\n            document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(item) {\r\n                item.onclick = function() {\r\n                    var subPage = item.getAttribute('data-sub');\r\n                    // Update sidebar active state\r\n                    document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(b) { b.classList.remove('active'); });\r\n                    item.classList.add('active');\r\n                    // Show sub-page\r\n                    document.querySelectorAll('#advContent .page').forEach(function(p) { p.classList.remove('active'); });\r\n                    var target = document.getElementById('page-' + subPage);\r\n                    if (target) target.classList.add('active');\r\n                    advCurrentSub = subPage;\r\n                };\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  Device Selectors for Advanced Pages\r\n        // ================================================================\r\n        function refreshAdvancedDeviceSelectors() {\r\n            var online = (allDevices || []).filter(function(d) { return d.online; });\r\n            var selectors = ['advFuncDevice', 'advLimitDevice', 'advSpeedDevice', 'calDevice', 'advStreamDevice'];\r\n            selectors.forEach(function(id) {\r\n                var sel = document.getElementById(id);\r\n                if (!sel) return;\r\n                var current = sel.value;\r\n                // Rebuild options\r\n                sel.innerHTML = '';\r\n                if (id === 'calDevice' || id === 'advConnectDevice') {\r\n                    var defaultOpt = document.createElement('option');\r\n                    defaultOpt.textContent = '未选择设备';\r\n                    defaultOpt.value = '';\r\n                    sel.appendChild(defaultOpt);\r\n                }\r\n                online.forEach(function(d) {\r\n                    var option = document.createElement('option');\r\n                    option.value = d.ip;\r\n                    option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                    sel.appendChild(option);\r\n                });\r\n                if (current) sel.value = current;\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  API helpers - exposed to global scope for console.html\r\n        // ================================================================\r\n        async function apiGet(path) {\r\n            var r = await fetch(API_BASE + path);\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        async function apiPost(path, body) {\r\n            var opts = { method: 'POST', headers: {'Content-Type': 'application/json'} };\r\n            if (body) opts.body = JSON.stringify(body);\r\n            var r = await fetch(API_BASE + path, opts);\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        // Expose to global scope\r\n        window.apiGet = apiGet;\r\n        window.apiPost = apiPost;\r\n        async function apiDelete(path) {\r\n            var r = await fetch(API_BASE + path, { method: 'DELETE' });\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        async function apiPut(path, body) {\r\n            var r = await fetch(API_BASE + path, {\r\n                method: 'PUT',\r\n                headers: { 'Content-Type': 'application/json' },\r\n                body: JSON.stringify(body)\r\n            });\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        window.apiDelete = apiDelete;\r\n        window.apiPut = apiPut;\r\n        // ================================================================\r\n        //  Function Detection (P4.1-P4.21)\r\n        // ================================================================\r\n        function funcDetectRun() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnFuncRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 探测中...';\r\n            document.getElementById('funcProgress').style.display = 'block';\r\n            document.getElementById('funcResultArea').innerHTML = '';\r\n            addLog('info', '功能探测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/function/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始探测';\r\n                document.getElementById('funcProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '功能探测完成');\r\n                    addLog('success', '功能探测完成: ' + (resp.message || ''));\r\n                    renderFuncResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '探测失败');\r\n                    addLog('error', '功能探测失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始探测';\r\n                document.getElementById('funcProgress').style.display = 'none';\r\n                showToast('error', '探测异常: ' + e.message);\r\n            });\r\n            // Simulate progress (REMOVED - hardcoded fake progress)\r\n            // Progress bar now: 0% on start → \"执行中...\" → 100% on real API response\r\n        }\r\n        function funcDetectRestore() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var btn = document.getElementById('btnFuncRestore');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 恢复中...';\r\n            apiPost('/api/v1/advanced/function/restore?device_ip=' + deviceIp + '&username=admin&password=&port=80', null).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '⟳ 恢复默认值';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '参数已恢复默认值');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '恢复失败');\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '⟳ 恢复默认值';\r\n                showToast('error', '恢复异常: ' + e.message);\r\n            });\r\n        }\r\n        function renderFuncResults(results) {\r\n            var area = document.getElementById('funcResultArea');\r\n            var html = '<table class=\"result-table\"><thead><tr><th>功能</th><th>支持</th><th>最小值</th><th>最大值</th><th>当前值</th><th>状态</th></tr></thead><tbody>';\r\n            var keys = Object.keys(results);\r\n            if (keys.length === 0) {\r\n                html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">暂无结果</td></tr>';\r\n            } else {\r\n                keys.forEach(function(key) {\r\n                    var item = results[key];\r\n                    var supported = item.supported ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>';\r\n                    var status = item.status || '完成';\r\n                    html += '<tr>';\r\n                    html += '<td>' + key + '</td>';\r\n                    html += '<td>' + supported + '</td>';\r\n                    html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\r\n                    html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\r\n                    html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\r\n                    html += '<td><span class=\"badge yes\">' + status + '</span></td>';\r\n                    html += '</tr>';\r\n                });\r\n            }\r\n            html += '</tbody></table>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Limit Test (P6.0-P6.4)\r\n        // ================================================================\r\n        function limitTestRun() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnLimitRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('limitProgress').style.display = 'block';\r\n            document.getElementById('limitDirection').style.display = 'block';\r\n            document.getElementById('limitResultArea').innerHTML = '';\r\n            addLog('info', '限位测试开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/limit/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '限位测试完成');\r\n                    addLog('success', '限位测试完成: ' + (resp.message || ''));\r\n                    renderLimitResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '限位测试失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded simulation)\r\n            var limitProgText = document.getElementById('limitProgressText');\r\n            var limitProgBar = document.getElementById('limitProgressBar');\r\n            var limitDirEl = document.getElementById('limitDirection');\r\n            if (limitProgText) limitProgText.textContent = '测试中... 等待设备响应';\r\n            if (limitProgBar) limitProgBar.style.width = '30%';\r\n            if (limitDirEl) { limitDirEl.textContent = '当前方向: 初始化...'; limitDirEl.style.display = 'block'; }\r\n\n[2080 more lines in file. Use offset=470 to continue.]"}],"isError":false,"timestamp":1781234150406}}
