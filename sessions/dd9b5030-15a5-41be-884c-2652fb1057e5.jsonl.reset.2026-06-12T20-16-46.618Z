{"type":"message","id":"32f66481","parentId":"f1335ffd","timestamp":"2026-06-12T10:39:01.879Z","message":{"role":"toolResult","toolCallId":"call_ec2b4b35f5ee4d7d955012b2","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 1 block(s) in C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\device_manager.py."}],"details":{"diff":"     ...\n  94 \n  95     def __init__(self, storage_path: Path | None = None) -> None:\n  96         \"\"\"初始化设备管理器。\n  97 \n- 98         Args:\n- 99             storage_path: 设备数据持久化 JSON 路径，默认使用 CONFIG_DIR/ptz_config.json。\n+ 98         v6.10: 使用 data/devices/{mac}/ 目录存储设备数据。\n 100         \"\"\"\n 101         self._devices: dict[str, Device] = {}\n 102         self._groups: dict[str, DeviceGroup] = {}\n 103         self._backups: dict[str, Any] = {}  # mac -> config backup data\n 104         self._lock = threading.RLock()\n 105 \n-106         if storage_path is None:\n-107             CONFIG_DIR.mkdir(parents=True, exist_ok=True)\n-108             storage_path = CONFIG_DIR / \"ptz_config.json\"\n-109         self._storage_path = storage_path.resolve()\n+105         from src.config_paths import DEVICES_DIR, REGISTRY_FILE\n+106         self._devices_dir = DEVICES_DIR\n+107         self._registry_file = REGISTRY_FILE\n+108         self._devices_dir.mkdir(parents=True, exist_ok=True)\n 110 \n-111         CONFIG_BACKUP_DIR.mkdir(parents=True, exist_ok=True)\n-112 \n 113         self._load()\n-114         log.info(f\"DeviceManager 初始化完成, storage={self._storage_path}\")\n+111         log.info(f\"DeviceManager 初始化完成, devices_dir={self._devices_dir}\")\n 115 \n 116     # ============================================================\n 117     # Registration\n 118     # ============================================================\n     ...","firstChangedLine":98},"isError":false,"timestamp":1781260741879}}
{"type":"message","id":"1849fd42","parentId":"32f66481","timestamp":"2026-06-12T10:39:23.852Z","message":{"role":"assistant","content":[{"type":"text","text":"修改 `_save` 方法："},{"type":"toolCall","id":"call_92396a741de84e798bcc2630","name":"edit","arguments":{"edits":[{"newText":"    def _save(self) -> None:\n        \"\"\"v6.10: 持久化数据到 devices/{mac}/info.json + registry.json。\"\"\"\n        with self._lock:\n            # 保存每个设备到独立文件\n            for mac, dev in self._devices.items():\n                device_dir = self._devices_dir / mac\n                device_dir.mkdir(parents=True, exist_ok=True)\n                info_path = device_dir / \"info.json\"\n                \n                # 读取现有数据，合并\n                existing = {}\n                if info_path.exists():\n                    try:\n                        with open(info_path, \"r\", encoding=\"utf-8\") as f:\n                            existing = json.load(f)\n                    except Exception:\n                        pass\n                \n                dev_data = {\n                    \"mac\": mac,\n                    \"ip\": dev.ip,\n                    \"name\": dev.name,\n                    \"model\": dev.model,\n                    \"status\": dev.status,\n                    \"registered_at\": dev.registered_at,\n                    \"last_heartbeat\": dev.last_heartbeat,\n                }\n                if dev.metadata:\n                    dev_data.update(dev.metadata)\n                \n                # 合并现有数据\n                existing.update(dev_data)\n                existing[\"last_updated\"] = datetime.now(timezone.utc).replace(tzinfo=None).isoformat()\n                \n                with open(info_path, \"w\", encoding=\"utf-8\") as f:\n                    json.dump(existing, f, indent=2, ensure_ascii=False)\n            \n            # 更新 registry.json\n            registry = {\"devices\": {}, \"active_device\": \"\"}\n            if self._registry_file.exists():\n                try:\n                    with open(self._registry_file, \"r\", encoding=\"utf-8\") as f:\n                        registry = json.load(f)\n                except Exception:\n                    pass\n            \n            for mac, dev in self._devices.items():\n                registry[\"devices\"][mac] = {\n                    \"name\": dev.name,\n                    \"model\": dev.model,\n                    \"ip\": dev.ip,\n                    \"last_seen\": dev.last_heartbeat,\n                }\n            \n            if self._devices:\n                registry[\"active_device\"] = list(self._devices.keys())[0]\n            \n            with open(self._registry_file, \"w\", encoding=\"utf-8\") as f:\n                json.dump(registry, f, indent=2, ensure_ascii=False)\n            \n            log.info(f\"设备数据已保存: {len(self._devices)} 台设备\")","oldText":"    def _save(self) -> None:\n        \"\"\"持久化数据到 JSON 文件。\n\n        ptz_config.json 格式:\n        {\n            \"devices\": {\n                \"MAC\": {ip, username, password, port, model, ...}\n            }\n        }\n        \"\"\"\n        with self._lock:\n            # ptz_config.json 格式: devices 是 dict\n            devices_dict = {}\n            for mac, dev in self._devices.items():\n                dev_data = {\n                    \"ip\": dev.ip,\n                    \"name\": dev.name,\n                    \"model\": dev.model,\n                    \"status\": dev.status,\n                    \"registered_at\": dev.registered_at,\n                    \"last_heartbeat\": dev.last_heartbeat,\n                }\n                # 合并 metadata 中的字段\n                if dev.metadata:\n                    dev_data.update(dev.metadata)\n                devices_dict[mac] = dev_data\n\n            data = {\n                \"devices\": devices_dict\n            }\n\n            tmp_path = self._storage_path.with_suffix(\".tmp\")\n            with open(tmp_path, \"w\", encoding=\"utf-8\") as f:\n                json.dump(data, f, indent=2, ensure_ascii=False)\n            tmp_path.replace(self._storage_path)\n            log.info(f\"设备数据已保存: {len(self._devices)} 台设备\")"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\device_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":123367,"output":933,"cacheRead":0,"cacheWrite":0,"totalTokens":124300,"cost":{"input":0.12336699999999999,"output":0.0029856,"cacheRead":0,"cacheWrite":0,"total":0.12635259999999998}},"stopReason":"toolUse","timestamp":1781260741882,"responseId":"cht000d5b95@dx19ebb69ef03b85f582"}}
