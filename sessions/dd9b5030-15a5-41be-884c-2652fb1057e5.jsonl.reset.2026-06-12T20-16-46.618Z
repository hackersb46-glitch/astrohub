{"type":"message","id":"20abac33","parentId":"b1ea6e24","timestamp":"2026-06-12T03:42:47.520Z","message":{"role":"assistant","content":[{"type":"text","text":"在加载曝光模式后调用状态更新："},{"type":"toolCall","id":"call_3ec0274bbbb64e47be509668","name":"edit","arguments":{"edits":[{"newText":"// 加载曝光模式\nfunction loadExposure(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\n        if (r && r.success && r.data) {\n            var select = document.getElementById('exposureMode');\n            if (select && r.data.mode) {\n                // v5.47: 只支持 auto/manual，其他模式统一为 manual\n                select.value = (r.data.mode === 'auto') ? 'auto' : 'manual';\n                // 更新快门光圈禁用状态\n                updateShutterIrisState();\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Exposure] Load failed:', e);\n    });\n}","oldText":"// 加载曝光模式\nfunction loadExposure(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\n        if (r && r.success && r.data) {\n            var select = document.getElementById('exposureMode');\n            if (select && r.data.mode) {\n                select.value = r.data.mode;\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Exposure] Load failed:', e);\n    });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":100144,"output":351,"cacheRead":0,"cacheWrite":0,"totalTokens":100495,"cost":{"input":0.100144,"output":0.0011232000000000002,"cacheRead":0,"cacheWrite":0,"total":0.1012672}},"stopReason":"toolUse","timestamp":1781235739950,"responseId":"cht000d4a25@dx19eb9ecaee6b894142"}}
