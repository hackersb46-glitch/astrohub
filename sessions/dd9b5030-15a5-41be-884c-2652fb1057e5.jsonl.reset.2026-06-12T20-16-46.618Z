{"type":"message","id":"2bc299dc","parentId":"cfbd3175","timestamp":"2026-06-12T11:12:38.829Z","message":{"role":"toolResult","toolCallId":"tool-076c6510e5734948903561dc360e4f14","toolName":"read","content":[{"type":"text","text":"\"\"\"AstroHub E2E 测试\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_astrohub():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        errors = []\n        \n        try:\n            # 1. 打开主页\n            print('[TEST] 打开主页...')\n            page.goto('http://localhost:10280/', timeout=10000)\n            page.wait_for_load_state('networkidle', timeout=15000)\n            print('[PASS] 主页加载成功')\n            \n            # 2. 检查版本号\n            version = page.locator('.version').text_content()\n            print(f'[INFO] 版本: {version}')\n            \n            # 3. 检查设备列表\n            print('[TEST] 切换到设备管理...')\n            page.click('button[data-page=\"devices\"]')\n            page.wait_for_timeout(3000)  # 等待渲染\n            \n            # 检查设备表格\n            rows = page.locator('#deviceTable tr').count()\n            print(f'[INFO] 设备行数: {rows}')\n            \n            # 检查表格内容\n            table_html = page.locator('#deviceTable').inner_html()\n            print(f'[DEBUG] 表格内容: {table_html[:200]}...')\n            \n            if rows >= 1:\n                print('[PASS] 设备列表显示正常')\n            else:\n                errors.append('设备列表为空')\n            \n            if rows > 1:\n                print('[PASS] 设备列表显示正常')\n            else:\n                errors.append('设备列表为空')\n            \n            # 4. 连接设备\n            print('[TEST] 连接设备...')\n            # 找到连接按钮\n            connect_btns = page.locator('#deviceTable button:has-text(\"连接\")')\n            if connect_btns.count() > 0:\n                connect_btns.first.click()\n                page.wait_for_timeout(3000)\n                \n                # 检查状态变化\n                print('[INFO] 已点击连接按钮')\n            else:\n                print('[WARN] 未找到连接按钮')\n            \n            # 5. 截图\n            page.screenshot(path='tests/e2e_screenshot.png')\n            print('[INFO] 截图已保存')\n            \n        except Exception as e:\n            errors.append(str(e))\n            print(f'[ERROR] {e}')\n        \n        browser.close()\n        \n        if errors:\n            print(f'\\n[FAILED] 测试失败: {errors}')\n            return False\n        else:\n            print('\\n[PASS] 所有测试通过')\n            return True\n\nif __name__ == '__main__':\n    test_astrohub()\n"}],"isError":false,"timestamp":1781262758829}}
