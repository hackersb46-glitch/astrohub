{"type":"message","id":"6303e6da","parentId":"65df7816","timestamp":"2026-06-12T10:54:08.187Z","message":{"role":"assistant","content":[{"type":"text","text":"设备已保存凭据，但 API 返回\"未保存凭据\"。检查 `_resolve_device_id_to_ip` 函数："},{"type":"toolCall","id":"tool-14d6e4d1ac154e5dad302615c9d9b1ab","name":"read","arguments":{"limit":40,"offset":174,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":72463,"output":71,"cacheRead":0,"cacheWrite":0,"totalTokens":72534,"cost":{"input":0.072463,"output":0.00022720000000000002,"cacheRead":0,"cacheWrite":0,"total":0.0726902}},"stopReason":"toolUse","timestamp":1781261637111,"responseId":"cht000dfff4@dx19ebb7797f8b85f582"}}
{"type":"message","id":"e5d6669c","parentId":"6303e6da","timestamp":"2026-06-12T10:54:08.197Z","message":{"role":"toolResult","toolCallId":"tool-14d6e4d1ac154e5dad302615c9d9b1ab","toolName":"read","content":[{"type":"text","text":"def _resolve_device_id_to_ip(mgr: \"PTZManager\", device_id: str) -> str | None:\r\n    \"\"\"解析 device_id 为实际 IP 地址。\r\n\r\n    device_id 可能是 IP 地址或 MAC 地址。\r\n    - 如果是 IP: 直接返回\r\n    - 如果是 MAC: 从 SADP 发现缓存或已存储设备中查找 IP\r\n    \"\"\"\r\n    import re\r\n    # 判断是否为 MAC 地址格式 (冒号或横杠分隔的6组十六进制)\r\n    mac_pattern = re.compile(r\"^([0-9a-fA-F]{2}[:-]){5}[0-9a-fA-F]{2}$\")\r\n    if mac_pattern.match(device_id):\r\n        # BUG-016 修复: 额外验证 MAC 长度必须为12位十六进制\r\n        mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n        if len(mac_clean) == 12 and re.match(r'^[0-9a-f]{12}$', mac_clean):\r\n            # 是 MAC 地址，尝试从发现缓存中查找\r\n            discovered = mgr.get_discovered_devices()\r\n            for dev in discovered:\r\n                dev_mac = dev.get(\"mac\", \"\").lower().replace(\":\", \"-\")\r\n                if dev_mac == device_id.lower().replace(\":\", \"-\"):\r\n                    return dev.get(\"ip\")\r\n            # 从已存储设备中查找\r\n            stored = mgr.list_stored_devices()\r\n            for dev in stored:\r\n                dev_mac = dev.get(\"mac\", \"\").lower().replace(\":\", \"-\")\r\n                if dev_mac == device_id.lower().replace(\":\", \"-\"):\r\n                    ip = dev.get(\"ip\", \"\")\r\n                    if ip:\r\n                        return ip\r\n        return None\r\n    # 看起来像 IP 地址，直接返回\r\n    return device_id\r\n\r\n\r\n# ================================================================ #\r\n#  健康检查端点\r\n# ================================================================ #\r\n\r\n\r\n@health_router.get(\"/health\", summary=\"全局健康检查\")\r\nasync def global_health() -> dict:\r\n\n[2913 more lines in file. Use offset=214 to continue.]"}],"isError":false,"timestamp":1781261648197}}
