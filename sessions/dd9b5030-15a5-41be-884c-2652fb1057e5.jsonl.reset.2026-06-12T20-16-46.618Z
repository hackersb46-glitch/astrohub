ceIp);\n-411     \n-412     // 加载降噪\n-413     loadNoiseReduce(deviceIp);\n-414     \n-415     // 加载快门\n-416     loadShutter(deviceIp);\n-417     \n-418     // 加载光圈\n-419     loadIris(deviceIp);\n-420     \n-421     // 加载锐度\n-422     loadSharpness(deviceIp);\n-423     \n-424     // 加载亮度/对比度/饱和度\n-425     loadColorParams(deviceIp);\n+404         \n+405         // 然后加载其他参数（顺序执行但不阻塞）\n+406         loadExposure(deviceIp);\n+407         loadOsdStatus(deviceIp);\n+408         loadWhiteBalance(deviceIp);\n+409         loadNoiseReduce(deviceIp);\n+410         loadShutter(deviceIp);\n+411         loadIris(deviceIp);\n+412         loadSharpness(deviceIp);\n+413         loadColorParams(deviceIp);\n+414     })();\n 426 }\n 427 \n 428 // 加载 OSD 状态\n 429 function loadOsdStatus(deviceIp) {\n     ...","firstChangedLine":385},"isError":false,"timestamp":1781285592380}}
{"type":"message","id":"cac61254","parentId":"9228a608","timestamp":"2026-06-12T17:33:21.813Z","message":{"role":"assistant","content":[{"type":"text","text":"**修复 OSD 开关状态同步（不破坏原有逻辑）：**"},{"type":"toolCall","id":"tool-e8be8b38081b4a8d9da91e8bbba38b9d","name":"edit","arguments":{"edits":[{"newText":"function updatePtzOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnPtzOsdOn');\n    var btnOff = document.getElementById('btnPtzOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n    // v6.14: 同步开关状态\n    var sw = document.getElementById('ptzOsdSwitch');\n    if (sw) sw.checked = enabled;\n}","oldText":"function updatePtzOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnPtzOsdOn');\n    var btnOff = document.getElementById('btnPtzOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":51985,"output":366,"cacheRead":0,"cacheWrite":0,"totalTokens":52351,"cost":{"input":0.051984999999999996,"output":0.0011712,"cacheRead":0,"cacheWrite":0,"total":0.053156199999999994}},"stopReason":"toolUse","timestamp":1781285592381,"responseId":"cht000d1a15@dx19ebce52104b958232"}}
