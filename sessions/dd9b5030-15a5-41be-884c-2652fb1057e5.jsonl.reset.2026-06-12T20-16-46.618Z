".version\").text_content()\n        print(f\"[VERSION TEST] 版本: {version}\")\n        assert version == \"v6.0\"\n        print(\"[VERSION TEST] ✓ 版本测试通过\")\n        \n        await browser.close()\n\nasync def test_page_load():\n    \"\"\"测试页面加载\"\"\"\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False)\n        page = await browser.new_page()\n        \n        print(\"[PAGE TEST] 打开 AstroHub...\")\n        await page.goto(ASTROHUB_URL)\n        await page.wait_for_timeout(3000)\n        \n        # 截图\n        os.makedirs(\"test_results\", exist_ok=True)\n        await page.screenshot(path=\"test_results/v6_home.png\")\n        print(\"[PAGE TEST] 截图: test_results/v6_home.png\")\n        \n        await browser.close()\n        print(\"[PAGE TEST] ✓ 页面测试通过\")\n\nasync def main():\n    \"\"\"运行所有测试\"\"\"\n    print(\"=\" * 50)\n    print(\"AstroHub v6.0 E2E 测试\")\n    print(\"=\" * 50)\n    \n    try:\n        await test_api_connected()\n        await test_version()\n        await test_page_load()\n        print(\"\\n[SUCCESS] ✓ 所有测试通过!\")\n    except Exception as e:\n        print(f\"\\n[FAILED] ✗ 测试失败: {e}\")\n        raise\n\nif __name__ == \"__main__\":\n    asyncio.run(main())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_v6.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":87304,"output":779,"cacheRead":0,"cacheWrite":0,"totalTokens":88083,"cost":{"input":0.08730399999999999,"output":0.0024928000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0897968}},"stopReason":"toolUse","timestamp":1781252825857,"responseId":"cht000d4501@dx19ebaf12988ba5d322"}}
