{"type":"message","id":"4d2cd987","parentId":"7289a007","timestamp":"2026-06-12T10:17:39.105Z","message":{"role":"toolResult","toolCallId":"call_98d22f11c117463bb986dfd5","toolName":"read","content":[{"type":"text","text":"\"\"\"\nsrc/core/ptz_flow.py - M1 PTZ 发现与配置完整流程编排 (P1-P3)\n\n实现步骤:\n  P1  : 收集本机硬件/网络信息, 物理网卡选择\n  P1.1: 收集主机硬件 (hostname/CPU/RAM/GPU/VRAM)\n  P1.2: 枚举物理网卡 (排除虚拟/隧道)\n  P1.3: 用户选择网卡 (单网卡自动, 多网卡交互)\n  P2  : SADP 发现 + IP 修改\n  P2.1: SADP 扫描发现设备 (10秒窗口)\n  P2.2: 设备型号识别 + MAC 匹配\n  P2.3: 激活状态检测\n  P2.4: IP 可达性判断 (PING)\n  P2.5: 修改设备 IP (同网段 .64, 占用时找下一个)\n  P2.6: 保存设备凭证到 PTZ_config.json\n  P3  : ISAPI 认证\n  P3.1: 用户输入账号密码\n  P3.2: GET /ISAPI/System/deviceInfo 验证\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport platform\nimport subprocess\nimport time\nfrom pathlib import Path\nfrom typing import Optional\n\nimport xml.etree.ElementTree as ET\n\nfrom src.config_paths import CONFIG_DIR, ensure_directories\nfrom src.core.nic_selector import (\n    NICInfo,\n    get_physical_nic_display,\n    get_selected_nic_info,\n    list_physical_nics,\n    select_nic,\n)\nfrom src.core.net_detector import find_available_ip, suggest_target_ip\nfrom src.core.ptz_manager import check_reachable\nfrom src.core.sadp_discovery import (\n    SADPManager,\n    SADPDevice,\n    sadp_error_message,\n)\n\ntry:\n    import requests\n    from requests.auth import HTTPDigestAuth\n    HAS_REQUESTS = True\nexcept ImportError:\n    HAS_REQUESTS = False\n\ntry:\n    import psutil\n    HAS_PSUTIL = True\nexcept ImportError:\n    HAS_PSUTIL = False\n\ntry:\n    import subprocess\n    import platform\n    HAS_SUBPROCESS = True\nexcept ImportError:\n    HAS_SUBPROCESS = False\n\n# ============================================================\n# P1 System Info\n# ============================================================\n\n\ndef _collect_system_info() -> dict:\n    \"\"\"P1.1: 收集主机硬件信息.\"\"\"\n    info: dict = {\n        \"hostname\": platform.node(),\n        \"cpu_model\": \"\",\n        \"ram_gb\": 0,\n        \"gpu_count\": 0,\n        \"gpu_names\": [],\n        \"vram_gb\": 0,\n    }\n\n    # CPU\n    try:\n        if platform.system() == \"Windows\":\n            result = subprocess.run(\n                [\"wmic\", \"cpu\", \"get\", \"name\"],\n                capture_output=True, text=True, timeout=10,\n                creationflags=subprocess.CREATE_NO_WINDOW,\n            )\n            lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]\n            if len(lines) >= 2:\n                info[\"cpu_model\"] = lines[1].strip()\n    except Exception:\n        pass\n\n\n[780 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1781259459105}}
