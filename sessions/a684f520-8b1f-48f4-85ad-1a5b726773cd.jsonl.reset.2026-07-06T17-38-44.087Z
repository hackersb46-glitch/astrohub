{"type":"message","id":"05e8671d","parentId":"149d2ba4","timestamp":"2026-07-06T16:35:03.041Z","message":{"role":"toolResult","toolCallId":"call_c6872103f7b0482492764d82","toolName":"read","content":[{"type":"text","text":"// 加载快门\r\nfunction loadShutter(deviceIp) {\r\n    // v7.32: 必须有 function.json\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.shutter) {\r\n        console.warn('[Shutter] No function.json data available');\r\n        return;\r\n    }\r\n\r\n    var shutterValues = deviceFunctionData.functions.shutter.opt_values;\r\n    if (!shutterValues || !Array.isArray(shutterValues) || shutterValues.length === 0) {\r\n        console.warn('[Shutter] shutter not supported');\r\n        var shutterSelect = document.getElementById('shutterSpeed');\r\n        if (shutterSelect) {\r\n            shutterSelect.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            shutterSelect.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/shutter').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var sh = r.data;\r\n            deviceImageParams.shutter = sh;\r\n\r\n            var shutterSelect = document.getElementById('shutterSpeed');\r\n            if (shutterSelect) {\r\n                shutterSelect.innerHTML = '';\r\n                shutterSelect.disabled = false;\r\n\r\n                shutterValues.forEach(function(p) {\r\n                    var opt = document.createElement('option');\r\n                    opt.value = p;\r\n                    opt.textContent = p;\r\n                    if (p === sh.current_level) opt.selected = true;\r\n                    shutterSelect.appendChild(opt);\r\n                });\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Shutter] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 加载光圈\r\nfunction loadIris(deviceIp) {\r\n    // v7.32: 必须有 function.json\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.iris) {\r\n        console.warn('[Iris] No function.json data available');\r\n        return;\r\n    }\r\n\r\n    var irisValues = deviceFunctionData.functions.iris.opt_values;\r\n    if (!irisValues || !Array.isArray(irisValues) || irisValues.length === 0) {\r\n        console.warn('[Iris] iris not supported');\r\n        var irisSelect = document.getElementById('irisLevel');\r\n        if (irisSelect) {\r\n            irisSelect.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            irisSelect.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var ir = r.data;\r\n            deviceImageParams.iris = ir;\r\n\r\n            var irisSelect = document.getElementById('irisLevel');\r\n            if (irisSelect) {\r\n                irisSelect.innerHTML = '';\r\n                irisSelect.disabled = false;\r\n\r\n                var current = ir.current_level;\r\n\r\n                irisValues.forEach(function(val) {\r\n                    var numVal = parseInt(val);\r\n                    var opt = document.createElement('option');\r\n                    opt.value = numVal;\r\n                    var fNum = numVal / 100;\r\n                    opt.textContent = 'F' + fNum.toFixed(1);\r\n\n[884 more lines in file. Use offset=1157 to continue.]"}],"isError":false,"timestamp":1783355703041}}
