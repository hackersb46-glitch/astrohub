e') === 'replay' && typeof initReplayPage === 'function') {\r\n648: function moveVideoToAdvanced() {\r\n649: var videoContainer = document.getElementById('divPlugin');\r\n661: function moveVideoToConsole() {\r\n662: var videoContainer = document.getElementById('divPlugin');\r\n1893: wasmStartRecord(filename).then(function(result) {\r\n1924: wasmStopRecord().then(function(result) {\r\n1940: wasmStopRecord().then(function(result) {\r\n2055: var canvas = document.querySelector('#divPlugin canvas');\r\n2058: canvas = document.getElementById('divPlugin').querySelector('canvas');\r\n2549: document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\r\n2556: wasmStartRealPlay(channel, streamType, true);\r\n2585: wasmObserveResize('divPlugin');\r\n2645: if (activePage && activePage.id === 'page-console') {\r\n2648: wasmStartRealPlay(channel, streamType, true);\r\n2659: if (typeof wasmStopRealPlay === 'function') wasmStopRealPlay();\r\n2669: wasmStartRealPlay(channel, streamType, true);\r\n2674: wasmStopRealPlay();\r\n2686: wasmStartRealPlay(channel, streamType, true).then(function() {"}],"details":{"status":"completed","exitCode":0,"durationMs":376,"aggregated":"182: #divPlugin { width:100%; aspect-ratio:16/9; display:block; overflow:hidden; }\r\n183: #divPlugin .parent-wnd { width:100% !important; height:100% !important; }\r\n184: #divPlugin .parent-wnd > div { width:100% !important; height:100% !important; border:none !important; }\r\n185: #divPlugin .video-container { width:100% !important; height:100% !important; }\r\n186: #divPlugin canvas.play-window { width:100% !important; height:100% !important; }\r\n220: <button class=\"nav-btn active\" data-page=\"dashboard\">�Ǳ���</button>\r\n221: <button class=\"nav-btn\" data-page=\"devices\">�豸����</button>\r\n222: <button class=\"nav-btn\" data-page=\"console\">����̨</button>\r\n223: <button class=\"nav-btn\" data-page=\"observation\">�۲�ƻ�</button>\r\n225: <button class=\"nav-btn\" data-page=\"advanced\">�߼�����</button>\r\n226: <button class=\"nav-btn\" data-page=\"replay\">�ط�</button>\r\n227: <button class=\"nav-btn\" data-page=\"settings\">����</button>\r\n389: initNav();\r\n611: function initNav() {\r\n612: document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n617: document.getElementById('page-' + btn.getAttribute('data-page')).classList.add('active');\r\n618: if (btn.getAttribute('data-page') === 'devices') { refreshDevices(); }\r\n619: if (btn.getAttribute('data-page') === 'console') {\r\n625: wasmStartRealPlay(ch, st, true);\r\n629: if (btn.getAttribute('data-page') === 'advanced') {\r\n630: moveVideoToAdvanced();\r\n632: } else if (btn.getAttribute('data-page') === 'console') {\r\n633: moveVideoToConsole();\r\n635: if (btn.getAttribute('data-page')) refreshAdvancedDeviceSelectors();\r\n637: if (btn.getAttribute('data-page') === 'settings' && typeof loadStorageSettings === 'function') {\r\n641: if (btn.getAttribute('data-page') === 'replay' && typeof initReplayPage === 'function') {\r\n648: function moveVideoToAdvanced() {\r\n649: var videoContainer = document.getElementById('divPlugin');\r\n661: function moveVideoToConsole() {\r\n662: var videoContainer = document.getElementById('divPlugin');\r\n1893: wasmStartRecord(filename).then(function(result) {\r\n1924: wasmStopRecord().then(function(result) {\r\n1940: wasmStopRecord().then(function(result) {\r\n2055: var canvas = document.querySelector('#divPlugin canvas');\r\n2058: canvas = document.getElementById('divPlugin').querySelector('canvas');\r\n2549: document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\r\n2556: wasmStartRealPlay(channel, streamType, true);\r\n2585: wasmObserveResize('divPlugin');\r\n2645: if (activePage && activePage.id === 'page-console') {\r\n2648: wasmStartRealPlay(channel, streamType, true);\r\n2659: if (typeof wasmStopRealPlay === 'function') wasmStopRealPlay();\r\n2669: wasmStartRealPlay(channel, streamType, true);\r\n2674: wasmStopRe