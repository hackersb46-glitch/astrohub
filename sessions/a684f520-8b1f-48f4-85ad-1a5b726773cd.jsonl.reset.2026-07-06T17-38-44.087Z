dal { background:#1a1e2e; border:1px solid #30363d; border-radius:12px; padding:24px; min-width:320px; max-width:480px; box-shadow:0 8px 32px rgba(0,0,0,0.6); }\r\n        .astro-modal-title { margin:0 0 16px 0; font-size:18px; font-weight:600; }\r\n        .astro-modal-body { margin:0 0 20px 0; color:#e0e6f0; line-height:1.6; font-size:14px; }\r\n        .astro-modal-actions { display:flex; gap:12px; justify-content:flex-end; }\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n                    showToast('success', result.message || '归位成功');\r\n                    if (typeof operationLog === 'function') operationLog('归位', 'success');\r\n                } else if (result) {\r\n                    showToast('error', result.message || '归位失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '归位异常: ' + e.message);\r\n            });\r\n        }\r\n        function ptzStop() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiPost('/api/v1/ptz/' + dev + '/stop', null).catch(function(e) {});\r\n        }\r\n        function getPtzPosition() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiGet('/api/v1/ptz/' + dev + '/position').then(function(result) {\r\n                var posEl = document.getElementById('ptzPosition');\r\n                if (result && result.success && result.data) {\r\n                    var p = result.data;\r\n                    posEl.innerHTML = 'Pan: ' + (p.pan || 0) + ' | Tilt: ' + (p.tilt || 0) + ' | Zoom: ' + (p.zoom || 0);\r\n                } else {\r\n                    posEl.innerHTML = 'Pan: -- | Tilt: -- | Zoom: --';\r\n                }\r\n            }).catch(function(e) {});\r\n        }\r\n        // Calibration (placeholder)\r\n        function calibrate(type) {\r\n            if (!window.conn