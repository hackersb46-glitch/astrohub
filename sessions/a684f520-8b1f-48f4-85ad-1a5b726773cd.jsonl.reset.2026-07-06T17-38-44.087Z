height'] = s.get('height', 0)\n                        break\n                dur = float(probe.get('format', {}).get('duration', 0))\n                h, m = divmod(int(dur), 3600)\n                m, s = divmod(m, 60)\n                info['duration'] = f\"{h:02d}:{m:02d}:{s:02d}\"\n                info['duration_sec'] = int(dur)\n        except Exception:\n            info['width'] = 0; info['height'] = 0; info['duration'] = '00:00:00'\n    else:\n        try:\n            from PIL import Image\n            with Image.open(file_path) as img:\n                info['width'] = img.width\n                info['height'] = img.height\n        except Exception:\n            info['width'] = 0; info['height'] = 0\n\n    return {\"success\": True, \"data\": info}\n\n\nclass DeleteFilesRequest(BaseModel):\n    files: list[str] = []"}],"path":"astrohub\\src\\api\\router.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":73204,"output":752,"cacheRead":0,"cacheWrite":0,"totalTokens":73956,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783353844736,"responseId":"cht000db7e7@dx19f382cffbf2872503"}}
