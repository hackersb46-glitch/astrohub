.value = c.contrast;\r\n            if (saturation && c.saturation !== undefined) saturation.value = c.saturation;\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Color] Load failed:', e);\r\n    });\r\n}\r\n\r\n// ==================== 设置函数 ====================\r\n\r\n// 设置锐度\r\nfunction setSharpness(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/sharpness', { level: parseInt(value) })\r\n        .then(function(r) { if (r && r.success && typeof operationLog === 'function') operationLog('锐度: ' + value, 'success'); });\r\n}\r\n\r\n// 设置白平衡模式\r\n// 白平衡模式切换:显示/隐藏对应控件\r\nfunction onWbModeChange(mode) {\r\n    var manualControls = document.getElementById('wbManualControls');\r\n    var localControls = document.getElementById('wbLocalControls');\r\n    var wbRed = document.getElementById('wbRed');\r\n    var wbBlue = document.getElementById('wbBlue');\r\n\r\n    if (mode === 'manual') {\r\n        if (manualControls) manualControls.style.display = 'flex';\r\n        if (localControls) localControls.style.display = 'none';\r\n        if (wbRed) wbRed.disabled = false;\r\n        if (wbBlue) wbBlue.disabled = false;\r\n        setWhiteBalanceMode('manual');\r\n    } else if (mode === 'local') {\r\n        if (manualControls) manualControls.style.display = 'none';\r\n\n[804 more lines in file. Use offset=1237 to continue.]"}],"isError":false,"timestamp":1783355734021}}
