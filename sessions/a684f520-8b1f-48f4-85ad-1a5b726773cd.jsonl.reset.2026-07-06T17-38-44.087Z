录(bDateDir 创建的目录可能是 YYYY-MM-DD 或 YYYYMMDD)\r\n        downloads = Path.home() / \"Downloads\"\r\n        src_candidates = [\r\n            downloads / date_str / req.filename,\r\n            downloads / date_str_alt / req.filename,\r\n            downloads / req.filename,\r\n        ]\r\n\r\n        src_file = None\r\n        # 重试等待文件落盘(I_StopRecord 回调成功不代表文件已写完)\r\n        for _ in range(6):\r\n\n[2253 more lines in file. Use offset=2055 to continue.]"}],"isError":false,"timestamp":1783352901353}}
