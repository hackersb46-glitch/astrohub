{"type":"message","id":"fa21a876","parentId":"7da93a56","timestamp":"2026-05-20T18:10:51.656Z","message":{"role":"toolResult","toolCallId":"toolu_tool-03419bfffd60418eb6c84ac9275a8c70","toolName":"exec","content":[{"type":"text","text":"<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>AstroHub</title>\r\n    <style>\r\n        * { margin:0; padding:0; box-sizing:border-box; }\r\n        body { font-family: -apple-system, 'Segoe UI', sans-serif; background:#0a0e17; color:#e0e6f0; min-height:100vh; }\r\n        .header { background:linear-gradient(135deg, #1a1e2e, #0d1117); padding:12px 24px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #21262d; }\r\n        .logo { font-size:24px; font-weight:700; color:#58a6ff; }\r\n        .logo span { color:#f0883e; }\r\n        .version { font-size:12px; color:#8b949e; background:#21262d; padding:2px 8px; border-radius:12px; }\r\n        .status-bar { display:flex; gap:16px; align-items:center; }\r\n        .status-item { display:flex; align-items:center; gap:6px; font-size:13px; }\r\n        .status-dot { width:8px; height:8px; border-radius:50%; }\r\n        .status-dot.green { background:#3fb950; box-shadow:0 0 6px #3fb950; }\r\n        .status-dot.yellow { background:#d29922; box-shadow:0 0 6px #d29922; }\r\n        .status-dot.red { background:#f85149; box-shadow:0 0 6px #f85149; }\r\n        .nav { background:#161b22; padding:8px 24px; display:flex; gap:4px; align-items:center; border-bottom:1px solid #21262d; flex-wrap:wrap; }\r\n        .nav-btn { background:none; border:none; color:#8b949e; padding:8px 16px; cursor:pointer; border-radius:6px; font-size:14px; transition:all 0.2s; }\r\n        .nav-btn:hover { background:#21262d; color:#e0e6f0; }\r\n        .nav-btn.active { background:#238636; color:#fff; }\r\n        /* --- Advanced Page: Left Sidebar Layout --- */\r\n        .advanced-layout { display:flex; gap:0; min-height:600px; }\r\n        .advanced-sidebar { width:200px; background:#161b22; border-right:1px solid #21262d; padding:8px 0; flex-shrink:0; }\r\n        .advanced-sidebar .sidebar-item { background:none; border:none; color:#8b949e; padding:10px 16px; cursor:pointer; font-size:13px; transition:all 0.2s; width:100%; text-align:left; display:block; }\r\n        .advanced-sidebar .sidebar-item:hover { background:#21262d; color:#e0e6f0; }\r\n        .advanced-sidebar .sidebar-item.active { background:#238636; color:#fff; border-left:3px solid #3fb950; }\r\n        .advanced-content { flex:1; min-width:0; padding:20px; }\r\n        .advanced-content .page { display:none; }\r\n        .advanced-content .page.active { display:block; }\r\n        /* --- Observation Page Layout --- */\r\n        .observation-layout { display:grid; grid-template-columns:1fr 1fr; gap:20px; }\r\n        .obs-card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; }\r\n        .obs-card h3 { font-size:15px; color:#58a6ff; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #21262d; }\r\n        .obs-placeholder { color:#6e7681; font-size:13px; padding:20px 0; text-align:center; }\r\n        .obs-actions { margin-top:16px; display:flex; gap:8px; justify-content:flex-end; }\r\n        .main { padding:20px 24px; }\r\n        .page { display:none; }\r\n        .page.active { display:block; }\r\n        .grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:16px; margin-bottom:20px; }\r\n        .card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; transition:border-color 0.2s; }\r\n        .card:hover { border-color:#30363d; }\r\n        .card-title { font-size:12px; color:#8b949e; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }\r\n        .card-value { font-size:32px; font-weight:700; color:#e0e6f0; }\r\n        .card-value.green { color:#3fb950; }\r\n        .card-sub { font-size:12px; color:#6e7681; margin-top:4px; }\r\n        table { width:100%; border-collapse:collapse; }\r\n        th, td { text-align:left; padding:10px 16px; border-bottom:1px solid #21262d; font-size:14px; }\r\n        th { color:#8b949e; font-weight:500; background:#0d1117; }\r\n        tr:hover { background:#161b22; }\r\n        .badge { padding:2px 8px; border-radius:12px; font-size:12px; font-weight:500; }\r\n        .badge.online { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.offline { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .badge.sadp { background:rgba(88,166,255,0.15); color:#58a6ff; }\r\n        .badge.manual { background:rgba(240,136,62,0.15); color:#f0883e; }\r\n        .badge.yes { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.no { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .ptz-controls { display:grid; grid-template-columns:repeat(3, 80px); gap:8px; justify-content:center; margin:20px 0; }\r\n        .ptz-btn { width:80px; height:80px; border:1px solid #30363d; border-radius:10px; background:#161b22; color:#e0e6f0; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; }\r\n        .ptz-btn:hover { background:#238636; border-color:#238636; }\r\n        .ptz-btn.center { background:#21262d; cursor:default; }\r\n        .ptz-btn.center:hover { background:#21262d; transform:none; }\r\n        .ptz-btn:active:not(.center) { transform:scale(0.95); }\r\n        .ptz-speed { display:flex; align-items:center; gap:12px; justify-content:center; margin:16px 0; }\r\n        .ptz-speed input[type=range] { width:200px; accent-color:#58a6ff; }\r\n        .form-group { margin-bottom:16px; }\r\n        .form-group label { display:block; font-size:14px; color:#8b949e; margin-bottom:6px; }\r\n        .form-group input, .form-group select { width:100%; padding:10px 12px; background:#0d1117; border:1px solid #30363d; border-radius:6px; color:#e0e6f0; font-size:14px; }\r\n        .form-group input:focus, .form-group select:focus { outline:none; border-color:#58a6ff; }\r\n        .btn { padding:10px 20px; border:none; border-radius:6px; font-size:14px; cursor:pointer; transition:all 0.2s; }\r\n        .btn-primary { background:#238636; color:#fff; }\r\n        .btn-primary:hover { background:#2ea043; }\r\n        .btn-secondary { background:#30363d; color:#e0e6f0; }\r\n        .btn-secondary:hover { background:#484f58; }\r\n        .btn-danger { background:#da3633; color:#fff; }\r\n        .btn-danger:hover { background:#f85149; }\r\n        .btn-warning { background:#d29922; color:#0d1117; }\r\n        .btn-warning:hover { background:#e3b341; }\r\n        .btn-sm { padding:6px 12px; font-size:12px; }\r\n        .btn:disabled { opacity:0.5; cursor:not-allowed; }\r\n        .btn-group { display:flex; gap:8px; flex-wrap:wrap; }\r\n        .progress-bar { height:8px; background:#21262d; border-radius:4px; overflow:hidden; }\r\n        .progress-fill { height:100%; border-radius:4px; transition:width 0.3s; }\r\n        .progress-fill.green { background:#3fb950; }\r\n        .progress-fill.yellow { background:#d29922; }\r\n        .progress-fill.red { background:#f85149; }\r\n        .progress-fill.blue { background:#58a6ff; }\r\n        /* Advanced page status panel */\r\n        .advanced-status-panel { background:#0d1117; border:1px solid #21262d; border-radius:10px; padding:16px; margin:16px 0; }\r\n        .advanced-status-panel h4 { font-size:15px; color:#e0e6f0; margin-bottom:12px; border-bottom:1px solid #21262d; padding-bottom:8px; }\r\n        .status-row { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #21262d; font-size:14px; }\r\n        .status-row:last-child { border-bottom:none; }\r\n        .status-label { color:#8b949e; }\r\n        .status-value { color:#e0e6f0; font-family:monospace; }\r\n        .adv-header { display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap; }\r\n        .adv-header select { max-width:300px; }\r\n        .result-table { margin:16px 0; }\r\n        .progress-section { margin:16px 0; }\r\n        .progress-text { font-size:13px; color:#8b949e; margin-bottom:4px; }\r\n        .current-direction { font-size:18px; color:#58a6ff; font-family:monospace; text-align:center; padding:8px; background:#0d1117; border-radius:8px; margin:12px 0; }\r\n        .log-entry { padding:6px 12px; border-left:3px solid #30363d; margin-bottom:4px; font-size:13px; font-family:monospace; }\r\n        .log-entry.info { border-color:#58a6ff; }\r\n        .log-entry.warn { border-color:#d29922; }\r\n        .log-entry.error { border-color:#f85149; }\r\n        .log-entry.success { border-color:#3fb950; }\r\n        /* Toast notification */\r\n        .toast-container { position:fixed; top:60px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; }\r\n        .toast { padding:12px 20px; border-radius:8px; font-size:14px; animation:slideIn 0.3s ease; min-width:250px; max-width:400px; }\r\n        .toast.success { background:#1a4731; border:1px solid #3fb950; color:#3fb950; }\r\n        .toast.error { background:#4d1c1a; border:1px solid #f85149; color:#f85149; }\r\n        .toast.info { background:#1a3a52; border:1px solid #58a6ff; color:#58a6ff; }\r\n        .toast.warning { background:#4a3a1a; border:1px solid #d29922; color:#d29922; }\r\n        @keyframes slideIn { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }\r\n        /* Modal */\r\n        .modal-backdrop { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9000; display:flex; align-items:center; justify-content:center; }\r\n        .modal { background:#161b22; border:1px solid #30363d; border-radius:12px; padding:24px; width:400px; max-width:90vw; }\r\n        .modal h3 { margin-bottom:16px; font-size:18px; }\r\n        .modal .btn-group { justify-content:flex-end; margin-top:20px; }\r\n        /* Loading spinner */\r\n        .spinner { display:inline-block; width:16px; height:16px; border:2px solid #30363d; border-top-color:#58a6ff; border-radius:50%; animation:spin 0.8s linear infinite; }\r\n        @keyframes spin { to { transform:rotate(360deg); } }\r\n        .loading { pointer-events:none; opacity:0.7; }\r\n        /* Device actions */\r\n        .actions { display:flex; gap:4px; flex-wrap:wrap; }\r\n        /* PTZ status panel */\r\n        .ptz-position { text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0; font-family:monospace; font-size:14px; }\r\n        .toolbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap; }\r\n        .toolbar-actions { display:flex; gap:8px; }\r\n        .device-info-panel { background:#0d1117; border-radius:8px; padding:16px; margin-top:12px; font-size:13px; }\r\n        .device-info-panel .info-row { display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid #21262d; }\r\n        .device-info-panel .info-row:last-child { border-bottom:none; }\r\n        .device-info-panel .info-label { color:#8b949e; }\r\n        .device-info-panel .info-value { color:#e0e6f0; font-family:monospace; }\r\n        @media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-right { width:100% !important; } }\r\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\r\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\r\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; }\r\n        .console-right { flex:1; min-width:0; display:flex; flex-direction:column; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"header\">\r\n        <div class=\"logo\">Astro<span>Hub</span></div>\r\n        <div class=\"status-bar\">\r\n            <div class=\"status-item\"><span class=\"status-dot green\" id=\"wsDot\"></span><span id=\"wsStatus\">WebSocket</span></div>\r\n            <div class=\"status-item\" id=\"clock\"></div>\r\n            <span class=\"version\">v5.15</span>\r\n        </div>\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n// WASM SDK global functions (simple version)\r\nfunction setLoginStatus(msg, color) {\r\n    var el = document.getElementById('login-status');\r\n    if (el) {\r\n        el.textContent = msg;\r\n        if (color) el.style.color = color;\r\n    }\r\n    console.log('[WASM] Status: ' + msg);\r\n}\r\nfunction clickLogin2() {\r\n    console.log('[CLICKLOGIN2] Called');\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        console.log('[WASM SDK] No device connected');\r\n        return;\r\n    }\r\n    console.log('[CLICKLOGIN2] Device IP: ' + window.connectedDevice.ip);\r\n    var szIP = window.connectedDevice.ip;\r\n    var szPort = window.connectedDevice.port || 80;\r\n    var szUsername = window.connectedDevice.username || 'admin';\r\n    var szPassword = window.connectedDevice.password || '';\r\n    g_szDeviceIdentify2 = szIP + '_' + szPort;\r\n    console.log('[WASM SDK] Login: ' + szIP + ':' + szPort);\r\n    WebVideoCtrl.I_Login(szIP, 1, szPort, szUsername, szPassword, {\r\n        timeout: 5000,\r\n        success: function(xmlDoc) {\r\n            g_bLoggedIn2 = true;\r\n            console.log('[WASM SDK] Login success: ' + g_szDeviceIdentify2);\r\n            // I_GetDevicePort is SYNCHRONOUS - no .then() needed\r\n                var oPort = WebVideoCtrl.I_GetDevicePort(g_szDeviceIdentify2);\r\n                console.log('[WASM SDK] GetDevicePort result:', oPort);\r\n                if (oPort) {\r\n                    g_iRtspPort2 = oPort.iRtspPort || 554;\r\n                    console.log('[WASM SDK] RTSP port:', g_iRtspPort2);\r\n                }\r\n                // Start stream after short delay\r\n                console.log('[WASM SDK] Calling startConsoleStream2 in 200ms...');\r\n                setTimeout(function() {\r\n                    console.log('[WASM SDK] setTimeout fired, startConsoleStream2 exists:', typeof window.startConsoleStream2);\r\n                    if (window.startConsoleStream2) {\r\n                        window.startConsoleStream2('sub');\r\n                    } else {\r\n                        console.error('[WASM SDK] startConsoleStream2 not found!');\r\n                    }\r\n                }, 200);\r\n        },\r\n        error: function(status, xmlDoc) {\r\n            console.error('[WASM SDK] Login failed:', status);\r\n            g_bLoggedIn2 = false;\r\n        }\r\n    });\r\n}\r\nwindow.clickLogin2 = clickLogin2; // Manually expose to window\r\nfunction startConsoleStream2(mode) {\r\n    console.log(\"[STARTSTREAM2] Called, g_bLoggedIn2=\", g_bLoggedIn2);\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) { console.log(\"[STARTSTREAM2] No device\"); return; }\r\n    if (!g_bLoggedIn2) { if (window.clickLogin2) window.clickLogin2(); return; }\r\n    var iStreamType = (mode === 'main') ? 1 : 2;\r\n    var oWndInfo = WebVideoCtrl.I_GetWindowStatus(g_iWndIndex2);\r\n    var doStart = function() {\r\n        console.log('[WASM SDK] Starting real play, stream=' + iStreamType);\r\n        WebVideoCtrl.I_StartRealPlay(g_szDeviceIdentify2, {\r\n            // iRtspPort not needed for WASM WebSocket mode\r\n            iStreamType: iStreamType,\r\n            iChannelID: 1,\r\n            bZeroChannel: false,\r\n            success: function() {\r\n                g_bPlaying2 = true;\r\n                console.log('[WASM SDK] Real play started');\r\n            },\r\n            error: function(status, xmlDoc) {\r\n                console.error('[WASM SDK] StartRealPlay error:', status);\r\n            }\r\n        });\r\n    };\r\n    if (oWndInfo != null) {\r\n        WebVideoCtrl.I_Stop({ success: function() { doStart(); }, error: function() { doStart(); } });\r\n    } else {\r\n        doStart();\r\n    }\r\n}\r\nwindow.startConsoleStream2 = startConsoleStream2; // Manually expose\r\n        function stopConsoleStream2() {\r\n    if (!g_bPlaying2) return;\r\n    var oWndInfo = WebVideoCtrl.I_GetWindowStatus(g_iWndIndex2);\r\n    if (oWndInfo != null) {\r\n        WebVideoCtrl.I_Stop({ success: function() { g_bPlaying2 = false; console.log('[WASM SDK] Stopped'); } });\r\n    }\r\n}\r\n\r\n</script>[... 95924 more characters truncated]"}],"details":{"status":"completed","exitCode":0,"durationMs":328,"aggregated":"<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>AstroHub</title>\r\n    <style>\r\n        * { margin:0; padding:0; box-sizing:border-box; }\r\n        body { font-family: -apple-system, 'Segoe UI', sans-serif; background:#0a0e17; color:#e0e6f0; min-height:100vh; }\r\n        .header { background:linear-gradient(135deg, #1a1e2e, #0d1117); padding:12px 24px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #21262d; }\r\n        .logo { font-size:24px; font-weight:700; color:#58a6ff; }\r\n        .logo span { color:#f0883e; }\r\n        .version { font-size:12px; color:#8b949e; background:#21262d; padding:2px 8px; border-radius:12px; }\r\n        .status-bar { display:flex; gap:16px; align-items:center; }\r\n        .status-item { display:flex; align-items:center; gap:6px; font-size:13px; }\r\n        .status-dot { width:8px; height:8px; border-radius:50%; }\r\n        .status-dot.green { background:#3fb950; box-shadow:0 0 6px #3fb950; }\r\n        .status-dot.yellow { background:#d29922; box-shadow:0 0 6px #d29922; }\r\n        .status-dot.red { background:#f85149; box-shadow:0 0 6px #f85149; }\r\n        .nav { background:#161b22; padding:8px 24px; display:flex; gap:4px; align-items:center; border-bottom:1px solid #21262d; flex-wrap:wrap; }\r\n        .nav-btn { background:none; border:none; color:#8b949e; padding:8px 16px; cursor:pointer; border-radius:6px; font-size:14px; transition:all 0.2s; }\r\n        .nav-btn:hover { background:#21262d; color:#e0e6f0; }\r\n        .nav-btn.active { background:#238636; color:#fff; }\r\n        /* --- Advanced Page: Left Sidebar Layout --- */\r\n        .advanced-layout { display:flex; gap:0; min-height:600px; }\r\n        .advanced-sidebar { width:200px; background:#161b22; border-right:1px solid #21262d; padding:8px 0; flex-shrink:0; }\r\n        .advanced-sidebar .sidebar-item { background:none; border:none; color:#8b949e; padding:10px 16px; cursor:pointer; font-size:13px; transition:all 0.2s; width:100%; text-align:left; display:block; }\r\n        .advanced-sidebar .sidebar-item:hover { background:#21262d; color:#e0e6f0; }\r\n        .advanced-sidebar .sidebar-item.active { background:#238636; color:#fff; border-left:3px solid #3fb950; }\r\n        .advanced-content { flex:1; min-width:0; padding:20px; }\r\n        .advanced-content .page { display:none; }\r\n        .advanced-content .page.active { display:block; }\r\n        /* --- Observation Page Layout --- */\r\n        .observation-layout { display:grid; grid-template-columns:1fr 1fr; gap:20px; }\r\n        .obs-card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; }\r\n        .obs-card h3 { font-size:15px; color:#58a6ff; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #21262d; }\r\n        .obs-placeholder { color:#6e7681; font-size:13px; padding:20px 0; text-align:center; }\r\n        .obs-actions { margin-top:16px; display:flex; gap:8px; justify-content:flex-end; }\r\n        .main { padding:20px 24px; }\r\n        .page { display:none; }\r\n        .page.active { display:block; }\r\n        .grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:16px; margin-bottom:20px; }\r\n        .card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; transition:border-color 0.2s; }\r\n        .card:hover { border-color:#30363d; }\r\n        .card-title { font-size:12px; color:#8b949e; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }\r\n        .card-value { font-size:32px; font-weight:700; color:#e0e6f0; }\r\n        .card-value.green { color:#3fb950; }\r\n        .card-sub { font-size:12px; color:#6e7681; margin-top:4px; }\r\n        table { width:100%; border-collapse:collapse; }\r\n        th, td { text-align:left; padding:10px 16px; border-bottom:1px solid #21262d; font-size:14px; }\r\n        th { color:#8b949e; font-weight:500; background:#0d1117; }\r\n        tr:hover { background:#161b22; }\r\n        .badge { padding:2px 8px; border-radius:12px; font-size:12px; font-weight:500; }\r\n        .badge.online { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.offline { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .badge.sadp { background:rgba(88,166,255,0.15); color:#58a6ff; }\r\n        .badge.manual { background:rgba(240,136,62,0.15); color:#f0883e; }\r\n        .badge.yes { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.no { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .ptz-controls { display:grid; grid-template-columns:repeat(3, 80px); gap:8px; justify-content:center; margin:20px 0; }\r\n        .ptz-btn { width:80px; height:80px; border:1px solid #30363d; border-radius:10px; background:#161b22; color:#e0e6f0; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; }\r\n        .ptz-btn:hover { background:#238636; border-color:#238636; }\r\n        .ptz-btn.center { background:#21262d; cursor:default; }\r\n        .ptz-btn.center:hover { background:#21262d; transform:none; }\r\n        .ptz-btn:active:not(.center) { transform:scale(0.95); }\r\n        .ptz-speed { display:flex; align-items:center; gap:12px; justify-content:center; margin:16px 0; }\r\n        .ptz-speed input[type=range] { width:200px; accent-color:#58a6ff; }\r\n        .form-group { margin-bottom:16px; }\r\n        .form-group label { display:block; font-size:14px; color:#8b949e; margin-bottom:6px; }\r\n        .form-group input, .form-group select { width:100%; padding:10px 12px; background:#0d1117; border:1px solid #30363d; border-radius:6px; color:#e0e6f0; font-size:14px; }\r\n        .form-group input:focus, .form-group select:focus { outline:none; border-color:#58a6ff; }\r\n        .btn { padding:10px 20px; border:none; border-radius:6px; font-size:14px; cursor:pointer; transition:all 0.2s; }\r\n        .btn-primary { background:#238636; color:#fff; }\r\n        .btn-primary:hover { background:#2ea043; }\r\n        .btn-secondary { background:#30363d; color:#e0e6f0; }\r\n        .btn-secondary:hover { background:#484f58; }\r\n        .btn-danger { background:#da3633; color:#fff; }\r\n        .btn-danger:hover { background:#f85149; }\r\n        .btn-warning { background:#d29922; color:#0d1117; }\r\n        .btn-warning:hover { background:#e3b341; }\r\n        .btn-sm { padding:6px 12px; font-size:12px; }\r\n        .btn:disabled { opacity:0.5; cursor:not-allowed; }\r\n        .btn-group { display:flex; gap:8px; flex-wrap:wrap; }\r\n        .progress-bar { height:8px; background:#21262d; border-radius:4px; overflow:hidden; }\r\n        .progress-fill { height:100%; border-radius:4px; transition:width 0.3s; }\r\n        .progress-fill.green { background:#3fb950; }\r\n        .progress-fill.yellow { background:#d29922; }\r\n        .progress-fill.red { background:#f85149; }\r\n        .progress-fill.blue { background:#58a6ff; }\r\n        /* Advanced page status panel */\r\n        .advanced-status-panel { background:#0d1117; border:1px solid #21262d; border-radius:10px; padding:16px; margin:16px 0; }\r\n        .advanced-status-panel h4 { font-size:15px; color:#e0e6f0; margin-bottom:12px; border-bottom:1px solid #21262d; padding-bottom:8px; }\r\n        .status-row { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #21262d; font-size:14px; }\r\n        .status-row:last-child { border-bottom:none; }\r\n        .status-label { color:#8b949e; }\r\n        .status-value { color:#e0e6f0; font-family:monospace; }\r\n        .adv-header { display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap; }\r\n        .adv-header select { max-width:300px; }\r\n        .result-table { margin:16px 0; }\r\n        .progress-section { margin:16px 0; }\r\n        .progress-text { font-size:13px; color:#8b949e; margin-bottom:4px; }\r\n        .current-direction { font-size:18px; color:#58a6ff; font-family:monospace; text-align:center; padding:8px; background:#0d1117; border-radius:8px; margin:12px 0; }\r\n        .log-entry { padding:6px 12px; border-left:3px solid #30363d; margin-bottom:4px; font-size:13px; font-family:monospace; }\r\n        .log-entry.info { border-color:#58a6ff; }\r\n        .log-entry.warn { border-color:#d29922; }\r\n        .log-entry.error { border-color:#f85149; }\r\n        .log-entry.success { border-color:#3fb950; }\r\n        /* Toast notification */\r\n        .toast-container { position:fixed; top:60px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; }\r\n        .toast { padding:12px 20px; border-radius:8px; font-size:14px; animation:slideIn 0.3s ease; min-width:250px; max-width:400px; }\r\n        .toast.success { background:#1a4731; border:1px solid #3fb950; color:#3fb950; }\r\n        .toast.error { background:#4d1c1a; border:1px solid #f85149; color:#f85149; }\r\n        .toast.info { background:#1a3a52; border:1px solid #58a6ff; color:#58a6ff; }\r\n        .toast.warning { background:#4a3a1a; border:1px solid #d29922; color:#d29922; }\r\n        @keyframes slideIn { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }\r\n        /* Modal */\r\n        .modal-backdrop { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9000; display:flex; align-items:center; justify-content:center; }\r\n        .modal { background:#161b22; border:1px solid #30363d; border-radius:12px; padding:24px; width:400px; max-width:90vw; }\r\n        .modal h3 { margin-bottom:16px; font-size:18px; }\r\n        .modal .btn-group { justify-content:flex-end; margin-top:20px; }\r\n        /* Loading spinner */\r\n        .spinner { display:inline-block; width:16px; height:16px; border:2px solid #30363d; border-top-color:#58a6ff; border-radius:50%; animation:spin 0.8s linear infinite; }\r\n        @keyframes spin { to { transform:rotate(360deg); } }\r\n        .loading { pointer-events:none; opacity:0.7; }\r\n        /* Device actions */\r\n        .actions { display:flex; gap:4px; flex-wrap:wrap; }\r\n        /* PTZ status panel */\r\n        .ptz-position { text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0; font-family:monospace; font-size:14px; }\r\n        .toolbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap; }\r\n        .toolbar-actions { display:flex; gap:8px; }\r\n        .device-info-panel { background:#0d1117; border-radius:8px; padding:16px; margin-top:12px; font-size:13px; }\r\n        .device-info-panel .info-row { display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid #21262d; }\r\n        .device-info-panel .info-row:last-child { border-bottom:none; }\r\n        .device-info-panel .info-label { color:#8b949e; }\r\n        .device-info-panel .info-value { color:#e0e6f0; font-family:monospace; }\r\n        @media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-right { width:100% !important; } }\r\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\r\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\r\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; }\r\n        .console-right { flex:1; min-width:0; display:flex; flex-direction:column; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"header\">\r\n        <div class=\"logo\">Astro<span>Hub</span></div>\r\n        <div class=\"status-bar\">\r\n            <div class=\"status-item\"><span class=\"status-dot green\" id=\"wsDot\"></span><span id=\"wsStatus\">WebSocket</span></div>\r\n            <div class=\"status-item\" id=\"clock\"></div>\r\n            <span class=\"version\">v5.15</span>\r\n        </div>\r\n    </div>\r\n    <div class=\"nav\">\r\n        <button class=\"nav-btn active\" data-page=\"dashboard\">�Ǳ���</button>\r\n        <button class=\"nav-btn\" data-page=\"devices\">�豸����</button>\r\n        <button class=\"nav-btn\" data-page=\"console\">����̨</button>\r\n        <button class=\"nav-btn\" data-page=\"observation\">�۲�ƻ�</button>\r\n        <!-- Advanced Features: У׼ ���ܲ��� ��λ���� �ٶȲ��� ����/�洢 -->\r\n        <button class=\"nav-btn\" data-page=\"advanced\">�߼�����</button>\r\n        <button class=\"nav-btn\" data-page=\"replay\">�ط�</button>\r\n    </div>\r\n    <div class=\"main\">\r\n        <!-- ==================== �Ǳ��� ==================== -->\r\n\r\n        <!-- ==================== Page Modules ==================== -->\r\n        {% include \"includes/dashboard.html\" %}\r\n        {% include \"includes/devices.html\" %}\r\n        {% include \"includes/console.html\" %}\r\n        {% include \"includes/observation.html\" %}\r\n        {% include \"includes/advanced.html\" %}\r\n        {% include \"includes/replay.html\" %}\r\n    </div>\r\n    <!-- Toast ���� -->\r\n    <div class=\"toast-container\" id=\"toastContainer\"></div>\r\n    <!-- Modal ���� -->\r\n    <div id=\"modalContainer\"></div>\r\n    <script>\r\n        console.log(\"[MAIN SCRIPT] Starting script execution\");\r\n        // WASM SDK global variables (before IIFE)\r\n        var g_szDeviceIdentify = '';\r\n        var g_bLoggedIn = false;\r\n        var g_bPlaying = false;\r\n        var g_iRtspPort = 554;\r\nvar g_szDeviceIdentify2 = \"\";\r\nvar g_bLoggedIn2 = false;\r\nvar g_bPlaying2 = false;\r\nvar g_iRtspPort2 = 554;\r\nvar g_iWndIndex2 = 0;\r\nvar g_iWebSocketPort = 7681;\r\n        var g_iWndIndex = 0;\r\nvar g_iChannelList = [];\r\nvar g_iChannelID = 1;\r\n        var g_iChannelID = 1;\r\n// Global functions\r\n    (function() {\r\n        'use strict';\r\n        // ================================================================\r\n        //  Configuration\r\n        // ================================================================\r\n        var API_BASE = window.location.origin;\r\n        var WS_URL = (window.location.protocol === 'https:' ? 'wss' : 'ws') + '://' + window.location.host + '/ws';\r\n        // Cached device data\r\n        var allDevices = [];\r\n        var currentModal = null;\r\n        // --- v3: Global connected device state ---\r\n        var connectedDevice = null; // {ip, model, name, mac, username, password, port, online}\r\n        // Advanced menu state (now sidebar)\r\n        var advMenuActive = false;\r\n        var advCurrentSub = 'calibration';\r\n        // Onboarding wizard state\r\n        var wizardState = {\r\n            step: 0,\r\n            totalSteps: 5,\r\n            mac: '',\r\n            deviceIP: '',\r\n            runningTest: false,\r\n            testResults: { function: null, limit: null, speed: null }\r\n        };\r\n        // ================================================================\r\n        //  Initialization\r\n        // ================================================================\r\n        function init() {\r\n            console.log('[INIT] init() called');\r\n            updateClock();\r\n            setInterval(updateClock, 1000);\r\n            initNav();\r\n            initPtzSpeed();\r\n            initMouseUp();\r\n            refreshDevices();\r\n            addLog('info', 'AstroHub ������');\r\n            connectWS();\r\n        }\r\n        // ================================================================\r\n        //  Navigation\r\n        // ================================================================\r\n        function initNav() {\r\n            document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n                btn.addEventListener('click', function() {\r\n                    document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n                    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n                    btn.classList.add('active');\r\n                    document.getElementById('page-' + btn.getAttribute('data-page')).classList.add('active');\r\n                    if (btn.getAttribute('data-page') === 'devices') refreshDevices();\r\n                    if (btn.getAttribute('data-page') === 'console') {\r\n                        refreshPtzDeviceList();\r\n                        loadWasmDevices();\r\n                        // Resize WASM player when console becomes visible\r\n                        setTimeout(function() {\r\n                            var container = document.getElementById('divPlugin');\r\n                            if (container && window.WebVideoCtrl) {\r\n                                try { WebVideoCtrl.I_Resize(container.offsetWidth, container.offsetHeight); console.log('[WASM] Resized to', container.offsetWidth, container.offsetHeight); } catch(e) { console.warn('Resize error:', e); }\r\n                            }\r\n                        }, 100);\r\n                        // Check if device is online and trigger WASM login\r\n                        if (!window.connectedDevice && allDevices && allDevices.length > 0) {\r\n                            var onlineDev = allDevices.find(function(d) { return d.online; });\r\n                            if (onlineDev) {\r\n                                // Fetch credentials and set connectedDevice\r\n                                apiGet('/api/v1/ptz/devices/' + onlineDev.ip + '/credentials').then(function(creds) {\r\n                                    if (creds && creds.success) {\r\n                                        window.connectedDevice = {\r\n                                            ip: onlineDev.ip,\r\n                                            model: onlineDev.model || '',\r\n                                            name: onlineDev.name || onlineDev.device_name || '',\r\n                                            mac: onlineDev.mac || '',\r\n                                            username: creds.username || 'admin',\r\n                                            password: creds.password || '',\r\n                                            port: creds.port || 80,\r\n                                            online: true\r\n                                        };\r\n                                        if (window.clickLogin2) { window.clickLogin2(); }\r\n                                    }\r\n                                }).catch(function(e) { console.warn('Failed to fetch credentials:', e); });\r\n                            }\r\n                        } else if (window.connectedDevice && window.clickLogin2) {\r\n                            window.clickLogin2();\r\n                        }\r\n                    }\r\n                    if (btn.getAttribute('data-page') === 'advanced') initAdvSidebar();\r\n                    if (btn.getAttribute('data-page')) refreshAdvancedDeviceSelectors();\r\n                });\r\n            });\r\n        }\r\n        // Sidebar click handlers for advanced page sub-items\r\n        function initAdvSidebar() {\r\n            document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(item) {\r\n                item.onclick = function() {\r\n                    var subPage = item.getAttribute('data-sub');\r\n                    // Update sidebar active state\r\n                    document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(b) { b.classList.remove('active'); });\r\n                    item.classList.add('active');\r\n                    // Show sub-page\r\n                    document.querySelectorAll('#advContent .page').forEach(function(p) { p.classList.remove('active'); });\r\n                    var target = document.getElementById('page-' + subPage);\r\n                    if (target) target.classList.add('active');\r\n                    advCurrentSub = subPage;\r\n                };\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  Device Selectors for Advanced Pages\r\n        // ================================================================\r\n        function refreshAdvancedDeviceSelectors() {\r\n            var online = (allDevices || []).filter(function(d) { return d.online; });\r\n            var selectors = ['advFuncDevice', 'advLimitDevice', 'advSpeedDevice', 'calDevice', 'advStreamDevice'];\r\n            selectors.forEach(function(id) {\r\n                var sel = document.getElementById(id);\r\n                if (!sel) return;\r\n                var current = sel.value;\r\n                // Rebuild options\r\n                sel.innerHTML = '';\r\n                if (id === 'calDevice' || id === 'advConnectDevice') {\r\n                    var defaultOpt = document.createElement('option');\r\n                    defaultOpt.textContent = 'δѡ���豸';\r\n                    defaultOpt.value = '';\r\n                    sel.appendChild(defaultOpt);\r\n                }\r\n                online.forEach(function(d) {\r\n                    var option = document.createElement('option');\r\n                    option.value = d.ip;\r\n                    option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                    sel.appendChild(option);\r\n                });\r\n                if (current) sel.value = current;\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  API helpers\r\n        // ================================================================\r\n        async function apiGet(path) {\r\n            var r = await fetch(API_BASE + path);\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        async function apiPost(path, body) {\r\n            var opts = { method: 'POST', headers: {'Content-Type': 'application/json'} };\r\n            if (body) opts.body = JSON.stringify(body);\r\n            var r = await fetch(API_BASE + path, opts);\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        async function apiDelete(path) {\r\n            var r = await fetch(API_BASE + path, { method: 'DELETE' });\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        // ================================================================\r\n        //  Function Detection (P4.1-P4.21)\r\n        // ================================================================\r\n        function funcDetectRun() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceIp = connectedDevice.ip;\r\n            var device = connectedDevice;\r\n            var btn = document.getElementById('btnFuncRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> ̽����...';\r\n            document.getElementById('funcProgress').style.display = 'block';\r\n            document.getElementById('funcResultArea').innerHTML = '';\r\n            addLog('info', '����̽�⿪ʼ: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/function/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ̽��';\r\n                document.getElementById('funcProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '����̽�����');\r\n                    addLog('success', '����̽�����: ' + (resp.message || ''));\r\n                    renderFuncResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '̽��ʧ��');\r\n                    addLog('error', '����̽��ʧ��: ' + (resp ? resp.message : 'δ֪'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ̽��';\r\n                document.getElementById('funcProgress').style.display = 'none';\r\n                showToast('error', '̽���쳣: ' + e.message);\r\n            });\r\n            // Simulate progress (REMOVED - hardcoded fake progress)\r\n            // Progress bar now: 0% on start �� \"ִ����...\" �� 100% on real API response\r\n        }\r\n        function funcDetectRestore() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceIp = connectedDevice.ip;\r\n            var btn = document.getElementById('btnFuncRestore');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> �ָ���...';\r\n            apiPost('/api/v1/advanced/function/restore?device_ip=' + deviceIp + '&username=admin&password=&port=80', null).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? �ָ�Ĭ��ֵ';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '�����ѻָ�Ĭ��ֵ');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '�ָ�ʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? �ָ�Ĭ��ֵ';\r\n                showToast('error', '�ָ��쳣: ' + e.message);\r\n            });\r\n        }\r\n        function renderFuncResults(results) {\r\n            var area = document.getElementById('funcResultArea');\r\n            var html = '<table class=\"result-table\"><thead><tr><th>����</th><th>֧��</th><th>��Сֵ</th><th>���ֵ</th><th>��ǰֵ</th><th>״̬</th></tr></thead><tbody>';\r\n            var keys = Object.keys(results);\r\n            if (keys.length === 0) {\r\n                html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">���޽��</td></tr>';\r\n            } else {\r\n                keys.forEach(function(key) {\r\n                    var item = results[key];\r\n                    var supported = item.supported ? '<span class=\"badge yes\">?</span>' : '<span class=\"badge no\">?</span>';\r\n                    var status = item.status || '���';\r\n                    html += '<tr>';\r\n                    html += '<td>' + key + '</td>';\r\n                    html += '<td>' + supported + '</td>';\r\n                    html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\r\n                    html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\r\n                    html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\r\n                    html += '<td><span class=\"badge yes\">' + status + '</span></td>';\r\n                    html += '</tr>';\r\n                });\r\n            }\r\n            html += '</tbody></table>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Limit Test (P6.0-P6.4)\r\n        // ================================================================\r\n        function limitTestRun() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceIp = connectedDevice.ip;\r\n            var device = connectedDevice;\r\n            var btn = document.getElementById('btnLimitRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> ������...';\r\n            document.getElementById('limitProgress').style.display = 'block';\r\n            document.getElementById('limitDirection').style.display = 'block';\r\n            document.getElementById('limitResultArea').innerHTML = '';\r\n            addLog('info', '��λ���Կ�ʼ: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/limit/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ����';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '��λ�������');\r\n                    addLog('success', '��λ�������: ' + (resp.message || ''));\r\n                    renderLimitResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '����ʧ��');\r\n                    addLog('error', '��λ����ʧ��: ' + (resp ? resp.message : 'δ֪'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ����';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                showToast('error', '�����쳣: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded simulation)\r\n            var limitProgText = document.getElementById('limitProgressText');\r\n            var limitProgBar = document.getElementById('limitProgressBar');\r\n            var limitDirEl = document.getElementById('limitDirection');\r\n            if (limitProgText) limitProgText.textContent = '������... �ȴ��豸��Ӧ';\r\n            if (limitProgBar) limitProgBar.style.width = '30%';\r\n            if (limitDirEl) { limitDirEl.textContent = '��ǰ����: ��ʼ��...'; limitDirEl.style.display = 'block'; }\r\n            // simulateProgress/simulateDirections REMOVED - hardcoded fake progress\r\n        }\r\n        function renderLimitResults(results) {\r\n            var area = document.getElementById('limitResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">���޽��</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>��λ���Խ��</h4>';\r\n            // P axis\r\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">P����λ</span><span class=\"status-value\">' + pLimit[0] + ' ~ ' + pLimit[1] + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">T����λ</span><span class=\"status-value\">' + tLimit[0] + ' ~ ' + tLimit[1] + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">��ת</span><span class=\"status-value\">' + (results.flip ? '��' : '��') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">�ȶ���</span><span class=\"status-value\">' + (results.stable ? '<span class=\"badge yes\">? �ȶ�</span>' : '<span class=\"badge no\">? ���ȶ�</span>') + '</span></div>';\r\n            if (results.csv_path) {\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">CSV ·��</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\r\n            }\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Speed Test (P5.4 + M4 P3)\r\n        // ================================================================\r\n        function speedTestRun() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceIp = connectedDevice.ip;\r\n            var device = connectedDevice;\r\n            var btn = document.getElementById('btnSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> ������...';\r\n            document.getElementById('speedProgress').style.display = 'block';\r\n            document.getElementById('speedResultArea').innerHTML = '';\r\n            addLog('info', '�ٶȲ��Կ�ʼ: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ����';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '�ٶȲ������');\r\n                    addLog('success', '�ٶȲ������: ' + (resp.message || ''));\r\n                    renderSpeedResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '����ʧ��');\r\n                    addLog('error', '�ٶȲ���ʧ��: ' + (resp ? resp.message : 'δ֪'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ����';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                showToast('error', '�����쳣: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded speed labels)\r\n            var speedProgText = document.getElementById('speedProgressText');\r\n            var speedProgBar = document.getElementById('speedProgressBar');\r\n            if (speedProgText) speedProgText.textContent = '������... �ȴ��豸��Ӧ';\r\n            if (speedProgBar) speedProgBar.style.width = '30%';\r\n            // REMOVED simulateProgress (was hardcoded: '�ٶȵ�λ 1', '50', '100')\r\n            // Speed results now display actual values returned from backend\r\n        }\r\n        function renderSpeedResults(results) {\r\n            var area = document.getElementById('speedResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">���޽��</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>�ٶȲ��Խ��</h4>';\r\n            // Speed mapping table\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            var mapKeys = Object.keys(speedMap);\r\n            if (mapKeys.length > 0) {\r\n                html += '<table class=\"result-table\" style=\"margin:12px 0\"><thead><tr><th>�ٶȵ�λ</th><th>ʵ������ (��/s)</th></tr></thead><tbody>';\r\n                mapKeys.forEach(function(k) {\r\n                    html += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\r\n                });\r\n                html += '</tbody></table>';\r\n            }\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">������� R2</span><span class=\"status-value\">' + (results.r_squared || results.r2 || '--') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">����</span><span class=\"status-value\">' + (results.accuracy || '--') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">ͨ��</span><span class=\"status-value\">' + (results.passed ? '<span class=\"badge yes\">?</span>' : '<span class=\"badge no\">?</span>') + '</span></div>';\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Progress Simulation\r\n        // ================================================================\r\n        function simulateProgress(textId, barId, totalSteps, labels) {\r\n            var current = 0;\r\n            var interval = setInterval(function() {\r\n                current++;\r\n                if (current > totalSteps) { clearInterval(interval); return; }\r\n                var pct = Math.round((current / totalSteps) * 100);\r\n                var textEl = document.getElementById(textId);\r\n                var barEl = document.getElementById(barId);\r\n                if (textEl) textEl.textContent = labels ? labels[current-1] : '������... ' + current + '/' + totalSteps;\r\n                if (barEl) barEl.style.width = pct + '%';\r\n            }, 2000);\r\n        }\r\n        function simulateDirections() {\r\n            var dirs = ['P+ �ƶ���...', 'P- �ƶ���...', 'T+ �ƶ���...', 'T- �ƶ���...'];\r\n            var i = 0;\r\n            var interval = setInterval(function() {\r\n                var el = document.getElementById('limitDirection');\r\n                if (!el) { clearInterval(interval); return; }\r\n                if (i >= dirs.length) { clearInterval(interval); el.textContent = '������� ?'; el.style.color = '#3fb950'; return; }\r\n                el.textContent = '��ǰ����: ' + dirs[i];\r\n                i++;\r\n            }, 3000);\r\n        }\r\n        // ================================================================\r\n        //  Connect Device Page (�߼����� -> �����豸)\r\n        // ================================================================\r\n        function onConnectDeviceChange() {\r\n            var ip = document.getElementById('advConnectDevice').value;\r\n            var noDevice = document.getElementById('connectNoDevice');\r\n            var controlArea = document.getElementById('connectControlArea');\r\n            var statusSpan = document.getElementById('connectDeviceStatus');\r\n            if (ip) {\r\n                var device = allDevices.find(function(d) { return d.ip === ip; });\r\n                noDevice.style.display = 'none';\r\n                controlArea.style.display = 'block';\r\n                statusSpan.textContent = device ? ('������: ' + ip) : ip;\r\n            } else {\r\n                noDevice.style.display = 'block';\r\n                controlArea.style.display = 'none';\r\n                statusSpan.textContent = '';\r\n            }\r\n        }\r\n        // ���ܼ�⣨�����豸ҳ��棩\r\n        function connectFuncDetectRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '����ѡ���豸'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectFuncRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> ̽����...';\r\n            document.getElementById('connectFuncProgress').style.display = 'block';\r\n            document.getElementById('connectFuncResultMini').innerHTML = '';\r\n            addLog('info', '���ܼ�⿪ʼ: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/function/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ���';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '���ܼ�����');\r\n                    addLog('success', '���ܼ�����: ' + (resp.message || ''));\r\n                    renderConnectFuncResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'function');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '̽��ʧ��');\r\n                    addLog('error', '���ܼ��ʧ��: ' + (resp ? resp.message : 'δ֪'));\r\n                    document.getElementById('connectFuncResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">? ' + (resp ? resp.message : '̽��ʧ��') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ���';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                showToast('error', '̽���쳣: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectFuncDetectRun\r\n        }\r\n        function renderConnectFuncResultMini(results) {\r\n            var area = document.getElementById('connectFuncResultMini');\r\n            var keys = Object.keys(results);\r\n            var supported = 0, total = keys.length;\r\n            keys.forEach(function(k) { if (results[k] && results[k].supported) supported++; });\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#3fb950\">? ֧�� ' + supported + '/' + total + ' ���</span>';\r\n        }\r\n        // ��λ��⣨�����豸ҳ��棩\r\n        function connectLimitTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '����ѡ���豸'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectLimitRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> ������...';\r\n            document.getElementById('connectLimitProgress').style.display = 'block';\r\n            document.getElementById('connectLimitResultMini').innerHTML = '';\r\n            addLog('info', '��λ��⿪ʼ: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/limit/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ���';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '��λ������');\r\n                    addLog('success', '��λ������: ' + (resp.message || ''));\r\n                    renderConnectLimitResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'limit');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '����ʧ��');\r\n                    addLog('error', '��λ���ʧ��: ' + (resp ? resp.message : 'δ֪'));\r\n                    document.getElementById('connectLimitResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">? ' + (resp ? resp.message : '����ʧ��') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ���';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                showToast('error', '�����쳣: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectLimitTestRun\r\n        }\r\n        function renderConnectLimitResultMini(results) {\r\n            var area = document.getElementById('connectLimitResultMini');\r\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#d29922\">P: ' + pLimit[0] + '~' + pLimit[1] + ' | T: ' + tLimit[0] + '~' + tLimit[1] + '</span>';\r\n        }\r\n        // �ٶȼ�⣨�����豸ҳ��棩\r\n        function connectSpeedTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '����ѡ���豸'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> ������...';\r\n            document.getElementById('connectSpeedProgress').style.display = 'block';\r\n            document.getElementById('connectSpeedResultMini').innerHTML = '';\r\n            addLog('info', '�ٶȼ�⿪ʼ: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ���';\r\n                document.getElementById('connectSpeedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '�ٶȼ�����');\r\n                    addLog('success', '�ٶȼ�����: ' + (resp.message || ''));\r\n                    renderConnectSpeedResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'speed');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '����ʧ��');\r\n                    addLog('error', '�ٶȼ��ʧ��: ' + (resp ? resp.message : 'δ֪'));\r\n                    document.getElementById('connectSpeedResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">? ' + (resp ? resp.message : '����ʧ��') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '? ��ʼ���';\r\n                document.getElementById('connectSpeedProgress').style.display = 'none';\r\n                showToast('error', '�����쳣: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectSpeedTestRun (was hardcoded: �ٶȵ�λ 1, 50, 100)\r\n        }\r\n        function renderConnectSpeedResultMini(results) {\r\n            var area = document.getElementById('connectSpeedResultMini');\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            var count = Object.keys(speedMap).length;\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#f0883e\">? �Ѳ��� ' + count + ' ���ٶȵ�λ</span>';\r\n        }\r\n        // һ����⣨ȫ����\r\n        var detectionState = { running: false, step: 0, totalSteps: 3, results: {} };\r\n        function startDetection() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '����ѡ���豸'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnStartDetection');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> �����...';\r\n            document.getElementById('detectionProgress').style.display = 'block';\r\n            document.getElementById('detectionLog').innerHTML = '';\r\n            detectionState = { running: true, step: 0, totalSteps: 3, results: {}, deviceIp: deviceIp, device: device };\r\n            addDetectionLog('info', '��ʼһ�����: ' + deviceIp);\r\n            runDetectionStep();\r\n        }\r\n        function runDetectionStep() {\r\n            var state = detectionState;\r\n            if (!state.running) return;\r\n            var steps = [\r\n                { name: '���ܼ��', url: '/api/v1/advanced/function/run', key: 'function' },\r\n                { name: '��λ���', url: '/api/v1/advanced/limit/run', key: 'limit' },\r\n                { name: '�ٶȼ��', url: '/api/v1/advanced/speed/run', key: 'speed' }\r\n            ];\r\n            if (state.step >= steps.length) {\r\n                finishDetection();\r\n                return;\r\n            }\r\n            var stepInfo = steps[state.step];\r\n            var pct = Math.round(((state.step) / state.totalSteps) * 100);\r\n            document.getElementById('detectionProgressText').textContent = '���� ' + (state.step + 1) + '/' + state.totalSteps + ': ' + stepInfo.name;\r\n            document.getElementById('detectionProgressBar').style.width = pct + '%';\r\n            addDetectionLog('info', '? ���� ' + stepInfo.name + '...');\r\n            apiPost(stepInfo.url, {\r\n                device_ip: state.deviceIp,\r\n                username: (state.device && state.device.username) || 'admin',\r\n                password: (state.device && state.device.password) || '',\r\n                port: (state.device && state.device.port) || 80\r\n            }).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    state.results[stepInfo.key] = resp.results || {};\r\n                    addDetectionLog('success', '? ' + stepInfo.name + ' ���');\r\n                } else {\r\n                    addDetectionLog('error', '? ' + stepInfo.name + ' ʧ��: ' + (resp ? resp.message : 'δ֪'));\r\n                }\r\n                state.step++;\r\n                var newPct = Math.round((state.step / state.totalSteps) * 100);\r\n                document.getElementById('detectionProgressBar').style.width = newPct + '%';\r\n                runDetectionStep();\r\n            }).catch(function(e) {\r\n                addDetectionLog('error', '? ' + stepInfo.name + ' �쳣: ' + e.message);\r\n                state.step++;\r\n                runDetectionStep();\r\n            });\r\n        }\r\n        function finishDetection() {\r\n            var btn = document.getElementById('btnStartDetection');\r\n            btn.disabled = false;\r\n            btn.innerHTML = '? ��ʼ��⣨ȫ����';\r\n            document.getElementById('detectionProgressText').textContent = '�����ɣ�';\r\n            document.getElementById('detectionProgressBar').style.width = '100%';\r\n            document.getElementById('detectionProgressBar').className = 'progress-fill green';\r\n            var state = detectionState;\r\n            var completed = Object.keys(state.results).length;\r\n            addDetectionLog('info', '=== ������: ' + completed + '/' + state.totalSteps + ' ��ͨ�� ===');\r\n            // ��ʾ�������\r\n            if (completed > 0) {\r\n                var allResults = {};\r\n                Object.keys(state.results).forEach(function(k) {\r\n                    Object.keys(state.results[k]).forEach(function(rk) { allResults[rk] = state.results[k][rk]; });\r\n                });\r\n                if (state.results.function) renderConnectFullResults(state.results.function, 'function');\r\n                if (state.results.limit) renderConnectFullResults(state.results.limit, 'limit');\r\n                if (state.results.speed) renderConnectFullResults(state.results.speed, 'speed');\r\n            }\r\n            detectionState.running = false;\r\n        }\r\n        function addDetectionLog(level, msg) {\r\n            var log = document.getElementById('detectionLog');\r\n            if (!log) return;\r\n            var entry = document.createElement('div');\r\n            entry.className = 'log-entry ' + level;\r\n            entry.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\r\n            log.insertBefore(entry, log.firstChild);\r\n        }\r\n        // Ԥ�õ����\r\n        function presetGoto() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\r\n            if (!deviceIp) { showToast('warning', '����ѡ���豸'); return; }\r\n            var resultDiv = document.getElementById('presetResult');\r\n            resultDiv.textContent = '����Ԥ�õ� ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId, null).then(function(resp) {\r\n                if (resp && resp.success !== false) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">? �ѵ���Ԥ�õ� ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">? ����ʧ��: ' + (resp ? resp.message : 'δ֪') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">? �쳣: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function presetSet() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\r\n            if (!deviceIp) { showToast('warning', '����ѡ���豸'); return; }\r\n            var resultDiv = document.getElementById('presetResult');\r\n            resultDiv.textContent = '����Ԥ�õ� ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId + '/set', null).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">? ������Ԥ�õ� ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">? ����ʧ��: ' + (resp ? resp.message : 'δ֪') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">? �쳣: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        // ��Ⱦ����������������豸ҳ��\r\n        function renderConnectFullResults(results, type) {\r\n            var area = document.getElementById('connectFullResultArea');\r\n            var noResult = document.getElementById('connectNoResult');\r\n            if (!area) return;\r\n            area.style.display = 'block';\r\n            noResult.style.display = 'none';\r\n            var html = '<div style=\"margin-top:16px\">';\r\n            html += '<h4 style=\"font-size:15px;color:#e0e6f0;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #21262d\">';\r\n            if (type === 'function') html += '?? ���ܼ���������';\r\n            else if (type === 'limit') html += '?? ��λ����������';\r\n            else if (type === 'speed') html += '? �ٶȼ���������';\r\n            else html += '�����';\r\n            html += '</h4>';\r\n            if (type === 'function') {\r\n                html += '<table class=\"result-table\"><thead><tr><th>����</th><th>֧��</th><th>��Сֵ</th><th>���ֵ</th><th>��ǰֵ</th><th>״̬</th></tr></thead><tbody>';\r\n                var keys = Object.keys(results);\r\n                if (keys.length === 0) {\r\n                    html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">���޽��</td></tr>';\r\n                } else {\r\n                    keys.forEach(function(key) {\r\n                        var item = results[key];\r\n                        var supported = item.supported ? '<span class=\"badge yes\">?</span>' : '<span class=\"badge no\">?</span>';\r\n                        var status = item.status || '���';\r\n                        html += '<tr>';\r\n                        html += '<td>' + key + '</td>';\r\n                        html += '<td>' + supported + '</td>';\r\n                        html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\r\n                        html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\r\n                        html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\r\n                        html += '<td><span class=\"badge yes\">' + status + '</span></td>';\r\n                        html += '</tr>';\r\n                    });\r\n                }\r\n                html += '</tbody></table>';\r\n            } else if (type === 'limit') {\r\n                var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n                var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n                html += '<div class=\"advanced-status-panel\">';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">P����λ</span><span class=\"status-value\">' + pLimit[0] + ' ~ ' + pLimit[1] + '</span></div>';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">T����λ</span><span class=\"status-value\">' + tLimit[0] + ' ~ ' + tLimit[1] + '</span></div>';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">��ת</span><span class=\"status-value\">' + (results.flip ? '��' : '��') + '</span></div>';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">�ȶ���</span><span class=\"status-value\">' + (results.stable ? '<span class=\"badge yes\">? �ȶ�</span>' : '<span class=\"badge no\">? ���ȶ�</span>') + '</span></div>';\r\n                if (results.csv_path) html += '<div class=\"status-row\"><span class=\"status-label\">CSV ·��</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\r\n                html += '</div>';\r\n            } else if (type === 'speed') {\r\n                var speedMap = results.speed_map || results.speed_mapping || {};\r\n                var mapKeys = Object.keys(speedMap);\r\n                if (mapKeys.length > 0) {\r\n                    html += '<table class=\"result-table\" style=\"margin:12px 0\"><thead><tr><th>�ٶȵ�λ</th><th>ʵ������ (��/s)</th></tr></thead><tbody>';\r\n                    mapKeys.forEach(function(k) {\r\n                        html += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\r\n                    });\r\n                    html += '</tbody></table>';\r\n                }\r\n                html += '<div class=\"advanced-status-panel\">';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">������� R2</span><span class=\"status-value\">' + (results.r_squared || results.r2 || '--') + '</span></div>';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">ͨ��</span><span class=\"status-value\">' + (results.passed ? '<span class=\"badge yes\">?</span>' : '<span class=\"badge no\">?</span>') + '</span></div>';\r\n                html += '</div>';\r\n            }\r\n            html += '</div>';\r\n            // Append rather than replace to show all test results\r\n            area.innerHTML += html;\r\n        }\r\n        // ================================================================\r\n        // ================================================================\r\n        //  Ԥ�õ��б����� (����̨��)\r\n        // ================================================================\r\n        function loadPresetList() {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            var btn = document.getElementById('btnPresetLoad');\r\n            btn.disabled = true;\r\n            btn.textContent = '������...';\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '���ڻ�ȡԤ�õ��б�...';\r\n            apiGet('/api/v1/ptz/' + dev + '/presets').then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.textContent = '?? �����б�';\r\n                var sel = document.getElementById('ptzPresetSelect');\r\n                sel.innerHTML = '<option value=\"\">ѡ��Ԥ�õ�</option>';\r\n                if (resp && resp.success && resp.presets && resp.presets.length > 0) {\r\n                    resp.presets.forEach(function(p) {\r\n                        var opt = document.createElement('option');\r\n                        opt.value = p.id;\r\n                        opt.textContent = p.name ? ('P' + p.id + ' - ' + p.name) : 'Ԥ�õ� ' + p.id;\r\n                        sel.appendChild(opt);\r\n                    });\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">�Ѽ��� ' + resp.presets.length + ' ��Ԥ�õ�</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#d29922\">δ��ȡ��Ԥ�õ� (�豸���ܲ�֧��)</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.textContent = '?? �����б�';\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">��ȡʧ��: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function ptzGotoSelectedPreset() {\r\n            var dev = connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            if (!presetId) { showToast('warning', '����ѡ��Ԥ�õ�'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '��ת��Ԥ�õ� ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId, null).then(function(resp) {\r\n                if (resp && resp.success !== false) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">? ��ǰ��Ԥ�õ� ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">? ��תʧ��: ' + (resp ? resp.message : 'δ֪') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">? �쳣: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function ptzSetSelectedPreset() {\r\n            var dev = connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            if (!presetId) { showToast('warning', '����ѡ��Ԥ�õ���'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '���浱ǰλ��ΪԤ�õ� ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId + '/set', null).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">? �ѱ���Ԥ�õ� ' + presetId + '</span>';\r\n                    loadPresetList(); // refresh\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">? ����ʧ��: ' + (resp ? resp.message : 'δ֪') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">? �쳣: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function findMacByIP(ip) {\r\n            var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n            return dev ? dev.mac : '';\r\n        }\r\n        // PTZ Speed Slider\r\n        function initPtzSpeed() {\r\n            var slider = document.getElementById('ptzSpeed');\r\n            if (slider) {\r\n                slider.addEventListener('input', function(e) {\r\n                    document.getElementById('ptzSpeedVal').textContent = e.target.value;\r\n                });\r\n            }\r\n        }\r\n        // Mouse/Touch Up - stop PTZ\r\n        function initMouseUp() {\r\n            document.addEventListener('mouseup', function() { ptzStop(); });\r\n            document.addEventListener('touchend', function() { ptzStop(); });\r\n        }\r\n        // Clock\r\n        function updateClock() {\r\n            var clock = document.getElementById('clock');\r\n            if (clock) clock.textContent = new Date().toLocaleTimeString('zh-CN');\r\n        }\r\n        // Toast Notifications\r\n        function showToast(type, message) {\r\n            var container = document.getElementById('toastContainer');\r\n            var toast = document.createElement('div');\r\n            toast.className = 'toast ' + type;\r\n            toast.textContent = message;\r\n            container.appendChild(toast);\r\n            setTimeout(function() {\r\n                if (toast.parentNode) toast.parentNode.removeChild(toast);\r\n            }, 4000);\r\n        }\r\n        // Logging\r\n        function addLog(level, msg) {\r\n            var c = document.getElementById('logContainer');\r\n            if (!c) return;\r\n            var d = document.createElement('div');\r\n            d.className = 'log-entry ' + level;\r\n            d.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\r\n            c.insertBefore(d, c.firstChild);\r\n            if (c.children.length > 50) c.removeChild(c.lastChild);\r\n        }\r\n        // WebSocket\r\n        function connectWS() {\r\n            try {\r\n                var ws = new WebSocket(WS_URL);\r\n                ws.onopen = function() {\r\n                    document.getElementById('wsDot').className = 'status-dot green';\r\n                    document.getElementById('wsStatus').textContent = '������';\r\n                    addLog('info', 'WebSocket ������');\r\n                };\r\n                ws.onclose = function() {\r\n                    document.getElementById('wsDot').className = 'status-dot red';\r\n                    document.getElementById('wsStatus').textContent = '�ѶϿ�';\r\n                    setTimeout(connectWS, 3000);\r\n                };\r\n                ws.onmessage = function(e) {\r\n                    try {\r\n                        var data = JSON.parse(e.data);\r\n                        if (data.type === 'health') updateHealth(data);\r\n                    } catch(err) {}\r\n                };\r\n            } catch(e) {\r\n                addLog('warn', 'WebSocket ����ʧ��');\r\n            }\r\n        }\r\n        function updateHealth(data) {\r\n            var s = data.system || {};\r\n            if (s.cpu !== undefined) {\r\n                var bar = document.getElementById('cpuBar');\r\n                bar.style.width = s.cpu + '%';\r\n                bar.className = 'progress-fill ' + (s.cpu < 60 ? 'green' : s.cpu < 85 ? 'yellow' : 'red');\r\n                document.getElementById('cpuVal').textContent = s.cpu + '%';\r\n            }\r\n            if (s.memory !== undefined) {\r\n                var bar = document.getElementById('memBar');\r\n                bar.style.width = s.memory + '%';\r\n                bar.className = 'progress-fill ' + (s.memory < 60 ? 'green' : s.memory < 85 ? 'yellow' : 'red');\r\n                document.getElementById('memVal').textContent = s.memory + '%';\r\n            }\r\n            if (s.disk !== undefined) {\r\n                var bar = document.getElementById('diskBar');\r\n                bar.style.width = s.disk + '%';\r\n                bar.className = 'progress-fill ' + (s.disk < 70 ? 'green' : s.disk < 90 ? 'yellow' : 'red');\r\n                document.getElementById('diskVal').textContent = s.disk + '%';\r\n            }\r\n        }\r\n        // SADP Discovery\r\n        function discoverDevices() {\r\n            var btn = document.getElementById('btnDiscover');\r\n            var spinner = document.getElementById('discoverSpinner');\r\n            btn.disabled = true;\r\n            spinner.style.display = 'inline-block';\r\n            addLog('info', 'SADP �豸���ֿ�ʼ...');\r\n            showToast('info', '����ɨ��������豸 (10s)...');\r\n            apiGet('/api/v1/discovery/sadp').then(function(data) {\r\n                if (data.success) {\r\n                    addLog('success', 'SADP ���� ' + data.count + ' ̨�豸: ' + data.message);\r\n                    showToast('success', data.message);\r\n                    refreshDevices();\r\n                } else {\r\n                    addLog('error', '����ʧ��: ' + (data.message || 'δ֪����'));\r\n                    showToast('error', data.message || '����ʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                addLog('error', 'SADP �����쳣: ' + e.message);\r\n                showToast('error', 'SADP �����쳣: ' + e.message);\r\n            }).finally(function() {\r\n                spinner.style.display = 'none';\r\n                btn.disabled = false;\r\n            });\r\n        }\r\n        // Device List\r\n        function refreshDevices() {\r\n            console.log('[REFRESH] refreshDevices called');\r\n            return apiGet('/api/v1/devices').then(function(result) {\r\n                console.log('[REFRESH] API response:', result);\r\n                if (!result.success) {\r\n                    allDevices = [];\r\n                    renderDevices([]);\r\n                    return;\r\n                }\r\n                allDevices = result.data || [];\r\n                renderDevices(allDevices);\r\n                // Update dashboard counters\r\n                var online = allDevices.filter(function(d) { return d.online; }).length;\r\n                var countEl = document.getElementById('devCount');\r\n                if (countEl) countEl.textContent = allDevices.length;\r\n                var onlineEl = document.getElementById('devOnline');\r\n                if (onlineEl) onlineEl.textContent = online;\r\n                var totalEl = document.getElementById('devTotal');\r\n                if (totalEl) totalEl.textContent = allDevices.length;\r\n                // Update PTZ & advanced device dropdowns\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n            }).catch(function(e) {\r\n                console.warn('Failed to refresh devices:', e);\r\n            });\r\n        }\r\n        function renderDevices(devices) {\r\n            var tb = document.getElementById('deviceTable');\r\n            if (!tb) return;\r\n            if (!devices.length) {\r\n                tb.innerHTML = '<tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">�����豸</td></tr>';\r\n                return;\r\n            }\r\n            var html = devices.map(function(d) {\r\n                var sourceBadge = d.source === 'sadp'\r\n                    ? '<span class=\"badge sadp\">SADP</span>'\r\n                    : '<span class=\"badge manual\">�ֶ�</span>';\r\n                var onlineBadge = d.online\r\n                    ? '<span class=\"badge online\">����</span>'\r\n                    : '<span class=\"badge offline\">����</span>';\r\n                var actions = buildDeviceActions(d);\r\n                return '<tr>'\r\n                    + '<td>' + sourceBadge + '</td>'\r\n                    + '<td>' + (d.mac || '--') + '</td>'\r\n                    + '<td>' + (d.ip || '--') + '</td>'\r\n                    + '<td>' + (d.gateway || '--') + '</td>'\r\n                    + '<td>' + (d.name || d.device_name || '--') + '</td>'\r\n                    + '<td>' + (d.model || '--') + '</td>'\r\n                    + '<td>' + onlineBadge + '</td>'\r\n                    + '<td>' + actions + '</td>'\r\n                    + '</tr>';\r\n            }).join('');\r\n            tb.innerHTML = html;\r\n        }\r\n        function buildDeviceActions(d) {\r\n            var btns = [];\r\n            if (d.online) {\r\n                btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"disconnectDevice(\\'' + d.ip + '\\')\">�Ͽ�</button>');\r\n                btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoInline(\\'' + d.ip + '\\')\">��Ϣ</button>');\r\n                // Add \"����\" button for new devices\r\n            } else {\r\n                btns.push('<button class=\"btn btn-primary btn-sm\" onclick=\"connectDevice(\\'' + d.ip + '\\')\">����</button>');\r\n            }\r\n            // Add modify IP button for all devices\r\n            btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\'' + (d.mac || '') + '\\',\\'' + (d.ip || '') + '\\')\">�޸�IP</button>');\r\n            btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\')\">ɾ��</button>');\r\n            return '<div class=\"actions\">' + btns.join('') + '</div>';\r\n        }\r\n        // Device Actions\r\n        function connectDevice(ip) {\r\n            addLog('info', '���������豸: ' + ip);\r\n            apiPost('/api/v1/devices/' + ip + '/connect', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '�豸������: ' + ip);\r\n                    addLog('success', result.message || '���ӳɹ�');\r\n                    refreshDevices();\r\n                    refreshPtzDeviceList();\r\n                    refreshAdvancedDeviceSelectors();\r\n                    // --- v3: Update global connectedDevice ---\r\n                    var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n                    if (dev) {\r\n                        connectedDevice = window.connectedDevice = {\r\n                            ip: dev.ip, model: dev.model || '', name: dev.name || dev.device_name || '',\r\n                            mac: dev.mac || '', username: 'admin', password: '', port: 80, online: true\r\n                        };\r\n                        addLog('info', '�Ѽ�ס�����豸: ' + connectedDevice.ip);\r\n                        // WASM SDK login - user clicked Connect\r\n                        if (window.clickLogin2) { window.clickLogin2(); }\r\n                    }\r\n                } else if (result && result.message && result.message.indexOf('ƾ��') >= 0) {\r\n                    var username = prompt(\"\\u8bf7\\u8f93\\u5165\\u7528\\u6237\\u540d:\", \"admin\");\r\n                    if (!username) return;\r\n                    var password = prompt(\"\\u8bf7\\u8f93\\u5165\\u5bc6\\u7801:\");\r\n                    if (!password) return;\r\n                    apiPost(\"/api/v1/devices/\" + ip + \"/connect\", { username: username, password: password }).then(function(result) {\r\n                        if (result && result.success) {\r\n                            showToast(\"success\", \"\\u5df2\\u8fde\\u63a5: \" + ip);\r\n                            addLog(\"success\", result.message || \"\\u8fde\\u63a5\\u6210\\u529f\");\r\n                            refreshDevices(); refreshPtzDeviceList(); refreshAdvancedDeviceSelectors();\r\n                            var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n                            if (dev) connectedDevice = { ip: dev.ip, model: dev.model||\"\", name: dev.name||dev.device_name||\"\", mac: dev.mac||\"\", username: username, password: password, port: 80, online: true };\r\n                        } else showToast(\"error\", result ? result.message : \"\\u8fde\\u63a5\\u5931\\u8d25\");\r\n                    }).catch(function(e) { showToast(\"error\", \"\\u8fde\\u63a5\\u5f02\\u5e38: \" + e.message); });\r\n                    return;\r\n                } else {\r\n                    showToast('error', result ? result.message : '����ʧ��');\r\n                    addLog('error', result ? result.message : '����ʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '�����쳣: ' + e.message);\r\n                addLog('error', '�����쳣: ' + e.message);\r\n            });\r\n        }\r\n        function connectDeviceWithCreds(ip, username, password, port) {\r\n            apiPost('/api/v1/devices/' + ip + '/connect', {\r\n                username: username, password: password, port: port\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '�豸������: ' + ip);\r\n                    addLog('success', result.message || '���ӳɹ�');\r\n                    refreshDevices();\r\n                    refreshPtzDeviceList();\r\n                    refreshAdvancedDeviceSelectors();\r\n                    // --- v3: Update global connectedDevice ---\r\n                    var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n                    if (dev) {\r\n                        connectedDevice = window.connectedDevice = {\r\n                            ip: dev.ip, model: dev.model || '', name: dev.name || dev.device_name || '',\r\n                            mac: dev.mac || '', username: username, password: password, port: port, online: true\r\n                        };\r\n                        addLog('info', '�Ѽ�ס�����豸: ' + connectedDevice.ip);\r\n                        // WASM SDK login - user clicked Connect\r\n                        if (window.clickLogin2) { window.clickLogin2(); }\r\n                    }\r\n                } else {\r\n                    showToast('error', result ? result.message : '����ʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '�����쳣: ' + e.message);\r\n            });\r\n        }\r\n        function disconnectDevice(ip) {\r\n            apiPost('/api/v1/devices/' + ip + '/disconnect', null).then(function() {\r\n                showToast('info', '�豸�ѶϿ�: ' + ip);\r\n                addLog('info', '�豸�ѶϿ�: ' + ip);\r\n                refreshDevices();\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n                // --- v3: Clear global connectedDevice if it matches ---\r\n                if (connectedDevice && connectedDevice.ip === ip) {\r\n                    connectedDevice = null;\r\n                    addLog('info', '����������豸״̬');\r\n                }\r\n                var panel = document.getElementById('deviceInfoPanel');\r\n                if (panel) panel.style.display = 'none';\r\n            }).catch(function(e) {\r\n                showToast('error', '�Ͽ��쳣: ' + e.message);\r\n            });\r\n        }\r\n        function deleteDevice(identifier) {\r\n            if (!confirm('ȷ��ɾ���豸 ' + identifier + '��')) return;\r\n            apiDelete('/api/v1/devices/' + identifier).then(function() {\r\n                showToast('success', '�豸��ɾ��');\r\n                addLog('info', '�豸��ɾ��: ' + identifier);\r\n                refreshDevices();\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n            }).catch(function(e) {\r\n                showToast('error', 'ɾ���쳣: ' + e.message);\r\n            });\r\n        }\r\n        // Show modify IP modal for SADP device\r\n        // Submit modify IP\r\n        // Add Device Modal\r\n        // Connect Device Modal (credentials input)\r\n        // PTZ Device List Update\r\n        function refreshPtzDeviceList() {\r\n            var online = (allDevices || []).filter(function(d) { return d.online; });\r\n            var select = document.getElementById('ptzDevice');\r\n            if (!select) return;\r\n            select.innerHTML = '<option value=\"\">δѡ���豸</option>';\r\n            online.forEach(function(d) {\r\n                var option = document.createElement('option');\r\n                option.value = d.ip;\r\n                option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                select.appendChild(option);\r\n            });\r\n            // Auto-select the globally connected device\r\n            if (connectedDevice && select.querySelector('option[value=\"' + connectedDevice.ip + '\"]')) {\r\n                select.value = connectedDevice.ip;\r\n                onPtzDeviceChange();\r\n            }\r\n        }\r\n        function onPtzDeviceChange() {\r\n            var ip = connectedDevice.ip;\r\n            var controlArea = document.getElementById('ptzControlArea');\r\n            var noDevice = document.getElementById('ptzNoDevice');\r\n            var connInfo = document.getElementById('ptzConnectedInfo');\r\n            if (ip) {\r\n                controlArea.style.display = 'block';\r\n                noDevice.style.display = 'none';\r\n                connInfo.style.display = 'block';\r\n                document.getElementById('ptzSelectedInfo').textContent = ip;\r\n                getPtzPosition();\r\n            } else {\r\n                controlArea.style.display = 'none';\r\n                noDevice.style.display = 'block';\r\n                connInfo.style.display = 'none';\r\n                document.getElementById('ptzPosition').innerHTML = 'Pan: -- | Tilt: -- | Zoom: --';\r\n            }\r\n        }\r\n        // PTZ Controls\r\n        function ptzMove(dir) {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir, speed: speed\r\n            }).then(function(result) {\r\n                if (result && !result.success) {\r\n                    showToast('error', result.message || '�ƶ�ʧ��');\r\n                    addLog('error', 'PTZ �ƶ�ʧ��: ' + (result.message || ''));\r\n                }\r\n            }).catch(function(e) {\r\n                addLog('info', 'PTZ �ƶ�: ' + dir);\r\n            });\r\n        }\r\n        function ptzHome() {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/home', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || '��λ�ɹ�');\r\n                } else if (result) {\r\n                    showToast('error', result.message || '��λʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '��λ�쳣: ' + e.message);\r\n            });\r\n        }\r\n        function ptzStop() {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) return;\r\n            apiPost('/api/v1/ptz/' + dev + '/stop', null).catch(function(e) {});\r\n        }\r\n        function getPtzPosition() {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) return;\r\n            apiGet('/api/v1/ptz/' + dev + '/position').then(function(result) {\r\n                var posEl = document.getElementById('ptzPosition');\r\n                if (result && result.success && result.position) {\r\n                    var p = result.position;\r\n                    posEl.innerHTML = 'Pan: ' + (p.pan || 0) + ' | Tilt: ' + (p.tilt || 0) + ' | Zoom: ' + (p.zoom || 0);\r\n                } else {\r\n                    posEl.innerHTML = 'Pan: -- | Tilt: -- | Zoom: --';\r\n                }\r\n            }).catch(function(e) {});\r\n        }\r\n        // Calibration (placeholder)\r\n        function calibrate(type) {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '���������豸'); return; }\r\n            var dev = connectedDevice.ip;\r\n            apiPost('/api/v1/calibration/' + dev + '/' + type, null).then(function(r) {\r\n                if (r.ok !== false) addLog('info', '��ʼ ' + type + ' У׼...');\r\n            }).catch(function(e) { addLog('error', 'У׼ʧ��'); });\r\n        }\r\n        // ASCOM (placeholder)\r\n        function connectAscom(type) {\r\n            apiPost('/api/v1/ascom/' + type + '/connect', null).then(function(r) {\r\n                if (r && r.success !== false) {\r\n                    showToast('success', type + ' ���ӳɹ�');\r\n                    addLog('info', type + ' ���ӳɹ�');\r\n                }\r\n            }).catch(function(e) { addLog('error', type + ' ����ʧ��'); });\r\n        }\r\n        // Settings (placeholder)\r\n        function saveSettings() {\r\n            apiPost('/api/v1/settings', {\r\n                port: parseInt(document.getElementById('settingPort').value),\r\n                log_level: document.getElementById('settingLogLevel').value,\r\n                db_path: document.getElementById('settingDbPath').value\r\n            }).then(function() {\r\n                addLog('info', '�����ѱ���');\r\n                showToast('success', '�����ѱ���');\r\n            }).catch(function(e) { showToast('error', '����ʧ��'); });\r\n        }\r\n        // Stream / Storage Controls\r\n        function refreshStreamDeviceList() {\r\n            var online = (allDevices || []).filter(function(d) { return d.online; });\r\n            var sel = document.getElementById('advStreamDevice');\r\n            if (!sel) return;\r\n            var current = sel.value;\r\n            sel.innerHTML = '<option value=\"\">δ�����豸</option>';\r\n            online.forEach(function(d) {\r\n                var option = document.createElement('option');\r\n                option.value = d.ip;\r\n                option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                sel.appendChild(option);\r\n            });\r\n            if (current) sel.value = current;\r\n        }\r\n        function onStreamDeviceChange() {\r\n            var ip = document.getElementById('advStreamDevice').value;\r\n            var noDevice = document.getElementById('streamNoDevice');\r\n            var controlArea = document.getElementById('streamControlArea');\r\n            var statusSpan = document.getElementById('streamDeviceStatus');\r\n            if (ip) {\r\n                var device = allDevices.find(function(d) { return d.ip === ip; });\r\n                noDevice.style.display = 'none';\r\n                controlArea.style.display = 'block';\r\n                statusSpan.textContent = device ? ('������: ' + ip) : ip;\r\n                resetStreamButtons();\r\n            } else {\r\n                noDevice.style.display = 'block';\r\n                controlArea.style.display = 'none';\r\n                statusSpan.textContent = '';\r\n            }\r\n        }\r\n        function resetStreamButtons() {\r\n            document.getElementById('btnStreamStart').disabled = false;\r\n            document.getElementById('btnStreamStop').disabled = true;\r\n            document.getElementById('btnRecordStart').disabled = false;\r\n            document.getElementById('btnRecordStop').disabled = true;\r\n            document.getElementById('streamStatusInfo').textContent = '״̬: δ����';\r\n            document.getElementById('recordStatusInfo').textContent = '״̬: δ¼��';\r\n        }\r\n        function streamStart() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceId = connectedDevice.ip;\r\n            var device = allDevices.find(function(d) { return d.ip === deviceId; });\r\n            document.getElementById('btnStreamStart').disabled = true;\r\n            document.getElementById('streamStatusInfo').textContent = '״̬: ��������...';\r\n            var url = '/api/v1/streams/' + deviceId + '/start';\r\n            // Add query params for rtsp_url and stream_name\r\n            // The API accepts query parameters\r\n            apiPost(url + '?stream_name=' + encodeURIComponent((device && device.device_name) || device.ip), null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '����������: ' + deviceId);\r\n                    addLog('success', result.message || '���������ɹ�');\r\n                    document.getElementById('btnStreamStop').disabled = false;\r\n                    document.getElementById('streamStatusInfo').textContent = '״̬: ������ (Stream: ' + (result.stream_id || deviceId) + ')';\r\n                    // Set HLS preview URL if available\r\n                    if (result.stream_id) {\r\n                        var video = document.getElementById('streamVideo');\r\n                        var preview = document.getElementById('streamPreview');\r\n                        if (video && preview) {\r\n                            // Try HLS source\r\n                            var hlsSrc = '/hls/' + result.stream_id + '/playlist.m3u8';\r\n                            video.src = hlsSrc;\r\n                            preview.style.display = 'block';\r\n                        }\r\n                    }\r\n                    resetAdvancedSelectors();\r\n                } else {\r\n                    showToast('error', result ? result.message : '��������ʧ��');\r\n                    document.getElementById('btnStreamStart').disabled = false;\r\n                    document.getElementById('streamStatusInfo').textContent = '״̬: ����ʧ��';\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '�����쳣: ' + e.message);\r\n                document.getElementById('btnStreamStart').disabled = false;\r\n                document.getElementById('streamStatusInfo').textContent = '״̬: �쳣';\r\n            });\r\n        }\r\n        function streamStop() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceId = connectedDevice.ip;\r\n            apiPost('/api/v1/streams/' + deviceId + '/stop', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '������ֹͣ: ' + deviceId);\r\n                    addLog('info', '������ֹͣ');\r\n                    document.getElementById('btnStreamStart').disabled = false;\r\n                    document.getElementById('btnStreamStop').disabled = true;\r\n                    document.getElementById('streamStatusInfo').textContent = '״̬: δ����';\r\n                    document.getElementById('streamPreview').style.display = 'none';\r\n                } else {\r\n                    showToast('error', result ? result.message : '����ֹͣʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '�����쳣: ' + e.message);\r\n            });\r\n        }\r\n        function recordStart() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceId = connectedDevice.ip;\r\n            var targetName = document.getElementById('recordTargetName').value.trim();\r\n            var body = targetName ? { target_name: targetName } : null;\r\n            document.getElementById('btnRecordStart').disabled = true;\r\n            document.getElementById('recordStatusInfo').textContent = '״̬: ����¼��...';\r\n            apiPost('/api/v1/ptz/' + deviceId + '/record/start', body).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '¼��������: ' + deviceId);\r\n                    addLog('success', result.message || '¼�������ɹ�');\r\n                    document.getElementById('btnRecordStop').disabled = false;\r\n                    document.getElementById('recordStatusInfo').textContent = '״̬: ¼����';\r\n                } else {\r\n                    showToast('error', result ? result.message : '¼������ʧ��');\r\n                    document.getElementById('btnRecordStart').disabled = false;\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '¼���쳣: ' + e.message);\r\n                document.getElementById('btnRecordStart').disabled = false;\r\n            });\r\n        }\r\n        function recordStop() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceId = connectedDevice.ip;\r\n            apiPost('/api/v1/ptz/' + deviceId + '/record/stop', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '¼����ֹͣ');\r\n                    addLog('info', '¼����ֹͣ: ' + (result.message || ''));\r\n                    document.getElementById('btnRecordStart').disabled = false;\r\n                    document.getElementById('btnRecordStop').disabled = true;\r\n                    document.getElementById('recordStatusInfo').textContent = '״̬: δ¼��';\r\n                } else {\r\n                    showToast('error', result ? result.message : '¼��ֹͣʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '¼���쳣: ' + e.message);\r\n            });\r\n        }\r\n        function snapshotCapture() {\r\n            if (!connectedDevice || !connectedDevice.ip) { showToast('warning', '�����ڡ��豸�������������豸'); return; }\r\n            var deviceId = connectedDevice.ip;\r\n            var btn = document.getElementById('btnSnapshot');\r\n            btn.disabled = true;\r\n            btn.textContent = 'ץȡ��...';\r\n            apiGet('/api/v1/streams/' + deviceId + '/snapshot').then(function(result) {\r\n                btn.disabled = false;\r\n                btn.textContent = '?? ץȡ����';\r\n                if (result && result.success) {\r\n                    showToast('success', '����ץȡ�ɹ�');\r\n                    addLog('success', result.message || '����ץȡ�ɹ�');\r\n                    // Try to show snapshot using the data URL or preview URL\r\n                    if (result.data && result.data.preview_url) {\r\n                        // Open in new tab or show in preview\r\n                        var preview = document.getElementById('snapshotPreview');\r\n                        var img = document.getElementById('snapshotImg');\r\n                        if (preview && img) {\r\n                            img.src = result.data.preview_url;\r\n                            preview.style.display = 'block';\r\n                        }\r\n                    }\r\n                } else {\r\n                    showToast('error', result ? result.message : '����ץȡʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.textContent = '?? ץȡ����';\r\n                showToast('error', '�����쳣: ' + e.message);\r\n            });\r\n        }\r\n        // Auto refresh\r\n        setInterval(refreshDevices, 15000);\r\n        // ================================================================\r\n        //  ����̨�������ܺ��� (�޸�6)\r\n        // ================================================================\r\n        // ���ٿ���\r\n        function setTracking(mode) {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '�������Ϸ�ѡ���������豸'); return; }\r\n            // ���ð�ť״̬\r\n            ['btnTrackSidereal','btnTrackLunar','btnTrackSolar','btnTrackOff'].forEach(function(id) {\r\n                var b = document.getElementById(id);\r\n                if(b) { b.className = 'btn btn-secondary'; b.style.opacity = '1'; }\r\n            });\r\n            apiPost('/api/v1/ascom/telescope/tracking?mode=' + mode, null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || '����ģʽ������');\r\n                    // ������ǰ��ť\r\n                    var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\r\n                    var activeBtn = document.getElementById(btnMap[mode]);\r\n                    if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\r\n                } else {\r\n                    // ���ڷ�ASCOM��Զ������UI����\r\n                    showToast('info', '����ģʽ: ' + mode + ' (�豸��Ӧ: ' + (result ? result.message : '��') + ')');\r\n                    var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\r\n                    var activeBtn = document.getElementById(btnMap[mode]);\r\n                    if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('info', '����ģʽ: ' + mode + ' (APIδ��Ӧ)');\r\n                var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\r\n                var activeBtn = document.getElementById(btnMap[mode]);\r\n                if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\r\n            });\r\n        }\r\n        // ��ͼ (����̨��)\r\n        function consoleSnapshot() {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            var btn = document.getElementById('btnConsoleSnapshot');\r\n            btn.disabled = true;\r\n            btn.textContent = 'ץȡ��...';\r\n            apiPost('/api/v1/ptz/' + dev + '/capture', null).then(function(result) {\r\n                btn.disabled = false;\r\n                btn.textContent = '?? ��ͼ';\r\n                if (result && result.success) {\r\n                    showToast('success', '��ͼ�ɹ�: ' + (result.data ? result.data.filename : ''));\r\n                    if (result.data && result.data.image_path) {\r\n                        var preview = document.getElementById('consoleSnapshotPreview');\r\n                        var img = document.getElementById('consoleSnapshotImg');\r\n                        if (preview && img) {\r\n                            img.alt = '��ͼ: ' + result.data.filename;\r\n                            preview.style.display = 'block';\r\n                        }\r\n                    }\r\n                } else {\r\n                    showToast('error', result ? result.message : '��ͼʧ��');\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.textContent = '?? ��ͼ';\r\n                showToast('error', '��ͼ�쳣: ' + e.message);\r\n            });\r\n        }\r\n        // ¼�� (����̨��)\r\n        function consoleRecordStart() {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/record/start', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '¼��������');\r\n                    document.getElementById('btnConsoleRecordStart').disabled = true;\r\n                    document.getElementById('btnConsoleRecordStop').disabled = false;\r\n                    document.getElementById('consoleRecordStatus').textContent = '¼����';\r\n                    document.getElementById('consoleRecordStatus').style.color = '#f85149';\r\n                } else {\r\n                    showToast('error', result ? result.message : '¼������ʧ��');\r\n                }\r\n            }).catch(function(e) { showToast('error', '¼���쳣: ' + e.message); });\r\n        }\r\n        function consoleRecordStop() {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/record/stop', null).then(function(result) {\r\n                showToast('info', '¼����ֹͣ');\r\n                document.getElementById('btnConsoleRecordStart').disabled = false;\r\n                document.getElementById('btnConsoleRecordStop').disabled = true;\r\n                document.getElementById('consoleRecordStatus').textContent = 'δ¼��';\r\n                document.getElementById('consoleRecordStatus').style.color = '#8b949e';\r\n            }).catch(function(e) { showToast('error', '¼��ֹͣ�쳣: ' + e.message); });\r\n        }\r\n        // �������\r\n        function adjustImage(param, value) {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) return;\r\n            // ���ڻ������UI������ʵ�ʿ�����ISAPI���� (������)\r\n            var labels = {brightness:'����',contrast:'�Աȶ�',saturation:'���Ͷ�'};\r\n            var label = labels[param] || param;\r\n            // ռλ����ʾ��ǰֵ\r\n            console.log('[�������] ' + label + ': ' + value);\r\n        }\r\n        // OSD ������ʾ����\r\n        function toggleOsd(enabled) {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/osd/toggle?enabled=' + enabled, null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message);\r\n                    document.getElementById('btnOsdOn').className = enabled ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-secondary';\r\n                    document.getElementById('btnOsdOff').className = enabled ? 'btn btn-sm btn-secondary' : 'btn btn-sm btn-primary';\r\n                } else {\r\n                    showToast('error', result ? result.message : 'OSD �л�ʧ��');\r\n                }\r\n            }).catch(function(e) { showToast('error', 'OSD �л��쳣: ' + e.message); });\r\n        }\r\n        // �佹����\r\n        function ptzZoom(direction) {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: direction === 'in' ? 'zoom-in' : 'zoom-out',\r\n                speed: speed\r\n            }).catch(function(e) { addLog('info', 'PTZ �佹: ' + direction); });\r\n        }\r\n        // �Խ�����\r\n        function ptzFocus(mode) {\r\n            var dev = connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '����ѡ���豸'); return; }\r\n            var dir = mode === 'auto' ? 'focus-auto' : mode === 'near' ? 'focus-near' : 'focus-far';\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir,\r\n                speed: parseInt(document.getElementById('ptzSpeed').value)\r\n            }).catch(function(e) { addLog('info', 'PTZ �Խ�: ' + mode); });\r\n        }\r\n        // ================================================================\r\n        //  BUG-017 �޸�: ��¶������ȫ�� window��ʹ HTML onclick �ɵ���\r\n        //  �豸����ҳ�水ť������/����/ˢ�£��Լ�����ҳ�潻����\r\n        //  onclick ������������ IIFE �ڲ���������ʽ��¶��ȫ�֡�\r\n        // ================================================================\r\n        var _expose = [\r\n            discoverDevices, refreshDevices,\r\n            connectDevice, disconnectDevice, deleteDevice,\r\n            ptzMove, ptzHome, ptzStop, getPtzPosition, onPtzDeviceChange,\r\n            calibrate, saveSettings,\r\n            funcDetectRun, funcDetectRestore,\r\n            limitTestRun, speedTestRun,\r\n            streamStart, streamStop, recordStart, recordStop, snapshotCapture,\r\n            onStreamDeviceChange, resetStreamButtons,\r\n            presetGoto, presetSet, startDetection,\r\n            connectFuncDetectRun, connectLimitTestRun, connectSpeedTestRun,\r\n            // ����̨���� (�޸�6)\r\n            setTracking, consoleSnapshot, consoleRecordStart, consoleRecordStop,\r\n             adjustImage, toggleOsd,\r\n            ptzZoom, ptzFocus,\r\n            // Ԥ�õ��б�����\r\n            loadPresetList, ptzGotoSelectedPreset, ptzSetSelectedPreset,\r\n            addDeviceInline, modifyIpPrompt, showDeviceInfoInline,\r\n        ];\r\n        _expose.forEach(function(fn) { window[fn.name] = fn; });\r\n        // Go! - init() executes immediately for instant page interaction\r\n        init();\r\n        function loadWasmDevices() {\r\n            var sel = document.getElementById('device-select');\r\n            if (!sel) return;\r\n            var currentVal = sel.value;\r\n            apiGet('/api/v1/devices').then(function(resp) {\r\n                var devices = resp && resp.success ? (resp.data || resp.devices || []) : [];\r\n                allDevices = devices;\r\n                var ptzDevices = devices.filter(function(d) { return d.online && (d.type === 'ptz' || d.ptz === true); });\r\n                sel.innerHTML = '<option value=\"\">-- ѡ�� PTZ �豸 --</option>';\r\n                ptzDevices.forEach(function(d) {\r\n                    var opt = document.createElement('option');\r\n                    opt.value = d.ip;\r\n                    opt.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                    sel.appendChild(opt);\r\n                });\r\n                if (currentVal && sel.querySelector('option[value=\"' + currentVal + '\"]')) {\r\n                    sel.value = currentVal;\r\n                }\r\n            }).catch(function(e) {\r\n                console.warn('[WASM] Failed to load devices:', e);\r\n                sel.innerHTML = '<option value=\"\">-- ����ʧ�� --</option>';\r\n            });\r\n        }\r\n        function wasmLogout() {\r\n            if (!g_bLoggedIn) return;\r\n            try {\r\n                stopConsoleStream();\r\n                WebVideoCtrl.I_Logout(g_szDeviceIdentify);\r\n            } catch(e) {}\r\n            g_bLoggedIn = false;\r\n            g_szDeviceIdentify = '';\r\n            g_bPlaying = false;\r\n            setLoginStatus('�ѵǳ�', '#8b949e');\r\n            document.getElementById('login-btn').textContent = '��¼';\r\n        }\r\n        // Inline helpers (no modal)\r\n        function addDeviceInline() {\r\n            var ip = prompt(\"\\u8bbe\\u5907 IP:\");\r\n            if (!ip) return;\r\n            apiPost(\"/api/v1/devices\", { ip: ip }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"\\u5df2\\u6dfb\\u52a0\"); refreshDevices(); }\r\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\r\n            }).catch(function(e) { showToast(\"error\", e.message); });\r\n        }\r\n        function modifyIpPrompt(mac, oldIp) {\r\n            var newIp = prompt(\"IP (MAC: \" + mac + \")\", oldIp);\r\n            if (!newIp || newIp === oldIp) return;\r\n            apiPost(\"/api/v1/devices/\" + oldIp, { ip: newIp, mac: mac }).then(function(r) {\r\n                if (r && r.success) { showToast(\"success\", \"IP \\u5df2\\u4fee\\u6539\"); refreshDevices(); }\r\n                else showToast(\"error\", r ? r.message : \"\\u5931\\u8d25\");\r\n            }).catch(function(e) { showToast(\"error\", e.message); });\r\n        }\r\n        function showDeviceInfoInline(ip) {\r\n            var el = document.getElementById(\"deviceInfoPanel\");\r\n            if (!el) return;\r\n            el.style.display = \"block\";\r\n            el.innerHTML = \"\\u83b7\\u53d6\\u4e2d...\";\r\n            apiGet(\"/api/v1/devices/\" + ip + \"/info\").then(function(info) {\r\n                if (info && info.success) {\r\n                    var d = info.data || {};\r\n                    el.innerHTML = Object.keys(d).map(function(k) { return \"<div><b>\" + k + \":</b> \" + d[k] + \"</div>\"; }).join(\"\");\r\n                } else el.innerHTML = \"\\u65e0\\u6cd5\\u83b7\\u53d6\";\r\n            }).catch(function() { el.innerHTML = \"\\u5931\\u8d25\"; });\r\n        }\r\n    })();\r\n</script>\r\n    <!-- WASM SDK Scripts -->\r\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js\"></script>\r\n<script>\r\n// MD5 shim for WASM SDK (after CryptoJS loaded)\r\nwindow.MD5 = function(str) { return CryptoJS.MD5(str).toString(); };\r\nconsole.log('[WASM] MD5 shim installed');\r\n</script>\r\n    <script src=\"static/websdk/wasm/jquery.min.js\"></script>\r\n    <script src=\"static/websdk/wasm/webVideoCtrl.js\"></script>\r\n    <script src=\"static/websdk/wasm/jsPlugin-3.0.0.min.js\"></script>\r\n    <script>\r\n    // WASM SDK Initialization (GLOBAL scope)\r\n    (function() {\r\n        function initWasm() {\r\n            var iRet = window.WebVideoCtrl.I_SupportNoPlugin();\r\n            console.log('[WASM] I_SupportNoPlugin:', iRet);\r\n            if (!iRet) {\r\n                console.error('[WASM] Browser does not support noPlugin mode');\r\n                return;\r\n            }\r\n            WebVideoCtrl.I_InitPlugin(\"100%\", \"100%\", {\r\n                bWndFull: true,\r\n                iPackageType: 2,\r\n                iWndowType: 1,\r\n                bNoPlugin: true,\r\n                cbEvent: function(iEventType, iParam1, iParam2) {\r\n                    console.log(\"[WASM] Event:\", iEventType, iParam1, iParam2);\r\n                },\r\n                cbDoubleClickWnd: function(iWndIndex, bFullScreen) {\r\n                    WebVideoCtrl.I_Stop();\r\n                },\r\n                cbSelWnd: function(xmlDoc) {\r\n                    g_iWndIndex = parseInt($(xmlDoc).find(\"SelectWnd\").eq(0).text(), 10);\r\n                },\r\n                cbInitPluginComplete: function() {\r\n                    console.log('[WASM] cbInitPluginComplete - inserting plugin');\r\n                    WebVideoCtrl.I_InsertOBJECTPlugin(\"divPlugin\");\r\n                    // WASM SDK ready - login/play happens when user clicks connect\r\n                },\r\n                cbPluginErrorHandler: function(iWndIndex, iErrorCode, oError) {\r\n                    console.error('[WASM] Plugin error:', iWndIndex, iErrorCode);\r\n                },\r\n                cbPerformanceLack: function() {\r\n                    console.error('[WASM] Performance issue');\r\n                }\r\n            });\r\n            console.log('[WASM] I_InitPlugin called');\r\n        }\r\n        if (document.readyState === 'loading') {\r\n            document.addEventListener('DOMContentLoaded', initWasm);\r\n        } else {\r\n            initWasm();\r\n        }\r\n    })();\r\n</script>\r\n    <script>\r\n// WASM SDK global variables\r\nvar g_szDeviceIdentify = '';\r\nvar g_bLoggedIn = false;\r\nvar g_bPlaying = false;\r\nvar g_iRtspPort = 554;\r\nvar g_szDeviceIdentify2 = \"\";\r\nvar g_bLoggedIn2 = false;\r\nvar g_bPlaying2 = false;\r\nvar g_iRtspPort2 = 554;\r\nvar g_iWndIndex2 = 0;\r\nvar g_iWebSocketPort = 7681;\r\nvar g_iWndIndex = 0;\r\nvar g_iChannelList = [];\r\nvar g_iChannelID = 1;\r\nvar g_iChannelID = 1;\r\nvar connectedDevice = null;\r\n// WASM SDK global functions (simple version)\r\nfunction setLoginStatus(msg, color) {\r\n    var el = document.getElementById('login-status');\r\n    if (el) {\r\n        el.textContent = msg;\r\n        if (color) el.style.color = color;\r\n    }\r\n    console.log('[WASM] Status: ' + msg);\r\n}\r\nfunction clickLogin2() {\r\n    console.log('[CLICKLOGIN2] Called');\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        console.log('[WASM SDK] No device connected');\r\n        return;\r\n    }\r\n    console.log('[CLICKLOGIN2] Device IP: ' + window.connectedDevice.ip);\r\n    var szIP = window.connectedDevice.ip;\r\n    var szPort = window.connectedDevice.port || 80;\r\n    var szUsername = window.connectedDevice.username || 'admin';\r\n    var szPassword = window.connectedDevice.password || '';\r\n    g_szDeviceIdentify2 = szIP + '_' + szPort;\r\n    console.log('[WASM SDK] Login: ' + szIP + ':' + szPort);\r\n    WebVideoCtrl.I_Login(szIP, 1, szPort, szUsername, szPassword, {\r\n        timeout: 5000,\r\n        success: function(xmlDoc) {\r\n            g_bLoggedIn2 = true;\r\n            console.log('[WASM SDK] Login success: ' + g_szDeviceIdentify2);\r\n            // I_GetDevicePort is SYNCHRONOUS - no .then() needed\r\n                var oPort = WebVideoCtrl.I_GetDevicePort(g_szDeviceIdentify2);\r\n                console.log('[WASM SDK] GetDevicePort result:', oPort);\r\n                if (oPort) {\r\n                    g_iRtspPort2 = oPort.iRtspPort || 554;\r\n                    console.log('[WASM SDK] RTSP port:', g_iRtspPort2);\r\n                }\r\n                // Start stream after short delay\r\n                console.log('[WASM SDK] Calling startConsoleStream2 in 200ms...');\r\n                setTimeout(function() {\r\n                    console.log('[WASM SDK] setTimeout fired, startConsoleStream2 exists:', typeof window.startConsoleStream2);\r\n                    if (window.startConsoleStream2) {\r\n                        window.startConsoleStream2('sub');\r\n                    } else {\r\n                        console.error('[WASM SDK] startConsoleStream2 not found!');\r\n                    }\r\n                }, 200);\r\n        },\r\n        error: function(status, xmlDoc) {\r\n            console.error('[WASM SDK] Login failed:', status);\r\n            g_bLoggedIn2 = false;\r\n        }\r\n    });\r\n}\r\nwindow.clickLogin2 = clickLogin2; // Manually expose to window\r\nfunction startConsoleStream2(mode) {\r\n    console.log(\"[STARTSTREAM2] Called, g_bLoggedIn2=\", g_bLoggedIn2);\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) { console.log(\"[STARTSTREAM2] No device\"); return; }\r\n    if (!g_bLoggedIn2) { if (window.clickLogin2) window.clickLogin2(); return; }\r\n    var iStreamType = (mode === 'main') ? 1 : 2;\r\n    var oWndInfo = WebVideoCtrl.I_GetWindowStatus(g_iWndIndex2);\r\n    var doStart = function() {\r\n        console.log('[WASM SDK] Starting real play, stream=' + iStreamType);\r\n        WebVideoCtrl.I_StartRealPlay(g_szDeviceIdentify2, {\r\n            // iRtspPort not needed for WASM WebSocket mode\r\n            iStreamType: iStreamType,\r\n            iChannelID: 1,\r\n            bZeroChannel: false,\r\n            success: function() {\r\n                g_bPlaying2 = true;\r\n                console.log('[WASM SDK] Real play started');\r\n            },\r\n            error: function(status, xmlDoc) {\r\n                console.error('[WASM SDK] StartRealPlay error:', status);\r\n            }\r\n        });\r\n    };\r\n    if (oWndInfo != null) {\r\n        WebVideoCtrl.I_Stop({ success: function() { doStart(); }, error: function() { doStart(); } });\r\n    } else {\r\n        doStart();\r\n    }\r\n}\r\nwindow.startConsoleStream2 = startConsoleStream2; // Manually expose\r\n        function stopConsoleStream2() {\r\n    if (!g_bPlaying2) return;\r\n    var oWndInfo = WebVideoCtrl.I_GetWindowStatus(g_iWndIndex2);\r\n    if (oWndInfo != null) {\r\n        WebVideoCtrl.I_Stop({ success: function() { g_bPlaying2 = false; console.log('[WASM SDK] Stopped'); } });\r\n    }\r\n}\r\n\r\n</script>","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1779300651656}}
