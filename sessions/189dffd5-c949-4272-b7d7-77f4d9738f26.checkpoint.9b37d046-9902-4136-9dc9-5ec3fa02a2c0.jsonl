{"type":"message","id":"8b09746f","parentId":"f0a0cbb4","timestamp":"2026-05-29T11:13:39.934Z","message":{"role":"assistant","content":[{"type":"text","text":"..."},{"type":"toolCall","id":"tool-d7e675a0fa194b4e96e35472555ea3ab","name":"edit","arguments":{"edits":[{"newText":"class SpeedTester:\n    def __init__(self, ptz: Any) -> None:\n        self.ptz = ptz\n\n    def run_all_tests(self, config: Any = None, speed_profile: str = 'lite') -> list[dict[str, Any]]:\n        return run_all_tests(self.ptz, config, speed_profile)\n\n\n# ================================================================ #\n#  独立运行入口\n# ================================================================ #\n\ndef run_speed_test(ip: str = None, username: str = \"admin\", password: str = \"\", port: int = 80, speed_profile: str = 'lite') -> dict:\n    \"\"\"独立运行Speed测试。\n    \n    Args:\n        ip: 设备IP，如果为None则从配置读取当前设备\n        username: 用户名\n        password: 密码\n        port: 端口\n        speed_profile: 速度档位模式\n    \n    Returns:\n        测试结果\n    \"\"\"\n    from src.ptz.isapi.client import ISAPIClient\n    from src.ptz.isapi.ptz import PTZController\n    \n    # 读取当前设备\n    if ip is None:\n        device = get_current_device()\n        if device is None:\n            return {\"success\": False, \"error\": \"未配置当前设备，请先发现设备或指定IP\"}\n        ip = device.get(\"ip\", \"\")\n        port = device.get(\"port\", 80)\n        if not ip:\n            return {\"success\": False, \"error\": \"当前设备未配置IP\"}\n    \n    # 连接设备\n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n    if not client.verify_credentials():\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n    \n    ptz = PTZController(client)\n    \n    # 运行测试\n    results = run_all_tests(ptz, None, speed_profile)\n    \n    return {\n        \"success\": len(results) > 0,\n        \"total_tests\": len(results),\n        \"results\": results\n    }\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"AstroHub Speed测试\")\n    parser.add_argument(\"--ip\", type=str, help=\"设备IP (默认从配置读取)\")\n    parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n    parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n    parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n    parser.add_argument(\"--profile\", type=str, default=\"lite\", choices=['lite', 'medium', 'full'], help=\"速度档位模式\")\n    args = parser.parse_args()\n    \n    print(\"=\" * 50)\n    print(\"AstroHub Speed测试\")\n    print(\"=\" * 50)\n    \n    result = run_speed_test(ip=args.ip, username=args.username, password=args.password, port=args.port, speed_profile=args.profile)\n    \n    if result.get(\"success\"):\n        print(f\"[完成] 速度测试: {result.get('total_tests', 0)} 项\")\n    else:\n        print(f\"[失败] {result.get('error', '未知错误')}\"","oldText":"class SpeedTester:\n    def __init__(self, ptz: Any) -> None:\n        self.ptz = ptz\n\n    def run_all_tests(self, config: Any = None, speed_profile: str = 'lite') -> list[dict[str, Any]]:\n        return run_all_tests(self.ptz, config, speed_profile)"}],"path":"astrohub/src/advanced/speed.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":64207,"output":893,"cacheRead":0,"cacheWrite":0,"totalTokens":65100,"cost":{"input":0.064207,"output":0.0028576,"cacheRead":0,"cacheWrite":0,"total":0.0670646}},"stopReason":"toolUse","timestamp":1780053197628,"responseId":"cht000d7745@dx19e73704b28b9cb282"}}
