{"type":"message","id":"78a29ba3","parentId":"49114d4a","timestamp":"2026-05-29T11:10:42.074Z","message":{"role":"toolResult","toolCallId":"call_bd07a94b3a474791bcd2514b","toolName":"write","content":[{"type":"text","text":"Successfully wrote 46 bytes to astrohub/data/device_config.json"}],"isError":false,"timestamp":1780053042074}}
{"type":"message","id":"f1fbe512","parentId":"78a29ba3","timestamp":"2026-05-29T11:10:42.074Z","message":{"role":"toolResult","toolCallId":"call_af351e9769104b1b865cc676","toolName":"read","content":[{"type":"text","text":"\"\"\"\nAstroHub v2.0 - 功能探测模块 (Function Detection)\n\n实现 P4.1-P4.21 共 18 项设备功能探测 (严格按 doc/review/M1_method.csv):\n- 每一项: GET端点探测 → 读取当前值 → 读取取值范围 → 修改测试 → 恢复原始值 → 结果写入config\n- 基于 ISAPI client 发送请求\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport xml.etree.ElementTree as ET\nfrom dataclasses import dataclass, field\nfrom typing import Any\n\nfrom src.ptz.isapi.client import ISAPIClient, ISAPIResponse\nfrom src.ptz.constants import ISAPI_CHANNEL, HOME_COORDS\nfrom src.advanced.device_path import get_device_info, get_data_path_write\n\n\ndef verify_home_preset(client) -> dict:\n    \"\"\"P5.0: Verify or create preset 10 (HOME) before function detection.\n\n    Steps: goto_preset(10) → verify coords=1800/450/10\n    If not matching, set_preset(10) from current position.\n    If preset 10 already exists, ONLY verify, DO NOT overwrite.\n    \"\"\"\n    import time\n    from src.ptz.isapi.ptz import PTZController\n\n    ptz = PTZController(client)\n\n    # First try to goto preset 10 to see if it exists\n    ptz.goto_preset(10)\n    time.sleep(2)\n    pos = ptz.get_position()\n\n    expected = HOME_COORDS  # {pan: 1800, tilt: 450, zoom: 10}\n\n    if pos:\n        pan_ok = abs(pos.get(\"pan\", 0) - expected[\"pan\"]) <= 10\n        tilt_ok = abs(pos.get(\"tilt\", 0) - expected[\"tilt\"]) <= 5\n        zoom_ok = abs(pos.get(\"zoom\", 0) - expected[\"zoom\"]) <= 1\n        if pan_ok and tilt_ok and zoom_ok:\n            return {\n                \"success\": True, \"preset_exists\": True,\n                \"position\": pos, \"message\": \"Preset 10 verified, coords match HOME\"\n            }\n\n    # Preset 10 doesn't match HOME coords - need to set it\n    # Don't blindly overwrite: first verify we're at a reasonable position\n    result = ptz.set_preset(10)\n    if result:\n        time.sleep(1)\n        ptz.goto_preset(10)\n        time.sleep(2)\n        pos = ptz.get_position()\n    return {\n        \"success\": result, \"preset_exists\": False,\n        \"position\": pos or {}, \"message\": \"Preset 10 set\"\n    }\n\n\n# ================================================================ #\n#  功能探测端点定义 (P4.1-P4.21) - 严格按 M1_method.csv\n# ================================================================ #\n\nFUNCTION_ENDPOINTS: dict[str, dict[str, Any]] = {\n    # --- P4.1 IrLED 红外补光 ---\n    \"ir_led\": {\n        \"p_id\": \"P4.1\",\n        \"label\": \"IrLED 红外补光\",\n        \"endpoint\": \"/Image/channels/{ch}/IrLight\",\n        \"test_key\": \"brightnessLimit\",\n        \"test_value\": 50,\n        \"range_min\": 1,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.2 白平衡 ---\n    \"white_balance\": {\n        \"p_id\": \"P4.2\",\n        \"label\": \"白平衡\",\n        \"endpoint\": \"/Image/channels/{ch}/whiteBalance\",\n        \"test_key\": \"WhiteBalanceRed\",\n        \"test_keys\": {\"WhiteBalanceRed\": 200, \"WhiteBalanceBlue\": 200},\n        \"test_value\": 200,\n        \"range_min\": 0,\n        \"range_max\": 255,\n        \"mode\": \"multi_field\",\n    },\n\n    # --- P4.3 Gain 模拟增益 ---\n    \"gain\": {\n        \"p_id\": \"P4.3\",\n        \"label\": \"Gain 模拟增益\",\n\n[999 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1780053042074}}
{"type":"message","id":"e829aef4","parentId":"f1fbe512","timestamp":"2026-05-29T11:11:02.575Z","message":{"role":"assistant","content":[{"type":"text","text":"现在创建设备配置管理模块，并修复三个脚本："},{"type":"toolCall","id":"call_fa83007b4e76411f9b552254","name":"write","arguments":{"path":"astrohub/src/advanced/device_config.py","content":"\"\"\"\nAstroHub v2.0 - 设备配置管理\n\n统一管理设备配置：\n- 读取/写入 device_config.json\n- 当前设备、历史设备\n- IP/MAC/型号等信息\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\nCONFIG_FILE = Path(__file__).parent.parent.parent / \"data\" / \"device_config.json\"\n\n\ndef ensure_config() -> Path:\n    \"\"\"确保配置文件存在。\"\"\"\n    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)\n    if not CONFIG_FILE.exists():\n        save_config({\n            \"current_device\": None,\n            \"devices\": {}\n        })\n    return CONFIG_FILE\n\n\ndef load_config() -> dict[str, Any]:\n    \"\"\"加载设备配置。\"\"\"\n    ensure_config()\n    with open(CONFIG_FILE, \"r\", encoding=\"utf-8\") as f:\n        return json.load(f)\n\n\ndef save_config(config: dict[str, Any]) -> None:\n    \"\"\"保存设备配置。\"\"\"\n    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)\n    with open(CONFIG_FILE, \"w\", encoding=\"utf-8\") as f:\n        json.dump(config, f, indent=2, ensure_ascii=False)\n\n\ndef get_current_device() -> dict[str, Any] | None:\n    \"\"\"获取当前设备信息。\"\"\"\n    config = load_config()\n    current_mac = config.get(\"current_device\")\n    if not current_mac:\n        return None\n    return config.get(\"devices\", {}).get(current_mac)\n\n\ndef set_current_device(mac: str, ip: str = \"\", model: str = \"\", port: int = 80) -> None:\n    \"\"\"设置当前设备。\"\"\"\n    config = load_config()\n    mac_clean = mac.replace(\":\", \"\").lower()\n    \n    config[\"current_device\"] = mac_clean\n    if mac_clean not in config.get(\"devices\", {}):\n        config.setdefault(\"devices\", {})[mac_clean] = {}\n    \n    config[\"devices\"][mac_clean][\"mac\"] = mac_clean\n    if ip:\n        config[\"devices\"][mac_clean][\"ip\"] = ip\n    if model:\n        config[\"devices\"][mac_clean][\"model\"] = model\n    config[\"devices\"][mac_clean][\"port\"] = port\n    \n    save_config(config)\n\n\ndef update_device_info(mac: str, **kwargs) -> None:\n    \"\"\"更新设备信息。\"\"\"\n    config = load_config()\n    mac_clean = mac.replace(\":\", \"\").lower()\n    \n    if mac_clean not in config.get(\"devices\", {}):\n        config.setdefault(\"devices\", {})[mac_clean] = {\"mac\": mac_clean}\n    \n    config[\"devices\"][mac_clean].update(kwargs)\n    save_config(config)\n\n\ndef list_devices() -> list[dict[str, Any]]:\n    \"\"\"列出所有历史设备。\"\"\"\n    config = load_config()\n    return list(config.get(\"devices\", {}).values())\n\n\ndef get_device_by_mac(mac: str) -> dict[str, Any] | None:\n    \"\"\"根据MAC获取设备信息。\"\"\"\n    config = load_config()\n    mac_clean = mac.replace(\":\", \"\").lower()\n    return config.get(\"devices\", {}).get(mac_clean)\n"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":66200,"output":694,"cacheRead":0,"cacheWrite":0,"totalTokens":66894,"cost":{"input":0.0662,"output":0.0022208,"cacheRead":0,"cacheWrite":0,"total":0.06842079999999999}},"stopReason":"toolUse","timestamp":1780053042075,"responseId":"cht000d3db9@dx19e736dff69b8aa822"}}
