{"type":"message","id":"84b6e858","parentId":"0802aba7","timestamp":"2026-05-29T11:07:36.504Z","message":{"role":"toolResult","toolCallId":"call_97c986d765f04b4a998daf77","toolName":"read","content":[{"type":"text","text":"\"\"\"\nAstroHub v2.0 - 设备数据路径管理\n\n统一管理设备数据存储路径：\n- 设备标识：MAC地址（从ISAPI获取）\n- 路径规范：data/{短型号}_{mac}/{YYYYMMDD}_{序号}/\n- 读取规则：永远读最新记录\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef get_device_info(ptz: Any) -> dict[str, str]:\n    \"\"\"从设备获取唯一标识信息。\n\n    Args:\n        ptz: PTZController实例\n\n    Returns:\n        dict: {mac, model, model_short, serial}\n    \"\"\"\n    # 从PTZController获取ISAPIClient\n    client = ptz.client if hasattr(ptz, 'client') else ptz\n\n    # 获取设备信息\n    resp = client.get('/System/deviceInfo')\n    xml = resp.xml\n\n    # 解析XML\n    import xml.etree.ElementTree as ET\n    root = ET.fromstring(xml)\n\n    # 提取字段\n    mac = \"\"\n    model = \"\"\n    serial = \"\"\n\n    for child in root:\n        tag = child.tag.split('}')[-1] if '}' in child.tag else child.tag\n        if tag == 'macAddress':\n            mac = child.text or \"\"\n        elif tag == 'model':\n            model = child.text or \"\"\n        elif tag == 'serialNumber':\n            serial = child.text or \"\"\n\n    # MAC地址去除冒号，转小写\n    mac_clean = mac.replace(':', '').lower()\n\n    # 短型号：取前缀（去掉后缀数字和字母）\n    # iDS-2DF8C832IXS-A -> iDS-2DF8C\n    model_short = model\n    if len(model) > 8:\n        model_short = model[:8]\n        while model_short and model_short[-1].isdigit():\n            model_short = model_short[:-1]\n\n    return {\n        'mac': mac,\n        'mac_clean': mac_clean,\n        'model': model,\n        'model_short': model_short,\n        'serial': serial\n    }\n\n\ndef get_device_dir(model_short: str, mac_clean: str) -> Path:\n    \"\"\"获取设备根目录路径。\n\n    Args:\n        model_short: 短型号\n        mac_clean: MAC地址（无冒号，小写）\n\n    Returns:\n        Path: data/{model_short}_{mac_clean}/\n    \"\"\"\n    return Path('data') / f'{model_short}_{mac_clean}'\n\n\ndef find_latest_session(model_short: str, mac_clean: str) -> Path | None:\n    \"\"\"查找最新的测试目录。\n\n    Args:\n        model_short: 短型号\n        mac_clean: MAC地址（无冒号，小写）\n\n    Returns:\n        Path: 最新目录路径，如不存在返回None\n    \"\"\"\n    device_dir = get_device_dir(model_short, mac_clean)\n    if not device_dir.exists():\n        return None\n\n    # 列出所有 {YYYYMMDD}_{序号} 目录\n    pattern = re.compile(r'^(\\d{8})_(\\d{3})$')\n    sessions = []\n    for d in device_dir.iterdir():\n        if d.is_dir():\n            match = pattern.match(d.name)\n            if match:\n                date_str = match.group(1)\n                seq = int(match.group(2))\n                sessions.append((date_str, seq, d))\n\n    if not sessions:\n        return None\n\n    # 按日期和序号排序，返回最新的\n    sessions.sort(key=lambda x: (x[0], x[2]))\n    return sessions[-1][2]\n\n\ndef create_new_session(model_short: str, mac_clean: str) -> Path:\n    \"\"\"创建新的测试目录。\n\n    Args:\n        model_short: 短型号\n        mac_clean: MAC地址（无冒号，小写）\n\n    Returns:\n        Path: 新目录路径\n    \"\"\"\n    device_dir = get_device_dir(model_short, mac_clean)\n    device_dir.mkdir(parents=True, exist_ok=True)\n\n    today = datetime.now().strftime('%Y%m%d')\n\n    # 查找当天已有的目录\n    pattern = re.compile(rf'^{today}_(\\d{3})$')\n    max_seq = 0\n    for d in device_dir.iterdir():\n        if d.is_dir():\n            match = pattern.match(d.name)\n            if match:\n                seq = int(match.group(1))\n                max_seq = max(max_seq, seq)\n\n    # 新序号\n    new_seq = max_seq + 1\n    new_dir = device_dir / f'{today}_{new_seq:03d}'\n    new_dir.mkdir(parents=True, exist_ok=True)\n    return new_dir\n\n\ndef get_data_path_read(model_short: str, mac_clean: str, test_type: str) -> Path | None:\n    \"\"\"获取读取路径（最新目录中的文件）。\n\n    Args:\n        model_short: 短型号\n        mac_clean: MAC地址（无冒号，小写）\n        test_type: 测试类型 (function/limit/speed)\n\n    Returns:\n        Path: 文件路径，如不存在返回None\n    \"\"\"\n    latest_dir = find_latest_session(model_short, mac_clean)\n    if latest_dir is None:\n        return None\n    return latest_dir / f'{test_type}.json'\n\n\ndef get_data_path_write(model_short: str, mac_clean: str, test_type: str) -> Path:\n    \"\"\"获取写入路径（创建新目录或使用当天最新）。\n\n    Args:\n        model_short: 短型号\n        mac_clean: MAC地址（无冒号，小写）\n        test_type: 测试类型 (function/limit/speed)\n\n    Returns:\n        Path: 文件路径\n    \"\"\"\n    # 查找当天最新目录\n    device_dir = get_device_dir(model_short, mac_clean)\n    today = datetime.now().strftime('%Y%m%d')\n\n    pattern = re.compile(rf'^{today}_(\\d{3})$')\n    max_seq = 0\n    if device_dir.exists():\n        for d in device_dir.iterdir():\n            if d.is_dir():\n                match = pattern.match(d.name)\n                if match:\n                    seq = int(match.group(1))\n                    max_seq = max(max_seq, seq)\n\n    if max_seq == 0:\n        # 今天还没有目录，创建001\n        session_dir = device_dir / f'{today}_001'\n    else:\n        # 使用当天最新目录\n        session_dir = device_dir / f'{today}_{max_seq:03d}'\n\n    session_dir.mkdir(parents=True, exist_ok=True)\n    return session_dir / f'{test_type}.json'"}],"isError":false,"timestamp":1780052856504}}
