devices\"][mac_clean][\"mac\"] = mac_clean\n    if ip:\n        config[\"devices\"][mac_clean][\"ip\"] = ip\n    if model:\n        config[\"devices\"][mac_clean][\"model\"] = model\n    config[\"devices\"][mac_clean][\"port\"] = port\n    if username:\n        config[\"devices\"][mac_clean][\"username\"] = username\n    if password:\n        config[\"devices\"][mac_clean][\"password\"] = password\n    \n    save_config(config)\n\n\ndef update_device_info(mac: str, **kwargs) -> None:\n    \"\"\"更新设备信息。\"\"\"\n    config = load_config()\n    mac_clean = mac.replace(\":\", \"\").lower()\n    \n    if mac_clean not in config.get(\"devices\", {}):\n        config.setdefault(\"devices\", {})[mac_clean] = {\"mac\": mac_clean}\n    \n    config[\"devices\"][mac_clean].update(kwargs)\n    save_config(config)\n\n\ndef list_devices() -> list[dict[str, Any]]:\n    \"\"\"列出所有历史设备。\"\"\"\n    config = load_config()\n    return list(config.get(\"devices\", {}).values())\n\n\ndef get_device_by_mac(mac: str) -> dict[str, Any] | None:\n    \"\"\"根据MAC获取设备信息。\"\"\"\n    config = load_config()\n    mac_clean = mac.replace(\":\", \"\").lower()\n    return config.get(\"devices\", {}).get(mac_clean)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\advanced\\device_config.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":63453,"output":743,"cacheRead":0,"cacheWrite":0,"totalTokens":64196,"cost":{"input":0.063453,"output":0.0023776,"cacheRead":0,"cacheWrite":0,"total":0.06583059999999999}},"stopReason":"toolUse","timestamp":1780134332120,"responseId":"cht000d7c4a@dx19e784650b2b8aa822"}}
