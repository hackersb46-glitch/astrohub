mid = int((zoom_min + zoom_max) / 2)\n                      _print(f\"Zoom档位: {zoom_levels}\")\n                      \n                      # 创建CSV\n                      csv_path = get_data_path_write(model_short, mac_clean, 'speed')\n                      csv_path = csv_path.with_suffix('.csv')\n                      with open(csv_path, \"w\", newline=\"\", encoding=\"utf-8\") as f:\n                          writer.writerow([\"timestamp\", \"axis\", \"direction\", \"speed_level\", \"zoom\", \"repeat_idx\", \"position\"])\n                      \n                      # 速度档位\n                      speed_levels = SPEED_PROFILES.get(speed_profile, ['lite', 'medium', 'full'])\n                      speed_profile = speed_profiles[speed_profile]\n                      \n                      # 计算总测试数\n                      total_tests = len(zoom_levels) * len(speed_levels) * 2 * 3\n                      _print(f\"总测试数: {total_tests}\")\n                      \n                      # 计算各个轴的测试数\n                      for axis in [\"pan\", \"tilt\"]:\n                          axis_tests = axis * 2 if axis == \"pan\":\n                              pan_tests = len(speed_levels)\n                          else:\n                              tilt_tests = len(speed_levels) * 2\n                          _print(f\"  {axis}轴测试数: {len(speed_levels) * 2 * 3}  }\n                      for zoom_val in zoom_levels:\n                          # 设置Zoom档位\n                          ptz.absolute_move(pan=1800, tilt=450, zoom=zoom_val, speed=50)\n                          stable_count = 0\n                          for _ in range(300):\n                              pos = ptz.get_position()\n                            actual = pos.get(axis, 0.0)\n                            if actual == zoom_val:\n                                stable_count += 1\n                                if stable_count >= 20:\n                                    break\n                            else:\n                                stable_count = 0\n                            time.sleep(0.1)\n                          if stable_count < 20:\n                              _print(f\"  告: Zoom验证失败,目标{zoom_val}\")\n                      \n                          for speed in speed_levels:\n                              for repeat_idx in range(3):\n                                for direction in [1, -1]:\n                                    direction_str = \"+\" if direction > 0 else \"-\"\n                                    axis_short = axis[0].upper()\n                                    _print(f\"  {axis_short}={dir_str}{speed:>3} {repeat_idx+1}/3, 总 {current_test}/{total_tests}\", end=\"\\r\")\n                                \n                                # 确定起点位置\n                                if axis == \"pan\":\n                                    # Pan有限位时使用虚拟限位: min=10, max=3590\n                                    # Pan无限位时从当前位置开始, 验证稳定\n                                    start_pos = None\n                                    # 从limit_data读取Pan是否有限位\n                                    pan_has_limit = not limit_data.get(\"is_infinite\", True)\n                                    pan_min_val = 10 if not pan_has_limit else 3590\n                                    pan_max_val = 3590 if not pan_has_limit else pan_min\n                                    # 根据direction_info确定起点\n                                    pan_positive_increases = pan_dir.get(\"positive_command_increases\", True)\n                                    if pan_positive_increases == (direction > 0):\n                                        # 正向， 从pan_min往大走\n                                        start_pos = pan_min_val\n                                    else:\n                                        # 正向, 从pan_max往小走\n                                        start_pos = pan_max_val\n                                    # Tilt轴限位\n                                    tilt_min = limit_data.get(\"tilt_min\", -200)\n                                    tilt_max = limit_data.get(\"tilt_max\", 900)\n                                    # Tilt:根据direction_info确定起点\n                                    tilt_positive_increases = tilt_dir.get(\"positive_command_increases\", True)\n                                    if tilt_positive_increases == (direction > 0):\n                                        # 正向, 从tilt_min往大走\n                                        start_pos = tilt_min\n                                    else:\n                                        # 正向, 从tilt_max往小走\n                                        start_pos = tilt_max\n                                \n                                # 测速(不再每次回HOME)\n                                measure_speed_single(\n                                    ptz, axis, speed, str(csv_path),\n                                    direction, zoom_val, repeat_idx,\n start_pos, limit_data\n                                )\n\n                                ptz.stop_move()\n                                stable_count = 0\n                                last_pos = None\n                                for _ in range(300):\n                                    pos = ptz.get_position()\n                                    actual = pos.get(axis, 0.0)\n                                    if actual == last_pos:\n                                        stable_count += 1\n                                        if stable_count >= 20:\n                                            break\n                                    else:\n                                        stable_count = 0\n                                    time.sleep(0.1)\n                                if stable_count < 20:\n                                    _print(f\"  告: {axis}轴未稳定\")\n                                \n                                # 连续移动\n                                # Pan/Tilt轴统一使用 speed_level * direction\n                                actual_speed = speed_level * direction\n                                ptz.continuous_move(\n                                    pan=actual_speed if axis == \"pan\" else 0,\n                                    tilt=actual_speed if axis == \"tilt\" else 0,\n                                )\n                                # 采样(检测限位和翻转)\n                                samples = []\n                                hit_limit = False\n                                flip_detected_sampling = False\n\n                                for _ in range(110):\n                                    position = ptz.get_position()\n                                    pos = position.get(axis, 0.0) if position else 0.0\n                                    samples.append(pos)\n                                    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S.%f\")[:-3]\n                                    with open(raw_csv_path, \"a\", newline=\"\", encoding=\"utf-8\") as f:\n                                        writer.writerow([timestamp, axis, direction, speed_level, zoom_val, repeat_idx, pos])\n                                    \n                                    # 检测限位停止\n                                    hit_limit = False\n                                    \n                                    # Pan有限位:检测到达限位\n                                    if not is_infinite:\n                                        if pos == pan_max or pos == pan_min:\n                                            if len(samples) >= 20:\n                                                recent = samples[-20:]\n                                                if all(p == pos for p in recent):\n                                                    hit_limit = True\n                                    # Pan无限位:不检测跳变,继续采样到110点\n                                \n                                elif axis == \"tilt\":\n                                    # Tilt轴限位检测:连续20点达到tmin或 tmax\n                                    if len(samples) >= 20:\n                                        recent = samples[-20:]\n                                        if all(p == pos for p in recent):\n                                            hit_limit = True\n                                    \n                                    # Tilt轴翻转检测:达到Tmax后数值降低连续5个点\n                                    if len(samples) >= 5:\n                                        if all(samples[i] < samples[i-1] for i in range(-4, 0)):\n                                            flip_detected_sampling = True\n                                            break\n                                    \n                                    # 到达限位后立即停止\n                                    if hit_limit:\n                                        break\n\n                                    time.sleep(0.1)\n                                # 停止并验证稳定(连续20点位置不变)\n                                stable_count = 0\n                                last_pos = None\n                                for _ in range(300):\n                                    pos = ptz.get_position()\n                                    actual = pos.get(axis, 0.0)\n                                    if actual == last_pos:\n                                        stable_count += 1\n                                        if stable_count >= 20:\n                                            break\n                                    else:\n                                        stable_count = 0\n                                    last_pos = actual\n                                    time.sleep(0.1)\n                                if stable_count < 20:\n                                    _print(f\"  警告: {axis}轴未稳定\")\n                                \n                                return samples\n                                \n检查配置文件是否创建：："},{"type":"toolCall","id":"tool-1cd411992e5a4674992a441f59d62310","name":"exec","