{"type":"message","id":"dbdb27a8","parentId":"00162103","timestamp":"2026-05-30T10:22:27.271Z","message":{"role":"toolResult","toolCallId":"tool-afb8b262dd6f4570a2ecf4e6b9ce5cae","toolName":"read","content":[{"type":"text","text":"\n\n# ================================================================ #\n#  独立运行入口\n# ================================================================ #\n\ndef run_function_test(ip: str = None, username: str = \"admin\", password: str = \"\", port: int = 80) -> dict:\n    \"\"\"独立运行Function测试。\n    \n    自动读取活跃设备，无需指定IP。\n    \n    Args:\n        ip: 设备IP（可选，默认从活跃设备读取）\n        username: 用户名\n        password: 密码\n        port: 端口\n    \n    Returns:\n        测试结果\n    \"\"\"\n    # 读取活跃设备\n    if ip is None:\n        device = get_current_device()\n        if device is None:\n            return {\"success\": False, \"error\": \"未设置活跃设备，请先用 device.py add 添加设备\"}\n        ip = device.get(\"ip\", \"\")\n        port = device.get(\"port\", 80)\n        if not ip:\n            return {\"success\": False, \"error\": \"活跃设备未配置IP\"}\n    \n    # 连接设备\n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n    if not client.verify_credentials():\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n    \n    # 运行测试\n    detector = FunctionDetector(client)\n    result = detector.run_all()\n    \n    # 更新设备信息（型号、MAC）\n    if detector._device_info:\n        mac = detector._device_info.get(\"mac_clean\", \"\")\n        model_short = detector._device_info.get(\"model_short\", \"\")\n        update_device_info(mac, model=model_short, ip=ip, port=port)\n    \n    return result\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"AstroHub Function测试\")\n    parser.add_argument(\"--ip\", type=str, help=\"设备IP (默认从配置读取)\")\n    parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n    parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n    parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n    args = parser.parse_args()\n    \n    print(\"=\" * 50)\n    print(\"AstroHub Function测试\")\n    print(\"=\" * 50)\n\n[8 more lines in file. Use offset=1160 to continue.]"}],"isError":false,"timestamp":1780136547271}}
