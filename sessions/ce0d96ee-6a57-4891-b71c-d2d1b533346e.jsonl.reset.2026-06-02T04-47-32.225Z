{"type":"message","id":"3da66227","parentId":"ba2bbbf5","timestamp":"2026-05-31T02:44:07.577Z","message":{"role":"assistant","content":[{"type":"text","text":"检查 Tilt zoom=10 的原始数据："},{"type":"toolCall","id":"call_60627cbdf96644928c56e035","name":"write","arguments":{"content":"import csv\nfrom datetime import datetime\nimport json\n\n# 读取JSON结果\nwith open('data/iDS-2DF_240f9b764193/20260531_001/speed.json', 'r', encoding='utf-8') as f:\n    jdata = json.load(f)\n\n# 读取CSV\nwith open('data/iDS-2DF_240f9b764193/20260531_001/speed.csv', 'r', encoding='utf-8') as f:\n    reader = csv.DictReader(f)\n    rows = list(reader)\n\n# 检查 Tilt zoom=10 speed=100 (最大差异)\nprint('=== Tilt zoom=10 speed=100 Raw Data ===')\nprint()\n\nfor direction in [1, -1]:\n    print(f'--- Direction={direction} ---')\n    \n    # JSON结果\n    json_result = [r for r in jdata['results'] if r['axis']=='tilt' and r['zoom']==10 and r['speed_level']==100 and r['direction']==direction]\n    if json_result:\n        print(f'JSON: speed_val={json_result[0][\"speed_val\"]:.2f} repeats={json_result[0][\"repeats\"]}')\n    \n    # CSV数据\n    data = [r for r in rows if r['axis']=='tilt' and r['zoom']=='10' and r['speed_level']=='100' and r['direction']==str(direction)]\n    \n    # 按repeat分组\n    repeats = {}\n    for r in data:\n        rid = r['repeat_idx']\n        repeats.setdefault(rid, []).append(r)\n    \n    print(f'CSV repeats: {len(repeats)}')\n    \n    for rid in sorted(repeats.keys()):\n        points = repeats[rid]\n        positions = [float(p['position']) for p in points]\n        timestamps = [p['timestamp'] for p in points]\n        \n        print(f'  Repeat {rid}: {len(positions)} points')\n        \n        # 判断运动方向\n        trend_sum = sum(positions[i] - positions[i-1] for i in range(1, min(11, len(positions))))\n        movement_dir = 'increasing' if trend_sum > 0 else 'decreasing'\n        \n        # 限位检测 (连续20点位置相同且等于限位值)\n        tilt_min, tilt_max = -200, 900\n        valid_end = len(positions)\n        limit_detected = False\n        \n        for i in range(20, len(positions)):\n            if all(positions[j] == positions[i] for j in range(i-19, i+1)):\n                if positions[i] == tilt_min or positions[i] == tilt_max:\n                    valid_end = i - 19\n                    limit_detected = True\n                    print(f'    Limit detected at index {i}, pos={positions[i]}, valid_end={valid_end}')\n                    break\n        \n        # 翻转检测\n        flip_detected = False\n        for i in range(10, valid_end):\n            recent_trend = sum(positions[j] - positions[j-1] for j in range(i-4, i+1))\n            if movement_dir == 'increasing' and recent_trend < 0:\n                flip_detected = True\n                valid_end = i\n                print(f'    Flip detected at index {i}')\n                break\n            elif movement_dir == 'decreasing' and recent_trend > 0:\n                flip_detected = True\n                valid_end = i\n                print(f'    Flip detected at index {i}')\n                break\n        \n        if not limit_detected and not flip_detected:\n            valid_end = len(positions) - 5\n            print(f'    No limit/flip, valid_end={valid_end}')\n        \n        # 有效点\n        valid_start = 5\n        valid_positions = positions[valid_start:valid_end]\n        valid_timestamps = timestamps[valid_start:valid_end]\n        \n        print(f'    Valid points: {len(valid_positions)}')\n        print(f'    First valid pos: {valid_positions[0] if valid_positions else \"N/A\"}')\n        print(f'    Last valid pos: {valid_positions[-1] if valid_positions else \"N/A\"}')\n        \n        if len(valid_positions) >= 2:\n            # 计算位移\n            total_move = 0.0\n            for i in range(1, len(valid_positions)):\n                diff = valid_positions[i] - valid_positions[i-1]\n                total_move += diff\n            \n            # 计算时间\n            t_start = datetime.strptime(valid_timestamps[0], '%Y-%m-%d %H:%M:%S.%f')\n            t_end = datetime.strptime(valid_timestamps[-1], '%Y-%m-%d %H:%M:%S.%f')\n            time_sec = (t_end - t_start).total_seconds()\n            \n            speed = abs(total_move) / time_sec if time_sec > 0 else 0\n            print(f'    total_move={total_move:.2f} time={time_sec:.3f}s speed={speed:.2f}')\n    print()\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\check_raw.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":100567,"output":1130,"cacheRead":0,"cacheWrite":0,"totalTokens":101697,"cost":{"input":0.10056699999999999,"output":0.0036160000000000003,"cacheRead":0,"cacheWrite":0,"total":0.10418299999999998}},"stopReason":"toolUse","timestamp":1780195420180,"responseId":"cht000d9bfb@dx19e7bea791fb992462"}}
