          # 有跳变:分段计算\n+327                     prev_idx = 0\n+328                     for jump_idx in jump_indices:\n+329                         # 跳变前:从上一段起点到边界(0或3600)\n+330                         prev_pos = valid_positions[prev_idx]\n+331                         curr_pos = valid_positions[jump_idx]\n+332                         \n+333                         # 判断跳变方向\n+334                         if curr_pos < prev_pos:\n+335                             # 正向跳变:从3600跳到0附近\n+336                             # 跳变前:从prev_pos到3600\n+337                             total_move += abs(3600 - prev_pos)\n+338                         else:\n+339                             # 反向跳变:从0跳到3600附近\n+340                             # 跳变前:从prev_pos到0\n+341                             total_move += abs(prev_pos - 0)\n+342                         \n+343                         prev_idx = jump_idx\n+344                     \n+345                     # 最后一段:从跳变点到终点\n+346                     last_jump_pos = valid_positions[jump_indices[-1]]\n+347                     if last_jump_pos < start_pos:\n+348                         # 正向跳变后:从0到终点\n+349                         total_move += abs(valid_positions[-1] - 0)\n+350                     else:\n+351                         # 反向跳变后:从3600到终点\n+352                         total_move += abs(3600 - valid_positions[-1])\n 335             else:\n 336                 # 累加位移\n 337                 total_move = 0.0\n 338                 for i in range(1, len(valid_positions)):\n     ...","firstChangedLine":311},"isError":false,"timestamp":1780132751019}}
{"type":"message","id":"f8e6e894","parentId":"af9a186a","timestamp":"2026-05-30T09:19:29.564Z","message":{"role":"assistant","content":[{"type":"text","text":"**修复Tilt翻转检测逻辑：**"},{"type":"toolCall","id":"call_b7d4a3d17bba40198ba86043","name":"edit","arguments":{"edits":[{"newText":"            # 检测限位/翻转\n            valid_end = len(positions)\n            flip_detected = False\n\n            # Pan无限位:不排除跳变,用净位移计算\n            # Pan有限位:检测到达限位\n            # Tilt轴翻转检测:趋势反转\n            if axis == \"tilt\":\n                # 翻转检测:连续5个点趋势与初始趋势相反\n                for i in range(10, len(positions)):\n                    # 检查最近5个点趋势\n                    recent_trend = sum(positions[j] - positions[j-1] for j in range(i-4, i+1))\n                    \n                    if movement_dir == \"increasing\" and recent_trend < 0:\n                        # 递增趋势变为递减 → 翻转\n                        flip_detected = True\n                        valid_end = i\n                        break\n                    elif movement_dir == \"decreasing\" and recent_trend > 0:\n                        # 递减趋势变为递增 → 翻转\n                        flip_detected = True\n                        valid_end = i\n                        break","oldText":"            # 检测限位/翻转\n            valid_end = len(positions)\n            flip_detected = False\n\n            # Pan无限位:不排除跳变,用净位移计算\n            # Pan有限位:检测到达限位\n            # Tilt轴翻转检测:在限位附近出现的趋势反转\n            if axis == \"tilt\":\n                for i in range(1, len(positions)):\n                    curr = positions[i]\n                    prev = positions[i-1]\n\n                    if movement_dir == \"increasing\":\n                        # 递增趋势→经过900→递减趋势(900±200范围内)\n                        if curr < prev and curr >= 700:\n                            flip_detected = True\n                            valid_end = i\n                            break\n\n                    elif movement_dir == \"decreasing\":\n                        # 递减趋势→经过-200→递增趋势(-200±200范围内)\n                        if curr > prev and curr <= 0:\n                            flip_detected = True\n                            valid_end = i\n                            break"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\advanced\\speed.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":30606,"output":537,"cacheRead":0,"cacheWrite":0,"totalTokens":31143,"cost":{"input":0.030605999999999998,"output":0.0017184000000000001,"cacheRead":0,"cacheWrite":0,"total":0.032324399999999996}},"stopReason":"toolUse","timestamp":1780132751019,"responseId":"cht000d3933@dx19e782e2cb0b8aa822"}}
