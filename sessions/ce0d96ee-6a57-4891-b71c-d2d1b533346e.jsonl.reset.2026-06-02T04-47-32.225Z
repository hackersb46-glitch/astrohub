-587         if not ip:\n-588             return {\"success\": False, \"error\": \"活跃设备未配置IP\"}\n+590     if username is None:\n+591         username = device.get(\"username\", \"admin\")\n+592     if password is None:\n+593         password = device.get(\"password\", \"\")\n 589     \n+595     if not ip:\n+596         return {\"success\": False, \"error\": \"活跃设备未配置IP\"}\n+597     \n 590     # 连接设备\n 591     client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n 592     if not client.verify_credentials():\n 593         return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n     ...\n 612 if __name__ == \"__main__\":\n 613     import argparse\n 614     parser = argparse.ArgumentParser(description=\"AstroHub Speed测试\")\n 615     parser.add_argument(\"--ip\", type=str, help=\"设备IP (默认从配置读取)\")\n-616     parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n-617     parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n-618     parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n+624     parser.add_argument(\"--username\", type=str, help=\"用户名 (默认从配置读取)\")\n+625     parser.add_argument(\"--password\", type=str, help=\"密码 (默认从配置读取)\")\n+626     parser.add_argument(\"--port\", type=int, help=\"端口 (默认从配置读取)\")\n 619     parser.add_argument(\"--profile\", type=str, default=\"lite\", choices=['lite', 'medium', 'full'], help=\"速度档位模式\")\n 620     args = parser.parse_args()\n 621     \n 622     _print(\"=\" * 50)\n     ...","firstChangedLine":562},"isError":false,"timestamp":1780132721196}}
