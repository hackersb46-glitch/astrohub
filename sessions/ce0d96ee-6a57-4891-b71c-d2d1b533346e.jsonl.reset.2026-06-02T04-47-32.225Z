False, \"error\": \"活跃设备未配置IP\"}\n+608         return {\"success\": False, \"error\": \"设备配置未配置IP\"}\n 608     \n 609     # 连接设备\n 610     client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n 611     if not client.verify_credentials():\n     ...\n 616     # 运行测试\n 617     results = run_all_tests(ptz, None, speed_profile)\n 618     \n 619     # 更新设备信息\n-620     device_info = get_current_device()\n-621     if device_info and device_info.get(\"mac\"):\n-622         update_device_info(device_info[\"mac\"], last_speed_test=len(results))\n+621     from src.advanced.config_writer import load_device_config, save_device_config, DeviceConfig\n+622     config = load_device_config('240f9b764193')\n+623     if config:\n+624         config.speed = {\"last_test\": len(results)}\n+625         save_device_config(config)\n 623     \n 624     return {\n 625         \"success\": len(results) > 0,\n 626         \"total_tests\": len(results),\n     ...","firstChangedLine":576},"isError":false,"timestamp":1780135069961}}
