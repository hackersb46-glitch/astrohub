ve}')\n    \n    # 时间\n    t_start = datetime.strptime(valid_timestamps[0], '%Y-%m-%d %H:%M:%S.%f')\n    t_end = datetime.strptime(valid_timestamps[-1], '%Y-%m-%d %H:%M:%S.%f')\n    time_sec = (t_end - t_start).total_seconds()\n    print(f'  Time: {time_sec:.3f} seconds')\n    \n    # 速度\n    speed = abs(total_move) / time_sec\n    print(f'  Speed: {speed:.2f}')\n    print()\n\""}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":64287,"output":629,"cacheRead":0,"cacheWrite":0,"totalTokens":64916,"cost":{"input":0.064287,"output":0.0020128000000000004,"cacheRead":0,"cacheWrite":0,"total":0.06629979999999999}},"stopReason":"toolUse","timestamp":1780152028122,"responseId":"cht000d0463@dx19e79544ed1b85f532"}}
