{"type":"message","id":"b3565ec7","parentId":"0b374f41","timestamp":"2026-05-31T02:42:17.264Z","message":{"role":"assistant","content":[{"type":"text","text":"**测试已完成！**\n\n- speed.csv: 1426KB\n- speed.json: 27KB\n- 最后更新：03:12:14\n\n检查结果："},{"type":"toolCall","id":"call_54a339c7b991423389a6500a","name":"write","arguments":{"content":"import json\nfrom collections import defaultdict\n\nwith open('data/iDS-2DF_240f9b764193/20260531_001/speed.json', 'r', encoding='utf-8') as f:\n    data = json.load(f)\n\nresults = data['results']\nprint('=== Speed Test Validation ===')\nprint(f'success: {data[\"success\"]}')\nprint(f'total_tests: {data[\"total_tests\"]}')\nprint(f'speed_profile: {data[\"speed_profile\"]}')\nprint()\n\n# 检测1: 同Z值下，正反向差异值5%以上\nprint('--- Check 1: Forward/Backward Difference > 5% ---')\nissues_1 = []\nfor axis in ['pan', 'tilt']:\n    for zoom in sorted(set(r['zoom'] for r in results if r['axis']==axis)):\n        for speed in sorted(set(r['speed_level'] for r in results if r['axis']==axis)):\n            pos = [r for r in results if r['axis']==axis and r['zoom']==zoom and r['speed_level']==speed and r['direction']==1]\n            neg = [r for r in results if r['axis']==axis and r['zoom']==zoom and r['speed_level']==speed and r['direction']==-1]\n            if pos and neg:\n                pos_val = pos[0]['speed_val']\n                neg_val = neg[0]['speed_val']\n                if pos_val > 0 and neg_val > 0:\n                    diff = abs(pos_val - neg_val) / max(pos_val, neg_val) * 100\n                    if diff > 5:\n                        issues_1.append((axis, zoom, speed, pos_val, neg_val, diff))\n                        print(f'  WARN: {axis} zoom={zoom} speed={speed} pos={pos_val:.2f} neg={neg_val:.2f} diff={diff:.2f}%')\nif not issues_1:\n    print('  PASS: All differences <= 5%')\nprint()\n\n# 检测3: 同Z值下，速度值高低与实际移动速度高低不成同趋势关系\nprint('--- Check 3: Speed Level vs Actual Speed Consistency ---')\nissues_3 = []\nfor axis in ['pan', 'tilt']:\n    for zoom in sorted(set(r['zoom'] for r in results if r['axis']==axis)):\n        speeds = sorted(set(r['speed_level'] for r in results if r['axis']==axis and r['zoom']==zoom))\n        actual_speeds = []\n        for speed in speeds:\n            avg_speed = sum(r['speed_val'] for r in results if r['axis']==axis and r['zoom']==zoom and r['speed_level']==speed) / 2\n            actual_speeds.append((speed, avg_speed))\n\n        for i in range(1, len(actual_speeds)):\n            speed_prev, actual_prev = actual_speeds[i-1]\n            speed_curr, actual_curr = actual_speeds[i]\n            if speed_prev < speed_curr and actual_prev > actual_curr:\n                issues_3.append((axis, zoom, speed_prev, speed_curr, actual_prev, actual_curr))\n                print(f'  WARN: {axis} zoom={zoom} speed_level {speed_prev}->{speed_curr} but actual {actual_prev:.2f}->{actual_curr:.2f}')\nif not issues_3:\n    print('  PASS: Speed level and actual speed are consistent')\nprint()\n\n# 检测4: 相同速度下，低Z值速度低于高Z值\nprint('--- Check 4: Lower Zoom Should Have Higher Speed ---')\nissues_4 = []\nfor axis in ['pan', 'tilt']:\n    for speed in sorted(set(r['speed_level'] for r in results if r['axis']==axis)):\n        zooms = sorted(set(r['zoom'] for r in results if r['axis']==axis and r['speed_level']==speed))\n        speeds_by_zoom = []\n        for zoom in zooms:\n            avg_speed = sum(r['speed_val'] for r in results if r['axis']==axis and r['zoom']==zoom and r['speed_level']==speed) / 2\n            speeds_by_zoom.append((zoom, avg_speed))\n\n        for i in range(1, len(speeds_by_zoom)):\n            zoom_prev, speed_prev = speeds_by_zoom[i-1]\n            zoom_curr, speed_curr = speeds_by_zoom[i]\n            if zoom_prev < zoom_curr and speed_prev < speed_curr:\n                issues_4.append((axis, speed, zoom_prev, zoom_curr, speed_prev, speed_curr))\n                print(f'  WARN: {axis} speed={speed} zoom {zoom_prev}->{zoom_curr} but speed {speed_prev:.2f}->{speed_curr:.2f}')\nif not issues_4:\n    print('  PASS: Lower zoom has higher speed')\nprint()\n\nprint('=== Summary ===')\nprint(f'  Check 1 issues: {len(issues_1)}')\nprint(f'  Check 3 issues: {len(issues_3)}')\nprint(f'  Check 4 issues: {len(issues_4)}')\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\validate_speed.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":98570,"output":1153,"cacheRead":0,"cacheWrite":0,"totalTokens":99723,"cost":{"input":0.09856999999999999,"output":0.0036896000000000003,"cacheRead":0,"cacheWrite":0,"total":0.10225959999999999}},"stopReason":"toolUse","timestamp":1780195312635,"responseId":"cht000fc3d9@dx19e7be8c611b8ab592"}}
