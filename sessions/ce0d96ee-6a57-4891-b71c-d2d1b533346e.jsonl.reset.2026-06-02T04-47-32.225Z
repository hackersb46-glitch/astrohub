{"type":"message","id":"8dbc4cf5","parentId":"b59bc68a","timestamp":"2026-05-30T09:44:45.642Z","message":{"role":"toolResult","toolCallId":"tool-19a0370b79a94a3caba8a82bba8e7c4a","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nAstroHub v2.0 - 设备发现脚本\n\n功能：\n- SADP发现网络中的设备\n- 手动添加设备\n- 修改设备IP\n- 显示历史设备\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\n# 添加项目根目录到路径\nimport sys\nPROJECT_ROOT = Path(__file__).parent.parent\nsys.path.insert(0, str(PROJECT_ROOT))\n\nfrom src.advanced.device_config import (\n    load_config, save_config, get_current_device, set_current_device,\n    update_device_info, list_devices, get_device_by_mac\n)\n\n\ndef discover_devices(timeout: int = 10) -> list[dict[str, Any]]:\n    \"\"\"使用SADP发现设备。\n    \n    Args:\n        timeout: 发现超时时间（秒）\n    \n    Returns:\n        发现的设备列表\n    \"\"\"\n    try:\n        from src.core.sadp_discovery import SADPManager\n        \n        manager = SADPManager()\n        raw_devices = manager.discover_devices(timeout=timeout)\n        \n        result = []\n        for d in raw_devices:\n            # SADPManager返回的是dict\n            if isinstance(d, dict):\n                result.append({\n                    \"mac\": d.get(\"mac\", \"\"),\n                    \"ip\": d.get(\"ip\", \"\"),\n                    \"model\": d.get(\"model\", \"\"),\n                    \"serial_number\": d.get(\"serial_number\", \"\"),\n                    \"firmware_version\": d.get(\"firmware_version\", \"\"),\n                    \"activated\": d.get(\"activated\", False),\n                    \"http_port\": d.get(\"http_port\", 80),\n                    \"sdk_port\": d.get(\"sdk_port\", 8000),\n                })\n            else:\n                # 兼容SADPDevice对象\n                result.append({\n                    \"mac\": d.mac,\n                    \"ip\": d.ip,\n                    \"model\": d.model,\n                    \"serial_number\": d.serial_number,\n                    \"firmware_version\": d.firmware_version,\n                    \"activated\": d.activated,\n                    \"http_port\": d.http_port,\n                    \"sdk_port\": d.sdk_port,\n                })\n        \n        return result\n    \n    except Exception as e:\n        print(f\"[错误] SADP发现失败: {e}\")\n        return []\n\n\ndef scan_isapi(ip_start: str, ip_end: str = None, port: int = 80) -> list[dict[str, Any]]:\n    \"\"\"扫描ISAPI设备（不需要SADP）。\n    \n    Args:\n        ip_start: 起始IP\n        ip_end: 结束IP（可选，默认只扫描单个IP）\n        port: 端口\n    \n    Returns:\n        发现的设备列表\n    \"\"\"\n    from src.ptz.isapi.client import ISAPIClient\n    import xml.etree.ElementTree as ET\n    \n    devices = []\n    \n    # 解析IP范围\n    if ip_end is None:\n        ip_end = ip_start\n    \n    start_parts = [int(x) for x in ip_start.split('.')]\n    end_parts = [int(x) for x in ip_end.split('.')]\n    \n    for i in range(start_parts[3], end_parts[3] + 1):\n        ip = f\"{start_parts[0]}.{start_parts[1]}.{start_parts[2]}.{i}\"\n        \n        try:\n            client = ISAPIClient(ip=ip, username=\"admin\", password=\"\", port=port, timeout=2)\n            resp = client.get(\"/System/deviceInfo\")\n            \n            if resp.status_code == 200:\n                root = ET.fromstring(resp.xml)\n                \n                device_info = {\"ip\": ip, \"port\": port}\n                for child in root:\n                    tag = child.tag.split('}')[-1] if '}' in child.tag else child.tag\n                    if tag == 'macAddress':\n                        device_info['mac'] = (child.text or \"\").replace(':', '').lower()\n                    elif tag == 'model':\n                        device_info['model'] = child.text or \"\"\n                    elif tag == 'serialNumber':\n                        device_info['serial_number'] = child.text or \"\"\n                    elif tag == 'firmwareVersion':\n                        device_info['firmware_version'] = child.text or \"\"\n                \n                devices.append(device_info)\n                print(f\"[发现] {ip} - {device_info.get('model', 'Unknown')}\")\n        \n        except Exception:\n            pass\n    \n    return devices\n\n\ndef add_device(ip: str, mac: str = None, model: str = \"\", port: int = 80,\n               username: str = \"admin\", password: str = \"\") -> dict[str, Any]:\n    \"\"\"添加设备（手动或自动获取信息）。\n    \n    Args:\n        ip: 设备IP\n        mac: MAC地址（可选，自动获取）\n        model: 型号（可选，自动获取）\n        port: 端口\n        username: 用户名\n        password: 密码\n    \n    Returns:\n        设备信息\n    \"\"\"\n    from src.ptz.isapi.client import ISAPIClient\n    import xml.etree.ElementTree as ET\n    \n    try:\n        client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n        \n        if not client.verify_credentials():\n            return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n        \n        # 获取设备信息\n        resp = client.get(\"/System/deviceInfo\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"error\": f\"获取设备信息失败: {ip}\"}\n        \n        root = ET.fromstring(resp.xml)\n        \n        device_info = {\"ip\": ip, \"port\": port}\n        for child in root:\n            tag = child.tag.split('}')[-1] if '}' in child.tag else child.tag\n            if tag == 'macAddress':\n                device_info['mac'] = (child.text or \"\").replace(':', '').lower()\n            elif tag == 'model':\n                device_info['model'] = child.text or \"\"\n            elif tag == 'serialNumber':\n                device_info['serial_number'] = child.text or \"\"\n            elif tag == 'firmwareVersion':\n                device_info['firmware_version'] = child.text or \"\"\n        \n        # 如果提供了MAC，使用提供的\n        if mac:\n            device_info['mac'] = mac.replace(':', '').lower()\n        if model:\n            device_info['model'] = model\n        \n        # 保存到配置\n        mac_clean = device_info.get('mac', '')\n        if not mac_clean:\n            return {\"success\": False, \"error\": \"无法获取MAC地址\"}\n        \n        set_current_device(mac_clean, ip=device_info['ip'], model=device_info.get('model', ''), port=port)\n        \n        return {\n            \"success\": True,\n            \"device\": device_info,\n            \"message\": f\"设备已添加: {device_info.get('model', 'Unknown')} @ {ip}\"\n        }\n    \n    except Exception as e:\n        return {\"success\": False, \"error\": f\"添加设备异常: {e}\"}\n\n\ndef modify_device_ip(mac: str, new_ip: str, subnet_mask: str = \"255.255.255.0\",\n                    gateway: str = \"\", password: str = \"\") -> dict[str, Any]:\n    \"\"\"修改设备IP。\n    \n    Args:\n        mac: 设备MAC地址\n        new_ip: 新IP\n        subnet_mask: 子网掩码\n        gateway: 网关\n        password: 设备密码\n    \n    Returns:\n        修改结果\n    \"\"\"\n    try:\n        from src.core.sadp_discovery import SADPManager\n        \n        manager = SADPManager()\n        result = manager.modify_device_network(\n            mac=mac,\n            new_ip=new_ip,\n            subnet_mask=subnet_mask,\n            gateway=gateway,\n            password=password\n        )\n        \n        # 更新配置\n        if result.get(\"success\"):\n            update_device_info(mac, ip=new_ip)\n        \n        return result\n    \n    except Exception as e:\n        return {\"success\": False, \"error\": f\"修改IP异常: {e}\"}\n\n\ndef show_devices():\n    \"\"\"显示所有历史设备。\"\"\"\n    config = load_config()\n    devices = config.get(\"devices\", {})\n    current = config.get(\"current_device\")\n    \n    print(\"=\" * 60)\n    print(\"AstroHub - 设备列表\")\n    print(\"=\" * 60)\n    \n    if not devices:\n        print(\"[信息] 暂无设备记录\")\n        return\n    \n    for mac, info in devices.items():\n        is_current = \" [当前]\" if mac == current else \"\"\n        print(f\"\\n{info.get('model', 'Unknown')}{is_current}\")\n        print(f\"  MAC:  {mac}\")\n        print(f\"  IP:   {info.get('ip', 'N/A')}\")\n        print(f\"  Port: {info.get('port', 80)}\")\n        if info.get('serial_number'):\n            print(f\"  SN:   {info.get('serial_number')}\")\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"AstroHub 设备管理\")\n    subparsers = parser.add_subparsers(dest=\"command\", help=\"命令\")\n    \n    # discover 命令\n    discover_parser = subparsers.add_parser(\"discover\", help=\"发现设备 (SADP)\")\n    discover_parser.add_argument(\"--timeout\", type=int, default=10, help=\"超时时间(秒)\")\n    \n    # scan 命令\n    scan_parser = subparsers.add_parser(\"scan\", help=\"扫描ISAPI设备\")\n    scan_parser.add_argument(\"ip\", type=str, help=\"IP地址或范围 (如 192.168.1.1 或 192.168.1.1-254)\")\n    scan_parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n    \n    # add 命令\n    add_parser = subparsers.add_parser(\"add\", help=\"添加设备\")\n    add_parser.add_argument(\"ip\", type=str, help=\"设备IP\")\n    add_parser.add_argument(\"--mac\", type=str, help=\"MAC地址\")\n    add_parser.add_argument(\"--model\", type=str, help=\"型号\")\n    add_parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n    add_parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n    add_parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n    \n    # modify 命令\n    modify_parser = subparsers.add_parser(\"modify\", help=\"修改设备IP\")\n    modify_parser.add_argument(\"mac\", type=str, help=\"设备MAC地址\")\n    modify_parser.add_argument(\"new_ip\", type=str, help=\"新IP地址\")\n    modify_parser.add_argument(\"--subnet\", type=str, default=\"255.255.255.0\", help=\"子网掩码\")\n    modify_parser.add_argument(\"--gateway\", type=str, default=\"\", help=\"网关\")\n    modify_parser.add_argument(\"--password\", type=str, default=\"\", help=\"设备密码\")\n    \n    # list 命令\n    subparsers.add_parser(\"list\", help=\"显示历史设备\")\n    \n    # use 命令（设置当前设备）\n    use_parser = subparsers.add_parser(\"use\", help=\"设置当前设备\")\n    use_parser.add_argument(\"mac\", type=str, help=\"设备MAC地址\")\n    \n    args = parser.parse_args()\n    \n    if args.command == \"discover\":\n        print(\"=\" * 60)\n        print(\"AstroHub - SADP设备发现\")\n        print(\"=\" * 60)\n        devices = discover_devices(args.timeout)\n        if devices:\n            print(f\"\\n发现 {len(devices)} 个设备:\")\n            for d in devices:\n                print(f\"  - {d.get('model', 'Unknown')} @ {d.get('ip')} (MAC: {d.get('mac')})\")\n        else:\n            print(\"\\n未发现设备\")\n    \n    elif args.command == \"scan\":\n        print(\"=\" * 60)\n        print(\"AstroHub - ISAPI设备扫描\")\n        print(\"=\" * 60)\n        \n        ip_parts = args.ip.split('-')\n        ip_start = ip_parts[0]\n        ip_end = ip_parts[0] if len(ip_parts) == 1 else f\"{ip_start.rsplit('.', 1)[0]}.{ip_parts[1]}\"\n        \n        devices = scan_isapi(ip_start, ip_end, args.port)\n        print(f\"\\n扫描完成，发现 {len(devices)} 个设备\")\n    \n    elif args.command == \"add\":\n        print(\"=\" * 60)\n        print(\"AstroHub - 添加设备\")\n        print(\"=\" * 60)\n        result = add_device(args.ip, args.mac, args.model, args.port, args.username, args.password)\n        if result.get(\"success\"):\n            print(f\"\\n[成功] {result.get('message')}\")\n            device = result.get('device', {})\n            print(f\"  型号: {device.get('model', 'N/A')}\")\n            print(f\"  MAC:  {device.get('mac', 'N/A')}\")\n        else:\n            print(f\"\\n[失败] {result.get('error')}\")\n    \n    elif args.command == \"modify\":\n        print(\"=\" * 60)\n        print(\"AstroHub - 修改设备IP\")\n        print(\"=\" * 60)\n        result = modify_device_ip(args.mac, args.new_ip, args.subnet, args.gateway, args.password)\n        if result.get(\"success\"):\n            print(f\"\\n[成功] IP已修改为 {args.new_ip}\")\n        else:\n            print(f\"\\n[失败] {result.get('error')}\")\n    \n    elif args.command == \"list\":\n        show_devices()\n    \n    elif args.command == \"use\":\n        device = get_device_by_mac(args.mac)\n        if device:\n            config = load_config()\n            config[\"current_device\"] = args.mac\n            save_config(config)\n            print(f\"[成功] 当前设备已设置为: {device.get('model', 'Unknown')} @ {device.get('ip')}\")\n        else:\n            print(f\"[失败] 未找到设备: {args.mac}\")\n    \n    else:\n        parser.print_help()\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1780134285642}}
