{"type":"message","id":"bf411fa8","parentId":"0dc07de2","timestamp":"2026-06-28T19:58:10.458Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me fix the encoding issue and do the full audit.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_LuW6eZO0cb6FWtZnZURL7963","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"Audit: dead code, hardcoded secrets, dependency graph for speed/limit/function\"\"\"\nimport re, os, sys\nsys.stdout.reconfigure(encoding='utf-8')\n\nBASE = r'C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub'\n\ndef read(path):\n    with open(os.path.join(BASE, path), encoding='utf-8') as f:\n        return f.read()\n\ndef find_refs(html, name):\n    \"\"\"Find all references to name (excluding function definitions)\"\"\"\n    refs = []\n    for m in re.finditer(re.escape(name), html):\n        ctx_pre = html[max(0,m.start()-50):m.start()]\n        ctx_post = html[m.end():m.end()+80]\n        if 'function ' + name not in html[max(0,m.start()-30):m.end()]:\n            refs.append((m.start(), ctx_pre.strip()[-60:] + '>>' + name + '<<' + ctx_post.strip()[:80]))\n    return refs\n\ndef check_html_id(html_body, id_name):\n    return id_name in html_body\n\n# ==================== 1. Dependency Check ====================\nprint(\"=\" * 60)\nprint(\"1. DEPENDENCY AUDIT: Which functions/buttons actually exist?\")\nprint(\"=\" * 60)\n\nindex = read('src/web/index.html')\nbody = index[index.find('<body'):index.find('</body>')]\n\nchecks = [\n    # (name, description)\n    ('btnSpeedRun', '主控台速度测试按钮'),\n    ('speedResultArea', '主控台速度结果显示区'),\n    ('speedProgress', '主控台速度进度条'),\n    ('speedProgressText', '主控台速度进度文字'),\n    ('speedProgressBar', '主控台速度进度条'),\n    ('btnLimitRun', '主控台限位测试按钮'),\n    ('limitResultArea', '主控台限位结果显示区'),\n    ('limitProgress', '主控台限位进度条'),\n    ('btnFuncRun', '主控台功能测试按钮'),\n    ('funcResultArea', '主控台功能结果显示区'),\n    ('connectSpeedProgress', '连接页面速度进度条'),\n    ('connectSpeedResultMini', '连接页面速度迷你结果'),\n    ('connectFullResultArea', '连接页面完整结果区'),\n    ('connectSpeedTestRun', '连接页面速度测试函数'),\n]\n\nfor id_name, desc in checks:\n    in_body = id_name in body\n    in_js = id_name in index\n    status = 'BODY' if in_body else ('JS-only' if in_js else 'MISSING')\n    print(f'  [{status:7s}] {id_name:30s} = {desc}')\n\n# ==================== 2. Dead Code Audit ====================\nprint()\nprint(\"=\" * 60)\nprint(\"2. DEAD CODE: Functions that reference missing HTML elements\")\nprint(\"=\" * 60)\n\ndead_fns = {\n    'speedTestRun': ['btnSpeedRun', 'speedResultArea', 'speedProgress', 'speedProgressText', 'speedProgressBar'],\n    'renderSpeedResults': ['speedResultArea'],\n    '_renderSpeedByZoom': [],  # called by renderSpeedResults only\n    'limitTestRun': ['btnLimitRun', 'limitResultArea', 'limitProgress', 'limitProgressText', 'limitProgressBar', 'limitDirection'],\n    'renderLimitResults': ['limitResultArea'],\n    'funcDetectRun': ['btnFuncRun', 'funcResultArea'],\n    'renderFuncResults': ['funcResultArea'],\n}\n\nfor fn, missing_ids in dead_fns.items():\n    missing = [m for m in missing_ids if m not in body]\n    if missing:\n        print(f'  DEAD: {fn}(), missing HTML: {missing}')\n    elif missing_ids:\n        print(f'  LIVE: {fn}() - all ids present')\n\n# ==================== 3. connectSpeedTestRun analysis ====================\nprint()\nprint(\"=\" * 60)\nprint(\"3. connectSpeedTestRun DEEP CHECK\")\nprint(\"=\" * 60)\n\nfor kw in ['connectSpeedTestRun', 'connectSpeedResultMini', 'connectSpeedProgress',\n           'connectFullResultArea', 'connectFuncDetectRun', 'connectLimitTestRun',\n           'connectFuncResultMini', 'connectLimitResultMini']:\n    refs = find_refs(index, kw)\n    body_has = kw in body\n    print(f'  {kw}: body={body_has}, js_refs={len(refs)}')\n\n# ==================== 4. Router endpoint usage ====================\nprint()\nprint(\"=\" * 60)\nprint(\"4. ROUTER ENDPOINTS: Who calls what?\")\nprint(\"=\" * 60)\n\nendpoints = [\n    ('/advanced/speed/run', 'speedTestRun', 'speedTestRun, connectSpeedTestRun'),\n    ('/advanced/speed/cancel', '', ''),\n    ('/advanced/speed/status', '', ''),\n    ('/advanced/limit/run', 'limitTestRun', ''),\n    ('/advanced/function/run', 'funcDetectRun', ''),\n    ('/advanced/detect/start', 'advanced.html', '高级测试一键检测'),\n]\n\nrouter = read('src/api/router.py')\nfor ep, _, desc in endpoints:\n    in_router = f'@api_router.post(\"{ep}\"' in router or f'@api_router.get(\"{ep}\"' in router\n    in_html = ep in index\n    in_adv = read('src/web/includes/advanced.html') if os.path.exists(os.path.join(BASE, 'src/web/includes/advanced.html')) else ''\n    in_adv_has = ep in in_adv\n    print(f'  {ep}: router={in_router}, index.html={in_html}, advanced.html={in_adv_has}')\n\n# ==================== 5. Hardcoded secrets audit ====================\nprint()\nprint(\"=\" * 60)\nprint(\"5. HARDCODED SECRETS AUDIT\")\nprint(\"=\" * 60)\n\nsensitive_patterns = [\n    (r'\\b192\\.168\\.\\d{1,3}\\.\\d{1,3}\\b', 'IP地址'),\n    (r'password\\s*[=:]\\s*[\"\\'][^\"\\']+[\"\\']', '密码'),\n    (r'api[_-]?key\\s*[=:]\\s*[\"\\'][^\"\\']+[\"\\']', 'API Key'),\n    (r'sk-[a-zA-Z0-9]{20,}', 'API Key (sk-格式)'),\n    (r'admin\\s*[\"\\']', '用户名'),\n    (r'mac\\s*[=:]\\s*[\"\\'][0-9a-fA-F:]+[\"\\']', 'MAC地址硬编码'),\n    (r'device_ip\\s*[=:]\\s*[\"\\'][0-9.]+[\"\\']', '设备IP硬编码'),\n    (r'model.*[\"\\']DS-|DH-|iDS-[^\"\\']+[\"\\']', '设备型号硬编码'),\n]\n\nfiles_to_check = [\n    'src/advanced/speed.py',\n    'src/advanced/limit.py',\n    'src/advanced/function.py',\n    'src/api/router.py',\n    'src/ptz/isapi/ptz.py',\n    'src/ptz/isapi/client.py',\n    'src/core/ptz_controller.py',\n    'src/advanced/device_path.py',\n    'src/config_paths.py',\n]\n\nfor fp in files_to_check:\n    full = os.path.join(BASE, fp)\n    if not os.path.exists(full):\n        print(f'  {fp}: FILE NOT FOUND')\n        continue\n    content = read(fp)\n    issues = []\n    for pat, label in sensitive_patterns:\n        matches = list(re.finditer(pat, content, re.IGNORECASE))\n        for m in matches:\n            val = m.group()\n            # filter out false positives\n            if 'password' in pat and ('config' in content[max(0,m.start()-30):m.start()].lower() or 'os.environ' in content[max(0,m.start()-30):m.start()]):\n                continue\n            if 'device_ip' in pat and 'req.' in content[max(0,m.start()-20):m.start()]:\n                continue\n            line_num = content[:m.start()].count('\\n') + 1\n            issues.append(f'  L{line_num}: {label} = {val[:80]}')\n    if issues:\n        print(f'  {fp}:')\n        for i in issues[:10]:\n            print(i)\n    else:\n        print(f'  {fp}: clean')\n\n# ==================== 6. Data file paths hardcoded ====================\nprint()\nprint(\"=\" * 60)\nprint(\"6. HARDCODED PATHS CHECK\")\nprint(\"=\" * 60)\n\nfor fp in files_to_check:\n    full = os.path.join(BASE, fp)\n    if not os.path.exists(full):\n        continue\n    content = read(fp)\n    matches = list(re.finditer(r'[\"\\'][A-Za-z]:\\\\[^\"\\']*\\.(?:json|csv|yaml|toml|ini)[\"\\']', content))\n    if matches:\n        print(f'  {fp}:')\n        for m in matches:\n            line_num = content[:m.start()].count('\\n') + 1\n            print(f'    L{line_num}: {m.group()[:100]}')\n\nprint()\nprint(\"DONE\")\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\_audit.py"}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":78447,"output":2190,"cacheRead":0,"cacheWrite":0,"totalTokens":80637,"cost":{"input":0.078447,"output":0.007008,"cacheRead":0,"cacheWrite":0,"total":0.085455}},"stopReason":"toolUse","timestamp":1782676671279,"responseId":"cht000d4aa0@dx19f0fcf4cb5b85e322"}}
