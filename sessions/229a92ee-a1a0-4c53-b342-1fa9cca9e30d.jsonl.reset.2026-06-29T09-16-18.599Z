{"type":"message","id":"1331c963","parentId":"a5191a03","timestamp":"2026-06-28T10:55:31.827Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to replace the quickAddModal with the unified showModal approach. Let me replace the whole old section.","thinkingSignature":"reasoning_content"},{"type":"text","text":"Now replace quickAddModal with unified showModal:"},{"type":"toolCall","id":"call_00_FiaO3ld9d50WU3ixGYt95596","name":"edit","arguments":{"edits":[{"newText":"        // v7.117: 快速添加设备 — 使用统一弹窗\n        window.showQuickAddModal = function(ip, gateway) {\n            var localhostGateway = window.localhostGateway || gateway || '';\n            showModal({\n                type: 'form',\n                title: '添加设备',\n                fields: [\n                    { id:'quickAddIp', label:'IP 地址', value: ip || '', placeholder: '' },\n                    { id:'quickAddGateway', label:'网关', value: localhostGateway, placeholder: '' },\n                    { id:'quickAddUser', label:'用户名', value: 'admin', placeholder: '' },\n                    { id:'quickAddPass', label:'密码', type:'password', value: '', placeholder: '', required:true }\n                ],\n                onConfirm: function(data) {\n                    var ip = (data.quickAddIp || '').trim();\n                    var gateway = (data.quickAddGateway || '').trim();\n                    var username = (data.quickAddUser || '').trim();\n                    var password = data.quickAddPass;\n                    if (!ip) { addLog('error', '请输入 IP 地址'); return; }\n                    if (!password) { addLog('error', '请输入密码'); return; }\n                    apiPost('/api/v1/devices', {ip: ip, gateway: gateway, username: username, password: password})\n                        .then(function(result) {\n                            if (result.success) {\n                                addLog('done', '设备已添加: ' + ip);\n                                refreshDevices();\n                                setTimeout(function() { connectDevice(ip); }, 500);\n                            } else {\n                                addLog('error', result.message || '添加失败');\n                            }\n                        }).catch(function(e) { addLog('error', '添加设备失败: ' + e); });\n                }\n            });\n        };\n        window.closeQuickAddModal = function() { closeModal(false); };\n        window.submitQuickAdd = function() { closeModal(true); };\n        // v7.15: 添加设备按钮（完整输入）\n        window.showAddDeviceModal = function() {\n            showQuickAddModal('', '');\n        };","oldText":"        // v7.15: 显示快速添加设备模态框\n        window.showQuickAddModal = function(ip, gateway) {\n            var localhostGateway = window.localhostGateway || gateway || '';\n            var modalHtml = '<div id=\"quickAddModal\" class=\"modal-overlay\" onclick=\"closeQuickAddModal(event)\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:10000\">' +\n                '<div class=\"modal-content\" onclick=\"event.stopPropagation()\" style=\"background:#1a1e2e;padding:24px;border-radius:12px;min-width:360px;box-shadow:0 4px 20px rgba(0,0,0,0.5)\">' +\n                '<h3 style=\"margin:0 0 20px 0;color:#58a6ff;font-size:18px\">添加设备</h3>' +\n                '<div style=\"margin-bottom:16px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">IP 地址</label>' +\n                '<input type=\"text\" id=\"quickAddIp\" value=\"' + (ip || '') + '\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\n                '<div style=\"margin-bottom:16px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">网关</label>' +\n                '<input type=\"text\" id=\"quickAddGateway\" value=\"' + localhostGateway + '\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\n                '<div style=\"margin-bottom:16px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">用户名</label>' +\n                '<input type=\"text\" id=\"quickAddUser\" value=\"admin\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\n                '<div style=\"margin-bottom:20px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">密码</label>' +\n                '<input type=\"password\" id=\"quickAddPass\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\n                '<div style=\"display:flex;gap:12px;justify-content:flex-end\">' +\n                '<button class=\"btn btn-secondary\" onclick=\"closeQuickAddModal()\" style=\"padding:8px 16px\">取消</button>' +\n                '<button class=\"btn btn-primary\" onclick=\"submitQuickAdd()\" style=\"padding:8px 16px\">添加并连接</button></div></div></div>';\n            document.body.insertAdjacentHTML('beforeend', modalHtml);\n        };\n        window.closeQuickAddModal = function(e) {\n            if (e && e.target !== e.currentTarget) return;\n            var modal = document.getElementById('quickAddModal');\n            if (modal) modal.remove();\n        };\n        window.submitQuickAdd = function() {\n            var ip = document.getElementById('quickAddIp').value.trim();\n            var gateway = document.getElementById('quickAddGateway').value.trim();\n            var username = document.getElementById('quickAddUser').value.trim();\n            var password = document.getElementById('quickAddPass').value;\n            if (!ip) { addLog('error', '请输入 IP 地址'); return; }\n            if (!password) { addLog('error', '请输入密码'); return; }\n            closeQuickAddModal();\n            apiPost('/api/v1/devices', {ip: ip, gateway: gateway, username: username, password: password})\n                .then(function(result) {\n                    if (result.success) {\n                        addLog('done', '设备已添加: ' + ip);\n                        refreshDevices();\n                        setTimeout(function() { connectDevice(ip); }, 500);\n                    } else {\n                        addLog('error', result.message || '添加失败');\n                    }\n                }).catch(function(e) { addLog('error', '添加设备失败: ' + e); });\n        };\n        // v7.15: 添加设备按钮（完整输入）\n        window.showAddDeviceModal = function() {\n            showQuickAddModal('', '');\n        };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":83589,"output":1830,"cacheRead":0,"cacheWrite":0,"totalTokens":85419,"cost":{"input":0.083589,"output":0.005856,"cacheRead":0,"cacheWrite":0,"total":0.089445}},"stopReason":"toolUse","timestamp":1782644112928,"responseId":"cht000e6ef8@dx19f0dde89dfb87f332"}}
