8         .astro-modal-field { margin-bottom:14px; }\n+ 159         .astro-modal-field label { display:block; margin-bottom:6px; color:#8b949e; font-size:13px; }\n+ 160         .astro-modal-field input { width:100%; padding:10px; background:#0d1117; border:1px solid #30363d; border-radius:6px; color:#e0e6f0; font-size:14px; box-sizing:border-box; }\n+ 161         .astro-modal-field input:focus { outline:none; border-color:#58a6ff; }\n  157         /* Loading spinner */\n  158         .spinner { display:inline-block; width:16px; height:16px; border:2px solid #30363d; border-top-color:#58a6ff; border-radius:50%; animation:spin 0.8s linear infinite; }\n  159         @keyframes spin { to { transform:rotate(360deg); } }\n  160         .loading { pointer-events:none; opacity:0.7; }\n      ...","firstChangedLine":152},"isError":false,"timestamp":1782644022993}}
{"type":"message","id":"b6309975","parentId":"312f0c3e","timestamp":"2026-06-28T10:54:24.191Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to replace the old showAlert, showConfirm, and quickAddModal with the unified showModal. Let me also replace the confirmRestart that uses browser confirm(). Let me do the replacements carefully.\n\nFirst, replace the old showAlert and showConfirm with the unified showModal function.","thinkingSignature":"reasoning_content"},{"type":"text","text":"Now replace old showAlert/showConfirm with unified showModal:\n\n"},{"type":"toolCall","id":"call_eakr2xop8q0unrj5amicjj7x","name":"edit","arguments":{"edits":[{"newText":"        // v7.117: 统一弹窗组件 — 替代所有旧弹窗\n        // options: { type:'alert'|'confirm'|'form', title, message, fields, onConfirm, onCancel }\n        window.showModal = function(options) {\n            closeModal();\n            var opts = options || {};\n            var type = opts.type || 'alert';\n            var title = opts.title || (type === 'confirm' ? '确认' : '提示');\n            var titleColor = type === 'confirm' ? '#58a6ff' : '#f0883e';\n            var bodyHtml = '';\n\n            if (type === 'form' && opts.fields) {\n                opts.fields.forEach(function(f) {\n                    bodyHtml += '<div class=\"astro-modal-field\"><label>' + (f.label || '') + '</label>' +\n                        '<input type=\"' + (f.type || 'text') + '\" id=\"astroModalField_' + (f.id || '') + '\"' +\n                        ' value=\"' + (f.value || '') + '\" placeholder=\"' + (f.placeholder || '') + '\"' +\n                        (f.required ? ' required' : '') + '></div>';\n                });\n            } else if (opts.message) {\n                bodyHtml = '<p class=\"astro-modal-body\">' + opts.message + '</p>';\n            }\n\n            var actionsHtml = '';\n            if (type === 'confirm' || type === 'form') {\n                actionsHtml = '<button class=\"btn btn-secondary\" onclick=\"closeModal(false)\">取消</button>' +\n                    '<button class=\"btn btn-primary\" onclick=\"closeModal(true)\">确定</button>';\n            } else {\n                actionsHtml = '<button class=\"btn btn-primary\" onclick=\"closeModal(true)\" style=\"width:100%\">确定</button>';\n            }\n\n            var html = '<div id=\"astroModal\" class=\"astro-modal-backdrop\">' +\n                '<div class=\"astro-modal\">' +\n                '<h3 class=\"astro-modal-title\" style=\"color:' + titleColor + '\">' + title + '</h3>' +\n                bodyHtml +\n                '<div class=\"astro-modal-actions\">' + actionsHtml + '</div>' +\n                '</div></div>';\n            document.body.insertAdjacentHTML('beforeend', html);\n            window._modalCallback = opts.onConfirm || null;\n            window._modalType = type;\n\n            // ESC 关闭\n            window._modalEscHandler = function(e) { if (e.key === 'Escape') closeModal(false); };\n            document.addEventListener('keydown', window._modalEscHandler);\n\n            // 聚焦第一个输入框\n            if (type === 'form') {\n                setTimeout(function() {\n                    var firstInput = document.querySelector('#astroModal input');\n                    if (firstInput) firstInput.focus();\n                }, 100);\n            }\n        };\n        window.closeModal = function(result) {\n            var modal = document.getElementById('astroModal');\n            if (modal) modal.remove();\n            if (window._modalEscHandler) {\n                document.removeEventListener('keydown', window._modalEscHandler);\n                window._modalEscHandler = null;\n            }\n            if (result && window._modalCallback) {\n                if (window._modalType === 'form') {\n                    var data = {};\n                    var inputs = document.querySelectorAll('#astroModal [id^=\"astroModalField_\"]');\n                    inputs.forEach(function(el) {\n                        var key = el.id.replace('astroModalField_', '');\n                        data[key] = el.value;\n                    });\n                    window._modalCallback(data);\n                } else {\n                    window._modalCallback();\n                }\n            }\n            window._modalCallback = null;\n            window._modalType = null;\n        };\n        // 兼容旧接口\n        window.showAlert = function(message, title) { showModal({ type:'alert', title:title, message:message }); };\n        window.showConfirm = function(message, onConfirm, title) { showModal({ type:'confirm', title:title, message:message, onConfirm:onConfirm }); };\n        window.closeAlert = function() { closeModal(false); };\n        window.closeConfirm = function(result) { closeModal(result); };","oldText":"        // v7.15: 网页级别弹窗\n        window.showAlert = function(message, title) {\n            var alertHtml = '<div id=\"alertModal\" class=\"modal-overlay\" onclick=\"closeAlert()\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:10000\">' +\n                '<div onclick=\"event.stopPropagation()\" style=\"background:#1a1e2e;padding:24px;border-radius:12px;min-width:300px;max-width:500px;box-shadow:0 4px 20px rgba(0,0,0,0.5)\">' +\n                '<h3 style=\"margin:0 0 16px 0;color:#f0883e\">' + (title || '提示') + '</h3>' +\n                '<p style=\"margin:0 0 20px 0;color:#e0e6f0;line-height:1.6\">' + message + '</p>' +\n                '<button class=\"btn btn-primary\" onclick=\"closeAlert()\" style=\"width:100%\">确定</button></div></div>';\n            document.body.insertAdjacentHTML('beforeend', alertHtml);\n        };\n        window.closeAlert = function() {\n            var modal = document.getElementById('alertModal');\n            if (modal) modal.remove();\n        };\n        window.showConfirm = function(message, onConfirm, title) {\n            var confirmHtml = '<div id=\"confirmModal\" class=\"modal-overlay\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:10000\">' +\n                '<div onclick=\"event.stopPropagation()\" style=\"background:#1a1e2e;padding:24px;border-radius:12px;min-width:300px;max-width:500px;box-shadow:0 4px 20px rgba(0,0,0,0.5)\">' +\n                '<h3 style=\"margin:0 0 16px 0;color:#58a6ff\">' + (title || '确认') + '</h3>' +\n                '<p style=\"margin:0 0 20px 0;color:#e0e6f0;line-height:1.6\">' + message + '</p>' +\n                '<div style=\"display:flex;gap:12px;justify-content:flex-end\">' +\n                '<button class=\"btn btn-secondary\" onclick=\"closeConfirm(false)\">取消</button>' +\n                '<button class=\"btn btn-primary\" onclick=\"closeConfirm(true)\">确定</button></div></div></div>';\n            window._confirmCallback = onConfirm;\n            document.body.insertAdjacentHTML('beforeend', confirmHtml);\n        };\n        window.closeConfirm = function(result) {\n            var modal = document.getElementById('confirmModal');\n            if (modal) modal.remove();\n            if (result && window._confirmCallback) {\n                window._confirmCallback();\n                window._confirmCallback = null;\n            }\n        };"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":79340,"output":1946,"cacheRead":0,"cacheWrite":0,"totalTokens":81286,"cost":{"input":0.07934,"output":0.0062272000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0855672}},"stopReason":"toolUse","timestamp":1782644022996,"responseId":"cht000fd225@dx19f0ddd2699ba5d452"}}
