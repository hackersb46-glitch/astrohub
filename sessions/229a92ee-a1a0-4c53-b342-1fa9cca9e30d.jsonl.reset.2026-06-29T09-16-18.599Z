{"type":"message","id":"d8283f70","parentId":"a58631ce","timestamp":"2026-06-28T19:45:52.439Z","message":{"role":"toolResult","toolCallId":"call_498v5hld516kpomi4aiq7pml","toolName":"read","content":[{"type":"text","text":"     btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('limitProgress').style.display = 'none';\r\n                document.getElementById('limitDirection').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded simulation)\r\n            var limitProgText = document.getElementById('limitProgressText');\r\n            var limitProgBar = document.getElementById('limitProgressBar');\r\n            var limitDirEl = document.getElementById('limitDirection');\r\n            if (limitProgText) limitProgText.textContent = '测试中... 等待设备响应';\r\n            if (limitProgBar) limitProgBar.style.width = '30%';\r\n            if (limitDirEl) { limitDirEl.textContent = '当前方向: 初始化...'; limitDirEl.style.display = 'block'; }\r\n            // simulateProgress/simulateDirections REMOVED - hardcoded fake progress\r\n        }\r\n        function renderLimitResults(results) {\r\n            var area = document.getElementById('limitResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\r\n                return;\r\n            }\r\n            if (!results.success) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#f85149\">测试失败: ' + (results.message || '未知错误') + '</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>限位测试结果</h4>';\r\n            // P axis\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">P轴限位</span><span class=\"status-value\">' + results.pan_min + ' ~ ' + results.pan_max + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">T轴限位</span><span class=\"status-value\">' + results.tilt_min + ' ~ ' + results.tilt_max + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">Z轴限位</span><span class=\"status-value\">' + results.zoom_min + ' ~ ' + results.zoom_max + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">翻转</span><span class=\"status-value\">' + (results.has_flip ? '有' : '无') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">稳定性</span><span class=\"status-value\">' + (results.stability_check ? '<span class=\"badge yes\">✅ 稳定</span>' : '<span class=\"badge no\">❌ 不稳定</span>') + '</span></div>';\r\n            if (results.csv_path) {\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">CSV 路径</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\r\n            }\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Speed Test (P5.4 + M4 P3)\r\n        // ================================================================\r\n        "}],"isError":false,"timestamp":1782675952439}}
