{"type":"message","id":"3e462207","parentId":"074c8c1e","timestamp":"2026-06-28T10:42:26.472Z","message":{"role":"toolResult","toolCallId":"call_00_IyYthiGtH1ijoEamgpHC2397","toolName":"read","content":[{"type":"text","text":"        //  主控台新增功能函数 (修复6)\r\n        // ================================================================\r\n        // 跟踪控制\r\n        function setTracking(mode) {\r\n            var dev = window.connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '请先在上方选择已连接设备'); return; }\r\n            // 重置按钮状态\r\n            ['btnTrackSidereal','btnTrackLunar','btnTrackSolar','btnTrackOff'].forEach(function(id) {\r\n                var b = document.getElementById(id);\r\n                if(b) { b.className = 'btn btn-secondary'; b.style.opacity = '1'; }\r\n            });\r\n            apiPost('/api/v1/ascom/telescope/tracking?mode=' + mode, null).then(function(result) {\r\n                var trackLabels = {trackSidereal:'恒星跟踪',trackLunar:'月球跟踪',trackSolar:'太阳跟踪',trackOff:'关闭跟踪'};\r\n                if (typeof operationLog === 'function') operationLog('跟踪: ' + (trackLabels[mode] || mode), 'success');\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || '跟踪模式已设置');\r\n                    // 高亮当前按钮\r\n                    var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\r\n                    var activeBtn = document.getElementById(btnMap[mode]);\r\n                    if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\r\n                } else {\r\n                    // 对于非ASCOM望远镜,给UI反馈\r\n                    showToast('info', '跟踪模式: ' + mode + ' (设备响应: ' + (result ? result.message : '无') + ')');\r\n                    var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\r\n                    var activeBtn = document.getElementById(btnMap[mode]);\r\n                    if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('info', '跟踪模式: ' + mode + ' (API未响应)');\r\n                var btnMap = {trackSidereal:'btnTrackSidereal',trackLunar:'btnTrackLunar',trackSolar:'btnTrackSolar',trackOff:'btnTrackOff'};\r\n                var activeBtn = document.getElementById(btnMap[mode]);\r\n                if (activeBtn) { activeBtn.className = 'btn btn-primary'; }\r\n            });\r\n        }\r\n        // 截图 (主控台版) - v7.109: 使用 ISAPI 后端 API\r\n        function consoleSnapshot() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n                showToast('warning', '请先连接设备');\r\n                return;\r\n            }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var btn = document.getElementById('btnConsoleSnapshot');\r\n            btn.disabled = true;\r\n            btn.textContent = '抓取中...';\r\n            apiPost('/api/v1/ptz/' + deviceIp + '/capture', null).then(function(result) {\r\n                btn.disabled = false;\r\n                btn.textContent = '📷 截图';\r\n                if (result && result.success) {\r\n                    showToast('success', '截图成功: ' + (result.data && result.data.filename || ''));\r\n                    if (typeof operationLog === 'function') operationLog('截图', 'success');\r\n                    var timeStr = new Date().toLocaleTimeString('en-US', { hour12: false });\r\n                    if (typeof mediaLog === 'function') mediaLog(timeStr + ' 截图成功', 'success');\r\n                } else {\r\n                    showToast('error', result ? result.message : '截图失败');\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.textContent = '📷 截图';\r\n                showToast('error', '截图异常: ' + e.message);\r\n            });\r\n        }\r\n        // 录像 (主控台版) - v7.110: WASM录制 + 自动上传 + 30分钟分割\r\n        var _recordSegmentTimer = null;  // 30分钟分割定时器\r\n        var _recordSegmentAuto = false;  // 是否自动分割\r\n\r\n        function consoleRecordStart(autoRestart) {\r\n            if (!WasmPlayer || !WasmPlayer.playing) {\r\n                showToast('warning', '请先开始预览');\r\n                return;\r\n            }\r\n            var dev = window.connectedDevice;\r\n            var deviceName = (dev && (dev.name || dev.device_name || dev.ip) || 'device').replace(/[^a-zA-Z0-9\\u4e00-\\u9fa5_-]/g, '_');\r\n            var now = new Date();\r\n            var dateStr = now.getFullYear() + String(now.getMonth()+1).padStart(2,'0') + String(now.getDate()).padStart(2,'0');\r\n            var timeStr = String(now.getHours()).padStart(2,'0') + String(now.getMinutes()).padStart(2,'0') + String(now.getSeconds()).padStart(2,'0');\r\n            var baseFilename = deviceName + '_' + dateStr + '_' + timeStr;\r\n            // v7.113: 只在重名时加序号，新baseName自动重置为1\r\n            if (!window._recordSeq) window._recordSeq = {_lastBase: '', _counter: 0};\r\n            if (window._recordSeq._lastBase === baseFilename) {\r\n                window._recordSeq._counter += 1;\r\n            } else {\r\n                window._recordSeq._counter = 0;\r\n                window._recordSeq._lastBase = baseFilename;\r\n            }\r\n            var seq = window._recordSeq._counter;\r\n            var filename = seq > 0 ? baseFilename + '_' + seq : baseFilename;\r\n            window._currentRecordFile = filename + '.mp4';\r\n\r\n            wasmStartRecord(filename).then(function(result) {\r\n                // v7.111: 如果用户已点击停止，不再更新状态\r\n                if (!window._isRecording) return;\r\n                if (result && result.success) {\r\n                    var msg = autoRestart ? '录像段已启动' : '录像已启动';\r\n                    showToast('success', msg);\r\n                    if (typeof operationLog === 'function') operationLog(autoRestart ? '录像分段重启' : '录像开始', 'warning');\r\n                    if (typeof updateRecordToggleUI === 'function') updateRecordToggleUI(true);\r\n                    if (typeof updateMediaOutputStatus === 'function') updateMediaOutputStatus('recording');\r\n                    var statusEl = document.getElementById('consoleRecordStatus');\r\n                    if (statusEl) statusEl.textContent = '录像中';\r\n                    var ts = new Date().toLocaleTimeString('en-US', { hour12: false });\r\n\n[959 more lines in file. Use offset=2148 to continue.]"}],"isError":false,"timestamp":1782643346472}}
