dEventListener('keydown',function(e){if(e.key==='Escape')closeReplayModal()});","oldText":"                if(selectMode)return;\n                var m=document.getElementById('replay-modal');\n                if(!m){m=document.createElement('div');m.id='replay-modal';m.className='replay-modal';m.onclick=function(e){if(e.target===m)closeModal()};document.body.appendChild(m)}\n                m.innerHTML=type==='image'\n                    ?'<button class=\"replay-modal-close\" onclick=\"closeModal()\">×</button><img class=\"replay-modal-img\" src=\"'+url+'\">'\n                    :'<button class=\"replay-modal-close\" onclick=\"closeModal()\">×</button><video class=\"replay-modal-video\" controls autoplay src=\"'+url+'\"></video>';\n                m.classList.add('active');\n            };\n            \n            window.closeModal=function(){\n                var m=document.getElementById('replay-modal');\n                if(m){var v=m.querySelector('video');if(v){v.pause();v.src=''}m.classList.remove('active')}\n            };\n            \n            document.addEventListener('keydown',function(e){if(e.key==='Escape')closeModal()});"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\replay.html"}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":143514,"output":798,"cacheRead":0,"cacheWrite":0,"totalTokens":144312,"cost":{"input":0.143514,"output":0.0025536,"cacheRead":0,"cacheWrite":0,"total":0.1460676}},"stopReason":"toolUse","timestamp":1782681038879,"responseId":"cht000d1b2d@dx19f1011fb12b893752"}}
