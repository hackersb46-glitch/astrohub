{"type":"message","id":"314c8c6b","parentId":"ba28fa45","timestamp":"2026-06-28T19:42:19.986Z","message":{"role":"toolResult","toolCallId":"call_00_WC54kkNKtPkL5HINXDuQ2927","toolName":"read","content":[{"type":"text","text":"            }\r\n            if (!results.success) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#f85149\">测试失败: ' + (results.message || '未知错误') + '</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>限位测试结果</h4>';\r\n            // P axis\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">P轴限位</span><span class=\"status-value\">' + results.pan_min + ' ~ ' + results.pan_max + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">T轴限位</span><span class=\"status-value\">' + results.tilt_min + ' ~ ' + results.tilt_max + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">Z轴限位</span><span class=\"status-value\">' + results.zoom_min + ' ~ ' + results.zoom_max + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">翻转</span><span class=\"status-value\">' + (results.has_flip ? '有' : '无') + '</span></div>';\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">稳定性</span><span class=\"status-value\">' + (results.stability_check ? '<span class=\"badge yes\">✅ 稳定</span>' : '<span class=\"badge no\">❌ 不稳定</span>') + '</span></div>';\r\n            if (results.csv_path) {\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">CSV 路径</span><span class=\"status-value\">' + results.csv_path + '</span></div>';\r\n            }\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        // ================================================================\r\n        //  Speed Test (P5.4 + M4 P3)\r\n        // ================================================================\r\n        function speedTestRun() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('speedProgress').style.display = 'block';\r\n            document.getElementById('speedResultArea').innerHTML = '';\r\n            addLog('info', '速度测试开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '速度测试完成');\r\n                    addLog('success', '速度测试完成: ' + (resp.message || ''));\r\n                    renderSpeedResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '速度测试失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('speedResultArea').innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#f85149\">❌ ' + (resp ? resp.message : '测试失败') + '</p></div>';\r\n                }\r\n            }).catch(function(e) {\r\n\n[2330 more lines in file. Use offset=930 to continue.]"}],"isError":false,"timestamp":1782675739986}}
