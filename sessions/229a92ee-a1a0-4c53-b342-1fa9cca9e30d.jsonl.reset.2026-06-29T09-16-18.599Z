{"type":"message","id":"3a256966","parentId":"d4dd1f89","timestamp":"2026-06-28T19:29:15.408Z","message":{"role":"toolResult","toolCallId":"call_00_fD4OYtwEmAJW9ZSEmiVM1849","toolName":"read","content":[{"type":"text","text":"            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('speedProgress').style.display = 'block';\r\n            document.getElementById('speedResultArea').innerHTML = '';\r\n            addLog('info', '速度测试开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '速度测试完成');\r\n                    addLog('success', '速度测试完成: ' + (resp.message || ''));\r\n                    renderSpeedResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '速度测试失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('speedResultArea').innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#f85149\">❌ ' + (resp ? resp.message : '测试失败') + '</p></div>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始测试';\r\n                document.getElementById('speedProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // Progress bar: real status (no hardcoded speed labels)\r\n            var speedProgText = document.getElementById('speedProgressText');\r\n            var speedProgBar = document.getElementById('speedProgressBar');\r\n            if (speedProgText) speedProgText.textContent = '测试中... 等待设备响应';\r\n            if (speedProgBar) speedProgBar.style.width = '30%';\r\n            // REMOVED simulateProgress (was hardcoded: '速度档位 1', '50', '100')\r\n            // Speed results now display actual values returned from backend\r\n        }\r\n        function _renderSpeedTable(title, speedMap) {\r\n            var keys = Object.keys(speedMap);\r\n            if (keys.length === 0) return '';\r\n            var h = '<div style=\"margin-bottom:12px\"><strong style=\"color:#e0e6f0;font-size:13px\">' + title + '</strong>';\r\n            h += '<table class=\"result-table\" style=\"margin:6px 0\"><thead><tr><th>速度档位</th><th>实际速率 (°/s)</th></tr></thead><tbody>';\r\n            keys.forEach(function(k) {\r\n                h += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\r\n            });\r\n            h += '</tbody></table></div>';\r\n            return h;\r\n        }\r\n        function renderSpeedResults(results) {\r\n            var area = document.getElementById('speedResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>速度测试结果</h4>';\r\n            // 按Zoom分组交叉表\r\n            var byZoom = results.by_zoom || {};\r\n            if (byZoom && Object.keys(byZoom).length > 0) {\r\n                html += _renderSpeedByZoom(byZoom);\r\n            }\r\n            // 总体 + Pan/Tilt汇总\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            html += _renderSpeedTable('📊 总体', speedMap);\r\n            var panMap = results.pan_speed || {};\r\n            html += _renderSpeedTable('🔵 Pan轴', panMap);\r\n            var tiltMap = results.tilt_speed || {};\r\n            html += _renderSpeedTable('🟠 Tilt轴', tiltMap);\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">测试总数</span><span class=\"status-value\">' + (results.total_tests || '--') + '</span></div>';\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        function _renderSpeedByZoom(byZoom) {\r\n            // byZoom: {zoom_val: {pan: {speed: val}, tilt: {speed: val}}}\r\n            var zooms = Object.keys(byZoom).sort(function(a,b){return parseInt(a)-parseInt(b)});\r\n            if (zooms.length === 0) return '';\r\n            // 收集所有速度档位\r\n\n[2278 more lines in file. Use offset=982 to continue.]"}],"isError":false,"timestamp":1782674955408}}
