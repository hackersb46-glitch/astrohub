{"type":"message","id":"275162cf","parentId":"86e41b81","timestamp":"2026-06-28T10:35:50.081Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to see the full set_preset method in ptz.py, the full modal CSS and HTML, and the quickAddModal and confirmRestart implementations.","thinkingSignature":"reasoning_content"},{"type":"text","text":"...\n\n"},{"type":"toolCall","id":"call_e5jdnln2sklmfdt0q3a2x93q","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\ptz\\isapi\\ptz.py","offset":125,"limit":80}},{"type":"toolCall","id":"call_016r3v5c7jn31zbnzlrj7xlf","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html","offset":140,"limit":80}},{"type":"toolCall","id":"call_ao43ve8u2ddbpz1kzeah5q51","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html","offset":330,"limit":120}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":24368,"output":308,"cacheRead":0,"cacheWrite":0,"totalTokens":24676,"cost":{"input":0.024367999999999997,"output":0.0009856,"cacheRead":0,"cacheWrite":0,"total":0.025353599999999997}},"stopReason":"toolUse","timestamp":1782642940964,"responseId":"cht000da04b@dx19f0dcc9e72b894652"}}
{"type":"message","id":"4da8ee97","parentId":"275162cf","timestamp":"2026-06-28T10:35:50.091Z","message":{"role":"toolResult","toolCallId":"call_e5jdnln2sklmfdt0q3a2x93q","toolName":"read","content":[{"type":"text","text":"            LOG.log(\"done\", f\"获取预置点列表: {len(presets)} 个\")\r\n            return presets\r\n        except Exception as e:\r\n            LOG.log(\"error\", f\"获取预置点列表异常: {e}\")\r\n            return []\r\n\r\n    def set_preset(self, preset_id: int, pan: int = None, tilt: int = None, zoom: int = None, name: str = \"\") -> bool:\r\n        \"\"\"设置预置点。统一使用 PTZPreset XML。\r\n\r\n        两种模式:\r\n        - 无坐标: set_preset(10, name=\"HOME\") → 设置当前位置为预置点\r\n        - 有坐标: set_preset(10, pan=1800, tilt=450, zoom=10, name=\"HOME\")\r\n\r\n        参数:\r\n            preset_id: 预置点编号 (1-300)\r\n            pan: 方位角 (可选，不传则设置当前位置)\r\n            tilt: 仰角 (可选)\r\n            zoom: 变倍 (可选)\r\n            name: 预置点名称 (可选)\r\n\r\n        返回:\r\n            True = 成功\r\n        \"\"\"\r\n        if pan is not None and tilt is not None:\r\n            # 模式1: 指定坐标\r\n            z = zoom if zoom is not None else 10\r\n            xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZPreset>\r\n<id>{preset_id}</id>\r\n<presetName>{name}</presetName>\r\n<AbsoluteHigh>\r\n<elevation>{tilt}</elevation>\r\n<azimuth>{pan}</azimuth>\r\n<absoluteZoom>{z}</absoluteZoom>\r\n</AbsoluteHigh>\r\n</PTZPreset>\"\"\"\r\n            LOG.log(\"info\", f\"ISAPI 设置预置点: {preset_id} name={name or '(无)'} pan={pan}\")\r\n        else:\r\n            # 模式2: 设置当前位置\r\n            xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZPreset>\r\n<id>{preset_id}</id>\r\n<presetName>{name}</presetName>\r\n</PTZPreset>\"\"\"\r\n            LOG.log(\"info\", f\"ISAPI 设置预置点: {preset_id} name={name or '(无)'} (当前位置)\")\r\n\r\n        result = self.client.put(f\"{self._ptz_base()}/presets/{preset_id}\", xml)\r\n        if result.status_code == 200:\r\n            LOG.log(\"done\", f\"预置点 {preset_id} 设置成功\")\r\n            return True\r\n        else:\r\n            LOG.log(\"error\", f\"预置点 {preset_id} 设置失败: HTTP {result.status_code}\")\r\n            return False\r\n\r\n    def goto_home(self) -> bool:\r\n        \"\"\"Move to HOME preset 10.\"\"\"\r\n        if not self.goto_preset(self.home_preset):\r\n            LOG.log(\"error\", \"goto_home: failed to goto preset\")\r\n            return False\r\n        LOG.log(\"done\", \"goto_home: preset 10 sent\")\r\n        return True\r\n\r\n    def setup_home_preset(self) -> bool:\r\n        \"\"\"绝对值移动到(1800,450,10)并设预置10为HOME，10s超时。\r\n\r\n        统一方法 —— 所有调用方通过此方法设置HOME。\r\n        步骤: absolute_move → 等到位 → set_preset(10, name=\"HOME\") 用当前位置。\r\n        \"\"\"\r\n        import time\r\n        self.absolute_move(1800, 450, 10)\r\n        deadline = time.time() + 10\r\n        while time.time() < deadline:\r\n            pos = self.get_position()\r\n            if pos and pos.get(\"pan\") == 1800 and pos.get(\"tilt\") == 450 and pos.get(\"zoom\") == 10:\r\n                if self.set_preset(10, name=\"HOME\"):\r\n                    return True\r\n            time.sleep(0.1)\r\n        return False\r\n\r\n    def goto_home_and_wait(self, samples: int = 20, interval: float = 0.1, max_wait: float = 30.0) -> bool:\r\n\n[477 more lines in file. Use offset=205 to continue.]"}],"isError":false,"timestamp":1782642950091}}
{"type":"message","id":"c8e2ddd2","parentId":"4da8ee97","timestamp":"2026-06-28T10:35:50.091Z","message":{"role":"toolResult","toolCallId":"call_016r3v5c7jn31zbnzlrj7xlf","toolName":"read","content":[{"type":"text","text":"        .log-entry.info { border-color:#58a6ff; }\r\n        .log-entry.warn { border-color:#d29922; }\r\n        .log-entry.error { border-color:#f85149; }\r\n        .log-entry.success { border-color:#3fb950; }\r\n        /* Toast notification */\r\n        .toast-container { position:fixed; top:60px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; }\r\n        .toast { padding:12px 20px; border-radius:8px; font-size:14px; animation:slideIn 0.3s ease; min-width:250px; max-width:400px; }\r\n        .toast.success { background:#1a4731; border:1px solid #3fb950; color:#3fb950; }\r\n        .toast.error { background:#4d1c1a; border:1px solid #f85149; color:#f85149; }\r\n        .toast.info { background:#1a3a52; border:1px solid #58a6ff; color:#58a6ff; }\r\n        .toast.warning { background:#4a3a1a; border:1px solid #d29922; color:#d29922; }\r\n        @keyframes slideIn { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }\r\n        /* Modal */\r\n        .modal-backdrop { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9000; display:flex; align-items:center; justify-content:center; }\r\n        .modal { background:#161b22; border:1px solid #30363d; border-radius:12px; padding:24px; width:400px; max-width:90vw; }\r\n        .modal h3 { margin-bottom:16px; font-size:18px; }\r\n        .modal .btn-group { justify-content:flex-end; margin-top:20px; }\r\n        /* Loading spinner */\r\n        .spinner { display:inline-block; width:16px; height:16px; border:2px solid #30363d; border-top-color:#58a6ff; border-radius:50%; animation:spin 0.8s linear infinite; }\r\n        @keyframes spin { to { transform:rotate(360deg); } }\r\n        .loading { pointer-events:none; opacity:0.7; }\r\n        /* Device actions */\r\n        .actions { display:flex; gap:4px; flex-wrap:wrap; }\r\n        /* PTZ status panel */\r\n        .ptz-position { text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0; font-family:monospace; font-size:14px; }\r\n        .toolbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap; }\r\n        .toolbar-actions { display:flex; gap:8px; }\r\n        .device-info-panel { background:#0d1117; border-radius:8px; padding:16px; margin-top:12px; font-size:13px; }\r\n        .device-info-panel .info-row { display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid #21262d; }\r\n        .device-info-panel .info-row:last-child { border-bottom:none; }\r\n        .device-info-panel .info-label { color:#8b949e; }\r\n        .device-info-panel .info-value { color:#e0e6f0; font-family:monospace; }\r\n        @media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-center, .console-right { width:100% !important; } }\r\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\r\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\r\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; min-width:0; overflow:hidden; }\r\n        .console-center { flex:1; min-width:0; display:flex; flex-direction:column; }\r\n        .console-right { flex:0 0 25%; max-width:300px; display:flex; flex-direction:column; }\r\n        /* WASM 播放器容器: 强制子元素填满, 保持 16:9 */\r\n        #divPlugin { width:100%; aspect-ratio:16/9; display:block; overflow:hidden; }\r\n        #divPlugin .parent-wnd { width:100% !important; height:100% !important; }\r\n        #divPlugin .parent-wnd > div { width:100% !important; height:100% !important; border:none !important; }\r\n        #divPlugin .video-container { width:100% !important; height:100% !important; }\r\n        #divPlugin canvas.play-window { width:100% !important; height:100% !important; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"header\">\r\n        <div class=\"logo\">Astro<span>Hub</span></div>\r\n        <div class=\"status-bar\">\r\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wsDot\"></span><span id=\"wsStatus\">ISAPI: 未连接</span></div>\r\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"mediaInputDot\"></span><span id=\"mediaInputStatus\">媒体输入: 等待连接</span></div>\r\n            <div class=\"status-item\"><span class=\"status-dot\" id=\"mediaOutputDot\" style=\"background:#30363d;box-shadow:none\"></span><span id=\"mediaOutputStatus\">未录制</span></div>\r\n            <div class=\"status-item\" id=\"clock\"></div>\r\n            <!-- 快速连接开关 -->\r\n            <div class=\"status-item\">\r\n                <span style=\"color:#8b949e;font-size:12px\">快速连接</span>\r\n                <label class=\"switch\">\r\n                    <input type=\"checkbox\" id=\"quickConnectSwitch\" onchange=\"quickConnect(this.checked)\">\r\n                    <span class=\"slider\"></span>\r\n                </label>\r\n            </div>\r\n            <!-- 重启按钮 -->\r\n            <button class=\"btn btn-secondary btn-sm\" onclick=\"confirmRestart()\" style=\"padding:2px 8px\">重启</button>\r\n            <span class=\"version\" id=\"version-display\">...</span>\r\n        </div>\r\n    </div>\r\n    <div class=\"nav\">\r\n        <button class=\"nav-btn active\" data-page=\"dashboard\">仪表盘</button>\r\n        <button class=\"nav-btn\" data-page=\"devices\">设备管理</button>\r\n        <button class=\"nav-btn\" data-page=\"console\">主控台</button>\r\n        <button class=\"nav-btn\" data-page=\"observation\">观测计划</button>\r\n        <!-- Advanced Features: 校准 功能测试 限位测试 速度测试 推流/存储 -->\r\n        <button class=\"nav-btn\" data-page=\"advanced\">高级功能</button>\r\n        <button class=\"nav-btn\" data-page=\"replay\">回放</button>\r\n        <button class=\"nav-btn\" data-page=\"settings\">设置</button>\r\n    </div>\r\n    <div class=\"main\">\r\n        <!-- ==================== 仪表盘 ==================== -->\r\n\r\n\n[2887 more lines in file. Use offset=220 to continue.]"}],"isError":false,"timestamp":1782642950091}}
{"type":"message","id":"d4416c22","parentId":"c8e2ddd2","timestamp":"2026-06-28T10:35:50.092Z","message":{"role":"toolResult","toolCallId":"call_ao43ve8u2ddbpz1kzeah5q51","toolName":"read","content":[{"type":"text","text":"                        </div>\r\n                        <div style=\"margin-top:12px\">\r\n                            <span id=\"extSaveStatus\" style=\"font-size:13px;color:#3fb950\"></span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <!-- Toast 容器 -->\r\n    <div class=\"toast-container\" id=\"toastContainer\"></div>\r\n    <!-- Modal 容器 -->\r\n    <div id=\"modalContainer\"></div>\r\n    <script>\r\n        console.log(\"[MAIN SCRIPT] Starting script execution\");\r\n        var _loginInProgress = false;  // v7.69: 防止并发登录\r\n// Global functions\r\n    (function() {\r\n        'use strict';\r\n        // ================================================================\r\n        //  Configuration\r\n        // ================================================================\r\n        var API_BASE = window.location.origin;\r\n        var WS_URL = (window.location.protocol === 'https:' ? 'wss' : 'ws') + '://' + window.location.host + '/ws';\r\n        // Cached device data\r\n        var allDevices = [];\r\n        var currentModal = null;\r\n        // --- v3: Global connected device state ---\r\n        // Advanced menu state (now sidebar)\r\n        var advMenuActive = false;\r\n        var advCurrentSub = 'calibration';\r\n        // Onboarding wizard state\r\n        var wizardState = {\r\n            step: 0,\r\n            totalSteps: 5,\r\n            mac: '',\r\n            deviceIP: '',\r\n            runningTest: false,\r\n            testResults: { function: null, limit: null, speed: null }\r\n        };\r\n        // ================================================================\r\n        //  Initialization\r\n        // ================================================================\r\n        function init() {\r\n            console.log('[INIT] init() called');\r\n            updateClock();\r\n            setInterval(updateClock, 1000);\r\n            initNav();\r\n            initPtzSpeed();\r\n            initMouseUp();\r\n            refreshDevices();\r\n            // v6.0: 从后端获取连接状态\r\n            restoreConnectionState();\r\n            addLog('info', 'AstroHub 已启动');\r\n            connectWS();\r\n            loadLocalhostInfo();\r\n        }\r\n        \r\n        // v7.15: 加载本机信息\r\n        function loadLocalhostInfo() {\r\n            apiGet('/api/v1/localhost').then(function(result) {\r\n                if (result.success && result.data) {\r\n                    var info = result.data;\r\n                    document.getElementById('localhost-hostname').textContent = info.hostname || '-';\r\n                    document.getElementById('localhost-cpu').textContent = info.cpu_model || '-';\r\n                    document.getElementById('localhost-ram').textContent = info.ram_gb ? info.ram_gb + ' GB' : '-';\r\n                    var gpu = (info.gpu_names || []).join(', ') || '-';\r\n                    if (info.vram_gb > 0) gpu += ' (' + info.vram_gb + 'GB)';\r\n                    document.getElementById('localhost-gpu').textContent = gpu;\r\n                    document.getElementById('localhost-ip').textContent = info.local_ip || '-';\r\n                    document.getElementById('localhost-gateway').textContent = info.gateway || '-';\r\n                    window.localhostGateway = info.gateway; // 保存网关供后续使用\r\n                    document.getElementById('localhostCard').style.display = 'block';\r\n                    \r\n                    // v7.15: 首次运行，显示提示并重启\r\n                    if (result.first_run) {\r\n                        showStartupProgress();\r\n                    }\r\n                }\r\n            }).catch(function(e) { console.warn('加载本机信息失败:', e); });\r\n        }\r\n        // v7.15: 显示启动进度条\r\n        \r\n        // v7.15: 网页级别弹窗\r\n        window.showAlert = function(message, title) {\r\n            var alertHtml = '<div id=\"alertModal\" class=\"modal-overlay\" onclick=\"closeAlert()\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:10000\">' +\r\n                '<div onclick=\"event.stopPropagation()\" style=\"background:#1a1e2e;padding:24px;border-radius:12px;min-width:300px;max-width:500px;box-shadow:0 4px 20px rgba(0,0,0,0.5)\">' +\r\n                '<h3 style=\"margin:0 0 16px 0;color:#f0883e\">' + (title || '提示') + '</h3>' +\r\n                '<p style=\"margin:0 0 20px 0;color:#e0e6f0;line-height:1.6\">' + message + '</p>' +\r\n                '<button class=\"btn btn-primary\" onclick=\"closeAlert()\" style=\"width:100%\">确定</button></div></div>';\r\n            document.body.insertAdjacentHTML('beforeend', alertHtml);\r\n        };\r\n        window.closeAlert = function() {\r\n            var modal = document.getElementById('alertModal');\r\n            if (modal) modal.remove();\r\n        };\r\n        window.showConfirm = function(message, onConfirm, title) {\r\n            var confirmHtml = '<div id=\"confirmModal\" class=\"modal-overlay\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:10000\">' +\r\n                '<div onclick=\"event.stopPropagation()\" style=\"background:#1a1e2e;padding:24px;border-radius:12px;min-width:300px;max-width:500px;box-shadow:0 4px 20px rgba(0,0,0,0.5)\">' +\r\n                '<h3 style=\"margin:0 0 16px 0;color:#58a6ff\">' + (title || '确认') + '</h3>' +\r\n                '<p style=\"margin:0 0 20px 0;color:#e0e6f0;line-height:1.6\">' + message + '</p>' +\r\n                '<div style=\"display:flex;gap:12px;justify-content:flex-end\">' +\r\n                '<button class=\"btn btn-secondary\" onclick=\"closeConfirm(false)\">取消</button>' +\r\n                '<button class=\"btn btn-primary\" onclick=\"closeConfirm(true)\">确定</button></div></div></div>';\r\n            window._confirmCallback = onConfirm;\r\n            document.body.insertAdjacentHTML('beforeend', confirmHtml);\r\n        };\r\n        window.closeConfirm = function(result) {\r\n            var modal = document.getElementById('confirmModal');\r\n            if (modal) modal.remove();\r\n            if (result && window._confirmCallback) {\r\n                window._confirmCallback();\r\n                window._confirmCallback = null;\r\n            }\r\n        };\r\n        \r\nfunction showStartupProgress() {\r\n            var progressHtml = '<div id=\"startupOverlay\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.9);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:99999\">' +\r\n                '<div style=\"text-align:center;color:#e0e6f0\">' +\r\n                '<div style=\"font-size:24px;margin-bottom:20px\">🚀 首次运行，正在收集本机信息...</div>' +\r\n\n[2657 more lines in file. Use offset=450 to continue.]"}],"isError":false,"timestamp":1782642950091}}
