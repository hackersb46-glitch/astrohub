{"type":"message","id":"153857ba","parentId":"12e82e89","timestamp":"2026-06-29T05:29:29.095Z","message":{"role":"toolResult","toolCallId":"call_m0zx6svtwa2bk6ors1r766i7","toolName":"read","content":[{"type":"text","text":"            // REMOVED simulateProgress (was hardcoded: '速度档位 1', '50', '100')\r\n            // Speed results now display actual values returned from backend\r\n        }\r\n        function _renderSpeedTable(title, speedMap) {\r\n            var keys = Object.keys(speedMap);\r\n            if (keys.length === 0) return '';\r\n            var h = '<div style=\"margin-bottom:12px\"><strong style=\"color:#e0e6f0;font-size:13px\">' + title + '</strong>';\r\n            h += '<table class=\"result-table\" style=\"margin:6px 0\"><thead><tr><th>速度档位</th><th>实际速率 (°/s)</th></tr></thead><tbody>';\r\n            keys.forEach(function(k) {\r\n                h += '<tr><td>' + k + '</td><td>' + speedMap[k] + '</td></tr>';\r\n            });\r\n            h += '</tbody></table></div>';\r\n            return h;\r\n        }\r\n        function renderSpeedResults(results) {\r\n            var area = document.getElementById('speedResultArea');\r\n            if (!results || Object.keys(results).length === 0) {\r\n                area.innerHTML = '<div class=\"advanced-status-panel\"><p style=\"color:#6e7681\">暂无结果</p></div>';\r\n                return;\r\n            }\r\n            var html = '<div class=\"advanced-status-panel\"><h4>速度测试结果</h4>';\r\n            // 按Zoom分组交叉表\r\n            var byZoom = results.by_zoom || {};\r\n            if (byZoom && Object.keys(byZoom).length > 0) {\r\n                html += _renderSpeedByZoom(byZoom);\r\n            }\r\n            // 总体 + Pan/Tilt汇总\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            html += _renderSpeedTable('📊 总体', speedMap);\r\n            var panMap = results.pan_speed || {};\r\n            html += _renderSpeedTable('🔵 Pan轴', panMap);\r\n            var tiltMap = results.tilt_speed || {};\r\n            html += _renderSpeedTable('🟠 Tilt轴', tiltMap);\r\n            html += '<div class=\"status-row\"><span class=\"status-label\">测试总数</span><span class=\"status-value\">' + (results.total_tests || '--') + '</span></div>';\r\n            html += '</div>';\r\n            area.innerHTML = html;\r\n        }\r\n        function _renderSpeedByZoom(byZoom) {\r\n            // byZoom: {zoom_val: {pan: {speed: val}, tilt: {speed: val}}}\r\n            var zooms = Object.keys(byZoom).sort(function(a,b){return parseInt(a)-parseInt(b)});\r\n            if (zooms.length === 0) return '';\r\n            // 收集所有速度档位\r\n            var allSpeeds = {};\r\n            zooms.forEach(function(z) {\r\n                var zd = byZoom[z];\r\n                ['pan','tilt'].forEach(function(ax) {\r\n                    var am = zd[ax] || {};\r\n                    Object.keys(am).forEach(function(s) { allSpeeds[s] = true; });\r\n                });\r\n            });\r\n            var speedLevels = Object.keys(allSpeeds).sort(function(a,b){return parseInt(a)-parseInt(b)});\r\n            if (speedLevels.length === 0) return '';\r\n            var h = '<div style=\"margin-bottom:12px\"><strong style=\"color:#e0e6f0;font-size:13px\">📐 按Zoom分组</strong>';\r\n            h += '<table class=\"result-table\" style=\"margin:6px 0;font-size:11px\"><thead><tr><th>档位</th>';\r\n            zooms.forEach(function(z) {\r\n                h += '<th style=\"text-align:center\">Z=' + z + '<br>Pan</th><th style=\"text-align:center\">Z=' + z + '<br>Tilt</th>';\r\n            });\r\n            h += '</tr></thead><tbody>';\r\n            speedLevels.forEach(function(sl) {\r\n                h += '<tr><td>' + sl + '</td>';\r\n                zooms.forEach(function(z) {\r\n                    var zd = byZoom[z];\r\n                    var pv = zd.pan && zd.pan[sl] != null ? zd.pan[sl] : '--';\r\n                    var tv = zd.tilt && zd.tilt[sl] != null ? zd.tilt[sl] : '--';\r\n                    h += '<td style=\"text-align:center\">' + pv + '</td><td style=\"text-align:center\">' + tv + '</td>';\r\n                });\r\n                h += '</tr>';\r\n            });\r\n            h += '</tbody></table></div>';\r\n            return h;\r\n        }\r\n        // ================================================================\r\n        //  Progress Simulation\r\n        // ================================================================\r\n        function simulateProgress(textId, barId, totalSteps, labels) {\r\n            var current = 0;\r\n            var interval = setInterval(function() {\r\n                current++;\r\n                if (current > totalSteps) { clearInterval(interval); return; }\r\n                var pct = Math.round((current / totalSteps) * 100);\r\n                var textEl = document.getElementById(textId);\r\n                var barEl = document.getElementById(barId);\r\n                if (textEl) textEl.textContent = labels ? labels[current-1] : '处理中... ' + current + '/' + totalSteps;\r\n                if (barEl) barEl.style.width = pct + '%';\r\n            }, 2000);\r\n        }\r\n        function simulateDirections() {\r\n            var dirs = ['P+ 移动中...', 'P- 移动中...', 'T+ 移动中...', 'T- 移动中...'];\r\n            var i = 0;\r\n            var interval = setInterval(function() {\r\n\n[2230 more lines in file. Use offset=1030 to continue.]"}],"isError":false,"timestamp":1782710969095}}
