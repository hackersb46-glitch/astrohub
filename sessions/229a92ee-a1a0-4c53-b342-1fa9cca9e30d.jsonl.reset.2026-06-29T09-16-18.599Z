{"type":"message","id":"8e286400","parentId":"c5845c4e","timestamp":"2026-06-28T10:38:21.241Z","message":{"role":"toolResult","toolCallId":"call_f6dsp60zfz3w9db9uj52l0r7","toolName":"read","content":[{"type":"text","text":"            console.log('[WASM] No device info, skip WASM login');\r\n            return;\r\n        }\r\n        \r\n        // 如果 SDK 已就绪，立即登录\r\n        if (WasmPlayer && WasmPlayer.sdkReady) {\r\n            var ip = window.connectedDevice.ip;\r\n            var port = window.connectedDevice.port || 80;\r\n            var username = window.connectedDevice.username || 'admin';\r\n            var password = window.connectedDevice.password || '';\r\n            \r\n            wasmLogin(ip, port, username, password).then(function(result) {\r\n                console.log('[WASM] Login result:', result);\r\n                // v7.111: 登录后自动播放（如果在主控台页面）\r\n                var activePage = document.querySelector('.page.active');\r\n                if (activePage && activePage.id === 'page-console') {\r\n                    var channel = WasmPlayer.channel || 1;\r\n                    var streamType = window._currentStreamType || 3;\r\n                    wasmStartRealPlay(channel, streamType, true);\r\n                }\r\n            }).catch(function(err) {\r\n                console.error('[WASM] Login failed:', err);\r\n            });\r\n        }\r\n        // 如果 SDK 未就绪，等待 wasm:ready 事件触发自动登录\r\n    }\r\n\r\n    // 设备断开后 - WASM 同步登出\r\n    function onDeviceDisconnected() {\r\n        if (typeof wasmStopRealPlay === 'function') wasmStopRealPlay();\r\n        if (typeof wasmLogout === 'function') wasmLogout();\r\n        // v7.111: 断开后重置码流按钮状态\r\n        setTimeout(updateStreamButtons, 500);\r\n    }\r\n\r\n    // 主控台按钮接口 - 开始预览\r\n    function doStartRealPlay() {\r\n        var channel = WasmPlayer.channel || 1;\r\n        var streamType = window._currentStreamType || 2;\r\n        wasmStartRealPlay(channel, streamType, true);\r\n    }\r\n\r\n    // 主控台按钮接口 - 停止预览\r\n    function doStopPreview() {\r\n        wasmStopRealPlay();\r\n        setTimeout(updateStreamButtons, 500);  // 等待状态更新\r\n    }\r\n\r\n    // 码流切换+预览（运动控制区码流按钮）\r\n    window._currentStreamType = 3;  // 默认第三码流\r\n    window._isRecording = false;\r\n\r\n    function switchAndPlay(streamType) {\r\n        window._currentStreamType = streamType;\r\n        updateStreamButtons();\r\n        var channel = WasmPlayer.channel || 1;\r\n        wasmStartRealPlay(channel, streamType, true).then(function() {\r\n            var streamNames = {1: '主码流', 2: '子码流', 3: '第三码流'};\r\n            var timeStr = new Date().toLocaleTimeString('en-US', { hour12: false });\r\n            if (typeof mediaLog === 'function') mediaLog(timeStr + ' 切换' + (streamNames[streamType] || '码流'), 'info');\r\n            if (typeof updateMediaInputStatus === 'function') updateMediaInputStatus('playing');\r\n        }).catch(function(e) {\r\n            console.error('[SWITCH] Failed:', e);\r\n        });\r\n    }\r\n\r\n    // 更新码流按钮状态：播放中=对应码流亮，停止=停止亮\r\n    function updateStreamButtons() {\r\n        var isPlaying = WasmPlayer && WasmPlayer.playing;\r\n        ['btnStreamMain','btnStreamSub','btnStreamThird','btnStreamStop'].forEach(function(id) {\r\n            var b = document.getElementById(id);\r\n            if (b) { b.classList.remove('btn-success'); b.classList.add('btn-primary'); }\r\n        });\r\n        if (isPlaying) {\r\n            var st = window._currentStreamType;\r\n            var activeId = st === 1 ? 'btnStreamMain' : st === 2 ? 'btnStreamSub' : 'btnStreamThird';\r\n            var activeBtn = document.getElementById(activeId);\r\n            if (activeBtn) { activeBtn.classList.remove('btn-primary'); activeBtn.classList.add('btn-success'); }\r\n        } else {\r\n            var stopBtn = document.getElementById('btnStreamStop');\r\n            if (stopBtn) { stopBtn.classList.remove('btn-primary'); stopBtn.classList.add('btn-success'); }\r\n        }\r\n    }\r\n\r\n    // 录像开关式按钮\r\n    function toggleRecord() {\r\n        if (!window._isRecording) {\r\n            // 立即更新状态，防止重复点击\r\n            updateRecordToggleUI(true);\r\n            var statusEl = document.getElementById('consoleRecordStatus');\r\n            if (statusEl) statusEl.textContent = '录像中';\r\n            consoleRecordStart();\r\n        } else {\r\n            // v7.111: 立即重置UI状态，不等WASM回调\r\n            updateRecordToggleUI(false);\r\n            if (typeof updateMediaOutputStatus === 'function') updateMediaOutputStatus('idle');\r\n            var statusEl = document.getElementById('consoleRecordStatus');\r\n            if (statusEl) statusEl.textContent = '未录像';\r\n            consoleRecordStop();\r\n        }\r\n\n[157 more lines in file. Use offset=2950 to continue.]"}],"isError":false,"timestamp":1782643101241}}
