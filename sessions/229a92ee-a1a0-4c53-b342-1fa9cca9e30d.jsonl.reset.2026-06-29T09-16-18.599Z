n(results),\r\n            }\r\n\r\n        return {\r\n            \"success\": success,\r\n            \"message\": f\"速度测试完成: {req.device_ip}\",\r\n            \"results\": formatted,\r\n            \"config_saved\": config_saved,\r\n            \"mac\": mac,\r\n\n[1392 more lines in file. Use offset=2678 to continue.]"}],"isError":false,"timestamp":1782664552207}}
