      method: 'POST',\r\n        headers: {'Content-Type': 'application/json'},\r\n        body: JSON.stringify({\r\n            device_ip: deviceIp,\r\n            username: username,\r\n            password: password,\r\n            items: detectItems,\r\n            speed_profile: requestBody.speed_profile || 'lite'\r\n        })\r\n    })\r\n    .then(r => r.json())\r\n    .then(data => {\r\n        if (data.success && data.task_id) {\r\n            addAdvOutput('info', '任务已启动: ' + data.task_id.substring(0,8));\r\n            pollAdvProgress(data.task_id);\r\n        } else {\r\n            btnRun.disabled = false;\r\n            btnStop.disabled = true;\r\n            addAdvOutput('error', data.message || '启动失败');\r\n            if (progressEl) progressEl.textContent = currentAdvTest + ' 失败';\r\n        }\r\n    })\r\n    .catch(e => {\r\n        btnRun.disabled = false;\r\n        btnStop.disabled = true;\r\n        addAdvOutput('error', '请求异常: ' + e.message);\r\n    });\r\n}\r\n\r\nfunction stopAdvTest() {\r\n    addAdvOutput('warn', '停止测试');\r\n    // v7.112: 清除轮询 + 调后端取消\r\n    if (advPollInterval) { clearInterval(advPollInterval); advPollInterval = null; }\r\n    if (advTaskId) {\r\n        fetch('/api/v1/advanced/detect/cancel/' + advTaskId, { method: 'POST' })\r\n        .then(r => r.json())\r\n        .then(d => { if (d.success) addAdvOutput('warn', '任务已取消: ' + advTaskId.substring(0,8)); })\r\n        .catch(function () {});\r\n        advTaskId = null;\r\n    }\r\n    var progressEl = document.getElementById('advProgress');\r\n    if (progressEl) progressEl.textContent = '';\r\n    document.getElementById('btnAdvRun').disabled = false;\r\n    document.getElementById('btnAdvStop').disabled = true;\r\n    // v7.54: 恢复其他页面标签\r\n    document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n\n[502 more lines in file. Use offset=360 to continue.]"}],"isError":false,"timestamp":1782675022584}}
