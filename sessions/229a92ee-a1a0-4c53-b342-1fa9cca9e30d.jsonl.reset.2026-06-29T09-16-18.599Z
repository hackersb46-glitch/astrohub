{"type":"message","id":"9b55b9c8","parentId":"20879de7","timestamp":"2026-06-28T10:55:02.999Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to:\n1. Replace the quickAddModal with the unified showModal\n2. Replace confirmRestart's `confirm()` with showModal\n3. Replace resetImageControls' `confirm()` with showModal\n4. Add the preset write modal\n\nLet me read the quickAddModal section and confirmRestart section again to replace them.","thinkingSignature":"reasoning_content"},{"type":"text","text":"Now replace quickAddModal:\n\n"},{"type":"toolCall","id":"call_aez99jzfrdyio5vshzdja9x8","name":"read","arguments":{"limit":80,"offset":1518,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":81272,"output":177,"cacheRead":0,"cacheWrite":0,"totalTokens":81449,"cost":{"input":0.081272,"output":0.0005664,"cacheRead":0,"cacheWrite":0,"total":0.08183839999999999}},"stopReason":"toolUse","timestamp":1782644090944,"responseId":"cht000d7b53@dx19f0dde3c7bb91a122"}}
{"type":"message","id":"86629794","parentId":"9b55b9c8","timestamp":"2026-06-28T10:55:03.004Z","message":{"role":"toolResult","toolCallId":"call_aez99jzfrdyio5vshzdja9x8","toolName":"read","content":[{"type":"text","text":"                var onlineBadge = d.online\r\n                    ? '<span class=\"badge online\">在线</span>'\r\n                    : '<span class=\"badge offline\">离线</span>';\r\n                var actions = buildDeviceActions(d);\r\n                return '<tr>'\r\n                    + '<td>' + sourceBadge + '</td>'\r\n                    + '<td>' + (d.mac || '--') + '</td>'\r\n                    + '<td>' + (d.ip || '--') + '</td>'\r\n                    + '<td>' + (d.gateway || '--') + '</td>'\r\n                    + '<td>' + (d.name || d.device_name || '--') + '</td>'\r\n                    + '<td>' + (d.model || '--') + '</td>'\r\n                    + '<td>' + onlineBadge + '</td>'\r\n                    + '<td>' + actions + '</td>'\r\n                    + '</tr>';\r\n            }).join('');\r\n            tb.innerHTML = html;\r\n        }\r\n        function buildDeviceActions(d) {\r\n            var btns = [];\r\n            var isConnected = window.connectedDevice && window.connectedDevice.ip === d.ip;\r\n            // v6.35: 连接开关(只有一个设备可连接)\r\n            var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\r\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\'' + d.ip + '\\', this.checked, \\'' + (d.gateway || '') + '\\')\" /><span class=\"slider\"></span></label>';\r\n            btns.push(switchHtml);\r\n            // v6.35: 信息按钮(弹窗显示设备详情)\r\n            btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoModal(\\'' + d.ip + '\\')\">信息</button>');\r\n            // Add modify IP button for all devices\r\n            // v7.15: 添加/删除按钮交互式\r\n            var isAdded = d.source === 'manual' || d.has_credentials;\r\n            if (isAdded) {\r\n                btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\')\">删除</button>');\r\n            } else {\r\n                btns.push('<button class=\"btn btn-primary btn-sm\" onclick=\"quickAddDevice(\\'' + d.ip + '\\', \\'' + (d.gateway || '') + '\\')\">添加</button>');\r\n            }\r\n            return '<div class=\"actions\" style=\"display:flex;align-items:center;gap:8px\">' + btns.join('') + '</div>';\r\n        }\r\n        // v6.35: 切换设备连接状态\r\n        window.toggleDeviceConnect = function(ip, checked, gateway) {\r\n            if (checked) {\r\n                var d = allDevices.find(function(dev) { return dev.ip === ip; });\r\n                if (d && d.has_credentials) {\r\n                    connectDevice(ip);\r\n                } else {\r\n                    showQuickAddModal(ip, gateway);\r\n                }\r\n            } else {\r\n                disconnectDevice(ip);\r\n            }\r\n        };\r\n        // v7.15: 快速添加设备\r\n        window.quickAddDevice = function(ip, gateway) {\r\n            showQuickAddModal(ip, gateway);\r\n        };\r\n        // v7.15: 显示快速添加设备模态框\r\n        window.showQuickAddModal = function(ip, gateway) {\r\n            var localhostGateway = window.localhostGateway || gateway || '';\r\n            var modalHtml = '<div id=\"quickAddModal\" class=\"modal-overlay\" onclick=\"closeQuickAddModal(event)\" style=\"position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:10000\">' +\r\n                '<div class=\"modal-content\" onclick=\"event.stopPropagation()\" style=\"background:#1a1e2e;padding:24px;border-radius:12px;min-width:360px;box-shadow:0 4px 20px rgba(0,0,0,0.5)\">' +\r\n                '<h3 style=\"margin:0 0 20px 0;color:#58a6ff;font-size:18px\">添加设备</h3>' +\r\n                '<div style=\"margin-bottom:16px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">IP 地址</label>' +\r\n                '<input type=\"text\" id=\"quickAddIp\" value=\"' + (ip || '') + '\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\r\n                '<div style=\"margin-bottom:16px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">网关</label>' +\r\n                '<input type=\"text\" id=\"quickAddGateway\" value=\"' + localhostGateway + '\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\r\n                '<div style=\"margin-bottom:16px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">用户名</label>' +\r\n                '<input type=\"text\" id=\"quickAddUser\" value=\"admin\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\r\n                '<div style=\"margin-bottom:20px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">密码</label>' +\r\n                '<input type=\"password\" id=\"quickAddPass\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\r\n                '<div style=\"display:flex;gap:12px;justify-content:flex-end\">' +\r\n                '<button class=\"btn btn-secondary\" onclick=\"closeQuickAddModal()\" style=\"padding:8px 16px\">取消</button>' +\r\n                '<button class=\"btn btn-primary\" onclick=\"submitQuickAdd()\" style=\"padding:8px 16px\">添加并连接</button></div></div></div>';\r\n            document.body.insertAdjacentHTML('beforeend', modalHtml);\r\n        };\r\n        window.closeQuickAddModal = function(e) {\r\n            if (e && e.target !== e.currentTarget) return;\r\n            var modal = document.getElementById('quickAddModal');\r\n            if (modal) modal.remove();\r\n        };\r\n        window.submitQuickAdd = function() {\r\n            var ip = document.getElementById('quickAddIp').value.trim();\r\n            var gateway = document.getElementById('quickAddGateway').value.trim();\r\n\n[1561 more lines in file. Use offset=1598 to continue.]"}],"isError":false,"timestamp":1782644103004}}
