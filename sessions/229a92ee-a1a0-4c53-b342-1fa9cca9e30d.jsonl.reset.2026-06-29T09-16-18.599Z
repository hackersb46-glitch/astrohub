ring,\n    //   body: string (HTML),\n    //   type: 'alert' | 'confirm' | 'custom',\n    //   confirmText: string (default '确定'),\n    //   cancelText: string (default '取消'),\n    //   onConfirm: function(modalEl) | null,\n    //   onCancel: function() | null,\n    //   onClose: function() | null,\n    //   width: string (default '400px'),\n    // }\n}\n```\n\nFor the quickAddModal, I'll use type='custom' with body containing the form HTML, and onConfirm reads the form values.\n\nLet me now implement this. I need to:\n\n1. Add the unified showModal function in index.html (replace showAlert/showConfirm)\n2. Add CSS for the unified modal\n3. Replace quickAddModal with showModal\n4. Replace confirmRestart with showModal\n5. In console.html, replace resetImageControls confirm() with showModal\n6. In console.html, add preset write button + modal\n\nLet me read the exact sections I need to modify.\n\nFor index.html:\n- L152-156: CSS for modal\n- L414-442: showAlert + showConfirm\n- L1522-1565: quickAddModal\n- L2750-2766: confirmRestart\n\nFor console.html:\n- resetImageControls uses confirm() - need to replace\n- Add preset write button near the preset area\n\nLet me start implementing. First, let me read the exact CSS section:","thinkingSignature":"reasoning_content"},{"type":"text","text":"Now the frontend. Let me read the exact sections to modify:\n\n"},{"type":"toolCall","id":"call_q6whgn7oklol6l6wx4uqo0he","name":"read","arguments":{"limit":10,"offset":152,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}},{"type":"toolCall","id":"call_w90sj80ftxi0cq44dvlljfz5","name":"read","arguments":{"limit":40,"offset":410,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":77188,"output":986,"cacheRead":0,"cacheWrite":0,"totalTokens":78174,"cost":{"input":0.07718799999999999,"output":0.0031552000000000004,"cacheRead":0