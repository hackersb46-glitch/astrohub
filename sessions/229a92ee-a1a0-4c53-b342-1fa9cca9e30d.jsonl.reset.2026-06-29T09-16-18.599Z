     window.disableAllControls = function(reason) {\r\n            // 禁用主控台控件\r\n            if (typeof disableImageControls === 'function') {\r\n                disableImageControls(reason);\r\n            }\r\n            // 禁用高级功能控件\r\n            var advButtons = ['btnConnectFuncRun', 'btnConnectSpeedRun', 'btnStartDetection'];\r\n            advButtons.forEach(function(id) {\r\n                var btn = document.getElementById(id);\r\n                if (btn) {\r\n                    btn.disabled = true;\r\n                    btn.style.opacity = '0.5';\r\n                }\r\n            });\r\n        };\r\n\r\n        window.enableAllControls = function() {\r\n            // 启用主控台控件\r\n            if (typeof enableImageControls === 'function') {\r\n                enableImageControls();\r\n            }\r\n            // 启用高级功能控件\r\n            var advButtons = ['btnConnectFuncRun', 'btnConnectSpeedRun', 'btnStartDetection'];\r\n            advButtons.forEach(function(id) {\r\n                var btn = document.getElementById(id);\r\n                if (btn) {\r\n                    btn.disabled = false;\r\n                    btn.style.opacity = '1';\r\n                }\r\n            });\r\n        };\r\n\r\n        // ================================================================\r\n        //  BUG-017 修复: 暴露函数到全局 window,使 HTML onclick 可调用\r\n        //  设备管理页面按钮(发现/添加/刷新)以及其他页面交互的\r\n        //  onclick 处理程序定义在 IIFE 内部,必须显式暴露到全局。\r\n        // ================================================================\r\n        var _expose = [\r\n            discoverDevices, refreshDevices,\r\n            connectDevice, disconnectDevice, deleteDevice,\r\n            ptzMove, ptzHome, ptzStop, getPtzPosition, onPtzDeviceChange,\r\n            calibrate, saveSettings,\r\n            funcDetectRun, funcDetectRestore,\r\n\n[547 more lines in file. Use offset=2560 to continue.]"}],"isError":false,"timestamp":1782643365581}}
