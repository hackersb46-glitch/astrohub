{"type":"message","id":"18b0b963","parentId":"f1852763","timestamp":"2026-06-28T20:11:55.106Z","message":{"role":"toolResult","toolCallId":"call_lrofkchziuc3w6grzm7dwuuj","toolName":"read","content":[{"type":"text","text":"function runAdvTest() {\r\n    // 尝试从全局 connectedDevice 或下拉框获取设备\r\n    var deviceIp = '';\r\n    var username = 'admin';\r\n    var password = '';\r\n\r\n    if (window.connectedDevice && window.connectedDevice.ip) {\r\n        deviceIp = window.connectedDevice.ip;\r\n        username = window.connectedDevice.username || 'admin';\r\n        password = window.connectedDevice.password || '';\r\n    } else {\r\n        // 从下拉框获取\r\n        var deviceSelect = document.getElementById('advConnectDevice');\r\n        if (deviceSelect && deviceSelect.value) {\r\n            deviceIp = deviceSelect.value;\r\n        } else {\r\n            addAdvOutput('error', '请先连接设备');\r\n            return;\r\n        }\r\n    }\r\n\r\n    const btnRun = document.getElementById('btnAdvRun');\r\n    const btnStop = document.getElementById('btnAdvStop');\r\n    btnRun.disabled = true;\r\n    btnStop.disabled = false;\r\n    \r\n    // v7.54: 禁用其他页面标签\r\n    document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n        btn.disabled = true;\r\n        btn.style.opacity = '0.5';\r\n        btn.style.cursor = 'not-allowed';\r\n    });\r\n\r\n    // v7.52: 显示进度\r\n    var progressEl = document.getElementById('advProgress');\r\n    if (progressEl) progressEl.textContent = currentAdvTest + '...\\u8fd0\\u884c\\u4e2d';\r\n\r\n    addAdvOutput('info', '开始测试: ' + currentAdvTest);\r\n    // v7.52: 显示设备名称而非IP\r\n    var deviceName = window.connectedDevice.name || window.connectedDevice.device_name || deviceIp;\r\n    addAdvOutput('info', '设备: ' + deviceName);\r\n\r\n    const apiMap = {\r\n        'function': '/api/v1/"}],"isError":false,"timestamp":1782677515106}}
{"type":"message","id":"8e41f885","parentId":"18b0b963","timestamp":"2026-06-28T20:11:55.106Z","message":{"role":"toolResult","toolCallId":"call_53z9dqfadzokwppj0x1oiqkc","toolName":"read","content":[{"type":"text","text":"    document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n        btn.disabled = true;\r\n        btn.style.opacity = '0.5';\r\n        btn.style.cursor = 'not-allowed';\r\n    });\r\n\r\n    // v7.52: 显示进度\r\n    var progressEl = document.getElementById('advProgress');\r\n    if (progressEl) progressEl.textContent = currentAdvTest + '...\\u8fd0\\u884c\\u4e2d';\r\n\r\n    addAdvOutput('info', '开始测试: ' + currentAdvTest);\r\n    // v7.52: 显示设备名称而非IP\r\n    var deviceName = window.connectedDevice.name || window.connectedDevice.device_name || deviceIp;\r\n    addAdvOutput('info', '设备: ' + deviceName);\r\n\r\n    const apiMap = {\r\n        'function': '/api/v1/advanced/function/run',\r\n        'limit': '/api/v1/advanced/limit/run',\r\n        'speed': '/api/v1/advanced/speed/run',\r\n        'astrocal': '/api/v1/calibrate/start'\r\n    };\r\n\r\n    if (currentAdvTest === 'stream') {\r\n        addAdvOutput('info', '推流控制，请使用主控台');\r\n        btnRun.disabled = false;\r\n        btnStop.disabled = true;\r\n        return;\r\n    }\r\n\r\n    if (currentAdvTest === 'astrocal') {\r\n        // 天文校准 - 跳转到校准页面\r\n        startAstroCalibration(deviceIp, username, password);\r\n        btnRun.disabled = false;\r\n        btnStop.disabled = true;\r\n        return;\r\n    }\r\n\r\n    const apiUrl = apiMap[currentAdvTest];\r\n    if (!apiUrl) {\r\n        addAdvOutput('error', '未知测试类型');\r\n        btnRun.disabled = false;\r\n        btnStop.disabled = true;\r\n        return;\r\n    }\r\n\r\n    // v7.52: 速度测试读取档位参数\r\n    var requestBody = {\r\n        device_ip: deviceIp,\r\n        username: username,\r\n        password: password\r\n    };\r\n    if (currentAdvTest === 'speed') {\r\n        var speedRadio = document.querySelector('input[name=\"speedProfile\"]:checked');\r\n        if (speedRadio) {\r\n            requestBody.speed_profile = speedRadio.value;\r\n            addAdvOutput('info', '档位: ' + speedRadio.value);\r\n        }\r\n    }\r\n\r\n    // v7.52: 使用异步检测API + 轮询进度\r\n    var detectApiUrl = '/api/v1/advanced/detect/start';\r\n    var detectItems = [currentAdvTest];\r\n\r\n    fetch(detectApiUrl, {\r\n        method: 'POST',\r\n        headers: {'Content-Type': 'application/json'},\r\n        body: JSON.stringify({\r\n            device_ip: deviceIp,\r\n            username: username,\r\n            password: password,\r\n            items: detectItems,\r\n            speed_profile: requestBody.speed_profile || 'lite'\r\n        })\r\n    })\r\n    .then(r => r.json())\r\n    .then(data => {\r\n        if (data.success && data.task_id) {\r\n            addAdvOutput('info', '任务已启动: ' + data.task_id.substring(0,8));\r\n            pollAdvProgress(data.task_id);\r\n        } else {\r\n            btnRun.disabled = false;\r\n            btnStop.disabled = true;\r\n            addAdvOutput('error', data.message || '启动失败');\r\n            if (progressEl) progressEl.textContent = currentAdvTest + ' 失败';\r\n        }\r\n    })\r\n    .catch(e => {\r\n        btnRun.disabled = false;\r\n        btnStop.disabled = true;\r\n        addAdvOutput('error', '请求异常: ' + e.message);\r\n    });\r\n}\r\n\r\nfunction stopAdvTest() {\r\n    addAdvOutput('warn', '停止测试');\r\n    // v7.112: 清除轮询 + 调后端取消\r\n    if (advPollInterval) { clearInterval(advPollInterval); advPollInterval = null; }\r\n    if (advTaskId) {\r\n        fetch('/api/v1/advanced/detect/cancel/' + advTaskId, { method: 'POST' })\r\n        .then(r => r.json())\r\n\n[517 more lines in file. Use offset=350 to continue.]"}],"isError":false,"timestamp":1782677515106}}
