          '<div style=\"margin-bottom:16px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">用户名</label>' +\r\n                '<input type=\"text\" id=\"quickAddUser\" value=\"admin\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\r\n                '<div style=\"margin-bottom:20px\"><label style=\"display:block;margin-bottom:6px;color:#8b949e;font-size:13px\">密码</label>' +\r\n                '<input type=\"password\" id=\"quickAddPass\" style=\"width:100%;padding:10px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:6px;font-size:14px\"></div>' +\r\n                '<div style=\"display:flex;gap:12px;justify-content:flex-end\">' +\r\n                '<button class=\"btn btn-secondary\" onclick=\"closeQuickAddModal()\" style=\"padding:8px 16px\">取消</button>' +\r\n                '<button class=\"btn btn-primary\" onclick=\"submitQuickAdd()\" style=\"padding:8px 16px\">添加并连接</button></div></div></div>';\r\n            document.body.insertAdjacentHTML('beforeend', modalHtml);\r\n        };\r\n        window.closeQuickAddModal = function(e) {\r\n            if (e && e.target !== e.currentTarget) return;\r\n            var modal = document.getElementById('quickAddModal');\r\n            if (modal) modal.remove();\r\n        };\r\n        window.submitQuickAdd = function() {\r\n            var ip = document.getElementById('quickAddIp').value.trim();\r\n            var gateway = document.getElementById('quickAddGateway').value.trim();\r\n            var username = document.getElementById('quickAddUser').value.trim();\r\n            var password = document.getElementById('quickAddPass').value;\r\n            if (!ip) { addLog('error', '请输入 IP 地址'); return; }\r\n            if (!password) { addLog('error', '请输入密码'); return; }\r\n            closeQuickAddModal();\r\n            apiPost('/api/v1/devices', {ip: ip, gateway: gateway, username: username, password: password})\r\n                .then(function(result) {\r\n                    if (result.success) {\r\n                        addLog('done', '设备已添加: ' + ip);\r\n                        refreshDevices();\r\n                        setTimeout(function() { connectDevice(ip); }, 500);\r\n                    } else {\r\n                        addLog('error', result.message || '添加失败');\r\n                    }\r\n                }).catch(function(e) { addLog('error', '添加设备失败: ' + e); });\r\n        };\r\n        // v7.15: 添加设备按钮（完整输入）\r\n        window.showAddDeviceModal = function() {\r\n            showQuickAddModal('', '');\r\n        };\r\n        // v6.35: 显示设备信息弹窗\r\n        window.showDeviceInfoModal = function(ip) {\r\n            var d = allDevices.find(function(dev) { return dev.ip === ip; }) || {};\r\n            var info = '<div style=\"font-size:14px;line-height:1.8\">' +\r\n                '<p><b>IP:</b> ' + (d.ip || '--') + '</p>' +\r\n                '<p><b>MAC:</b> ' + (d.mac || '--') + '</p>' +\r\n                '<p><b>名称:</b> ' + (d.name || d.device_name || '--') + '</p>' +\r\n                '<p><b>型号:</b> ' + (d.model || '--') + '</p>' +\r\n                '<p><b>网关:</b> ' + (d.gateway || '--') + '</p>' +\r\n                '<p><b>子网掩码:</b> ' + (d.subnet || '--') + '</p>' +\r\n                '<p><b>端口:</b> ' + (d.port || 80) + '</p>' +\r\n                '</div>';\r\n            if (window.showModal) {\r\n                showModal('设备信息', info);\r\n            } else {\r\n                if (window.showAlert) window.showAlert(info, '设备信息');\r\n            }\r\n        };\r\n        // v6.54: 连接/断开操作锁\r\n        var _connectionOperationInProgress = false;\r\n\r\n        // Device Actions\r\n        function connectDevice(ip) {\r\n            // v6.54: 防止重复点击\r\n            if (_connectionOperationInProgress) {\r\n                showToast('warning', '请等待上一次操作完成');\r\n                return;\r\n            }\r\n            _connectionOperationInProgress = true;\r\n\r\n            addLog('info', '正在连接设备: ' + ip);\r\n            showToast('info', '正在连接设备...');\r\n\r\n            // 禁用连接按钮\r\n            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(false);\r\n\r\n            // 先获取 credentials\r\n            apiGet('/api/v1/ptz/devices/' + ip + '/credentials').then(function(creds) {\r\n                var username = (creds && creds.success) ? creds.username : 'admin';\r\n                var password = (creds && creds.success) ? creds.password : '';\r\n                var port = (creds && creds.success) ? (creds.port || 80) : 80;\r\n\r\n                // 再调用 connect API\r\n                apiPost('/api/v1/devices/' + ip + '/connect', { username: username, password: password, port: port }).then(function(result) {\r\n\n[1497 more lines in file. Use offset=1610 to continue.]"}],"isError":false,"timestamp":1782642982510}}
{"type":"message","id":"67719294","parentId":"aa2e3db9","timestamp":"2026-06-28T10:36:22.510Z","message":{"role":"toolResult","toolCallId":"call_sbrwe8gnb9hb0u73lma3wflr","toolName":"read","content":[{"type":"text","text":"            detectionState.running = false;\r\n        }\r\n        function addDetectionLog(level, msg) {\r\n            var log = document.getElementById('detectionLog');\r\n            if (!log) return;\r\n            var entry = document.createElement('div');\r\n            entry.className = 'log-entry ' + level;\r\n            entry.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\r\n            log.insertBefore(entry, log.firstChild);\r\n        }\r\n        // 预置点管理\r\n        function presetGoto() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var resultDiv = document.getElementById('presetResult');\r\n            resultDiv.textContent = '调用预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId, null).then(function(resp) {\r\n                if (resp && resp.success !== false) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已调用预置点 ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 调用失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function presetSet() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var resultDiv = document.getElementById('presetResult');\r\n            resultDiv.textContent = '设置预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId + '/set', null).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已设置预置点 ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 设置失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        // 渲染完整检测结果到连接设备页面\r\n        function renderConnectFullResults(results, type) {\r\n            var area = document.getElementById('connectFullResultArea');\r\n            var noResult = document.getElementById('connectNoResult');\r\n            if (!area) return;\r\n            area.style.display = 'block';\r\n            noResult.style.display = 'none';\r\n            var html = '<div style=\"margin-top:16px\">';\r\n            html += '<h4 style=\"font-size:15px;color:#e0e6f0;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #21262d\">';\r\n            if (type === 'function') html += '🔍 功能检测完整结果';\r\n            else if (type === 'limit') html += '📐 限位检测完整结果';\r\n            else if (type === 'speed') html += '⚡ 速度检测完整结果';\r\n            else html += '检测结果';\r\n            html += '</h4>';\r\n            if (type === 'function') {\r\n                var funcData = results.functions || results;\r\n                html += '<table class=\"result-table\"><thead><tr><th>功能</th><th>支持</th><th>最小值</th><th>最大值</th><th>当前值</th><th>状态</th></tr></thead><tbody>';\r\n                var keys = Object.keys(funcData);\r\n                if (keys.length === 0) {\r\n                    html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">暂无结果</td></tr>';\r\n                } else {\r\n                    keys.forEach(function(key) {\r\n                        var item = funcData[key];\r\n                        if (!item || typeof item !== 'object' || !item.hasOwnProperty('supported')) return;\r\n                        var supported = item.supported ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>';\r\n                        var status = item.status || '完成';\r\n                        html += '<tr>';\r\n                        html += '<td>' + key + '</td>';\r\n                        html += '<td>' + supported + '</td>';\r\n                        html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\r\n                        html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\r\n                        html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\r\n                        html += '<td><span class=\"badge yes\">' + status + '</span></td>';\r\n                        html += '</tr>';\r\n                    });\r\n                }\r\n                html += '</tbody></table>';\r\n\n[1897 more lines in file. Use offset=1210 to continue.]"}],"isError":false,"timestamp":1782642982510}}
{"type":"message","id":"30e7002e","parentId":"67719294","timestamp":"2026-06-28T10:36:22.510Z","message":{"role":"toolResult","toolCallId":"call_gegt85ew1oraou7cfnrcpxdb","toolName":"read","content":[{"type":"text","text":"                document.getElementById('quickConnectSwitch').checked = false;\r\n            });\r\n        } else {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                disconnectDevice(window.connectedDevice.ip);\r\n            }\r\n        }\r\n    };\r\n\r\n    // 确认重启 - v7.98: 智能检测进程状态\r\n    window.confirmRestart = function() {\r\n        if (!confirm('确定要重启 AstroHub 吗?\\n重启期间服务将暂时不可用。')) return;\r\n\r\n        showToast('info', '正在重启...');\r\n\r\n        apiPost('/api/v1/system/restart', null).then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '重启中，10秒后自动刷新页面...');\r\n                setTimeout(function() { location.reload(); }, 10000);\r\n            } else {\r\n                showToast('error', r ? r.message : '重启失败');\r\n            }\r\n        }).catch(function(e) {\r\n            // 请求失败说明进程已退出，正在重启\r\n            showToast('warning', '重启中，10秒后自动刷新页面...');\r\n            setTimeout(function() { location.reload(); }, 10000);\r\n        });\r\n    };\r\n\r\n    // 页面切换函数\r\n    window.switchPage = function(page) {\r\n        document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n        document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n        document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\r\n        document.getElementById('page-' + page).classList.add('active');\r\n        \r\n        // 切换到主控台时，如果已登录但未播放，开始预览（渲染）\r\n        if (page === 'console' && WasmPlayer && WasmPlayer.loggedIn && !WasmPlayer.playing) {\r\n            var channel = WasmPlayer.channel || 1;\r\n            var streamType = window._currentStreamType || 3;\r\n            wasmStartRealPlay(channel, streamType, true);\r\n        }\r\n        // 切换到设置页时加载路径配置\r\n        if (page === 'settings' && typeof loadStorageSettings === 'function') {\r\n            loadStorageSettings();\r\n        }\r\n    };\r\n\r\n    console.log('[GLOBAL v5.27] Functions ready');\r\n\r\n\n[317 more lines in file. Use offset=2790 to continue.]"}],"isError":false,"timestamp":1782642982510}}
{"type":"message","id":"06f8fe23","parentId":"30e7002e","timestamp":"2026-06-28T10:36:40.761Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me summarize what I've found so far:\n\n1. **Existing modals**: \n   - `showAlert` - a simple alert with OK button, closes on overlay click\n   - `showConfirm` - confirm with cancel/ok buttons, but uses overlay click to close\n   - `showQuickAddModal` - add device modal, closes on overlay click too\n   - `showDeviceInfoModal` - shows device info using `showModal` or `showAlert`\n   - `confirmRestart` - uses native `confirm()` which is a browser-level dialog!\n\n2. **Preset UI**: \n   - `presetGoto()` / `presetSet()` on advanced page - takes preset ID from input, no name\n   - `loadPresetList()` / `ptzGotoSelectedPreset()` on console page - loads presets via API, selects from dropdown\n   - No \"write preset\" with name input anywhere\n\n3. **PTZ Backend**:\n   - `PTZController.set_preset(preset_id, pan=None, tilt=None, zoom=None, name=\"\")` - supports both modes\n   - API: `POST /api/v1/ptz/{device_id}/preset/{preset_id}/set` - currently only passes preset_id, no name\n\nNow let me look at what needs to happen:\n\n**Task 1**: Add preset write (set preset with name) on console page. Need:\n- Button on console page to trigger a modal\n- Modal with preset ID input + name input\n- Call API with preset_id and name\n\n**Task 2**: Replace all browser-native dialogs with custom modals:\n- `confirmRestart` uses native `confirm()` → needs `showConfirm` with overlay\n- Ensure all modals are non-dismissable except via ESC or Cancel button (no overlay-click close)\n- Background area behind modal should be non-interactive\n\nLet me check more details - the console page preset area, and the API endpoint more carefully.","thinkingSignature":"reasoning_content"},{"type":"text","text":"继续看主控台预置点区域和后端API。"},{"type":"toolCall","id":"call_00_7Brr6lelm2V9DZpQcPx17317","name":"read","arguments":{"offset":1226,"limit":60