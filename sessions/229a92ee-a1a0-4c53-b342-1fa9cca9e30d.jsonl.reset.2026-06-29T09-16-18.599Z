v1/ptz/' + dev + '/image/reset', {})\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '画面控制已重置到系统默认值');\r\n                if (typeof operationLog === 'function') operationLog('画面重置', 'success');\r\n            } else {\r\n                showToast('error', '重置失败: ' + (r.message || '未知错误'));\r\n            }\r\n        })\r\n        .catch(function(e) {\r\n            showToast('error', '重置请求失败');\r\n        });\r\n}\r\n\r\nfunction loadDeviceImageParams(deviceIp) {\r\n    if (!deviceIp) return;\r\n    \r\n    if (typeof apiGet === 'undefined') {\r\n        console.error('[IMAGE] apiGet not defined');\r\n        return;\r\n    }\r\n    \r\n    console.log('[IMAGE] Loading image params for:', deviceIp);\r\n    \r\n    // v6.41: 重置状态\r\n    functionCacheLoaded = false;\r\n    deviceFunctionData = null;\r\n    \r\n    // v7.32: 必须有 function.json 才能启用画面控制\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/function').then(function(r) {\r\n        if (r && r.success && r.data && r.data.functions) {\r\n            deviceFunctionData = r.data;\r\n            functionCacheLoaded = true;\r\n            console.log('[IMAGE] function.json loaded, detected_at:', r.data.detected_at);\r\n            enableImageControls();\r\n            // 移除覆盖层\r\n            removeFunctionOverlay();\r\n            // 加载图像参数\r\n            loadAllImageParams(deviceIp);\r\n        } else {\r\n            console.warn('[IMAGE] function.json not found - disabling image controls');\r\n            // 禁用画面控制\r\n            disableImageControls('请执行功能检测，以启用此功能');\r\n            // 显示覆盖层\r\n            showFunctionOverlay();\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[IMAGE] function.json failed:', e);\r\n\n[794 more lines in file. Use offset=780 to continue.]"}],"isError":false,"timestamp":1782644378011}}
