y btn-sm\" onclick=\"ptzHome()\">归位</button>\n   75                                 </div>\n-  76                                 <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n   77                                 <!-- 变焦/对焦 -->\n   78                                 <div class=\"section-subtitle\">变焦/对焦</div>\n   79                                 <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n   80                                     <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\n      ...","firstChangedLine":67},"isError":false,"timestamp":1782682894468}}
{"type":"message","id":"33c8dc13","parentId":"065e90d2","timestamp":"2026-06-28T21:41:38.235Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":" 响应Now fix the JS functions to use `addLog` instead of `ptzPresetResult`:","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_LqvUOEtpQR8CRRlBLm3p6686","name":"read","arguments":{"limit":80,"offset":953,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"sf","model":"glm-5.2","usage":{"input":153776,"output":120,"cacheRead":0,"cacheWrite":0,"totalTokens":153896,"cost":{"input":0.153776,"output":0.000384,"cacheRead":0,"cacheWrite":0,"total":0.15416}},"stopReason":"toolUse","timestamp":1782682894474,"responseId":"cht000dabc7@dx19f102e4148b8ab162"}}
{"type":"message","id":"6dae7b0b","parentId":"33c8dc13","timestamp":"2026-06-28T21:41:38.333Z","message":{"role":"toolResult","toolCallId":"call_00_LqvUOEtpQR8CRRlBLm3p6686","toolName":"read","content":[{"type":"text","text":"        function ptzGotoSelectedPreset() {\r\n            var dev = window.connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            if (!presetId) { showToast('warning', '请先选择预置点'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '跳转到预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId, null).then(function(resp) {\r\n                if (resp && resp.success !== false) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已前往预置点 ' + presetId + '</span>';\r\n                    if (typeof operationLog === 'function') operationLog('预置点: 前往 #' + presetId, 'success');\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 跳转失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function ptzSetSelectedPreset() {\r\n            var dev = window.connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            if (!presetId) { showToast('warning', '请先选择预置点编号'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '保存当前位置为预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId + '/set', null).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已保存预置点 ' + presetId + '</span>';\r\n                    if (typeof operationLog === 'function') operationLog('预置点: 保存 #' + presetId, 'success');\r\n                    loadPresetList(); // refresh\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 保存失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        // v7.117: 写入预置点 — 弹窗输入编号+名称\r\n        function ptzWritePreset() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先连接设备'); return; }\r\n            showModal({\r\n                type: 'form',\r\n                title: '写入预置点',\r\n                fields: [\r\n                    { id:'presetId', label:'预置点编号', value:'', placeholder:'1-300', required:true },\r\n                    { id:'presetName', label:'名称', value:'', placeholder:'选填' }\r\n                ],\r\n                onConfirm: function(data) {\r\n                    var presetId = parseInt(data.presetId);\r\n                    var presetName = (data.presetName || '').trim();\r\n                    if (!presetId || presetId < 1 || presetId > 300) {\r\n                        showToast('error', '预置点编号需在 1-300 之间');\r\n                        return;\r\n                    }\r\n                    var resultDiv = document.getElementById('ptzPresetResult');\r\n                    if (resultDiv) resultDiv.textContent = '写入预置点 ' + presetId + '...';\r\n                    var url = '/api/v1/ptz/' + dev + '/preset/' + presetId + '/set';\r\n                    if (presetName) url += '?name=' + encodeURIComponent(presetName);\r\n                    apiPost(url, null).then(function(resp) {\r\n                        if (resp && resp.success) {\r\n                            if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已写入预置点 ' + presetId + (presetName ? ' (' + presetName + ')' : '') + '</span>';\r\n                            if (typeof operationLog === 'function') operationLog('预置点: 写入 #' + presetId + (presetName ? ' ' + presetName : ''), 'success');\r\n                            loadPresetList();\r\n                        } else {\r\n                            if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 写入失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                        }\r\n                    }).catch(function(e) {\r\n                        if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n                    });\r\n                }\r\n            });\r\n        }\r\n        function findMacByIP(ip) {\r\n            var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n            return dev ? dev.mac : '';\r\n        }\r\n        // PTZ Speed Slider\r\n\n[1821 more lines in file. Use offset=1033 to continue.]"}],"isError":false,"timestamp":1782682898333}}
{"type":"message","id":"54ab3afc","parentId":"6dae7b0b","timestamp":"2026-06-28T21:42:23.987Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to:\n1. Remove `ptzSetSelectedPreset()` function (dead since button removed)\n2. Update `ptzGotoSelectedPreset()` and `ptzWritePreset()` to use `addLog` instead of `ptzPresetResult` div\n3. Remove `ptzPresetResult` references\n4. Hide scrollbars on all info panels\n\nLet me do all changes:","thinkingSignature":"reasoning_content"},{"type":"text","text":"Now remove `ptzSetSelectedPreset` and redirect result messages to `addLog`:\n\n"},{"type":"toolCall","id":"call_cay26strrelmsn22do7thzw0","name":"edit","arguments":{"edits":[{"newText":"        function ptzGotoSelectedPreset() {\n            var dev = window.connectedDevice.ip;\n            var sel = document.getElementById('ptzPresetSelect');\n            var presetId = parseInt(sel.value);\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            if (!presetId) { showToast('warning', '请先选择预置点'); return; }\n            addLog('info', '预置点: 前往 #' + presetId + '...');\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId, null).then(function(resp) {\n                if (resp && resp.success !== false) {\n                    addLog('success', '预置点: 已前往 #' + presetId);\n                } else {\n                    addLog('error', '预置点: 前往失败 ' + (resp ? resp.message : '未知'));\n                }\n            }).catch(function(e) {\n                addLog('error', '预置点: 异常 ' + e.message);\n            });\n        }\n        // v7.117: 写入预置点 — 弹窗输入编号+名称\n        function ptzWritePreset() {\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n            if (!dev) { showToast('warning', '请先连接设备'); return; }\n            showModal({\n                type: 'form',\n                title: '写入预置点',\n                fields: [\n                    { id:'presetId', label:'预置点编号', value:'', placeholder:'1-300', required:true },\n                    { id:'presetName', label:'名称', value:'', placeholder:'选填' }\n                ],\n                onConfirm: function(data) {\n                    var presetId = parseInt(data.presetId);\n                    var presetName = (data.presetName || '').trim();\n                    if (!presetId || presetId < 1 || presetId > 300) {\n                        showToast('error', '预置点编号需在 1-300 之间');\n                        return;\n                    }\n                    addLog('info', '预置点: 写入 #' + presetId + (presetName ? ' ' + presetName : '') + '...');\n                    var url = '/api/v1/ptz/' + dev + '/preset/' + presetId + '/set';\n                    if (presetName) url += '?name=' + encodeURIComponent(presetName);\n                    apiPost(url, null).then(function(resp) {\n                        if (resp && resp.success) {\n                            addLog('success', '预置点: 已写入 #' + presetId + (presetName ? ' ' + presetName : ''));\n                            loadPresetList();\n                        } else {\n                            addLog('error', '预置点: 写入失败 ' + (resp ? resp.message : '未知'));\n                        }\n                    }).catch(function(e) {\n                        addLog('error', '预置点: 异常 ' + e.message);\n                    });\n                }\n            });\n        }","oldText":"        function ptzGotoSelectedPreset() {\n            var dev = window.connectedDevice.ip;\n            var sel = document.getElementById('ptzPresetSelect');\n            var presetId = parseInt(sel.value);\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\n            if (!presetId) { showToast('warning', '请先选择预置点'); return; }\n            var resultDiv = document.getElementById('ptzPresetResult');\n            resultDiv.textContent = '跳转到预置点 ' + presetId + '...';\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId, null).then(function(resp) {\n        