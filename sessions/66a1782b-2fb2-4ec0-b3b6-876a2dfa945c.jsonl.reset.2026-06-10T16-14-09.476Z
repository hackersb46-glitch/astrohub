{"type":"message","id":"e7f9369d","parentId":"2101cc6d","timestamp":"2026-06-04T08:11:49.623Z","message":{"role":"assistant","content":[{"type":"text","text":"创建独立测试脚本："},{"type":"toolCall","id":"call_46b07715a4d9474b888290a5","name":"write","arguments":{"content":"#!/usr/bin/env python\n\"\"\"Live Stack 模块测试\"\"\"\n\nimport sys\nfrom pathlib import Path\n\n_project_root = str(Path(__file__).resolve().parent.parent)\nif _project_root not in sys.path:\n    sys.path.insert(0, _project_root)\n\nimport numpy as np\nimport cv2\n\nprint(\"=\" * 50)\nprint(\"Live Stack 模块测试\")\nprint(\"=\" * 50)\n\n# 测试导入\nfrom stack.live_stack import LiveStack, HAS_ASTROALIGN\nfrom stack.detect import StarDetector, HAS_PHOTUTILS\n\nprint(f\"\\n[环境]\")\nprint(f\"  astroalign 可用: {HAS_ASTROALIGN}\")\nprint(f\"  photutils 可用: {HAS_PHOTUTILS}\")\n\n# 创建 Live Stack\nlive_stack = LiveStack(\n    hardware_exposure_ms=100,\n    output_dir=\"stack/output_live\",\n    preview_interval=5,\n)\n\n# 启动\nprint(f\"\\n[启动 Live Stack]\")\nresult = live_stack.start(target_exposure=2.0)\nprint(f\"  {result['message']}\")\nprint(f\"  目标帧数: {result['target_frames']}\")\n\n# 添加帧（模拟轻微旋转和平移）\nprint(f\"\\n[添加帧]\")\nnp.random.seed(42)\n\nfor i in range(20):\n    base = np.ones((100, 100)) * 100\n    base[40:60, 40:60] = 500\n    \n    # 模拟轻微偏移和旋转\n    angle = np.random.uniform(-0.5, 0.5)\n    shift_x = np.random.uniform(-2, 2)\n    shift_y = np.random.uniform(-2, 2)\n    \n    M = cv2.getRotationMatrix2D((50, 50), angle, 1)\n    M[0, 2] += shift_x\n    M[1, 2] += shift_y\n    \n    shifted = cv2.warpAffine(base.astype(np.float32), M, (100, 100))\n    noise = np.random.normal(0, 10, (100, 100))\n    frame = shifted + noise\n    \n    result = live_stack.add_frame(frame.astype(np.uint8))\n    \n    if i % 5 == 0:\n        transform = result.get('transform', {})\n        print(f\"  帧 #{i+1}: method={transform.get('method', 'N/A')}, \" +\n              f\"rotation={transform.get('rotation', 0):.2f}°\")\n\n# 完成叠加\nprint(f\"\\n[完成]\")\nfinal = live_stack.finish()\nprint(f\"  {final['message']}\")\nprint(f\"  FITS: {final.get('fits_path', 'N/A')}\")\nprint(f\"  JPG: {final.get('jpg_path', 'N/A')}\")\n\n# 变换统计\nsummary = final.get('transform_summary', {})\nif summary:\n    print(f\"\\n[变换统计]\")\n    print(f\"  方法: {summary.get('method', 'N/A')}\")\n    if 'avg_rotation' in summary:\n        print(f\"  平均旋转: {summary['avg_rotation']:.3f}°\")\n        print(f\"  最大旋转: {summary['max_rotation']:.3f}°\")\n    if 'avg_shift_x' in summary:\n        print(f\"  平均平移 X: {summary['avg_shift_x']:.2f}\")\n        print(f\"  平均平移 Y: {summary['avg_shift_y']:.2f}\")\n\nprint(\"\\n\" + \"=\" * 50)\nprint(\"测试完成!\")\nprint(\"=\" * 50)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\test_live_stack.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":148286,"output":804,"cacheRead":0,"cacheWrite":0,"totalTokens":149090,"cost":{"input":0.148286,"output":0.0025728,"cacheRead":0,"cacheWrite":0,"total":0.15085880000000002}},"stopReason":"toolUse","timestamp":1780560665403,"responseId":"cht000d3ceb@dx19e91afb8acb87e692"}}
