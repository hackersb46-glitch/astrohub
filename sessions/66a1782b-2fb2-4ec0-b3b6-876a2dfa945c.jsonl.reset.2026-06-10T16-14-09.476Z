{"type":"message","id":"ef37fcb1","parentId":"e832ee19","timestamp":"2026-06-04T06:12:36.775Z","message":{"role":"assistant","content":[{"type":"text","text":"**Step 2: 图像对齐模块**"},{"type":"toolCall","id":"call_8cd069fc318443fe85993344","name":"write","arguments":{"content":"\"\"\"\n图像对齐模块\n\n使用 astroalign 进行基于星点的图像对齐。\n支持相位相关法（纯平移）和 ECC（仿射变换）作为备选。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport numpy as np\nfrom typing import Optional, Tuple\n\n# 尝试导入 astroalign\ntry:\n    import astroalign as aa\n    HAS_ASTROALIGN = True\nexcept ImportError:\n    HAS_ASTROALIGN = False\n    aa = None\n\nimport cv2\n\n# 导入星点检测\nfrom .detect import StarDetector\n\n\nclass ImageAligner:\n    \"\"\"\n    图像对齐器\n    \n    支持多种对齐方法：\n    1. astroalign: 基于星点匹配（推荐，最鲁棒）\n    2. 相位相关: 纯平移，亚像素精度\n    3. ECC: 仿射/透视变换\n    \"\"\"\n    \n    def __init__(\n        self,\n        method: str = 'auto',\n        min_stars: int = 3,\n        fwhm: float = 3.0,\n        threshold: float = 5.0,\n    ):\n        \"\"\"\n        初始化对齐器\n        \n        Args:\n            method: 对齐方法 ('auto', 'astroalign', 'phase', 'ecc')\n            min_stars: 最少星点数\n            fwhm: 星点 FWHM\n            threshold: 检测阈值\n        \"\"\"\n        self.method = method\n        self.min_stars = min_stars\n        self.detector = StarDetector(fwhm=fwhm, threshold=threshold)\n        \n        # 变换信息\n        self.last_transform = None\n    \n    def align(\n        self,\n        source: np.ndarray,\n        reference: np.ndarray,\n    ) -> Tuple[np.ndarray, dict]:\n        \"\"\"\n        将 source 对齐到 reference\n        \n        Args:\n            source: 待对齐图像\n            reference: 参考图像\n        \n        Returns:\n            (aligned_image, transform_info)\n        \"\"\"\n        method = self.method\n        \n        # 自动选择方法\n        if method == 'auto':\n            if HAS_ASTROALIGN:\n                method = 'astroalign'\n            else:\n                method = 'phase'\n        \n        if method == 'astroalign':\n            return self._align_astroalign(source, reference)\n        elif method == 'phase':\n            return self._align_phase(source, reference)\n        elif method == 'ecc':\n            return self._align_ecc(source, reference)\n        else:\n            raise ValueError(f\"未知对齐方法: {method}\")\n    \n    def _align_astroalign(\n        self,\n        source: np.ndarray,\n        reference: np.ndarray,\n    ) -> Tuple[np.ndarray, dict]:\n        \"\"\"\n        使用 astroalign 对齐（三角形法星点匹配）\n        \n        优点：\n        - 对 FoV、PSF、seeing 差异鲁棒\n        - 自动处理旋转、平移、缩放\n        - 无需 WCS\n        \"\"\"\n        if not HAS_ASTROALIGN:\n            return self._align_phase(source, reference)\n        \n        try:\n            # astroalign 需要 float 图像\n            src_float = source.astype(np.float32)\n            ref_float = reference.astype(np.float32)\n            \n            # 对齐\n            aligned, footprint = aa.register(src_float, ref_float)\n            \n            # 获取变换信息\n            try:\n                transf, (src_stars, tgt_stars) = aa.find_transform(src_float, ref_float)\n                \n                transform_info = {\n                    'method': 'astroalign',\n                    'rotation': np.degrees(transf.rotation),  # 度\n                    'translation': transf.translation.tolist(),  # [tx, ty]\n                    'scale': transf.scale,\n                    'src_stars': len(src_stars),\n                    'tgt_stars': len(tgt_stars),\n                    'success': True,\n                }\n            except Exception:\n                transform_info = {\n                    'method': 'astroalign',\n                    'success': True,\n                }\n            \n            self.last_transform = transform_info\n            \n            return aligned, transform_info\n        \n        except Exception as e:\n            # astroalign 失败，降级到相位相关\n            return self._align_phase(source, reference)\n    \n    def _align_phase(\n        self,\n        source: np.ndarray,\n        reference: np.ndarray,\n    ) -> Tuple[np.ndarray, dict]:\n        \"\"\"\n        相位相关法对齐（纯平移）\n        \n        优点：\n        - 亚像素精度\n        - 速度快\n        缺点：\n        - 只能处理平移，不能处理旋转\n        \"\"\"\n        # 确保图像是 float\n        src_float = source.astype(np.float32)\n        ref_float = reference.astype(np.float32)\n        \n        # 相位相关\n        result = cv2.phaseCorrelate(ref_float, src_float)\n        \n        shift_x = result[0][0]  # x 方向偏移\n        shift_y = result[0][1]  # y 方向偏移\n        response = result[1]    # 相关峰值\n        \n        # 构建平移矩阵\n        M = np.array([\n            [1, 0, -shift_x],\n            [0, 1, -shift_y]\n        ], dtype=np.float32)\n        \n        # 应用变换\n        h, w = source.shape[:2]\n        aligned = cv2.warpAffine(src_float, M, (w, h))\n        \n        transform_info = {\n            'method': 'phase',\n            'shift_x': float(shift_x),\n            'shift_y': float(shift_y),\n            'response': float(response),\n            'success': True,\n        }\n        \n        self.last_transform = transform_info\n        \n        return aligned, transform_info\n    \n    def _align_ecc(\n        self,\n        source: np.ndarray,\n        reference: np.ndarray,\n    ) -> Tuple[np.ndarray, dict]:\n        \"\"\"\n        ECC (Enhanced Correlation Coefficient) 对齐\n        \n        优点：\n        - 支持仿射/透视变换\n        - 精度高\n        缺点：\n        - 需要好的初始估计\n        - 慢\n        \"\"\"\n        # 确保图像是 float\n        src_float = source.astype(np.float32)\n        ref_float = reference.astype(np.float32)\n        \n        # 归一化\n        src_norm = cv2.normalize(src_float, None, 0, 255, cv2.NORM_MINMAX)\n        ref_norm = cv2.normalize(ref_float, None, 0, 255, cv2.NORM_MINMAX)\n        \n        # 初始化变换矩阵\n        warp_mode = cv2.MOTION_EUCLIDEAN  # 欧几里得变换（旋转+平移）\n        warp_matrix = np.eye(2, 3, dtype=np.float32)\n        \n        # 终止条件\n        criteria = (cv2.TERM_CRITERIA_EPS | cv2.TERM_CRITERIA_COUNT, 100, 1e-6)\n        \n        try:\n            # ECC 对齐\n            cc, warp_matrix = cv2.findTransformECC(\n                ref_norm, src_norm, warp_matrix, warp_mode, criteria\n            )\n            \n            # 应用变换\n            h, w = source.shape[:2]\n            aligned = cv2.warpAffine(src_float, warp_matrix, (w, h))\n            \n            # 提取参数\n            cos_theta = warp_matrix[0, 0]\n            sin_theta = warp_matrix[1, 0]\n            theta = np.arctan2(sin_theta, cos_theta)\n            \n            transform_info = {\n                'method': 'ecc',\n                'rotation': np.degrees(theta),\n                'tx': float(warp_matrix[0, 2]),\n                'ty': float(warp_matrix[1, 2]),\n                'correlation': float(cc),\n                'success': True,\n            }\n            \n            self.last_transform = transform_info\n            \n            return aligned, transform_info\n        \n        except Exception as e:\n            # ECC 失败，降级到相位相关\n            return self._align_phase(source, reference)\n\n\ndef align_images(\n    source: np.ndarray,\n    reference: np.ndarray,\n    method: str = 'auto',\n) -> Tuple[np.ndarray, dict]:\n    \"\"\"\n    快捷函数：对齐图像\n    \n    Args:\n        source: 待对齐图像\n        reference: 参考图像\n        method: 对齐方法\n    \n    Returns:\n        (aligned_image, transform_info)\n    \"\"\"\n    aligner = ImageAligner(method=method)\n    return aligner.align(source, reference)\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试图像对齐模块\")\n    \n    # 创建测试图像\n    ref = np.zeros((100, 100), dtype=np.float32)\n    ref[40:60, 40:60] = 100  # 参考点\n    \n    src = np.zeros((100, 100), dtype=np.float32)\n    src[45:65, 45:65] = 100  # 平移 +5\n    \n    # 相位相关测试\n    aligner = ImageAligner(method='phase')\n    aligned, info = aligner.align(src, ref)\n    \n    print(f\"对齐方法: {info['method']}\")\n    print(f\"位移: x={info.get('shift_x', 0):.2f}, y={info.get('shift_y', 0):.2f}\")\n    print(f\"astroalign 可用: {HAS_ASTROALIGN}\")\n    print(\"测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\align.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":125733,"output":2073,"cacheRead":0,"cacheWrite":0,"totalTokens":127806,"cost":{"input":0.12573299999999998,"output":0.006633600000000001,"cacheRead":0,"cacheWrite":0,"total":0.13236659999999997}},"stopReason":"toolUse","timestamp":1780553490335,"responseId":"cht000d5d70@dx19e914246a8b992462"}}
