w\\agents\\dev-factory\\astrohub\\calibrate\\test_all.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\documents\\DEVELOPMENT_PLAN.md","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\documents\\live_stack_requirements.md","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\main\\main.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\advanced.html","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\__init__.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\align.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\detect.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\output.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\process.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\stack.py","C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\test_all.py"]},"fromHook":true}
