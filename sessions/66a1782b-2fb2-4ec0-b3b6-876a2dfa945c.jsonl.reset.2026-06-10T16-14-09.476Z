ectedDevice?.lastPan || 0;\n+562     const tilt = window.connectedDevice?.lastTilt || 0;\n+563     \n+564     fetch('/api/v1/calibrate/capture', {\n+565         method: 'POST',\n+566         headers: {'Content-Type': 'application/json'},\n+567         body: JSON.stringify({\n+568             device_ip: astroCalSession,\n+569             pan: pan,\n+570             tilt: tilt\n+571         })\n+572     })\n+573     .then(r => r.json())\n+574     .then(data => {\n+575         if (data.success) {\n+576             addAdvOutput('success', '解析成功: RA=' + data.ra.toFixed(2) + 'h, DEC=' + data.dec.toFixed(2) + '°');\n+577             updateAstroCalStatus(data.coverage);\n+578         } else {\n+579             addAdvOutput('error', data.message || '解析失败');\n+580         }\n+581     })\n+582     .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n+583 }\n+584 \n+585 function updateAstroCalStatus(coverage) {\n+586     const statusEl = document.getElementById('astroCalStatus');\n+587     if (!statusEl || !coverage) return;\n+588     \n+589     let html = '校准点: ' + (coverage.total_points || 0) + ' | ';\n+590     html += 'Az覆盖: ' + coverage.az_spread.toFixed(0) + '° | ';\n+591     html += 'Alt覆盖: ' + coverage.alt_spread.toFixed(0) + '°';\n+592     \n+593     if (coverage.needs_more) {\n+594         html += '<br><span style=\"color:#d29922\">需要更多校准点</span>';\n+595     } else {\n+596         html += '<br><span style=\"color:#3fb950\">可以计算参数</span>';\n+597     }\n+598     \n+599     statusEl.innerHTML = html;\n+600 }\n+601 \n+602 function computeAstroCal() {\n+603     if (!astroCalSession) {\n+604         addAdvOutput('error', '请先启动校准');\n+605         return;\n+606     }\n+607     \n+608     addAdvOutput('info', '计算校准参数...');\n+609     \n+610     fetch('/api/v1/calibrate/compute', {\n+611         method: 'POST',\n+612         headers: {'Content-Type': 'application/json'},\n+613         body: JSON.stringify({device_ip: astroCalSession})\n+614     })\n+615     .then(r => r.json())\n+616     .then(data => {\n+617         if (data.success) {\n+618             addAdvOutput('success', '计算成功!');\n+619             if (data.params) {\n+620                 addAdvOutput('info', 'IA=' + data.params.IA?.toFixed(3) + '°, IH=' + data.params.IH?.toFixed(3) + '°');\n+621             }\n+622             if (data.rms) {\n+623                 addAdvOutput('info', 'RMS: Az=' + (data.rms.az || 0).toFixed(3) + '°, Alt=' + (data.rms.alt || 0).toFixed(3) + '°');\n+624             }\n+625         } else {\n+626             addAdvOutput('error', data.message || '计算失败');\n+627         }\n+628     })\n+629     .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n+630 }\n+631 \n+632 function saveAstroCal() {\n+633     if (!astroCalSession) {\n+634         addAdvOutput('error', '请先完成校准计算');\n+635         return;\n+636     }\n+637     \n+638     fetch('/api/v1/calibrate/save', {\n+639         method: 'POST',\n+640         headers: {'Content-Type': 'application/json'},\n+641         body: JSON.stringify({device_ip: astroCalSession})\n+642     })\n+643     .then(r => r.json())\n+644     .then(data => {\n+645         if (data.success) {\n+646             addAdvOutput('success', '校准结果已保存');\n+647         } else {\n+648             addAdvOutput('error', data.message || '保存失败');\n+649         }\n+650     })\n+651     .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n+652 }\n 376 </script>","firstChangedLine":376},"isError":false,"timestamp":1780517929965}}
