{"type":"message","id":"21acd02c","parentId":"c71b4508","timestamp":"2026-06-03T20:13:27.065Z","message":{"role":"assistant","content":[{"type":"text","text":"测试可能有阻塞，直接运行最终验证脚本："},{"type":"toolCall","id":"call_8ba504f7d1da4ccd8006dd2b","name":"write","arguments":{"content":"#!/usr/bin/env python\n\"\"\"校准模块功能测试\"\"\"\n\nfrom datetime import datetime\n\n# 测试核心模块\nprint(\"=\" * 50)\nprint(\"PTZ 天文校准模块测试\")\nprint(\"=\" * 50)\n\n# 1. 坐标转换\nprint(\"\\n[1] 坐标转换测试\")\nfrom calibrate.core.coordinates import equatorial_to_altaz, apply_refraction\n\nresult = equatorial_to_altaz(ra=5.5, dec=45, obs_time=datetime.now(), lat=40, lon=120)\nprint(f\"   RA=5.5h, DEC=45 -> Az={result['az']:.1f}, Alt={result['alt']:.1f}\")\n\nalt_true = apply_refraction(30)\nprint(f\"   Observed Alt=30 -> True Alt={alt_true:.3f}\")\n\n# 2. 亮星查询\nprint(\"\\n[2] 亮星查询测试\")\nfrom calibrate.core.star_catalog import get_bright_stars, recommend_calibration_stars\n\nstars = get_bright_stars(5)\nprint(f\"   Top 5 bright stars: {[s['name'] for s in stars]}\")\n\nrecommended = recommend_calibration_stars(datetime.now(), 40, 120, 3)\nprint(f\"   Recommended: {[s['name'] for s in recommended]}\")\n\n# 3. T-Point 模型\nprint(\"\\n[3] T-Point 模型测试\")\nfrom calibrate.core.model import PointingModel\n\nmodel = PointingModel()\ndelta_az, delta_alt = model.compute_correction(45, 60)\nprint(f\"   Correction at (45, 60): dAz={delta_az:.6f}, dAlt={delta_alt:.6f}\")\n\n# 4. Plate Solve 检查\nprint(\"\\n[4] Plate Solve 状态\")\nfrom calibrate.core.plate_solve import check_astap_installed\n\nstatus = check_astap_installed()\nprint(f\"   ASTAP installed: {status['installed']}\")\nif status['installed']:\n    print(f\"   Path: {status['path']}\")\n\n# 5. 手动校准\nprint(\"\\n[5] 手动校准测试\")\nfrom calibrate.calibration_manual import ManualCalibration\n\nmanual = ManualCalibration('192.168.1.100', 40, 120)\nstart = manual.start()\nprint(f\"   Started: {start['success']}\")\nprint(f\"   Recommended stars: {len(start['recommended_stars'])}\")\n\n# 6. 自动校准\nprint(\"\\n[6] 自动校准测试\")\nfrom calibrate.calibration_auto import AutoCalibration\n\nauto = AutoCalibration('192.168.1.100', 40, 120)\nstart = auto.start()\nprint(f\"   Started: {start['success']}\")\n\n# 7. 存储模块\nprint(\"\\n[7] 存储模块测试\")\nfrom calibrate.calibration_store import save_calibration, load_calibration, list_calibrated_devices\n\nresult = save_calibration(\n    device_ip='192.168.1.100',\n    params={'IA': 0.5, 'IH': -0.3, 'NP': 0.1},\n    obs_lat=40,\n    obs_lon=120\n)\nprint(f\"   Save result: {result['success']}\")\n\nloaded = load_calibration('192.168.1.100')\nprint(f\"   Load result: {loaded is not None}\")\n\ndevices = list_calibrated_devices()\nprint(f\"   Calibrated devices: {len(devices)}\")\n\n# 8. API 路由\nprint(\"\\n[8] API 路由测试\")\nfrom calibrate.router import router\n\nprint(f\"   Router prefix: {router.prefix}\")\nprint(f\"   Routes count: {len(router.routes)}\")\n\n# 9. 主服务集成\nprint(\"\\n[9] 主服务集成测试\")\ntry:\n    from src.main.main import app\n    print(f\"   FastAPI routes: {len(app.routes)}\")\n    print(f\"   Integration: OK\")\nexcept Exception as e:\n    print(f\"   Integration error: {e}\")\n\nprint(\"\\n\" + \"=\" * 50)\nprint(\"All tests completed!\")\nprint(\"=\" * 50)\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\test_all.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":93895,"output":944,"cacheRead":0,"cacheWrite":0,"totalTokens":94839,"cost":{"input":0.09389499999999999,"output":0.0030208,"cacheRead":0,"cacheWrite":0,"total":0.0969158}},"stopReason":"toolUse","timestamp":1780517587386,"responseId":"cht000dfc0e@dx19e8f1e4c5ab992462"}}
