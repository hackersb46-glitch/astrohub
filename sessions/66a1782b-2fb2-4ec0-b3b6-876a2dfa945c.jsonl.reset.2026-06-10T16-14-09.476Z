{"type":"message","id":"5098d4a9","parentId":"bc5c2ca8","timestamp":"2026-06-03T20:18:49.948Z","message":{"role":"assistant","content":[{"type":"text","text":"现在添加天文校准的具体实现函数："},{"type":"toolCall","id":"call_6d364508d95f493487b7bbb5","name":"edit","arguments":{"edits":[{"newText":"// 更新视频状态\nfunction updateAdvVideoStatus() {\n    const statusEl = document.getElementById('advVideoStatus');\n    if (window.connectedDevice && window.connectedDevice.ip) {\n        if (statusEl) statusEl.textContent = '已连接: ' + window.connectedDevice.ip;\n    } else {\n        if (statusEl) statusEl.textContent = '连接设备后显示实时画面';\n    }\n}\n\n// 天文校准功能\nlet astroCalSession = null;\nlet astroCalMethod = 'manual'; // 'manual' or 'auto'\n\nfunction startAstroCalibration(deviceIp, username, password) {\n    addAdvOutput('info', '启动天文校准...');\n    \n    // 获取观测站位置（从配置或默认值）\n    const obsLat = window.astroCalConfig?.obs_lat || 29.45;\n    const obsLon = window.astroCalConfig?.obs_lon || 100.33;\n    \n    fetch('/api/v1/calibrate/start', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: deviceIp,\n            obs_lat: obsLat,\n            obs_lon: obsLon,\n            method: astroCalMethod\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            astroCalSession = deviceIp;\n            addAdvOutput('success', '校准会话已创建');\n            \n            if (astroCalMethod === 'manual' && data.recommended_stars) {\n                showAstroCalStars(data.recommended_stars);\n            } else {\n                addAdvOutput('info', '请拍摄天空进行星图解析');\n            }\n            \n            renderAstroCalPanel();\n        } else {\n            addAdvOutput('error', data.message || '启动失败');\n        }\n    })\n    .catch(e => {\n        addAdvOutput('error', '请求异常: ' + e.message);\n    });\n}\n\nfunction showAstroCalStars(stars) {\n    addAdvOutput('info', '推荐校准星:');\n    stars.forEach((star, i) => {\n        addAdvOutput('test', (i+1) + '. ' + star.name + ' (Az=' + star.az.toFixed(1) + ', Alt=' + star.alt.toFixed(1) + ')');\n    });\n}\n\nfunction renderAstroCalPanel() {\n    const resultEl = document.getElementById('advResult');\n    \n    let html = '<div style=\"font-size:12px\">';\n    html += '<div style=\"margin-bottom:8px;font-weight:600;color:#58a6ff\">🌟 天文校准</div>';\n    \n    // 校准方法选择\n    html += '<div style=\"margin-bottom:12px\">';\n    html += '<label style=\"color:#8b949e;margin-right:12px\"><input type=\"radio\" name=\"calMethod\" value=\"manual\" ' + (astroCalMethod === 'manual' ? 'checked' : '') + ' onchange=\"setAstroCalMethod(\\'manual\\')\"> 手动对准</label>';\n    html += '<label style=\"color:#8b949e\"><input type=\"radio\" name=\"calMethod\" value=\"auto\" ' + (astroCalMethod === 'auto' ? 'checked' : '') + ' onchange=\"setAstroCalMethod(\\'auto\\')\"> 自动解析</label>';\n    html += '</div>';\n    \n    // 操作区域\n    if (astroCalMethod === 'manual') {\n        html += '<div style=\"margin-bottom:8px\">';\n        html += '<select id=\"astroCalStar\" style=\"width:100%;padding:6px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0\">';\n        html += '<option value=\"\">选择恒星</option>';\n        html += '</select>';\n        html += '</div>';\n        html += '<button class=\"btn btn-primary btn-sm\" style=\"width:100%\" onclick=\"recordAstroCalPoint()\">📍 记录当前位置</button>';\n    } else {\n        html += '<button class=\"btn btn-primary btn-sm\" style=\"width:100%;margin-bottom:8px\" onclick=\"captureAndSolve()\">📷 拍摄并解析</button>';\n    }\n    \n    // 状态显示\n    html += '<div id=\"astroCalStatus\" style=\"margin-top:12px;padding:8px;background:#0d1117;border-radius:4px;color:#8b949e\">';\n    html += '等待操作...';\n    html += '</div>';\n    \n    // 计算按钮\n    html += '<div style=\"margin-top:12px;display:flex;gap:8px\">';\n    html += '<button class=\"btn btn-warning btn-sm\" style=\"flex:1\" onclick=\"computeAstroCal()\">计算参数</button>';\n    html += '<button class=\"btn btn-secondary btn-sm\" style=\"flex:1\" onclick=\"saveAstroCal()\">保存</button>';\n    html += '</div>';\n    \n    html += '</div>';\n    resultEl.innerHTML = html;\n    \n    // 加载推荐星\n    if (astroCalMethod === 'manual') {\n        loadAstroCalStars();\n    }\n}\n\nfunction setAstroCalMethod(method) {\n    astroCalMethod = method;\n    renderAstroCalPanel();\n}\n\nfunction loadAstroCalStars() {\n    if (!window.connectedDevice) return;\n    \n    const obsLat = window.astroCalConfig?.obs_lat || 29.45;\n    const obsLon = window.astroCalConfig?.obs_lon || 100.33;\n    \n    fetch('/api/v1/calibrate/stars/recommended?lat=' + obsLat + '&lon=' + obsLon + '&count=5')\n    .then(r => r.json())\n    .then(data => {\n        if (data.success && data.recommended_stars) {\n            const select = document.getElementById('astroCalStar');\n            if (select) {\n                select.innerHTML = '<option value=\"\">选择恒星</option>';\n                data.recommended_stars.forEach(star => {\n                    select.innerHTML += '<option value=\"' + star.name + '\">' + star.name + ' (Az=' + star.az.toFixed(1) + ', Alt=' + star.alt.toFixed(1) + ')</option>';\n                });\n            }\n        }\n    });\n}\n\nfunction recordAstroCalPoint() {\n    if (!astroCalSession || !window.connectedDevice) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    const starSelect = document.getElementById('astroCalStar');\n    const starName = starSelect ? starSelect.value : '';\n    \n    if (!starName) {\n        addAdvOutput('warn', '请先选择恒星');\n        return;\n    }\n    \n    // 先选择恒星\n    fetch('/api/v1/calibrate/select_star', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: astroCalSession,\n            star_name: starName\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (!data.success) {\n            addAdvOutput('error', data.message || '选择失败');\n            return;\n        }\n        \n        // 获取当前PTZ位置并记录\n        const pan = window.connectedDevice.lastPan || 0;\n        const tilt = window.connectedDevice.lastTilt || 0;\n        \n        return fetch('/api/v1/calibrate/record', {\n            method: 'POST',\n            headers: {'Content-Type': 'application/json'},\n            body: JSON.stringify({\n                device_ip: astroCalSession,\n                pan: pan,\n                tilt: tilt\n            })\n        });\n    })\n    .then(r => r && r.json())\n    .then(data => {\n        if (data && data.success) {\n            addAdvOutput('success', '记录校准点 #' + data.point_index);\n            updateAstroCalStatus(data.coverage);\n        } else if (data) {\n            addAdvOutput('error', data.message || '记录失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction captureAndSolve() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    addAdvOutput('info', '拍摄并解析中...');\n    \n    const pan = window.connectedDevice?.lastPan || 0;\n    const tilt = window.connectedDevice?.lastTilt || 0;\n    \n    fetch('/api/v1/calibrate/capture', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({\n            device_ip: astroCalSession,\n            pan: pan,\n            tilt: tilt\n        })\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '解析成功: RA=' + data.ra.toFixed(2) + 'h, DEC=' + data.dec.toFixed(2) + '°');\n            updateAstroCalStatus(data.coverage);\n        } else {\n            addAdvOutput('error', data.message || '解析失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction updateAstroCalStatus(coverage) {\n    const statusEl = document.getElementById('astroCalStatus');\n    if (!statusEl || !coverage) return;\n    \n    let html = '校准点: ' + (coverage.total_points || 0) + ' | ';\n    html += 'Az覆盖: ' + coverage.az_spread.toFixed(0) + '° | ';\n    html += 'Alt覆盖: ' + coverage.alt_spread.toFixed(0) + '°';\n    \n    if (coverage.needs_more) {\n        html += '<br><span style=\"color:#d29922\">需要更多校准点</span>';\n    } else {\n        html += '<br><span style=\"color:#3fb950\">可以计算参数</span>';\n    }\n    \n    statusEl.innerHTML = html;\n}\n\nfunction computeAstroCal() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先启动校准');\n        return;\n    }\n    \n    addAdvOutput('info', '计算校准参数...');\n    \n    fetch('/api/v1/calibrate/compute', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({device_ip: astroCalSession})\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '计算成功!');\n            if (data.params) {\n                addAdvOutput('info', 'IA=' + data.params.IA?.toFixed(3) + '°, IH=' + data.params.IH?.toFixed(3) + '°');\n            }\n            if (data.rms) {\n                addAdvOutput('info', 'RMS: Az=' + (data.rms.az || 0).toFixed(3) + '°, Alt=' + (data.rms.alt || 0).toFixed(3) + '°');\n            }\n        } else {\n            addAdvOutput('error', data.message || '计算失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n\nfunction saveAstroCal() {\n    if (!astroCalSession) {\n        addAdvOutput('error', '请先完成校准计算');\n        return;\n    }\n    \n    fetch('/api/v1/calibrate/save', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({device_ip: astroCalSession})\n    })\n    .then(r => r.json())\n    .then(data => {\n        if (data.success) {\n            addAdvOutput('success', '校准结果已保存');\n        } else {\n            addAdvOutput('error', data.message || '保存失败');\n        }\n    })\n    .catch(e => addAdvOutput('error', '请求异常: ' + e.message));\n}\n</script>","oldText":"// 更新视频状态\nfunction updateAdvVideoStatus() {\n    const statusEl = document.getElementById('advVideoStatus');\n    if (window.connectedDevice && window.connectedDevice.ip) {\n        if (statusEl) statusEl.textContent = '已连接: ' + window.connectedDevice.ip;\n    } else {\n        if (statusEl) statusEl.textContent = '连接设备后显示实时画面';\n    }\n}\n</script>"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\advanced.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":105331,"output":3186,"cacheRead":0,"cacheWrite":0,"totalTokens":108517,"cost":{"input":0.105331,"output":0.010195200000000001,"cacheRead":0,"cacheWrite":0,"total":0.1155262}},"stopReason":"toolUse","timestamp":1780517873633,"responseId":"cht000d704e@dx19e8f22af53b87e692"}}
