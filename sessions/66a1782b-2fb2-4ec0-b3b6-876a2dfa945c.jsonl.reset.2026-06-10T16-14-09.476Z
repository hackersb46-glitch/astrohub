{"type":"message","id":"ac7f5e94","parentId":"8397b4bd","timestamp":"2026-06-04T06:10:30.702Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tool-ae224fcc4afd476baef10a56458c6a62","name":"write","arguments":{"content":"# stack 包初始化\n\"\"\"\n图像叠加降噪模块\n\n功能：\n- 星点检测 (photutils DAOStarFinder)\n- 图像对齐 (astroalign 三角形法)\n- Sigma Clipping 叠加 (ccdproc)\n- FITS + JPG 输出\n\n档位：\n- 关闭叠加 (仅 JPG)\n- 2s / 5s / 10s / 30s 预设\n- 自定义时间\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom .detect import detect_stars, StarDetector\nfrom .align import align_images, ImageAligner\nfrom .stack import stack_frames, FrameStacker\nfrom .output import save_fits, save_jpg, OutputWriter\nfrom .process import StackProcessor\n\n__all__ = [\n    'detect_stars',\n    'StarDetector',\n    'align_images',\n    'ImageAligner',\n    'stack_frames',\n    'FrameStacker',\n    'save_fits',\n    'save_jpg',\n    'OutputWriter',\n    'StackProcessor',\n]","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\__init__.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":117470,"output":260,"cacheRead":0,"cacheWrite":0,"totalTokens":117730,"cost":{"input":0.11746999999999999,"output":0.0008320000000000001,"cacheRead":0,"cacheWrite":0,"total":0.11830199999999999}},"stopReason":"toolUse","timestamp":1780553401189,"responseId":"cht000d6433@dx19e9140df69b87e692"}}
