{"type":"message","id":"751613be","parentId":"63e4f7f7","timestamp":"2026-06-04T06:20:30.510Z","message":{"role":"assistant","content":[{"type":"text","text":"测试脚本需要从包外运行。创建独立测试脚本："},{"type":"toolCall","id":"call_e6c3eefb988e45ee9a874675","name":"write","arguments":{"content":"#!/usr/bin/env python\n\"\"\"叠加模块完整测试\"\"\"\n\nimport sys\nfrom pathlib import Path\n\n# 添加项目根目录\n_project_root = str(Path(__file__).resolve().parent.parent)\nif _project_root not in sys.path:\n    sys.path.insert(0, _project_root)\n\nimport time\nimport numpy as np\n\nprint(\"=\" * 50)\nprint(\"图像叠加模块测试\")\nprint(\"=\" * 50)\n\n# 测试星点检测\nprint(\"\\n[1] 星点检测测试\")\nfrom stack.detect import StarDetector, detect_stars, HAS_PHOTUTILS\n\ndetector = StarDetector(fwhm=3.0, threshold=5.0)\n\n# 创建测试图像\ntest_img = np.zeros((100, 100), dtype=np.float32)\nfor x, y, brightness in [(30, 30, 100), (50, 50, 200), (70, 70, 150)]:\n    test_img[y-2:y+3, x-2:x+3] = brightness\n\nstars = detector.detect(test_img, use_photutils=False)\nprint(f\"   检测到 {len(stars)} 个星点\")\nprint(f\"   photutils 可用: {HAS_PHOTUTILS}\")\n\n# 测试图像对齐\nprint(\"\\n[2] 图像对齐测试\")\nfrom stack.align import ImageAligner, align_images, HAS_ASTROALIGN\n\nref = np.zeros((100, 100), dtype=np.float32)\nref[40:60, 40:60] = 100\n\nsrc = np.zeros((100, 100), dtype=np.float32)\nsrc[45:65, 45:65] = 100  # 平移 +5\n\naligner = ImageAligner(method='phase')\naligned, info = aligner.align(src, ref)\nprint(f\"   对齐方法: {info['method']}\")\nprint(f\"   位移: ({info.get('shift_x', 0):.2f}, {info.get('shift_y', 0):.2f})\")\nprint(f\"   astroalign 可用: {HAS_ASTROALIGN}\")\n\n# 测试叠加\nprint(\"\\n[3] 叠加测试\")\nfrom stack.stack import FrameStacker, stack_frames, HAS_CCDPROC\n\nframes = []\nnp.random.seed(42)\nfor i in range(10):\n    base = np.ones((50, 50)) * 100\n    base[20:30, 20:30] = 500\n    noise = np.random.normal(0, 10, (50, 50))\n    frames.append(base + noise)\n\nstacker = FrameStacker(method='sigma_clip')\nresult = stacker.stack(frames)\nprint(f\"   输入帧数: {len(frames)}\")\nprint(f\"   输出形状: {result.shape}\")\nprint(f\"   输出类型: {result.dtype}\")\nprint(f\"   ccdproc 可用: {HAS_CCDPROC}\")\n\n# 测试输出\nprint(\"\\n[4] 输出测试\")\nfrom stack.output import OutputWriter, save_fits, save_jpg, HAS_ASTROPY\n\nwriter = OutputWriter(output_dir=\"stack/output\")\ntest_result = np.random.rand(100, 100).astype(np.float32) * 1000\n\noutput = writer.save(\n    image=test_result,\n    basename=\"test_output\",\n    exposure_time=10.0,\n    n_frames=100,\n)\nprint(f\"   FITS: {output.get('fits_path', 'N/A')}\")\nprint(f\"   JPG: {output.get('jpg_path', 'N/A')}\")\nprint(f\"   astropy 可用: {HAS_ASTROPY}\")\n\n# 测试完整流程\nprint(\"\\n[5] 完整流程测试\")\nfrom stack.process import StackProcessor, STACK_PRESETS\n\ndef mock_frame_source():\n    np.random.seed(int(time.time() * 1000) % 1000)\n    base = np.ones((100, 100)) * 100\n    base[40:60, 40:60] = 500\n    noise = np.random.normal(0, 10, (100, 100))\n    return base + noise\n\nprocessor = StackProcessor(output_dir=\"stack/output\")\n\n# 测试 2s 档\nresult = processor.process(\n    frame_source=mock_frame_source,\n    mode='2s',\n    basename=\"test_2s\",\n)\nprint(f\"   2s档: {result['message']}\")\n\n# 测试关闭叠加\nresult_off = processor.process(\n    frame_source=mock_frame_source,\n    mode='off',\n    basename=\"test_off\",\n)\nprint(f\"   关闭叠加: {result_off['message']}\")\n\n# 预设档位\nprint(f\"   预设档位: {list(STACK_PRESETS.keys())}\")\n\nprint(\"\\n\" + \"=\" * 50)\nprint(\"所有测试通过!\")\nprint(\"=\" * 50)","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\test_all.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":128998,"output":1097,"cacheRead":0,"cacheWrite":0,"totalTokens":130095,"cost":{"input":0.128998,"output":0.0035104000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1325084}},"stopReason":"toolUse","timestamp":1780553939683,"responseId":"cht000d20a1@dx19e91495061b87e692"}}
