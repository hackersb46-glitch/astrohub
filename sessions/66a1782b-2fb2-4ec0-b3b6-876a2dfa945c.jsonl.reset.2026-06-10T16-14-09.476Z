{"type":"message","id":"8ec1c298","parentId":"b682268e","timestamp":"2026-06-04T06:13:38.867Z","message":{"role":"assistant","content":[{"type":"text","text":"**Step 3: 叠加算法模块**"},{"type":"toolCall","id":"call_c201225709c140deac1ac110","name":"write","arguments":{"content":"\"\"\"\n图像叠加模块\n\n使用 ccdproc 进行 Sigma Clipping 叠加。\n支持 Mean、Median 叠加作为备选。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport numpy as np\nfrom typing import Optional, List\n\n# 尝试导入 ccdproc\ntry:\n    from ccdproc import Combiner\n    from astropy.nddata import CCDData\n    from astropy import units as u\n    HAS_CC DPROC = True\nexcept ImportError:\n    HAS_CC DPROC = False\n    Combiner = None\n    CCDData = None\n    u = None\n\n\nclass FrameStacker:\n    \"\"\"\n    图像叠加器\n    \n    支持多种叠加方法：\n    1. Sigma Clipping + Mean (推荐，专业天文首选)\n    2. Median (异常值抵抗强)\n    3. Mean (最快，但无异常值抵抗)\n    \"\"\"\n    \n    def __init__(\n        self,\n        method: str = 'sigma_clip',\n        sigma_low: float = 3.0,\n        sigma_high: float = 3.0,\n        max_iter: int = 5,\n    ):\n        \"\"\"\n        初始化叠加器\n        \n        Args:\n            method: 叠加方法 ('sigma_clip', 'median', 'mean')\n            sigma_low: Sigma clipping 下限阈值\n            sigma_high: Sigma clipping 上限阈值\n            max_iter: 最大迭代次数\n        \"\"\"\n        self.method = method\n        self.sigma_low = sigma_low\n        self.sigma_high = sigma_high\n        self.max_iter = max_iter\n    \n    def stack(self, frames: List[np.ndarray]) -> np.ndarray:\n        \"\"\"\n        叠加多帧图像\n        \n        Args:\n            frames: 图像列表 (已对齐)\n        \n        Returns:\n            叠加结果 (32-bit float)\n        \"\"\"\n        if not frames:\n            raise ValueError(\"图像列表为空\")\n        \n        if len(frames) == 1:\n            return frames[0].astype(np.float32)\n        \n        # 根据帧数选择方法\n        if len(frames) < 5 and self.method == 'sigma_clip':\n            # 帧数太少，Sigma Clip 不稳定\n            method = 'median'\n        else:\n            method = self.method\n        \n        if HAS_CC DPROC and method == 'sigma_clip':\n            return self._stack_ccdproc(frames)\n        else:\n            return self._stack_numpy(frames, method)\n    \n    def _stack_ccdproc(self, frames: List[np.ndarray]) -> np.ndarray:\n        \"\"\"\n        使用 ccdproc 进行 Sigma Clipping 叠加\n        \n        优点：\n        - 专业级实现\n        - 自动处理 NaN\n        - 可计算不确定性\n        \"\"\"\n        # 转换为 CCDData\n        ccd_frames = []\n        for frame in frames:\n            if frame.dtype != np.float32:\n                frame = frame.astype(np.float32)\n            ccd = CCDData(frame, unit=u.adu)\n            ccd_frames.append(ccd)\n        \n        # 创建 Combiner\n        combiner = Combiner(ccd_frames)\n        \n        # Sigma Clipping\n        combiner.sigma_clipping(\n            low_thresh=self.sigma_low,\n            high_thresh=self.sigma_high,\n            func='mean',\n        )\n        \n        # 平均叠加\n        result = combiner.average_combine()\n        \n        return result.data.astype(np.float32)\n    \n    def _stack_numpy(\n        self,\n        frames: List[np.ndarray],\n        method: str,\n    ) -> np.ndarray:\n        \"\"\"\n        使用 numpy 进行叠加 (无 ccdproc 时的降级方案)\n        \"\"\"\n        # 转换为 float32 数组\n        stack = np.array([f.astype(np.float32) for f in frames])\n        \n        if method == 'mean':\n            result = np.mean(stack, axis=0)\n        \n        elif method == 'median':\n            result = np.median(stack, axis=0)\n        \n        elif method == 'sigma_clip':\n            # 简化版 Sigma Clipping\n            mean = np.mean(stack, axis=0)\n            std = np.std(stack, axis=0)\n            \n            # 防止除零\n            std = np.where(std < 1e-6, 1.0, std)\n            \n            # 创建掩码\n            mask = np.abs(stack - mean) <= self.sigma_high * std\n            \n            # 应用掩码后的均值\n            masked_sum = np.sum(stack * mask, axis=0)\n            masked_count = np.sum(mask, axis=0)\n            \n            # 防止除零\n            masked_count = np.where(masked_count < 1, 1, masked_count)\n            \n            result = masked_sum / masked_count\n        \n        else:\n            raise ValueError(f\"未知叠加方法: {method}\")\n        \n        return result.astype(np.float32)\n    \n    def stack_with_rejection(\n        self,\n        frames: List[np.ndarray],\n        reject_method: str = 'minmax',\n        nlow: int = 1,\n        nhigh: int = 1,\n    ) -> np.ndarray:\n        \"\"\"\n        带 MinMax 拒绝的叠加\n        \n        Args:\n            frames: 图像列表\n            reject_method: 拒绝方法 ('minmax', 'sigma')\n            nlow: 剔除最小 N 个值\n            nhigh: 剔除最大 N 个值\n        \n        Returns:\n            叠加结果\n        \"\"\"\n        if len(frames) <= nlow + nhigh:\n            # 帧数太少，直接取均值\n            return np.mean([f.astype(np.float32) for f in frames], axis=0)\n        \n        # 转换为数组\n        stack = np.array([f.astype(np.float32) for f in frames])\n        \n        if reject_method == 'minmax':\n            # MinMax clipping (IRAF 风格)\n            sorted_stack = np.sort(stack, axis=0)\n            clipped = sorted_stack[nlow:-nhigh] if nhigh > 0 else sorted_stack[nlow:]\n            result = np.mean(clipped, axis=0)\n        \n        else:\n            result = self._stack_numpy(frames, 'sigma_clip')\n        \n        return result\n\n\ndef stack_frames(\n    frames: List[np.ndarray],\n    method: str = 'sigma_clip',\n    sigma: float = 3.0,\n) -> np.ndarray:\n    \"\"\"\n    快捷函数：叠加帧\n    \n    Args:\n        frames: 图像列表\n        method: 叠加方法\n        sigma: Sigma clipping 阈值\n    \n    Returns:\n        叠加结果\n    \"\"\"\n    stacker = FrameStacker(\n        method=method,\n        sigma_low=sigma,\n        sigma_high=sigma,\n    )\n    return stacker.stack(frames)\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试图像叠加模块\")\n    \n    # 创建测试图像\n    frames = []\n    np.random.seed(42)\n    \n    for i in range(10):\n        base = np.ones((50, 50)) * 100  # 背景\n        base[20:30, 20:30] = 500  # 星点\n        noise = np.random.normal(0, 10, (50, 50))  # 噪声\n        frames.append(base + noise)\n    \n    # 叠加\n    stacker = FrameStacker(method='sigma_clip')\n    result = stacker.stack(frames)\n    \n    print(f\"输入帧数: {len(frames)}\")\n    print(f\"输出形状: {result.shape}\")\n    print(f\"输出类型: {result.dtype}\")\n    print(f\"ccdproc 可用: {HAS_CC DPROC}\")\n    print(\"测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\stack.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":127852,"output":1677,"cacheRead":0,"cacheWrite":0,"totalTokens":129529,"cost":{"input":0.127852,"output":0.0053664,"cacheRead":0,"cacheWrite":0,"total":0.1332184}},"stopReason":"toolUse","timestamp":1780553556788,"responseId":"cht000fbf33@dx19e914348d0b8ab592"}}
