{"type":"message","id":"ec5e9665","parentId":"a2afd620","timestamp":"2026-06-03T19:44:27.735Z","message":{"role":"assistant","content":[{"type":"text","text":"**Phase 1.3：Plate Solve 模块**"},{"type":"toolCall","id":"tool-bb2956de798c43feb7650ec7f1d8abf0","name":"write","arguments":{"content":"\"\"\"\nPlate Solve 模块\n\n调用 ASTAP 进行星图识别，返回图像中心点的 RA/DEC。\n\n依赖：ASTAP 软件（需用户自行安装）\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport os\nimport subprocess\nimport re\nfrom pathlib import Path\nfrom typing import Optional\n\n# ASTAP 默认路径（Windows）\nASTAP_DEFAULT_PATHS = [\n    \"C:\\\\Program Files\\\\ASTAP\\\\astap.exe\",\n    \"C:\\\\Program Files (x86)\\\\ASTAP\\\\astap.exe\",\n    \"C:\\\\ASTAP\\\\astap.exe\",\n    os.path.expanduser(\"~\\\\ASTAP\\\\astap.exe\"),\n]\n\n# Linux/macOS 路径\nASTAP_LINUX_PATHS = [\n    \"/usr/bin/astap\",\n    \"/usr/local/bin/astap\",\n    \"/opt/astap/astap\",\n    \"~/astap/astap\",\n]\n\n\ndef find_astap_path() -> Optional[str]:\n    \"\"\"\n    查找 ASTAP 可执行文件路径\n\n    Returns:\n        ASTAP 路径或 None\n    \"\"\"\n    # 根据操作系统选择搜索路径\n    if os.name == 'nt':  # Windows\n        search_paths = ASTAP_DEFAULT_PATHS\n    else:  # Linux/macOS\n        search_paths = ASTAP_LINUX_PATHS\n\n    for path in search_paths:\n        full_path = os.path.expanduser(path)\n        if os.path.isfile(full_path):\n            return full_path\n\n    # 尝试在 PATH 中查找\n    try:\n        result = subprocess.run(\n            ['astap', '--version'],\n            capture_output=True,\n            text=True,\n            timeout=5\n        )\n        if result.returncode == 0:\n            return 'astap'  # 在 PATH 中\n    except Exception:\n        pass\n\n    return None\n\n\ndef check_astap_installed() -> dict:\n    \"\"\"\n    检查 ASTAP 是否已安装\n\n    Returns:\n        {'installed': bool, 'path': str或None, 'version': str或None, 'message': str}\n    \"\"\"\n    path = find_astap_path()\n\n    if not path:\n        return {\n            'installed': False,\n            'path': None,\n            'version': None,\n            'message': 'ASTAP 未安装。请从 https://www.hnsky.org/astap.htm 下载安装。',\n        }\n\n    # 尝试获取版本\n    try:\n        result = subprocess.run(\n            [path, '--version'],\n            capture_output=True,\n            text=True,\n            timeout=5\n        )\n        version = result.stdout.strip() if result.stdout else 'unknown'\n    except Exception:\n        version = 'unknown'\n\n    return {\n        'installed': True,\n        'path': path,\n        'version': version,\n        'message': f'ASTAP 已安装: {path}',\n    }\n\n\ndef solve_image(\n    image_path: str,\n    fov_hint: Optional[float] = None,\n    astap_path: Optional[str] = None,\n    timeout: int = 60,\n) -> dict:\n    \"\"\"\n    进行星图识别（Plate Solve）\n\n    Args:\n        image_path: 图像文件路径\n        fov_hint: 视场角提示（度），可选，可加速解析\n        astap_path: ASTAP 可执行文件路径，可选\n        timeout: 超时时间（秒）\n\n    Returns:\n        成功时:\n            {'success': True, 'ra': 赤经(小时), 'dec': 赁纬(角度), 'rotation': 旋转角(角度), 'fov': 视场角(度)}\n\n        失败时:\n            {'success': False, 'error': 错误信息}\n    \"\"\"\n    # 检查图像文件\n    if not os.path.isfile(image_path):\n        return {\n            'success': False,\n            'error': f'图像文件不存在: {image_path}',\n        }\n\n    # 查找 ASTAP\n    if not astap_path:\n        astap_path = find_astap_path()\n\n    if not astap_path:\n        return {\n            'success': False,\n            'error': 'ASTAP 未安装',\n        }\n\n    # 创建临时输出目录\n    image_dir = os.path.dirname(image_path)\n    output_ini = os.path.join(image_dir, 'astap_result.ini')\n\n    # 构建 ASTAP 命令\n    # astap -f <image> -o <output> [-fov <degrees>]\n    cmd = [\n        astap_path,\n        '-f', image_path,\n        '-o', output_ini,\n    ]\n\n    if fov_hint:\n        cmd.extend(['-fov', str(fov_hint)])\n\n    # 执行 ASTAP\n    try:\n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            timeout=timeout,\n            cwd=image_dir,\n        )\n    except subprocess.TimeoutExpired:\n        return {\n            'success': False,\n            'error': f'ASTAP 执行超时 ({timeout}秒)',\n        }\n    except Exception as e:\n        return {\n            'success': False,\n            'error': f'ASTAP 执行异常: {str(e)}',\n        }\n\n    # 检查输出文件\n    if not os.path.isfile(output_ini):\n        # 检查 stderr 是否有错误信息\n        error_msg = result.stderr.strip() if result.stderr else '未生成结果文件'\n        return {\n            'success': False,\n            'error': f'解析失败: {error_msg}',\n        }\n\n    # 解析结果文件\n    try:\n        solution = parse_astap_ini(output_ini)\n    except Exception as e:\n        return {\n            'success': False,\n            'error': f'结果解析失败: {str(e)}',\n        }\n\n    # 清理临时文件\n    try:\n        os.remove(output_ini)\n    except Exception:\n        pass\n\n    return solution\n\n\ndef parse_astap_ini(ini_path: str) -> dict:\n    \"\"\"\n    解析 ASTAP 输出的 INI 文件\n\n    ASTAP 输出格式示例:\n        RA=05:35:16\n        DEC=-05:23:12\n        ORIENT=123.4\n        FOV=2.5\n        ...\n\n    Returns:\n        {'success': True, 'ra': ..., 'dec': ..., 'rotation': ..., 'fov': ...}\n    \"\"\"\n    with open(ini_path, 'r', encoding='utf-8', errors='ignore') as f:\n        content = f.read()\n\n    # 提取关键值\n    ra_str = extract_ini_value(content, 'RA')\n    dec_str = extract_ini_value(content, 'DEC')\n    orient_str = extract_ini_value(content, 'ORIENT')\n    fov_str = extract_ini_value(content, 'FOV')\n\n    if not ra_str or not dec_str:\n        return {\n            'success': False,\n            'error': 'INI 文件缺少 RA/DEC 信息',\n        }\n\n    # 转换 RA/DEC\n    try:\n        ra_hours = parse_ra_to_hours(ra_str)\n        dec_deg = parse_dec_to_degrees(dec_str)\n        rotation = float(orient_str) if orient_str else 0.0\n        fov = float(fov_str) if fov_str else 0.0\n    except Exception as e:\n        return {\n            'success': False,\n            'error': f'坐标转换失败: {str(e)}',\n        }\n\n    return {\n        'success': True,\n        'ra': round(ra_hours, 6),\n        'dec': round(dec_deg, 6),\n        'rotation': round(rotation, 4),\n        'fov': round(fov, 4),\n    }\n\n\ndef extract_ini_value(content: str, key: str) -> Optional[str]:\n    \"\"\"\n    从 INI 内容中提取指定键的值\n    \"\"\"\n    # 匹配格式: KEY=value 或 KEY = value\n    pattern = rf'{key}\\s*[=:]\\s*(.+)'\n    match = re.search(pattern, content, re.IGNORECASE)\n\n    if match:\n        return match.group(1).strip()\n\n    return None\n\n\ndef parse_ra_to_hours(ra_str: str) -> float:\n    \"\"\"\n    将 RA 字符串转换为小时\n\n    支持格式:\n        - 05:35:16 (时分秒)\n        - 83.75 (角度)\n        - 5.59 (小时)\n    \"\"\"\n    ra_str = ra_str.strip()\n\n    # 时分秒格式\n    if ':' in ra_str:\n        parts = ra_str.split(':')\n        hours = float(parts[0])\n        minutes = float(parts[1]) if len(parts) > 1 else 0\n        seconds = float(parts[2]) if len(parts) > 2 else 0\n        return hours + minutes / 60 + seconds / 3600\n\n    # 角度格式 (>24 表示角度)\n    value = float(ra_str)\n    if value > 24:\n        return value / 15  # 角度转小时\n\n    return value\n\n\ndef parse_dec_to_degrees(dec_str: str) -> float:\n    \"\"\"\n    将 DEC 字符串转换为角度\n\n    支持格式:\n        - -05:23:12 (度分秒)\n        - -5.39 (角度)\n    \"\"\"\n    dec_str = dec_str.strip()\n\n    # 度分秒格式\n    if ':' in dec_str:\n        parts = dec_str.split(':')\n        sign = -1 if parts[0].startswith('-') else 1\n        degrees = abs(float(parts[0]))\n        minutes = float(parts[1]) if len(parts) > 1 else 0\n        seconds = float(parts[2]) if len(parts) > 2 else 0\n        return sign * (degrees + minutes / 60 + seconds / 3600)\n\n    return float(dec_str)\n\n\ndef solve_image_online(\n    image_path: str,\n    api_url: str = \"http://nova.astrometry.net/api.php\",\n    api_key: Optional[str] = None,\n    timeout: int = 120,\n) -> dict:\n    \"\"\"\n    使用在线 astrometry.net API 解析（备用方案）\n\n    需要网络连接和 API key。\n\n    Args:\n        image_path: 图像路径\n        api_url: API 地址\n        api_key: API key（可选，可从 astrometry.net 获取）\n        timeout: 超时时间\n\n    Returns:\n        解析结果\n    \"\"\"\n    # 此功能需要网络请求，暂不实现\n    # 实际使用时可用 requests 库调用 astrometry.net API\n    return {\n        'success': False,\n        'error': '在线解析功能暂未实现，请使用 ASTAP 本地解析',\n    }\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试 Plate Solve 模块\")\n\n    # 检查 ASTAP 安装\n    status = check_astap_installed()\n    print(f\"\\nASTAP 状态: {status['message']}\")\n\n    if status['installed']:\n        print(f\"路径: {status['path']}\")\n        print(f\"版本: {status['version']}\")\n\n    # 测试 RA/DEC 解析\n    print(\"\\n测试坐标解析:\")\n    test_ra = parse_ra_to_hours(\"05:35:16\")\n    test_dec = parse_dec_to_degrees(\"-05:23:12\")\n    print(f\"RA '05:35:16' → {test_ra:.4f} 小时\")\n    print(f\"DEC '-05:23:12' → {test_dec:.4f} 度\")\n\n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\core\\plate_solve.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":69270,"output":2521,"cacheRead":0,"cacheWrite":0,"totalTokens":71791,"cost":{"input":0.06927,"output":0.0080672,"cacheRead":0,"cacheWrite":0,"total":0.0773372}},"stopReason":"toolUse","timestamp":1780515817421,"responseId":"cht000d8253@dx19e8f0349dfb9cb282"}}
