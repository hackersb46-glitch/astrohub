   import astroalign as aa\n    HAS_ASTROALIGN = True\nexcept ImportError:\n    HAS_ASTROALIGN = False\n    aa = None\n\nimport cv2\n\nfrom .detect import StarDetector\nfrom .output import OutputWriter\n\n\nclass LiveStack:\n    \"\"\"\n    Live Stack 实时叠加器\n    \n    特点：\n    - Running Mean 实时累加（O(1) 内存）\n    - XY + 旋转对齐（astroalign）\n    - 实时预览输出\n    \"\"\"\n    \n    def __init__(\n        self,\n        hardware_exposure_ms: float = 100,\n        fwhm: float = 3.0,\n        threshold: float = 5.0,\n        output_dir: str = \"stack/output\",\n        preview_interval: int = 5,  # 每 N 帧刷新预览\n    ):\n\n... (truncated)"},"isError":false,"timestamp":1780560796924}}
{"type":"message","id":"c1abef9d","parentId":"2d0ac693","timestamp":"2026-06-04T08:14:40.319Z","message":{"role":"assistant","content":[{"type":"text","text":"文件太复杂，直接重新编写一个更简洁的版本："},{"type":"toolCall","id":"tool-7557ceba8adf42f89191b2a3ebb114ee","name":"write","arguments":{"content":"\"\"\"\nLive Stack 实时叠加模块\n\n边采集边叠加，实时输出预览。\n必须包含 XY + 旋转对齐。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport time\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Optional, Callable\n\ntry:\n    import astroalign as aa\n    HAS_ASTROALIGN = True\nexcept ImportError:\n    HAS_ASTROALIGN = False\n\nimport cv2\n\nfrom .detect import StarDetector\nfrom .output import OutputWriter\n\n\nclass LiveStack:\n    \"\"\"\n    Live Stack 实时叠加器\n    \n    Running Mean + XY + 旋转对齐\n    \"\"\"\n    \n    def __init__(\n        self,\n        hardware_exposure_ms: float = 100,\n        output_dir: str = \"stack/output\",\n        fwhm: float = 3.0,\n        threshold: float = 5.0,\n    ):\n        self.hardware_exposure_ms = hardware_exposure_ms\n        self.output_dir = output_dir\n        \n        # 检测器\n        self.detector = StarDetector(fwhm=fwhm, threshold=threshold)\n        self.writer = OutputWriter(output_dir=output_dir)\n        \n        # Running Mean 状态\n        self.running_mean = None\n        self.frame_count = 0\n        self.reference_frame = None\n        \n        # 目标状态\n        self.target_frames = 0\n        self.target_exposure = 0\n        self.is_running = False\n    \n    def start(self, target_exposure: float) -> dict:\n        \"\"\"启动 Live Stack\"\"\"\n        self.target_exposure = target_exposure\n        self.target_frames = int(target_exposure * 1000 / self.hardware_exposure_ms)\n        \n        # 重置状态\n        self.running_mean = None\n        self.frame_count = 0\n        self.reference_frame = None\n        self.is_running = True\n        \n        return {\n            'success': True,\n            'target_frames': self.target_frames,\n            'hardware_exposure_ms': self.hardware_exposure_ms,\n            'message': f'Live Stack 启动: {self.target_frames} 帧',\n        }\n    \n    def add_frame(self, frame: np.ndarray) -> dict:\n        \"\"\"添加一帧\"\"\"\n        if not self.is_running:\n            return {'success': False, 'message': '未启动'}\n        \n        frame_float = frame.astype(np.float32)\n        \n        # 第一帧作为参考\n        if self.reference_frame is None:\n            self.reference_frame = frame_float\n            self.running_mean = frame_float.copy()\n            self.frame_count = 1\n            \n            return {\n                'success': True,\n                'frame_count': 1,\n                'is_reference': True,\n            }\n        \n        # 对齐\n        aligned = self._align_frame(frame_float)\n        \n        # Running Mean\n        self.frame_count += 1\n        alpha = 1.0 / self.frame_count\n        self.running_mean = self.running_mean * (1 - alpha) + aligned * alpha\n        \n        return {\n            'success': True,\n            'frame_count': self.frame_count,\n            'progress': self.frame_count / self.target_frames,\n        }\n    \n    def _align_frame(self, frame: np.ndarray) -> np.ndarray:\n        \"\"\"对齐帧 (XY + 旋转)\"\"\"\n        if HAS_ASTROALIGN:\n            try:\n                aligned, _ = aa.register(frame, self.reference_frame)\n                return aligned\n            except Exception:\n                pass\n        \n        # 降级：相位相关 (仅平移)\n        result = cv2.phaseCorrelate(self.reference_frame.astype(np.float32), \n                                    frame.astype(np.float32))\n        shift_x, shift_y = result[0][0], result[0][1]\n        \n        M = np.array([[1, 0, -shift_x], [0, 1, -shift_y]], dtype=np.float32)\n        h, w = frame.shape[:2]\n        aligned = cv2.warpAffine(frame, M, (w, h))\n        \n        return aligned\n    \n    def finish(self, basename: Optional[str] = None) -> dict:\n        \"\"\"完成叠加\"\"\"\n        self.is_running = False\n        \n        if self.frame_count < 1 or self.running_mean is None:\n            return {'success': False, 'message': '无帧数据'}\n        \n        if not basename:\n            basename = f\"live_stack_{datetime.now().strftime('%Y%m%d_%H%M%S')}\"\n        \n        output = self.writer.save(\n            image=self.running_mean,\n            basename=basename,\n            exposure_time=self.target_exposure,\n            n_frames=self.frame_count,\n        )\n        \n        return {\n            'success': True,\n            'fits_path': output.get('fits_path'),\n            'jpg_path': output.get('jpg_path'),\n            'frame_count': self.frame_count,\n            'exposure_time': self.target_exposure,\n            'message': f'完成: {self.frame_count}帧',\n        }\n    \n    def get_preview(self) -> Optional[np.ndarray]:\n        \"\"\"获取预览图 (8-bit)\"\"\"\n        if self.running_mean is None:\n            return None\n        \n        # 归一化到 8-bit\n        img = self.running_mean.astype(np.float64)\n        vmin = np.percentile(img, 1)\n        vmax = np.percentile(img, 99)\n        \n        if vmax - vmin < 1e-6:\n            return np.zeros_like(img, dtype=np.uint8)\n        \n        img_scaled = (img - vmin) / (vmax - vmin)\n        img_scaled = np.clip(img_scaled, 0, 1)\n        \n        return (img_scaled * 255).astype(np.uint8)\n    \n    def get_status(self) -> dict:\n        \"\"\"获取状态\"\"\"\n        return {\n            'is_running': self.is_running,\n            'frame_count': self.frame_count,\n            'target_frames': self.target_frames,\n            'progress': min(1.0, self.frame_count / self.target_frames) if self.target_frames > 0 else 0,\n        }\n    \n    def stop(self) -> None:\n        \"\"\"停止\"\"\"\n        self.is_running = False\n\n\n# 模块测试\nif __name__ == '__main__':\n    import sys\n    from pathlib import Path\n    _root = str(Path(__file__).resolve().parent.parent)\n    if _root not in sys.path:\n        sys.path.insert(0, _root)\n    \n    print(\"=\" * 50)\n    print(\"Live Stack 测试\")\n    print(\"=\" * 50)\n    \n    print(f\"astroalign 可用: {HAS_ASTROALIGN}\")\n    \n    live = LiveStack(hardware_exposure_ms=100, output_dir=\"stack/output_live\")\n    \n    # 启动\n    result = live.start(target_exposure=2.0)\n    print(f\"\\n启动: {result['message']}\")\n    \n    # 添加帧\n    np.random.seed(42)\n    for i in range(20):\n        base = np.ones((100, 100)) * 100\n        base[40:60, 40:60] = 500\n        \n        # 添加随机偏移\n        offset_x = np.random.randint(-3, 4)\n        offset_y = np.random.randint(-3, 4)\n        shifted = np.roll(base, offset_x, axis=1)\n        shifted = np.roll(shifted, offset_y, axis=0)\n        \n        noise = np.random.normal(0, 10, (100, 100))\n        frame = shifted + noise\n        \n        result = live.add_frame(frame.astype(np.uint8))\n        \n        if (i + 1) % 5 == 0:\n            print(f\"  帧 {i+1}/20: 进度 {result.get('progress', 0)*100:.0f}%\")\n    \n    # 完成\n    final = live.finish(basename=\"test_live_2s\")\n    print(f\"\\n完成: {final['message']}\")\n    print(f\"FITS: {final.get('fits_path', 'N/A')}\")\n    print(f\"JPG: {final.get('jpg_path', 'N/A')}\")\n    \n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\live_stack.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":143360,"output":1754,"cacheRead":0,"cacheWrite":0,"totalTokens":145114,"cost":{"input":0.14336,"output":0.0056128,"cacheRead":0,"cacheWrite":0,"total":0.1489728}},"stopReason":"toolUse","timestamp":1780560796927,"responseId":"cht000d1c55@dx19e91b1cddfb8aa822"}}
