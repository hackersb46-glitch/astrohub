{"type":"message","id":"ab9881bb","parentId":"a7135a24","timestamp":"2026-06-03T19:45:27.449Z","message":{"role":"assistant","content":[{"type":"text","text":"**Phase 1.4：T-Point 误差模型**"},{"type":"toolCall","id":"tool-d33dd31ed563421fbeed65afc6664192","name":"write","arguments":{"content":"\"\"\"\nT-Point 误差模型模块\n\n定义 PTZ 指向误差参数，计算修正量，最小二乘拟合。\n\n基于经典 T-Point 模型，包含基础6参数。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport math\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Optional\n\nfrom .coordinates import equatorial_to_altaz, apply_refraction\n\n\nclass PointingModel:\n    \"\"\"\n    PTZ 指向误差模型\n\n    基于 T-Point 的基础6参数模型:\n    - IA: 方位零点偏差 (Azimuth Index Error)\n    - IH: 高度零点偏差 (Altitude Index Error)\n    - NP: 轴不正交性 (Non-Perpendicularity)\n    - level_ns: 水平偏差-南北 (Level North-South)\n    - level_ew: 水平偏差-东西 (Level East-West)\n    - AW: 轴倾斜 (Axis Tilt)\n\n    误差方程:\n        ΔAz = IA + NP*tan(h) + (level_ns*cos(A) + level_ew*sin(A))*tan(h) + AW*sec(h)\n        Δh  = IH + level_ns*sin(A) - level_ew*cos(A)\n    \"\"\"\n\n    def __init__(self):\n        \"\"\"初始化模型参数\"\"\"\n        # 基础6参数（弧度）\n        self.params = {\n            'IA': 0.0,       # 方位零点偏差\n            'IH': 0.0,       # 高度零点偏差\n            'NP': 0.0,       # 轴不正交性\n            'level_ns': 0.0, # 水平偏差-南北\n            'level_ew': 0.0, # 水平偏差-东西\n            'AW': 0.0,       # 轴倾斜\n        }\n\n        # 模型元数据\n        self.fitted = False\n        self.fit_time = None\n        self.fit_rms = {'az': 0.0, 'alt': 0.0}\n        self.num_points = 0\n\n    def compute_correction(self, az: float, alt: float) -> tuple[float, float]:\n        \"\"\"\n        计算指向修正量\n\n        Args:\n            az: 方位角 (角度)\n            alt: 高度角 (角度)\n\n        Returns:\n            (ΔAz, ΔAlt) 修正量 (角度)\n        \"\"\"\n        # 角度转弧度\n        az_rad = math.radians(az)\n        alt_rad = math.radians(alt)\n\n        # 防止奇点（天顶）\n        if alt > 85:\n            alt_rad = math.radians(85)\n\n        # T-Point 误差方程\n        # ΔAz = IA + NP*tan(h) + (level_ns*cos(A) + level_ew*sin(A))*tan(h) + AW*sec(h)\n\n        tan_alt = math.tan(alt_rad)\n        sec_alt = 1.0 / math.cos(alt_rad) if math.cos(alt_rad) > 0.01 else 100.0  # 截断\n\n        delta_az = (\n            self.params['IA']\n            + self.params['NP'] * tan_alt\n            + self.params['level_ns'] * math.cos(az_rad) * tan_alt\n            + self.params['level_ew'] * math.sin(az_rad) * tan_alt\n            + self.params['AW'] * sec_alt\n        )\n\n        # Δh = IH + level_ns*sin(A) - level_ew*cos(A)\n        delta_alt = (\n            self.params['IH']\n            + self.params['level_ns'] * math.sin(az_rad)\n            - self.params['level_ew'] * math.cos(az_rad)\n        )\n\n        return math.degrees(delta_az), math.degrees(delta_alt)\n\n    def apply_correction(self, az: float, alt: float) -> tuple[float, float]:\n        \"\"\"\n        应用修正：返回修正后的方位/高度\n\n        Args:\n            az: 原始方位角 (角度)\n            alt: 原始高度角 (角度)\n\n        Returns:\n            (修正后方位角, 修正后高度角)\n        \"\"\"\n        delta_az, delta_alt = self.compute_correction(az, alt)\n\n        # 修正后坐标\n        az_corrected = az + delta_az\n        alt_corrected = alt + delta_alt\n\n        # 规范化方位角到 0-360\n        az_corrected = az_corrected % 360\n        if az_corrected < 0:\n            az_corrected += 360\n\n        # 高度角限制\n        alt_corrected = max(-90, min(90, alt_corrected))\n\n        return az_corrected, alt_corrected\n\n    def reverse_correction(self, az_target: float, alt_target: float) -> tuple[float, float]:\n        \"\"\"\n        反向修正：从目标坐标计算 PTZ 应指向的坐标\n\n        用于 GOTO 指令计算。\n\n        Args:\n            az_target: 目标方位角\n            alt_target: 目标高度角\n\n        Returns:\n            (PTZ方位角, PTZ高度角)\n        \"\"\"\n        # 当前参数对应的修正量\n        delta_az, delta_alt = self.compute_correction(az_target, alt_target)\n\n        # PTZ 应指向的坐标 = 目标坐标 - 修正量\n        az_ptz = az_target - delta_az\n        alt_ptz = alt_target - delta_alt\n\n        # 规范化\n        az_ptz = az_ptz % 360\n        if az_ptz < 0:\n            az_ptz += 360\n\n        alt_ptz = max(-90, min(90, alt_ptz))\n\n        return az_ptz, alt_ptz\n\n    def fit(self, calibration_points: list[dict], obs_lat: float, obs_lon: float) -> dict:\n        \"\"\"\n        最小二乘拟合校准参数\n\n        Args:\n            calibration_points: 校准点列表\n                [{'az_enc': PTZ方位读数, 'alt_enc': PTZ高度读数,\n                  'ra_actual': 实际赤经, 'dec_actual': 实际赤纬,\n                  'obs_time': 观测时间}, ...]\n            obs_lat: 观测站纬度 (角度)\n            obs_lon: 观测站经度 (角度)\n\n        Returns:\n            {'success': bool, 'params': {...}, 'rms_az': ..., 'rms_alt': ..., 'message': ...}\n        \"\"\"\n        if len(calibration_points) < 4:\n            return {\n                'success': False,\n                'params': self.params,\n                'rms_az': 0,\n                'rms_alt': 0,\n                'message': '校准点不足 (需要至少4个点)',\n            }\n\n        # 构建观测矩阵\n        try:\n            M, y = self._build_observation_matrix(calibration_points, obs_lat, obs_lon)\n        except Exception as e:\n            return {\n                'success': False,\n                'params': self.params,\n                'rms_az': 0,\n                'rms_alt': 0,\n                'message': f'矩阵构建失败: {str(e)}',\n            }\n\n        # 最小二乘求解\n        try:\n            x_hat = np.linalg.lstsq(M, y, rcond=None)[0]\n        except Exception as e:\n            return {\n                'success': False,\n                'params': self.params,\n                'rms_az': 0,\n                'rms_alt': 0,\n                'message': f'最小二乘求解失败: {str(e)}',\n            }\n\n        # 更新参数\n        param_names = ['IA', 'IH', 'NP', 'level_ns', 'level_ew', 'AW']\n        for i, name in enumerate(param_names):\n            self.params[name] = x_hat[i]\n\n        # 计算残差\n        residuals = y - M @ x_hat\n        n_az = len(calibration_points)\n        n_alt = len(calibration_points)\n\n        rms_az = math.sqrt(np.mean(residuals[:n_az] ** 2))\n        rms_alt = math.sqrt(np.mean(residuals[n_az:] ** 2))\n\n        # 转换为角度显示\n        rms_az_deg = math.degrees(rms_az)\n        rms_alt_deg = math.degrees(rms_alt)\n\n        # 更新元数据\n        self.fitted = True\n        self.fit_time = datetime.now().isoformat()\n        self.fit_rms = {'az': rms_az_deg, 'alt': rms_alt_deg}\n        self.num_points = len(calibration_points)\n\n        return {\n            'success': True,\n            'params': {k: math.degrees(v) for k, v in self.params.items()},  # 转为角度\n            'rms_az': round(rms_az_deg, 4),\n            'rms_alt': round(rms_alt_deg, 4),\n            'message': f'拟合成功，RMS: Az={rms_az_deg:.3f}°, Alt={rms_alt_deg:.3f}°',\n        }\n\n    def _build_observation_matrix(\n        self,\n        calibration_points: list[dict],\n        obs_lat: float,\n        obs_lon: float,\n    ) -> tuple[np.ndarray, np.ndarray]:\n        \"\"\"\n        构建观测矩阵\n\n        观测方程: M · x = y\n        x = [IA, IH, NP, level_ns, level_ew, AW]\n        y = [ΔAz_1, ΔAz_2, ..., ΔAlt_1, ΔAlt_2, ...]\n        \"\"\"\n        n = len(calibration_points)\n        M = np.zeros((2 * n, 6))\n        y = np.zeros(2 * n)\n\n        for i, point in enumerate(calibration_points):\n            # PTZ 读数\n            az_enc = math.radians(point['az_enc'])\n            alt_enc = math.radians(point['alt_enc'])\n\n            # 实际天文坐标 → Alt/Az\n            pos = equatorial_to_altaz(\n                ra=point['ra_actual'],\n                dec=point['dec_actual'],\n                obs_time=point['obs_time'],\n                lat=obs_lat,\n                lon=obs_lon,\n            )\n\n            # 理想位置（去除折射）\n            az_ideal = math.radians(pos['az'])\n            alt_ideal = math.radians(apply_refraction(pos['alt']))\n\n            # 观测残差\n            delta_az = az_enc - az_ideal\n            delta_alt = alt_enc - alt_ideal\n\n            y[i] = delta_az\n            y[n + i] = delta_alt\n\n            # Jacobian 矩阵\n            # ΔAz = IA + NP*tan(h) + level_ns*cos(A)*tan(h) + level_ew*sin(A)*tan(h) + AW*sec(h)\n            tan_alt = math.tan(alt_enc)\n            sec_alt = 1.0 / math.cos(alt_enc) if math.cos(alt_enc) > 0.01 else 100.0\n\n            # 方位方程 Jacobian\n            M[i, 0] = 1.0  # IA\n            M[i, 1] = 0.0  # IH (不影响方位)\n            M[i, 2] = tan_alt  # NP\n            M[i, 3] = math.cos(az_enc) * tan_alt  # level_ns\n            M[i, 4] = math.sin(az_enc) * tan_alt  # level_ew\n            M[i, 5] = sec_alt  # AW\n\n            # ΔAlt = IH + level_ns*sin(A) - level_ew*cos(A)\n            # 高度方程 Jacobian\n            M[n + i, 0] = 0.0  # IA (不影响高度)\n            M[n + i, 1] = 1.0  # IH\n            M[n + i, 2] = 0.0  # NP (不影响高度)\n            M[n + i, 3] = math.sin(az_enc)  # level_ns\n            M[n + i, 4] = -math.cos(az_enc)  # level_ew\n            M[n + i, 5] = 0.0  # AW (不影响高度)\n\n        return M, y\n\n    def get_params_degrees(self) -> dict:\n        \"\"\"\n        返回参数（角度单位）\n        \"\"\"\n        return {k: math.degrees(v) for k, v in self.params.items()}\n\n    def set_params_degrees(self, params: dict) -> None:\n        \"\"\"\n        设置参数（角度单位）\n        \"\"\"\n        for k, v in params.items():\n            if k in self.params:\n                self.params[k] = math.radians(v)\n\n    def to_dict(self) -> dict:\n        \"\"\"\n        导出模型为字典（用于存储）\n        \"\"\"\n        return {\n            'params': self.get_params_degrees(),\n            'fitted': self.fitted,\n            'fit_time': self.fit_time,\n            'fit_rms': self.fit_rms,\n            'num_points': self.num_points,\n        }\n\n    def from_dict(self, data: dict) -> None:\n        \"\"\"\n        从字典加载模型\n        \"\"\"\n        if 'params' in data:\n            self.set_params_degrees(data['params'])\n\n        self.fitted = data.get('fitted', False)\n        self.fit_time = data.get('fit_time')\n        self.fit_rms = data.get('fit_rms', {'az': 0.0, 'alt': 0.0})\n        self.num_points = data.get('num_points', 0)\n\n\ndef create_model_from_calibration(\n    calibration_points: list[dict],\n    obs_lat: float,\n    obs_lon: float,\n) -> tuple[PointingModel, dict]:\n    \"\"\"\n    从校准点创建模型\n\n    Args:\n        calibration_points: 校准点列表\n        obs_lat: 纬度\n        obs_lon: 经度\n\n    Returns:\n        (模型, 拟合结果)\n    \"\"\"\n    model = PointingModel()\n    result = model.fit(calibration_points, obs_lat, obs_lon)\n    return model, result\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试 T-Point 模型模块\")\n\n    # 创建模型\n    model = PointingModel()\n\n    # 测试修正计算\n    az, alt = 45, 60\n    delta_az, delta_alt = model.compute_correction(az, alt)\n    print(f\"\\n修正量计算: Az={az}°, Alt={alt}° → ΔAz={delta_az:.4f}°, ΔAlt={delta_alt:.4f}°\")\n\n    # 测试反向修正\n    az_ptz, alt_ptz = model.reverse_correction(az, alt)\n    print(f\"反向修正: 目标({az}°, {alt}°) → PTZ应指向({az_ptz:.2f}°, {alt_ptz:.2f}°)\")\n\n    # 测试拟合（使用模拟数据）\n    print(\"\\n测试拟合（模拟数据）:\")\n    from datetime import datetime\n\n    # 模拟校准点\n    sim_points = [\n        {'az_enc': 0, 'alt_enc': 30, 'ra_actual': 0, 'dec_actual': 30, 'obs_time': datetime(2024, 1, 1, 20, 0)},\n        {'az_enc': 90, 'alt_enc': 45, 'ra_actual': 6, 'dec_actual': 45, 'obs_time': datetime(2024, 1, 1, 20, 0)},\n        {'az_enc': 180, 'alt_enc': 60, 'ra_actual': 12, 'dec_actual': 60, 'obs_time': datetime(2024, 1, 1, 20, 0)},\n        {'az_enc': 270, 'alt_enc': 40, 'ra_actual': 18, 'dec_actual': 40, 'obs_time': datetime(2024, 1, 1, 20, 0)},\n    ]\n\n    result = model.fit(sim_points, obs_lat=40, obs_lon=120)\n    print(f\"拟合结果: {result['message']}\")\n    if result['success']:\n        print(f\"参数: {result['params']}\")\n\n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\core\\model.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":71830,"output":3570,"cacheRead":0,"cacheWrite":0,"totalTokens":75400,"cost":{"input":0.07182999999999999,"output":0.011424000000000002,"cacheRead":0,"cacheWrite":0,"total":0.083254}},"stopReason":"toolUse","timestamp":1780515867751,"responseId":"cht000dd456@dx19e8f040d86b828282"}}
