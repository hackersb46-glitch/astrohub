{"type":"message","id":"f161a2fd","parentId":"9b04d084","timestamp":"2026-06-03T19:43:37.408Z","message":{"role":"assistant","content":[{"type":"text","text":"**Phase 1.2：亮星星表模块**"},{"type":"toolCall","id":"call_f7b42f27d0bb47579240b6cd","name":"write","arguments":{"content":"\"\"\"\n亮星星表模块\n\n提供适合校准的亮星列表，基于 Hipparcos 星表。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport math\nfrom datetime import datetime\nfrom typing import Optional\n\nfrom .coordinates import equatorial_to_altaz\n\n\n# 亮星数据（Hipparcos 前50亮星，V < 2.0）\n# 格式：name, ra (小时), dec (角度), mag (星等), constellation (星座)\nBRIGHT_STARS = [\n    (\"天狼星 Sirius\", 6.752, -16.716, -1.46, \"大犬座\"),\n    (\"老人星 Canopus\", 6.399, -52.696, -0.74, \"船底座\"),\n    (\"大角星 Arcturus\", 14.261, 19.182, -0.05, \"牧夫座\"),\n    (\"织女星 Vega\", 18.616, 38.784, 0.03, \"天琴座\"),\n    (\"五车二 Capella\", 5.278, 45.998, 0.08, \"御夫座\"),\n    (\"参宿七 Rigel\", 5.242, -8.202, 0.13, \"猎户座\"),\n    (\"南河三 Procyon\", 7.655, 5.225, 0.34, \"小犬座\"),\n    (\"参宿四 Betelgeuse\", 5.919, 7.407, 0.42, \"猎户座\"),\n    (\"水委一 Achernar\", 1.629, -57.237, 0.46, \"波江座\"),\n    (\"马腹一 Hadar\", 14.064, -60.373, 0.61, \"半人马座\"),\n    (\"牛郎星 Altair\", 19.846, 8.868, 0.77, \"天鹰座\"),\n    (\"十字架二 Acrux\", 12.443, -63.099, 0.76, \"南十字座\"),\n    (\"毕宿五 Aldebaran\", 4.599, 16.509, 0.85, \"金牛座\"),\n    (\"心宿二 Antares\", 16.490, -26.432, 0.96, \"天蝎座\"),\n    (\"角宿一 Spica\", 13.420, -11.161, 0.97, \"室女座\"),\n    (\"北落师门 Fomalhaut\", 22.961, -29.622, 1.16, \"南鱼座\"),\n    (\"天津四 Deneb\", 20.691, 45.280, 1.25, \"天鹅座\"),\n    (\"南十字三 Mimosa\", 12.792, -59.689, 1.25, \"南十字座\"),\n    (\"轩辕十四 Regulus\", 10.140, 11.967, 1.40, \"狮子座\"),\n    (\"北极星 Polaris\", 37.954, 89.264, 1.98, \"小熊座\"),\n    (\"参宿五 Bellatrix\", 5.623, 6.349, 1.64, \"猎户座\"),\n    (\"参宿六 Saiph\", 5.795, -9.669, 2.09, \"猎户座\"),\n    (\"天船三 Mirfak\", 3.410, 49.862, 1.80, \"英仙座\"),\n    (\"天枢 Dubhe\", 11.062, 61.751, 1.79, \"大熊座\"),\n    (\"天璇 Merak\", 11.031, 56.382, 2.37, \"大熊座\"),\n    (\"天玑 Phecda\", 11.897, 53.695, 2.44, \"大熊座\"),\n    (\"天权 Megrez\", 12.154, 57.033, 3.31, \"大熊座\"),\n    (\"玉衡 Alioth\", 12.900, 55.960, 1.77, \"大熊座\"),\n    (\"开阳 Mizar\", 13.399, 54.925, 2.27, \"大熊座\"),\n    (\"摇光 Alkaid\", 13.792, 49.313, 1.86, \"大熊座\"),\n    (\"北河二 Castor\", 7.577, 31.888, 1.58, \"双子座\"),\n    (\"北河三 Pollux\", 7.755, 28.026, 1.14, \"双子座\"),\n    (\"南河二 Gomeisa\", 7.394, 8.288, 2.89, \"小犬座\"),\n    (\"井宿三 Alhena\", 6.366, 16.399, 1.93, \"双子座\"),\n    (\"天关 Alnath\", 5.457, 28.608, 1.65, \"金牛座\"),\n    (\"毕宿一 Electra\", 3.723, 24.105, 3.72, \"金牛座\"),\n    (\"毕宿二 Celaeno\", 3.713, 24.283, 5.46, \"金牛座\"),\n    (\"毕宿三 Taygeta\", 3.728, 24.446, 4.30, \"金牛座\"),\n    (\"毕宿四 Maia\", 3.757, 24.227, 3.87, \"金牛座\"),\n    (\"毕宿五 Aldebaran\", 4.599, 16.509, 0.85, \"金牛座\"),\n    (\"昴宿六 Alcyone\", 3.791, 24.105, 2.87, \"金牛座\"),\n    (\"参宿一 Alnitak\", 5.681, -1.943, 1.77, \"猎户座\"),\n    (\"参宿二 Alnilam\", 5.608, -1.201, 1.69, \"猎户座\"),\n    (\"参宿三 Mintaka\", 5.538, -0.299, 2.23, \"猎户座\"),\n    (\"伐二 Saiph\", 5.795, -9.669, 2.09, \"猎户座\"),\n    (\"天狼星 Sirius\", 6.752, -16.716, -1.46, \"大犬座\"),\n    (\"弧矢七 Adhara\", 6.961, -28.972, 1.50, \"大犬座\"),\n    (\"弧矢一 Wezen\", 7.234, -26.932, 1.84, \"大犬座\"),\n    (\"弧矢二 Aludra\", 7.412, -29.311, 2.45, \"大犬座\"),\n    (\"军市一 Mirzam\", 6.384, -17.956, 1.98, \"大犬座\"),\n]\n\n\ndef get_bright_stars(limit: int = 50) -> list[dict]:\n    \"\"\"\n    获取亮星列表\n\n    Args:\n        limit: 返回数量限制 (默认50)\n\n    Returns:\n        [{'name': 星名, 'ra': 赤经(小时), 'dec': 赤纬(角度), 'mag': 星等, 'constellation': 星座}, ...]\n    \"\"\"\n    stars = []\n    for i, (name, ra, dec, mag, constellation) in enumerate(BRIGHT_STARS[:limit]):\n        stars.append({\n            'name': name,\n            'ra': ra,\n            'dec': dec,\n            'mag': mag,\n            'constellation': constellation,\n        })\n    return stars\n\n\ndef get_visible_stars(\n    obs_time: datetime | str,\n    lat: float,\n    lon: float,\n    min_alt: float = 15,\n    max_alt: float = 85,\n    max_mag: float = 2.0,\n) -> list[dict]:\n    \"\"\"\n    获取当前可见的亮星\n\n    Args:\n        obs_time: 观测时间\n        lat: 纬度 (角度)\n        lon: 经度 (角度)\n        min_alt: 最小高度角 (默认15°)\n        max_alt: 最大高度角 (默认85°, 避免天顶)\n        max_mag: 最大星等 (默认2.0)\n\n    Returns:\n        可见星列表 (按星等排序)\n    \"\"\"\n    if isinstance(obs_time, str):\n        obs_time = datetime.fromisoformat(obs_time.replace('Z', '+00:00'))\n\n    visible = []\n    stars = get_bright_stars(limit=50)\n\n    for star in stars:\n        # 星等过滤\n        if star['mag'] > max_mag:\n            continue\n\n        # 计算当前位置\n        try:\n            pos = equatorial_to_altaz(\n                ra=star['ra'],\n                dec=star['dec'],\n                obs_time=obs_time,\n                lat=lat,\n                lon=lon,\n            )\n\n            # 高度角过滤\n            if min_alt <= pos['alt'] <= max_alt:\n                star_copy = star.copy()\n                star_copy['az'] = round(pos['az'], 2)\n                star_copy['alt'] = round(pos['alt'], 2)\n                star_copy['ha'] = round(pos['ha'], 2)\n                visible.append(star_copy)\n        except Exception:\n            continue\n\n    # 按星等排序\n    visible.sort(key=lambda s: s['mag'])\n\n    return visible\n\n\ndef recommend_calibration_stars(\n    obs_time: datetime | str,\n    lat: float,\n    lon: float,\n    count: int = 5,\n) -> list[dict]:\n    \"\"\"\n    推荐适合校准的恒星\n\n    选择原则：\n    1. 覆盖不同方位角（每45°扇区至少一颗）\n    2. 覆盖不同高度角（低/中/高）\n    3. 优先亮星\n\n    Args:\n        obs_time: 观测时间\n        lat: 纬度\n        lon: 经度\n        count: 推荐数量 (默认5)\n\n    Returns:\n        推荐星列表\n    \"\"\"\n    visible = get_visible_stars(obs_time, lat, lon, min_alt=15, max_alt=85, max_mag=2.0)\n\n    if len(visible) <= count:\n        return visible\n\n    # 按方位角分扇区选择\n    sectors = {}\n    sector_size = 360 / count\n\n    for star in visible:\n        az = star['az']\n        sector_idx = int(az / sector_size)\n\n        if sector_idx not in sectors:\n            sectors[sector_idx] = star\n        else:\n            # 同扇区内选更亮的\n            if star['mag'] < sectors[sector_idx]['mag']:\n                sectors[sector_idx] = star\n\n    # 如果扇区不足，用剩余亮星补充\n    selected = list(sectors.values())\n\n    if len(selected) < count:\n        for star in visible:\n            if star not in selected:\n                selected.append(star)\n                if len(selected) >= count:\n                    break\n\n    # 按方位角排序\n    selected.sort(key=lambda s: s['az'])\n\n    return selected[:count]\n\n\ndef find_star_by_name(name: str) -> Optional[dict]:\n    \"\"\"\n    按名称查找恒星\n\n    Args:\n        name: 星名（支持中文或英文名，部分匹配）\n\n    Returns:\n        星信息或None\n    \"\"\"\n    name_lower = name.lower()\n\n    for star in get_bright_stars():\n        if name_lower in star['name'].lower():\n            return star\n\n    return None\n\n\ndef get_star_position(\n    star_name: str,\n    obs_time: datetime | str,\n    lat: float,\n    lon: float,\n) -> Optional[dict]:\n    \"\"\"\n    获取指定恒星的当前地平坐标\n\n    Args:\n        star_name: 星名\n        obs_time: 观测时间\n        lat: 纬度\n        lon: 经度\n\n    Returns:\n        {'name': ..., 'ra': ..., 'dec': ..., 'az': ..., 'alt': ...} 或 None\n    \"\"\"\n    star = find_star_by_name(star_name)\n    if not star:\n        return None\n\n    pos = equatorial_to_altaz(\n        ra=star['ra'],\n        dec=star['dec'],\n        obs_time=obs_time,\n        lat=lat,\n        lon=lon,\n    )\n\n    result = star.copy()\n    result['az'] = round(pos['az'], 2)\n    result['alt'] = round(pos['alt'], 2)\n    result['ha'] = round(pos['ha'], 2)\n\n    return result\n\n\n# 模块测试\nif __name__ == '__main__':\n    from datetime import datetime\n\n    print(\"测试亮星星表模块\")\n\n    # 测试获取亮星\n    stars = get_bright_stars(limit=10)\n    print(f\"\\n前10颗亮星：\")\n    for s in stars:\n        print(f\"  {s['name']}: RA={s['ra']:.2f}h, DEC={s['dec']:.2f}°, mag={s['mag']}\")\n\n    # 测试可见星\n    obs_time = datetime(2024, 1, 1, 20, 0, 0)\n    lat, lon = 40, 120\n\n    visible = get_visible_stars(obs_time, lat, lon)\n    print(f\"\\n当前可见亮星 ({len(visible)}颗)：\")\n    for s in visible[:5]:\n        print(f\"  {s['name']}: Az={s['az']:.1f}°, Alt={s['alt']:.1f}°\")\n\n    # 测试推荐校准星\n    recommended = recommend_calibration_stars(obs_time, lat, lon, count=5)\n    print(f\"\\n推荐校准星 ({len(recommended)}颗)：\")\n    for s in recommended:\n        print(f\"  {s['name']}: Az={s['az']:.1f}°, Alt={s['alt']:.1f}°, mag={s['mag']}\")\n\n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\core\\star_catalog.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":70251,"output":3196,"cacheRead":0,"cacheWrite":0,"totalTokens":73447,"cost":{"input":0.070251,"output":0.0102272,"cacheRead":0,"cacheWrite":0,"total":0.0804782}},"stopReason":"toolUse","timestamp":1780515755055,"responseId":"cht000dba8a@dx19e8f025569b828282"}}
