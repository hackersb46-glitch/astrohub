{"type":"message","id":"97e3a752","parentId":"2712f25e","timestamp":"2026-06-03T19:42:35.039Z","message":{"role":"assistant","content":[{"type":"text","text":"**Phase 1.1：坐标转换模块**"},{"type":"toolCall","id":"tool-70187fdd9b2a4554a83fe1fbb82cdf69","name":"write","arguments":{"content":"\"\"\"\n坐标转换模块\n\n提供赤道坐标 (RA/DEC) 与地平坐标 (Alt/Az) 的转换功能。\n\n依赖：astropy (天文坐标计算)\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport math\nfrom datetime import datetime\nfrom typing import Optional\n\ntry:\n    from astropy.time import Time\n    from astropy.coordinates import (\n        SkyCoord,\n        EarthLocation,\n        AltAz,\n        ICRS,\n    )\n    from astropy import units as u\n    HAS_ASTROPY = True\nexcept ImportError:\n    HAS_ASTROPY = False\n\n\ndef equatorial_to_altaz(\n    ra: float,\n    dec: float,\n    obs_time: datetime | str,\n    lat: float,\n    lon: float,\n    altitude: float = 0,\n) -> dict:\n    \"\"\"\n    赤道坐标 → 地平坐标\n\n    Args:\n        ra: 赤经 (小时, 0-24) 或角度 (0-360)\n        dec: 赤纬 (角度, -90 到 +90)\n        obs_time: 观测时间 (datetime 或 ISO字符串)\n        lat: 纬度 (角度, -90 到 +90)\n        lon: 经度 (角度, -180 到 +180, 东经为正)\n        altitude: 海拔高度 (米)\n\n    Returns:\n        {'az': 方位角(角度), 'alt': 高度角(角度), 'ha': 时角(小时)}\n\n    Example:\n        >>> equatorial_to_altaz(ra=5.5, dec=45, obs_time='2024-01-01 20:00', lat=40, lon=120)\n        {'az': 123.4, 'alt': 67.2, 'ha': -3.2}\n    \"\"\"\n    # 时间处理\n    if isinstance(obs_time, str):\n        obs_time = datetime.fromisoformat(obs_time.replace('Z', '+00:00'))\n\n    if HAS_ASTROPY:\n        # 使用 astropy 精确计算\n        time = Time(obs_time)\n\n        # 观测站位置\n        location = EarthLocation(\n            lat=lat * u.deg,\n            lon=lon * u.deg,\n            height=altitude * u.m\n        )\n\n        # 天体坐标\n        # 判断 ra 是小时还是角度\n        if ra <= 24:\n            skycoord = SkyCoord(ra=ra * u.hourangle, dec=dec * u.deg, frame='icrs')\n        else:\n            skycoord = SkyCoord(ra=ra * u.deg, dec=dec * u.deg, frame='icrs')\n\n        # 转换到 Alt-Az\n        altaz_frame = AltAz(obstime=time, location=location)\n        altaz_coord = skycoord.transform_to(altaz_frame)\n\n        # 计算时角\n        lst = time.sidereal_time('apparent', longitude=lon * u.deg)\n        if ra <= 24:\n            ha = (lst.hour - ra) % 24\n            if ha > 12:\n                ha -= 24\n        else:\n            ha_hours = ra / 15  # 角度转小时\n            ha = (lst.hour - ha_hours) % 24\n            if ha > 12:\n                ha -= 24\n\n        return {\n            'az': float(altaz_coord.az.deg),\n            'alt': float(altaz_coord.alt.deg),\n            'ha': float(ha),\n        }\n    else:\n        # 无 astropy 时使用简化计算\n        return _equatorial_to_altaz_simple(ra, dec, obs_time, lat, lon)\n\n\ndef _equatorial_to_altaz_simple(\n    ra: float,\n    dec: float,\n    obs_time: datetime,\n    lat: float,\n    lon: float,\n) -> dict:\n    \"\"\"\n    简化版坐标转换（无 astropy 依赖）\n\n    使用经典球面三角公式。\n    \"\"\"\n    # 角度转弧度\n    ra_rad = math.radians(ra * 15 if ra <= 24 else ra)  # 小时转角度\n    dec_rad = math.radians(dec)\n    lat_rad = math.radians(lat)\n\n    # 计算恒星时\n    # 简化：使用 UTC 时间估算 LST\n    utc_hour = obs_time.hour + obs_time.minute / 60 + obs_time.second / 3600\n    # LST ≈ UTC + lon/15 + 基础修正\n    lst_hours = (utc_hour + lon / 15 + _gmst_offset(obs_time)) % 24\n\n    # 时角\n    ha_rad = math.radians((lst_hours - (ra_rad * 12 / math.pi)) * 15)  # 小时转角度再转弧度\n\n    # 球面三角公式\n    sin_alt = math.sin(dec_rad) * math.sin(lat_rad) + \\\n              math.cos(dec_rad) * math.cos(lat_rad) * math.cos(ha_rad)\n    alt_rad = math.asin(sin_alt)\n\n    cos_alt = math.cos(alt_rad)\n    if cos_alt < 1e-6:\n        cos_alt = 1e-6  # 防止除零\n\n    sin_az = -math.sin(ha_rad) * math.cos(dec_rad) / cos_alt\n    cos_az = (math.sin(dec_rad) - math.sin(lat_rad) * sin_alt) / (math.cos(lat_rad) * cos_alt)\n\n    az_rad = math.atan2(sin_az, cos_az)\n    if az_rad < 0:\n        az_rad += 2 * math.pi\n\n    # 时角（小时）\n    ha_hours = math.degrees(ha_rad) / 15\n    if ha_hours > 12:\n        ha_hours -= 24\n\n    return {\n        'az': math.degrees(az_rad),\n        'alt': math.degrees(alt_rad),\n        'ha': ha_hours,\n    }\n\n\ndef _gmst_offset(obs_time: datetime) -> float:\n    \"\"\"\n    计算 GMST 基础修正（简化版）\n\n    返回 GMST 在 UTC 0时的值（小时）\n    \"\"\"\n    # 简化计算：基于日期\n    year = obs_time.year\n    month = obs_time.month\n    day = obs_time.day\n\n    # 简化的 Julian Date\n    jd = _julian_date(year, month, day)\n\n    # T = (JD - 2451545.0) / 36525\n    T = (jd - 2451545.0) / 36525\n\n    # GMST at 0h UT (简化公式)\n    gmst0 = 6.697374558 + 2400.051336 * T + 0.000025862 * T * T\n    gmst0 = gmst0 % 24\n\n    return gmst0\n\n\ndef _julian_date(year: int, month: int, day: int) -> float:\n    \"\"\"\n    计算 Julian Date（简化版）\n    \"\"\"\n    if month <= 2:\n        year -= 1\n        month += 12\n\n    A = int(year / 100)\n    B = 2 - A + int(A / 4)\n\n    jd = int(365.25 * (year + 4716)) + int(30.6001 * (month + 1)) + day + B - 1524.5\n    return jd\n\n\ndef altaz_to_equatorial(\n    az: float,\n    alt: float,\n    obs_time: datetime | str,\n    lat: float,\n    lon: float,\n) -> dict:\n    \"\"\"\n    地平坐标 → 赤道坐标（逆转换）\n\n    Args:\n        az: 方位角 (角度, 0-360, 北为0, 东增)\n        alt: 高度角 (角度, -90 到 +90)\n        obs_time: 观测时间\n        lat: 纬度\n        lon: 经度\n\n    Returns:\n        {'ra': 赤经(小时), 'dec': 赁纬(角度), 'ha': 时角(小时)}\n    \"\"\"\n    if isinstance(obs_time, str):\n        obs_time = datetime.fromisoformat(obs_time.replace('Z', '+00:00'))\n\n    if HAS_ASTROPY:\n        time = Time(obs_time)\n        location = EarthLocation(\n            lat=lat * u.deg,\n            lon=lon * u.deg,\n            height=0 * u.m\n        )\n\n        altaz_frame = AltAz(obstime=time, location=location)\n        altaz_coord = SkyCoord(\n            az=az * u.deg,\n            alt=alt * u.deg,\n            frame=altaz_frame\n        )\n\n        icrs_coord = altaz_coord.transform_to('icrs')\n\n        # 计算时角\n        lst = time.sidereal_time('apparent', longitude=lon * u.deg)\n        ha = (lst.hour - icrs_coord.ra.hour) % 24\n        if ha > 12:\n            ha -= 24\n\n        return {\n            'ra': float(icrs_coord.ra.hour),\n            'dec': float(icrs_coord.dec.deg),\n            'ha': float(ha),\n        }\n    else:\n        return _altaz_to_equatorial_simple(az, alt, obs_time, lat, lon)\n\n\ndef _altaz_to_equatorial_simple(\n    az: float,\n    alt: float,\n    obs_time: datetime,\n    lat: float,\n    lon: float,\n) -> dict:\n    \"\"\"\n    简化版逆转换\n    \"\"\"\n    az_rad = math.radians(az)\n    alt_rad = math.radians(alt)\n    lat_rad = math.radians(lat)\n\n    # 球面三角逆公式\n    sin_dec = math.sin(alt_rad) * math.sin(lat_rad) + \\\n              math.cos(alt_rad) * math.cos(lat_rad) * math.cos(az_rad)\n    dec_rad = math.asin(sin_dec)\n\n    cos_dec = math.cos(dec_rad)\n    if cos_dec < 1e-6:\n        cos_dec = 1e-6\n\n    cos_ha = (math.sin(alt_rad) - math.sin(lat_rad) * sin_dec) / (math.cos(lat_rad) * cos_dec)\n    sin_ha = -math.sin(az_rad) * math.cos(alt_rad) / cos_dec\n\n    ha_rad = math.atan2(sin_ha, cos_ha)\n\n    # 时角（小时）\n    ha_hours = math.degrees(ha_rad) / 15\n    if ha_hours > 12:\n        ha_hours -= 24\n\n    # 计算恒星时\n    utc_hour = obs_time.hour + obs_time.minute / 60 + obs_time.second / 3600\n    lst_hours = (utc_hour + lon / 15 + _gmst_offset(obs_time)) % 24\n\n    # RA = LST - HA\n    ra_hours = (lst_hours - ha_hours) % 24\n\n    return {\n        'ra': ra_hours,\n        'dec': math.degrees(dec_rad),\n        'ha': ha_hours,\n    }\n\n\ndef apply_refraction(\n    alt_observed: float,\n    pressure: float = 1010,\n    temperature: float = 10,\n) -> float:\n    \"\"\"\n    大气折射修正\n\n    将观测高度角转换为真实高度角（去除折射影响）\n\n    Args:\n        alt_observed: 观测高度角 (角度)\n        pressure: 气压 (hPa/mbar, 默认1010)\n        temperature: 温度 (摄氏度, 默认10)\n\n    Returns:\n        真实高度角 (角度)\n\n    Note:\n        折射使星看起来比实际位置更高。\n        真实高度 = 观测高度 - 折射量\n    \"\"\"\n    if alt_observed <= 0:\n        return alt_observed  # 地平线以下不修正\n\n    # Saemundsson 公式 (标准条件: 1010 hPa, 10°C)\n    # R = 1.02 / tan(h + 10.3/(h+5.11)) arcmin\n    h = alt_observed\n\n    if h < 5:\n        # 低高度角使用更保守的修正\n        R_arcmin = 1.02 / math.tan(math.radians(h + 2))\n    else:\n        R_arcmin = 1.02 / math.tan(math.radians(h + 10.3 / (h + 5.11)))\n\n    # 气压和温度修正\n    # R ∝ P/T\n    P_ratio = pressure / 1010\n    T_ratio = 283.15 / (temperature + 273.15)  # 10°C = 283.15K\n\n    R_arcmin *= P_ratio * T_ratio\n\n    # 转换为角度\n    R_deg = R_arcmin / 60\n\n    # 真实高度 = 观测高度 - 折射\n    alt_true = alt_observed - R_deg\n\n    return alt_true\n\n\ndef remove_refraction(\n    alt_true: float,\n    pressure: float = 1010,\n    temperature: float = 10,\n) -> float:\n    \"\"\"\n    反向折射修正\n\n    将真实高度角转换为观测高度角（添加折射影响）\n\n    Args:\n        alt_true: 真实高度角 (角度)\n        pressure: 气压 (hPa)\n        temperature: 温度 (摄氏度)\n\n    Returns:\n        观测高度角 (角度)\n    \"\"\"\n    if alt_true <= 0:\n        return alt_true\n\n    # 估算折射（迭代）\n    # 简化：直接使用 apply_refraction 的逆运算估算\n    h = alt_true\n    R_arcmin = 1.02 / math.tan(math.radians(h + 10.3 / (h + 5.11)))\n\n    P_ratio = pressure / 1010\n    T_ratio = 283.15 / (temperature + 273.15)\n    R_arcmin *= P_ratio * T_ratio\n\n    R_deg = R_arcmin / 60\n\n    alt_observed = alt_true + R_deg\n\n    return alt_observed\n\n\n# 模块测试\nif __name__ == '__main__':\n    # 测试坐标转换\n    print(\"测试坐标转换模块\")\n\n    # 测试参数\n    ra = 5.5  # 小时\n    dec = 45  # 角度\n    obs_time = datetime(2024, 1, 1, 20, 0, 0)\n    lat = 40  # 北京纬度\n    lon = 120  # 东经\n\n    result = equatorial_to_altaz(ra, dec, obs_time, lat, lon)\n    print(f\"RA={ra}h, DEC={dec}° → Az={result['az']:.2f}°, Alt={result['alt']:.2f}°, HA={result['ha']:.2f}h\")\n\n    # 逆转换测试\n    inv_result = altaz_to_equatorial(result['az'], result['alt'], obs_time, lat, lon)\n    print(f\"Az={result['az']:.2f}°, Alt={result['alt']:.2f}° → RA={inv_result['ra']:.2f}h, DEC={inv_result['dec']:.2f}°\")\n\n    # 折射测试\n    alt_obs = 30\n    alt_true = apply_refraction(alt_obs)\n    print(f\"观测高度={alt_obs}° → 真实高度={alt_true:.3f}° (折射修正={alt_obs - alt_true:.3f}°)\")\n\n    print(\"测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\core\\coordinates.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":62578,"output":3422,"cacheRead":0,"cacheWrite":0,"totalTokens":66000,"cost":{"input":0.062578,"output":0.0109504,"cacheRead":0,"cacheWrite":0,"total":0.0735284}},"stopReason":"toolUse","timestamp":1780515695958,"responseId":"cht000dae0b@dx19e8f016eb6b828282"}}
