{"type":"message","id":"98978735","parentId":"ba11c69e","timestamp":"2026-06-04T06:18:08.110Z","message":{"role":"assistant","content":[{"type":"text","text":"**Step 5: 完整流程处理器**"},{"type":"toolCall","id":"tool-59733d16b15d41b38a22a2c0dff11a26","name":"write","arguments":{"content":"\"\"\"\n完整流程处理器\n\n整合帧采集、对齐、叠加、输出的完整流程。\n\n档位：\n- 关闭叠加 (仅 JPG)\n- 2s / 5s / 10s / 30s 预设\n- 自定义时间\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport time\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Optional, Callable, List\n\nfrom .detect import StarDetector\nfrom .align import ImageAligner\nfrom .stack import FrameStacker\nfrom .output import OutputWriter\n\n\n# 预设档位配置\nSTACK_PRESETS = {\n    'off': {'exposure': 0, 'n_frames': 1, 'stack_method': 'none'},\n    '2s': {'exposure': 2, 'n_frames': 20, 'stack_method': 'median'},\n    '5s': {'exposure': 5, 'n_frames': 50, 'stack_method': 'sigma_clip'},\n    '10s': {'exposure': 10, 'n_frames': 100, 'stack_method': 'sigma_clip'},\n    '30s': {'exposure': 30, 'n_frames': 300, 'stack_method': 'sigma_clip'},\n}\n\n# 默认帧率 (假设 PTZ 输出 10 fps)\nDEFAULT_FPS = 10\n\n\nclass StackProcessor:\n    \"\"\"\n    叠加处理器\n    \n    完整流程：\n    1. 采集帧\n    2. 对齐帧\n    3. 叠加\n    4. 输出 FITS + JPG\n    \"\"\"\n    \n    def __init__(\n        self,\n        output_dir: str = \"stack/output\",\n        fps: float = DEFAULT_FPS,\n        align_method: str = 'auto',\n        stack_method: str = 'sigma_clip',\n        fwhm: float = 3.0,\n        threshold: float = 5.0,\n        sigma: float = 3.0,\n    ):\n        \"\"\"\n        初始化处理器\n        \n        Args:\n            output_dir: 输出目录\n            fps: 视频帧率\n            align_method: 对齐方法 ('auto', 'astroalign', 'phase', 'ecc')\n            stack_method: 叠加方法 ('sigma_clip', 'median', 'mean')\n            fwhm: 星点 FWHM\n            threshold: 检测阈值\n            sigma: Sigma clipping 阈值\n        \"\"\"\n        self.output_dir = output_dir\n        self.fps = fps\n        self.align_method = align_method\n        self.stack_method = stack_method\n        self.fwhm = fwhm\n        self.threshold = threshold\n        self.sigma = sigma\n        \n        # 组件\n        self.aligner = ImageAligner(method=align_method, fwhm=fwhm, threshold=threshold)\n        self.stacker = FrameStacker(method=stack_method, sigma_low=sigma, sigma_high=sigma)\n        self.writer = OutputWriter(output_dir=output_dir)\n        \n        # 状态\n        self.is_running = False\n        self.progress = 0.0\n        self.frames_collected = []\n        self.reference_frame = None\n    \n    def process(\n        self,\n        frame_source: Callable,\n        mode: str = '2s',\n        custom_exposure: Optional[float] = None,\n        basename: Optional[str] = None,\n        callback: Optional[Callable] = None,\n    ) -> dict:\n        \"\"\"\n        执行完整叠加流程\n        \n        Args:\n            frame_source: 获取帧的函数，返回 numpy array\n            mode: 模式 ('off', '2s', '5s', '10s', '30s', 'custom')\n            custom_exposure: 自定义曝光时间 (秒)，mode='custom' 时使用\n            basename: 输出文件名基础\n            callback: 进度回调函数\n        \n        Returns:\n            {'success': bool, 'fits_path': ..., 'jpg_path': ..., 'message': ...}\n        \"\"\"\n        self.is_running = True\n        self.progress = 0.0\n        \n        try:\n            # 获取配置\n            if mode == 'custom' and custom_exposure:\n                n_frames = int(custom_exposure * self.fps)\n                exposure_time = custom_exposure\n                stack_method = self.stack_method if n_frames >= 5 else 'median'\n            elif mode in STACK_PRESETS:\n                preset = STACK_PRESETS[mode]\n                n_frames = preset['n_frames']\n                exposure_time = preset['exposure']\n                stack_method = preset['stack_method']\n            else:\n                return {'success': False, 'message': f\"未知模式: {mode}\"}\n            \n            # 关闭叠加模式\n            if mode == 'off' or n_frames <= 1:\n                frame = frame_source()\n                if frame is None:\n                    return {'success': False, 'message': '无法获取帧'}\n                \n                # 仅保存 JPG\n                if not basename:\n                    basename = f\"single_{datetime.now().strftime('%Y%m%d_%H%M%S')}\"\n                \n                self.writer._save_jpg(frame, f\"{self.output_dir}/{basename}.jpg\")\n                \n                return {\n                    'success': True,\n                    'jpg_path': f\"{self.output_dir}/{basename}.jpg\",\n                    'exposure_time': 0,\n                    'n_frames': 1,\n                    'message': '单帧 JPG 已保存',\n                }\n            \n            # 生成文件名\n            if not basename:\n                basename = f\"stack_{mode}_{datetime.now().strftime('%Y%m%d_%H%M%S')}\"\n            \n            # 采集帧\n            self.frames_collected = []\n            self.reference_frame = None\n            \n            for i in range(n_frames):\n                if not self.is_running:\n                    return {'success': False, 'message': '用户中断'}\n                \n                frame = frame_source()\n                if frame is None:\n                    continue\n                \n                # 第一帧作为参考\n                if self.reference_frame is None:\n                    self.reference_frame = frame.astype(np.float32)\n                    self.frames_collected.append(self.reference_frame)\n                else:\n                    # 对齐后添加\n                    aligned, info = self.aligner.align(frame, self.reference_frame)\n                    self.frames_collected.append(aligned)\n                \n                # 更新进度\n                self.progress = (i + 1) / n_frames\n                if callback:\n                    callback(self.progress, i + 1, n_frames)\n            \n            # 叠加\n            self.stacker.method = stack_method\n            result_image = self.stacker.stack(self.frames_collected)\n            \n            # 输出\n            output_result = self.writer.save(\n                image=result_image,\n                basename=basename,\n                exposure_time=exposure_time,\n                n_frames=n_frames,\n            )\n            \n            return {\n                'success': True,\n                'fits_path': output_result.get('fits_path'),\n                'jpg_path': output_result.get('jpg_path'),\n                'exposure_time': exposure_time,\n                'n_frames': n_frames,\n                'stack_method': stack_method,\n                'message': f'叠加完成: {n_frames}帧, 等效{exposure_time}s',\n            }\n        \n        except Exception as e:\n            return {'success': False, 'message': f'处理异常: {str(e)}'}\n        \n        finally:\n            self.is_running = False\n            self.progress = 0.0\n    \n    def stop(self) -> None:\n        \"\"\"\n        停止处理\n        \"\"\"\n        self.is_running = False\n    \n    def get_status(self) -> dict:\n        \"\"\"\n        获取当前状态\n        \"\"\"\n        return {\n            'is_running': self.is_running,\n            'progress': round(self.progress * 100, 1),\n            'frames_collected': len(self.frames_collected),\n        }\n    \n    def get_presets(self) -> dict:\n        \"\"\"\n        获取预设档位信息\n        \"\"\"\n        return STACK_PRESETS.copy()\n\n\ndef get_frame_from_video(video_path: str, frame_idx: int) -> Optional[np.ndarray]:\n    \"\"\"\n    从视频文件获取帧（用于测试）\n    \n    Args:\n        video_path: 视频文件路径\n        frame_idx: 帧索引\n    \n    Returns:\n        灰度图像 numpy array\n    \"\"\"\n    import cv2\n    \n    cap = cv2.VideoCapture(video_path)\n    cap.set(cv2.CAP_PROP_POS_FRAMES, frame_idx)\n    \n    ret, frame = cap.read()\n    cap.release()\n    \n    if not ret:\n        return None\n    \n    # 转换为灰度\n    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n    return gray\n\n\nif __name__ == '__main__':\n    print(\"测试完整流程处理器\")\n    \n    # 创建模拟帧源\n    def mock_frame_source():\n        np.random.seed(int(time.time() * 1000) % 1000)\n        base = np.ones((100, 100)) * 100\n        base[40:60, 40:60] = 500\n        noise = np.random.normal(0, 10, (100, 100))\n        return base + noise\n    \n    processor = StackProcessor(output_dir=\"stack/output_test\")\n    \n    # 测试 2s 档\n    result = processor.process(\n        frame_source=mock_frame_source,\n        mode='2s',\n        basename=\"test_2s\",\n    )\n    \n    print(f\"成功: {result['success']}\")\n    print(f\"消息: {result['message']}\")\n    print(f\"FITS: {result.get('fits_path', 'N/A')}\")\n    print(f\"JPG: {result.get('jpg_path', 'N/A')}\")\n    \n    # 测试关闭叠加\n    result_off = processor.process(\n        frame_source=mock_frame_source,\n        mode='off',\n        basename=\"test_off\",\n    )\n    print(f\"关闭叠加: {result_off['message']}\")\n    \n    # 获取预设\n    presets = processor.get_presets()\n    print(f\"预设档位: {list(presets.keys())}\")\n    \n    print(\"测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\process.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":126590,"output":2179,"cacheRead":0,"cacheWrite":0,"totalTokens":128769,"cost":{"input":0.12659,"output":0.0069728,"cacheRead":0,"cacheWrite":0,"total":0.1335628}},"stopReason":"toolUse","timestamp":1780553754559,"responseId":"cht000dd3ae@dx19e91463056b87e692"}}
