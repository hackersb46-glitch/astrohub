{"type":"message","id":"d14b10cb","parentId":"cf47bf82","timestamp":"2026-06-03T19:48:27.803Z","message":{"role":"assistant","content":[{"type":"text","text":"**Phase 3：API 路由模块**"},{"type":"toolCall","id":"call_4f400367070f4c0cbbace83f","name":"write","arguments":{"content":"\"\"\"\n校准 API 路由\n\n提供校准相关的 REST API 接口。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom datetime import datetime\nfrom fastapi import APIRouter, HTTPException, Request\nfrom pydantic import BaseModel\nfrom typing import Optional, List, Dict, Any\n\nfrom .calibration_manual import ManualCalibration\nfrom .calibration_auto import AutoCalibration\nfrom .calibration_store import (\n    save_calibration,\n    load_calibration,\n    get_calibration_history,\n    list_calibrated_devices,\n)\nfrom .core.star_catalog import get_visible_stars, recommend_calibration_stars\nfrom .core.plate_solve import check_astap_installed\n\nrouter = APIRouter(prefix=\"/api/v1/calibrate\", tags=[\"calibrate\"])\n\n# 存储活跃的校准会话\n_active_sessions: Dict[str, Any] = {}\n\n\n# ============== 请求/响应模型 ==============\n\nclass StartCalibrationRequest(BaseModel):\n    device_ip: str\n    obs_lat: float\n    obs_lon: float\n    method: str = \"manual\"  # \"manual\" 或 \"auto\"\n\n\nclass SelectStarRequest(BaseModel):\n    device_ip: str\n    star_name: str\n\n\nclass RecordPointRequest(BaseModel):\n    device_ip: str\n    pan: float\n    tilt: float\n\n\nclass CaptureAndSolveRequest(BaseModel):\n    device_ip: str\n    pan: Optional[float] = None\n    tilt: Optional[float] = None\n    image_path: Optional[str] = None\n    fov_hint: Optional[float] = None\n\n\nclass ComputeRequest(BaseModel):\n    device_ip: str\n\n\nclass SaveRequest(BaseModel):\n    device_ip: str\n\n\n# ============== API 端点 ==============\n\n@router.get(\"/status\")\nasync def get_calibration_status():\n    \"\"\"\n    获取校准系统状态\n    \"\"\"\n    astap_status = check_astap_installed()\n    calibrated_devices = list_calibrated_devices()\n\n    return {\n        \"success\": True,\n        \"astap\": astap_status,\n        \"calibrated_devices\": calibrated_devices,\n        \"active_sessions\": list(_active_sessions.keys()),\n    }\n\n\n@router.get(\"/devices\")\nasync def list_devices():\n    \"\"\"\n    列出所有已校准设备\n    \"\"\"\n    devices = list_calibrated_devices()\n    return {\n        \"success\": True,\n        \"devices\": devices,\n    }\n\n\n@router.get(\"/devices/{device_ip}\")\nasync def get_device_calibration(device_ip: str):\n    \"\"\"\n    获取设备校准信息\n    \"\"\"\n    calib = load_calibration(device_ip)\n    if not calib:\n        raise HTTPException(status_code=404, detail=\"设备校准信息不存在\")\n\n    return {\n        \"success\": True,\n        \"calibration\": calib,\n    }\n\n\n@router.get(\"/devices/{device_ip}/history\")\nasync def get_device_history(device_ip: str, limit: int = 10):\n    \"\"\"\n    获取设备校准历史\n    \"\"\"\n    history = get_calibration_history(device_ip, limit)\n    return {\n        \"success\": True,\n        \"device_ip\": device_ip,\n        \"history\": history,\n    }\n\n\n@router.post(\"/start\")\nasync def start_calibration(request: StartCalibrationRequest):\n    \"\"\"\n    开始校准会话\n    \"\"\"\n    device_ip = request.device_ip\n\n    # 创建校准会话\n    if request.method == \"manual\":\n        session = ManualCalibration(\n            device_ip=device_ip,\n            obs_lat=request.obs_lat,\n            obs_lon=request.obs_lon,\n        )\n    elif request.method == \"auto\":\n        session = AutoCalibration(\n            device_ip=device_ip,\n            obs_lat=request.obs_lat,\n            obs_lon=request.obs_lon,\n        )\n    else:\n        raise HTTPException(status_code=400, detail=f\"未知校准方法: {request.method}\")\n\n    # 开始校准\n    result = session.start()\n    _active_sessions[device_ip] = session\n\n    return {\n        \"success\": result[\"success\"],\n        \"method\": request.method,\n        \"device_ip\": device_ip,\n        \"recommended_stars\": result.get(\"recommended_stars\", []),\n        \"astap_status\": result.get(\"astap_status\"),\n        \"message\": result[\"message\"],\n    }\n\n\n@router.get(\"/session/{device_ip}\")\nasync def get_session_status(device_ip: str):\n    \"\"\"\n    获取校准会话状态\n    \"\"\"\n    if device_ip not in _active_sessions:\n        raise HTTPException(status_code=404, detail=\"校准会话不存在\")\n\n    session = _active_sessions[device_ip]\n    status = session.get_status()\n\n    return {\n        \"success\": True,\n        \"device_ip\": device_ip,\n        \"status\": status,\n    }\n\n\n@router.post(\"/select_star\")\nasync def select_star(request: SelectStarRequest):\n    \"\"\"\n    选择恒星（仅手动模式）\n    \"\"\"\n    device_ip = request.device_ip\n\n    if device_ip not in _active_sessions:\n        raise HTTPException(status_code=404, detail=\"校准会话不存在\")\n\n    session = _active_sessions[device_ip]\n    if not isinstance(session, ManualCalibration):\n        raise HTTPException(status_code=400, detail=\"此操作仅适用于手动校准模式\")\n\n    result = session.select_star(request.star_name)\n\n    return {\n        \"success\": result[\"success\"],\n        \"star\": result.get(\"star\"),\n        \"position\": result.get(\"position\"),\n        \"message\": result[\"message\"],\n    }\n\n\n@router.post(\"/record\")\nasync def record_point(request: RecordPointRequest):\n    \"\"\"\n    记录校准点（手动模式）\n    \"\"\"\n    device_ip = request.device_ip\n\n    if device_ip not in _active_sessions:\n        raise HTTPException(status_code=404, detail=\"校准会话不存在\")\n\n    session = _active_sessions[device_ip]\n    if not isinstance(session, ManualCalibration):\n        raise HTTPException(status_code=400, detail=\"此操作仅适用于手动校准模式\")\n\n    result = session.record_point(request.pan, request.tilt)\n\n    return {\n        \"success\": result[\"success\"],\n        \"point_index\": result.get(\"point_index\"),\n        \"total_points\": result.get(\"total_points\"),\n        \"coverage\": result.get(\"coverage\"),\n        \"message\": result[\"message\"],\n    }\n\n\n@router.post(\"/capture\")\nasync def capture_and_solve(request: CaptureAndSolveRequest):\n    \"\"\"\n    拍摄并解析（自动模式）\n    \"\"\"\n    device_ip = request.device_ip\n\n    if device_ip not in _active_sessions:\n        raise HTTPException(status_code=404, detail=\"校准会话不存在\")\n\n    session = _active_sessions[device_ip]\n    if not isinstance(session, AutoCalibration):\n        raise HTTPException(status_code=400, detail=\"此操作仅适用于自动校准模式\")\n\n    result = session.capture_and_solve(\n        pan_enc=request.pan,\n        tilt_enc=request.tilt,\n        image_path=request.image_path,\n        fov_hint=request.fov_hint,\n    )\n\n    return {\n        \"success\": result[\"success\"],\n        \"point_index\": result.get(\"point_index\"),\n        \"total_points\": result.get(\"total_points\"),\n        \"ra\": result.get(\"ra\"),\n        \"dec\": result.get(\"dec\"),\n        \"coverage\": result.get(\"coverage\"),\n        \"movement_hint\": result.get(\"movement_hint\"),\n        \"message\": result[\"message\"],\n    }\n\n\n@router.post(\"/compute\")\nasync def compute_calibration(request: ComputeRequest):\n    \"\"\"\n    计算校准参数\n    \"\"\"\n    device_ip = request.device_ip\n\n    if device_ip not in _active_sessions:\n        raise HTTPException(status_code=404, detail=\"校准会话不存在\")\n\n    session = _active_sessions[device_ip]\n    result = session.compute()\n\n    return {\n        \"success\": result[\"success\"],\n        \"params\": result.get(\"params\"),\n        \"rms\": result.get(\"rms\") or result.get(\"fit_rms\"),\n        \"message\": result[\"message\"],\n    }\n\n\n@router.post(\"/save\")\nasync def save_calibration_result(request: SaveRequest):\n    \"\"\"\n    保存校准结果\n    \"\"\"\n    device_ip = request.device_ip\n\n    if device_ip not in _active_sessions:\n        raise HTTPException(status_code=404, detail=\"校准会话不存在\")\n\n    session = _active_sessions[device_ip]\n    result = session.save()\n\n    return {\n        \"success\": result[\"success\"],\n        \"message\": result[\"message\"],\n    }\n\n\n@router.post(\"/reset\")\nasync def reset_calibration(device_ip: str):\n    \"\"\"\n    重置校准会话\n    \"\"\"\n    if device_ip not in _active_sessions:\n        raise HTTPException(status_code=404, detail=\"校准会话不存在\")\n\n    session = _active_sessions[device_ip]\n    result = session.reset()\n\n    return {\n        \"success\": result[\"success\"],\n        \"message\": result[\"message\"],\n    }\n\n\n@router.delete(\"/session/{device_ip}\")\nasync def delete_session(device_ip: str):\n    \"\"\"\n    删除校准会话\n    \"\"\"\n    if device_ip in _active_sessions:\n        del _active_sessions[device_ip]\n\n    return {\n        \"success\": True,\n        \"message\": f\"会话 {device_ip} 已删除\",\n    }\n\n\n@router.get(\"/stars/visible\")\nasync def get_visible_stars_api(lat: float, lon: float, min_alt: float = 15, max_alt: float = 85):\n    \"\"\"\n    获取当前可见亮星\n    \"\"\"\n    obs_time = datetime.now()\n    stars = get_visible_stars(obs_time, lat, lon, min_alt, max_alt)\n\n    return {\n        \"success\": True,\n        \"obs_time\": obs_time.isoformat(),\n        \"stars\": stars,\n    }\n\n\n@router.get(\"/stars/recommended\")\nasync def get_recommended_stars_api(lat: float, lon: float, count: int = 5):\n    \"\"\"\n    获取推荐校准星\n    \"\"\"\n    obs_time = datetime.now()\n    stars = recommend_calibration_stars(obs_time, lat, lon, count)\n\n    return {\n        \"success\": True,\n        \"obs_time\": obs_time.isoformat(),\n        \"recommended_stars\": stars,\n    }\n\n\n# ============== 模块导出 ==============\n\ndef get_router():\n    \"\"\"获取路由器\"\"\"\n    return router\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"校准 API 路由模块\")\n    print(f\"路由前缀: {router.prefix}\")\n    print(f\"路由数量: {len(router.routes)}\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":87333,"output":2257,"cacheRead":0,"cacheWrite":0,"totalTokens":89590,"cost":{"input":0.087333,"output":0.0072224,"cacheRead":0,"cacheWrite":0,"total":0.0945554}},"stopReason":"toolUse","timestamp":1780516068771,"responseId":"cht000d3eb4@dx19e8f071ec0ba29112"}}
