{"type":"message","id":"4d071dfb","parentId":"4b08ab41","timestamp":"2026-06-03T19:46:09.008Z","message":{"role":"assistant","content":[{"type":"text","text":"Phase 1 完成。继续 Phase 2：校准流程模块。"},{"type":"toolCall","id":"tool-4d19945fb78a40eb98fb62ef53eb9c3d","name":"write","arguments":{"content":"\"\"\"\n校准存储模块\n\n保存和加载校准参数，管理校准历史记录。\n\n存储位置：\n- 校准参数: config/calibration.json\n- 历史记录: calibrate/history/\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport json\nimport os\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Optional\n\n# 默认存储路径\nDEFAULT_CONFIG_PATH = \"config/calibration.json\"\nDEFAULT_HISTORY_PATH = \"calibrate/history\"\n\n\ndef get_config_path() -> str:\n    \"\"\"\n    获取校准配置文件路径\n    \"\"\"\n    # 从项目根目录查找\n    base_dir = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n    config_dir = os.path.join(base_dir, \"config\")\n\n    if not os.path.exists(config_dir):\n        os.makedirs(config_dir, exist_ok=True)\n\n    return os.path.join(config_dir, \"calibration.json\")\n\n\ndef get_history_path() -> str:\n    \"\"\"\n    获取校准历史记录目录路径\n    \"\"\"\n    base_dir = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n    history_dir = os.path.join(base_dir, DEFAULT_HISTORY_PATH)\n\n    if not os.path.exists(history_dir):\n        os.makedirs(history_dir, exist_ok=True)\n\n    return history_dir\n\n\ndef save_calibration(\n    device_ip: str,\n    params: dict,\n    obs_lat: float,\n    obs_lon: float,\n    timestamp: Optional[str] = None,\n    metadata: Optional[dict] = None,\n) -> dict:\n    \"\"\"\n    保存校准结果\n\n    Args:\n        device_ip: 设备 IP\n        params: 校准参数 (IA, IH, NP, ...)\n        obs_lat: 观测站纬度\n        obs_lon: 观测站经度\n        timestamp: 时间戳 (可选)\n        metadata: 其他元数据 (可选)\n\n    Returns:\n        {'success': bool, 'path': str, 'message': str}\n    \"\"\"\n    if not timestamp:\n        timestamp = datetime.now().isoformat()\n\n    config_path = get_config_path()\n\n    # 加载现有配置\n    config = {}\n    if os.path.exists(config_path):\n        try:\n            with open(config_path, 'r', encoding='utf-8') as f:\n                config = json.load(f)\n        except Exception:\n            config = {}\n\n    # 更新设备校准信息\n    if 'devices' not in config:\n        config['devices'] = {}\n\n    device_key = device_ip.replace('.', '_')  # IP 转 key\n\n    config['devices'][device_key] = {\n        'device_ip': device_ip,\n        'params': params,\n        'obs_lat': obs_lat,\n        'obs_lon': obs_lon,\n        'timestamp': timestamp,\n        'metadata': metadata or {},\n    }\n\n    # 保存配置\n    try:\n        with open(config_path, 'w', encoding='utf-8') as f:\n            json.dump(config, f, indent=2, ensure_ascii=False)\n    except Exception as e:\n        return {\n            'success': False,\n            'path': config_path,\n            'message': f'保存失败: {str(e)}',\n        }\n\n    # 同时保存到历史记录\n    save_to_history(device_ip, params, obs_lat, obs_lon, timestamp, metadata)\n\n    return {\n        'success': True,\n        'path': config_path,\n        'message': f'校准结果已保存: {config_path}',\n    }\n\n\ndef load_calibration(device_ip: str) -> Optional[dict]:\n    \"\"\"\n    加载校准结果\n\n    Args:\n        device_ip: 设备 IP\n\n    Returns:\n        校准信息或 None\n    \"\"\"\n    config_path = get_config_path()\n\n    if not os.path.exists(config_path):\n        return None\n\n    try:\n        with open(config_path, 'r', encoding='utf-8') as f:\n            config = json.load(f)\n    except Exception:\n        return None\n\n    device_key = device_ip.replace('.', '_')\n\n    if 'devices' not in config or device_key not in config['devices']:\n        return None\n\n    return config['devices'][device_key]\n\n\ndef save_to_history(\n    device_ip: str,\n    params: dict,\n    obs_lat: float,\n    obs_lon: float,\n    timestamp: str,\n    metadata: Optional[dict] = None,\n) -> str:\n    \"\"\"\n    保存到历史记录\n\n    Returns:\n        历史文件路径\n    \"\"\"\n    history_path = get_history_path()\n\n    # 生成文件名\n    ts_short = timestamp.replace(':', '-').replace('.', '-')[:19]\n    filename = f\"{device_ip.replace('.', '_')}_{ts_short}.json\"\n    filepath = os.path.join(history_path, filename)\n\n    # 历史记录内容\n    history_entry = {\n        'device_ip': device_ip,\n        'params': params,\n        'obs_lat': obs_lat,\n        'obs_lon': obs_lon,\n        'timestamp': timestamp,\n        'metadata': metadata or {},\n    }\n\n    try:\n        with open(filepath, 'w', encoding='utf-8') as f:\n            json.dump(history_entry, f, indent=2, ensure_ascii=False)\n    except Exception:\n        pass\n\n    return filepath\n\n\ndef get_calibration_history(device_ip: str, limit: int = 10) -> list[dict]:\n    \"\"\"\n    获取校准历史记录\n\n    Args:\n        device_ip: 设备 IP\n        limit: 最大返回数量\n\n    Returns:\n        历史记录列表 (按时间倒序)\n    \"\"\"\n    history_path = get_history_path()\n    device_key = device_ip.replace('.', '_')\n\n    if not os.path.exists(history_path):\n        return []\n\n    # 查找匹配的历史文件\n    history_files = []\n    for f in os.listdir(history_path):\n        if f.startswith(device_key) and f.endswith('.json'):\n            history_files.append(os.path.join(history_path, f))\n\n    # 按时间倒序排序\n    history_files.sort(reverse=True)\n\n    # 加载历史记录\n    history = []\n    for filepath in history_files[:limit]:\n        try:\n            with open(filepath, 'r', encoding='utf-8') as f:\n                entry = json.load(f)\n                entry['filepath'] = filepath\n                history.append(entry)\n        except Exception:\n            continue\n\n    return history\n\n\ndef delete_calibration(device_ip: str) -> dict:\n    \"\"\"\n    删除校准结果\n\n    Args:\n        device_ip: 设备 IP\n\n    Returns:\n        {'success': bool, 'message': str}\n    \"\"\"\n    config_path = get_config_path()\n\n    if not os.path.exists(config_path):\n        return {'success': False, 'message': '配置文件不存在'}\n\n    try:\n        with open(config_path, 'r', encoding='utf-8') as f:\n            config = json.load(f)\n    except Exception:\n        return {'success': False, 'message': '读取配置失败'}\n\n    device_key = device_ip.replace('.', '_')\n\n    if 'devices' not in config or device_key not in config['devices']:\n        return {'success': False, 'message': '设备校准记录不存在'}\n\n    # 删除\n    del config['devices'][device_key]\n\n    # 保存\n    try:\n        with open(config_path, 'w', encoding='utf-8') as f:\n            json.dump(config, f, indent=2, ensure_ascii=False)\n    except Exception as e:\n        return {'success': False, 'message': f'保存失败: {str(e)}'}\n\n    return {'success': True, 'message': f'设备 {device_ip} 校准记录已删除'}\n\n\ndef list_calibrated_devices() -> list[dict]:\n    \"\"\"\n    列出所有已校准设备\n\n    Returns:\n        [{'device_ip': ..., 'timestamp': ..., 'obs_lat': ..., 'obs_lon': ...}, ...]\n    \"\"\"\n    config_path = get_config_path()\n\n    if not os.path.exists(config_path):\n        return []\n\n    try:\n        with open(config_path, 'r', encoding='utf-8') as f:\n            config = json.load(f)\n    except Exception:\n        return []\n\n    if 'devices' not in config:\n        return []\n\n    devices = []\n    for key, data in config['devices'].items():\n        devices.append({\n            'device_ip': data.get('device_ip'),\n            'timestamp': data.get('timestamp'),\n            'obs_lat': data.get('obs_lat'),\n            'obs_lon': data.get('obs_lon'),\n            'rms': data.get('metadata', {}).get('fit_rms'),\n        })\n\n    return devices\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试校准存储模块\")\n\n    # 测试保存\n    test_params = {\n        'IA': 0.5,\n        'IH': -0.3,\n        'NP': 0.1,\n        'level_ns': 0.05,\n        'level_ew': -0.02,\n        'AW': 0.01,\n    }\n\n    result = save_calibration(\n        device_ip='192.168.1.100',\n        params=test_params,\n        obs_lat=40.0,\n        obs_lon=120.0,\n        metadata={'fit_rms': {'az': 0.1, 'alt': 0.15}},\n    )\n    print(f\"\\n保存结果: {result['message']}\")\n\n    # 测试加载\n    loaded = load_calibration('192.168.1.100')\n    if loaded:\n        print(f\"加载成功: {loaded['params']}\")\n\n    # 测试历史记录\n    history = get_calibration_history('192.168.1.100')\n    print(f\"历史记录数量: {len(history)}\")\n\n    # 测试设备列表\n    devices = list_calibrated_devices()\n    print(f\"已校准设备数量: {len(devices)}\")\n\n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\calibration_store.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":75435,"output":2152,"cacheRead":0,"cacheWrite":0,"totalTokens":77587,"cost":{"input":0.075435,"output":0.006886400000000001,"cacheRead":0,"cacheWrite":0,"total":0.0823214}},"stopReason":"toolUse","timestamp":1780515927465,"responseId":"cht000ff42f@dx19e8f04f6c5b8ab592"}}
