{"type":"message","id":"6eb7226d","parentId":"0e7424d5","timestamp":"2026-06-03T19:47:04.239Z","message":{"role":"assistant","content":[{"type":"text","text":"**Phase 2.1：方案一 - 手动校准**"},{"type":"toolCall","id":"tool-94c8f6ecb5dc461a9635165d6140d49d","name":"write","arguments":{"content":"\"\"\"\n方案一：已知恒星手动校准\n\n用户手动将恒星移动到 PTZ 画面中央，系统记录校准点。\n\n流程：\n1. 系统推荐可见亮星\n2. 用户选择恒星 → 系统显示其当前 Alt/Az\n3. 用户手动控制 PTZ 将星移到画面中央\n4. 用户点击\"记录\" → 系统记录 PTZ 读数 + 理论位置\n5. 重复 4-5 次\n6. 系统计算校准参数\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport math\nfrom datetime import datetime\nfrom typing import Optional\n\nfrom .core.coordinates import equatorial_to_altaz, apply_refraction\nfrom .core.star_catalog import (\n    get_bright_stars,\n    get_visible_stars,\n    recommend_calibration_stars,\n    get_star_position,\n)\nfrom .core.model import PointingModel\nfrom .calibration_store import save_calibration\n\n\nclass ManualCalibration:\n    \"\"\"\n    方案一：已知恒星手动校准\n    \"\"\"\n\n    def __init__(\n        self,\n        device_ip: str,\n        obs_lat: float,\n        obs_lon: float,\n        get_ptz_position_fn: Optional[callable] = None,\n    ):\n        \"\"\"\n        初始化手动校准\n\n        Args:\n            device_ip: PTZ 设备 IP\n            obs_lat: 观测站纬度 (角度)\n            obs_lon: 观测站经度 (角度)\n            get_ptz_position_fn: 获取 PTZ 位置的函数 (返回 {'pan': float, 'tilt': float})\n        \"\"\"\n        self.device_ip = device_ip\n        self.obs_lat = obs_lat\n        self.obs_lon = obs_lon\n        self.get_ptz_position = get_ptz_position_fn\n\n        # 校准数据\n        self.calibration_points = []\n        self.selected_star = None\n        self.model = PointingModel()\n        self.started = False\n        self.completed = False\n\n    def start(self) -> dict:\n        \"\"\"\n        开始校准，返回推荐的校准星列表\n\n        Returns:\n            {'success': True, 'recommended_stars': [...], 'message': ...}\n        \"\"\"\n        self.started = True\n        self.calibration_points = []\n        self.completed = False\n\n        obs_time = datetime.now()\n\n        # 推荐校准星\n        recommended = recommend_calibration_stars(\n            obs_time=obs_time,\n            lat=self.obs_lat,\n            lon=self.obs_lon,\n            count=5,\n        )\n\n        return {\n            'success': True,\n            'recommended_stars': recommended,\n            'obs_time': obs_time.isoformat(),\n            'message': f'推荐 {len(recommended)} 颗校准星，请选择一颗进行校准',\n        }\n\n    def select_star(self, star_name: str) -> dict:\n        \"\"\"\n        用户选择恒星，返回其当前位置\n\n        Args:\n            star_name: 星名（部分匹配）\n\n        Returns:\n            {'success': bool, 'star': {...}, 'position': {'az': ..., 'alt': ...}, 'message': ...}\n        \"\"\"\n        obs_time = datetime.now()\n\n        # 获取星位置\n        star_pos = get_star_position(star_name, obs_time, self.obs_lat, self.obs_lon)\n\n        if not star_pos:\n            return {\n                'success': False,\n                'star': None,\n                'position': None,\n                'message': f'未找到恒星: {star_name}',\n            }\n\n        self.selected_star = star_pos\n\n        # 应用折射修正后的理论位置\n        alt_refracted = apply_refraction(star_pos['alt'])\n\n        return {\n            'success': True,\n            'star': star_pos,\n            'position': {\n                'az': star_pos['az'],\n                'alt': round(alt_refracted, 2),  # 折射修正后\n            },\n            'message': f'已选择 {star_pos[\"name\"]}, 请将恒星移动到画面中央后点击记录',\n        }\n\n    def record_point(self, pan_enc: Optional[float] = None, tilt_enc: Optional[float] = None) -> dict:\n        \"\"\"\n        用户对准后记录校准点\n\n        Args:\n            pan_enc: PTZ Pan 读数 (角度，可选，如果不提供则调用 get_ptz_position)\n            tilt_enc: PTZ Tilt 读数 (角度)\n\n        Returns:\n            {'success': bool, 'point_index': ..., 'total_points': ..., 'message': ...}\n        \"\"\"\n        if not self.selected_star:\n            return {\n                'success': False,\n                'point_index': 0,\n                'total_points': len(self.calibration_points),\n                'message': '请先选择恒星',\n            }\n\n        # 获取 PTZ 位置\n        if pan_enc is None or tilt_enc is None:\n            if self.get_ptz_position:\n                try:\n                    pos = self.get_ptz_position()\n                    pan_enc = pos.get('pan', 0)\n                    tilt_enc = pos.get('tilt', 0)\n                except Exception as e:\n                    return {\n                        'success': False,\n                        'point_index': 0,\n                        'total_points': len(self.calibration_points),\n                        'message': f'获取 PTZ 位置失败: {str(e)}',\n                    }\n            else:\n                return {\n                    'success': False,\n                    'point_index': 0,\n                    'total_points': len(self.calibration_points),\n                    'message': '请提供 PTZ 位置或设置 get_ptz_position_fn',\n                }\n\n        # 记录校准点\n        obs_time = datetime.now()\n\n        point = {\n            'az_enc': pan_enc,  # PTZ Pan 对应 Azimuth\n            'alt_enc': tilt_enc,  # PTZ Tilt 对应 Altitude\n            'ra_actual': self.selected_star['ra'],\n            'dec_actual': self.selected_star['dec'],\n            'star_name': self.selected_star['name'],\n            'obs_time': obs_time.isoformat(),\n        }\n\n        self.calibration_points.append(point)\n\n        # 检查覆盖情况\n        coverage = self._check_coverage()\n\n        return {\n            'success': True,\n            'point_index': len(self.calibration_points),\n            'total_points': len(self.calibration_points),\n            'star_name': self.selected_star['name'],\n            'az_enc': pan_enc,\n            'alt_enc': tilt_enc,\n            'coverage': coverage,\n            'message': f'已记录 {self.selected_star[\"name\"]}, 当前共 {len(self.calibration_points)} 个校准点',\n        }\n\n    def _check_coverage(self) -> dict:\n        \"\"\"\n        检查校准点覆盖情况\n\n        Returns:\n            {'az_spread': 方位角范围, 'alt_spread': 高度角范围, 'needs_more': bool}\n        \"\"\"\n        if len(self.calibration_points) < 2:\n            return {'az_spread': 0, 'alt_spread': 0, 'needs_more': True}\n\n        az_values = [p['az_enc'] for p in self.calibration_points]\n        alt_values = [p['alt_enc'] for p in self.calibration_points]\n\n        az_spread = max(az_values) - min(az_values)\n        alt_spread = max(alt_values) - min(alt_values)\n\n        # 需要：方位角覆盖 > 120°, 高度角覆盖 > 30°, 至少 4 个点\n        needs_more = (\n            az_spread < 120 or\n            alt_spread < 30 or\n            len(self.calibration_points) < 4\n        )\n\n        return {\n            'az_spread': round(az_spread, 1),\n            'alt_spread': round(alt_spread, 1),\n            'min_az': round(min(az_values), 1),\n            'max_az': round(max(az_values), 1),\n            'min_alt': round(min(alt_values), 1),\n            'max_alt': round(max(alt_values), 1),\n            'needs_more': needs_more,\n        }\n\n    def can_compute(self) -> bool:\n        \"\"\"\n        是否可以计算校准参数\n\n        需要：\n        - 至少 4 个校准点\n        - 方位角覆盖 > 120°\n        - 高度角覆盖 > 30°\n        \"\"\"\n        coverage = self._check_coverage()\n        return not coverage['needs_more']\n\n    def compute(self) -> dict:\n        \"\"\"\n        计算校准参数\n\n        Returns:\n            {'success': bool, 'params': {...}, 'rms': {...}, 'message': ...}\n        \"\"\"\n        if not self.can_compute():\n            coverage = self._check_coverage()\n            return {\n                'success': False,\n                'params': None,\n                'rms': None,\n                'message': f'校准点不足: 方位角覆盖={coverage[\"az_spread\"]}° (需>120°), 高度角覆盖={coverage[\"alt_spread\"]}° (需>30°)',\n            }\n\n        # 拟合模型\n        fit_result = self.model.fit(\n            calibration_points=self.calibration_points,\n            obs_lat=self.obs_lat,\n            obs_lon=self.obs_lon,\n        )\n\n        if fit_result['success']:\n            self.completed = True\n\n        return fit_result\n\n    def save(self) -> dict:\n        \"\"\"\n        保存校准结果\n\n        Returns:\n            {'success': bool, 'message': ...}\n        \"\"\"\n        if not self.completed:\n            return {'success': False, 'message': '请先完成校准计算'}\n\n        # 保存校准参数\n        save_result = save_calibration(\n            device_ip=self.device_ip,\n            params=self.model.get_params_degrees(),\n            obs_lat=self.obs_lat,\n            obs_lon=self.obs_lon,\n            metadata={\n                'fit_rms': self.model.fit_rms,\n                'num_points': self.model.num_points,\n                'calibration_points': self.calibration_points,\n                'method': 'manual',\n            },\n        )\n\n        return save_result\n\n    def get_status(self) -> dict:\n        \"\"\"\n        获取当前校准状态\n\n        Returns:\n            {'started': bool, 'completed': bool, 'total_points': ..., 'coverage': ...}\n        \"\"\"\n        return {\n            'started': self.started,\n            'completed': self.completed,\n            'total_points': len(self.calibration_points),\n            'coverage': self._check_coverage(),\n            'selected_star': self.selected_star,\n            'can_compute': self.can_compute(),\n        }\n\n    def reset(self) -> dict:\n        \"\"\"\n        重置校准\n\n        Returns:\n            {'success': True, 'message': '校准已重置'}\n        \"\"\"\n        self.started = False\n        self.completed = False\n        self.calibration_points = []\n        self.selected_star = None\n        self.model = PointingModel()\n\n        return {'success': True, 'message': '校准已重置'}\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试手动校准模块\")\n\n    # 创建校准实例\n    calib = ManualCalibration(\n        device_ip='192.168.1.100',\n        obs_lat=40.0,\n        obs_lon=120.0,\n    )\n\n    # 开始校准\n    start_result = calib.start()\n    print(f\"\\n开始校准: {start_result['message']}\")\n    print(f\"推荐校准星: {[s['name'] for s in start_result['recommended_stars']]}\")\n\n    # 选择恒星\n    if start_result['recommended_stars']:\n        first_star = start_result['recommended_stars'][0]['name']\n        select_result = calib.select_star(first_star)\n        print(f\"\\n选择恒星: {select_result['message']}\")\n        if select_result['success']:\n            print(f\"位置: Az={select_result['position']['az']}°, Alt={select_result['position']['alt']}°\")\n\n    # 模拟记录校准点\n    print(\"\\n模拟记录校准点...\")\n    calib.selected_star = {'name': 'Test Star', 'ra': 5.5, 'dec': 45}\n\n    # 记录多个点\n    test_points = [\n        {'pan': 30, 'tilt': 40},\n        {'pan': 90, 'tilt': 50},\n        {'pan': 150, 'tilt': 60},\n        {'pan': 210, 'tilt': 45},\n    ]\n\n    for pt in test_points:\n        calib.selected_star = {'name': f'Star_{pt[\"pan\"]}', 'ra': pt[\"pan\"] / 15, 'dec': pt[\"tilt\"]}\n        result = calib.record_point(pt['pan'], pt['tilt'])\n        print(f\"  记录点: {result['message']}\")\n\n    # 检查状态\n    status = calib.get_status()\n    print(f\"\\n校准状态: {status['coverage']}\")\n\n    # 计算校准参数（使用模拟数据）\n    # 实际计算需要更多真实数据\n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\calibration_manual.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":77625,"output":2849,"cacheRead":0,"cacheWrite":0,"totalTokens":80474,"cost":{"input":0.077625,"output":0.009116800000000001,"cacheRead":0,"cacheWrite":0,"total":0.08674180000000001}},"stopReason":"toolUse","timestamp":1780515969021,"responseId":"cht000d29fa@dx19e8f059915ba29112"}}
