{"type":"message","id":"8d86e874","parentId":"6e8575a1","timestamp":"2026-06-03T19:47:48.758Z","message":{"role":"assistant","content":[{"type":"text","text":"**Phase 2.2：方案二 - 自动解析校准**"},{"type":"toolCall","id":"call_459d337eca874ada89d176f0","name":"write","arguments":{"content":"\"\"\"\n方案二：任意位置自动解析校准\n\n用户控制 PTZ 指向任意位置，系统通过 Plate Solve 识别实际指向。\n\n流程：\n1. 用户控制 PTZ 指向任意位置\n2. 用户点击\"拍摄并解析\"\n3. 系统调用 Plate Solve → 得到实际 RA/DEC\n4. 记录 PTZ 读数 + 实际位置\n5. 用户移动 PTZ >30°\n6. 重复 4-5 次\n7. 系统计算校准参数\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport os\nimport math\nfrom datetime import datetime\nfrom typing import Optional\n\nfrom .core.coordinates import equatorial_to_altaz, altaz_to_equatorial, apply_refraction\nfrom .core.plate_solve import solve_image, check_astap_installed\nfrom .core.model import PointingModel\nfrom .calibration_store import save_calibration\n\n\nclass AutoCalibration:\n    \"\"\"\n    方案二：任意位置自动解析校准\n    \"\"\"\n\n    def __init__(\n        self,\n        device_ip: str,\n        obs_lat: float,\n        obs_lon: float,\n        get_ptz_position_fn: Optional[callable] = None,\n        capture_image_fn: Optional[callable] = None,\n        image_dir: str = \"calibrate/image\",\n    ):\n        \"\"\"\n        初始化自动校准\n\n        Args:\n            device_ip: PTZ 设备 IP\n            obs_lat: 观测站纬度 (角度)\n            obs_lon: 观测站经度 (角度)\n            get_ptz_position_fn: 获取 PTZ 位置的函数\n            capture_image_fn: 拍摄图像的函数 (返回图像路径)\n            image_dir: 图像存储目录\n        \"\"\"\n        self.device_ip = device_ip\n        self.obs_lat = obs_lat\n        self.obs_lon = obs_lon\n        self.get_ptz_position = get_ptz_position_fn\n        self.capture_image = capture_image_fn\n        self.image_dir = image_dir\n\n        # 校准数据\n        self.calibration_points = []\n        self.model = PointingModel()\n        self.started = False\n        self.completed = False\n        self.last_point = None\n\n    def start(self) -> dict:\n        \"\"\"\n        开始校准\n\n        Returns:\n            {'success': True, 'astap_status': {...}, 'message': ...}\n        \"\"\"\n        # 检查 ASTAP 是否安装\n        astap_status = check_astap_installed()\n\n        self.started = True\n        self.calibration_points = []\n        self.completed = False\n        self.last_point = None\n\n        return {\n            'success': True,\n            'astap_status': astap_status,\n            'message': '校准已开始，请将 PTZ 指向有星星的天空位置，然后点击拍摄',\n        }\n\n    def capture_and_solve(\n        self,\n        pan_enc: Optional[float] = None,\n        tilt_enc: Optional[float] = None,\n        image_path: Optional[str] = None,\n        fov_hint: Optional[float] = None,\n    ) -> dict:\n        \"\"\"\n        拍摄并解析，记录校准点\n\n        Args:\n            pan_enc: PTZ Pan 读数 (可选)\n            tilt_enc: PTZ Tilt 读数 (可选)\n            image_path: 已有图像路径 (可选，如不提供则拍摄)\n            fov_hint: 视场角提示 (度)\n\n        Returns:\n            {'success': bool, 'point_index': ..., 'ra': ..., 'dec': ..., 'message': ...}\n        \"\"\"\n        # 获取 PTZ 位置\n        if pan_enc is None or tilt_enc is None:\n            if self.get_ptz_position:\n                try:\n                    pos = self.get_ptz_position()\n                    pan_enc = pos.get('pan', 0)\n                    tilt_enc = pos.get('tilt', 0)\n                except Exception as e:\n                    return {\n                        'success': False,\n                        'message': f'获取 PTZ 位置失败: {str(e)}',\n                    }\n            else:\n                return {\n                    'success': False,\n                    'message': '请提供 PTZ 位置或设置 get_ptz_position_fn',\n                }\n\n        # 获取图像\n        if not image_path:\n            if self.capture_image:\n                try:\n                    image_path = self.capture_image()\n                except Exception as e:\n                    return {\n                        'success': False,\n                        'message': f'拍摄失败: {str(e)}',\n                    }\n            else:\n                return {\n                    'success': False,\n                    'message': '请提供图像路径或设置 capture_image_fn',\n                }\n\n        # 检查图像文件\n        if not os.path.isfile(image_path):\n            return {\n                'success': False,\n                'message': f'图像文件不存在: {image_path}',\n            }\n\n        # Plate Solve\n        obs_time = datetime.now()\n        solve_result = solve_image(image_path, fov_hint=fov_hint)\n\n        if not solve_result['success']:\n            return {\n                'success': False,\n                'message': f'星图识别失败: {solve_result.get(\"error\", \"未知错误\")}',\n            }\n\n        # 记录校准点\n        point = {\n            'az_enc': pan_enc,\n            'alt_enc': tilt_enc,\n            'ra_actual': solve_result['ra'],\n            'dec_actual': solve_result['dec'],\n            'obs_time': obs_time.isoformat(),\n            'image_path': image_path,\n            'rotation': solve_result.get('rotation', 0),\n            'fov': solve_result.get('fov', 0),\n        }\n\n        self.calibration_points.append(point)\n        self.last_point = point\n\n        # 检查覆盖\n        coverage = self._check_coverage()\n        movement_hint = self._get_movement_hint()\n\n        return {\n            'success': True,\n            'point_index': len(self.calibration_points),\n            'total_points': len(self.calibration_points),\n            'ra': solve_result['ra'],\n            'dec': solve_result['dec'],\n            'az_enc': pan_enc,\n            'alt_enc': tilt_enc,\n            'coverage': coverage,\n            'movement_hint': movement_hint,\n            'message': f'已记录校准点 #{len(self.calibration_points)}, RA={solve_result[\"ra\"]:.2f}h, DEC={solve_result[\"dec\"]:.2f}°',\n        }\n\n    def _check_coverage(self) -> dict:\n        \"\"\"\n        检查校准点覆盖情况\n        \"\"\"\n        if len(self.calibration_points) < 2:\n            return {\n                'az_spread': 0,\n                'alt_spread': 0,\n                'needs_more': True,\n            }\n\n        az_values = [p['az_enc'] for p in self.calibration_points]\n        alt_values = [p['alt_enc'] for p in self.calibration_points]\n\n        az_spread = max(az_values) - min(az_values)\n        alt_spread = max(alt_values) - min(alt_values)\n\n        # 需要：方位角覆盖 > 120°, 高度角覆盖 > 30°, 至少 4 个点\n        needs_more = (\n            az_spread < 120 or\n            alt_spread < 30 or\n            len(self.calibration_points) < 4\n        )\n\n        return {\n            'az_spread': round(az_spread, 1),\n            'alt_spread': round(alt_spread, 1),\n            'min_az': round(min(az_values), 1),\n            'max_az': round(max(az_values), 1),\n            'min_alt': round(min(alt_values), 1),\n            'max_alt': round(max(alt_values), 1),\n            'needs_more': needs_more,\n        }\n\n    def _get_movement_hint(self) -> str:\n        \"\"\"\n        获取移动建议\n\n        要求：每次移动 >30°\n        \"\"\"\n        if not self.last_point:\n            return \"移动 PTZ 到新的天空位置\"\n\n        coverage = self._check_coverage()\n\n        if coverage['az_spread'] < 120:\n            return f\"建议水平移动 >30°，当前方位角覆盖仅 {coverage['az_spread']}°\"\n\n        if coverage['alt_spread'] < 30:\n            return f\"建议垂直移动 >30°，当前高度角覆盖仅 {coverage['alt_spread']}°\"\n\n        return \"继续采集更多校准点，或点击计算完成校准\"\n\n    def can_compute(self) -> bool:\n        \"\"\"\n        是否可以计算校准参数\n        \"\"\"\n        coverage = self._check_coverage()\n        return not coverage['needs_more']\n\n    def compute(self) -> dict:\n        \"\"\"\n        计算校准参数\n        \"\"\"\n        if not self.can_compute():\n            coverage = self._check_coverage()\n            return {\n                'success': False,\n                'params': None,\n                'rms': None,\n                'message': f'校准点不足: 方位角覆盖={coverage[\"az_spread\"]}° (需>120°), 高度角覆盖={coverage[\"alt_spread\"]}° (需>30°)',\n            }\n\n        # 拟合模型\n        fit_result = self.model.fit(\n            calibration_points=self.calibration_points,\n            obs_lat=self.obs_lat,\n            obs_lon=self.obs_lon,\n        )\n\n        if fit_result['success']:\n            self.completed = True\n\n        return fit_result\n\n    def save(self) -> dict:\n        \"\"\"\n        保存校准结果\n        \"\"\"\n        if not self.completed:\n            return {'success': False, 'message': '请先完成校准计算'}\n\n        save_result = save_calibration(\n            device_ip=self.device_ip,\n            params=self.model.get_params_degrees(),\n            obs_lat=self.obs_lat,\n            obs_lon=self.obs_lon,\n            metadata={\n                'fit_rms': self.model.fit_rms,\n                'num_points': self.model.num_points,\n                'calibration_points': self.calibration_points,\n                'method': 'auto',\n            },\n        )\n\n        return save_result\n\n    def get_status(self) -> dict:\n        \"\"\"\n        获取当前校准状态\n        \"\"\"\n        return {\n            'started': self.started,\n            'completed': self.completed,\n            'total_points': len(self.calibration_points),\n            'coverage': self._check_coverage(),\n            'last_point': self.last_point,\n            'can_compute': self.can_compute(),\n            'movement_hint': self._get_movement_hint(),\n        }\n\n    def reset(self) -> dict:\n        \"\"\"\n        重置校准\n        \"\"\"\n        self.started = False\n        self.completed = False\n        self.calibration_points = []\n        self.last_point = None\n        self.model = PointingModel()\n\n        return {'success': True, 'message': '校准已重置'}\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试自动校准模块\")\n\n    # 创建校准实例\n    calib = AutoCalibration(\n        device_ip='192.168.1.100',\n        obs_lat=40.0,\n        obs_lon=120.0,\n    )\n\n    # 开始校准\n    start_result = calib.start()\n    print(f\"\\n开始校准: {start_result['message']}\")\n    print(f\"ASTAP 状态: {start_result['astap_status']['message']}\")\n\n    # 检查状态\n    status = calib.get_status()\n    print(f\"\\n校准状态: {status}\")\n\n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\calibrate\\calibration_auto.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":84788,"output":2496,"cacheRead":0,"cacheWrite":0,"totalTokens":87284,"cost":{"input":0.084788,"output":0.0079872,"cacheRead":0,"cacheWrite":0,"total":0.0927752}},"stopReason":"toolUse","timestamp":1780516024252,"responseId":"cht000f0e58@dx19e8f0670d9b8ab592"}}
