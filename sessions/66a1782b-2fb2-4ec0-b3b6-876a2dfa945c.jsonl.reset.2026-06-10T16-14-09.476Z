{"type":"message","id":"3d905082","parentId":"5b3a7a9e","timestamp":"2026-06-04T06:15:54.542Z","message":{"role":"assistant","content":[{"type":"text","text":"**Step 4: 输出模块 (FITS + JPG)**"},{"type":"toolCall","id":"call_a596e2a35c6345d9ac7c2563","name":"write","arguments":{"content":"\"\"\"\n输出模块\n\n保存 FITS 16-bit 和 JPG 8-bit 文件。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport os\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Optional\n\n# FITS 相关\ntry:\n    from astropy.io import fits\n    from astropy import units as u\n    HAS_ASTROPY = True\nexcept ImportError:\n    HAS_ASTROPY = False\n    fits = None\n\nimport cv2\n\n\nclass OutputWriter:\n    \"\"\"\n    输出写入器\n    \n    支持：\n    - FITS 16-bit (叠加后)\n    - JPG 8-bit (预览)\n    \"\"\"\n    \n    def __init__(self, output_dir: str = \"stack/output\"):\n        \"\"\"\n        初始化输出器\n        \n        Args:\n            output_dir: 输出目录\n        \"\"\"\n        self.output_dir = output_dir\n        \n        # 创建目录\n        if not os.path.exists(output_dir):\n            os.makedirs(output_dir, exist_ok=True)\n    \n    def save(\n        self,\n        image: np.ndarray,\n        basename: str,\n        exposure_time: float,\n        n_frames: int,\n        save_fits: bool = True,\n        save_jpg: bool = True,\n    ) -> dict:\n        \"\"\"\n        保存图像\n        \n        Args:\n            image: 叠加后的图像 (float32)\n            basename: 基础文件名\n            exposure_time: 等效曝光时间 (秒)\n            n_frames: 叠加帧数\n            save_fits: 是否保存 FITS\n            save_jpg: 是否保存 JPG\n        \n        Returns:\n            {'fits_path': ..., 'jpg_path': ...}\n        \"\"\"\n        result = {}\n        \n        # FITS 输出\n        if save_fits and HAS_ASTROPY:\n            fits_path = os.path.join(self.output_dir, f\"{basename}.fits\")\n            self._save_fits(image, fits_path, exposure_time, n_frames)\n            result['fits_path'] = fits_path\n        \n        # JPG 输出\n        if save_jpg:\n            jpg_path = os.path.join(self.output_dir, f\"{basename}.jpg\")\n            self._save_jpg(image, jpg_path)\n            result['jpg_path'] = jpg_path\n        \n        return result\n    \n    def _save_fits(\n        self,\n        image: np.ndarray,\n        filepath: str,\n        exposure_time: float,\n        n_frames: int,\n    ) -> None:\n        \"\"\"\n        保存 FITS 文件 (16-bit)\n        \n        Header 包含：\n        - EXPTIME: 等效曝光时间\n        - NFRAMES: 叠加帧数\n        - DATE-OBS: 观测时间\n        - STACKMETH: 叠加方法\n        \"\"\"\n        # 归一化到 16-bit\n        img_normalized = self._normalize_to_16bit(image)\n        \n        # 创建 FITS\n        hdu = fits.PrimaryHDU(img_normalized.astype(np.uint16))\n        \n        # 设置 Header\n        hdu.header['EXPTIME'] = (exposure_time, 'Equivalent exposure time (seconds)')\n        hdu.header['NFRAMES'] = (n_frames, 'Number of stacked frames')\n        hdu.header['DATE-OBS'] = (datetime.now().isoformat(), 'Observation date/time')\n        hdu.header['STACKMETH'] = ('SIGMA_CLIP', 'Stacking method')\n        hdu.header['BITPIX'] = (16, 'Bits per pixel')\n        hdu.header['BSCALE'] = (1.0, 'Scale factor')\n        hdu.header['BZERO'] = (32768.0, 'Zero offset')\n        \n        # 保存\n        hdu.writeto(filepath, overwrite=True)\n    \n    def _save_jpg(self, image: np.ndarray, filepath: str) -> None:\n        \"\"\"\n        保存 JPG 文件 (8-bit)\n        \n        自动对比度拉伸\n        \"\"\"\n        # 归一化到 8-bit\n        img_8bit = self._normalize_to_8bit(image)\n        \n        # 保存\n        cv2.imwrite(filepath, img_8bit, [cv2.IMWRITE_JPEG_QUALITY, 95])\n    \n    def _normalize_to_16bit(self, image: np.ndarray) -> np.ndarray:\n        \"\"\"\n        归一化到 16-bit (0-65535)\n        \"\"\"\n        img = image.astype(np.float64)\n        \n        # 百分位拉伸\n        vmin = np.percentile(img, 0.5)\n        vmax = np.percentile(img, 99.5)\n        \n        if vmax - vmin < 1e-6:\n            return np.zeros_like(image, dtype=np.uint16)\n        \n        # 拉伸并裁剪\n        img_scaled = (img - vmin) / (vmax - vmin)\n        img_scaled = np.clip(img_scaled, 0, 1)\n        \n        # 转换到 16-bit\n        img_16bit = (img_scaled * 65535).astype(np.uint16)\n        \n        return img_16bit\n    \n    def _normalize_to_8bit(self, image: np.ndarray) -> np.ndarray:\n        \"\"\"\n        归一化到 8-bit (0-255) 并应用对比度拉伸\n        \"\"\"\n        img = image.astype(np.float64)\n        \n        # 百分位拉伸（更强的对比度）\n        vmin = np.percentile(img, 1)\n        vmax = np.percentile(img, 99)\n        \n        if vmax - vmin < 1e-6:\n            return np.zeros_like(image, dtype=np.uint8)\n        \n        # 拉伸并裁剪\n        img_scaled = (img - vmin) / (vmax - vmin)\n        img_scaled = np.clip(img_scaled, 0, 1)\n        \n        # Gamma 校正（可选）\n        # img_scaled = np.power(img_scaled, 0.5)\n        \n        # 转换到 8-bit\n        img_8bit = (img_scaled * 255).astype(np.uint8)\n        \n        return img_8bit\n\n\ndef save_fits(\n    image: np.ndarray,\n    filepath: str,\n    exposure_time: float,\n    n_frames: int,\n) -> str:\n    \"\"\"\n    快捷函数：保存 FITS\n    \"\"\"\n    writer = OutputWriter()\n    writer._save_fits(image, filepath, exposure_time, n_frames)\n    return filepath\n\n\ndef save_jpg(image: np.ndarray, filepath: str) -> str:\n    \"\"\"\n    快捷函数：保存 JPG\n    \"\"\"\n    writer = OutputWriter()\n    writer._save_jpg(image, filepath)\n    return filepath\n\n\nif __name__ == '__main__':\n    print(\"测试输出模块\")\n    \n    # 创建测试图像\n    test_img = np.random.rand(100, 100).astype(np.float32) * 1000\n    \n    writer = OutputWriter(output_dir=\"stack/output\")\n    result = writer.save(\n        image=test_img,\n        basename=\"test_stack\",\n        exposure_time=10.0,\n        n_frames=100,\n    )\n    \n    print(f\"FITS: {result.get('fits_path', 'N/A')}\")\n    print(f\"JPG: {result.get('jpg_path', 'N/A')}\")\n    print(f\"astropy 可用: {HAS_ASTROPY}\")\n    print(\"测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\output.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":131263,"output":1614,"cacheRead":0,"cacheWrite":0,"totalTokens":132877,"cost":{"input":0.131263,"output":0.005164800000000001,"cacheRead":0,"cacheWrite":0,"total":0.1364278}},"stopReason":"toolUse","timestamp":1780553697055,"responseId":"cht000d01c9@dx19e91457e6fb958402"}}
