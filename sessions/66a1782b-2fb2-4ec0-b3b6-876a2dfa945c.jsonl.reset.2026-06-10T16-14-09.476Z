{"type":"message","id":"9ff4f78c","parentId":"75869381","timestamp":"2026-06-04T08:10:23.967Z","message":{"role":"assistant","content":[{"type":"text","text":"需求文档已写入。现在重写 `live_stack.py`（包含 XY + 旋转对齐）："},{"type":"toolCall","id":"tool-f325ac67c7994b13829759f8f46a1f12","name":"write","arguments":{"content":"\"\"\"\nLive Stack 实时叠加模块\n\n边采集边叠加，实时输出预览。\n对齐必须包含 XY + 旋转（使用 astroalign 三角形法）。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport time\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Optional, Callable, Tuple\n\n# 尝试导入 astroalign\ntry:\n    import astroalign as aa\n    HAS_ASTROALIGN = True\nexcept ImportError:\n    HAS_ASTROALIGN = False\n    aa = None\n\nimport cv2\n\nfrom .detect import StarDetector\nfrom .output import OutputWriter\n\n\nclass LiveStack:\n    \"\"\"\n    Live Stack 实时叠加器\n    \n    特点：\n    - Running Mean 实时累加（O(1) 内存）\n    - XY + 旋转对齐（astroalign）\n    - 实时预览输出\n    \"\"\"\n    \n    def __init__(\n        self,\n        hardware_exposure_ms: float = 100,\n        fwhm: float = 3.0,\n        threshold: float = 5.0,\n        output_dir: str = \"stack/output\",\n        preview_interval: int = 5,  # 每 N 帧刷新预览\n    ):\n        \"\"\"\n        初始化 Live Stack\n        \n        Args:\n            hardware_exposure_ms: PTZ 硬件曝光时间 (毫秒)\n            fwhm: 星点 FWHM\n            threshold: 检测阈值\n            output_dir: 输出目录\n            preview_interval: 预览刷新间隔（帧数）\n        \"\"\"\n        self.hardware_exposure_ms = hardware_exposure_ms\n        self.fwhm = fwhm\n        self.threshold = threshold\n        self.output_dir = output_dir\n        self.preview_interval = preview_interval\n        \n        # 星点检测器\n        self.detector = StarDetector(fwhm=fwhm, threshold=threshold)\n        \n        # 输出写入器\n        self.writer = OutputWriter(output_dir=output_dir)\n        \n        # Running Mean 状态\n        self.running_mean = None  # float32 累加图像\n        self.frame_count = 0\n        self.reference_frame = None\n        self.reference_stars = None\n        \n        # 目标状态\n        self.target_frames = 0\n        self.target_exposure = 0\n        self.is_running = False\n        \n        # 变换信息记录\n        self.transform_history = []\n    \n    def start(\n        self,\n        target_exposure: float,\n        mode: str = 'continuous',\n    ) -> dict:\n        \"\"\"\n        开始 Live Stack\n        \n        Args:\n            target_exposure: 目标等效曝光时间 (秒)\n            mode: 模式 ('continuous' 连续叠加, 'fixed' 固定帧数)\n        \n        Returns:\n            状态信息\n        \"\"\"\n        # 计算目标帧数\n        hardware_exposure_s = self.hardware_exposure_ms / 1000\n        self.target_frames = int(target_exposure / hardware_exposure_s)\n        self.target_exposure = target_exposure\n        \n        # 重置状态\n        self.running_mean = None\n        self.frame_count = 0\n        self.reference_frame = None\n        self.reference_stars = None\n        self.transform_history = []\n        self.is_running = True\n        \n        return {\n            'success': True,\n            'target_frames': self.target_frames,\n            'target_exposure': target_exposure,\n            'hardware_exposure_ms': self.hardware_exposure_ms,\n            'message': f'Live Stack 已启动，目标 {self.target_frames} 帧',\n        }\n    \n    def add_frame(\n        self,\n        frame: np.ndarray,\n        callback: Optional[Callable] = None,\n    ) -> dict:\n        \"\"\"\n        添加一帧到 Live Stack\n        \n        Args:\n            frame: 新帧 (灰度图像)\n            callback: 进度回调函数\n        \n        Returns:\n            {'success': bool, 'frame_count': ..., 'preview_path': ..., 'transform': ...}\n        \"\"\"\n        if not self.is_running:\n            return {'success': False, 'message': 'Live Stack 未启动'}\n        \n        # 转换为 float32\n        frame_float = frame.astype(np.float32)\n        \n        # 第一帧：作为参考\n        if self.reference_frame is None:\n            self.reference_frame = frame_float\n            self.reference_stars = self.detector.get_star_positions(frame)\n            self.running_mean = frame_float\n            self.frame_count = 1\n            \n            return {\n                'success': True,\n                'frame_count': 1,\n                'is_reference': True,\n                'stars_detected': len(self.reference_stars) if self.reference_stars else 0,\n            }\n        \n        # 后续帧：对齐后累加\n        try:\n            # 对齐（XY + 旋转）\n            aligned_frame, transform_info = self._align_frame(frame_float)\n            \n            # Running Mean 累加\n            self.frame_count += 1\n            self.running_mean = (\n                self.running_mean * (self.frame_count - 1) + aligned_frame\n            ) / self.frame_count\n            \n            # 记录变换\n            self.transform_history.append(transform_info)\n            \n            # 检查是否需要预览刷新\n            preview_path = None\n            if self.frame_count % self.preview_interval == 0:\n                preview_path = self._save_preview()\n            \n            # 回调\n            if callback:\n                callback(self.frame_count, self.target_frames, transform_info)\n            \n            return {\n                'success': True,\n                'frame_count': self.frame_count,\n                'transform': transform_info,\n                'preview_path': preview_path,\n            }\n        \n        except Exception as e:\n            return {'success': False, 'message': f'对齐失败: {str(e)}'}\n    \n    def _align_frame(\n        self,\n        frame: np.ndarray,\n    ) -> Tuple[np.ndarray, dict]:\n        \"\"\"\n        对齐帧（XY + 旋转）\n        \n        使用 astroalign 三角形法进行星点匹配对齐。\n        降级使用相位相关（仅平移）。\n        \"\"\"\n        # 检测当前帧星点\n        current_stars = self.detector.get_star_positions(frame)\n        \n        # astroalign 对齐（推荐）\n        if HAS_ASTROALIGN and len(current_stars) >= 3 and len(self.reference_stars) >= 3:\n            try:\n                aligned, footprint = aa.register(frame, self.reference_frame)\n                \n                # 获取变换信息\n                try:\n                    transf, (src_pts, tgt_pts) = aa.find_transform(frame, self.reference_frame)\n                    \n                    transform_info = {\n                        'method': 'astroalign',\n                        'rotation': np.degrees(transf.rotation),  # 旋转角度\n                        'translation': transf.translation.tolist(),  # XY 平移\n                        'scale': transf.scale,  # 缩放\n                        'src_stars': len(src_pts),\n                        'tgt_stars': len(tgt_pts),\n                    }\n                except Exception:\n                    transform_info = {'method': 'astroalign'}\n                \n                return aligned, transform_info\n            \n            except Exception as e:\n                # astroalign 失败，降级\n                pass\n        \n        # 降级：相位相关（仅平移）\n        shift, response = self._phase_correlate(frame, self.reference_frame)\n        \n        # 应用平移\n        M = np.array([[1, 0, -shift[0]], [0, 1, -shift[1]]], dtype=np.float32)\n        h, w = frame.shape[:2]\n        aligned = cv2.warpAffine(frame, M, (w, h))\n        \n        transform_info = {\n            'method': 'phase_correlate',\n            'shift_x': float(shift[0]),\n            'shift_y': float(shift[1]),\n            'rotation': 0.0,  # 无旋转\n            'response': float(response),\n        }\n        \n        return aligned, transform_info\n    \n    def _phase_correlate(\n        self,\n        source: np.ndarray,\n        reference: np.ndarray,\n    ) -> Tuple[np.ndarray, float]:\n        \"\"\"\n        相位相关法计算平移\n        \n        Returns:\n            (shift, response)\n        \"\"\"\n        # 确保 float32\n        src = source.astype(np.float32)\n        ref = reference.astype(np.float32)\n        \n        result = cv2.phaseCorrelate(ref, src)\n        \n        shift = np.array([result[0][0], result[0][1]])\n        response = result[1]\n        \n        return shift, response\n    \n    def _save_preview(self) -> str:\n        \"\"\"\n        保存预览 JPG\n        \n        Returns:\n            JPG 文件路径\n        \"\"\"\n        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n        preview_name = f\"live_preview_{timestamp}\"\n        \n        preview_path = self.writer._save_jpg(\n            self.running_mean,\n            f\"{self.output_dir}/{preview_name}.jpg\"\n        )\n        \n        return preview_path\n    \n    def finish(\n        self,\n        basename: Optional[str] = None,\n    ) -> dict:\n        \"\"\"\n        完成 Live Stack，保存最终结果\n        \n        Args:\n            basename: 输出文件名基础\n        \n        Returns:\n            {'success': bool, 'fits_path': ..., 'jpg_path': ..., 'transform_summary': ...}\n        \"\"\"\n        self.is_running = False\n        \n        if self.running_mean is None or self.frame_count == 0:\n            return {'success': False, 'message': '无叠加数据'}\n        \n        # 生成文件名\n        if not basename:\n            basename = f\"live_stack_{datetime.now().strftime('%Y%m%d_%H%M%S')}\"\n        \n        # 保存 FITS + JPG\n        output_result = self.writer.save(\n            image=self.running_mean,\n            basename=basename,\n            exposure_time=self.target_exposure,\n            n_frames=self.frame_count,\n        )\n        \n        # 变换统计\n        transform_summary = self._summarize_transforms()\n        \n        return {\n            'success': True,\n            'fits_path': output_result.get('fits_path'),\n            'jpg_path': output_result.get('jpg_path'),\n            'frame_count': self.frame_count,\n            'exposure_time': self.target_exposure,\n            'transform_summary': transform_summary,\n            'message': f'Live Stack 完成，共 {self.frame_count} 帧',\n        }\n    \n    def _summarize_transforms(self) -> dict:\n        \"\"\"\n        统计变换历史\n        \n        Returns:\n            {'avg_rotation': ..., 'avg_shift_x': ..., 'avg_shift_y': ...}\n        \"\"\"\n        if not self.transform_history:\n            return {}\n        \n        # 分离 astroalign 和 phase_correlate\n        astroalign_records = [t for t in self.transform_history if t.get('method') == 'astroalign']\n        phase_records = [t for t in self.transform_history if t.get('method') == 'phase_correlate']\n        \n        summary = {}\n        \n        if astroalign_records:\n            rotations = [t.get('rotation', 0) for t in astroalign_records]\n            translations = [t.get('translation', [0, 0]) for t in astroalign_records]\n            \n            summary['method'] = 'astroalign'\n            summary['avg_rotation'] = np.mean(rotations)\n            summary['max_rotation'] = np.max(np.abs(rotations))\n            summary['avg_translation'] = np.mean(translations, axis=0).tolist()\n        \n        if phase_records:\n            shifts_x = [t.get('shift_x', 0) for t in phase_records]\n            shifts_y = [t.get('shift_y', 0) for t in phase_records]\n            \n            summary['method'] = 'phase_correlate'\n            summary['avg_shift_x'] = np.mean(shifts_x)\n            summary['avg_shift_y'] = np.mean(shifts_y)\n        \n        return summary\n    \n    def get_status(self) -> dict:\n        \"\"\"\n        获取当前状态\n        \n        Returns:\n            {'is_running': ..., 'frame_count': ..., 'progress': ..., 'running_mean': ...}\n        \"\"\"\n        progress = 0.0\n        if self.target_frames > 0 and self.frame_count > 0:\n            progress = min(1.0, self.frame_count / self.target_frames)\n        \n        return {\n            'is_running': self.is_running,\n            'frame_count': self.frame_count,\n            'target_frames': self.target_frames,\n            'progress': round(progress * 100, 1),\n            'hardware_exposure_ms': self.hardware_exposure_ms,\n            'has_reference': self.reference_frame is not None,\n        }\n    \n    def reset(self) -> None:\n        \"\"\"\n        重置 Live Stack\n        \"\"\"\n        self.running_mean = None\n        self.frame_count = 0\n        self.reference_frame = None\n        self.reference_stars = None\n        self.transform_history = []\n        self.is_running = False\n\n\n# 模块测试\nif __name__ == '__main__':\n    import sys\n    from pathlib import Path\n    _project_root = str(Path(__file__).resolve().parent.parent)\n    if _project_root not in sys.path:\n        sys.path.insert(0, _project_root)\n    \n    print(\"测试 Live Stack 模块\")\n    \n    # 创建测试帧源\n    np.random.seed(42)\n    \n    live_stack = LiveStack(\n        hardware_exposure_ms=100,\n        output_dir=\"stack/output_live\",\n    )\n    \n    # 启动\n    result = live_stack.start(target_exposure=2.0)\n    print(f\"启动: {result['message']}\")\n    print(f\"astroalign 可用: {HAS_ASTROALIGN}\")\n    \n    # 添加帧（模拟轻微旋转）\n    for i in range(20):\n        base = np.ones((100, 100)) * 100\n        base[40:60, 40:60] = 500\n        \n        # 模拟轻微偏移和旋转\n        angle = np.random.uniform(-0.5, 0.5)\n        M = cv2.getRotationMatrix2D((50, 50), angle, 1)\n        shifted = cv2.warpAffine(base, M, (100, 100))\n        \n        noise = np.random.normal(0, 10, (100, 100))\n        frame = shifted + noise\n        \n        result = live_stack.add_frame(frame)\n        if i % 5 == 0:\n            print(f\"  帧 #{i+1}: {result.get('transform', {}).get('method', 'N/A')}\")\n    \n    # 完成\n    final = live_stack.finish()\n    print(f\"\\n完成: {final['message']}\")\n    print(f\"FITS: {final.get('fits_path', 'N/A')}\")\n    print(f\"JPG: {final.get('jpg_path', 'N/A')}\")\n    \n    # 变换统计\n    summary = final.get('transform_summary', {})\n    print(f\"变换统计: {summary}\")\n    \n    print(\"\\n测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\live_stack.py"}}],"api":"openai-completions","provider":"zai","model":"gl