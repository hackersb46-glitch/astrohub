{"type":"message","id":"b03aca71","parentId":"51132854","timestamp":"2026-06-04T06:11:30.321Z","message":{"role":"assistant","content":[{"type":"text","text":"**Step 1: 星点检测模块**"},{"type":"toolCall","id":"tool-16781b387a2e4b6b84e0924d1421591c","name":"write","arguments":{"content":"\"\"\"\n星点检测模块\n\n使用 photutils DAOStarFinder 进行高精度星点检测。\n支持降级到 OpenCV 方法（无 photutils 时）。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport numpy as np\nfrom typing import Optional\n\n# 尝试导入 photutils\ntry:\n    from photutils.detection import DAOStarFinder\n    HAS_PHOTUTILS = True\nexcept ImportError:\n    HAS_PHOTUTILS = False\n    DAOStarFinder = None\n\nimport cv2\n\n\nclass StarDetector:\n    \"\"\"\n    星点检测器\n    \n    优先使用 photutils DAOStarFinder（PSF拟合，精度高）\n    降级使用 OpenCV 方法（速度快，精度中等）\n    \"\"\"\n    \n    def __init__(\n        self,\n        fwhm: float = 3.0,\n        threshold: float = 5.0,\n        sharplo: float = 0.2,\n        sharphi: float = 1.0,\n        roundlo: float = -1.0,\n        roundhi: float = 1.0,\n    ):\n        \"\"\"\n        初始化星点检测器\n        \n        Args:\n            fwhm: 星点半高全宽 (像素)，根据 seeing 调整\n            threshold: 检测阈值 (SNR)，越高越严格\n            sharplo: 锐度下限，过滤非星形物体\n            sharphi: 锐度上限\n            roundlo: 圆度下限\n            roundhi: 圆度上限\n        \"\"\"\n        self.fwhm = fwhm\n        self.threshold = threshold\n        self.sharplo = sharplo\n        self.sharphi = sharphi\n        self.roundlo = roundlo\n        self.roundhi = roundhi\n    \n    def detect(self, image: np.ndarray, use_photutils: bool = True) -> list:\n        \"\"\"\n        检测星点\n        \n        Args:\n            image: 灰度图像 (numpy array)\n            use_photutils: 是否使用 photutils (默认True，无则降级)\n        \n        Returns:\n            星点列表 [(x, y, flux, sharpness, roundness), ...]\n            按亮度排序\n        \"\"\"\n        if use_photutils and HAS_PHOTUTILS:\n            return self._detect_photutils(image)\n        else:\n            return self._detect_opencv(image)\n    \n    def _detect_photutils(self, image: np.ndarray) -> list:\n        \"\"\"\n        使用 photutils DAOStarFinder 检测\n        \n        优点：\n        - PSF 拟合，亚像素精度\n        - 自动计算 sharpness, roundness\n        - 过滤宇宙射线、热像素\n        \"\"\"\n        # 确保图像是 float\n        if image.dtype != np.float32:\n            image = image.astype(np.float32)\n        \n        # 创建检测器\n        daofind = DAOStarFinder(\n            fwhm=self.fwhm,\n            threshold=self.threshold,\n            sharplo=self.sharplo,\n            sharphi=self.sharphi,\n            roundlo=self.roundlo,\n            roundhi=self.roundhi,\n        )\n        \n        # 检测\n        sources = daofind(image)\n        \n        if sources is None:\n            return []\n        \n        # 转换为列表\n        stars = []\n        for row in sources:\n            x = row['xcentroid']\n            y = row['ycentroid']\n            flux = row['flux']\n            sharpness = row['sharpness']\n            roundness = row['roundness']\n            stars.append((x, y, flux, sharpness, roundness))\n        \n        # 按亮度排序\n        stars.sort(key=lambda s: s[2], reverse=True)\n        \n        return stars\n    \n    def _detect_opencv(self, image: np.ndarray) -> list:\n        \"\"\"\n        使用 OpenCV 方法检测 (降级方案)\n        \n        方法：\n        1. 背景估计 (median blur)\n        2. 阈值检测\n        3. 连通域分析\n        \"\"\"\n        # 背景估计\n        background = cv2.medianBlur(image, 15)\n        \n        # 残差\n        residual = image.astype(np.float32) - background.astype(np.float32)\n        \n        # 阈值\n        mean_bg = np.mean(background)\n        std_bg = np.std(residual)\n        \n        if std_bg < 1:\n            std_bg = 1\n        \n        threshold_val = self.threshold * std_bg\n        mask = residual > threshold_val\n        \n        # 连通域\n        num_labels, labels, stats, centroids = cv2.connectedComponentsWithStats(\n            mask.astype(np.uint8)\n        )\n        \n        stars = []\n        for i in range(1, num_labels):  # 跳过背景\n            area = stats[i, cv2.CC_STAT_AREA]\n            if area < 3:  # 最小面积\n                continue\n            \n            x = centroids[i, 0]\n            y = centroids[i, 1]\n            flux = np.max(residual[labels == i])\n            \n            # 计算锐度 (近似)\n            sharpness = 0.5  # 默认值\n            \n            stars.append((x, y, flux, sharpness, 0.0))\n        \n        # 按亮度排序\n        stars.sort(key=lambda s: s[2], reverse=True)\n        \n        return stars\n    \n    def get_star_positions(self, image: np.ndarray) -> np.ndarray:\n        \"\"\"\n        获取星点位置数组 (用于对齐)\n        \n        Returns:\n            ndarray shape (N, 2), 每行为 [x, y]\n        \"\"\"\n        stars = self.detect(image)\n        \n        if not stars:\n            return np.array([])\n        \n        positions = np.array([[s[0], s[1]] for s in stars])\n        return positions\n\n\ndef detect_stars(\n    image: np.ndarray,\n    fwhm: float = 3.0,\n    threshold: float = 5.0,\n) -> list:\n    \"\"\"\n    快捷函数：检测星点\n    \n    Args:\n        image: 灰度图像\n        fwhm: 星点 FWHM\n        threshold: 检测阈值\n    \n    Returns:\n        星点列表\n    \"\"\"\n    detector = StarDetector(fwhm=fwhm, threshold=threshold)\n    return detector.detect(image)\n\n\n# 模块测试\nif __name__ == '__main__':\n    print(\"测试星点检测模块\")\n    \n    # 创建测试图像（模拟星点）\n    test_img = np.zeros((100, 100), dtype=np.float32)\n    \n    # 添加模拟星点\n    for x, y, brightness in [(30, 30, 100), (50, 50, 200), (70, 70, 150)]:\n        test_img[y-2:y+3, x-2:x+3] = brightness\n    \n    # 检测\n    detector = StarDetector(fwhm=3.0, threshold=5.0)\n    stars = detector.detect(test_img, use_photutils=False)  # 测试时用 OpenCV\n    \n    print(f\"检测到 {len(stars)} 个星点\")\n    for i, star in enumerate(stars[:5]):\n        print(f\"  #{i+1}: x={star[0]:.1f}, y={star[1]:.1f}, flux={star[2]:.1f}\")\n    \n    print(f\"\\nphotutils 可用: {HAS_PHOTUTILS}\")\n    print(\"测试完成\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\detect.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":117767,"output":1665,"cacheRead":0,"cacheWrite":0,"totalTokens":119432,"cost":{"input":0.117767,"output":0.005328,"cacheRead":0,"cacheWrite":0,"total":0.123095}},"stopReason":"toolUse","timestamp":1780553430715,"responseId":"cht000f92de@dx19e914154a2b8ab592"}}
