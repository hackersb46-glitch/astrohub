{"type":"message","id":"52ed7ce2","parentId":"e1e481d1","timestamp":"2026-06-04T08:25:39.625Z","message":{"role":"assistant","content":[{"type":"text","text":"---\n\n## 开发完成汇报 ✅\n\n### 已完成模块\n\n| 文件 | 功能 | 特性 |\n|------|------|------|\n| `live_stack.py` | Live Stack 核心算法 | Running Mean + XY + 旋转对齐 |\n| `live_view.py` | 实时预览控制 | 不保存中间帧，仅在内存处理 |\n| `requirements.md` | 需求文档 | 布局调整、硬件曝光时间处理 |\n\n### 关键特性\n\n1. **默认不保存中间叠加图像** ✅\n   - Running Mean 在内存中累加\n   - 仅最终输出 FITS + JPG\n\n2. **XY + 旋转对齐** ✅\n   - 优先使用 astroalign 三角形法\n   - 降级使用相位相关\n\n3. **硬件曝光时间处理** ✅\n   - 可配置 PTZ 硬件曝光参数\n   - 自动计算需要的帧数\n\n4. **实时预览** ✅\n   - 每 N 帧刷新预览\n   - Base64 编码供前端显示\n\n### 文件结构\n\n```\nastrohub/stack/\n├── live_stack.py      # Live Stack 核心\n├── live_view.py       # 实时预览\n├── requirements.md    # 需求文档\n├── detect.py          # 星点检测\n├── align.py           # 图像对齐\n├── stack.py           # 传统叠加\n├── output.py          # FITS+JPG输出\n└── process.py         # 完整流程\n```\n\n**待下一步**：集成到前端 UI（主控台 + 高级功能）"}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":150704,"output":367,"cacheRead":0,"cacheWrite":0,"totalTokens":151071,"cost":{"input":0.150704,"output":0.0011744000000000001,"cacheRead":0,"cacheWrite":0,"total":0.1518784}},"stopReason":"stop","timestamp":1780561505689,"responseId":"cht000d5be9@dx19e91bc7257b958402"}}
{"type":"message","id":"40502cda","parentId":"52ed7ce2","timestamp":"2026-06-04T08:49:26.826Z","message":{"role":"user","content":[{"type":"text","text":"Conversation info (untrusted metadata):\n```json\n{\n  \"chat_id\": \"telegram:8447197723\",\n  \"message_id\": \"31397\",\n  \"sender_id\": \"8447197723\",\n  \"sender\": \"Yixing Zhang\",\n  \"timestamp\": \"Thu 2026-06-04 16:49 GMT+8\"\n}\n```\n\nSender (untrusted metadata):\n```json\n{\n  \"label\": \"Yixing Zhang (8447197723)\",\n  \"id\": \"8447197723\",\n  \"name\": \"Yixing Zhang\",\n  \"username\": \"ZhangyixingTG\"\n}\n```\n\n现在集成"}],"timestamp":1780562966817}}
{"type":"message","id":"56ef516c","parentId":"40502cda","timestamp":"2026-06-04T08:50:20.076Z","message":{"role":"assistant","content":[{"type":"text","text":"好的，开始集成到前端 UI。\n\n首先创建后端 API 路由："},{"type":"toolCall","id":"call_3d6c08349040412fb23d7763","name":"write","arguments":{"content":"\"\"\"\nLive Stack API 路由\n\n提供 Live Stack 的 REST API 接口。\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nimport os\nimport numpy as np\nfrom datetime import datetime\nfrom fastapi import APIRouter, HTTPException, Request\nfrom fastapi.responses import JSONResponse\nfrom pydantic import BaseModel\nfrom typing import Optional, List\nimport cv2\nimport base64\n\nrouter = APIRouter(prefix=\"/api/v1/stack\", tags=[\"stack\"])\n\n# 全局 Live Stack 会话\n_live_sessions = {}\n\n\n# ============== 请求模型 ==============\n\nclass StartRequest(BaseModel):\n    device_ip: str\n    target_exposure: float = 2.0  # 秒\n    hardware_exposure_ms: float = 100.0  # 毫秒\n    mode: str = 'live'  # 'live' 或 'fixed'\n\n\nclass AddFrameRequest(BaseModel):\n    device_ip: str\n    frame_data: str  # base64 编码的图像\n\n\nclass FinishRequest(BaseModel):\n    device_ip: str\n    basename: Optional[str] = None\n    save_output: bool = True\n\n\nclass StatusRequest(BaseModel):\n    device_ip: str\n\n\n# ============== API 端点 ==============\n\n@router.get(\"/presets\")\nasync def get_presets():\n    \"\"\"获取预设档位\"\"\"\n    return {\n        \"success\": True,\n        \"presets\": {\n            \"off\": {\"exposure\": 0, \"frames\": 1, \"label\": \"关闭叠加\"},\n            \"2s\": {\"exposure\": 2, \"frames\": 20, \"label\": \"2秒\"},\n            \"5s\": {\"exposure\": 5, \"frames\": 50, \"label\": \"5秒\"},\n            \"10s\": {\"exposure\": 10, \"frames\": 100, \"label\": \"10秒\"},\n            \"30s\": {\"exposure\": 30, \"frames\": 300, \"label\": \"30秒\"},\n        }\n    }\n\n\n@router.post(\"/start\")\nasync def start_live_stack(request: StartRequest):\n    \"\"\"启动 Live Stack\"\"\"\n    from stack import LiveStack\n    \n    device_ip = request.device_ip\n    \n    # 创建 Live Stack\n    live = LiveStack(\n        hardware_exposure_ms=request.hardware_exposure_ms,\n        output_dir=\"stack/output\",\n    )\n    \n    result = live.start(target_exposure=request.target_exposure)\n    \n    if result['success']:\n        _live_sessions[device_ip] = live\n    \n    return result\n\n\n@router.post(\"/frame\")\nasync def add_frame(request: AddFrameRequest):\n    \"\"\"添加帧到 Live Stack\"\"\"\n    device_ip = request.device_ip\n    \n    if device_ip not in _live_sessions:\n        raise HTTPException(status_code=404, detail=\"Live Stack 会话不存在\")\n    \n    live = _live_sessions[device_ip]\n    \n    # 解码 base64 图像\n    try:\n        img_data = base64.b64decode(request.frame_data.split(',')[1] if ',' in request.frame_data else request.frame_data)\n        nparr = np.frombuffer(img_data, np.uint8)\n        frame = cv2.imdecode(nparr, cv2.IMREAD_GRAYSCALE)\n        \n        if frame is None:\n            return {'success': False, 'message': '图像解码失败'}\n    except Exception as e:\n        return {'success': False, 'message': f'图像解码异常: {str(e)}'}\n    \n    # 添加帧\n    result = live.add_frame(frame)\n    \n    # 获取预览\n    if result['success']:\n        preview = live.get_preview()\n        if preview is not None:\n            # 编码预览为 base64\n            success, buffer = cv2.imencode('.jpg', preview, [cv2.IMWRITE_JPEG_QUALITY, 85])\n            if success:\n                result['preview_base64'] = base64.b64encode(buffer).decode('utf-8')\n    \n    return result\n\n\n@router.post(\"/finish\")\nasync def finish_live_stack(request: FinishRequest):\n    \"\"\"完成 Live Stack\"\"\"\n    device_ip = request.device_ip\n    \n    if device_ip not in _live_sessions:\n        raise HTTPException(status_code=404, detail=\"Live Stack 会话不存在\")\n    \n    live = _live_sessions[device_ip]\n    result = live.finish(basename=request.basename, save_output=request.save_output)\n    \n    # 清理会话\n    if request.save_output:\n        del _live_sessions[device_ip]\n    \n    return result\n\n\n@router.get(\"/status/{device_ip}\")\nasync def get_status(device_ip: str):\n    \"\"\"获取 Live Stack 状态\"\"\"\n    if device_ip not in _live_sessions:\n        return {\n            \"success\": True,\n            \"is_running\": False,\n            \"frame_count\": 0,\n        }\n    \n    live = _live_sessions[device_ip]\n    return {\n        \"success\": True,\n        **live.get_status()\n    }\n\n\n@router.delete(\"/session/{device_ip}\")\nasync def delete_session(device_ip: str):\n    \"\"\"删除 Live Stack 会话\"\"\"\n    if device_ip in _live_sessions:\n        del _live_sessions[device_ip]\n    \n    return {\n        \"success\": True,\n        \"message\": f\"会话 {device_ip} 已删除\",\n    }\n\n\n@router.get(\"/preview/{device_ip}\")\nasync def get_preview(device_ip: str):\n    \"\"\"获取当前预览图像\"\"\"\n    if device_ip not in _live_sessions:\n        raise HTTPException(status_code=404, detail=\"Live Stack 会话不存在\")\n    \n    live = _live_sessions[device_ip]\n    preview = live.get_preview()\n    \n    if preview is None:\n        return {\"success\": False, \"message\": \"无预览图像\"}\n    \n    # 编码为 base64\n    success, buffer = cv2.imencode('.jpg', preview, [cv2.IMWRITE_JPEG_QUALITY, 85])\n    \n    if not success:\n        return {\"success\": False, \"message\": \"编码失败\"}\n    \n    b64 = base64.b64encode(buffer).decode('utf-8')\n    \n    return {\n        \"success\": True,\n        \"preview_base64\": b64,\n    }\n\n\n# ============== 模块导出 ==============\n\ndef get_router():\n    \"\"\"获取路由器\"\"\"\n    return router\n\n\nif __name__ == '__main__':\n    print(\"Live Stack API 路由\")\n    print(f\"路由前缀: {router.prefix}\")\n    print(f\"路由数量: {len(router.routes)}\")","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\stack\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":158379,"output":1421,"cacheRead":0,"cacheWrite":0,"totalTokens":159800,"cost":{"input":0.158379,"output":0.0045472,"cacheRead":0,"cacheWrite":0,"total":0.1629262}},"stopReason":"toolUse","timestamp":1780562966827,"responseId":"cht000da5ca@dx19e91d2f25ab9cb282"}}
