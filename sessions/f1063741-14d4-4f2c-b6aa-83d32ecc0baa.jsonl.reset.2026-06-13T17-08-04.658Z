 ps_script\n            ], cwd=cwd)\n        else:\n            # Linux/macOS: фНПчЈ nohup ххАхЏхЈ\n            restart_cmd = f'nohup python src/main/main.py --headless > /dev/null 2>&1 &'\n            subprocess.Popen(restart_cmd, shell=True, cwd=cwd)\n        \n        # хЛЖшПхщхКхНхшПчЈяМv6.42: хЂх хА3чЇчЁЎфПххКшПхяМ\n        import threading\n        def delayed_exit():\n            time.sleep(3)  # 3чЇчЁЎфПхЎЂцЗчЋЏцЖхАххК\n            os._exit(0)\n        threading.Thread(target=delayed_exit, daemon=True).start()\n        \n        return {\"success\": True, \"message\": \"щхЏфИ­...\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"щхЏхЄБшДЅ: {e}\"}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":49944,"output":717,"cacheRead":0,"cacheWrite":0,"totalTokens":50661,"cost":{"input":0.049943999999999995,"output":0.0022944000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0522384}},"stopReason":"toolUse","timestamp":1781364578982,"responseId":"cht000dfb4c@dx19ec19a5ca7b958232"}}
