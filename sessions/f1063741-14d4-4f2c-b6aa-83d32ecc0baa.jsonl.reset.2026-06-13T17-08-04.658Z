{"type":"message","id":"d3d72741","parentId":"9e755627","timestamp":"2026-06-13T14:51:58.528Z","message":{"role":"toolResult","toolCallId":"tool-70aca836969449c3bed6161a44030202","toolName":"read","content":[{"type":"text","text":"        heartbeat_task = asyncio.create_task(\n            self._heartbeat_loop(conn.connection_id)\n        )\n\n        try:\n            await self._message_loop(conn, monitor)\n        except WebSocketDisconnect:\n            pass\n        except Exception:\n            pass\n        finally:\n            heartbeat_task.cancel()\n            try:\n                await heartbeat_task\n            except asyncio.CancelledError:\n                pass\n\n            conn.status.value = \"closing\"\n            await self.broadcast_manager.unsubscribe_all(conn.connection_id)\n            monitor.record_disconnect(conn.connection_id)\n            await self.ws_manager.remove_connection(conn.connection_id)\n\n    async def _heartbeat_loop(self, connection_id: str) -> None:\n        \"\"\"хПшЗГхОЊчЏ - цЏ30чЇхщpingяМ60чЇц pongц­хМу\n\n        Wave 4:\n        - хЎЂцЗчЋЏцЏ30чЇхщping\n        - цхЁхЈ60чЇц хПшЗГхц­хМ\n        \"\"\"\n        while True:\n            await asyncio.sleep(self.config.heartbeat_interval)\n\n            conn = await self.ws_manager.get_connection(connection_id)\n            if conn is None or conn.status.value == \"closed\":\n                break\n\n            # цЃцЅцЏхІшЖцЖ (60чЇц ххК)\n            now = time.time()\n            if (now - conn.last_active) > (self.config.heartbeat_interval * self.config.heartbeat_timeout_count):\n                print(f\"[M8 WS] Heartbeat timeout: {connection_id}\")\n                await self.ws_manager.remove_connection(connection_id)\n                break\n\n            # хщ ping\n            try:\n                conn_ws = (await self.ws_manager.get_connection(connection_id))\n                if conn_ws:\n                    await conn_ws.websocket.send_text(\"ping\")\n            except Exception:\n                break\n\n    async def _message_loop(self, conn, monitor) -> None:\n        \"\"\"цЖцЏцЅцЖхОЊчЏу\"\"\"\n        parser = MessageParser()\n\n        while True:\n            raw_message = await conn.websocket.receive_text()\n\n            # хПшЗГ pong ххК\n            if raw_message == HEARTBEAT_PONG_MSG:\n                await self.ws_manager.handle_pong(conn.connection_id)\n                continue\n\n            monitor.record_message(conn.connection_id)\n\n            try:\n                message_type, payload, message_id = parser.parse(raw_message)\n            except Exception as e:\n                response = {\n                    \"type\": MessageType.ERROR.value,\n                    \"payload\": {\n                        \"code\": ErrorCode.INVALID_MESSAGE.value,\n                        \"message\": str(e),\n                    },\n                }\n                if message_id:\n                    response[\"id\"] = message_id\n                await conn.websocket.send_json(response)\n                continue\n\n            # хЄчшЗЏчБ\n            response = await self._route_message(message_type, payload, conn)\n            if response:\n                if message_id:\n                    response[\"id\"] = message_id\n                await conn.websocket.send_json(response)\n\n    async def _route_message(\n        self, message_type: str, payload: dict, conn\n    ) -> dict | None:\n        \"\"\"шЗЏчБцЖцЏхАхЄчхЈу\"\"\"\n        # шЎЂщ\n        if message_type == MessageType.SUBSCRIBE.value:\n            topic = payload.get(\"topic\", \"\")\n            if topic:\n                success = await self.broadcast_manager.subscribe(conn.connection_id, topic)\n                return {\n                    \"type\": MessageType.SUBSCRIBE.value,\n                    \"payload\": {\"topic\": topic, \"success\": success},\n                }\n\n        # хцЖшЎЂщ\n        if message_type == MessageType.UNSUBSCRIBE.value:\n            topic = payload.get(\"topic\", \"\")\n            if topic:\n                await self.broadcast_manager.unsubscribe(conn.connection_id, topic)\n                return {\n                    \"type\": MessageType.UNSUBSCRIBE.value,\n                    \"payload\": {\"topic\": topic, \"success\": True},\n                }\n\n        # хПшЗГ ping (цхЁчЋЏхЄчхЎЂцЗчЋЏ ping)\n        if message_type == MessageType.PING.value:\n            await self.ws_manager.handle_pong(conn.connection_id)\n            return {\n                \"type\": MessageType.PONG.value,\n                \"payload\": {\"timestamp\": time.time()},\n            }\n\n        # хЇцхА handlers\n        handlers = _get_message_handlers()\n        handler = handlers.get(message_type)\n        if handler:\n            return await handler(payload, conn)\n\n        return {\n            \"type\": MessageType.ERROR.value,\n            \"payload\": {\n                \"code\": ErrorCode.UNKNOWN_MESSAGE_TYPE.value,\n                \"message\": f\"цЊчЅцЖцЏчБЛх: {message_type}\",\n            },\n        }\n\n    async def _sync_latest_state(self, connection_id: str) -> None:\n        \"\"\"ц­чКПщшПххц­ЅццАчЖцу\n\n        Wave 4: щшПхцЈщшЎОхЄхЈчКПчЖцуцЕчЖцч­у\n        \"\"\"\n        conn = await self.ws_manager.get_connection(connection_id)\n        if conn is None:\n            return\n\n        # цЈщшЎОхЄчЖц\n        device_status = await self._get_device_status_snapshot()\n        if device_status:\n            await self.ws_manager.send_to_connection(\n                connection_id,\n                {\n                    \"type\": MessageType.DEVICE_ONLINE_BROADCAST.value,\n                    \"payload\": {\n\n[69 more lines in file. Use offset=350 to continue.]"}],"isError":false,"timestamp":1781362318528}}
{"type":"message","id":"a11af281","parentId":"d3d72741","timestamp":"2026-06-13T14:52:09.653Z","message":{"role":"assistant","content":[{"type":"text","text":"чхА `_handle_connection` цЙцГфИ­яМ\n1. хЙЖхцЇхЖцЃцЅ\n2. `await websocket.accept()` \n3. цЗЛх шПцЅ\n\n**хГщЎяМWebSocketServer х `accept()` ххшЎЄшЏ/хЙЖхцЃцЅяМхІцшЖшПцхЄЇшПцЅцАфМшПх 1008 хГщ­ч **у\n\nфНцЅхПцОчЄК 403 ForbiddenушПцЏ FastAPI хЈ accept фЙхчшЎЄшЏхБцчЛу\n\nцЃцЅ WebSocket шЎЄшЏцЈЁхяМ"},{"type":"toolCall","id":"call_cb141a5cfe4649088c3331d3","name":"read","arguments":{"limit":150,"offset":1,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\websocket\\core\\auth.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":57424,"output":132,"cacheRead":0,"cacheWrite":0,"totalTokens":57556,"cost":{"input":0.057423999999999996,"output":0.0004224,"cacheRead":0,"cacheWrite":0,"total":0.0578464}},"stopReason":"toolUse","timestamp":1781362318529,"responseId":"cht000d54a7@dx19ec177eb5dba5b442"}}
{"type":"message","id":"005a4fb7","parentId":"a11af281","timestamp":"2026-06-13T14:52:09.659Z","message":{"role":"toolResult","toolCallId":"call_cb141a5cfe4649088c3331d3","toolName":"read","content":[{"type":"text","text":"\"\"\"\nM8 WebSocket v1.0 - WebSocket шПцЅшЎЄшЏ\n\nхЎчА:\n- P0.4: WS шПцЅшЎЄшЏ (шПцЅцЖцКхИІ token, цхЁчЋЏщЊшЏ)\n- цЏцфЛ URL query хцАццЖцЏфИ­цх token\n- Token щЊшЏфИшПццЃцЅ\n\nAuthor: щчхМ @хцЙхЄЉц\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Any\n\nfrom src.websocket.constants import (\n    WS_TOKEN_EXPIRE_MINUTES,\n)\n\n\n# ================================================================== #\n#  Token щЊшЏхЈ (хЏЙцЅ M7 JWT цЈЁх)\n# ================================================================== #\n\nclass WSAuthenticator:\n    \"\"\"WebSocket шПцЅшЎЄшЏу\"\"\"\n\n    def __init__(self) -> None:\n        # чЎх token х­хЈ (чфКЇчЏхЂхКхЄчЈ M7 JWT цЈЁх)\n        # {token: {\"user\": ..., \"exp\": ..., \"active\": ...}}\n        self._tokens: dict[str, dict[str, Any]] = {}\n\n    def register_token(self, token: str, user: str = \"\", expires_minutes: int = WS_TOKEN_EXPIRE_MINUTES) -> None:\n        \"\"\"цГЈхцц Tokenу\n\n        Args:\n            token: JWT token х­чЌІфИВ\n            user: чЈцЗх\n            expires_minutes: шПццЖщД (хщ)\n        \"\"\"\n        self._tokens[token] = {\n            \"user\": user,\n            \"created_at\": time.time(),\n            \"expires_minutes\": expires_minutes,\n            \"active\": True,\n        }\n\n    def validate_token(self, token: str) -> dict[str, Any] | None:\n        \"\"\"щЊшЏ Token цЏхІцц (P0.4)у\n\n        Args:\n            token: шІщЊшЏч token\n\n        Returns:\n            хІцццшПх token фПЁцЏ (чЈцЗхч­), хІхшПх None\n        \"\"\"\n        if not token:\n            return None\n\n        token_info = self._tokens.get(token)\n        if token_info is None:\n            return None\n\n        if not token_info.get(\"active\"):\n            return None\n\n        # цЃцЅшПц\n        created = token_info.get(\"created_at\", 0)\n        expires = token_info.get(\"expires_minutes\", WS_TOKEN_EXPIRE_MINUTES)\n        if time.time() - created > expires * 60:\n            token_info[\"active\"] = False\n            return None\n\n        return token_info\n\n    def revoke_token(self, token: str) -> bool:\n        \"\"\"хщ Tokenу\n\n        Args:\n            token: шІхщч token\n\n        Returns:\n            цЏхІцх\n        \"\"\"\n        if token in self._tokens:\n            self._tokens[token][\"active\"] = False\n            return True\n        return False\n\n    def cleanup_expired(self) -> int:\n        \"\"\"цИчшПц Tokenу\n\n        Returns:\n            цИчцАщ\n        \"\"\"\n        now = time.time()\n        to_remove = []\n        for token, info in self._tokens.items():\n            expires = info.get(\"expires_minutes\", WS_TOKEN_EXPIRE_MINUTES)\n            if now - info.get(\"created_at\", 0) > expires * 60:\n                to_remove.append(token)\n\n        for token in to_remove:\n            del self._tokens[token]\n\n        return len(to_remove)\n\n\n# ================================================================== #\n#  хЈхБхфО\n# ================================================================== #\n\n_ws_auth: WSAuthenticator | None = None\n\n\ndef get_ws_auth() -> WSAuthenticator:\n    \"\"\"шЗххЈхБ WSAuthenticator хЎфОу\"\"\"\n    return _ws_auth  # type: ignore[return-value]\n\n\ndef init_ws_auth() -> WSAuthenticator:\n    \"\"\"ххЇххЈхБ WSAuthenticator хЎфОу\n\n    Returns:\n        WSAuthenticator хЎфО\n    \"\"\"\n    global _ws_auth\n    _ws_auth = WSAuthenticator()\n    return _ws_auth\n"}],"isError":false,"timestamp":1781362329659}}
