{"type":"message","id":"d6fe2d08","parentId":"f5c81ddb","timestamp":"2026-06-13T14:51:28.179Z","message":{"role":"toolResult","toolCallId":"call_bfd399c8b8c8425bbac438ff","toolName":"read","content":[{"type":"text","text":"    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager цЊххЇх\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ц цГшЇЃцшЎОхЄц шЏ: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        level = data.get(\"level\", \"1/60\")\r\n        \r\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<Shutter version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <ShutterLevel>{level}</ShutterLevel>\r\n</Shutter>'''\r\n\r\n        put_resp = client.put(\"/Image/channels/1/Shutter\", xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": f\"хПЋщЈхЗВшЎОчНЎфИК {level}\"}\r\n        return {\"success\": False, \"message\": f\"цДцАхЄБшДЅ: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"шЎОчНЎхПЋщЈхМхИИ: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/iris\", summary=\"шЗхххшЎОчНЎ\", tags=[\"Image\"])\r\nasync def get_iris(device_id: str) -> dict:\r\n    \"\"\"шЗхшЎОхЄхххНхшЎОчНЎу\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager цЊххЇх\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ц цГшЇЃцшЎОхЄц шЏ: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        resp = client.get(\"/Image/channels/1/Iris\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"шЗххххЄБшДЅ: HTTP {resp.status_code}\"}\r\n\r\n        root = ET.fromstring(resp.xml)\r\n        result = {\"success\": True, \"data\": {}}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n            if tag in (\"IrisLevel\", \"irisLevel\"):\r\n                result[\"data\"][\"current_level\"] = int((elem.text or \"160\").strip())\r\n            elif tag in (\"minIrisLevelLimit\", \"MinIrisLevelLimit\"):\r\n                result[\"data\"][\"min\"] = int((elem.text or \"160\").strip())\r\n            elif tag in (\"maxIrisLevelLimit\", \"MaxIrisLevelLimit\"):\r\n                result[\"data\"][\"max\"] = int((elem.text or \"2200\").strip())\r\n\r\n        return result\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"шЗххххМхИИ: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/image/iris\", summary=\"шЎОчНЎхх\", tags=[\"Image\"])\r\nasync def set_iris(device_id: str, data: dict) -> dict:\r\n    \"\"\"шЎОчНЎхххцАу\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager цЊххЇх\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ц цГшЇЃцшЎОхЄц шЏ: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        level = data.get(\"level\", 160)\r\n        \r\n        xml_str