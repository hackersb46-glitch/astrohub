{"type":"message","id":"6beffd3e","parentId":"2f9eb750","timestamp":"2026-06-13T15:00:04.225Z","message":{"role":"toolResult","toolCallId":"tool-800d38172a5d44639d5965e1bd4bcc81","toolName":"exec","content":[{"type":"text","text":"# ================================================================ #\r\n#  ЯЕЭГяПНяПНяПНяПНяПНЫЕяПН\r\n# ================================================================ #\r\n\r\n@api_router.post(\"/system/restart\", summary=\"яПНяПНяПНяПН AstroHub\", tags=[\"System\"])\r\nasync def restart_astrohub() -> dict:\r\n    \"\"\"яПНяПНяПНяПН AstroHub яПНяПНяПНяПН\"\"\"\r\n    import subprocess\r\n    import sys\r\n    import os\r\n    \r\n    try:\r\n        # яПНяПНяПНяПНяПНяПНяПНяПНяПНХБяПН\r\n        restart_cmd = f'sleep 2 && cd \"{os.getcwd()}\" && python -m uvicorn src.main.main:app --host 0.0.0.0 --port 10280'\r\n        \r\n        # ЪЙяПНяПН subprocess яПНяПНяПНяПНяПНТНяПНяПНяПН\r\n        subprocess.Popen(restart_cmd, shell=True, cwd=os.getcwd())\r\n        \r\n        # яПНгГйКяПНяПНЫГяПНяПНяПНЧАяПНяПНяПНяПН\r\n        import threading\r\n        def delayed_exit():\r\n            time.sleep(1)\r\n            os._exit(0)\r\n        threading.Thread(target=delayed_exit, daemon=True).start()\r\n        \r\n        return {\"success\": True, \"message\": \"яПНяПНяПНяПНяПНяПН...\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"яПНяПНяПНяПНЪЇяПНяПН: {e}\"}"}],"details":{"status":"completed","exitCode":0,"durationMs":390,"aggregated":"# ================================================================ #\r\n#  ЯЕЭГяПНяПНяПНяПНяПНЫЕяПН\r\n# ================================================================ #\r\n\r\n@api_router.post(\"/system/restart\", summary=\"яПНяПНяПНяПН AstroHub\", tags=[\"System\"])\r\nasync def restart_astrohub() -> dict:\r\n    \"\"\"яПНяПНяПНяПН AstroHub яПНяПНяПНяПН\"\"\"\r\n    import subprocess\r\n    import sys\r\n    import os\r\n    \r\n    try:\r\n        # яПНяПНяПНяПНяПНяПНяПНяПНяПНХБяПН\r\n        restart_cmd = f'sleep 2 && cd \"{os.getcwd()}\" && python -m uvicorn src.main.main:app --host 0.0.0.0 --port 10280'\r\n        \r\n        # ЪЙяПНяПН subprocess яПНяПНяПНяПНяПНТНяПНяПНяПН\r\n        subprocess.Popen(restart_cmd, shell=True, cwd=os.getcwd())\r\n        \r\n        # яПНгГйКяПНяПНЫГяПНяПНяПНЧАяПНяПНяПНяПН\r\n        import threading\r\n        def delayed_exit():\r\n            time.sleep(1)\r\n            os._exit(0)\r\n        threading.Thread(target=delayed_exit, daemon=True).start()\r\n        \r\n        return {\"success\": True, \"message\": \"яПНяПНяПНяПНяПНяПН...\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"яПНяПНяПНяПНЪЇяПНяПН: {e}\"}","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781362804225}}
