{"type":"message","id":"82faae4d","parentId":"11181c7a","timestamp":"2026-06-13T14:59:52.472Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_cd6bd6d47623448385e92760","name":"read","arguments":{"edits":"[{\"newText\": \"    # Wave 4: WebSocket чЋЏчЙ (v6.41: чЇЛщЄ WebSocketServerяМфНПчЈ main.py фИ­ччЎхчЋЏчЙ)\\n    # WASM SDK щшІц шЎЄшЏч WebSocket шПцЅ\\n    # try:\\n    #     from websocket.server import WebSocketServer, WebSocketServerConfig\\n    #     ws_server = WebSocketServer(config=WebSocketServerConfig(\\n    #         path=\\\"/ws\\\",\\n    #         heartbeat_interval=30,\\n    #         heartbeat_timeout_count=2,\\n    #     ))\\n    #     ws_server.mount_to(app)\\n    # except Exception as e:\\n    #     print(f\\\"[api] WebSocket цшННхЄБшДЅ (хЏщ): {e}\\\")\\n    \\n    return app\", \"oldText\": \"    # Wave 4: цшНН WebSocket чЋЏчЙ\\n    try:\\n        from websocket.server import WebSocketServer, WebSocketServerConfig\\n        ws_server = WebSocketServer(config=WebSocketServerConfig(\\n            path=\\\"/ws\\\",\\n            heartbeat_interval=30,\\n            heartbeat_timeout_count=2,  # 60чЇц ххКц­хМ (30s * 2)\\n        ))\\n        ws_server.mount_to(app)\\n    except Exception as e:\\n        print(f\\\"[api] WebSocket цшННхЄБшДЅ (хЏщ): {e}\\\")\\n    \\n    return app\"}]","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":80627,"output":346,"cacheRead":0,"cacheWrite":0,"totalTokens":80973,"cost":{"input":0.08062699999999999,"output":0.0011072,"cacheRead":0,"cacheWrite":0,"total":0.08173419999999999}},"stopReason":"toolUse","timestamp":1781362788265,"responseId":"cht000d9bad@dx19ec17f0959b91a742"}}
{"type":"message","id":"b8bcc491","parentId":"82faae4d","timestamp":"2026-06-13T14:59:52.481Z","message":{"role":"toolResult","toolCallId":"call_cd6bd6d47623448385e92760","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nAstroHub v2.0 - чЛфИшЗЏчБшх\r\n\r\nцДх M1-M11 цццЈЁхшЗЏчБхА /api/v1/ фИ:\r\n- /api/v1/health            - хЈхБхЅхКЗцЃцЅ\r\n- /api/v1/discovery/sadp    - SADP шЎОхЄхчА\r\n- /api/v1/devices/*         - шЎОхЄчЎЁчяМчхЎяМ\r\n- /api/v1/ptz/*             - PTZ цЇхЖяМчхЎяМ\r\n- /api/v1/streams/*         - цЕцхЁ\r\n- /api/v1/calibration/*     - ц Ёх\r\n- /api/v1/ascom/*           - ASCOM шЎОхЄ\r\n- /api/v1/settings          - чГЛчЛшЎОчНЎ\r\n\r\nAuthor: щчхМ @хцЙхЄЉц\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel\r\nfrom fastapi import APIRouter, FastAPI, Query\r\nfrom fastapi.responses import JSONResponse\r\n\r\n# v6.40: цфНцЅхП\r\nfrom src.operation_logger import log_api, log_web, log_error, log_info\r\n\r\n# ================================================================ #\r\n#  ц ИхПцЈЁххЏМхЅ\r\n# ================================================================ #\r\n\r\nfrom src.core.ptz_manager import PTZManager\r\nfrom src.core.device_manager import DeviceManager\r\nfrom src.core.stream_manager import StreamManager\r\nfrom src.core.calibration_manager import CalibrationManager\r\nfrom src.core.auth import AuthManager\r\nfrom src.core.ws_manager import WebSocketManager\r\nfrom src.core.ascom_manager import ASCOMManager\r\nfrom src.core.orchestrator import Orchestrator\r\nfrom src.core.health_monitor import HealthMonitor\r\n\r\n\r\n# ================================================================ #\r\n#  шЗЏчБхчМхЎфЙ\r\n# ================================================================ #\r\n\r\nAPI_V1_PREFIX = \"/api/v1\"\r\n\r\n# фИЛ API шЗЏчБхЈ\r\napi_router = APIRouter(prefix=API_V1_PREFIX, tags=[\"API v1\"])\r\n\r\n# хЅхКЗцЃцЅшЗЏчБхЈ\r\nhealth_router = APIRouter(prefix=\"/api/v1\", tags=[\"System\"])\r\n\r\n\r\n# ================================================================ #\r\n#  v6.40: цфНцЅхП API\r\n# ================================================================ #\r\n\r\nclass OperationLogRequest(BaseModel):\r\n    \"\"\"цфНцЅхПшЏЗцБ.\"\"\"\r\n    level: str = \"INFO\"\r\n    module: str = \"web\"\r\n    action: str = \"\"\r\n    detail: str | dict = \"\"\r\n\r\n@health_router.post(\"/log/operation\", summary=\"шЎАхНцфНцЅхП\")\r\nasync def log_operation_api(req: OperationLogRequest) -> dict:\r\n    \"\"\"хчЋЏхщцфНцЅхПхАхчЋЏ.\"\"\"\r\n    from src.operation_logger import log_operation\r\n    log_operation(req.level, req.module, req.action, req.detail)\r\n    return {\"success\": True}\r\n\r\n\r\n# ================================================================ #\r\n#  Pydantic шЏЗцБцЈЁх\r\n# ================================================================ #\r\n\r\nclass AddDeviceRequest(BaseModel):\r\n    \"\"\"цхЈцЗЛх шЎОхЄшЏЗцБу\"\"\"\r\n    ip: str\r\n    port: int = 80\r\n    username: str = \"admin\"\r\n    password: str\r\n    name: str = \"\"\r\n    model: str = \"\"\r\n    mac: str = \"\"\r\n\r\nclass ConnectDeviceRequest(BaseModel):\r\n    \"\"\"шПцЅшЎОхЄшЏЗцБу\"\"\"\r\n    username: str = \"admin\"\r\n    password: str\r\n    port: int = 80\r\n\r\nclass ModifyNetworkRequest(BaseModel):\r\n    \"\"\"фПЎцЙчНчЛщчНЎшЏЗцБу\"\"\"\r\n    ip: str\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str\r\n\r\nclass SADPIpModifyRequest(BaseModel):\r\n    \"\"\"SADP IP фПЎцЙшЏЗцБ (хЋхОЊчЏщЊшЏ)у\"\"\"\r\n    mac: str\r\n    password: str\r\n    new_ip: str\r\n    original_ip: str = \"\"\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str = \"\"\r\n\r\nclass SystemInfoRequest(BaseModel):\r\n    \"\"\"чГЛчЛфПЁцЏшЏЗцБяМхЏщччЛхЎ ipяМу\"\"\"\r\n    nic_index: int | None = None\r\n\r\nclass PTZMoveRequest(BaseModel):\r\n    \"\"\"PTZ чЇЛхЈшЏЗцБу\"\"\"\r\n    direction: str\r\n    speed: int = 50\r\n\r\nclass PTZAbsoluteRequest(BaseModel):\r\n    \"\"\"PTZ чЛхЏЙчЇЛхЈшЏЗцБу\"\"\"\r\n    pan: float\r\n    tilt: float\r\n    zoom: float | None = None\r\n    speed: int = 50\r\n\r\nclass PTZPresetRequest(BaseModel):\r\n    \"\"\"PTZ щЂчНЎфНшЏЗцБу\"\"\"\r\n    preset_id: int\r\n\r\nclass SADPScanRequest(BaseModel):\r\n    \"\"\"SADP хчАшЏЗцБу\"\"\"\r\n    bind_ip: str = \"0.0.0.0\"\r\n\r\nclass RemoveDeviceRequest(BaseModel):\r\n    \"\"\"чЇЛщЄшЎОхЄшЏЗцБу\"\"\"\r\n    ip: str = \"\"\r\n    mac: str = \"\"\r\n\r\n\r\nclass PTZCaptureRequest(BaseModel):\r\n    \"\"\"PTZ цЊхОшЏЗцБу\"\"\"\r\n    stream_url: str = \"\"\r\n    stream_id: str = \"\"\r\n\r\n\r\nclass PTZRecordRequest(BaseModel):\r\n    \"\"\"PTZ хНхшЏЗцБу\"\"\"\r\n    target_name: str = \"\"\r\n\r\n\r\nclass TelescopeSlewRequest(BaseModel):\r\n    \"\"\"цшПщ Slew шЏЗцБу\"\"\"\r\n    ra: float\r\n    dec: float\r\n\r\n\r\nclass TelescopeTrackingRequest(BaseModel):\r\n    \"\"\"цшПщшЗшИЊцЈЁхМшЏЗцБу\"\"\"\r\n    mode: str  # trackSidereal / trackLunar / trackSolar / trackOff\r\n\r\n\r\n# ================================================================ #\r\n#  цфНцЅхП (цхЄ 10 цЁ)\r\n# ================================================================ #\r\n\r\noperations_log: list[dict[str, str]] = []\r\nMAX_LOG_ENTRIES = 10\r\n\r\n\r\ndef operation_log(action: str, details: str) -> None:\r\n    \"\"\"шПНх цфНхАцЅхПхшЁЈяМчЏхНЂчМхВхКяМцхЄ MAX_LOG_ENTRIES цЁяМу\"\"\"\r\n    entry = {\r\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\r\n        \"action\": action,\r\n        \"details\": details,\r\n    }\r\n    operations_log.append(entry)\r\n    if len(operations_log) > MAX_LOG_ENTRIES:\r\n        operations_log.pop(0)\r\n\r\n\r\n# ================================================================ #\r\n#  чЎЁчхЈцГЈхЅ\r\n# ================================================================ #\r\n\r\n_managers: dict[str, Any] = {}\r\n\r\n\r\ndef set_managers(**kwargs: Any) -> None:\r\n    \"\"\"цГЈхЅццчЎЁчхЈхЎфОу\"\"\"\r\n    _managers.update(kwargs)\r\n\r\n\r\ndef _resolve_device_id_to_ip(mgr: \"PTZManager\", device_id: str) -> str | None:\r\n    \"\"\"шЇЃц device_id фИКхЎщ IP хАху\r\n\r\n    device_id хЏшНцЏ IP хАхц MAC хАху\r\n    - хІццЏ IP: чДцЅшПх\r\n    - хІццЏ MAC: фЛ SADP хчАчМх­цхЗВх­хЈшЎОхЄфИ­цЅцО IP\r\n    \"\"\"\r\n    import re\r\n    # хЄц­цЏхІфИК MAC хАхц МхМ (ххЗуцЈЊц хщцц хщчЌІ)\r\n    mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n    # ц хщчЌІ12фНхх­шПхЖ = MAC\r\n    if len(mac_clean) == 12 and re.match(r'^[0-9a-f]{12}$', mac_clean):\r\n        # цЏ MAC хАхяМхАшЏфЛхчАчМх­фИ­цЅцО\r\n        discovered = mgr.get_discovered_devices()\r\n        for dev in discovered:\r\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if dev_mac == mac_clean:\r\n                return dev.get(\"ip\")\r\n        # фЛхЗВх­хЈшЎОхЄфИ­цЅцО\r\n        stored = mgr.list_stored_devices()\r\n        for dev in stored:\r\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if dev_mac == mac_clean:\r\n                ip = dev.get(\"ip\", \"\")\r\n                if ip:\r\n                    return ip\r\n        return None\r\n    # чшЕЗцЅх IP хАхяМчДцЅшПх\r\n    return device_id\r\n\r\n\r\n# ================================================================ #\r\n#  хЅхКЗцЃцЅчЋЏчЙ\r\n# ================================================================ #\r\n\r\n\r\n@health_router.get(\"/health\", summary=\"хЈхБхЅхКЗцЃцЅ\")\r\nasync def global_health() -> dict:\r\n    \"\"\"хЈхБхЅхКЗцЃцЅчЋЏчЙ (GET /api/v1/health)у\"\"\"\r\n    module_keys = (\r\n        \"ptz_manager\",\r\n        \"device_manager\",\r\n        \"stream_manager\",\r\n        \"calibration_manager\",\r\n        \"db_manager\",\r\n        \"auth_service\",\r\n        \"ws_manager\",\r\n        \"ascom_manager\",\r\n        \"health_monitor\",\r\n        \"orchestrator\",\r\n    )\r\n\r\n    module_health: dict[str, dict[str, Any]] = {}\r\n    for key in module_keys:\r\n        module_health[key] = {\r\n            \"status\": \"initialized\" if _managers.get(key) is not None else \"not_initialized\",\r\n            \"present\": key in _managers,\r\n        }\r\n\r\n    all_present = all(m[\"present\"] for m in module_health.values())\r\n    initialized_count = sum(1 for m in module_health.values() if m[\"present\"])\r\n\r\n    return {\r\n        \"status\": \"healthy\" if all_present else \"degraded\",\r\n        \"modules\": module_health,\r\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\r\n    }\r\n\r\n\r\n# ================================================================ #\r\n#  SADP хчАчЋЏчЙ\r\n# ================================================================ #\r\n\r\n\r\n@api_router.get(\"/discovery/sadp\", summary=\"SADP шЎОхЄхчА\", tags=[\"Discovery\"])\r\nasync def sadp_discover(bind_ip: str = \"0.0.0.0\") -> dict:\r\n    \"\"\"щшП SADP хЄц­хчАхБхчНх PTZ шЎОхЄу\r\n    \r\n    BUG-003 фПЎхЄ: чДцЅфНПчЈ SADPManagerяМфИфОшЕ PTZManagerу\r\n    \"\"\"\r\n    start = time.time()\r\n    \r\n    # фМхфНПчЈ PTZManagerяМхІцхЗВххЇхяМ\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if mgr:\r\n        devices = mgr.discover_devices(bind_ip=bind_ip)\r\n    else:\r\n        # чДцЅфНПчЈ SADPManager фИфОшЕ PTZManager\r\n        try:\r\n            from src.core.sadp_discovery import SADPManager\r\n            sadp_mgr = SADPManager()\r\n            raw_devices = sadp_mgr.discover_devices(timeout=10, bind_ip=bind_ip)\r\n            # шНЌцЂфИК SADP ц хц МхМ\r\n            devices = []\r\n            for d in raw_devices:\r\n                devices.append({\r\n                    \"mac\": d.get(\"mac\", \"\"),\r\n                    \"ip\": d.get(\"ip\", \"\"),\r\n                    \"subnet_mask\": d.get(\"subnet_mask\", \"\"),\r\n                    \"gateway\": d.get(\"gateway\", \"\"),\r\n                    \"model\": d.get(\"model\", \"\"),\r\n                    \"serial_number\": d.get(\"serial_number\", \"\"),\r\n                    \"device_name\": d.get(\"device_name\", \"\"),\r\n                    \"firmware_version\": d.get(\"firmware_version\", \"\"),\r\n                    \"activated\": d.get(\"activated\", False),\r\n                    \"is_hikvision\": d.get(\"is_hikvision\", False),\r\n                    \"source\": \"sadp\",\r\n                })\r\n        except Exception as e:\r\n            return {\"success\": False, \"message\": f\"SADP хчАхМхИИ: {e}\", \"devices\": []}\r\n    \r\n    elapsed = round(time.time() - start, 1)\r\n\r\n    # BUG-015 фПЎхЄ: чЛфИ MAC хАхц МхМфИКцЈЊц хАх (24-0f-9b-76-41-93)\r\n    for dev in devices:\r\n        mac = dev.get(\"mac\", \"\")\r\n        if mac:\r\n            clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if len(clean) == 12:\r\n                dev[\"mac\"] = \"-\".join(clean[i:i+2] for i in range(0, 12, 2))\r\n\r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"хчА {len(devices)} хАшЎОхЄ (шцЖ {elapsed}s)\",\r\n        \"devices\": devices,\r\n        \"count\": len(devices),\r\n    }\r\n\r\n\r\n# ================================================================ #\r\n#  шЎОхЄчЎЁччЋЏчЙ\r\n# ================================================================ #\r\n\r\n\r\n@api_router.get(\"/devices\", summary=\"шЎОхЄхшЁЈ\", tags=[\"Devices\"])\r\nasync def list_devices() -> dict:\r\n    \"\"\"шЗхшЎОхЄхшЁЈяМMAC хЛщххЙЖ SADP хчА + цхЈх­хЈяМ.\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"data\": [], \"total\": 0}\r\n\r\n    def _normalize_mac(mac: str) -> str:\r\n        \"\"\"чЛфИ MAC фИКц хщчЌІхАхц МхМ (aabbccddeeff).\r\n\r\n        BUG-016 фПЎхЄ: хЂхМК MAC ц МхМц ЁщЊяМцчЛх MAC хАхяМхІ IP хАххЁЋхЅ MAC х­цЎЕяМу\r\n        \"\"\"\r\n        import re\r\n        clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n        # щЊшЏ: хПщЁЛцЏцАхЅН12фНхх­шПхЖх­чЌІ\r\n        if len(clean) != 12 or not re.match(r'^[0-9a-f]{12}$', clean):\r\n            return \"\"\r\n        return clean\r\n\r\n    def _has_device_mac(dev: dict) -> bool:\r\n        \"\"\"хЄц­шЎОхЄцЏхІццц MAC.\"\"\"\r\n        return bool(_normalize_mac(dev.get(\"mac\", \"\") or \"\"))\r\n\r\n    stored = mgr.list_stored_devices()\r\n    discovered = mgr.get_discovered_devices()\r\n    online_ips = mgr.list_controllers()\r\n\r\n    # --- Pass 1: х­хЈшЎОхЄц MAC хЛКчДЂхМ ---\r\n    keyed: dict[str, dict[str, Any]] = {}  # normalized_mac -> merged_record\r\n    no_mac: list[dict[str, Any]] = []      # manual entry without MAC\r\n\r\n    for dev in stored:\r\n        mac_norm = _normalize_mac(dev.get(\"mac\", \"\") or \"\")\r\n        if mac_norm:\r\n            keyed[mac_norm] = {\r\n                \"mac\": mac_norm,\r\n                \"ip\": dev.get(\"ip\", \"\"),\r\n                \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),  # чЈцЗшЎОчНЎчхчЇА\r\n                \"model\": dev.get(\"model\", \"\"),  # шЎОхЄххЗ\r\n                \"gateway\": dev.get(\"gateway\", \"\"),  # v6.01\r\n                \"subnet_mask\": dev.get(\"subnet_mask\", \"\"),  # v6.01\r\n                \"source\": \"manual\",\r\n                \"online\": False,  # updated later\r\n                \"activated\": False,\r\n                \"has_credentials\": True,\r\n            }\r\n        else:\r\n            no_mac.append({\r\n                \"mac\": \"\",\r\n                \"ip\": dev.get(\"ip\", \"\"),\r\n                \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),\r\n                \"model\": dev.get(\"model\", \"\"),\r\n                \"source\": \"manual\",\r\n                \"online\": False,\r\n\nт яИ [... middle content omitted т showing head and tail ...]\n\n    \"\"\"цДцАчЛщЂхцАу\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager цЊххЇх\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ц цГшЇЃцшЎОхЄц шЏ: {device_id}\"}\r\n\r\n    client = mgr._clients.get(target_ip)\r\n    if not client:\r\n        return {\"success\": False, \"message\": f\"ISAPI client not found for {target_ip}\"}\r\n\r\n    try:\r\n        # хшЗххНхшЎОчНЎ\r\n        resp = client.get(\"/Image/channels/1\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"шЗхчЛщЂшЎОчНЎхЄБшДЅ: HTTP {resp.status_code}\"}\r\n\r\n        xml_str = resp.xml\r\n        import xml.etree.ElementTree as ET\r\n        root = ET.fromstring(xml_str)\r\n\r\n        # фПЎцЙ Color шчЙ\r\n        updated = {}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n            if tag == \"Color\":\r\n                for child in elem:\r\n                    ctag = child.tag.split(\"}\")[-1] if \"}\" in child.tag else child.tag\r\n                    if ctag == \"brightnessLevel\" and req.brightness is not None:\r\n                        child.text = str(req.brightness)\r\n                        updated[\"brightness\"] = req.brightness\r\n                    elif ctag == \"contrastLevel\" and req.contrast is not None:\r\n                        child.text = str(req.contrast)\r\n                        updated[\"contrast\"] = req.contrast\r\n                    elif ctag == \"saturationLevel\" and req.saturation is not None:\r\n                        child.text = str(req.saturation)\r\n                        updated[\"saturation\"] = req.saturation\r\n                break\r\n\r\n        # хщцДцА\r\n        # фНПчЈ /Image/channels/1/Color чЋЏчЙяМшфИцЏцДфИЊ ImageChannel\r\n        color_xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<Color version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n<brightnessLevel>{updated.get(\"brightness\", 50)}</brightnessLevel>\r\n<contrastLevel>{updated.get(\"contrast\", 50)}</contrastLevel>\r\n<saturationLevel>{updated.get(\"saturation\", 50)}</saturationLevel>\r\n</Color>'''\r\n        \r\n        put_resp = client.put(\"/Image/channels/1/Color\", color_xml)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"чЛщЂшЎОчНЎхЗВцДцА\", \"data\": updated}\r\n        else:\r\n            return {\"success\": False, \"message\": f\"цДцАхЄБшДЅ: HTTP {put_resp.status_code}\"}\r\n\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"цДцАчЛщЂшЎОчНЎхМхИИ: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/capture\", summary=\"PTZ цЊхОяМISAPI хчяМ\", tags=[\"PTZ\"])\r\nasync def ptz_capture(device_id: str, req: PTZCaptureRequest | None = None) -> dict:\r\n    \"\"\"щшПцЕЗхКЗ ISAPI хчцЙцГцЊх PTZ шЎОхЄхНхшЇщЂхИЇу\r\n\r\n    фНПчЈ: GET /ISAPI/Streaming/Channels/{channel}/picture\r\n    фИхфОшЕ ffmpegу\r\n    \"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager цЊххЇх\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ц цГшЇЃцшЎОхЄц шЏ: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = mgr._clients.get(target_ip)\r\n    if not client:\r\n        return {\"success\": False, \"message\": f\"ISAPI client not found for {target_ip}\"}\r\n\r\n    try:\r\n        jpeg_bytes = client.capture_picture()\r\n        if not jpeg_bytes:\r\n            return {\"success\": False, \"message\": \"ISAPI цЊхОхЄБшДЅяМшЎОхЄцЊшПххОхцАцЎ\"}\r\n\r\n        # JPEG хЄДщЊшЏ\r\n        if jpeg_bytes[:3] != b\"\\xff\\xd8\\xff\":\r\n            return {\"success\": False, \"message\": \"шПхчцАцЎфИцЏццч JPEG\"}\r\n\r\n        # фПх­цфЛЖ\r\n        from src.stream.constants import DOWNLOAD_IMAGE_DIR\r\n        from src.core.file_naming import generate_filename\r\n\r\n        # шЗхшЎОхЄхчЇАяМхІцяМ\r\n\n[Read output capped at 79KB for this call. Use offset=1310 to continue.][... 31033 more characters truncated]"}],"details":{"truncation":{"truncated":true,"truncatedBy":"bytes","totalLines":3210,"totalBytes":125816,"outputLines":1309,"outputBytes":51190,"lastLinePartial":false,"firstLineExceedsLimit":false,"maxLines":2000,"maxBytes":51200}},"isError":false,"timestamp":1781362792481}}
