{"type":"message","id":"e83037d5","parentId":"dbb06bf7","timestamp":"2026-06-13T15:25:33.292Z","message":{"role":"toolResult","toolCallId":"call_535a1000973748199e8ba075","toolName":"read","content":[{"type":"text","text":"\"\"\"\nAstroHub v2.0 - шЎОхЄцАцЎшЗЏхОчЎЁч\n\nv6.19 цДцА:\n- х щЄ config_paths фОшЕяМчЛфИшЗЏхОхЎфЙ\n- чЛфИшЗЏхОяМdata/devices/{mac}/\n- хИІцЖщДцГцфЛЖяМdata/devices/{mac}/{test_type}_{timestamp}.json\n- шЏЛхшЇхяМцАИшПшЏЛццАшЎАхН\n\nAuthor: щчхМ @хцЙхЄЉц\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\n# ================================================================ #\n#  чЛфИшЗЏхОхЎфЙ (v6.19)\n# ================================================================ #\n\ndef _get_app_dir() -> Path:\n    \"\"\"шЗххКчЈчЈхКц ЙчЎхНу\"\"\"\n    import sys\n    if getattr(sys, 'frozen', False):\n        return Path(sys.executable).parent\n    return Path(__file__).resolve().parent.parent.parent\n\nAPP_DIR = _get_app_dir()\nDATA_DIR = APP_DIR / 'data'\nDEVICES_DIR = DATA_DIR / 'devices'\n\n\ndef get_devices_dir() -> Path:\n    \"\"\"v6.19: шЗхшЎОхЄцАцЎц ЙчЎхНу\"\"\"\n    return DEVICES_DIR\n\n\ndef get_device_info(ptz: Any) -> dict[str, str]:\n    \"\"\"фЛшЎОхЄшЗххЏфИц шЏфПЁцЏу\n\n    Args:\n        ptz: PTZControllerхЎфО\n\n    Returns:\n        dict: {mac, model, model_short, serial}\n    \"\"\"\n    # фЛPTZControllerшЗхISAPIClient\n    client = ptz.client if hasattr(ptz, 'client') else ptz\n\n    # шЗхшЎОхЄфПЁцЏ\n    resp = client.get('/System/deviceInfo')\n    xml = resp.xml\n\n    # шЇЃцXML\n    import xml.etree.ElementTree as ET\n    root = ET.fromstring(xml)\n\n    # цхх­цЎЕ\n    mac = \"\"\n    model = \"\"\n    serial = \"\"\n\n    for child in root:\n        tag = child.tag.split('}')[-1] if '}' in child.tag else child.tag\n        if tag == 'macAddress':\n            mac = child.text or \"\"\n        elif tag == 'model':\n            model = child.text or \"\"\n        elif tag == 'serialNumber':\n            serial = child.text or \"\"\n\n    # MACхАххЛщЄххЗяМшНЌхАх\n    mac_clean = mac.replace(':', '').lower()\n\n    # ч­ххЗяМххчМяМхЛцхчМцАх­хх­цЏяМ\n    # iDS-2DF8C832IXS-A -> iDS-2DF8C\n    model_short = model\n    if len(model) > 8:\n        model_short = model[:8]\n        while model_short and model_short[-1].isdigit():\n            model_short = model_short[:-1]\n\n    return {\n        'mac': mac,\n        'mac_clean': mac_clean,\n        'model': model,\n        'model_short': model_short,\n        'serial': serial\n    }\n\n\ndef get_device_dir(mac_clean: str) -> Path:\n    \"\"\"v6.03: шЗхшЎОхЄцАцЎчЎхНшЗЏхОу\n\n    Args:\n        mac_clean: MACхАхяМц ххЗяМхАхяМ\n\n    Returns:\n        Path: data/devices/{mac_clean}/\n    \"\"\"\n    return DEVICES_DIR / mac_clean\n\n\ndef get_data_path_read(model_short: str | None, mac_clean: str, test_type: str) -> Path | None:\n    \"\"\"v6.33: шЗхшЏЛхшЗЏхОяМфМхццАцЖщДцГцфЛЖяМхЖцЌЁхКхЎхчЇАцфЛЖяМу\n\n    Args:\n        model_short: ч­ххЗяМхЏщяМv6.33 фИхфНПчЈяМ\n        mac_clean: MACхАхяМц хщчЌІяМхАхяМ- хПщЁЛхЙщшЎОхЄ\n        test_type: цЕшЏчБЛх (function/limit/speed)\n\n    Returns:\n        Path: цфЛЖшЗЏхОяМхІфИх­хЈшПхNone\n    \"\"\"\n    device_dir = get_device_dir(mac_clean)\n    if not device_dir.exists():\n        return None\n\n    # v6.33: фМхцЅцОццАч {test_type}_*.json цЖщДцГцфЛЖ\n    pattern = re.compile(rf'^{test_type}_(\\d{{8}}_\\d{{6}})\\.json$')\n    latest_file = None\n    latest_time = None\n\n    for f in device_dir.iterdir():\n        if f.is_file():\n            match = pattern.match(f.name)\n            if match:\n                file_time = f.stat().st_mtime\n                if latest_time is None or file_time > latest_time:\n                    latest_time = file_time\n                    latest_file = f\n\n    # ццЖщДцГцфЛЖхшПхццАч\n    if latest_file:\n        return latest_file\n\n    # хЖцЌЁцЅцОхКхЎхчЇАцфЛЖ\n    fixed_path = device_dir / f'{test_type}.json'\n    if fixed_path.exists():\n        return fixed_path\n\n    return None\n\n\ndef get_data_path_write(model_short: str | None, mac_clean: str, test_type: str) -> Path:\n    \"\"\"v6.19: шЗхххЅшЗЏхОяМхКхЎхчЇАцфЛЖяМу\n\n    Args:\n        model_short: ч­ххЗяМхЏщяМv6.19 фИхфНПчЈяМ\n        mac_clean: MACхАхяМц хщчЌІяМхАхяМ\n        test_type: цЕшЏчБЛх (function/limit/speed)\n\n    Returns:\n        Path: цфЛЖшЗЏхО data/devices/{mac_clean}/{test_type}.json\n    \"\"\"\n    device_dir = get_device_dir(mac_clean)\n    device_dir.mkdir(parents=True, exist_ok=True)\n\n    return device_dir / f'{test_type}.json'\n"}],"isError":false,"timestamp":1781364333292}}
