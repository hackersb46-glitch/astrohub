{"type":"message","id":"37c8f2e7","parentId":"c512085c","timestamp":"2026-06-13T14:50:32.734Z","message":{"role":"toolResult","toolCallId":"call_333699bd2a9a47bca89db1c2","toolName":"read","content":[{"type":"text","text":"                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">чЉКхщхЊ <span id=\"dnrSpatialVal\" style=\"color:#58a6ff\">--</span></label>\n                                            <input type=\"range\" id=\"dnrSpatial\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('dnrSpatialVal').textContent=this.value\" onchange=\"setNoiseReduce('spatial', this.value)\">\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">цЖхщхЊ <span id=\"dnrTemporalVal\" style=\"color:#58a6ff\">--</span></label>\n                                            <input type=\"range\" id=\"dnrTemporal\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('dnrTemporalVal').textContent=this.value\" onchange=\"setNoiseReduce('temporal', this.value)\">\n                                        </div>\n                                    </div>\n                                    <!-- цхцЈЁхМ + хПЋщЈ/хх (v5.47: цДххАфИшЁ) -->\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\n                                        <label style=\"font-size:11px;color:#8b949e\">цхцЈЁхМ</label>\n                                        <select id=\"exposureMode\" style=\"width:100%;padding:4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setExposureMode(this.value);updateShutterIrisState()\">\n                                            <option value=\"auto\">шЊхЈ</option>\n                                            <option value=\"manual\">цхЈ</option>\n                                        </select>\n                                    </div>\n                                    <!-- хПЋщЈ/ххцДхфИшЁ -->\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">хПЋщЈ</label>\n                                            <select id=\"shutterSpeed\" style=\"width:100%;padding:3px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\" onchange=\"setShutterSpeed(this.value)\" disabled>\n                                                <option value=\"\">--</option>\n                                            </select>\n                                        </div>\n                                        <div style=\"flex:1\">\n                                            <label style=\"font-size:11px;color:#8b949e\">хх</label>\n                                            <select id=\"irisLevel\" style=\"width:100%;padding:3px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\" onchange=\"setIris(this.value)\" disabled>\n                                                <option value=\"\">--</option>\n                                            </select>\n                                        </div>\n                                    </div>\n                                    <!-- OSD цЇхЖ - v6.14: ц щЂцЙфИКтфПЁцЏт -->\n                                    <div class=\"form-group\" style=\"margin-bottom:8px;display:flex;justify-content:space-between;align-items:center\">\n                                        <label style=\"font-size:12px;margin:0\">фПЁцЏ</label>\n                                        <div style=\"display:flex;gap:16px\">\n                                            <div style=\"display:flex;align-items:center;gap:6px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">OSD</span>\n                                                <label class=\"toggle-switch\">\n                                                    <input type=\"checkbox\" id=\"infoOsdSwitch\" onchange=\"toggleInfoOsdSwitch(this.checked)\">\n                                                    <span class=\"toggle-slider\"></span>\n                                                </label>\n                                            </div>\n                                            <div style=\"display:flex;align-items:center;gap:6px\">\n                                                <span style=\"font-size:11px;color:#8b949e\">PTZ</span>\n                                                <label class=\"toggle-switch\">\n                                                    <input type=\"checkbox\" id=\"ptzOsdSwitch\" onchange=\"togglePtzOsdSwitch(this.checked)\">\n                                                    <span class=\"toggle-slider\"></span>\n                                                </label>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n<style>\n/* v6.02: цЈцхМхГц ЗхМ */\n.toggle-switch {\n    position: relative;\n    display: inline-block;\n    width: 40px;\n    height: 22px;\n}\n.toggle-switch input {\n    opacity: 0;\n    width: 0;\n    height: 0;\n}\n.toggle-slider {\n    position: absolute;\n    cursor: pointer;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background-color: #30363d;\n    transition: 0.3s;\n    border-radius: 22px;\n}\n.toggle-slider:before {\n    position: absolute;\n    content: \"\";\n    height: 16px;\n    width: 16px;\n    left: 3px;\n    bottom: 3px;\n    background-color: #e0e6f0;\n    transition: 0.3s;\n    border-radius: 50%;\n}\ninput:checked + .toggle-slider {\n    background-color: #238636;\n}\ninput:checked + .toggle-slider:before {\n    transform: translateX(18px);\n}\n\n/* цх щЂцПц ЗхМ */\n.collapsible-section {\n    background: #161b22;\n    border: 1px solid #21262d;\n    border-radius: 8px;\n    margin-bottom: 12px;\n    overflow: hidden;\n}\n.collapsible-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 10px 12px;\n    cursor: pointer;\n    background: #0d1117;\n    transition: background 0.2s;\n}\n.collapsible-header:hover {\n    background: #161b22;\n}\n.collapse-icon {\n    color: #8b949e;\n    font-size: 12px;\n    transition: transform 0.2s;\n}\n.collapsible-section.collapsed .collapse-icon {\n    transform: rotate(-90deg);\n}\n.collapsible-content {\n    padding: 12px;\n    max-height: 1000px;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out, padding 0.3s;\n}\n.collapsible-section.collapsed .collapsible-content {\n    max-height: 0;\n    padding: 0 12px;\n}\n.section-subtitle {\n    font-size: 12px;\n    color: #6e7681;\n    margin: 8px 0 4px;\n    padding-top: 8px;\n    border-top: 1px solid #21262d;\n}\n.section-subtitle:first-child {\n    border-top: none;\n    padding-top: 0;\n}\n</style>\n\n<script>\n// ч­хО apiGet/apiPost хЏчЈхххЎфЙхНцА\n(function() {\n    // цЃцЅ apiGet цЏхІхЗВхЎфЙ\n    if (typeof apiGet === 'undefined') {\n        console.warn('[CONSOLE] apiGet not yet defined, will retry on DOMContentLoaded');\n        document.addEventListener('DOMContentLoaded', function() {\n            // DOM х шННхЎцхщцАцЇшЁ\n            if (typeof apiGet !== 'undefined') {\n                console.log('[CONSOLE] apiGet now available');\n            }\n        });\n    }\n})();\n\n// цх /хБхМцЇхЖ\nfunction toggleSection(sectionId) {\n    var section = document.getElementById(sectionId);\n    if (section) {\n        section.classList.toggle('collapsed');\n    }\n}\n\n// ==================== хЈцх шННшЎОхЄхОххцА ====================\nvar deviceImageParams = {};\nvar deviceFunctionData = null; // v5.42: х­хЈfunction.jsonцАцЎ\n\n// v6.20: хшНцЏцчЖц\nvar deviceFunctionData = null;\nvar functionCacheLoaded = false;\n\n// v6.20: чІчЈчЛщЂцЇхЖцццЇфЛЖ\nfunction disableImageControls(reason) {\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // цОчЄКцчЄКцх­\n    var section = document.getElementById('imageControlSection');\n    if (section) {\n        var content = section.querySelector('.collapsible-content');\n        if (content && !document.getElementById('functionCacheWarning')) {\n            var warning = document.createElement('div');\n            warning.id = 'functionCacheWarning';\n            warning.style.cssText = 'background:#4a3a1a;border:1px solid #d29922;border-radius:6px;padding:12px;margin:8px 0;color:#d29922;font-size:12px;text-align:center';\n            warning.innerHTML = '<strong>т яИ ' + reason + '</strong><br><span style=\"color:#8b949e\">шЏЗхЈущЋчКЇхшН т хшНцЂцЕуфИ­хЎццЕшЏ</span>';\n            content.insertBefore(warning, content.firstChild);\n        }\n    }\n}\n\n// v6.20: хЏчЈчЛщЂцЇхЖ\nfunction enableImageControls() {\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = false;\n            el.style.opacity = '1';\n            el.style.cursor = 'pointer';\n        }\n    });\n    \n    // чЇЛщЄш­Іх\n    var warning = document.getElementById('functionCacheWarning');\n    if (warning) warning.remove();\n}\n\n// шПцЅшЎОхЄцЖх шННхОххцАяМфЛfunction.jsonшЏЛхшхДяМфЛISAPIшЏЛххНххМяМ\n// v6.20: фМхшЏЛхчМх­яМц чМх­цЖчІчЈцЇфЛЖ\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // v6.20: щчНЎчЖц\n    functionCacheLoaded = false;\n    deviceFunctionData = null;\n    \n    // v6.20: фНПчЈ async/await чЁЎфПщЁКхКфНфИщЛхЁ UI\n    (async function() {\n        // 1. ххАшЏх шНН function.json чМх­\n        try {\n            var r = await apiGet('/api/v1/ptz/' + deviceIp + '/function');\n            if (r && r.success && r.data && r.data.results) {\n                deviceFunctionData = r.data;\n                functionCacheLoaded = true;\n                console.log('[IMAGE] function.json loaded from cache');\n                enableImageControls();\n            } else {\n                console.warn('[IMAGE] function.json not found or invalid');\n                disableImageControls('цЊхЎцхшНцЕшЏ');\n                functionCacheLoaded = false;\n                return; // ц чМх­яМфИх шННхЖфЛхцА\n            }\n        } catch (e) {\n            console.warn('[IMAGE] function.json failed:', e);\n            disableImageControls('цЊхЎцхшНцЕшЏ');\n            functionCacheLoaded = false;\n            return;\n        }\n        \n        // 2. цчМх­цх шННхЖфЛхцАяМщЁКхКцЇшЁфНфИщЛхЁяМ\n        loadExposure(deviceIp);\n        loadOsdStatus(deviceIp);\n        loadWhiteBalance(deviceIp);\n        loadNoiseReduce(deviceIp);\n        loadShutter(deviceIp);\n        loadIris(deviceIp);\n        loadSharpness(deviceIp);\n        loadColorParams(deviceIp);\n    })();\n}\n\n// х шНН OSD чЖц\nfunction loadOsdStatus(deviceIp) {\n    // PTZ OSD\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/ptz').then(function(r) {\n        if (r && r.success) {\n            var enabled = r.enabled || r.data?.enabled || false;\n            updatePtzOsdButtons(enabled);\n            // фПх­хА localStorage\n            localStorage.setItem('osd_ptz_' + deviceIp, enabled ? '1' : '0');\n        } else {\n            // фЛ localStorage шЏЛхфИцЌЁшЎОчНЎ\n\n[568 more lines in file. Use offset=500 to continue.]"}],"isError":false,"timestamp":1781362232734}}
