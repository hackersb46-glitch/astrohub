{"type":"message","id":"3aa6972c","parentId":"f141e230","timestamp":"2026-06-13T15:26:35.922Z","message":{"role":"assistant","content":[{"type":"text","text":"цЃцЅ PTZ_FUNCTION_source.pyяМ"},{"type":"toolCall","id":"tool-de91faf1dd474bebb6a171edfced1be1","name":"read","arguments":{"limit":100,"offset":1,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\PTZ_FUNCTION_source.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":119821,"output":52,"cacheRead":0,"cacheWrite":0,"totalTokens":119873,"cost":{"input":0.119821,"output":0.0001664,"cacheRead":0,"cacheWrite":0,"total":0.1199874}},"stopReason":"toolUse","timestamp":1781364381679,"responseId":"cht000dac0c@dx19ec1977a05ba5c342"}}
{"type":"message","id":"13fa56e6","parentId":"3aa6972c","timestamp":"2026-06-13T15:26:35.929Z","message":{"role":"toolResult","toolCallId":"tool-de91faf1dd474bebb6a171edfced1be1","toolName":"read","content":[{"type":"text","text":"# -*- coding: utf-8 -*-\r\n\"\"\"\r\nPTZ_FUNCTION.py - PTZ Function Test Script\r\nReads from PTZ_CONFIG.json -> tests endpoints -> appends record to PTZ_CONFIG.json\r\nOutput: endpoint report in PTZ_CONFIG.json records\r\n\"\"\"\r\n\r\nimport sys, os, time, json\r\nfrom datetime import datetime\r\n\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\nfrom ptzhelper import (\r\n    log_init, log_info, log_warn, log_err, log_done, log_fail,\r\n    PTZHelper, load_device_config, save_device_config,\r\n    authenticate, safe_input, wait_stable,\r\n    safe_write_json, safe_read_json,\r\n    PTZ_CONFIG_FILE, append_record\r\n)\r\n\r\nSCRIPT_VERSION = 'v2.0'\r\nPROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))\r\n\r\n# ===== Load from PTZ_CONFIG =====\r\ndef load_from_ptz_config():\r\n    \"\"\"Load IP/auth from PTZ_CONFIG.json\"\"\"\r\n    data = safe_read_json(PTZ_CONFIG_FILE)\r\n    if not data:\r\n        log_err('PTZ_CONFIG.json not found, run PTZ_STARTUP first')\r\n        sys.exit(1)\r\n    ip = data.get('device_ip')\r\n    username = data.get('username', 'admin')\r\n    if not ip:\r\n        log_err('device_ip not found in PTZ_CONFIG.json')\r\n        sys.exit(1)\r\n    return data\r\n\r\n# ===== Endpoint probe =====\r\ndef test_endpoints(ip, auth):\r\n    log_info('========== Endpoint Probe ==========')\r\n    ptz = PTZHelper(ip, auth)\r\n    sess = ptz.session\r\n    sess.trust_env = False\r\n    ptz._clear_proxy()\r\n\r\n    endpoints = [\r\n        ('/ISAPI/System/deviceInfo',           'GET',  'Device Info'),\r\n        ('/ISAPI/PTZCtrl/channels/1/status',   'GET',  'PTZ Status'),\r\n        ('/ISAPI/PTZCtrl/channels/1/capabilities', 'GET', 'PTZ Capabilities'),\r\n        ('/ISAPI/Image/channels/1/color',      'GET',  'Image Color'),\r\n        ('/ISAPI/Image/channels/1/exposure',   'GET',  'Image Exposure'),\r\n        ('/ISAPI/Image/channels/1/whiteBalance','GET', 'White Balance'),\r\n        ('/ISAPI/Streaming/channels/1',        'GET',  'Stream Channel'),\r\n        ('/ISAPI/System/Network/interfaces',    'GET',  'Network Interface'),\r\n    ]\r\n\r\n    results = []\r\n    all_pass = True\r\n    for ep, method, desc in endpoints:\r\n        try:\r\n            if method == 'GET':\r\n                r = sess.get(f'http://{ip}{ep}', auth=ptz.auth, timeout=10)\r\n            else:\r\n                r = sess.put(f'http://{ip}{ep}', auth=ptz.auth, timeout=10)\r\n            ok = r.status_code in (200, 404, 400)\r\n            results.append({'endpoint': ep, 'method': method, 'desc': desc,\r\n                           'status_code': r.status_code, 'ok': ok})\r\n            if ok:\r\n                log_done(f'{method} {ep} -> {r.status_code} ({desc})')\r\n            else:\r\n                log_err(f'{method} {ep} -> {r.status_code} ({desc})')\r\n                all_pass = False\r\n        except Exception as e:\r\n            results.append({'endpoint': ep, 'method': method, 'desc': desc,\r\n                           'error': str(e), 'ok': False})\r\n            log_err(f'{method} {ep} -> ERROR: {e}')\r\n            all_pass = False\r\n\r\n    log_done(f'Endpoint probe done: {sum(1 for r in results if r[\"ok\"])}/{len(results)} passed')\r\n    return results, all_pass\r\n\r\n# ===== Basic motion test =====\r\ndef test_basic_motion(ip, auth):\r\n    log_info('========== Basic Motion Test ==========')\r\n    ptz = PTZHelper(ip, auth)\r\n\r\n    # HOME position\r\n    log_info('P5.0: HOME preset')\r\n    ptz.preset_goto(10)\r\n    wait_stable(ptz)\r\n    status = ptz.get_status()\r\n    log_info(f'P5.0: HOME az={status[\"azimuth\"]} el={status[\"elevation\"]} zoom={status[\"zoom\"]}')\r\n\r\n    # Save preset\r\n    log_info('P5.1: Save preset 10')\r\n    ok = ptz.save_preset(10, 'HOME')\r\n    log_done(f'P5.1: Save preset -> {\"OK\" if ok else \"FAIL\"}')\r\n\r\n    # Continuous move\r\n    log_info('P5.2: Continuous move test')\r\n    for pan, tilt, label in [(5, 0, 'Right'), (-5, 0, 'Left'), (0, 5, 'Up'), (0, -5, 'Down')]:\r\n\n[71 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1781364395929}}
