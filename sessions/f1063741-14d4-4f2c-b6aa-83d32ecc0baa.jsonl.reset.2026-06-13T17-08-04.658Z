{"type":"message","id":"18078c86","parentId":"bef168fb","timestamp":"2026-06-13T14:50:13.634Z","message":{"role":"assistant","content":[{"type":"text","text":"цЅхПцОчЄКцц WebSocket шПцЅшЂЋ 403 цчЛушПцЏ WASM ц­цОхЄБшДЅчц ЙцЌхх у\n\nцЅцО WASM WebSocket чИхГфЛЃч ххЄфЛНчцЌхЏЙцЏяМ"},{"type":"toolCall","id":"call_acc4bd0115054576a40b5994","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html","offset":1,"limit":500}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":27625,"output":81,"cacheRead":0,"cacheWrite":0,"totalTokens":27706,"cost":{"input":0.027625,"output":0.0002592,"cacheRead":0,"cacheWrite":0,"total":0.0278842}},"stopReason":"toolUse","timestamp":1781362206913,"responseId":"cht000e33df@dx19ec1763455b893102"}}
{"type":"message","id":"91dd05fe","parentId":"18078c86","timestamp":"2026-06-13T14:50:13.640Z","message":{"role":"toolResult","toolCallId":"call_acc4bd0115054576a40b5994","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\r\n<html lang=\"zh-CN\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>AstroHub</title>\r\n    <style>\r\n        * { margin:0; padding:0; box-sizing:border-box; }\r\n        body { font-family: -apple-system, 'Segoe UI', sans-serif; background:#0a0e17; color:#e0e6f0; min-height:100vh; }\r\n        .header { background:linear-gradient(135deg, #1a1e2e, #0d1117); padding:12px 24px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #21262d; }\r\n        .logo { font-size:24px; font-weight:700; color:#58a6ff; }\r\n        .logo span { color:#f0883e; }\r\n        .version { font-size:12px; color:#8b949e; background:#21262d; padding:2px 8px; border-radius:12px; }\r\n        .status-bar { display:flex; gap:16px; align-items:center; }\r\n        .status-item { display:flex; align-items:center; gap:6px; font-size:13px; }\r\n        .status-dot { width:8px; height:8px; border-radius:50%; }\r\n        .status-dot.green { background:#3fb950; box-shadow:0 0 6px #3fb950; }\r\n        .status-dot.yellow { background:#d29922; box-shadow:0 0 6px #d29922; }\r\n        .status-dot.red { background:#f85149; box-shadow:0 0 6px #f85149; }\r\n        /* хМхГц ЗхМ */\r\n        .switch { position:relative; display:inline-block; width:36px; height:18px; }\r\n        .switch input { opacity:0; width:0; height:0; }\r\n        .slider { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background-color:#30363d; transition:.2s; border-radius:18px; }\r\n        .slider:before { position:absolute; content:\"\"; height:12px; width:12px; left:3px; bottom:3px; background-color:#8b949e; transition:.2s; border-radius:50%; }\r\n        input:checked + .slider { background-color:#238636; }\r\n        input:checked + .slider:before { transform:translateX(18px); background-color:#fff; }\r\n        .nav { background:#161b22; padding:8px 24px; display:flex; gap:4px; align-items:center; border-bottom:1px solid #21262d; flex-wrap:wrap; }\r\n        .nav-btn { background:none; border:none; color:#8b949e; padding:8px 16px; cursor:pointer; border-radius:6px; font-size:14px; transition:all 0.2s; }\r\n        .nav-btn:hover { background:#21262d; color:#e0e6f0; }\r\n        .nav-btn.active { background:#238636; color:#fff; }\r\n        /* --- Advanced Page: Left Sidebar Layout --- */\r\n        .advanced-layout { display:flex; gap:0; min-height:600px; }\r\n        .advanced-sidebar { width:200px; background:#161b22; border-right:1px solid #21262d; padding:8px 0; flex-shrink:0; }\r\n        .advanced-sidebar .sidebar-item { background:none; border:none; color:#8b949e; padding:10px 16px; cursor:pointer; font-size:13px; transition:all 0.2s; width:100%; text-align:left; display:block; }\r\n        .advanced-sidebar .sidebar-item:hover { background:#21262d; color:#e0e6f0; }\r\n        .advanced-sidebar .sidebar-item.active { background:#238636; color:#fff; border-left:3px solid #3fb950; }\r\n        .advanced-content { flex:1; min-width:0; padding:20px; }\r\n        .advanced-content .page { display:none; }\r\n        .advanced-content .page.active { display:block; }\r\n        /* --- Observation Page Layout --- */\r\n        .observation-layout { display:grid; grid-template-columns:1fr 1fr; gap:20px; }\r\n        .obs-card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; }\r\n        .obs-card h3 { font-size:15px; color:#58a6ff; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #21262d; }\r\n        .obs-placeholder { color:#6e7681; font-size:13px; padding:20px 0; text-align:center; }\r\n        .obs-actions { margin-top:16px; display:flex; gap:8px; justify-content:flex-end; }\r\n        .main { padding:20px 24px; }\r\n        .page { display:none; }\r\n        .page.active { display:block; }\r\n        .grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:16px; margin-bottom:20px; }\r\n        .card { background:#161b22; border:1px solid #21262d; border-radius:10px; padding:16px; transition:border-color 0.2s; }\r\n        .card:hover { border-color:#30363d; }\r\n        .card-title { font-size:12px; color:#8b949e; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }\r\n        .card-value { font-size:32px; font-weight:700; color:#e0e6f0; }\r\n        .card-value.green { color:#3fb950; }\r\n        .card-sub { font-size:12px; color:#6e7681; margin-top:4px; }\r\n        table { width:100%; border-collapse:collapse; }\r\n        th, td { text-align:left; padding:10px 16px; border-bottom:1px solid #21262d; font-size:14px; }\r\n        th { color:#8b949e; font-weight:500; background:#0d1117; }\r\n        tr:hover { background:#161b22; }\r\n        .badge { padding:2px 8px; border-radius:12px; font-size:12px; font-weight:500; }\r\n        .badge.online { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.offline { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .badge.sadp { background:rgba(88,166,255,0.15); color:#58a6ff; }\r\n        .badge.manual { background:rgba(240,136,62,0.15); color:#f0883e; }\r\n        .badge.yes { background:rgba(63,185,80,0.15); color:#3fb950; }\r\n        .badge.no { background:rgba(248,81,73,0.15); color:#f85149; }\r\n        .ptz-controls { display:grid; grid-template-columns:repeat(3, 80px); gap:8px; justify-content:center; margin:20px 0; }\r\n        .ptz-btn { width:80px; height:80px; border:1px solid #30363d; border-radius:10px; background:#161b22; color:#e0e6f0; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; }\r\n        .ptz-btn:hover { background:#238636; border-color:#238636; }\r\n        .ptz-btn.center { background:#21262d; cursor:default; }\r\n        .ptz-btn.center:hover { background:#21262d; transform:none; }\r\n        .ptz-btn:active:not(.center) { transform:scale(0.95); }\r\n        .ptz-speed { display:flex; align-items:center; gap:12px; justify-content:center; margin:16px 0; }\r\n        .ptz-speed input[type=range] { width:200px; accent-color:#58a6ff; }\r\n        .form-group { margin-bottom:16px; }\r\n        .form-group label { display:block; font-size:14px; color:#8b949e; margin-bottom:6px; }\r\n        .form-group input, .form-group select { width:100%; padding:10px 12px; background:#0d1117; border:1px solid #30363d; border-radius:6px; color:#e0e6f0; font-size:14px; }\r\n        .form-group input:focus, .form-group select:focus { outline:none; border-color:#58a6ff; }\r\n        .btn { padding:10px 20px; border:none; border-radius:6px; font-size:14px; cursor:pointer; transition:all 0.2s; }\r\n        .btn-primary { background:#238636; color:#fff; }\r\n        .btn-primary:hover { background:#2ea043; }\r\n        .btn-secondary { background:#30363d; color:#e0e6f0; }\r\n        .btn-secondary:hover { background:#484f58; }\r\n        .btn-danger { background:#da3633; color:#fff; }\r\n        .btn-danger:hover { background:#f85149; }\r\n        .btn-warning { background:#d29922; color:#0d1117; }\r\n        .btn-warning:hover { background:#e3b341; }\r\n        .btn-sm { padding:6px 12px; font-size:12px; }\r\n        .btn:disabled { opacity:0.5; cursor:not-allowed; }\r\n        .btn-group { display:flex; gap:8px; flex-wrap:wrap; }\r\n        .progress-bar { height:8px; background:#21262d; border-radius:4px; overflow:hidden; }\r\n        .progress-fill { height:100%; border-radius:4px; transition:width 0.3s; }\r\n        .progress-fill.green { background:#3fb950; }\r\n        .progress-fill.yellow { background:#d29922; }\r\n        .progress-fill.red { background:#f85149; }\r\n        .progress-fill.blue { background:#58a6ff; }\r\n        /* Advanced page status panel */\r\n        .advanced-status-panel { background:#0d1117; border:1px solid #21262d; border-radius:10px; padding:16px; margin:16px 0; }\r\n        .advanced-status-panel h4 { font-size:15px; color:#e0e6f0; margin-bottom:12px; border-bottom:1px solid #21262d; padding-bottom:8px; }\r\n        .status-row { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #21262d; font-size:14px; }\r\n        .status-row:last-child { border-bottom:none; }\r\n        .status-label { color:#8b949e; }\r\n        .status-value { color:#e0e6f0; font-family:monospace; }\r\n        .adv-header { display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap; }\r\n        .adv-header select { max-width:300px; }\r\n        .result-table { margin:16px 0; }\r\n        .progress-section { margin:16px 0; }\r\n        .progress-text { font-size:13px; color:#8b949e; margin-bottom:4px; }\r\n        .current-direction { font-size:18px; color:#58a6ff; font-family:monospace; text-align:center; padding:8px; background:#0d1117; border-radius:8px; margin:12px 0; }\r\n        .log-entry { padding:6px 12px; border-left:3px solid #30363d; margin-bottom:4px; font-size:13px; font-family:monospace; }\r\n        .log-entry.info { border-color:#58a6ff; }\r\n        .log-entry.warn { border-color:#d29922; }\r\n        .log-entry.error { border-color:#f85149; }\r\n        .log-entry.success { border-color:#3fb950; }\r\n        /* Toast notification */\r\n        .toast-container { position:fixed; top:60px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; }\r\n        .toast { padding:12px 20px; border-radius:8px; font-size:14px; animation:slideIn 0.3s ease; min-width:250px; max-width:400px; }\r\n        .toast.success { background:#1a4731; border:1px solid #3fb950; color:#3fb950; }\r\n        .toast.error { background:#4d1c1a; border:1px solid #f85149; color:#f85149; }\r\n        .toast.info { background:#1a3a52; border:1px solid #58a6ff; color:#58a6ff; }\r\n        .toast.warning { background:#4a3a1a; border:1px solid #d29922; color:#d29922; }\r\n        @keyframes slideIn { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }\r\n        /* Modal */\r\n        .modal-backdrop { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9000; display:flex; align-items:center; justify-content:center; }\r\n        .modal { background:#161b22; border:1px solid #30363d; border-radius:12px; padding:24px; width:400px; max-width:90vw; }\r\n        .modal h3 { margin-bottom:16px; font-size:18px; }\r\n        .modal .btn-group { justify-content:flex-end; margin-top:20px; }\r\n        /* Loading spinner */\r\n        .spinner { display:inline-block; width:16px; height:16px; border:2px solid #30363d; border-top-color:#58a6ff; border-radius:50%; animation:spin 0.8s linear infinite; }\r\n        @keyframes spin { to { transform:rotate(360deg); } }\r\n        .loading { pointer-events:none; opacity:0.7; }\r\n        /* Device actions */\r\n        .actions { display:flex; gap:4px; flex-wrap:wrap; }\r\n        /* PTZ status panel */\r\n        .ptz-position { text-align:center; padding:12px; background:#0d1117; border-radius:8px; margin:12px 0; font-family:monospace; font-size:14px; }\r\n        .toolbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap; }\r\n        .toolbar-actions { display:flex; gap:8px; }\r\n        .device-info-panel { background:#0d1117; border-radius:8px; padding:16px; margin-top:12px; font-size:13px; }\r\n        .device-info-panel .info-row { display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid #21262d; }\r\n        .device-info-panel .info-row:last-child { border-bottom:none; }\r\n        .device-info-panel .info-label { color:#8b949e; }\r\n        .device-info-panel .info-value { color:#e0e6f0; font-family:monospace; }\r\n        @media (max-width:768px) { .grid { grid-template-columns:1fr 1fr; } .header { flex-direction:column; gap:8px; } .nav { overflow-x:auto; } .console-layout { flex-direction:column !important; } .console-left, .console-center, .console-right { width:100% !important; } }\r\n        /* Console page: left-right layout (SPEC: left=joystick, right=display) */\r\n        .console-layout { display:flex; gap:20px; align-items:flex-start; }\r\n        .console-left { flex:0 0 320px; display:flex; flex-direction:column; }\r\n        .console-center { flex:1; min-width:0; display:flex; flex-direction:column; }\r\n        .console-right { flex:0 0 25%; max-width:300px; display:flex; flex-direction:column; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"header\">\r\n        <div class=\"logo\">Astro<span>Hub</span></div>\r\n        <div class=\"status-bar\">\r\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wsDot\"></span><span id=\"wsStatus\">ISAPI: цЊшПцЅ</span></div>\r\n            <div class=\"status-item\"><span class=\"status-dot red\" id=\"wasmDot\"></span><span id=\"wasmStatus\">шЇщЂ: цЊшПцЅ</span></div>\r\n            <div class=\"status-item\" id=\"clock\"></div>\r\n            <!-- хПЋщшПцЅхМхГ -->\r\n            <div class=\"status-item\">\r\n                <span style=\"color:#8b949e;font-size:12px\">хПЋщшПцЅ</span>\r\n                <label class=\"switch\">\r\n                    <input type=\"checkbox\" id=\"quickConnectSwitch\" onchange=\"quickConnect(this.checked)\">\r\n                    <span class=\"slider\"></span>\r\n                </label>\r\n            </div>\r\n            <!-- щхЏцщЎ -->\r\n            <button class=\"btn btn-secondary btn-sm\" onclick=\"confirmRestart()\" style=\"padding:2px 8px\">щхЏ</button>\r\n            <span class=\"version\">v6.40</span>\r\n        </div>\r\n    </div>\r\n    <div 