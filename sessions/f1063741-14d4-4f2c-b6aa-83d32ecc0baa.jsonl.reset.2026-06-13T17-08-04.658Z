Content = 'шЇщЂ: шПцЅфИ­...';\r\n        } else if (state === 'connected') {\r\n            wasmDot.className = 'status-dot green';\r\n            wasmStatus.textContent = 'шЇщЂ: WASM';\r\n        } else if (state === 'disconnected') {\r\n            wasmDot.className = 'status-dot red';\r\n            wasmStatus.textContent = 'шЇщЂ: цЊшПцЅ';\r\n        }\r\n    };\r\n    \r\n    // v6.18: чЎххПЋщшПцЅ - чДцЅфЛхчЋЏшЗхфИцЌЁшЎОхЄ\r\n    var _quickConnectSkipNext = false;\r\n    window.quickConnect = function(checked) {\r\n        if (_quickConnectSkipNext) {\r\n            _quickConnectSkipNext = false;\r\n            return;\r\n        }\r\n        if (checked) {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                console.log('[QUICK] Already connected');\r\n                return;\r\n            }\r\n            // v6.18: фЛхчЋЏшЗхфИцЌЁшПцЅчшЎОхЄ\r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.device) {\r\n                    console.log('[QUICK] Connecting to:', r.device.ip);\r\n                    if (window.connectDevice) {\r\n                        window.connectDevice(r.device.ip);\r\n                    }\r\n                } else {\r\n                    showToast('warning', 'ц фИцЌЁшПцЅшЎОхЄяМшЏЗцЇшЁхчАцЕчЈ');\r\n                    _quickConnectSkipNext = true;\r\n                    document.getElementById('quickConnectSwitch').checked = false;\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', 'шЗхшЎОхЄфПЁцЏхЄБшДЅ');\r\n                _quickConnectSkipNext = true;\r\n                document.getElementById('quickConnectSwitch').checked = false;\r\n            });\r\n        } else {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                disconnectDevice(window.connectedDevice.ip);\r\n            }\r\n        }\r\n    };\r\n    \r\n    // чЁЎшЎЄщхЏ\r\n    window.confirmRestart = function() {\r\n        if (!confirm('чЁЎхЎшІщхЏ AstroHub хяМ\\nщхЏцщДцхЁхАццЖфИхЏчЈу')) return;\r\n        \r\n        showToast('info', 'ц­ЃхЈщхЏ AstroHub...');\r\n        \r\n        // шАчЈщхЏ API\r\n        apiPost('/api/v1/system/restart', null).then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', 'щхЏфИ­яМ10чЇхшЊхЈхЗцАщЁЕщЂ...');\r\n                setTimeout(function() {\r\n                    location.reload();\r\n                }, 10000);\r\n            } else {\r\n                showToast('error', r ? r.message : 'щхЏхЄБшДЅ');\r\n            }\r\n        }).catch(function(e) {\r\n            // хГфНПшЏЗцБхЄБшДЅяМфЙхшЎОщхЏцхяМцхЁхЗВхц­ЂяМ\r\n            showToast('warning', 'щхЏфИ­яМ10чЇхшЊхЈхЗцАщЁЕщЂ...');\r\n            setTimeout(function() {\r\n                location.reload();\r\n            }, 10000);\r\n        });\r\n    };\r\n    \r\n    // щЁЕщЂхцЂхНцА\r\n    window.switchPage = function(page) {\r\n        document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n        document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n        document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\r\n        document.getElementById('page-' + page).classList.add('active');\r\n    };\r\n    \r\n    console.log('[GLOBAL v5.27] Functions ready');\r\n    </script>\r\n</body>\r\n</html>\r\n\r\n\r\n\r\n\r\n\r\n\r\n"}],"isError":false,"timestamp":1781362383759}}
