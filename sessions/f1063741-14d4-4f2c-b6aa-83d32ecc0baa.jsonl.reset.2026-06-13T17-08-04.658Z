{"type":"message","id":"0a111015","parentId":"1d493d16","timestamp":"2026-06-13T15:04:21.112Z","message":{"role":"toolResult","toolCallId":"call_cabc4512ccb24ed1b57971b0","toolName":"read","content":[{"type":"text","text":"}\n\n// х шННхПЋщЈ\nfunction loadShutter(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/shutter').then(function(r) {\n        if (r && r.success && r.data) {\n            var sh = r.data;\n            deviceImageParams.shutter = sh;\n            \n            var shutterSelect = document.getElementById('shutterSpeed');\n            if (shutterSelect) {\n                shutterSelect.innerHTML = '';\n                \n                // шЊхЈщщЁЙ\n                var autoOpt = document.createElement('option');\n                autoOpt.value = 'auto';\n                autoOpt.textContent = 'шЊхЈ';\n                shutterSelect.appendChild(autoOpt);\n                \n                // v5.42: фЛ function.json шЗххПЋщЈшхД\n                var minShutter = '1/30000';\n                var maxShutter = '1/25';\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.shutter) {\n                    minShutter = deviceFunctionData.functions.shutter.min || '1/30000';\n                    maxShutter = deviceFunctionData.functions.shutter.max || '1/25';\n                }\n                \n                // хИИчЈхПЋщЈхМяМхЈшхДхяМ\n                var shutterPresets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000', '1/30000', '1/25'];\n                shutterPresets.forEach(function(p) {\n                    var opt = document.createElement('option');\n                    opt.value = p;\n                    opt.textContent = p;\n                    if (p === sh.current_level) opt.selected = true;\n                    shutterSelect.appendChild(opt);\n                });\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Shutter] Load failed:', e);\n        // шЎОчНЎщЛшЎЄщщЁЙ\n        var shutterSelect = document.getElementById('shutterSpeed');\n        if (shutterSelect) {\n            shutterSelect.innerHTML = '<option value=\"auto\">шЊхЈ</option>';\n            var presets = ['1/30', '1/60', '1/125', '1/250', '1/500', '1/1000', '1/2000', '1/4000', '1/8000'];\n            presets.forEach(function(p) {\n                shutterSelect.innerHTML += '<option value=\"' + p + '\">' + p + '</option>';\n            });\n        }\n    });\n}\n\n// х шННхх\nfunction loadIris(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\n        if (r && r.success && r.data) {\n            var ir = r.data;\n            deviceImageParams.iris = ir;\n            \n            var irisSelect = document.getElementById('irisLevel');\n            if (irisSelect) {\n                irisSelect.innerHTML = '';\n                \n                // v5.42: фЛ function.json шЗхххшхД\n                var minIris = 160;\n                var maxIris = 2200;\n                if (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.iris) {\n                    minIris = deviceFunctionData.functions.iris.min || 160;\n                    maxIris = deviceFunctionData.functions.iris.max || 2200;\n                }\n                \n                var current = ir.current_level || minIris;\n                \n                // F хМц хАяМц хцЕЗхКЗхххМяМ\n                var fValues = [\n                    {val: 160, label: 'F1.6'},\n                    {val: 200, label: 'F2.0'},\n                    {val: 280, label: 'F2.8'},\n                    {val: 400, label: 'F4.0'},\n                    {val: 560, label: 'F5.6'},\n                    {val: 800, label: 'F8.0'},\n                    {val: 1100, label: 'F11'},\n                    {val: 1600, label: 'F16'},\n                    {val: 2200, label: 'F22'}\n                ];\n                \n                fValues.forEach(function(f) {\n                    if (f.val >= minIris && f.val <= maxIris) {\n                        var opt = document.createElement('option');\n                        opt.value = f.val;\n                        opt.textContent = f.label;\n                        if (f.val === current) opt.selected = true;\n                        irisSelect.appendChild(opt);\n                    }\n                });\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Iris] Load failed:', e);\n        // шЎОчНЎщЛшЎЄщщЁЙ\n\n[314 more lines in file. Use offset=750 to continue.]"}],"isError":false,"timestamp":1781363061112}}
