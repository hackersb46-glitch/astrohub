{"type":"message","id":"b83e7197","parentId":"e8725131","timestamp":"2026-06-13T14:50:53.938Z","message":{"role":"toolResult","toolCallId":"tool-e422d536e27d4f9f895c77c539e57600","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python\r\n\"\"\"\r\nAstroHub v2.0 - чЛфИхЅхЃ\r\n\r\nFastAPI + pywebview цЁщЂхЎЂцЗчЋЏ / ц хЄДцхЁчЋЏу\r\n\r\nхшН:\r\n- FastAPI appяМцшНН src/web/index.html щццфЛЖ + SPA хщ\r\n- щццц core managers\r\n- WebSocket чЋЏчЙ /ws\r\n- lifespan: хЏхЈххЇх / хГщ­цИч\r\n- pywebview цЁщЂцЈЁхМ (1600x900, ц щЂ AstroHub)\r\n- --headless цЈЁхМ: фЛ uvicorn\r\n- чГЛчЛцч (Windows pystray)\r\n- цАцЎчЎхНшЊхЈххЛК\r\n\r\nAuthor: щчхМ @хцЙхЄЉц\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\n# ================================================================ #\r\n#  sys.path шЁЅфИяМфНП src/ фИч m1_ptz_astro ч­цЈЁххЏшЂЋщЁЖчКЇхЏМхЅ\r\n# ================================================================ #\r\nimport sys\r\nimport os\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\n\r\nimport warnings\r\nwarnings.warn(\r\n    \"src/main.py is deprecated. Use 'src/main/main.py' for unified entry, \"\r\n    \"or 'src/ptz/main.py' for PTZ module. \"\r\n    \"Will be removed in a future version.\",\r\n    DeprecationWarning,\r\n    stacklevel=2,\r\n)\r\n\r\nimport argparse\r\nimport sys\r\nimport threading\r\nfrom contextlib import asynccontextmanager\r\nfrom pathlib import Path\r\n\r\nimport uvicorn\r\nimport httpx\r\nfrom fastapi import FastAPI, Request, WebSocket, Request\r\nfrom fastapi.responses import FileResponse, HTMLResponse, Response\r\nfrom fastapi.templating import Jinja2Templates\r\nfrom fastapi.staticfiles import StaticFiles\r\n\r\nfrom src.config import HOST, PORT, WINDOW_TITLE, WINDOW_WIDTH, WINDOW_HEIGHT, ensure_directories\r\nfrom src.config_paths import DATA_DIR, HLS_DIR, CALIBRATION_DIR, get_web_dir, get_index_html\r\nfrom src.api.router import api_router, health_router, set_managers, _managers\r\nfrom src.core.ptz_manager import PTZManager\r\nfrom src.core.device_manager import DeviceManager\r\nfrom src.core.stream_manager import StreamManager\r\nfrom src.core.calibration_manager import CalibrationManager\r\nfrom src.core.auth import AuthManager\r\nfrom src.core.ws_manager import WebSocketManager\r\nfrom src.core.ascom_manager import ASCOMManager\r\nfrom src.core.orchestrator import Orchestrator\r\nfrom src.core.health_monitor import HealthMonitor\r\nfrom src.database.core.db_manager import DatabaseManager, init_db\r\nfrom src.logger import get_logger\r\n\r\nlog = get_logger(\"main\")\r\n\r\nasync def lifespan(app: FastAPI):\r\n    \"\"\"хКчЈчхНхЈцяМххЇхццчЎЁчхЈ т yield т цИчццчЎЁчхЈу\"\"\"\r\n    log.info(\"=== AstroHub хЏхЈфИ­ ===\")\r\n\r\n    ensure_directories()  # v6.31: фНПчЈц­ЃчЁЎчхНцАх\r\n\r\n    # ххЇхццчЎЁчхЈ\r\n    log.info(\"ххЇх PTZManager ...\")\r\n    ptz_mgr = PTZManager()\r\n    _managers[\"ptz_manager\"] = ptz_mgr\r\n\r\n    log.info(\"ххЇх DeviceManager ...\")\r\n    device_mgr = DeviceManager()\r\n    _managers[\"device_manager\"] = device_mgr\r\n\r\n    log.info(\"ххЇх StreamManager ...\")\r\n    stream_mgr = StreamManager()\r\n    _managers[\"stream_manager\"] = stream_mgr\r\n\r\n    log.info(\"ххЇх CalibrationManager ...\")\r\n    calib_mgr = CalibrationManager()\r\n    _managers[\"calibration_manager\"] = calib_mgr\r\n\r\n    log.info(\"ххЇх AuthManager ...\")\r\n    auth_svc = AuthManager()\r\n    _managers[\"auth_service\"] = auth_svc\r\n\r\n    log.info(\"ххЇх WebSocketManager ...\")\r\n    ws_mgr = WebSocketManager()\r\n    _managers[\"ws_manager\"] = ws_mgr\r\n\r\n    log.info(\"цЃцЕ ASCOM хЙГхА...\")\r\n    ascom_platform = \"windows\"  # default\r\n    try:\r\n        import sys as _sys\r\n        if _sys.platform == \"linux\":\r\n            ascom_platform = \"linux\"  # Alpaca on Linux\r\n        else:\r\n            # On Windows, check if Alpaca server is available\r\n            try:\r\n                import requests  # noqa: F811\r\n                resp = requests.get(\"http://localhost:5555/management/v1/apidevices\", timeout=3)\r\n                if resp.status_code == 200:\r\n                    log.info(\"цЃцЕхА ASCOM Alpaca Server (localhost:5555)\")\r\n                    ascom_platform = \"linux\"  # Use Alpaca protocol\r\n            except Exception:\r\n                log.info(\"ASCOM Alpaca Server цЊцЃцЕхАяМфНПчЈ Windows COM\")\r\n    except ImportError:\r\n        pass\r\n\r\n    log.info(\"ххЇх ASCOMManager ...\")\r\n    ascom_mgr = ASCOMManager(platform=ascom_platform)\r\n    _managers[\"ascom_manager\"] = ascom_mgr\r\n\r\n    log.info(\"ххЇх DatabaseManager (M5)...\")\r\n    try:\r\n        await init_db()\r\n        db_mgr = DatabaseManager()\r\n        _managers[\"db_manager\"] = db_mgr\r\n        log.info(\"DatabaseManager ххЇхцх\")\r\n    except Exception as e:\r\n        log.error(f\"DatabaseManager ххЇххЄБшДЅ: {e}\")\r\n        _managers[\"db_manager\"] = None\r\n        db_mgr = None\r\n\r\n    log.info(\"ххЇх HealthMonitor ...\")\r\n    health_mon = HealthMonitor()\r\n    _managers[\"health_monitor\"] = health_mon\r\n\r\n    log.info(\"ххЇх Orchestrator ...\")\r\n    orchestrator = Orchestrator()\r\n    await orchestrator.start()\r\n    _managers[\"orchestrator\"] = orchestrator\r\n\r\n    log.info(\"ххЇх ASCOM Alpaca Server (чЋЏхЃ 5555) ...\")\r\n    from src.core.alpaca_server import create_alpaca_server\r\n    alpaca_server = create_alpaca_server(\"localhost\", 5555, ptz_mgr)\r\n    alpaca_thread = threading.Thread(target=alpaca_server.serve_forever, daemon=True)\r\n    alpaca_thread.start()\r\n    _managers[\"alpaca_server\"] = alpaca_server\r\n    log.info(\"ASCOM Alpaca Server хЗВхЏхЈ: http://localhost:5555\")\r\n    log.info(\"  т Telescope (PTZ Pan/Tilt): шЎОхЄчМхЗ 0\")\r\n    log.info(\"  т Focuser (PTZ Zoom): шЎОхЄчМхЗ 0\")\r\n    log.info(\"  т FilterWheel (IRCUT цЅхЄхцЂ): шЎОхЄчМхЗ 0\")\r\n\r\n    # цГЈхЅхАшЗЏчБцЈЁх\r\n    set_managers(\r\n        ptz_manager=ptz_mgr,\r\n        device_manager=device_mgr,\r\n        stream_manager=stream_mgr,\r\n        calibration_manager=calib_mgr,\r\n        auth_service=auth_svc,\r\n        ws_manager=ws_mgr,\r\n        ascom_manager=ascom_mgr,\r\n        db_manager=db_mgr,\r\n        health_monitor=health_mon,\r\n        orchestrator=orchestrator,\r\n    )\r\n\r\n    log.info(\"=== AstroHub ццчЎЁчхЈххЇххЎц ===\")\r\n\r\n    # v6.01: хЏхЈцЖцЇшЁфИцЌЁ SADP хчАяМххЙЖчНхГфПЁцЏхА ptz_config\r\n    try:\r\n        log.info(\"хЏхЈцЖ SADP шЎОхЄхчА...\")\r\n        from src.core.sadp_discovery import SADPManager\r\n        sadp_mgr = SADPManager()\r\n        raw_devices = sadp_mgr.discover_devices(timeout=10)\r\n        if raw_devices:\r\n            log.info(f\"SADP хчА {len(raw_devices)} хАшЎОхЄ\")\r\n            # ххЙЖчНхГфПЁцЏхА ptz_config\r\n            ptz_cfg = ptz_mgr.config.load_ptz_config()\r\n            for d in raw_devices:\r\n                mac = d.get(\"mac\", \"\")\r\n                if mac and mac in ptz_cfg.get(\"devices\", {}):\r\n                    ptz_cfg[\"devices\"][mac][\"gateway\"] = d.get(\"gateway\", \"\")\r\n                    ptz_cfg[\"devices\"][mac][\"subnet_mask\"] = d.get(\"subnet_mask\", \"\")\r\n            ptz_mgr.config.save_ptz_config(ptz_cfg)\r\n            log.info(\"чНхГфПЁцЏхЗВххЙЖхА ptz_config.json\")\r\n        else:\r\n            log.info(\"SADP цЊхчАцАшЎОхЄ\")\r\n    except Exception as e:\r\n        log.warning(f\"хЏхЈцЖ SADP хчАхЄБшДЅ: {e}\")\r\n\r\n    yield\r\n\r\n    # ---- хГщ­щЖцЎЕ ----\r\n    log.info(\"=== AstroHub хГщ­фИ­ ===\")\r\n\r\n    # хц­Ђ ASCOM Alpaca Server\r\n    alpaca_srv = _managers.get(\"alpaca_server\")\r\n    if alpaca_srv:\r\n        log.info(\"ц­ЃхЈхГщ­ ASCOM Alpaca Server ...\")\r\n        alpaca_srv.shutdown()  # type: ignore[union-attr]\r\n        log.info(\"ASCOM Alpaca Server хЗВхГщ­\")\r\n\r\n    # хц­Ђ Orchestrator\r\n    if isinstance(orchestrator, Orchestrator):\r\n        await orchestrator.stop()\r\n        log.info(\"Orchestrator хЗВхц­Ђ\")\r\n\r\n    # ц­хМцц ASCOM шЎОхЄ\r\n    if isinstance(ascom_mgr, ASCOMManager):\r\n        ascom_mgr.disconnect_all()\r\n        log.info(\"ASCOM шЎОхЄхЗВхЈщЈц­хМ\")\r\n\r\n    # Close db_manager\r\n    if isinstance(db_mgr, DatabaseManager):\r\n        await db_mgr.close()\r\n        log.info(\"DatabaseManager хЗВхГщ­\")\r\n\r\n    _managers.clear()\r\n    log.info(\"=== AstroHub хЗВхЎхЈхГщ­ ===\")\r\n\r\n\r\n# ================================================================ #\r\n#  SPA хщшЗЏхОхшЁЈ\r\n# ================================================================ #\r\n\r\n_SPA_FALLBACK_PATHS = {\r\n    \"/\", \"/dashboard\", \"/devices\", \"/console\", \"/observation\", \"/advanced\", \"/replay\",\r\n}\r\n\r\n\r\n# ================================================================ #\r\n#  ххЛК FastAPI App\r\n# ================================================================ #\r\n\r\n_WEB_DIR = get_web_dir()\r\n_INDEX_HTML = get_index_html()\r\n_templates = Jinja2Templates(directory=str(_WEB_DIR))  # v6.32: ххЇхцЈЁцП\r\n\r\n\r\ndef create_app() -> FastAPI:\r\n    \"\"\"ххЛКхЙЖщчНЎ FastAPI хКчЈу\"\"\"\r\n    app = FastAPI(\r\n        title=\"AstroHub\",\r\n        description=\"чЛфИхЄЉцшЎОхЄцЇхЖхЙГхА\",\r\n        version=\"2.0\",\r\n        lifespan=lifespan,\r\n    )\r\n\r\n    # цшНН HLS щццфЛЖчЎхН\r\n    HLS_DIR.mkdir(parents=True, exist_ok=True)\r\n    app.mount(\"/hls\", StaticFiles(directory=str(HLS_DIR), html=True), name=\"hls\")\r\n\r\n    # цшНН src/web/static щццфЛЖ\r\n    app.mount(\"/static\", StaticFiles(directory=str(_WEB_DIR / \"static\"), html=True), name=\"static\")\r\n\r\n    # цшНН API шЗЏчБ\r\n    app.include_router(api_router)\r\n    app.include_router(health_router)\r\n\r\n    # ц ЙшЗЏхО -> index.html\r\n    @app.get(\"/\", response_class=HTMLResponse)\r\n    async def serve_index(request: Request) -> HTMLResponse:\r\n        return _templates.TemplateResponse(\"index.html\", {\"request\": request})\r\n\r\n    # SPA хщ - ццхчЋЏшЗЏчБшПх index.html\r\n# SPA хчЋЏшЗЏчБхшЁЈяМщшПфКшЗЏхОхКшПх 404яМ\r\n    _SPA_ROUTES = frozenset({\r\n        \"/\", \"/dashboard\", \"/devices\", \"/console\", \"/observation\", \"/advanced\", \"/replay\",\r\n    })\r\n\r\n    \r\n    # ================================================================ #\r\n    #  ISAPI Proxy for WASM SDK\r\n    # ================================================================ #\r\n\r\n\r\n    @app.api_route('/ISAPI/{path:path}', methods=['GET', 'POST', 'PUT', 'DELETE'])\r\n    async def isapi_proxy(path: str, request: Request) -> Response:\r\n        \"\"\"Proxy ISAPI requests to Hikvision device for WASM SDK.\"\"\"\r\n        # v6.40: ISAPI цфНцЅхП\r\n        from src.operation_logger import log_isapi\r\n        log_isapi(f\"{request.method}:{path}\", {\"path\": path})\r\n        \r\n        log_path = Path(__file__).resolve().parent / \"logs\" / \"isapi_debug.log\"\r\n        log_path.parent.mkdir(parents=True, exist_ok=True)\r\n        with open(str(log_path), \"a\", encoding=\"utf-8\") as _f:\r\n            _f.write(f\"[ISAPI ENTRY] method={request.method} path={path}\\n\")\r\n            _f.flush()\r\n        ptz_mgr = _managers.get('ptz_manager')\r\n        if not ptz_mgr:\r\n            return Response(content='PTZManager not initialized', status_code=500)\r\n\r\n        # Get device IP from deviceIdentify header (WASM SDK) or query params\r\n        device_identify = request.headers.get(\"deviceidentify\") or request.headers.get(\"deviceIdentify\")\r\n        device_ip = request.query_params.get(\"device_ip\") or request.query_params.get(\"ip\")\r\n        if not device_ip and device_identify:\r\n            device_ip = device_identify.split(\":\")[0]\r\n            print(f\"[ISAPI] Extracted device IP from deviceIdentify: {device_ip}\")\r\n        if not device_ip:\r\n            devices = ptz_mgr.list_stored_devices()\r\n\n[284 more lines in file. Use offset=301 to continue.]"}],"isError":false,"timestamp":1781362253938}}
