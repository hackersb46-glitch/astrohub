{"type":"message","id":"5c2c1d8a","parentId":"b7f3dda9","timestamp":"2026-06-13T14:50:41.244Z","message":{"role":"toolResult","toolCallId":"call_6dd52258046040ba95fb9b71","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nAstroHub v2.0 - чЛфИшЗЏчБшх\r\n\r\nцДх M1-M11 цццЈЁхшЗЏчБхА /api/v1/ фИ:\r\n- /api/v1/health            - хЈхБхЅхКЗцЃцЅ\r\n- /api/v1/discovery/sadp    - SADP шЎОхЄхчА\r\n- /api/v1/devices/*         - шЎОхЄчЎЁчяМчхЎяМ\r\n- /api/v1/ptz/*             - PTZ цЇхЖяМчхЎяМ\r\n- /api/v1/streams/*         - цЕцхЁ\r\n- /api/v1/calibration/*     - ц Ёх\r\n- /api/v1/ascom/*           - ASCOM шЎОхЄ\r\n- /api/v1/settings          - чГЛчЛшЎОчНЎ\r\n\r\nAuthor: щчхМ @хцЙхЄЉц\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel\r\nfrom fastapi import APIRouter, FastAPI, Query\r\nfrom fastapi.responses import JSONResponse\r\n\r\n# v6.40: цфНцЅхП\r\nfrom src.operation_logger import log_api, log_web, log_error, log_info\r\n\r\n# ================================================================ #\r\n#  ц ИхПцЈЁххЏМхЅ\r\n# ================================================================ #\r\n\r\nfrom src.core.ptz_manager import PTZManager\r\nfrom src.core.device_manager import DeviceManager\r\nfrom src.core.stream_manager import StreamManager\r\nfrom src.core.calibration_manager import CalibrationManager\r\nfrom src.core.auth import AuthManager\r\nfrom src.core.ws_manager import WebSocketManager\r\nfrom src.core.ascom_manager import ASCOMManager\r\nfrom src.core.orchestrator import Orchestrator\r\nfrom src.core.health_monitor import HealthMonitor\r\n\r\n\r\n# ================================================================ #\r\n#  шЗЏчБхчМхЎфЙ\r\n# ================================================================ #\r\n\r\nAPI_V1_PREFIX = \"/api/v1\"\r\n\r\n# фИЛ API шЗЏчБхЈ\r\napi_router = APIRouter(prefix=API_V1_PREFIX, tags=[\"API v1\"])\r\n\r\n# хЅхКЗцЃцЅшЗЏчБхЈ\r\nhealth_router = APIRouter(prefix=\"/api/v1\", tags=[\"System\"])\r\n\r\n\r\n# ================================================================ #\r\n#  v6.40: цфНцЅхП API\r\n# ================================================================ #\r\n\r\nclass OperationLogRequest(BaseModel):\r\n    \"\"\"цфНцЅхПшЏЗцБ.\"\"\"\r\n    level: str = \"INFO\"\r\n    module: str = \"web\"\r\n    action: str = \"\"\r\n    detail: str | dict = \"\"\r\n\r\n@health_router.post(\"/log/operation\", summary=\"шЎАхНцфНцЅхП\")\r\nasync def log_operation_api(req: OperationLogRequest) -> dict:\r\n    \"\"\"хчЋЏхщцфНцЅхПхАхчЋЏ.\"\"\"\r\n    from src.operation_logger import log_operation\r\n    log_operation(req.level, req.module, req.action, req.detail)\r\n    return {\"success\": True}\r\n\r\n\r\n# ================================================================ #\r\n#  Pydantic шЏЗцБцЈЁх\r\n# ================================================================ #\r\n\r\nclass AddDeviceRequest(BaseModel):\r\n    \"\"\"цхЈцЗЛх шЎОхЄшЏЗцБу\"\"\"\r\n    ip: str\r\n    port: int = 80\r\n    username: str = \"admin\"\r\n    password: str\r\n    name: str = \"\"\r\n    model: str = \"\"\r\n    mac: str = \"\"\r\n\r\nclass ConnectDeviceRequest(BaseModel):\r\n    \"\"\"шПцЅшЎОхЄшЏЗцБу\"\"\"\r\n    username: str = \"admin\"\r\n    password: str\r\n    port: int = 80\r\n\r\nclass ModifyNetworkRequest(BaseModel):\r\n    \"\"\"фПЎцЙчНчЛщчНЎшЏЗцБу\"\"\"\r\n    ip: str\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str\r\n\r\nclass SADPIpModifyRequest(BaseModel):\r\n    \"\"\"SADP IP фПЎцЙшЏЗцБ (хЋхОЊчЏщЊшЏ)у\"\"\"\r\n    mac: str\r\n    password: str\r\n    new_ip: str\r\n    original_ip: str = \"\"\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str = \"\"\r\n\r\nclass SystemInfoRequest(BaseModel):\r\n    \"\"\"чГЛчЛфПЁцЏшЏЗцБяМхЏщччЛхЎ ipяМу\"\"\"\r\n    nic_index: int | None = None\r\n\r\nclass PTZMoveRequest(BaseModel):\r\n    \"\"\"PTZ чЇЛхЈшЏЗцБу\"\"\"\r\n    direction: str\r\n    speed: int = 50\r\n\r\nclass PTZAbsoluteRequest(BaseModel):\r\n    \"\"\"PTZ чЛхЏЙчЇЛхЈшЏЗцБу\"\"\"\r\n    pan: float\r\n    tilt: float\r\n    zoom: float | None = None\r\n    speed: int = 50\r\n\r\nclass PTZPresetRequest(BaseModel):\r\n    \"\"\"PTZ щЂчНЎфНшЏЗцБу\"\"\"\r\n    preset_id: int\r\n\r\nclass SADPScanRequest(BaseModel):\r\n    \"\"\"SADP хчАшЏЗцБу\"\"\"\r\n    bind_ip: str = \"0.0.0.0\"\r\n\r\nclass RemoveDeviceRequest(BaseModel):\r\n    \"\"\"чЇЛщЄшЎОхЄшЏЗцБу\"\"\"\r\n    ip: str = \"\"\r\n    mac: str = \"\"\r\n\r\n\r\nclass PTZCaptureRequest(BaseModel):\r\n    \"\"\"PTZ цЊхОшЏЗцБу\"\"\"\r\n    stream_url: str = \"\"\r\n    stream_id: str = \"\"\r\n\r\n\r\nclass PTZRecordRequest(BaseModel):\r\n    \"\"\"PTZ хНхшЏЗцБу\"\"\"\r\n    target_name: str = \"\"\r\n\r\n\r\nclass TelescopeSlewRequest(BaseModel):\r\n    \"\"\"цшПщ Slew шЏЗцБу\"\"\"\r\n    ra: float\r\n    dec: float\r\n\r\n\r\nclass TelescopeTrackingRequest(BaseModel):\r\n    \"\"\"цшПщшЗшИЊцЈЁхМшЏЗцБу\"\"\"\r\n    mode: str  # trackSidereal / trackLunar / trackSolar / trackOff\r\n\r\n\r\n# ================================================================ #\r\n#  цфНцЅхП (цхЄ 10 цЁ)\r\n# ================================================================ #\r\n\r\noperations_log: list[dict[str, str]] = []\r\nMAX_LOG_ENTRIES = 10\r\n\r\n\r\ndef operation_log(action: str, details: str) -> None:\r\n    \"\"\"шПНх цфНхАцЅхПхшЁЈяМчЏхНЂчМхВхКяМцхЄ MAX_LOG_ENTRIES цЁяМу\"\"\"\r\n    entry = {\r\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\r\n        \"action\": action,\r\n        \"details\": details,\r\n    }\r\n    operations_log.append(entry)\r\n    if len(operations_log) > MAX_LOG_ENTRIES:\r\n        operations_log.pop(0)\r\n\r\n\r\n# ================================================================ #\r\n#  чЎЁчхЈцГЈхЅ\r\n# ================================================================ #\r\n\r\n_managers: dict[str, Any] = {}\r\n\r\n\r\ndef set_managers(**kwargs: Any) -> None:\r\n    \"\"\"цГЈхЅццчЎЁчхЈхЎфОу\"\"\"\r\n    _managers.update(kwargs)\r\n\r\n\r\ndef _resolve_device_id_to_ip(mgr: \"PTZManager\", device_id: str) -> str | None:\r\n    \"\"\"шЇЃц device_id фИКхЎщ IP хАху\r\n\r\n    device_id хЏшНцЏ IP хАхц MAC хАху\r\n    - хІццЏ IP: чДцЅшПх\r\n\n[3010 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1781362241244}}
