\n<IrcutFilterType opt=\"day,night,auto,schedule\">auto</IrcutFilterType>\r\n\r\n<nightToDayFilterLevel opt=\"1,2,3,4,5,6,7\">4</nightToDayFilterLevel>\r\n\r\n<Schedule>\r\n\r\n<scheduleType opt=\"day,night\">day</scheduleType>\r\n\r\n<TimeRange>\r\n\r\n<beginTime>07:00:00</beginTime>\r\n\r\n<endTime>18:00:00</endTime>\r\n\r\n</TimeRange>\r\n\r\n</Schedule>\r\n\r\n</IrcutFilter>\r\n\r\n<WhiteBalance>\r\n\r\n<WhiteBalanceStyle opt=\"manual,locked,\r\n\r\n/ISAPI/Image/channels/1/DSS/capabilities: 403\r\n\r\n/ISAPI/Image/channels/1/DSS?format=json: 403","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783244539680}}
