{"type":"message","id":"9eae2340","parentId":"46f46ef3","timestamp":"2026-07-04T23:23:01.310Z","message":{"role":"toolResult","toolCallId":"call_a77710b01adf446da1531dec","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nM12 Unified Integration v1.0 - 全局常量定义\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nfrom enum import Enum\r\nfrom pathlib import Path\r\n\r\n# === 版本与作者 ===\r\nVERSION = \"v8.39\"\r\nVERSION_NUM = \"8.13\"\r\nAUTHOR = \"雅痞张@南方天文\"\r\nPROJECT_NAME = \"MAIN\"\r\n\r\n# === 路径 ===\r\nBASE_DIR = Path(__file__).resolve().parent\r\n\r\n# === M1-M11 模块初始化顺序 ===\r\n# v7.12: 精简后保留的模块\r\n# 注意: device 模块已整合到 src/core/device_manager.py\r\nMODULE_ORDER = [\r\n    \"ptz\",\r\n    \"stream\",\r\n    \"calibration\",\r\n    \"database\",\r\n    \"websocket\",\r\n    \"ascom\",\r\n]\r\n\r\n\r\n# === 健康状态枚举 ===\r\nclass HealthStatus(Enum):\r\n    \"\"\"模块健康状态。\"\"\"\r\n    HEALTHY = \"healthy\"\r\n    DEGRADED = \"degraded\"\r\n    UNHEALTHY = \"unhealthy\"\r\n    UNKNOWN = \"unknown\"\r\n"}],"isError":false,"timestamp":1783207381310}}
