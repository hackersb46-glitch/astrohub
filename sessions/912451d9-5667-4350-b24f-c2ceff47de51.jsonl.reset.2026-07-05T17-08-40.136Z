{"type":"message","id":"bb5ef62e","parentId":"09aea6a6","timestamp":"2026-07-05T13:30:42.785Z","message":{"role":"toolResult","toolCallId":"functions.read:192","toolName":"read","content":[{"type":"text","text":"    // v7.54: 支持多种曝光模式\r\n    var mode = exposureMode.value;\r\n    var shutterEnabled = (mode === 'manual' || mode === 'ShutterFirst');\r\n    var irisEnabled = (mode === 'manual' || mode === 'IrisFirst');\r\n    var gainEnabled = (mode === 'manual' || mode === 'ShutterFirst' || mode === 'IrisFirst');\r\n    shutterSelect.disabled = !shutterEnabled;\r\n    irisSelect.disabled = !irisEnabled;\r\n    if (gainSlider) gainSlider.disabled = !gainEnabled;\r\n\r\n    // v8.40: 自动模式时隐藏快门/光圈/增益\r\n    var shutterRow = shutterSelect.parentElement.parentElement;\r\n    var gainRow = gainSlider ? gainSlider.parentElement : null;\r\n    if (mode === 'auto') {\r\n        shutterRow.style.display = 'none';\r\n        if (gainRow) gainRow.style.display = 'none';\r\n    } else {\r\n        shutterRow.style.display = '';\r\n        if (gainRow) gainRow.style.display = '';\r\n        shutterSelect.style.opacity = shutterEnabled ? '1' : '0.5';\r\n        irisSelect.style.opacity = irisEnabled ? '1' : '0.5';\r\n\n[258 more lines in file. Use offset=1770 to continue.]"}],"isError":false,"timestamp":1783258242783}}
{"type":"message","id":"4b604c32","parentId":"bb5ef62e","timestamp":"2026-07-05T13:30:42.785Z","message":{"role":"toolResult","toolCallId":"functions.read:193","toolName":"read","content":[{"type":"text","text":"    var shutterRow = shutterSelect.parentElement.parentElement;\r\n    var gainRow = gainSlider ? gainSlider.parentElement : null;\r\n    if (mode === 'auto') {\r\n        shutterRow.style.display = 'none';\r\n        if (gainRow) gainRow.style.display = 'none';\r\n    } else {\r\n        shutterRow.style.display = '';\r\n        if (gainRow) gainRow.style.display = '';\r\n        shutterSelect.style.opacity = shutterEnabled ? '1' : '0.5';\r\n        irisSelect.style.opacity = irisEnabled ? '1' : '0.5';\r\n        if (gainSlider) gainSlider.style.opacity = gainEnabled ? '1' : '0.5';\r\n    }\r\n}\r\n\r\n// 设置快门\r\nfunction setShutterSpeed(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '快门: ' + value);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('快门: ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置光圈\r\nfunction setIris(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev || !value) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                var select = document.getElementById('irisLevel');\r\n                var label = select.options[select.selectedIndex].text;\r\n                showToast('success', '光圈: ' + label);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('光圈: ' + label, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// v7.03: 设置增益\r\nfunction setGain(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/gain', { level: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '增益: ' + value);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('增益: ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// v7.03: 加载增益\r\nfunction loadGain(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/gain').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var g = r.data;\r\n            deviceImageParams.gain = g;\r\n\r\n            var slider = document.getElementById('gainLevel');\r\n            var valEl = document.getElementById('gainVal');\r\n\r\n            if (slider) {\r\n                slider.min = 0;\r\n                slider.max = g.limit || 100;\r\n                slider.value = g.current_level || 0;\r\n            }\r\n            if (valEl) valEl.textContent = g.current_level || 0;\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Gain] Load failed:', e);\r\n    });\r\n}\r\n\r\n// v6.02: PTZ OSD 开关\r\nfunction togglePtzOsdSwitch(enabled) {\r\n    ptzOsdEnabled = enabled;\r\n\n[188 more lines in file. Use offset=1840 to continue.]"}],"isError":false,"timestamp":1783258242783}}
{"type":"message","id":"7c455b39","parentId":"4b604c32","timestamp":"2026-07-05T13:30:42.786Z","message":{"role":"toolResult","toolCallId":"functions.read:194","toolName":"read","content":[{"type":"text","text":"            if (valEl) valEl.textContent = g.current_level || 0;\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Gain] Load failed:', e);\r\n    });\r\n}\r\n\r\n// v6.02: PTZ OSD 开关\r\nfunction togglePtzOsdSwitch(enabled) {\r\n    ptzOsdEnabled = enabled;\r\n    togglePtzOsd(enabled);\r\n}\r\n\r\n// v6.02: Info OSD 开关\r\nfunction toggleInfoOsdSwitch(enabled) {\r\n    infoOsdEnabled = enabled;\r\n    toggleInfoOsd(enabled);\r\n}\r\n\r\n// 切换 PTZ OSD\r\nfunction togglePtzOsd(enabled) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    updatePtzOsdButtons(enabled);\r\n    localStorage.setItem('osd_ptz_' + dev, enabled ? '1' : '0');\r\n\r\n    apiPost('/api/v1/ptz/' + dev + '/osd/ptz', { enabled: enabled })\r\n        .then(function(r) {\r\n            if (r && r.success) showToast('success', 'PTZ OSD: ' + (enabled ? '显示' : '关闭'));\r\n        });\r\n}\r\n\r\n// 切换 Info OSD\r\nfunction toggleInfoOsd(enabled) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    updateInfoOsdButtons(enabled);\r\n    localStorage.setItem('osd_info_' + dev, enabled ? '1' : '0');\r\n\r\n    apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled })\r\n        .then(function(r) {\r\n            if (r && r.success) showToast('success', 'Info OSD: ' + (enabled ? '显示' : '关闭'));\r\n        });\r\n}\r\n\r\n// v5.42: 开关式 OSD 切换\r\nvar ptzOsdEnabled = false;\r\nvar infoOsdEnabled = false;\r\n\r\nfunction togglePtzOsdToggle() {\r\n    ptzOsdEnabled = !ptzOsdEnabled;\r\n    var btn = document.getElementById('btnPtzOsd');\r\n    if (btn) {\r\n        btn.textContent = ptzOsdEnabled ? '显示' : '关闭';\r\n        btn.className = 'btn btn-sm ' + (ptzOsdEnabled ? 'btn-primary' : 'btn-secondary');\r\n    }\r\n    togglePtzOsd(ptzOsdEnabled);\r\n}\r\n\r\nfunction toggleInfoOsdToggle() {\r\n    infoOsdEnabled = !infoOsdEnabled;\r\n    var btn = document.getElementById('btnInfoOsd');\r\n    if (btn) {\r\n        btn.textContent = infoOsdEnabled ? '显示' : '关闭';\r\n        btn.className = 'btn btn-sm ' + (infoOsdEnabled ? 'btn-primary' : 'btn-secondary');\r\n    }\r\n    toggleInfoOsd(infoOsdEnabled);\r\n}\r\n\r\n// 更新按钮状态\r\nfunction updatePtzOsdButtons(enabled) {\r\n    // v7.01: 更新 toggle switch\r\n    var switchEl = document.getElementById('ptzOsdSwitch');\r\n    if (switchEl) {\r\n        switchEl.checked = enabled;\r\n    }\r\n    ptzOsdEnabled = enabled;\r\n}\r\n\r\nfunction updateInfoOsdButtons(enabled) {\r\n    // v7.01: 更新 toggle switch\r\n    var switchEl = document.getElementById('infoOsdSwitch');\r\n    if (switchEl) {\r\n        switchEl.checked = enabled;\r\n    }\r\n    infoOsdEnabled = enabled;\r\n}\r\n\r\n// ==================== v7.0: PTZ 坐标 + 图像参数实时刷新 ====================\r\nvar _ptzImagePollInterval = null;\r\n\r\nfunction startPtzImagePoll() {\r\n    if (_ptzImagePollInterval) return; // 已在运行\r\n\r\n    _ptzImagePollInterval = setInterval(function() {\r\n        if (!window.connectedDevice || !window.connectedDevice.ip) return;\r\n\r\n        var dev = window.connectedDevice.ip;\r\n\n[98 more lines in file. Use offset=1930 to continue.]"}],"isError":false,"timestamp":1783258242783}}
