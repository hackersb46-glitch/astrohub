ext or \\\"\\\").strip()\\n            elif tag in (\\\"maxShutterLevelLimit\\\", \\\"MaxShutterLevelLimit\\\"):\\n                max_limit = (elem.text or \\\"\\\").strip()\\n\\n        # 判断是否支持慢快门：minLimit 和 maxLimit 都存在且不同\\n        supported = bool(min_limit and max_limit and min_limit != max_limit)\\n\\n        # 计算当前倍率\\n        ratio = 1.0\\n        if supported and shutter_level and min_limit:\\n            from src.controlpanel.region_base import _parse_shutter_level\\n            base_time = _parse_shutter_level(shutter_level)\\n            min_time = _parse_shutter_level(min_limit)\\n            if base_time > 0 and min_time > 0:\\n                ratio = round(base_time / min_time, 2)\\n\\n        return {\\n            \\\"success\\\": True,\\n            \\\"data\\\": {\\n                \\\"supported\\\": supported,\\n                \\\"enabled\\\": ratio > 1.0,\\n                \\\"ratio\\\": ratio,\\n                \\\"shutter_level\\\": shutter_level,\\n                \\\"min_limit\\\": min_limit,\\n                \\\"max_limit\\\": max_limit\\n            }\\n        }\\n    except Exception as e:\\n        return {\\\"success\\\": False, \\\"message\\\": f\\\"获取慢快门异常: {e}\\\"}\\n\\n\\n@api_router.put(\\\"/ptz/{device_id}/image/slow-shutter\\\", summary=\\\"设置慢快门\\\", tags=[\\\"Image\\\"])\\nasync def set_slow_shutter(device_id: str, body: dict) -> dict:\\n    \\\"\\\"\\\"设置慢快门倍率。\\n\\n    请求体:\\n        {\\\"ratio\\\": 0}  → 关闭（恢复默认）\\n        {\\\"ratio\\\": 1.25} → 1.25倍率\\n        {\\\"ratio\\\": 2} → 2倍率\\n        {\\\"ratio\\\": 4} → 4倍率\\n        {\\\"ratio\\\": 8} → 8倍率\\n    \\\"\\\"\\\"\\n    import re\\n    mgr: PTZDeviceController | None = _managers.get(\\\"ptz_controller\\\")\\n    if not mgr:\\n        return {\\\"success\\\": False, \\\"message\\\": \\\"PTZDeviceController未初始化\\\"}\\n\\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\\n    if not target_ip:\\n        return {\\\"success\\\": False, \\\"message\\\": f\