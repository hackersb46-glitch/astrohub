{"type":"message","id":"50c372fd","parentId":"4d61d93f","timestamp":"2026-07-05T15:29:07.533Z","message":{"role":"toolResult","toolCallId":"toolu_6848c5e164ad4fc8b717b3a5","toolName":"read","content":[{"type":"text","text":"\"\"\"\nAstroHub v2.0 - 设备数据路径管理\n\nv6.19 更新:\n- 删除 config_paths 依赖，统一路径定义\n- 统一路径：data/devices/{mac}/\n- 带时间戳文件：data/devices/{mac}/{test_type}_{timestamp}.json\n- 读取规则：永远读最新记录\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\n# ================================================================ #\n#  统一路径定义 (v6.19)\n# ================================================================ #\n\ndef _get_app_dir() -> Path:\n    \"\"\"获取应用程序根目录。\"\"\"\n    import sys\n    if getattr(sys, 'frozen', False):\n        return Path(sys.executable).parent\n    return Path(__file__).resolve().parent.parent.parent\n\n\n[133 more lines in file. Use offset=31 to continue.]"}],"isError":false,"timestamp":1783265347532}}
{"type":"message","id":"26b24c79","parentId":"50c372fd","timestamp":"2026-07-05T15:29:07.533Z","message":{"role":"toolResult","toolCallId":"toolu_ece3dc3161e64dfea9f62a93","toolName":"read","content":[{"type":"text","text":"\"\"\"\nAstroHub v2.0 - 设备数据路径管理\n\nv6.19 更新:\n- 删除 config_paths 依赖，统一路径定义\n- 统一路径：data/devices/{mac}/\n- 带时间戳文件：data/devices/{mac}/{test_type}_{timestamp}.json\n- 读取规则：永远读最新记录\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\n# ================================================================ #\n#  统一路径定义 (v6.19)\n# ================================================================ #\n\ndef _get_app_dir() -> Path:\n    \"\"\"获取应用程序根目录。\"\"\"\n    import sys\n    if getattr(sys, 'frozen', False):\n        return Path(sys.executable).parent\n    return Path(__file__).resolve().parent.parent.parent\n\n\n[133 more lines in file. Use offset=31 to continue.]"}],"isError":false,"timestamp":1783265347532}}
