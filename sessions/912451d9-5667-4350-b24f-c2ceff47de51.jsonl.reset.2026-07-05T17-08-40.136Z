{"type":"message","id":"5a019c38","parentId":"7a76953f","timestamp":"2026-07-05T17:04:23.864Z","message":{"role":"toolResult","toolCallId":"toolu_9eea4a36ef0049eeb0db3aa6","toolName":"exec","content":[{"type":"text","text":"=== WB/Focus search function ===\r\nfunction _finishRegion() {\r\n        var overlay = document.getElementById('regionOverlay');\r\n        var box = document.getElementById('regionBox');\r\n        var dev = window.connectedDevice;\r\n        if (!dev || !dev.ip) { showToast('error', 'δ�����豸'); _resetRegionUI(); return; }\r\n\r\n        var ow = overlay.offsetWidth, oh = overlay.offsetHeight;\r\n        var sx = parseInt(box.style.left) / ow;\r\n        var sy = parseInt(box.style.top) / oh;\r\n        var sw = parseInt(box.style.width) / ow;\r\n        var sh = parseInt(box.style.height) / oh;\r\n        if (sw < 0.01 || sh < 0.01) { showToast('warning', '��ѡ����̫С'); _resetRegionUI(); return; }\r\n\r\n        var mode = _regionMode;\r\n        \r\n        // v8.39: ����ѡ���� localStorage����ƽ��ͶԽ��ֱ𱣴棩\r\n        var regionKey = 'region_' + mode;\r\n        localStorage.setItem(regionKey, JSON.stringify({ x: sx, y: sy, w: sw, h: sh }));\r\n        \r\n        var endpoint = mode === 'whitebalance' ? '/api/v1/vision/whitebalance-search'\r\n                                               : '/api/v1/vision/focus-search';\r\n        var label = mode === 'whitebalance' ? '��ƽ��' : '�Խ�';\r\n\r\n        _resetRegionUI();\r\n        showToast('info', label + '������...');\r\n        operationLog('���� ' + label + '������ʼ ����', 'info');\r\n        \r\n        // v8.41: ��������ʱ����ֹͣ��ť\r\n        var stopBtnId = mode === 'whitebalance' ? 'btnWbLocalStop' : 'btnFocusLocalStop';\r\n        var stopBtn = document.getElementById(stopBtnId);\r\n        if (stopBtn) { stopBtn.disabled = false; stopBtn.style.opacity = '1'; }\r\n\r\n        // SSE ��ʽ����\r\n        var body = JSON.stringify({ x: sx, y: sy, w: sw, h: sh });\r\n        fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })\r\n            .then(function(resp) {\r\n                if (!resp.ok) throw new Error('HTTP ' + resp.status);\r\n                var reader = resp.body.getReader();\r\n                var decoder = new TextDecoder();\r\n                var buf = '';\r\n                function pump() {\r\n                    return reader.read().then(function(r) {\r\n                        if (r.done) return;\r\n                        buf += decoder.decode(r.value, { stream: true });\r\n                        // �� \\n\\n �ָ��¼�\r\n                        var parts = buf.split('\\n\\n');\r\n                        buf = parts.pop();  // ���һ�ο��ܲ�����\r\n                        for (var i = 0; i < parts.length; i++) {\r\n                            var line = parts[i];\r\n                            if (!line.startsWith('data: ')) continue;\r\n                            try {\r\n                                var ev = JSON.parse(line.slice(6));\r\n                                if (ev.type === 'start') {\r\n                                    operationLog(label + '��ʼ, ' + ev.crop, 'info');\r\n                                } else if (ev.type === 'wb') {\r\n                                    operationLog('���� #' + ev.step + ': ' + ev.stage\r\n                                        + ' R=' + ev.red_gain + ' B=' + ev.blue_gain\r\n                                        + ' �� R=' + ev.r_avg + ' G=' + ev.g_avg + ' B=' + ev.b_avg\r\n                                        + ' (��=' + ev.delta + ')', 'debug');\r\n                                } else if (ev.type === 'focus') {\r\n                                    operationLog('�Խ� #' + ev.step + ': ' + ev.stage\r\n                                        + ' ' + ev.action + ' ����=' + ev.contrast\r\n                                        + ' (' + ev.duration + 's) ' + ev.message, 'debug');\r\n                                } else if (ev.type === 'done') {\r\n                                    if (ev.final_red !== undefined) {\r\n                                        showToast('success', label + '��� R=' + ev.final_red + ' B=' + ev.final_blue);\r\n                                        operationLog('���� ' + label + '���: R=' + ev.final_red + ' B=' + ev.final_blue + ' (' + ev.total_steps + '��) ����', 'success');\r\n                                        // ˢ������̨��ƽ�⻬����\r\n                                        var wbRed = document.getElementById('wbRed');\r\n                                        var wbBlue = document.getElementById('wbBlue');\r\n                                        var wbRedVal = document.getElementById('wbRedVal');\r\n                                        var wbBlueVal = document.getElementById('wbBlueVal');\r\n                                        if (wbRed) { wbRed.value = ev.final_red; if (wbRedVal) wbRedVal.textContent = ev.final_red; }\r\n                                        if (wbBlue) { wbBlue.value = ev.final_blue; if (wbBlueVal) wbBlueVal.textContent = ev.final_blue; }\r\n                                    } else {\r\n                                        var rollMsg = ev.rollback_steps ? ' (�ع�' + ev.rollback_steps + '��)' : '';\r\n                                        showToast('success', label + '��� ����=' + ev.final_contrast + rollMsg);\r\n                                        operationLog('���� ' + label + '���: ����=' + ev.final_contrast + rollMsg + ' (' + ev.total_steps + '��) ����', 'success');\r\n                                    }\r\n                                    // v8.41: ������ɺ�ָ�ֹͣ��ťΪ��ɫ\r\n                                    if (stopBtn) { stopBtn.disabled = true; stopBtn.style.opacity = '0.5'; }\r\n                                    var toggleId = mode === 'whitebalance' ? 'wbTimerToggle' : 'focusTimerToggle'; var toggleEl = document.getElementById(toggleId); if (toggleEl) { toggleEl.checked = false; }\r\n                                } else if (ev.type === 'cleanup') {\r\n                                    operationLog('�������', 'info');\r\n                                } else if (ev.type === 'error') {\r\n                                    operationLog(label + 'ʧ��: ' + ev.message, 'error');\r\n                                    showToast('error', label + 'ʧ��');\r\n                                    // v8.41: ����ʧ�ܺ�ָ�ֹͣ��ťΪ��ɫ\r\n                                    if (stopBtn) { stopBtn.disabled = true; stopBtn.style.opacity = '0.5'; }\r\n                                    var toggleId = mode === 'whitebalance' ? 'wbTimerToggle' : 'focusTimerToggle'; var toggleEl = document.getElementById(toggleId); if (toggleEl) { toggleEl.checked = false; }\r\n                                } else if (ev.type === 'interrupt') {\r\n                                    // v8.41: �û�ֹͣ\r\n                                    operationLog(label + ': ' + ev.message, 'warning');\r\n                                    showToast('warning', label + '��ֹͣ');\r\n                                    if (ev.final_red !== undefined) {\r\n                                        var wbRed2 = document.getElementById('wbRed');\r\n                                        var wbBlue2 = document.getElementById('wbBlue');\r\n                                        var wbRedVal2 = document.getElementById('wbRedVal');\r\n                                        var wbBlueVal2 = document.getElementById('wbBlueVal');\r\n                                        if (wbRed2) { wbRed2.value = ev.final_red; if (wbRedVal2) wbRedVal2.textContent = ev.final_red; }\r\n                                        if (wbBlue2) { wbBlue2.value = ev.final_blue; if (wbBlueVal2) wbBlueVal2.textContent = ev.final_blue; }\r\n                                    }\r\n                                    // �ָ�ֹͣ��ťΪ��ɫ\r\n                                    if (stopBtn) { stopBtn.disabled = true; stopBtn.style.opacity = '0.5'; }\r\n                                    var toggleId = mode === 'whitebalance' ? 'wbTimerToggle' : 'focusTimerToggle'; var toggleEl = document.getElementById(toggleId); if (toggleEl) { toggleEl.checked = false; }\r\n                                }\r\n                            } catch(e) { /* �����𻵵� JSON */ }\r\n                        }\r\n                        return pump();\r\n                    });\r\n                }\r\n                return pump();\r\n            })\r\n            .catch(function(e) {\r\n                operationLog(label + '�쳣: ' + e.message, 'error');\r\n                showToast('error', '�쳣: ' + e.message);\r\n                // v8.41: �ָ�ֹͣ��ťΪ��ɫ\r\n                if (stopBtn) { stopBtn.disabled = true; stopBtn.style.opacity = '0.5'; }\r\n                var toggleId = mode === 'whitebalance' ? 'wbTimerToggle' : 'focusTimerToggle'; var toggleEl = document.getElementById(toggleId); if (toggleEl) { toggleEl.checked = false; }\r\n            });\r\n    }"}],"details":{"status":"completed","exitCode":0,"durationMs":444,"aggregated":"=== WB/Focus search function ===\r\nfunction _finishRegion() {\r\n        var overlay = document.getElementById('regionOverlay');\r\n        var box = document.getElementById('regionBox');\r\n        var dev = window.connectedDevice;\r\n        if (!dev || !dev.ip) { showToast('error', 'δ�����豸'); _resetRegionUI(); return; }\r\n\r\n        var ow = overlay.offsetWidth, oh = overlay.offsetHeight;\r\n        var sx = parseInt(box.style.left) / ow;\r\n        var sy = parseInt(box.style.top) / oh;\r\n        var sw = parseInt(box.style.width) / ow;\r\n        var sh = parseInt(box.style.height) / oh;\r\n        if (sw < 0.01 || sh < 0.01) { showToast('warning', '��ѡ����̫С'); _resetRegionUI(); return; }\r\n\r\n        var mode = _regionMode;\r\n        \r\n        // v8.39: ����ѡ���� localStorage����ƽ��ͶԽ��ֱ𱣴棩\r\n        var regionKey = 'region_' + mode;\r\n        localStorage.setItem(regionKey, JSON.stringify({ x: sx