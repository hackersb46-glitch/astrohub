{"type":"message","id":"b7d8ead5","parentId":"ebcf5c86","timestamp":"2026-07-05T13:30:42.783Z","message":{"role":"toolResult","toolCallId":"functions.read:180","toolName":"read","content":[{"type":"text","text":"        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', label + ': ' + value);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog(label + ': ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// v8.44: 慢快门\r\nfunction loadSlowShutter(deviceIp) {\r\n    var sel = document.getElementById('slowShutterSelect');\r\n    if (!sel) return;\r\n    \r\n    // v8.45: 从function.json读取DSS支持倍率\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.slow_shutter) {\r\n        sel.disabled = true;\r\n        sel.innerHTML = '<option value=\"\">设备不支持</option>';\r\n        return;\r\n    }\r\n    \r\n    var dss = deviceFunctionData.functions.slow_shutter;\r\n    if (!dss.supported) {\r\n        sel.disabled = true;\r\n        sel.innerHTML = '<option value=\"\">设备不支持</option>';\r\n        return;\r\n    }\r\n    \r\n    sel.disabled = false;\r\n    sel.innerHTML = '';\r\n    \r\n\n[458 more lines in file. Use offset=1570 to continue.]"}],"isError":false,"timestamp":1783258242782}}
