_ip = _resolve_device_id_to_ip(mgr, device_id)\n+3747     if not target_ip:\n+3748         return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n+3749 \n+3750     ctrl, err = mgr._get_controller(target_ip)\n+3751     if err:\n+3752         return {\"success\": False, \"message\": err}\n+3753 \n+3754     client = ctrl.client\n+3755     ratio = body.get(\"ratio\", 0)\n+3756 \n+3757     try:\n+3758         resp = client.get(\"/Image/channels/1/Shutter\")\n+3759         if resp.status_code != 200:\n+3760             return {\"success\": False, \"message\": f\"获取当前快门失败: HTTP {resp.status_code}\"}\n+3761 \n+3762         xml_str = resp.xml\n+3763 \n+3764         if ratio == 0:\n+3765             import xml.etree.ElementTree as ET\n+3766             root = ET.fromstring(xml_str)\n+3767             max_limit = None\n+3768             for elem in root.iter():\n+3769                 tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n+3770                 if tag in (\"maxShutterLevelLimit\", \"MaxShutterLevelLimit\"):\n+3771                     max_limit = (elem.text or \"\").strip()\n+3772                     break\n+3773             if max_limit:\n+3774                 xml_str = re.sub(\n+3775                     r'(<minShutterLevelLimit>)[^<]*(</minShutterLevelLimit>)',\n+3776                     f'\\\\g<1>{max_limit}\\\\g<2>',\n+3777                     xml_str\n+3778                 )\n+3779         else:\n+3780             import xml.etree.ElementTree as ET\n+3781             from src.controlpanel.region_base import _parse_shutter_level\n+3782             root = ET.fromstring(xml_str)\n+3783             shutter_level = None\n+3784             max_limit = None\n+3785             for elem in root.iter():\n+3786                 tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n+3787                 if tag in (\"ShutterLevel\", \"shutterLevel\"):\n+3788                     shutter_level = (elem.text or \"\").strip()\n+3789                 elif tag in (\"maxShutterLevelLimit\", \"MaxShutterLevelLimit\"):\n+3790                     max_limit = (elem.text or \"\").strip()\n+3791 \n+3792             if not shutter_level or not max_limit:\n+3793                 return {\"success\": False, \"message\": \"无法读取快门基准值\"}\n+3794 \n+3795             base_time = _parse_shutter_level(shutter_level)\n+3796             min_time = base_time / ratio\n+3797             if min_time > 0:\n+3798                 min_val = f\"1/{int(1/min_time)}\"\n+3799             else:\n+3800                 min_val = max_limit\n+3801 \n+3802             xml_str = re.sub(\n+3803                 r'(<minShutterLevelLimit>)[^<]*(</minShutterLevelLimit>)',\n+3804                 f'\\\\g<1>{min_val}\\\\g<2>',\n+3805                 xml_str\n+3806             )\n+3807 \n+3808         put_resp = client.put(\"/Image/channels/1/Shutter\", xml_str)\n+3809         if put_resp.status_code == 200:\n+3810             log_info(\"image\", \"slow_shutter\", {\"device\": device_id, \"ratio\": ratio})\n+3811             return {\"success\": True, \"message\": f\"慢快门: {'关闭' if ratio == 0 else f'{ratio}x'}\"}\n+3812         else:\n+3813             return {\"success\": False, \"message\": f\"设置失败: HTTP {put_resp.status_code}\"}\n+3814     except Exception as e:\n+3815         return {\"success\": False, \"message\": f\"设置慢快门异常: {e}\"}\n+3816 \n+3817 \n 3667 @api_router.get(\"/ptz/{device_id}/osd/ptz\", summary=\"获取PTZ OSD状态\", tags=[\"OSD\"])\n 3668 async def get_osd_ptz(device_id: str) -> dict:\n 3669     \"\"\"获取PTZ OSD显示状态。\"\"\"\n 3670     import xml.etree.ElementTree as ET\n      ...","firstChangedLine":3667},"isError":false,"timestamp":1783214611418}}
