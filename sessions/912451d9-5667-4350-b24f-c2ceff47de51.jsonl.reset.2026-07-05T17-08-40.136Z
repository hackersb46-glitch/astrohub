{"type":"message","id":"238bd9a9","parentId":"6883b475","timestamp":"2026-07-05T13:30:42.785Z","message":{"role":"toolResult","toolCallId":"functions.read:188","toolName":"read","content":[{"type":"text","text":"    if (!dev) return;\r\n    apiPut('/api/v1/ptz/' + dev + '/image/slow-shutter', { dss_level: val }).then(function(r) {\r\n        if (r && r.success) {\r\n            showToast('success', r.message);\r\n            if (typeof operationLog === 'function') operationLog('慢快门: ' + r.message, 'success');\r\n        }\r\n    });\r\n}\r\n// v8.43: 三段式开关 - 更新高亮\r\nfunction updateSwitchHighlight(switchId, selectedValue) {\r\n    var switchEl = document.getElementById(switchId);\r\n    if (!switchEl) return;\r\n    var buttons = switchEl.querySelectorAll('.ts-btn');\r\n    buttons.forEach(function(btn) {\r\n        if (btn.dataset.value === selectedValue) {\r\n            btn.classList.add('active');\r\n        } else {\r\n            btn.classList.remove('active');\r\n        }\r\n    });\r\n}\r\n\r\n// v8.43: 设置日夜模式\r\nfunction setDayNightMode(mode) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/filter', { dayNightMode: mode })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '日夜模式: ' + mode);\r\n                if (typeof operationLog === 'function') operationLog('日夜模式: ' + mode, 'success');\r\n                updateSwitchHighlight('dayNightSwitch', mode);\r\n            }\r\n        });\r\n}\r\n\r\n// v8.43: 设置IR滤镜\r\nfunction setIRCutFilter(filter) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/filter', { irCutFilter: filter })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', 'IR滤镜: ' + filter);\r\n                if (typeof operationLog === 'function') operationLog('IR滤镜: ' + filter, 'success');\r\n                updateSwitchHighlight('irCutSwitch', filter);\r\n            }\r\n        });\r\n}\r\n\r\n// v8.43: 加载滤镜状态\r\nfunction loadFilterStatus(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/filter').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            updateSwitchHighlight('dayNightSwitch', r.data.dayNightMode);\r\n            updateSwitchHighlight('irCutSwitch', r.data.irCutFilter);\r\n        }\r\n    });\r\n}\r\n\r\n\n[368 more lines in file. Use offset=1660 to continue.]"}],"isError":false,"timestamp":1783258242782}}
{"type":"message","id":"f240d892","parentId":"238bd9a9","timestamp":"2026-07-05T13:30:42.785Z","message":{"role":"toolResult","toolCallId":"functions.read:189","toolName":"read","content":[{"type":"text","text":"                if (typeof operationLog === 'function') operationLog('日夜模式: ' + mode, 'success');\r\n                updateSwitchHighlight('dayNightSwitch', mode);\r\n            }\r\n        });\r\n}\r\n\r\n// v8.43: 设置IR滤镜\r\nfunction setIRCutFilter(filter) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/filter', { irCutFilter: filter })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', 'IR滤镜: ' + filter);\r\n                if (typeof operationLog === 'function') operationLog('IR滤镜: ' + filter, 'success');\r\n                updateSwitchHighlight('irCutSwitch', filter);\r\n            }\r\n        });\r\n}\r\n\r\n// v8.43: 加载滤镜状态\r\nfunction loadFilterStatus(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/filter').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            updateSwitchHighlight('dayNightSwitch', r.data.dayNightMode);\r\n            updateSwitchHighlight('irCutSwitch', r.data.irCutFilter);\r\n        }\r\n    });\r\n}\r\n\r\n// 加载曝光模式\r\nfunction loadExposure(deviceIp) {\r\n    // v7.54: 从 function.json 加载曝光模式选项\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.exposure_mode) {\r\n        console.warn('[Exposure] No function.json data available');\r\n        return;\r\n    }\r\n\r\n    var exposureValues = deviceFunctionData.functions.exposure_mode.opt_values;\r\n    if (!exposureValues || !Array.isArray(exposureValues) || exposureValues.length === 0) {\r\n        console.warn('[Exposure] exposure_mode not supported');\r\n        var select = document.getElementById('exposureMode');\r\n        if (select) {\r\n            select.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            select.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n\r\n    // 填充选项\r\n    var select = document.getElementById('exposureMode');\r\n    if (select) {\r\n        select.innerHTML = '';\r\n        select.disabled = false;\r\n\r\n        exposureValues.forEach(function(p) {\r\n            var opt = document.createElement('option');\r\n            opt.value = p;\r\n            // 中文标签\r\n            var labelMap = {\r\n                'manual': '手动',\r\n                'auto': '自动',\r\n                'IrisFirst': '光圈优先',\r\n                'ShutterFirst': '快门优先'\r\n            };\r\n            opt.textContent = labelMap[p] || p;\r\n            select.appendChild(opt);\r\n        });\r\n    }\r\n\r\n    // 获取当前值\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            if (select && r.data.mode) {\r\n                select.value = r.data.mode;\r\n                // 更新快门光圈禁用状态\r\n                updateShutterIrisState();\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n\n[318 more lines in file. Use offset=1710 to continue.]"}],"isError":false,"timestamp":1783258242782}}
{"type":"message","id":"a76eab47","parentId":"f240d892","timestamp":"2026-07-05T13:30:42.785Z","message":{"role":"toolResult","toolCallId":"functions.read:190","toolName":"read","content":[{"type":"text","text":"// 加载曝光模式\r\nfunction loadExposure(deviceIp) {\r\n    // v7.54: 从 function.json 加载曝光模式选项\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.exposure_mode) {\r\n        console.warn('[Exposure] No function.json data available');\r\n        return;\r\n    }\r\n\r\n    var exposureValues = deviceFunctionData.functions.exposure_mode.opt_values;\r\n    if (!exposureValues || !Array.isArray(exposureValues) || exposureValues.length === 0) {\r\n        console.warn('[Exposure] exposure_mode not supported');\r\n        var select = document.getElementById('exposureMode');\r\n        if (select) {\r\n            select.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            select.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n\r\n    // 填充选项\r\n    var select = document.getElementById('exposureMode');\r\n    if (select) {\r\n        select.innerHTML = '';\r\n        select.disabled = false;\r\n\r\n        exposureValues.forEach(function(p) {\r\n            var opt = document.createElement('option');\r\n            opt.value = p;\r\n            // 中文标签\r\n            var labelMap = {\r\n                'manual': '手动',\r\n                'auto': '自动',\r\n                'IrisFirst': '光圈优先',\r\n                'ShutterFirst': '快门优先'\r\n            };\r\n            opt.textContent = labelMap[p] || p;\r\n            select.appendChild(opt);\r\n        });\r\n    }\r\n\r\n    // 获取当前值\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            if (select && r.data.mode) {\r\n                select.value = r.data.mode;\r\n                // 更新快门光圈禁用状态\r\n                updateShutterIrisState();\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Exposure] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 设置曝光模式\r\nfunction setExposureMode(mode) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    // v7.54: 支持多种曝光模式的中文显示\r\n    var labelMap = {\r\n        'manual': '手动',\r\n        'auto': '自动',\r\n        'IrisFirst': '光圈优先',\r\n        'ShutterFirst': '快门优先'\r\n    };\r\n    apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: mode })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '曝光模式: ' + (labelMap[mode] || mode));\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('曝光: ' + (labelMap[mode] || mode), 'success');\r\n            }\r\n        });\r\n    // v5.47: 更新快门光圈禁用状态\r\n    updateShutterIrisState();\r\n}\r\n\r\n// v5.47: 更新快门光圈禁用状态\r\nfunction updateShutterIrisState() {\r\n    // v7.30: 检查设备是否连接\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        // 设备未连接,所有控件保持禁用\r\n        return;\r\n    }\r\n\r\n    var exposureMode = document.getElementById('exposureMode');\r\n    var shutterSelect = document.getElementById('shutterSpeed');\r\n    var irisSelect = document.getElementById('irisLevel');\r\n    var gainSlider = document.getElementById('gainLevel');\r\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\r\n\r\n    // v7.54: 支持多种曝光模式\r\n    var mode = exposureMode.value;\r\n    var shutterEnabled = (mode === 'manual' || mode === 'ShutterFirst');\r\n    var irisEnabled = (mode === 'manual' || mode === 'IrisFirst');\r\n    var gainEnabled = (mode === 'manual' || mode === 'ShutterFirst' || mode === 'IrisFirst');\r\n    shutterSelect.disabled = !shutterEnabled;\r\n    irisSelect.disabled = !irisEnabled;\r\n    if (gainSlider) gainSlider.disabled = !gainEnabled;\r\n\r\n    // v8.40: 自动模式时隐藏快门/光圈/增益\r\n\n[268 more lines in file. Use offset=1760 to continue.]"}],"isError":false,"timestamp":1783258242783}}
