{"type":"message","id":"126b0224","parentId":"60e78159","timestamp":"2026-07-05T12:59:18.656Z","message":{"role":"toolResult","toolCallId":"toolu_759230ffc2fb4b7ea2c949f0","toolName":"read","content":[{"type":"text","text":"function onWbModeChange(mode) {\r\n    var manualControls = document.getElementById('wbManualControls');\r\n    var localControls = document.getElementById('wbLocalControls');\r\n    var wbRed = document.getElementById('wbRed');\r\n    var wbBlue = document.getElementById('wbBlue');\r\n\r\n    if (mode === 'manual') {\r\n        if (manualControls) manualControls.style.display = 'flex';\r\n        if (localControls) localControls.style.display = 'none';\r\n        if (wbRed) wbRed.disabled = false;\r\n        if (wbBlue) wbBlue.disabled = false;\r\n        setWhiteBalanceMode('manual');\r\n    } else if (mode === 'local') {\r\n        if (manualControls) manualControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'block';\r\n        if (wbRed) wbRed.disabled = true;\r\n        if (wbBlue) wbBlue.disabled = true;\r\n        // v8.39: 局部模式自动切换到手动模式\r\n        setWhiteBalanceMode('manual');\r\n    } else {\r\n        // 自动\r\n        if (manualControls) manualControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'none';\r\n        if (wbRed) wbRed.disabled = true;\r\n        if (wbBlue) wbBlue.disabled = true;\r\n        setWhiteBalanceMode('auto');\r\n    }\r\n}\r\n\r\n// 停止自动白平衡\r\nfunction stopAutoWhiteBalance() {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    if (typeof operationLog === 'function') operationLog('用户停止', 'warning');\r\n    apiPost('/api/v1/vision/whitebalance-stop', {}).then(function(r) {\r\n        if (r && r.success) {\r\n            showToast('success', '已停止白平衡搜索');\r\n        }\r\n    }).catch(function(e) {\r\n        showToast('error', '停止失败');\r\n    });\r\n    // 恢复按钮状态\r\n    var stopBtn = document.getElementById('btnWbLocalStop');\r\n    var confirmBtn = document.getElementById('btnWbTimerConfirm');\r\n    var selectBtn = document.getElementById('btnWbRegionSelect');\r\n    if (stopBtn) stopBtn.disabled = true;\r\n    if (confirmBtn) { confirmBtn.disabled = true; confirmBtn.style.opacity = '0.5'; }\r\n    if (selectBtn) { selectBtn.style.opacity = '1'; }\r\n    selectBtn.style.opacity = '1';\r\n    stopWbTimer();\r\n\n[769 more lines in file. Use offset=1259 to continue.]"}],"isError":false,"timestamp":1783256358656}}
