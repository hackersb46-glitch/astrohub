  if (overlay) overlay.remove();\r\n865: }\r\n866: \r\n867: // v7.32: ��ת�����ܼ��ҳ��\r\n868: function goToFunctionTest() {\r\n869:     // �Ƴ����ǲ�\r\n870:     removeFunctionOverlay();\r\n871:     // ��ת���߼�����ҳ��\r\n872:     document.querySelector('[data-page=\"advanced\"]').click();\r\n873:     // ѡ���ܼ��\r\n874:     setTimeout(function() {\r\n875:         document.querySelector('[data-test=\"function\"]').click();\r\n876:     }, 500);","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783263128503}}
