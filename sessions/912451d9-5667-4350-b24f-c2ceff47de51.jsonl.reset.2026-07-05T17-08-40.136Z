{"type":"message","id":"34c831bd","parentId":"24537368","timestamp":"2026-07-05T12:59:11.377Z","message":{"role":"toolResult","toolCallId":"toolu_441c4db33fd847d88739d507","toolName":"read","content":[{"type":"text","text":"function setWhiteBalanceMode(mode) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: mode })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '白平衡: ' + (mode === 'auto' ? '自动' : '手动'));\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('白平衡: ' + (mode === 'auto' ? '自动' : '手动'), 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置白平衡增益 R/B\r\nfunction setWhiteBalanceGain(channel, value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    // 更新显示\r\n    if (channel === 'red') {\r\n        var el = document.getElementById('wbRedVal');\r\n        if (el) el.textContent = value;\r\n    } else {\r\n        var el = document.getElementById('wbBlueVal');\r\n        if (el) el.textContent = value;\r\n    }\r\n\r\n    var key = channel === 'red' ? 'red_gain' : 'blue_gain';\r\n    var label = channel === 'red' ? 'R (红增益)' : 'B (蓝增益)';\r\n\r\n    // v6.56: 只发送增益值,不发送模式(模式已通过下拉菜单切换)\r\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', label + ': ' + value);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('白平衡' + label + ': ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置降噪\r\nfunction setNoiseReduce(type, value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n\r\n    var el = document.getElementById(type === 'spatial' ? 'dnrSpatialVal' : 'dnrTemporalVal');\r\n    if (el) el.textContent = value;\r\n\r\n    var key = type === 'spatial' ? 'spatial_level' : 'temporal_level';\r\n    var label = type === 'spatial' ? '空域降噪' : '时域降噪';\r\n\n[490 more lines in file. Use offset=1538 to continue.]"}],"isError":false,"timestamp":1783256351376}}
