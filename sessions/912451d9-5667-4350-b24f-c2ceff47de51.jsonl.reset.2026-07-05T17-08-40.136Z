 \"\",\n            },\n            \"detected_at\": datetime.now(timezone.utc).replace(tzinfo=None).isoformat(),\n            \"functions\": {}\n        }\n\n        for item_key, data in result.items():\n            output[\"functions\"][item_key] = {\n                \"p_id\": data.get(\"p_id\", \"\"),\n                \"item\": data.get(\"item\", item_key),\n                \"label\": data.get(\"label\", item_key),\n                \"supported\": data.get(\"supported\", False),\n                \"min\": data.get(\"min_val\"),\n                \"max\": data.get(\"max_val\"),\n                \"endpoint\": data.get(\"endpoint\", \"\"),\n                \"opt_values\": data.get(\"opt_values\", []),\n                \"current_values\": data.get(\"current_values\", {}),\n                \"test_results\": data.get(\"test_results\", []),\n                \"restored\": data.get(\"restored\", False),\n                \"error\": data.get(\"error\")\n            }\n\n        # 步骤5: 保存到function.json\n        try:\n            self._init_device_info()\n            output_file = get_data_path_write(self._model_short, self._mac_clean, 'function')\n            with open(output_file, 'w', encoding='utf-8') as f:\n                json.dump(output, f, indent=2, ensure_ascii=False)\n        except Exception:\n            pass\n\n        return output\n\n    def cancel(self) -> None:\n        \"\"\"取消探测。\"\"\"\n        self._cancelled = True\n\n\n# --- 活跃测试器注册（用于取消） ---\n_active_func_detector: FunctionDetector | None = None\n\n\ndef cancel_active_function(device_ip: str) -> bool:\n    \"\"\"取消指定设备的功能探测。\"\"\"\n    global _active_func_detector\n    if _active_func_detector is not None:\n        _active_func_detector.cancel()\n        return True\n    return False","oldText":"    def cancel(self) -> None:\n        \"\"\"取消探测。\"\"\"\n        self._cancelled = True\n\n\n# --- 活跃测试器注册（用于取消） ---\n_active_func_detector: FunctionDetector | None = None\n\n\ndef cancel_active_function(device_