teBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3130         nr_xml = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3131 <NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3142         sharp_xml = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3143 <Sharpness version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3219         xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3220 <Exposure version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3300         xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3301 <Shutter version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3373         xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3374 <Iris version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3445         xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3446 <Gain version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3515         xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3516 <Sharpness version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n      3838     xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n      3839 <WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">"}],"details":{"status":"completed","exitCode":0,"durationMs":478,"aggregated":"[32;1mLineNumber[0m[32;1m Line[0m\r\n[32;1m----------[0m [32;1m----[0m\r\n        44 from src.main.constants import VERSION, VERSION_NUM\r\n       273 @health_router.get(\"/version\", summary=\"��ȡ�汾��\")\r\n       274 async def get_version() -> dict:\r\n       275     \"\"\"��ȡϵͳ�汾�� (GET /api/v1/version)��\"\"\"\r\n       277         \"version\": VERSION,\r\n       278         \"version_num\": VERSION_NUM,\r\n       340                     \"firmware_version\": d.get(\"firm