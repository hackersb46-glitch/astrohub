{"type":"message","id":"c69f15af","parentId":"9098b4c9","timestamp":"2026-07-05T01:22:09.095Z","message":{"role":"toolResult","toolCallId":"call_00934ea454994d0db41868eb","toolName":"read","content":[{"type":"text","text":"            return {\"success\": True, \"message\": \"滤镜设置成功\"}\r\n        else:\r\n            return {\"success\": False, \"message\": f\"设置失败: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置滤镜异常: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/osd/ptz\", summary=\"获取PTZ OSD状态\", tags=[\"OSD\"])\r\nasync def get_osd_ptz(device_id: str) -> dict:\r\n    \"\"\"获取PTZ OSD显示状态。\"\"\"\r\n\n[529 more lines in file. Use offset=3670 to continue.]"}],"isError":false,"timestamp":1783214529095}}
{"type":"message","id":"2abd4ed5","parentId":"c69f15af","timestamp":"2026-07-05T01:22:59.501Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_a04e29a9756f49a49ce9e27c","name":"edit","arguments":{"edits":[{"newText":"        return {\"success\": False, \"message\": f\"设置滤镜异常: {e}\"}\n\n\n# === 慢快门 (v8.44) ===\n\n@api_router.get(\"/ptz/{device_id}/image/slow-shutter\", summary=\"获取慢快门设置\", tags=[\"Image\"])\nasync def get_slow_shutter(device_id: str) -> dict:\n    \"\"\"获取慢快门状态和倍率。\"\"\"\n    import xml.etree.ElementTree as ET\n    mgr: PTZDeviceController | None = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    try:\n        resp = client.get(\"/Image/channels/1/Shutter\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取慢快门失败: HTTP {resp.status_code}\"}\n\n        root = ET.fromstring(resp.xml)\n        shutter_level = None\n        min_limit = None\n        max_limit = None\n\n        for elem in root.iter():\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n            if tag in (\"ShutterLevel\", \"shutterLevel\"):\n                shutter_level = (elem.text or \"\").strip()\n            elif tag in (\"minShutterLevelLimit\", \"MinShutterLevelLimit\"):\n                min_limit = (elem.text or \"\").strip()\n            elif tag in (\"maxShutterLevelLimit\", \"MaxShutterLevelLimit\"):\n                max_limit = (elem.text or \"\").strip()\n\n        # 判断是否支持慢快门：minLimit 和 maxLimit 都存在且不同\n        supported = bool(min_limit and max_limit and min_limit != max_limit)\n\n        # 计算当前倍率\n        ratio = 1.0\n        if supported and shutter_level and min_limit:\n            from src.controlpanel.region_base import _parse_shutter_level\n            base_time = _parse_shutter_level(shutter_level)\n            min_time = _parse_shutter_level(min_limit)\n            if base_time > 0 and min_time > 0:\n                ratio = round(base_time / min_time, 2)\n\n        return {\n            \"success\": True,\n            \"data\": {\n                \"supported\": supported,\n                \"enabled\": ratio > 1.0,\n                \"ratio\": ratio,\n                \"shutter_level\": shutter_level,\n                \"min_limit\": min_limit,\n                \"max_limit\": max_limit\n            }\n        }\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"获取慢快门异常: {e}\"}\n\n\n@api_router.put(\"/ptz/{device_id}/image/slow-shutter\", summary=\"设置慢快门\", tags=[\"Image\"])\nasync def set_slow_shutter(device_id: str, body: dict) -> dict:\n    \"\"\"设置慢快门倍率。\n\n    请求体:\n        {\"ratio\": 0}  → 关闭（恢复默认）\n        {\"ratio\": 1.25} → 1.25倍率\n        {\"ratio\": 2} → 2倍率\n        {\"ratio\": 4} → 4倍率\n        {\"ratio\": 8} → 8倍率\n    \"\"\"\n    import re\n    mgr: PTZDeviceController | None = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    ratio = body.get(\"ratio\", 0)\n\n    try:\n        # 先 GET 当前 Shutter XML\n        resp = client.get(\"/Image/channels/1/Shutter\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取当前快门失败: HTTP {resp.status_code}\"}\n\n        xml_str = resp.xml\n\n        if ratio == 0:\n            # 关闭慢快门：minShutterLevelLimit = maxShutterLevelLimit（设为相同值）\n            # 读取当前 maxShutterLevelLimit 作为关闭值\n            import xml.etree.ElementTree as ET\n            root = ET.fromstring(xml_str)\n            max_limit = None\n            for elem in root.iter():\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n                if tag in (\"maxShutterLevelLimit\", \"MaxShutterLevelLimit\"):\n                    max_limit = (elem.text or \"\").strip()\n                    break\n            if max_limit:\n                xml_str = re.sub(\n                    r'(<minShutterLevelLimit>)[^<]*(</minShutterLevelLimit>)',\n                    f'\\\\g<1>{max_limit}\\\\g<2>',\n                    xml_str\n                )\n        else:\n            # 开启慢快门：根据倍率计算 minShutterLevelLimit\n            # minLimit = baseShutter × ratio\n            import xml.etree.ElementTree as ET\n            from src.controlpanel.region_base import _parse_shutter_level\n            root = ET.fromstring(xml_str)\n            shutter_level = None\n            max_limit = None\n            for elem in root.iter():\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n                if tag in (\"ShutterLevel\", \"shutterLevel\"):\n                    shutter_level = (elem.text or \"\").strip()\n                elif tag in (\"maxShutterLevelLimit\", \"MaxShutterLevelLimit\"):\n                    max_limit = (elem.text or \"\").strip()\n\n            if not shutter_level or not max_limit:\n                return {\"success\": False, \"message\": \"无法读取快门基准值\"}\n\n            base_time = _parse_shutter_level(shutter_level)\n            min_time = base_time / ratio\n            # 转换回分数格式\n            if min_time > 0:\n                min_val = f\"1/{int(1/min_time)}\"\n            else:\n                min_val = max_limit\n\n            xml_str = re.sub(\n                r'(<minShutterLevelLimit>)[^<]*(</minShutterLevelLimit>)',\n                f'\\\\g<1>{min_val}\\\\g<2>',\n                xml_str\n            )\n\n        put_resp = client.put(\"/Image/channels/1/Shutter\", xml_str)\n        if put_resp.status_code == 200:\n            log_info(\"image\", \"slow_shutter\", {\"device\": device_id, \"ratio\": ratio})\n            return {\"success\": True, \"message\": f\"慢快门: {'关闭' if ratio == 0 else f'{ratio}x'}\"}\n        else:\n            return {\"success\": False, \"message\": f\"设置失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置慢快门异常: {e}\"}\n\n\n@api_router.get(\"/ptz/{device_id}/osd/ptz\", summary=\"获取PTZ OSD状态\", tags=[\"OSD\"])","oldText":"        return {\"success\": False, \"message\": f\"设置滤镜异常: {e}\"}\n\n\n@api_router.get(\"/ptz/{device_id}/osd/ptz\", summary=\"获取PTZ OSD状态\", tags=[\"OSD\"])","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":140379,"output":1973,"cacheRead":0,"cacheWrite":0,"totalTokens":142352,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783214529098,"responseId":"cht000d7a53@dx19f2fde67bd29bb503"}}
