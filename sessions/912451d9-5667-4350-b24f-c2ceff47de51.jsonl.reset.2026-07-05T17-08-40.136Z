 236 行之后、237 行之前插入滤镜控制区："},{"type":"toolCall","id":"call_ceb861ef8a434c70afee3fd6","name":"edit","arguments":{"edits":[{"newText":"            </div>\n            <!-- 滤镜与日夜模式 (v8.43) -->\n            <div class=\"section-subtitle\">滤镜与日夜模式</div>\n            <div style=\"display:flex;gap=4px;justify-content=center;flex-wrap=wrap;margin-bottom=4px\">\n                <!-- 日夜模式 -->\n                <div style=\"flex:1;width=33%\">\n                    <label style=\"font-size=11px;color=#8b949e;margin-bottom=2px;display:block\">日夜模式</label>\n                    <select id=\"dayNightMode\" style=\"width=100%;padding=4px;background=#0d1117;border=1px solid #30363d;border-radius=4px;color=#e0e6f0;font-size=11px\"\n                            onchange=\"setDayNightMode(this.value)\">\n                        <option value=\"auto\">自动</option>\n                        <option value=\"day\">日</option>\n                        <option value=\"night\">夜</option>\n                    </select>\n                </div>\n                <!-- IRCut 滤镜 -->\n                <div style=\"flex:1;width=33%\">\n                    <label style=\"font-size=11px;color=#8b949e;margin-bottom=2px;display:block\">IR 滤镜</label>\n                    <select id=\"irCutFilter\" style=\"width=100%;padding=4px;background=#0d1117;border=1px solid #30363d;border-radius=4px;color=#e0e6f0;font-size=11px\"\n                            onchange=\"setIRCutFilter(this.value)\">\n                        <option value=\"auto\">自动</option>\n                        <option value=\"on\">开</option>\n                        <option value=\"off\">关</option>\n                    </select>\n                </div>\n                <!-- 当前状态显示 -->\n                <div style=\"flex=1;width=33%;display:flex;align-items=center;gap=6px\">\n                    <span style=\"font-size=11px;color=#8b949e\">状态:</span>\n                    <span id=\"filterStatus\" style=\"font-size=11px;color=#58a6ff\">--</span>\n          