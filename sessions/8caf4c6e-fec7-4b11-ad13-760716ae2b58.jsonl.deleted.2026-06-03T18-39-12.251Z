gin: true,`n                cbEvent:\"\n    $idx = $content.IndexOf($target2)\n}\n\nif ($idx -lt 0) {\n    Write-Output \"ERROR: pattern not found\"\n    exit 1\n}\n\n$replacement = \"bWndFull: true,`r`n                iPackageType: 2,`r`n                iWndowType: 1,`r`n                bNoPlugin: true,`r`n                proxyAddress: {`r`n                    ip: location.hostname,`r`n                    port: location.port || '10280'`r`n                },`r`n                cbEvent:\"\n\n$content = $content.Substring(0, $idx) + $replacement + $content.Substring($idx + $target.Length)\n[System.IO.File]::WriteAllText($path, $content, [System.Text.Encoding]::UTF8)\nWrite-Output \"OK: proxyAddress added at index $idx\"\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\_fix_proxy.ps1"}}],"api":"openai-completions","provider":"YerPlan","model":"qwen3.6-plus","usage":{"input":23042,"output":713,"cacheRead":0,"cacheWrite":0,"totalTokens":23755,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779302259933,"responseId":"chatcmpl-73f31dca-68d1-904c-9856-0783e92881fe"}}
