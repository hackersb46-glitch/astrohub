{"type":"message","id":"0b75ad14","parentId":"c052d04d","timestamp":"2026-06-13T20:23:02.891Z","message":{"role":"toolResult","toolCallId":"tool-b05a0984cd4047dd8378cd3ba4a0e532","toolName":"read","content":[{"type":"text","text":"                } else {\r\n                    if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#d29922\">未获取到预置点</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                if (resultDiv) resultDiv.innerHTML = '<span style=\"color:#f85149\">获取失败: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function ptzGotoSelectedPreset() {\r\n            var dev = window.connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            if (!presetId) { showToast('warning', '请先选择预置点'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '跳转到预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId, null).then(function(resp) {\r\n                if (resp && resp.success !== false) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已前往预置点 ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 跳转失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function ptzSetSelectedPreset() {\r\n            var dev = window.connectedDevice.ip;\r\n            var sel = document.getElementById('ptzPresetSelect');\r\n            var presetId = parseInt(sel.value);\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            if (!presetId) { showToast('warning', '请先选择预置点编号'); return; }\r\n            var resultDiv = document.getElementById('ptzPresetResult');\r\n            resultDiv.textContent = '保存当前位置为预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + dev + '/preset/' + presetId + '/set', null).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已保存预置点 ' + presetId + '</span>';\r\n                    loadPresetList(); // refresh\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 保存失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function findMacByIP(ip) {\r\n            var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n            return dev ? dev.mac : '';\r\n        }\r\n        // PTZ Speed Slider\r\n        function initPtzSpeed() {\r\n            var slider = document.getElementById('ptzSpeed');\r\n            if (slider) {\r\n                slider.addEventListener('input', function(e) {\r\n                    document.getElementById('ptzSpeedVal').textContent = e.target.value;\r\n                });\r\n            }\r\n        }\r\n        // Mouse/Touch Up - stop PTZ\r\n        function initMouseUp() {\r\n            document.addEventListener('mouseup', function() { ptzStop(); });\r\n            document.addEventListener('touchend', function() { ptzStop(); });\r\n        }\r\n        // Clock\r\n        function updateClock() {\r\n            var clock = document.getElementById('clock');\r\n            if (clock) clock.textContent = new Date().toLocaleTimeString('zh-CN');\r\n        }\r\n        // Toast Notifications\r\n        function showToast(type, message) {\r\n            var container = document.getElementById('toastContainer');\r\n            var toast = document.createElement('div');\r\n            toast.className = 'toast ' + type;\r\n            toast.textContent = message;\r\n            container.appendChild(toast);\r\n            setTimeout(function() {\r\n                if (toast.parentNode) toast.parentNode.removeChild(toast);\r\n            }, 4000);\r\n        }\r\n        // Logging\r\n        function addLog(level, msg) {\r\n            var c = document.getElementById('logContainer');\r\n            if (!c) return;\r\n            var d = document.createElement('div');\r\n            d.className = 'log-entry ' + level;\r\n            d.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\r\n            c.insertBefore(d, c.firstChild);\r\n            if (c.children.length > 50) c.removeChild(c.lastChild);\r\n        }\r\n        // WebSocket\r\n        function connectWS() {\r\n            try {\r\n                var ws = new WebSocket(WS_URL);\r\n                ws.onopen = function() {\r\n                    addLog('info', 'WebSocket 已连接');\r\n                };\r\n                ws.onclose = function() {\r\n                    setTimeout(connectWS, 3000);\r\n                };\r\n                ws.onmessage = function(e) {\r\n                    try {\r\n                        var data = JSON.parse(e.data);\r\n                        if (data.type === 'health') updateHealth(data);\r\n                    } catch(err) {}\r\n                };\r\n            } catch(e) {\r\n                addLog('warn', 'WebSocket 连接失败');\r\n            }\r\n        }\r\n        function updateHealth(data) {\r\n            var s = data.system || {};\r\n            if (s.cpu !== undefined) {\r\n                var bar = document.getElementById('cpuBar');\r\n                bar.style.width = s.cpu + '%';\r\n                bar.className = 'progress-fill ' + (s.cpu < 60 ? 'green' : s.cpu < 85 ? 'yellow' : 'red');\r\n                document.getElementById('cpuVal').textContent = s.cpu + '%';\r\n            }\r\n            if (s.memory !== undefined) {\r\n                var bar = document.getElementById('memBar');\r\n                bar.style.width = s.memory + '%';\r\n                bar.className = 'progress-fill ' + (s.memory < 60 ? 'green' : s.memory < 85 ? 'yellow' : 'red');\r\n                document.getElementById('memVal').textContent = s.memory + '%';\r\n            }\r\n            if (s.disk !== undefined) {\r\n                var bar = document.getElementById('diskBar');\r\n                bar.style.width = s.disk + '%';\r\n                bar.className = 'progress-fill ' + (s.disk < 70 ? 'green' : s.disk < 90 ? 'yellow' : 'red');\r\n                document.getElementById('diskVal').textContent = s.disk + '%';\r\n            }\r\n        }\r\n        // SADP Discovery\r\n        function discoverDevices() {\r\n            var btn = document.getElementById('btnDiscover');\r\n            var spinner = document.getElementById('discoverSpinner');\r\n            btn.disabled = true;\r\n            spinner.style.display = 'inline-block';\r\n            addLog('info', 'SADP 设备发现开始...');\r\n            showToast('info', '正在扫描局域网设备 (10s)...');\r\n            apiGet('/api/v1/discovery/sadp').then(function(data) {\r\n                if (data.success) {\r\n                    addLog('success', 'SADP 发现 ' + data.count + ' 台设备: ' + data.message);\r\n                    showToast('success', data.message);\r\n                    refreshDevices();\r\n                } else {\r\n                    addLog('error', '发现失败: ' + (data.message || '未知错误'));\r\n                    showToast('error', data.message || '发现失败');\r\n                }\r\n            }).catch(function(e) {\r\n                addLog('error', 'SADP 发现异常: ' + e.message);\r\n                showToast('error', 'SADP 发现异常: ' + e.message);\r\n            }).finally(function() {\r\n                spinner.style.display = 'none';\r\n                btn.disabled = false;\r\n            });\r\n        }\r\n        // Device List\r\n        var _sadpAutoRunning = false;\r\n        function autoSadpDiscover() {\r\n            if (_sadpAutoRunning) return;\r\n            _sadpAutoRunning = true;\r\n            apiGet('/api/v1/discovery/sadp').then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', 'SADP 发现 ' + (result.count || 0) + ' 台设备');\r\n                }\r\n                refreshDevices();  // 刷新设备列表（含网关信息）\r\n                _sadpAutoRunning = false;\r\n            }).catch(function(e) {\r\n                _sadpAutoRunning = false;\r\n            });\r\n        }\r\n        function refreshDevices() {\r\n            console.log('[REFRESH] refreshDevices called');\r\n            return apiGet('/api/v1/devices').then(function(result) {\r\n                console.log('[REFRESH] API response:', result);\r\n                if (!result.success) {\r\n                    allDevices = [];\r\n                    renderDevices([]);\r\n                    return;\r\n                }\r\n                allDevices = result.data || [];\r\n                renderDevices(allDevices);\r\n                // Update dashboard counters\r\n                var online = allDevices.filter(function(d) { return d.online; }).length;\r\n                var countEl = document.getElementById('devCount');\r\n                if (countEl) countEl.textContent = allDevices.length;\r\n                var onlineEl = document.getElementById('devOnline');\r\n                if (onlineEl) onlineEl.textContent = online;\r\n                var totalEl = document.getElementById('devTotal');\r\n                if (totalEl) totalEl.textContent = allDevices.length;\r\n                // Update PTZ & advanced device dropdowns\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n            }).catch(function(e) {\r\n                console.warn('Failed to refresh devices:', e);\r\n            });\r\n        }\r\n        function renderDevices(devices) {\r\n            var tb = document.getElementById('deviceTable');\r\n            if (!tb) return;\r\n            if (!devices.length) {\r\n                tb.innerHTML = '<tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">暂无设备</td></tr>';\r\n                return;\r\n            }\r\n            var html = devices.map(function(d) {\r\n                var sourceBadge = d.source === 'sadp'\r\n                    ? '<span class=\"badge sadp\">SADP</span>'\r\n                    : '<span class=\"badge manual\">手动</span>';\r\n                var onlineBadge = d.online\r\n                    ? '<span class=\"badge online\">在线</span>'\r\n                    : '<span class=\"badge offline\">离线</span>';\r\n                var actions = buildDeviceActions(d);\r\n                return '<tr>'\r\n                    + '<td>' + sourceBadge + '</td>'\r\n                    + '<td>' + (d.mac || '--') + '</td>'\r\n                    + '<td>' + (d.ip || '--') + '</td>'\r\n                    + '<td>' + (d.gateway || '--') + '</td>'\r\n                    + '<td>' + (d.name || d.device_name || '--') + '</td>'\r\n                    + '<td>' + (d.model || '--') + '</td>'\r\n                    + '<td>' + onlineBadge + '</td>'\r\n                    + '<td>' + actions + '</td>'\r\n                    + '</tr>';\r\n            }).join('');\r\n            tb.innerHTML = html;\r\n        }\r\n        function buildDeviceActions(d) {\r\n            var btns = [];\r\n            var isConnected = window.connectedDevice && window.connectedDevice.ip === d.ip;\r\n            // v6.35: 连接开关（只有一个设备可连接）\r\n            var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\r\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\'' + d.ip + '\\', this.checked)\" /><span class=\"slider\"></span></label>';\r\n            btns.push(switchHtml);\r\n            // v6.35: 信息按钮（弹窗显示设备详情）\r\n            btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoModal(\\'' + d.ip + '\\')\">信息</button>');\r\n            // Add modify IP button for all devices\r\n            btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\'' + (d.mac || '') + '\\',\\'' + (d.ip || '') + '\\')\">修改IP</button>');\r\n            btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\')\">删除</button>');\r\n            return '<div class=\"actions\" style=\"display:flex;align-items:center;gap:8px\">' + btns.join('') + '</div>';\r\n        }\r\n        // v6.35: 切换设备连接状态\r\n        window.toggleDeviceConnect = function(ip, checked) {\r\n            if (checked) {\r\n                connectDevice(ip);\r\n            } else {\r\n                disconnectDevice(ip);\r\n            }\r\n        };\r\n        // v6.35: 显示设备信息弹窗\r\n        window.showDeviceInfoModal = function(ip) {\r\n            var d = allDevices.find(function(dev) { return dev.ip === ip; }) || {};\r\n            var info = '<div style=\"font-size:14px;line-height:1.8\">' +\r\n                '<p><b>IP:</b> ' + (d.ip || '--') + '</p>' +\r\n                '<p><b>MAC:</b> ' + (d.mac || '--') + '</p>' +\r\n                '<p><b>名称:</b> ' + (d.name || d.device_name || '--') + '</p>' +\r\n                '<p><b>型号:</b> ' + (d.model || '--') + '</p>' +\r\n                '<p><b>网关:</b> ' + (d.gateway || '--') + '</p>' +\r\n                '<p><b>子网掩码:</b> ' + (d.subnet || '--') + '</p>' +\r\n                '<p><b>端口:</b> ' + (d.port || 80) + '</p>' +\r\n                '</div>';\r\n            if (window.showModal) {\r\n                showModal('设备信息', info);\r\n            } else {\r\n                alert(info);\r\n            }\r\n        };\r\n        // v6.54: 连接/断开操作锁\r\n        var _connectionOperationInProgress = false;\r\n        \r\n        // Device Actions\r\n        function connectDevice(ip) {\r\n            // v6.54: 防止重复点击\r\n            if (_connectionOperationInProgress) {\r\n                showToast('warning', '请等待上一次操作完成');\r\n                return;\r\n            }\r\n            _connectionOperationInProgress = true;\r\n            \r\n            addLog('info', '正在连接设备: ' + ip);\r\n            showToast('info', '正在连接设备...');\r\n            \r\n            // 禁用连接按钮\r\n            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(false);\r\n            \r\n            // 先获取 credentials\r\n            apiGet('/api/v1/ptz/devices/' + ip + '/credentials').then(function(creds) {\r\n                var username = (creds && creds.success) ? creds.username : 'admin';\r\n                var password = (creds && creds.success) ? creds.password : '';\r\n                var port = (creds && creds.success) ? (creds.port || 80) : 80;\r\n\r\n                // 再调用 connect API\r\n                apiPost('/api/v1/devices/' + ip + '/connect', { username: username, password: password, port: port }).then(function(result) {\r\n                    if (result && result.success) {\r\n                        addLog('success', result.message || '连接成功');\r\n                        // Set connectedDevice BEFORE refreshDevices\r\n                        var dev = allDevices.find(function(d) { return d.ip === ip; }) || { ip: ip };\r\n                        window.connectedDevice = {\r\n                            ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\r\n                            mac: dev.mac || '', username: username, password: password, port: port, online: true\r\n                        };\r\n                        // Update button immediately\r\n                        if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                        // 动态加载设备图像参数（白平衡、快门、光圈、降噪、锐度、OSD）\r\n\n[1536 more lines in file. Use offset=1300 to continue.]"}],"isError":false,"timestamp":1781382182891}}
{"type":"message","id":"ff1f24ca","parentId":"0b75ad14","timestamp":"2026-06-13T20:23:10.449Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，让我继续找到 PTZ 控制的按钮事件处理代码："},{"type":"toolCall","id":"tool-d698c17496ed4645a0505d7e15f42d04","name":"read","arguments":{"limit":300,"offset":1300,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":93162,"output":59,"cacheRead":0,"cacheWrite":0,"totalTokens":93221,"cost":{"input":0.093162,"output":0.0001888,"cacheRead":0,"cacheWrite":0,"total":0.0933508}},"stopReason":"toolUse","timestamp":1781382182892,"responseId":"cht000dc10c@dx19ec2a703dbb894142"}}
{"type":"message","id":"20c6c8de","parentId":"ff1f24ca","timestamp":"2026-06-13T20:23:10.458Z","message":{"role":"toolResult","toolCallId":"tool-d698c17496ed4645a0505d7e15f42d04","toolName":"read","content":[{"type":"text","text":"                        // v5.42: 增加延迟确保设备连接完成\r\n                        setTimeout(function() {\r\n                            console.log('[CONNECT] Calling loadDeviceImageParams for:', ip);\r\n                            if (typeof loadDeviceImageParams === 'function') {\r\n                                loadDeviceImageParams(ip);\r\n                                console.log('[CONNECT] loadDeviceImageParams called');\r\n                            } else {\r\n                                console.error('[CONNECT] loadDeviceImageParams not found');\r\n                            }\r\n                        }, 500);\r\n                        // WASM SDK login (with loading indicator)\r\n                        showToast('info', '正在初始化视频流...');\r\n                        if (window.clickLogin2) { window.clickLogin2(); }\r\n                        \r\n                        // v6.54: 等待视频播放后启用按钮\r\n                        setTimeout(function() {\r\n                            _connectionOperationInProgress = false;\r\n                            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                        }, 3000);\r\n                    } else if (result && result.message && result.message.indexOf('凭证') >= 0) {\r\n                        // credentials 错误，提示用户输入\r\n                        _connectionOperationInProgress = false;\r\n                        if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                        var username2 = prompt(\"请输入用户名:\", \"admin\");\r\n                        if (!username2) return;\r\n                        var password2 = prompt(\"请输入密码:\");\r\n                        if (!password2) return;\r\n                        connectDeviceWithCreds(ip, username2, password2, 80);\r\n                    } else {\r\n                        _connectionOperationInProgress = false;\r\n                        if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                        showToast('error', result ? result.message : '连接失败');\r\n                        addLog('error', result ? result.message : '连接失败');\r\n                    }\r\n                }).catch(function(e) {\r\n                    _connectionOperationInProgress = false;\r\n                    if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                    showToast('error', '连接异常: ' + e.message);\r\n                    addLog('error', '连接异常: ' + e.message);\r\n                });\r\n            }).catch(function(e) {\r\n                // credentials API 失败，尝试无密码连接\r\n                apiPost('/api/v1/devices/' + ip + '/connect', null).then(function(result) {\r\n                    if (result && result.success) {\r\n                        showToast('success', '设备已连接: ' + ip);\r\n                        refreshDevices();\r\n                        refreshPtzDeviceList();\r\n                        refreshAdvancedDeviceSelectors();\r\n                        var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n                        if (dev) {\r\n                            window.connectedDevice = {\r\n                                ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\r\n                                mac: dev.mac || '', username: 'admin', password: '', port: 80, online: true\r\n                            };\r\n                            if (window.clickLogin2) { window.clickLogin2(); }\r\n                              if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                        }\r\n                        _connectionOperationInProgress = false;\r\n                        if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                    } else {\r\n                        _connectionOperationInProgress = false;\r\n                        if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                        showToast('error', result ? result.message : '连接失败');\r\n                    }\r\n                });\r\n            });\r\n        }\r\n\r\n        function connectDeviceWithCreds(ip, username, password, port) {\r\n            apiPost('/api/v1/devices/' + ip + '/connect', {\r\n                username: username, password: password, port: port\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '设备已连接: ' + ip);\r\n                    addLog('success', result.message || '连接成功');\r\n                    refreshDevices();\r\n                    refreshPtzDeviceList();\r\n                    refreshAdvancedDeviceSelectors();\r\n                    // --- v3: Update global window.connectedDevice ---\r\n                    var dev = allDevices.find(function(d) { return d.ip === ip; });\r\n                    if (dev) {\r\n                        window.connectedDevice = window.connectedDevice = {\r\n                            ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\r\n                            mac: dev.mac || '', username: username, password: password, port: port, online: true\r\n                        };\r\n                        addLog('info', '已连接设备: ' + window.connectedDevice.ip);\r\n                        // 动态加载设备图像参数\r\n                        setTimeout(function() {\r\n                            console.log('[CONNECT2] Calling loadDeviceImageParams for:', ip);\r\n                            if (typeof loadDeviceImageParams === 'function') {\r\n                                loadDeviceImageParams(ip);\r\n                            }\r\n                        }, 500);\r\n                        // WASM SDK login - user clicked Connect\r\n                        if (window.clickLogin2) { window.clickLogin2(); }\r\n                              if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                    }\r\n                } else {\r\n                    showToast('error', result ? result.message : '连接失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '连接异常: ' + e.message);\r\n            });\r\n        }\r\n        function disconnectDevice(ip) {\r\n            // v6.54: 防止重复点击\r\n            if (_connectionOperationInProgress) {\r\n                showToast('warning', '请等待上一次操作完成');\r\n                return;\r\n            }\r\n            _connectionOperationInProgress = true;\r\n            \r\n            // 禁用连接按钮\r\n            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(false);\r\n            \r\n            showToast('info', '正在断开设备...');\r\n            // --- Stop PTZ position polling ---\r\n            if (window.stopPtzPositionPoll) window.stopPtzPositionPoll();\r\n            // --- Stop WASM video stream ---\r\n            if (window.wasmLogout) window.wasmLogout();\r\n            // v6.16: 清除 WASM 状态\r\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\r\n            \r\n            // v6.54: 禁用主控台和高级功能\r\n            if (window.disableAllControls) window.disableAllControls('请先连接设备');\r\n            \r\n            apiPost('/api/v1/devices/' + ip + '/disconnect', null).then(function() {\r\n                showToast('success', '设备已断开: ' + ip);\r\n                addLog('info', '设备已断开: ' + ip);\r\n                // --- Clear global window.connectedDevice first, before refresh ---\r\n                if (window.connectedDevice && window.connectedDevice.ip === ip) {\r\n                    window.connectedDevice = null;\r\n                    addLog('info', '已清除连接设备状态');\r\n                }\r\n                if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                refreshDevices();\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n                var panel = document.getElementById('deviceInfoPanel');\r\n                if (panel) panel.style.display = 'none';\r\n                \r\n                _connectionOperationInProgress = false;\r\n                if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n            }).catch(function(e) {\r\n                _connectionOperationInProgress = false;\r\n                if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                showToast('error', '断开异常: ' + e.message);\r\n            });\r\n        }\r\n        function deleteDevice(identifier) {\r\n            if (!confirm('确定删除设备 ' + identifier + '？')) return;\r\n            apiDelete('/api/v1/devices/' + identifier).then(function() {\r\n                showToast('success', '设备已删除');\r\n                addLog('info', '设备已删除: ' + identifier);\r\n                refreshDevices();\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n            }).catch(function(e) {\r\n                showToast('error', '删除异常: ' + e.message);\r\n            });\r\n        }\r\n        // Show modify IP modal for SADP device\r\n        // Submit modify IP\r\n        // Add Device Modal\r\n        // Connect Device Modal (credentials input)\r\n        // PTZ Device List Update\r\n        function refreshPtzDeviceList() {\r\n            var online = (allDevices || []).filter(function(d) { return d.online; });\r\n            var select = document.getElementById('ptzDevice');\r\n            if (select) {\r\n                select.innerHTML = '<option value=\"\">未选择设备</option>';\r\n                online.forEach(function(d) {\r\n                    var option = document.createElement('option');\r\n                    option.value = d.ip;\r\n                    option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                    select.appendChild(option);\r\n                });\r\n                if (window.connectedDevice && select.querySelector('option[value=\"' + window.connectedDevice.ip + '\"]')) {\r\n                    select.value = window.connectedDevice.ip;\r\n                }\r\n            }\r\n            // Trigger onPtzDeviceChange if connectedDevice exists (regardless of select)\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                onPtzDeviceChange();\r\n            }\r\n        }\r\n        function onPtzDeviceChange() {\r\n            var ip = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!ip) return;\r\n            var controlArea = document.getElementById('ptzControlArea');\r\n            var noDevice = document.getElementById('ptzNoDevice');\r\n            var connInfo = document.getElementById('ptzConnectedInfo');\r\n            // Only update UI if elements exist (user is on console page)\r\n            if (controlArea && noDevice && connInfo) {\r\n                controlArea.style.display = 'block';\r\n                noDevice.style.display = 'none';\r\n                connInfo.style.display = 'block';\r\n                document.getElementById('ptzSelectedInfo').textContent = ip;\r\n            }\r\n            // Fetch position always, but presets only once per connection\r\n            getPtzPosition();\r\n            if (!window._presetLoadedFor || window._presetLoadedFor !== ip) {\r\n                loadPresetList();\r\n                window._presetLoadedFor = ip;\r\n            }\r\n        }\r\n        // PTZ operation log display\r\n        function ptzLog(msg, type='info') {\r\n            const box = document.getElementById('ptzLogBox');\r\n            if (!box) { console.warn('[ptzLog] ptzLogBox not found'); return; }\r\n            const time = new Date().toLocaleTimeString();\r\n            const colors = {\r\n                'info': '#8b949e',\r\n                'success': '#3fb950',\r\n                'error': '#f85149',\r\n                'warning': '#d29922',\r\n                'debug': '#58a6ff'\r\n            }; \r\n            const icons = {\r\n                'info': '○',\r\n                'success': '●',\r\n                'error': '×',\r\n                'warning': '△',\r\n                'debug': '◇'\r\n            }; \r\n            const color = colors[type] || '#8b949e';\r\n            const icon = icons[type] || '○';\r\n            const entry = document.createElement('div');\r\n            entry.style.cssText = 'color:' + color + ';margin:2px 0;padding:2px 8px;font-size:13px;font-family:monospace';\r\n            entry.textContent = '[' + time + '] ' + icon + ' ' + msg;\r\n            box.insertBefore(entry, box.firstChild);\r\n            if (box.children.length > 50) box.removeChild(box.lastChild);\r\n            console.log('[ptzLog]', msg, type);\r\n            \r\n            // v6.40: 发送操作日志到后端\r\n            if (typeof apiPost === 'function') {\r\n                try {\r\n                    apiPost('/api/v1/log/operation', {\r\n                        level: type.toUpperCase(),\r\n                        module: 'web',\r\n                        action: 'ptz',\r\n                        detail: msg\r\n                    }).catch(function(e) { console.warn('[LOG] send failed:', e); });\r\n                } catch(e) {}\r\n            }\r\n        }\r\n        window.ptzLog = ptzLog;\r\n        // PTZ Controls\r\n        function ptzMove(dir) {\r\n            var dev = window.connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir, speed: speed\r\n            }).then(function(result) {\r\n                if (result && !result.success) {\r\n                    showToast('error', result.message || '移动失败');\r\n                    addLog('error', 'PTZ 移动失败: ' + (result.message || ''));\r\n                }\r\n            }).catch(function(e) {\r\n                addLog('info', 'PTZ 移动: ' + dir);\r\n            });\r\n        }\r\n        function ptzHome() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/home', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || '归位成功');\r\n                } else if (result) {\r\n                    showToast('error', result.message || '归位失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '归位异常: ' + e.message);\r\n            });\r\n        }\r\n        function ptzStop() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiPost('/api/v1/ptz/' + dev + '/stop', null).catch(function(e) {});\r\n        }\r\n        function getPtzPosition() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiGet('/api/v1/ptz/' + dev + '/position').then(function(result) {\r\n                var posEl = document.getElementById('ptzPosition');\r\n                if (result && result.success && result.data) {\r\n                    var p = result.data;\r\n                    posEl.innerHTML = 'Pan: ' + (p.pan || 0) + ' | Tilt: ' + (p.tilt || 0) + ' | Zoom: ' + (p.zoom || 0);\r\n                } else {\r\n                    posEl.innerHTML = 'Pan: -- | Tilt: -- | Zoom: --';\r\n                }\r\n            }).catch(function(e) {});\r\n        }\r\n        // Calibration (placeholder)\r\n        function calibrate(type) {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先连接设备'); return; }\r\n            var dev = window.connectedDevice.ip;\r\n            apiPost('/api/v1/calibration/' + dev + '/' + type, null).then(function(r) {\r\n                if (r.ok !== false) addLog('info', '开始 ' + type + ' 校准...');\r\n\n[1236 more lines in file. Use offset=1600 to continue.]"}],"isError":false,"timestamp":1781382190458}}
{"type":"message","id":"7ec0a602","parentId":"20c6c8de","timestamp":"2026-06-13T20:23:27.254Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我已经找到了关键代码：\n\n## 问题定位\n\n### 问题1：PTZ速度控制\n\n**前端代码** (`src/web/index.html` 第1329行)：\n```javascript\nfunction ptzMove(dir) {\n    var speed = parseInt(document.getElementById('ptzSpeed').value);  // 前端传 0-100\n    apiPost('/api/v1/ptz/' + dev + '/move', { direction: dir, speed: speed });\n}\n```\n\n**后端代码** (`src/ptz/isapi/ptz.py` 第162行)：\n```python\ndef continuous_move(self, pan: float = 0, tilt: float = 0, zoom: float = 0, focus: float = 0) -> bool:\n    # 将 0-100 范围映射到 -10~10 (ISAPI 2.0 规范)\n    pan_speed = int(pan)  # ❌ 这里直接用int(pan)，没有做映射！\n```\n\n**根本问题**：代码注释说\"映射到 -10~10\"，但实际**没有做映射**！\n\n让我查看官方 ISAPI 文档确认正确的速度范围："},{"type":"toolCall","id":"tool-4dfb91aac7fc49e3af02753d65b0f880","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\M1_method.csv","limit":100}},{"type":"toolCall","id":"tool-f35d723fe0a74f678e7c2acedf198f71","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\step5_function_source.py","limit":50,"offset":180}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":96304,"output":334,"cacheRead":0,"cacheWrite":0,"totalTokens":96638,"cost":{"input":0.096304,"output":0.0010688000000000002,"cacheRead":0,"cacheWrite":0,"total":0.0973728}},"stopReason":"toolUse","timestamp":1781382190460,"responseId":"cht000dc4b1@dx19ec2a732acb8ab282"}}
{"type":"message","id":"0d8ed6ea","parentId":"7ec0a602","timestamp":"2026-06-13T20:23:27.272Z","message":{"role":"toolResult","toolCallId":"tool-4dfb91aac7fc49e3af02753d65b0f880","toolName":"read","content":[{"type":"text","text":"﻿> 版本: v2,,,,,,,,,,,,,,,\r\n> 软件作者：雅痞张@南方天文（必须写入软件提示界面）,,,,,,,,,,,,,,,\r\n> 文档用途: 每次运行后逐项自检，达成标准则该项通过，未达成则记录问题,,,,,,,,,,,,,,,\r\n> 脚本设计: 实现一个可复用的，对于整个Astrohub可以用的脚本，在任何主机和任何PTZ设备上均可以实现发现、匹配功能，非一次性修改功能脚本,,,,,,,,,,,,,,,\r\n> 测试阶段，使用admin账号Nftw1357密码，但不可写死在脚本中。开发完成后清除包括各项限位、IP、MAC、设备名、用户名、密码、网关等所有针对特定主机和特定PTZ设备的信息,,,,,,,,,,,,,,,\r\n> 脚本不得使用任何测试阶段的预设，要让脚本能在完全新的主机、PTZ设备上都正常运作，不得做任何预设，命名规范为项目名（PTZ_ASTRO）+版本号（v1.1）。每个版本需要有开发记录，当前版本主要解决什么。仅允许自行迭代2级版本号，不允许自行迭代1级版本号,,,,,,,,,,,,,,,\r\n> 任何情况下，迭代版本，都必须将原来的版本代码复制成新文件，在新文件基础上做修改，不得直接修改前版本,,,,,,,,,,,,,,,\r\n> 开发过程文件、临时脚本都储存在D:\\PY APP\\PTZ_ASTRO，可以自建子目录。参考官方文档D:\\PY APP\\PTZ_ASTRO\\ref（此路径下所有东西不可编辑，只可以复制出去之后编辑）PDF也需要阅读,,,,,,,,,,,,,,,\r\n> 所有评审点自测通过后，将脚本和运行依赖的dll等文件复制到D:\\PY APP\\TBD，建立与脚本名相同的目录，用于独立隔离测试。,,,,,,,,,,,,,,,\r\n> 开发过程中，需要自测，前一个P没有通过，不得跳过当前P，必须修复，直到通过评审点。测试阶段，不得绕开脚本，使用额外工具。并且，当前一个P完成之后，固定的方法，不得修改、简化和删除，除非出现故障或者人类要求,,,,,,,,,,,,,,,\r\n> 不允许做任何假设，比如IP不可达、密码错误、网络环境故障，如有问题，就是评审点不通过。,,,,,,,,,,,,,,,\r\n> 任何有明确返回错误代码的，都需要查询错误码具体是什么。,,,,,,,,,,,,,,,\r\n> 必须全量搜索已有案例、查询官方文档，解决问题，绝对禁止提出IP不可达、密码错误、网关错误无法继续的报告，更不得要求人工修改IP、人工测试可达性，此类都属于当前节点评审不通过。,,,,,,,,,,,,,,,\r\n> 遇到阻滞，第一时间回看官方文档，查找关键词，全量阅读。禁止向人类发问。,,,,,,,,,,,,,,,\r\n> 每一个P自检通过评审之后，将正确方法记录在与本文件相同的m1_method.md表格的对应|操作方法|中,,,,,,,,,,,,,,,\r\n,,,,,,,,,,,,,,,\r\n编号（人类填写，AI禁止输入）,标题（人类填写，AI禁止输入）,内容描述（人类填写，AI禁止输入）,操作方法（人类填写，AI禁止输入）,评审标准（人类填写，AI禁止输入）,代码实现（AI填写，核心提炼、机器语言）,易错点（AI填写机器语言）,,,,,,,,,\r\nP0,前置准备,建立脚本运行的必要目录、LOG系统、配置文件,,,P0是总纲，本身无操作方法。子章节P0.1~P0.6各自独立。,P0是总纲，不产生直接操作。,,,,,,,,,\r\nP0.1,创建目录结构,在脚本路径下创建 record/ / log/ / report/ / download/ 4个子目录,脚本启动时自动检查并创建，不存在则创建，存在则跳过,目录路径正确，全部创建成功,\"脚本启动时检查并创建 record/、log/、report/、download/ 四个目录。\n代码：os.makedirs(name, exist_ok=True)\",\"import os\nfor d in ['record','log','report','download']:\n    os.makedirs(d, exist_ok=True)\",,,,,,,,,\r\nP0.2,创建LOG文件,在 log/ 目录下生成 log_yyyymmdd+3位序号.md 文件,按日期+序号命名，如 log_20260418-001.md,文件创建成功，内容格式正确,\"在 log/ 目录下创建 log_yyyymmdd+3位序号.md 文件。\n代码：log_file = f'log/log_{date_str}-{seq:03d}.md'\",\"from datetime import datetime\nlog_name = f\"\"log/log_{datetime.now().strftime('%Y%m%d')}-001.md\"\"\nopen(log_name, 'w', encoding='utf-8')\",,,,,,,,,\r\nP0.3,LOG格式规范,统一LOG记录格式，便于追踪每个操作节点,每条记录包含[info][warning][error][done][failed]级别+时间戳yyyymmdd-hhmmss+操作内容，以毫秒为单位，记录脚本运行时候每一步内部和屏幕显示、用户输入,LOG文件创建成功，内容格式正确,\"每条LOG记录格式：[info/warning/error/done/failed]+时间yyyy-mm-dd HH:MM:SS+具体内容。\n代码：LOG(level, msg) -> 写入文件\",\"def LOG(level, msg):\n    ts = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n    with open(log_name, 'a', encoding='utf-8') as f:\n        f.write(f'[{level}] {ts} {msg}\\n')\",,,,,,,,,\r\nP0.4,创建设备配置文件,在脚本目录下创建 config.json，记录设备信息列表,JSON格式，包含设备MAC、IP、型号、凭证等字段,文件创建成功，可正确读写,\"在脚本目录创建 config.json，记录设备信息列表（JSON格式：MAC/IP/型号/凭证/用户选择）。\n代码：json.dump(config, open('config.json','w'), ensure_ascii=False, indent=2)\",\"import json\ndevice_config = {\n    'mac': mac, 'ip': ip,\n    'model': model, 'auth': credentials,\n    'user_net': selected_interface\n}\njson.dump([device_config], open('config.json','w'), indent=2, ensure_ascii=False)\",,,,,,,,,\r\nP0.5,屏幕输出,脚本运行时有清晰的状态信息显示,显示当前阶段、日志文件路径、done时提示完成进度、待操作设备数量、使用说明,屏幕信息清晰，无乱码，格式规范,\"脚本运行时显示当前阶段、进度、日志文件路径；done时显示完成及后续说明；显示当前设备参数及使用说明。\n代码：print(f'[INFO] {stage} | log={log_name}')\",\"print(f'[INFO] P2.1 SADP扫描 | log={log_name}')\nprint(f'[done] P2 SADP完成 | 设备IP=192.168.5.x | 详见log')\nprint(f'当前设备 MAC={mac} IP={ip} 型号={model}')\",,,,,,,,,\r\nP0.6,操作逻辑,构建操作逻辑，人机交互方式,脚本运行时显示作者信息。设定选择的方式，数字键选择序号，键盘输入IP、用户名、密码等，密码需要隐去大部分字段用*表示。每一步操作需要无限循环，直到人类输入Q退出，enter下一步或确认，esc=清空，重新输入,创建完整的交互逻辑，后续都需要使用，如后续未使用，则本评审点不通过,\"脚本运行时显示参数信息及设定选项的方式；用户按序号选择；输入参数IP/用户名/密码等；主要字段用*号隐蔽显示；每一项都需要输入，循环直到用户按Q退出。\n代码：input('请选择网卡序号: ') / getpass.getpass('密码: ') \",\"import getpass\nchoice = input('请选择网卡序号: ')\npwd = getpass.getpass('密码: ')  # 显示为***\nuser = input('用户名 [admin]: ') or 'admin'\n# 循环验证直到 Q 退出\nwhile True:\n    ans = input('确认设备IP [Y/n/Q]: ')\n    if ans.upper() == 'Q': break\",,,,,,,,,\r\nP1,收集本机信息,获取本机硬件环境+网络环境，用户确认使用的网卡,,,P1是总纲。子章节P1.1~P1.3各自独立。,P1是总纲，不产生直接操作。,,,,,,,,,\r\nP1.1,收集主机硬件信息,获取本机 hostname、CPU型号、RAM大小、GPU+VRAM,调用系统API或命令行获取真实数据,hostname/CPU型号/RAM大小/GPU数量/VRAM数值均正确获取，测试阶段，本机处理器AMD R7 5700G，RAM=64gb，GPU=5060ti，VRAM=16gb,\"通过系统API获取本机 hostname、CPU型号、RAM大小、GPU+VRAM。\nWMI: Win32_ComputerSystem / Win32_Processor / Win32_VideoController\nnvidia-smi: 查询真实VRAM（NVIDIA GPU存在时优先）\",\"# RAM\nimport subprocess\nwmic = subprocess.check_output(['wmic','computersystem','get','totalphysicalsize'])\n# GPU/VRAM\nresult = subprocess.check_output(['nvidia-smi','--query-gpu=name,memory.total','--format=csv,noheader'], stderr=subprocess.DEVNULL)\n# GPU: Win32_VideoController.AdapterRAM\",,,,,,,,,\r\nP1.2,列举所有网卡,罗列所有物理网卡+虚拟网卡，获得网关、IP配置，按优先级排序,物理有线>物理无线>虚拟；有默认网关的同类网卡优先,正确罗列所有网卡，正确识别物理网卡，正确设置默认网关,\"获取本机所有网卡+网关+IP配置；有线>无线>其他；默认选同网段最优；用户可选择。\nPowerShell: Get-NetIPAddress + Get-NetRoute\",\"# PowerShell脚本获取网卡信息\nps_script = '''\n$adapters = Get-NetIPAddress -AddressFamily IPv4 | Where-Object {\n    $_.IPAddress -ne '127.0.0.1'\n} | ForEach-Object {\n    $iface = Get-NetInterface -ifIndex $_.InterfaceIndex -ErrorAction SilentlyContinue\n    [PSCustomObject]@{\n        IP=$_.IPAddress\n        Gateway=(Get-NetRoute -DestinationPrefix '0.0.0.0/0' -InterfaceIndex $_.InterfaceIndex).NextHop\n        Name=$_.InterfaceAlias\n    }\n}\n$adapters | Sort-Object { $_.Name -notmatch 'Wi-Fi|Bluetooth' } | Format-Table -AutoSize\n'''\nsubprocess.run(['powershell','-ExecutionPolicy','Bypass','-File',script_path])\",,,,,,,,,\r\nP1.3,用户选择网卡,用户从列表中选择使用哪个网卡进行后续操作,显示序号/IP/网关/类型，默认选序号1，按Q退出,用户选择后记录本机IP和网关；按Q退出程序,\"用户从列表选择使用的网卡和适配方案；显示 [IP/名称/型号/类型]；默认选第1项；按Q退出。\n代码：print列表 + input()选择\",\"adapters = [...]  # 从P1.2获取\nfor i, a in enumerate(adapters):\n    print(f'{i+1}. {a[\"\"ip\"\"]} | {a[\"\"name\"\"]} | {a[\"\"type\"\"]}')\nsel = input('选择网卡 [1/Q]: ')\nif sel.upper() == 'Q': sys.exit()\nchosen = adapters[int(sel)-1]\",,,,,,,,,\r\nP2,SADP发现+IP修改,通过SADP广播发现设备，以MAC为唯一标识，支持激活，IP修改,,使用DLL或命令符实现，不得使用官方示例exe等其他工具,P2是总纲。通过SADP广播发现设备，以MAC为唯一标识支持多台，IP修改。实现: _load_sadp_dll() 加载 Sadp.dll,P2是总纲，不产生直接操作。,,,,,,,,,\r\nP2.1,SADP设备扫描,SADP广播发现，10秒内返回设备列表（MAC/IP/型号/SN）,扫描到设备后列出清单，供用户数字序号选择,扫描到设备，信息完整；多设备时列出清单供选择,\"SADP广播扫描，10秒内返回设备列表（MAC/IP/型号/SN）。\nSADP SDK: SADP_Start_V40 -> 注册回调 -> 等待设备列表\n代码: p2_sadp_scan() -> SADP_Start_V40(cb) -> time.sleep(10) -> SADP_SendInquiry() -> SADP_Stop()\n回调 DEVICE_FIND_CALLBACK_V40 处理 SADP_DEVICE_INFO_V40，去重后返回 dev_list\n显示: p2_display_devices() 列出清单供用户数字序号选择\",\"import ctypes\nSDK_DIR = r'D:\\PY APP\\PTZ_ASTRO\\sdk\\HCNETSDK'\nsadp = ctypes.WinDLL(os.path.join(SDK_DIR, 'Sadp.dll'))\n# V40 callback\nCB_TYPE = ctypes.CFUNCTYPE(None, ctypes.c_void_p, ctypes.c_void_p)\ndev_list = []\ndef dev_cb(lpDi, userData):\n    addr = int(lpDi)\n    pV40 = ctypes.cast(addr, ctypes.POINTER(V40))\n    d = pV40.contents\n    dev_list.append({...})\n\n[253 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1781382207272}}
{"type":"message","id":"00311390","parentId":"0d8ed6ea","timestamp":"2026-06-13T20:23:27.273Z","message":{"role":"toolResult","toolCallId":"tool-f35d723fe0a74f678e7c2acedf198f71","toolName":"read","content":[{"type":"text","text":"            return False\n        time.sleep(3)\n        wait_stable(ptz)\n        s = record_sample(f'{label}_end')\n        log_info(f'    Result: az={s[\"azimuth\"]} el={s[\"elevation\"]} zoom={s[\"zoom\"]}')\n\n    # Return HOME\n    goto_home_stable()\n    close_csv()\n    log_done('P5.2: Absolute Move tests passed')\n    all_results.append({'test': 'P5.2 Absolute Move', 'pass': True, 'csv': csv_path})\n    return True\n\n\ndef test_relative_move():\n    \"\"\"P5.3: Relative Move - check if device supports it\"\"\"\n    log_info('\\n--- P5.3: Relative Move Test ---')\n    goto_home_stable()\n    csv_path = open_csv('p53_relative_move')\n\n    # Try relative move with +100 azimuth, +50 elevation\n    log_info('  Testing relative move (az=+100, el=+50)...')\n    start = record_sample('relative_start')\n    ok = ptz.relative_move(100, 50, 0)\n    log_info(f'  Relative move command: {\"OK\" if ok else \"NOT SUPPORTED\"}')\n\n    if ok:\n        time.sleep(3)\n        wait_stable(ptz)\n        end = record_sample('relative_end')\n        log_info(f'    start: az={start[\"azimuth\"]} el={start[\"elevation\"]} -> end: az={end[\"azimuth\"]} el={end[\"elevation\"]}')\n\n        # Return HOME\n        goto_home_stable()\n    else:\n        log_info('  Device does not support Relative Move (this is acceptable - no requirement)')\n\n    close_csv()\n    log_done(f'P5.3: Relative Move {\"supported\" if ok else \"not supported\"} (no requirement)')\n    all_results.append({'test': 'P5.3 Relative Move', 'pass': True, 'supported': ok, 'csv': csv_path})\n    return True\n\n\ndef test_pan_speed():\n    \"\"\"P5.4: Pan speed at 1/50/100, 2s each, monitor coordinate change\"\"\"\n    log_info('\\n--- P5.4: Pan Speed Control Test ---')\n    goto_home_stable()\n    csv_path = open_csv('p54_pan_speed')\n\n    speeds = [1, 50, 100]\n\n[192 more lines in file. Use offset=230 to continue.]"}],"isError":false,"timestamp":1781382207272}}
{"type":"message","id":"e24f0088","parentId":"00311390","timestamp":"2026-06-13T20:23:39.899Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我找到了关键信息！从 `step5_function_source.py` 第231行：\n\n```python\nspeeds = [1, 50, 100]  # P5.4: Pan speed at 1/50/100\n```\n\n这说明官方测试用的速度值是 **1, 50, 100**，直接传给设备。这意味着 ISAPI 的速度范围是 **0-100**（或 **-100 到 100**），不是 **-10 到 10**！\n\n让我继续搜索官方 ISAPI PTZ 控制文档："},{"type":"toolCall","id":"tool-0526d7f0df77438fabc84cf75b3f7019","name":"read","arguments":{"limit":50,"offset":100,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\PTZ_FUNCTION_source.py"}},{"type":"toolCall","id":"tool-85bc8879df6947899964810e14fd7667","name":"read","arguments":{"limit":50,"offset":85,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\ptzhelper_source.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":100097,"output":210,"cacheRead":0,"cacheWrite":0,"totalTokens":100307,"cost":{"input":0.10009699999999999,"output":0.0006720000000000001,"cacheRead":0,"cacheWrite":0,"total":0.100769}},"stopReason":"toolUse","timestamp":1781382207274,"responseId":"cht000dc5fe@dx19ec2a76af8b894142"}}
{"type":"message","id":"127f3606","parentId":"e24f0088","timestamp":"2026-06-13T20:23:39.912Z","message":{"role":"toolResult","toolCallId":"tool-0526d7f0df77438fabc84cf75b3f7019","toolName":"read","content":[{"type":"text","text":"    for pan, tilt, label in [(5, 0, 'Right'), (-5, 0, 'Left'), (0, 5, 'Up'), (0, -5, 'Down')]:\r\n        ok = ptz.continuous_move(pan=pan, tilt=tilt, zoom=0)\r\n        time.sleep(0.5)\r\n        ptz.stop()\r\n        log_info(f'  {label} -> {\"OK\" if ok else \"FAIL\"}')\r\n\r\n    # Return HOME\r\n    ptz.preset_goto(10)\r\n    wait_stable(ptz)\r\n    log_done('P5.3: Return HOME')\r\n\r\n    return True\r\n\r\n# ===== MAIN =====\r\ndef main():\r\n    print(f'PTZ_FUNCTION {SCRIPT_VERSION} - PTZ Function Test')\r\n    print('=' * 50)\r\n    log_init()\r\n    log_info(f'START PTZ_FUNCTION {SCRIPT_VERSION}')\r\n\r\n    # Load from PTZ_CONFIG.json\r\n    ptz_data = load_from_ptz_config()\r\n    ip = ptz_data['device_ip']\r\n    auth = (ptz_data.get('username', 'admin'), ptz_data.get('password', ''))\r\n    log_info(f'Loaded from PTZ_CONFIG: {ip}')\r\n\r\n    # Auth (try saved first, fallback to interactive)\r\n    auth_result = authenticate(ip)\r\n    if auth_result is not None:\r\n        auth = auth_result\r\n\r\n    # Endpoint probe\r\n    endpoint_results, ep_all_pass = test_endpoints(ip, auth)\r\n\r\n    # Basic motion test\r\n    motion_ok = test_basic_motion(ip, auth)\r\n\r\n    # Capabilities text (for PTZ_CONFIG notes)\r\n    ptz = PTZHelper(ip, auth)\r\n    cap_text = ptz.get_capabilities()\r\n\r\n    # Build record\r\n    record = {\r\n        'script': 'PTZ_FUNCTION',\r\n        'version': SCRIPT_VERSION,\r\n        'timestamp': datetime.now().isoformat(),\r\n        'result': 'PASS' if (ep_all_pass and motion_ok) else 'FAIL',\r\n        'notes': {\r\n            'endpoint_pass_count': sum(1 for r in endpoint_results if r['ok']),\r\n            'endpoint_total': len(endpoint_results),\r\n\n[22 more lines in file. Use offset=150 to continue.]"}],"isError":false,"timestamp":1781382219912}}
{"type":"message","id":"30c6df3f","parentId":"127f3606","timestamp":"2026-06-13T20:23:39.912Z","message":{"role":"toolResult","toolCallId":"tool-85bc8879df6947899964810e14fd7667","toolName":"read","content":[{"type":"text","text":"            'selected_interface': None,\n            'last_scan': None\n        }\n        safe_write_json(CONFIG_FILE, default)\n        log_info('P0.4: config.json initialized')\n    return safe_read_json(CONFIG_FILE) or {'devices': [], 'selected_interface': None}\n\ndef add_device_to_config(device_info):\n    \"\"\"Add/update device in config.json by MAC as unique key\"\"\"\n    cfg = safe_read_json(CONFIG_FILE) or {'devices': [], 'selected_interface': None}\n    mac = device_info.get('mac', '')\n    for i, dev in enumerate(cfg['devices']):\n        if dev.get('mac', '').lower() == mac.lower():\n            cfg['devices'][i].update(device_info)\n            safe_write_json(CONFIG_FILE, cfg)\n            return i\n    cfg['devices'].append(device_info)\n    safe_write_json(CONFIG_FILE, cfg)\n    return len(cfg['devices']) - 1\n\n# ===== Safe JSON =====\ndef safe_read_json(path):\n    if not os.path.exists(path):\n        return None\n    try:\n        with open(path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            if content.startswith('\\ufeff'):\n                content = content[1:]\n            return json.loads(content)\n    except Exception:\n        return None\n\ndef safe_write_json(path, data):\n    \"\"\"Write .tmp -> verify -> overwrite\"\"\"\n    tmp = path + '.tmp'\n    with open(tmp, 'w', encoding='utf-8') as f:\n        json.dump(data, f, indent=2, ensure_ascii=False)\n    with open(tmp, 'r', encoding='utf-8') as f:\n        verified = json.load(f)\n    shutil.move(tmp, path)\n\ndef append_record(config_path, record):\n    data = safe_read_json(config_path) or {}\n    if 'records' not in data:\n        data['records'] = []\n    data['records'].append(record)\n    safe_write_json(config_path, data)\n\n# ===== P0.6 Interaction Utilities =====\n\n[339 more lines in file. Use offset=135 to continue.]"}],"isError":false,"timestamp":1781382219912}}
{"type":"message","id":"6154a0fc","parentId":"30c6df3f","timestamp":"2026-06-13T20:23:52.680Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我找到了关键信息！从 `PTZ_FUNCTION_source.py` 第102行：\n\n```python\nfor pan, tilt, label in [(5, 0, 'Right'), (-5, 0, 'Left'), (0, 5, 'Up'), (0, -5, 'Down')]:\n    ok = ptz.continuous_move(pan=pan, tilt=tilt, zoom=0)\n```\n\n这里用的是 **5** 和 **-5**，不是 **50** 或 **10**！让我继续查看 `ptzhelper_source.py` 中的 `continuous_move` 实现："},{"type":"toolCall","id":"call_4585b10b227d45f59b3efc32","name":"read","arguments":{"limit":50,"offset":190,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\ptzhelper_source.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":117302,"output":175,"cacheRead":0,"cacheWrite":0,"totalTokens":117477,"cost":{"input":0.11730199999999999,"output":0.0005600000000000001,"cacheRead":0,"cacheWrite":0,"total":0.117862}},"stopReason":"toolUse","timestamp":1781382219913,"responseId":"cht000dc893@dx19ec2a7a0eab894142"}}
{"type":"message","id":"e71e8295","parentId":"6154a0fc","timestamp":"2026-06-13T20:23:52.687Z","message":{"role":"toolResult","toolCallId":"call_4585b10b227d45f59b3efc32","toolName":"read","content":[{"type":"text","text":"        for k in list(os.environ.keys()):\n            if 'proxy' in k.lower():\n                os.environ.pop(k, None)\n\n    def get_status(self, retries=2):\n        self._clear_proxy()\n        for attempt in range(retries + 1):\n            try:\n                r = self.session.get(\n                    f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/status',\n                    auth=self.auth, timeout=5)\n                if r.status_code != 200:\n                    if attempt < retries:\n                        time.sleep(0.5)\n                        continue\n                    return {'azimuth': 0, 'elevation': 0, 'zoom': 0}\n                text = r.text\n                az_m = re.search(r'<azimuth>(\\d+)</azimuth>', text)\n                el_m = re.search(r'<elevation>(-?\\d+)</elevation>', text)\n                zm_m = re.search(r'<absoluteZoom>(\\d+)</absoluteZoom>', text)\n                return {\n                    'azimuth': int(az_m.group(1)) if az_m else 0,\n                    'elevation': int(el_m.group(1)) if el_m else 0,\n                    'zoom': int(zm_m.group(1)) if zm_m else 0,\n                }\n            except Exception:\n                if attempt < retries:\n                    time.sleep(0.5)\n                    continue\n                return {'azimuth': 0, 'elevation': 0, 'zoom': 0}\n\n    def absolute_move(self, azimuth, elevation, zoom):\n        self._clear_proxy()\n        xml = (f'<PTZData><AbsoluteHigh>'\n              f'<azimuth>{azimuth}</azimuth>'\n              f'<elevation>{elevation}</elevation>'\n              f'<absoluteZoom>{zoom}</absoluteZoom>'\n              f'</AbsoluteHigh></PTZData>').encode('utf-8')\n        r = self.session.put(\n            f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/absolute/',\n            data=xml, auth=self.auth, timeout=5)\n        return r.status_code == 200\n\n    def relative_move(self, azimuth_delta, elevation_delta, zoom_delta=0):\n        \"\"\"P5.3: Relative move - move by delta from current position.\n        PUT /ISAPI/PTZCtrl/channels/1/relative/\n        \"\"\"\n        self._clear_proxy()\n        xml = (f'<PTZData><Relative>'\n              f'<azimuth>{azimuth_delta}</azimuth>'\n\n[234 more lines in file. Use offset=240 to continue.]"}],"isError":false,"timestamp":1781382232687}}
