{"type":"message","id":"967d4407","parentId":"a20de170","timestamp":"2026-06-13T21:44:35.312Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_5815fb97361945689fb75530","name":"write","arguments":{"content":"\"\"\"Playwright 检查官方 Web 端 PTZ 速度设置\"\"\"\nimport asyncio\nfrom playwright.async_api import async_playwright\n\nasync def check_official_ptz_speed():\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print('=== 检查官方 Web 端 PTZ 速度设置 ===')\n        print()\n        \n        # 访问官方 Web 端\n        print('1. 访问官方 Web 端...')\n        await page.goto('http://192.168.5.72/', wait_until='networkidle')\n        await asyncio.sleep(3)\n        \n        # 截图当前页面\n        await page.screenshot(path='official_web_login.png', full_page=True)\n        print('   截图保存: official_web_login.png')\n        \n        # 查找登录表单元素\n        print('2. 查找登录表单...')\n        \n        # 获取所有 input 元素\n        inputs = await page.query_selector_all('input')\n        print(f'   找到 {len(inputs)} 个 input 元素')\n        \n        for i, inp in enumerate(inputs[:10]):  # 只显示前10个\n            inp_name = await inp.get_attribute('name')\n            inp_id = await inp.get_attribute('id')\n            inp_type = await inp.get_attribute('type')\n            print(f'   Input {i}: name={inp_name}, id={inp_id}, type={inp_type}')\n        \n        # 尝试登录\n        print('3. 尝试登录...')\n        \n        # 尝试用户名输入框\n        for sel in ['input[name=\"userName\"]', 'input[name=\"username\"]', 'input[type=\"text\"]']:\n            try:\n                if await page.is_visible(sel):\n                    await page.fill(sel, 'admin')\n                    print(f'   用户名填写成功: {sel}')\n                    break\n            except:\n                pass\n        \n        # 尝试密码输入框\n        for sel in ['input[name=\"password\"]', 'input[type=\"password\"]']:\n            try:\n                if await page.is_visible(sel):\n                    await page.fill(sel, 'Nftw1357')\n                    print(f'   密码填写成功: {sel}')\n                    break\n            except:\n                pass\n        \n        # 尝试点击登录按钮\n        for sel in ['button[type=\"submit\"]', 'input[type=\"submit\"]', '.login-btn', 'button:has-text(\"登录\")']:\n            try:\n                if await page.is_visible(sel):\n                    await page.click(sel)\n                    print(f'   点击登录按钮: {sel}')\n                    break\n            except:\n                pass\n        \n        # 等待登录完成\n        await asyncio.sleep(5)\n        print('   登录完成')\n        \n        # 进入预览界面\n        print('4. 进入预览界面...')\n        await asyncio.sleep(2)\n        \n        # 截图当前页面\n        await page.screenshot(path='official_web_main.png', full_page=True)\n        print('   截图保存: official_web_main.png')\n        \n        # 查找 PTZ 控制区域\n        print('5. 查找 PTZ 速度控制...')\n        \n        # 查找所有 input 元素\n        inputs = await page.query_selector_all('input')\n        print(f'   找到 {len(inputs)} 个 input 元素')\n        \n        for i, inp in enumerate(inputs):\n            inp_type = await inp.get_attribute('type')\n            inp_id = await inp.get_attribute('id')\n            inp_class = await inp.get_attribute('class')\n            inp_min = await inp.get_attribute('min')\n            inp_max = await inp.get_attribute('max')\n            inp_value = await inp.get_attribute('value')\n            \n            # 只显示 range 或与速度相关的元素\n            if inp_type == 'range' or (inp_id and 'speed' in inp_id.lower()) or (inp_class and 'speed' in inp_class.lower()):\n                print(f'   ★ Input {i}: type={inp_type}, id={inp_id}, class={inp_class}, min={inp_min}, max={inp_max}, value={inp_value}')\n        \n        # 查找 select 元素（下拉菜单）\n        selects = await page.query_selector_all('select')\n        print(f'   找到 {len(selects)} 个 select 元素')\n        \n        for i, sel in enumerate(selects):\n            sel_id = await sel.get_attribute('id')\n            sel_class = await sel.get_attribute('class')\n            \n            # 获取所有 option\n            options = await sel.query_selector_all('option')\n            opt_values = []\n            for opt in options[:10]:  # 只取前10个\n                val = await opt.get_attribute('value')\n                text = await opt.inner_text()\n                opt_values.append(f'{val}:{text}')\n            \n            print(f'   Select {i}: id={sel_id}, class={sel_class}, options={opt_values}')\n        \n        # 截图 PTZ 区域\n        await page.screenshot(path='official_web_ptz.png', full_page=True)\n        print()\n        print('   截图保存: official_web_ptz.png')\n        \n        # 保持浏览器打开\n        print()\n        print('6. 等待 30 秒供手动检查...')\n        await asyncio.sleep(30)\n        \n        await browser.close()\n\nif __name__ == '__main__':\n    asyncio.run(check_official_ptz_speed())\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\inspect_official_ptz.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":55359,"output":1208,"cacheRead":0,"cacheWrite":0,"totalTokens":56567,"cost":{"input":0.055359,"output":0.0038656000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0592246}},"stopReason":"toolUse","timestamp":1781387052628,"responseId":"cht000d6092@dx19ec2f15369ba5c342"}}
