{"type":"message","id":"fdf81755","parentId":"19a964fd","timestamp":"2026-06-13T22:00:47.515Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我明白了！让我修改脚本，正确登录后再检查："},{"type":"toolCall","id":"call_527dff5a6f194b168a58cd8c","name":"write","arguments":{"content":"\"\"\"Playwright 检查官方 Web 端 PTZ 速度设置 - 正确登录\"\"\"\nimport asyncio\nfrom playwright.async_api import async_playwright\n\nasync def check_official_ptz_speed():\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False, slow_mo=1000)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print('=== 检查官方 Web 端 PTZ 速度设置 ===')\n        print()\n        \n        # 访问官方 Web 端\n        print('1. 访问官方 Web 端...')\n        await page.goto('http://192.168.5.72/', wait_until='domcontentloaded')\n        await asyncio.sleep(5)\n        \n        # 截图登录页面\n        await page.screenshot(path='official_1_login.png', full_page=True)\n        print('   截图: official_1_login.png')\n        \n        # 等待登录表单出现\n        print('2. 等待登录表单...')\n        await asyncio.sleep(2)\n        \n        # 查找所有可见的 input\n        inputs = await page.query_selector_all('input')\n        print(f'   找到 {len(inputs)} 个 input 元素')\n        \n        visible_inputs = []\n        for inp in inputs:\n            try:\n                is_visible = await inp.is_visible()\n                if is_visible:\n                    inp_type = await inp.get_attribute('type')\n                    inp_id = await inp.get_attribute('id')\n                    inp_name = await inp.get_attribute('name')\n                    visible_inputs.append({'elem': inp, 'type': inp_type, 'id': inp_id, 'name': inp_name})\n                    print(f'   可见: type={inp_type}, id={inp_id}, name={inp_name}')\n            except:\n                pass\n        \n        # 填写登录信息\n        print('3. 填写登录信息...')\n        \n        # 第一个可见的 text input 是用户名\n        text_inputs = [x for x in visible_inputs if x['type'] == 'text']\n        if text_inputs:\n            await text_inputs[0]['elem'].fill('admin')\n            print('   用户名: admin')\n        \n        # 密码 input\n        password_inputs = [x for x in visible_inputs if x['type'] == 'password']\n        if password_inputs:\n            await password_inputs[0]['elem'].fill('Nftw1357')\n            print('   密码: Nftw1357')\n        \n        # 截图填写后\n        await page.screenshot(path='official_2_filled.png', full_page=True)\n        print('   截图: official_2_filled.png')\n        \n        # 点击登录按钮\n        print('4. 点击登录按钮...')\n        \n        # 查找登录按钮\n        buttons = await page.query_selector_all('button, input[type=\"button\"], input[type=\"submit\"], a.btn')\n        print(f'   找到 {len(buttons)} 个按钮')\n        \n        for btn in buttons:\n            try:\n                text = await btn.inner_text()\n                btn_type = await btn.get_attribute('type')\n                btn_class = await btn.get_attribute('class')\n                is_visible = await btn.is_visible()\n                if is_visible and (text.strip() or btn_type == 'submit'):\n                    print(f'   按钮: text=\"{text.strip()}\", type={btn_type}, class={btn_class}')\n            except:\n                pass\n        \n        # 尝试点击登录\n        login_selectors = [\n            'input[type=\"submit\"]',\n            'button[type=\"submit\"]',\n            '.login-btn',\n            'button:has-text(\"登录\")',\n            'input[value*=\"登录\"]',\n        ]\n        \n        for sel in login_selectors:\n            try:\n                elem = await page.query_selector(sel)\n                if elem and await elem.is_visible():\n                    await elem.click()\n                    print(f'   点击登录: {sel}')\n                    break\n            except:\n                pass\n        \n        # 等待登录完成\n        print('5. 等待登录完成...')\n        await asyncio.sleep(5)\n        \n        # 截图登录后\n        await page.screenshot(path='official_3_after_login.png', full_page=True)\n        print('   截图: official_3_after_login.png')\n        \n        # 查找预览菜单\n        print('6. 查找预览菜单...')\n        \n        all_links = await page.query_selector_all('a, button, .menu-item')\n        print(f'   找到 {len(all_links)} 个链接/菜单')\n        \n        menu_items = []\n        for link in all_links[:30]:\n            try:\n                text = await link.inner_text()\n                href = await link.get_attribute('href')\n                onclick = await link.get_attribute('onclick')\n                is_visible = await link.is_visible()\n                if is_visible and text.strip():\n                    menu_items.append({'text': text.strip(), 'href': href, 'onclick': onclick})\n                    print(f'   菜单: text=\"{text.strip()[:20]}\" href={href}')\n            except:\n                pass\n        \n        # 点击预览\n        print('7. 点击预览菜单...')\n        \n        for item in menu_items:\n            if '预览' in item['text'] or 'preview' in str(item['href']).lower():\n                try:\n                    await page.click(f'a:has-text(\"{item[\"text\"]}\")')\n                    print(f'   点击: {item[\"text\"]}')\n                    break\n                except:\n                    pass\n        \n        await asyncio.sleep(3)\n        \n        # 截图预览界面\n        await page.screenshot(path='official_4_preview.png', full_page=True)\n        print('   截图: official_4_preview.png')\n        \n        # 查找 PTZ 速度控制\n        print('8. 查找 PTZ 速度控制...')\n        \n        # 所有 input\n        inputs = await page.query_selector_all('input')\n        print(f'   找到 {len(inputs)} 个 input 元素')\n        \n        for i, inp in enumerate(inputs):\n            try:\n                is_visible = await inp.is_visible()\n                if is_visible:\n                    inp_type = await inp.get_attribute('type')\n                    inp_id = await inp.get_attribute('id')\n                    inp_min = await inp.get_attribute('min')\n                    inp_max = await inp.get_attribute('max')\n                    inp_value = await inp.get_attribute('value')\n                    print(f'   Input {i}: type={inp_type}, id={inp_id}, min={inp_min}, max={inp_max}, value={inp_value}')\n            except:\n                pass\n        \n        # 所有 select\n        selects = await page.query_selector_all('select')\n        print(f'   找到 {len(selects)} 个 select 元素')\n        \n        for i, sel in enumerate(selects):\n            try:\n                is_visible = await sel.is_visible()\n                if is_visible:\n                    sel_id = await sel.get_attribute('id')\n                    options = await sel.query_selector_all('option')\n                    opt_list = []\n                    for opt in options[:10]:\n                        val = await opt.get_attribute('value')\n                        text = await opt.inner_text()\n                        opt_list.append(f'{val}:{text}')\n                    print(f'   Select {i}: id={sel_id}, options=[{\", \".join(opt_list)}]')\n            except:\n                pass\n        \n        print()\n        print('=== 检查完成 ===')\n        print('截图保存:')\n        print('  - official_1_login.png')\n        print('  - official_2_filled.png')\n        print('  - official_3_after_login.png')\n        print('  - official_4_preview.png')\n        \n        # 保持浏览器打开\n        print()\n        print('浏览器保持打开 60 秒供手动检查...')\n        await asyncio.sleep(60)\n        \n        await browser.close()\n\nif __name__ == '__main__':\n    asyncio.run(check_official_ptz_speed())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\inspect_official_ptz.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":61169,"output":1737,"cacheRead":0,"cacheWrite":0,"totalTokens":62906,"cost":{"input":0.061168999999999994,"output":0.005558400000000001,"cacheRead