{"type":"message","id":"eb010802","parentId":"d14d75c6","timestamp":"2026-06-13T22:58:10.994Z","message":{"role":"assistant","content":[{"type":"text","text":"让我直接检查 ISAPI 端点是否正确："},{"type":"toolCall","id":"tool-2c4f26425a0349688eb96bd3b3b546cb","name":"exec","arguments":{"command":"cd astrohub; python -c \"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI'\n\nprint('=== 测试 ISAPI 端点 ===')\nprint()\n\n# 1. 测试 Color 端点 (亮度/对比度/饱和度)\nprint('1. Color 端点:')\nr = requests.get(f'{base}/Image/channels/1/Color', auth=auth, timeout=10, proxies={'http':None,'https':None})\nprint(f'   GET /Image/channels/1/Color: {r.status_code}')\nif r.status_code == 200:\n    print(f'   响应长度: {len(r.text)}')\n\n# 2. 测试 NoiseReduce 端点 (降噪)\nprint()\nprint('2. NoiseReduce 端点:')\nr = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\nprint(f'   GET /Image/channels/1/noiseReduce: {r.status_code}')\nif r.status_code == 200:\n    print(f'   响应长度: {len(r.text)}')\n    print(f'   内容片段: {r.text[:300]}')\n\n# 3. 测试其他可能的降噪端点\nprint()\nprint('3. 其他降噪端点:')\nendpoints = [\n    '/Image/channels/1/noiseReduction',\n    '/Image/channels/1/NoiseReduction',\n    '/Image/channels/1/denoise',\n    '/Image/channels/1/spatialDenoise',\n    '/Image/channels/1/temporalDenoise',\n]\nfor ep in endpoints:\n    r = requests.get(f'{base}{ep}', auth=auth, timeout=5, proxies={'http':None,'https':None})\n    print(f'   GET {ep}: {r.status_code}')\n\" 2>&1","timeout":30,"workdir":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":121977,"output":499,"cacheRead":0,"cacheWrite":0,"totalTokens":122476,"cost":{"input":0.12197699999999999,"output":0.0015968000000000002,"cacheRead":0,"cacheWrite":0,"total":0.12357379999999998}},"stopReason":