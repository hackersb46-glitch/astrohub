nuous_move(pan=pan, tilt=tilt)\n 2380         if success:\n 2381             LOG.log(\"done\", f\"PTZ 移动成功: device={ip} direction={direction} speed={speed}(档位)→isapi={isapi_speed}\")\n      ...","firstChangedLine":2362},"isError":false,"timestamp":1781385185096}}
{"type":"message","id":"5ea3c7b2","parentId":"13ffe857","timestamp":"2026-06-13T21:13:23.388Z","message":{"role":"assistant","content":[{"type":"text","text":"修复 Zoom 操作："},{"type":"toolCall","id":"call_25a24a634de8484fb3820be7","name":"edit","arguments":{"edits":[{"newText":"        # Zoom operations - 官方档位映射\n        # ISAPI continuous_move 速度范围: -100 到 100\n        if 1 <= speed <= 7:\n            speed_mapping = {1: 14, 2: 28, 3: 43, 4: 57, 5: 71, 6: 86, 7: 100}\n            isapi_speed = speed_mapping.get(speed, 57)\n        else:\n            isapi_speed = min(max(speed, 0), 100)","oldText":"        # Zoom operations - 官方档位映射\n        # 将 1-7 档映射到 ISAPI 速度值\n        if 1 <= speed <= 7:\n            speed_mapping = {1: 57, 2: 114, 3: 171, 4: 228, 5: 285, 6: 342, 7: 400}\n            isapi_speed = speed_mapping.get(speed, 228)\n        else:\n            isapi_speed = min(max(speed, 0), 400)"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":122540,"output":299,"cacheRead":0,"cacheWrite":0,"totalTokens":122839,"cost":{"input":0.12254,"output":0.0009568000000000001,"cacheRead":0,"cacheWrite":0,"total":0.12349679999999999}},"stopReason":"toolUse","timestamp":1781385185098,"responseId":"cht000df6ce@dx19ec2d4ed21b8ab282"}}
{"type":"message","id":"0c9587b8","parentId":"5ea3c7b2","timestamp":"2026-06-13T21:13:23.405Z","message":{"role":"toolResult","toolCallId":"call_25a24a634de8484fb3820be7","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 1 block(s) in C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py."}],"details":{"diff":"      ...\n 2329             LOG.log(\"failed\", f\"PTZ 移动失败: device={ip} reason={err}\")\n 2330             return {\"success\": False, \"message\": err}\n 2331 \n 2332         # Zoom operations - 官方档位映射\n-2333         # 将 1-7 档映射到 ISAPI 速度值\n+2333         # ISAPI continuous_move 速度范围: -100 到 100\n 2334         if 1 <= speed <= 7:\n-2335             speed_mapping = {1: 57, 2: 114, 3: 171, 4: 228, 5: 285, 6: 342, 7: 400}\n-2336             isapi_speed = speed_mapping.get(speed, 228)\n+2335             speed_mapping = {1: 14, 2: 28, 3: 43, 4: 57, 5: 71, 6: 86, 7: 100}\n+2336             isapi_speed = speed_mapping.get(speed, 57)\n 2337         else:\n-2338             isapi_speed = min(max(speed, 0), 400)\n+2338             isapi_speed = min(max(speed, 0), 100)\n 2339         \n 2340         if direction == \"zoom-in\":\n 2341             success = ctrl.continuous_move(pan=0, tilt=0, zoom=isapi_speed)\n 2342             return {\"success\": success, \"message\": f\"PTZ zoom-in (档位={speed})\", \"isapi_speed\": isapi_speed}\n      ...","firstChangedLine":2333},"isError":false,"timestamp":1781385203405}}
{"type":"message","id":"22cd0e7d","parentId":"0c9587b8","timestamp":"2026-06-13T21:13:46.192Z","message":{"role":"assistant","content":[{"type":"text","text":"现在验证修复效果："},{"type":"toolCall","id":"call_f8d112bbab77461a9a0ce8f3","name":"write","arguments":{"content":"\"\"\"验证档位映射修复\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI/PTZCtrl/channels/1'\n\ndef get_position():\n    r = requests.get(f'{base}/status', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        az = re.search(r'<azimuth>(\\d+)</azimuth>', r.text)\n        return {'azimuth': int(az.group(1)) if az else 0}\n    return None\n\ndef continuous_move(pan):\n    xml = f'<PTZData><pan>{pan}</pan><tilt>0</tilt><zoom>0</zoom></PTZData>'.encode('utf-8')\n    r = requests.put(f'{base}/continuous/', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\n    return r.status_code == 200\n\ndef goto_home():\n    r = requests.put(f'{base}/presets/10/goto', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    time.sleep(3)\n\nprint('='*50)\nprint('验证档位映射 (ISAPI速度范围: -100 到 100)')\nprint('='*50)\n\n# 档位映射\nspeed_mapping = {1: 14, 2: 28, 3: 43, 4: 57, 5: 71, 6: 86, 7: 100}\n\nprint('\\n测试各档位对应的ISAPI速度值:\\n')\n\nfor gear, isapi_speed in speed_mapping.items():\n    goto_home()\n    time.sleep(1)\n    \n    start = get_position()\n    continuous_move(pan=isapi_speed)\n    time.sleep(2)\n    continuous_move(0)\n    time.sleep(0.5)\n    end = get_position()\n    \n    delta = abs(end['azimuth'] - start['azimuth'])\n    if delta > 1800:  # 处理跳变\n        delta = 3600 - delta\n    \n    actual_speed = delta / 2\n    print(f'档位{gear}: ISAPI={isapi_speed}, 移动{delta}度, 速度{actual_speed:.0f}度/秒')\n\nprint('\\n验证完成!')\nprint('档位7(ISAPI=100)应达到设备最大速度(约400度/秒)')\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_gear_mapping.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":122890,"output":612,"cacheRead":0,"cacheWrite":0,"totalTokens":123502,"cost":{"input":0.12289,"output":0.0019584000000000003,"cacheRead":0,"cacheWrite":0,"total":0.1248484}},"stopReason":"toolUse","timestamp":1781385203408,"responseId":"cht000dff4a@dx19ec2d532f6b9ca102"}}
