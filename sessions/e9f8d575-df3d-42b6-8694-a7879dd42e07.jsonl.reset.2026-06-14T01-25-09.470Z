{"type":"message","id":"2acecd53","parentId":"cd5a0081","timestamp":"2026-06-13T21:19:18.890Z","message":{"role":"assistant","content":[{"type":"text","text":"修复 Zoom 操作："},{"type":"toolCall","id":"call_2d0d7747064e46a394ace9d3","name":"edit","arguments":{"edits":[{"newText":"        # Zoom operations - 官方档位映射\n        # 档位映射: 1→7, 2→14, 3→21, 4→29, 5→36, 6→43, 7→50\n        if 1 <= speed <= 7:\n            speed_mapping = {1: 7, 2: 14, 3: 21, 4: 29, 5: 36, 6: 43, 7: 50}\n            isapi_speed = speed_mapping.get(speed, 29)\n        else:\n            isapi_speed = min(max(speed, 0), 100)","oldText":"        # Zoom operations - 官方档位映射\n        # 档位映射: 1→5, 2→11, 3→16, 4→21, 5→27, 6→32, 7→37\n        if 1 <= speed <= 7:\n            speed_mapping = {1: 5, 2: 11, 3: 16, 4: 21, 5: 27, 6: 32, 7: 37}\n            isapi_speed = speed_mapping.get(speed, 21)\n        else:\n            isapi_speed = min(max(speed, 0), 100)"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":131416,"output":349,"cacheRead":0,"cacheWrite":0,"totalTokens":131765,"cost":{"input":0.131416,"output":0.0011168,"cacheRead":0,"cacheWrite":0,"total":0.1325328}},"stopReason":"toolUse","timestamp":1781385548908,"responseId":"cht000d3d72@dx19ec2da5914b9cb212"}}
