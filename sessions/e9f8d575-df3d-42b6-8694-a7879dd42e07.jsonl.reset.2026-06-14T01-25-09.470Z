{"type":"message","id":"3205df2b","parentId":"7a81f37d","timestamp":"2026-06-13T22:59:11.492Z","message":{"role":"assistant","content":[{"type":"text","text":"现在让我直接测试 ISAPI 设置白平衡 R/B 和降噪："},{"type":"toolCall","id":"call_b2c705406c6f4ce4808a4f8a","name":"write","arguments":{"content":"\"\"\"测试 ISAPI 白平衡和降噪设置\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI'\n\nprint('=== 测试 ISAPI 白平衡和降噪设置 ===')\nprint()\n\n# 1. 测试白平衡 R/B 设置\nprint('1. 测试白平衡 R/B 设置:')\nprint()\n\nfor i in range(5):\n    red_val = 80 + i * 20\n    blue_val = 60 + i * 15\n    \n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<WhiteBalanceStyle>manual</WhiteBalanceStyle>\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\n</WhiteBalance>'''\n    \n    r = requests.put(f'{base}/Image/channels/1/whiteBalance', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    # 验证\n    r2 = requests.get(f'{base}/Image/channels/1/whiteBalance', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    print(f'  测试 {i+1}: R={red_val}, B={blue_val}')\n    print(f'    PUT 状态: {r.status_code}')\n    print(f'    GET 验证: {r2.text[:150]}...')\n    \n    time.sleep(1)\n\nprint()\n\n# 2. 测试降噪设置\nprint('2. 测试降噪设置:')\nprint()\n\nfor i in range(5):\n    level = 30 + i * 15\n    \n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>general</mode>\n<GeneralMode>\n<generalLevel>{level}</generalLevel>\n</GeneralMode>\n</NoiseReduce>'''\n    \n    r = requests.put(f'{base}/Image/channels/1/noiseReduce', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    # 验证\n    r2 = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    print(f'  测试 {i+1}: level={level}')\n    print(f'    PUT 状态: {r.status_code}')\n    print(f'    GET 验证: {r2.text[:200]}...')\n    \n    time.sleep(1)\n\nprint()\nprint('=== 测试完成 ===')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_isapi_image.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":135410,"output":698,"cacheRead":0,"cacheWrite":0,"totalTokens":136108,"cost":{"input":0.13541,"output":0.0022336,"cacheRead":0,"cacheWrite":0,"total":0.1376436}},"stopReason":"toolUse","timestamp":1781391534399,"responseId":"cht000d93da@dx19ec335b142ba5e412"}}
