{"type":"message","id":"367fddb0","parentId":"78097548","timestamp":"2026-06-13T21:17:06.282Z","message":{"role":"assistant","content":[{"type":"text","text":"验证修复效果："},{"type":"toolCall","id":"call_e9261ca8792a4287ba306992","name":"write","arguments":{"content":"\"\"\"最终验证档位映射\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI/PTZCtrl/channels/1'\n\ndef get_position():\n    r = requests.get(f'{base}/status', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        az = re.search(r'<azimuth>(\\d+)</azimuth>', r.text)\n        return {'azimuth': int(az.group(1)) if az else 0}\n    return None\n\ndef continuous_move(pan):\n    xml = f'<PTZData><pan>{pan}</pan><tilt>0</tilt><zoom>0</zoom></PTZData>'.encode('utf-8')\n    r = requests.put(f'{base}/continuous/', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\n    return r.status_code == 200\n\ndef absolute_move(azimuth):\n    xml = f'<PTZData><AbsoluteHigh><azimuth>{azimuth}</azimuth><elevation>450</elevation><absoluteZoom>10</absoluteZoom></AbsoluteHigh></PTZData>'.encode('utf-8')\n    r = requests.put(f'{base}/absolute/', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\n    time.sleep(2)\n\nprint('='*60)\nprint('最终验证: 档位映射 (1→5, 2→11, 3→16, 4→21, 5→27, 6→32, 7→37)')\nprint('='*60)\n\nspeed_mapping = {1: 5, 2: 11, 3: 16, 4: 21, 5: 27, 6: 32, 7: 37}\n\nprint('\\n档位测试 (移动0.5秒):\\n')\nprint(f'{\"档位\":<6} {\"ISAPI\":<8} {\"移动\":<10} {\"速度(度/秒)\"}')\nprint('-'*50)\n\nfor gear, isapi in speed_mapping.items():\n    absolute_move(1800)\n    time.sleep(1)\n    \n    start = get_position()\n    continuous_move(pan=isapi)\n    time.sleep(0.5)\n    continuous_move(0)\n    time.sleep(0.3)\n    end = get_position()\n    \n    delta = abs(end['azimuth'] - start['azimuth'])\n    speed = delta * 2\n    \n    print(f'{gear:<6} {isapi:<8} {delta:<10} {speed}')\n\nprint()\nprint('预期: 档位7 ≈ 400度/秒 (panMaxSpeed)')\nprint('='*60)\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_final_mapping.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":127435,"output":682,"cacheRead":0,"cacheWrite":0,"totalTokens":128117,"cost":{"input":0.127435,"output":0.0021824,"cacheRead":0,"cacheWrite":0,"total":0.1296174}},"stopReason":"toolUse","timestamp":1781385402084,"responseId":"cht000d0ee2@dx19ec2d839b9ba5a412"}}
