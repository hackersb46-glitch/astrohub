{"type":"message","id":"1a1d5136","parentId":"d648c44e","timestamp":"2026-06-13T22:18:26.225Z","message":{"role":"assistant","content":[{"type":"text","text":"服务启动有问题。让我直接测试："},{"type":"toolCall","id":"call_6e66af0daa6f431db7d2f28c","name":"exec","arguments":{"command":"cd astrohub; python -c \"\nimport os\nimport sys\nsys.path.insert(0, '.')\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI/PTZCtrl/channels/1'\n\ndef get_pos():\n    r = requests.get(f'{base}/status', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        az = re.search(r'<azimuth>(\\d+)</azimuth>', r.text)\n        return int(az.group(1)) if az else 0\n    return 0\n\ndef abs_move(az):\n    xml = f'<PTZData><AbsoluteHigh><azimuth>{az}</azimuth><elevation>450</elevation><absoluteZoom>10</absoluteZoom></AbsoluteHigh></PTZData>'.encode('utf-8')\n    requests.put(f'{base}/absolute/', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\n    time.sleep(2)\n\n# 测试 ISAPI 直接调用\nprint('=== ISAPI PAN=100 直接调用 ===')\nabs_move(1800)\ntime.sleep(1)\nstart = get_pos()\nxml = b'<PTZData><pan>100</pan><tilt>0</tilt><zoom>0</zoom></PTZData>'\nrequests.put(f'{base}/continuous/', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\ntime.sleep(0.5)\nxml = b'<PTZData><pan>0</pan><tilt>0</tilt><zoom>0</zoom></PTZData>'\nrequests.put(f'{base}/continuous/', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\ntime.sleep(0.3)\nend = get_pos()\ndelta = abs(end - start)\nspeed_isapi = delta * 2\nprint(f'ISAPI PAN=100: {speed_isapi} 度/秒')\n\n# 测试 AstroHub ptz_move 方法\nprint()\nprint('=== AstroHub ptz_move 档位7 ===')\nfrom src.core.ptz_manager import PTZManager\nmgr = PTZManager()\n\nabs_move(1800)\ntime.sleep(1)\nstart = get_pos()\nmgr.ptz_move('192.168.5.72', direction='right', speed=7)\ntime.sleep(0.5)\nmgr.ptz_stop('192.168.5.72')\ntime.sleep(0.3)\nend = get_pos()\ndelta = abs(end - start)\nspeed_astrohub = delta * 2\nprint(f'AstroHub 档位7: {speed_astrohub} 度/秒')\n\nprint()\nprint('=== 对比 ===')\nprint(f'差异: {speed_isapi - speed_astrohub} 度/秒')\nif abs(speed_isapi - speed_astrohub) < 100:\n    print('修复成功！')\nelse:\n    print('还有问题！')\n\" 2>&1","timeout":60,"workdir":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":86246,"output":740,"cacheRead":0,"cacheWrite":0,"totalTokens":86986,"cost":{"input":0.08624599999999999,"output":0.0023680000000000003,"cacheRead":0,"cacheWrite":0,"total":0.08861399999999998}},"stopReason":"toolUse","timestamp":1781389091812,"responseId":"cht000dd394@dx19ec3106758b8ab282"}}
