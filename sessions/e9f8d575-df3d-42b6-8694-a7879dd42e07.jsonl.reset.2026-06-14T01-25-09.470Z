tilt><zoom>0</zoom><focus>0</focus>'\n            xml += '</ptzSpeed></PTZData>'\n            result = self.client.put(f\"{self._ptz_base()}/continuous\", xml)\n            return result.status_code == 200\n\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <ptzSpeed>\n    <pan>{pan_speed}</pan>\n    <tilt>{tilt_speed}</tilt>\n    <zoom>{zoom_speed}</zoom>\n    <focus>{focus_speed}</focus>\n  </ptzSpeed>\n</PTZData>\"\"\"\n        result = self.client.put(f\"{self._ptz_base()}/continuous\", xml)\n        return result.status_code == 200"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":51530,"output":891,"cacheRead":0,"cacheWrite":0,"totalTokens":52421,"cost":{"input":0.05153,"output":0.0028512000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0543812}},"stopReason":"toolUse","timestamp":1781382428948,"responseId":"cht000d4e1a@dx19ec2aac8a0ba5d322"}}
