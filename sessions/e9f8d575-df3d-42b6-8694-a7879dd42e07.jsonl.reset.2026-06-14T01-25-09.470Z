{"type":"message","id":"834220ca","parentId":"74b7b39f","timestamp":"2026-06-13T23:52:54.480Z","message":{"role":"assistant","content":[{"type":"text","text":"创建测试验证单独设置空域或时域："},{"type":"toolCall","id":"call_554458caaa234367a23f9a45","name":"write","arguments":{"content":"\"\"\"测试单独设置空域或时域降噪\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI'\n\nprint('=== 测试单独设置空域或时域降噪 ===')\nprint()\n\n# 先设置一个初始状态\nxml = b'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>advanced</mode>\n<AdvancedMode>\n<FrameNoiseReduceLevel>50</FrameNoiseReduceLevel>\n<InterFrameNoiseReduceLevel>50</InterFrameNoiseReduceLevel>\n</AdvancedMode>\n</NoiseReduce>'''\nr = requests.put(f'{base}/Image/channels/1/noiseReduce', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\nprint(f'初始状态: 空域=50, 时域=50')\nprint()\n\n# 测试1: 只改空域，时域保持\nprint('测试1: 只设置空域=70，时域应保持50')\nxml1 = b'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>advanced</mode>\n<AdvancedMode>\n<FrameNoiseReduceLevel>70</FrameNoiseReduceLevel>\n<InterFrameNoiseReduceLevel>50</InterFrameNoiseReduceLevel>\n</AdvancedMode>\n</NoiseReduce>'''\nr = requests.put(f'{base}/Image/channels/1/noiseReduce', data=xml1, auth=auth, timeout=10, proxies={'http':None,'https':None})\nr2 = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\nspatial = re.search(r'<FrameNoiseReduceLevel>(\\d+)</FrameNoiseReduceLevel>', r2.text)\ntemporal = re.search(r'<InterFrameNoiseReduceLevel>(\\d+)</InterFrameNoiseReduceLevel>', r2.text)\nprint(f'  结果: 空域={spatial.group(1)}, 时域={temporal.group(1)}')\ntest1 = spatial.group(1) == '70' and temporal.group(1) == '50'\nprint(f'  验证: {\"PASS\" if test1 else \"FAIL\"}')\nprint()\n\ntime.sleep(1)\n\n# 测试2: 只改时域，空域保持\nprint('测试2: 只设置时域=80，空域应保持70')\nxml2 = b'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>advanced</mode>\n<AdvancedMode>\n<FrameNoiseReduceLevel>70</FrameNoiseReduceLevel>\n<InterFrameNoiseReduceLevel>80</InterFrameNoiseReduceLevel>\n</AdvancedMode>\n</NoiseReduce>'''\nr = requests.put(f'{base}/Image/channels/1/noiseReduce', data=xml2, auth=auth, timeout=10, proxies={'http':None,'https':None})\nr2 = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\nspatial = re.search(r'<FrameNoiseReduceLevel>(\\d+)</FrameNoiseReduceLevel>', r2.text)\ntemporal = re.search(r'<InterFrameNoiseReduceLevel>(\\d+)</InterFrameNoiseReduceLevel>', r2.text)\nprint(f'  结果: 空域={spatial.group(1)}, 时域={temporal.group(1)}')\ntest2 = spatial.group(1) == '70' and temporal.group(1) == '80'\nprint(f'  验证: {\"PASS\" if test2 else \"FAIL\"}')\nprint()\n\nprint('=== 测试总结 ===')\nprint(f'测试1: {\"PASS\" if test1 else \"FAIL\"}')\nprint(f'测试2: {\"PASS\" if test2 else \"FAIL\"}')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_nr_single.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":69355,"output":984,"cacheRead":0,"cacheWrite":0,"totalTokens":70339,"cost":{"input":0.069355,"output":0.0031488,"cacheRead":0,"cacheWrite":0,"total":0.07250380000000001}},"stopReason":"toolUse","timestamp":1781394737508,"responseId":"cht000d951d@dx19ec3668f72ba5e412"}}
