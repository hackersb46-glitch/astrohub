{"type":"message","id":"d9222320","parentId":"457c3559","timestamp":"2026-06-13T20:21:26.945Z","message":{"role":"toolResult","toolCallId":"tool-e6a0f9c34efa4d15911c9c2e778ee1ac","toolName":"exec","content":[{"type":"text","text":"review\r\nchangelog_dev.md\r\ncode_issues_report.md\r\ndata_storage.md\r\ndev_log_20260522.md\r\ndev_notes.md\r\nfrontend_spec.md\r\nlearnings.md\r\nm1_method_extract.md\r\nM1_method_source.csv\r\nM1_method.csv\r\nM1_review_source.csv\r\npitfalls.md\r\nPTZ_FUNCTION_source.py\r\nPTZ_LIMIT_source.py\r\nptzhelper_source.py\r\nspeed_test_spec.md\r\nstep4_probe_source.py\r\nstep5_function_source.py\r\nwasm_video_stream.md\r\nreview\\m1_speed_method.csv"}],"details":{"status":"completed","exitCode":0,"durationMs":407,"aggregated":"review\r\nchangelog_dev.md\r\ncode_issues_report.md\r\ndata_storage.md\r\ndev_log_20260522.md\r\ndev_notes.md\r\nfrontend_spec.md\r\nlearnings.md\r\nm1_method_extract.md\r\nM1_method_source.csv\r\nM1_method.csv\r\nM1_review_source.csv\r\npitfalls.md\r\nPTZ_FUNCTION_source.py\r\nPTZ_LIMIT_source.py\r\nptzhelper_source.py\r\nspeed_test_spec.md\r\nstep4_probe_source.py\r\nstep5_function_source.py\r\nwasm_video_stream.md\r\nreview\\m1_speed_method.csv","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781382086945}}
{"type":"message","id":"1e0845da","parentId":"d9222320","timestamp":"2026-06-13T20:21:32.574Z","message":{"role":"assistant","content":[{"type":"text","text":"..."},{"type":"toolCall","id":"call_21e92560727347f8bdafc1e1","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\PTZ_FUNCTION_source.py"}},{"type":"toolCall","id":"call_ec0a72870e364853b20f7ccf","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\step5_function_source.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":20622,"output":68,"cacheRead":0,"cacheWrite":0,"totalTokens":20690,"cost":{"input":0.020621999999999998,"output":0.00021760000000000003,"cacheRead":0,"cacheWrite":0,"total":0.020839599999999996}},"stopReason":"toolUse","timestamp":1781382086946,"responseId":"cht000daa57@dx19ec2a58226b85e102"}}
{"type":"message","id":"186bc4d2","parentId":"1e0845da","timestamp":"2026-06-13T20:21:32.585Z","message":{"role":"toolResult","toolCallId":"call_21e92560727347f8bdafc1e1","toolName":"read","content":[{"type":"text","text":"# -*- coding: utf-8 -*-\r\n\"\"\"\r\nPTZ_FUNCTION.py - PTZ Function Test Script\r\nReads from PTZ_CONFIG.json -> tests endpoints -> appends record to PTZ_CONFIG.json\r\nOutput: endpoint report in PTZ_CONFIG.json records\r\n\"\"\"\r\n\r\nimport sys, os, time, json\r\nfrom datetime import datetime\r\n\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\nfrom ptzhelper import (\r\n    log_init, log_info, log_warn, log_err, log_done, log_fail,\r\n    PTZHelper, load_device_config, save_device_config,\r\n    authenticate, safe_input, wait_stable,\r\n    safe_write_json, safe_read_json,\r\n    PTZ_CONFIG_FILE, append_record\r\n)\r\n\r\nSCRIPT_VERSION = 'v2.0'\r\nPROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))\r\n\r\n# ===== Load from PTZ_CONFIG =====\r\ndef load_from_ptz_config():\r\n    \"\"\"Load IP/auth from PTZ_CONFIG.json\"\"\"\r\n    data = safe_read_json(PTZ_CONFIG_FILE)\r\n    if not data:\r\n        log_err('PTZ_CONFIG.json not found, run PTZ_STARTUP first')\r\n        sys.exit(1)\r\n    ip = data.get('device_ip')\r\n    username = data.get('username', 'admin')\r\n    if not ip:\r\n        log_err('device_ip not found in PTZ_CONFIG.json')\r\n        sys.exit(1)\r\n    return data\r\n\r\n# ===== Endpoint probe =====\r\ndef test_endpoints(ip, auth):\r\n    log_info('========== Endpoint Probe ==========')\r\n    ptz = PTZHelper(ip, auth)\r\n    sess = ptz.session\r\n    sess.trust_env = False\r\n    ptz._clear_proxy()\r\n\r\n    endpoints = [\r\n        ('/ISAPI/System/deviceInfo',           'GET',  'Device Info'),\r\n        ('/ISAPI/PTZCtrl/channels/1/status',   'GET',  'PTZ Status'),\r\n        ('/ISAPI/PTZCtrl/channels/1/capabilities', 'GET', 'PTZ Capabilities'),\r\n        ('/ISAPI/Image/channels/1/color',      'GET',  'Image Color'),\r\n        ('/ISAPI/Image/channels/1/exposure',   'GET',  'Image Exposure'),\r\n        ('/ISAPI/Image/channels/1/whiteBalance','GET', 'White Balance'),\r\n        ('/ISAPI/Streaming/channels/1',        'GET',  'Stream Channel'),\r\n        ('/ISAPI/System/Network/interfaces',    'GET',  'Network Interface'),\r\n    ]\r\n\r\n    results = []\r\n    all_pass = True\r\n    for ep, method, desc in endpoints:\r\n        try:\r\n            if method == 'GET':\r\n                r = sess.get(f'http://{ip}{ep}', auth=ptz.auth, timeout=10)\r\n            else:\r\n                r = sess.put(f'http://{ip}{ep}', auth=ptz.auth, timeout=10)\r\n            ok = r.status_code in (200, 404, 400)\r\n            results.append({'endpoint': ep, 'method': method, 'desc': desc,\r\n                           'status_code': r.status_code, 'ok': ok})\r\n            if ok:\r\n                log_done(f'{method} {ep} -> {r.status_code} ({desc})')\r\n            else:\r\n                log_err(f'{method} {ep} -> {r.status_code} ({desc})')\r\n                all_pass = False\r\n        except Exception as e:\r\n            results.append({'endpoint': ep, 'method': method, 'desc': desc,\r\n                           'error': str(e), 'ok': False})\r\n            log_err(f'{method} {ep} -> ERROR: {e}')\r\n            all_pass = False\r\n\r\n    log_done(f'Endpoint probe done: {sum(1 for r in results if r[\"ok\"])}/{len(results)} passed')\r\n    return results, all_pass\r\n\r\n# ===== Basic motion test =====\r\ndef test_basic_motion(ip, auth):\r\n    log_info('========== Basic Motion Test ==========')\r\n    ptz = PTZHelper(ip, auth)\r\n\r\n    # HOME position\r\n    log_info('P5.0: HOME preset')\r\n    ptz.preset_goto(10)\r\n    wait_stable(ptz)\r\n    status = ptz.get_status()\r\n    log_info(f'P5.0: HOME az={status[\"azimuth\"]} el={status[\"elevation\"]} zoom={status[\"zoom\"]}')\r\n\r\n    # Save preset\r\n    log_info('P5.1: Save preset 10')\r\n    ok = ptz.save_preset(10, 'HOME')\r\n    log_done(f'P5.1: Save preset -> {\"OK\" if ok else \"FAIL\"}')\r\n\r\n    # Continuous move\r\n    log_info('P5.2: Continuous move test')\r\n    for pan, tilt, label in [(5, 0, 'Right'), (-5, 0, 'Left'), (0, 5, 'Up'), (0, -5, 'Down')]:\r\n        ok = ptz.continuous_move(pan=pan, tilt=tilt, zoom=0)\r\n        time.sleep(0.5)\r\n        ptz.stop()\r\n        log_info(f'  {label} -> {\"OK\" if ok else \"FAIL\"}')\r\n\r\n    # Return HOME\r\n    ptz.preset_goto(10)\r\n    wait_stable(ptz)\r\n    log_done('P5.3: Return HOME')\r\n\r\n    return True\r\n\r\n# ===== MAIN =====\r\ndef main():\r\n    print(f'PTZ_FUNCTION {SCRIPT_VERSION} - PTZ Function Test')\r\n    print('=' * 50)\r\n    log_init()\r\n    log_info(f'START PTZ_FUNCTION {SCRIPT_VERSION}')\r\n\r\n    # Load from PTZ_CONFIG.json\r\n    ptz_data = load_from_ptz_config()\r\n    ip = ptz_data['device_ip']\r\n    auth = (ptz_data.get('username', 'admin'), ptz_data.get('password', ''))\r\n    log_info(f'Loaded from PTZ_CONFIG: {ip}')\r\n\r\n    # Auth (try saved first, fallback to interactive)\r\n    auth_result = authenticate(ip)\r\n    if auth_result is not None:\r\n        auth = auth_result\r\n\r\n    # Endpoint probe\r\n    endpoint_results, ep_all_pass = test_endpoints(ip, auth)\r\n\r\n    # Basic motion test\r\n    motion_ok = test_basic_motion(ip, auth)\r\n\r\n    # Capabilities text (for PTZ_CONFIG notes)\r\n    ptz = PTZHelper(ip, auth)\r\n    cap_text = ptz.get_capabilities()\r\n\r\n    # Build record\r\n    record = {\r\n        'script': 'PTZ_FUNCTION',\r\n        'version': SCRIPT_VERSION,\r\n        'timestamp': datetime.now().isoformat(),\r\n        'result': 'PASS' if (ep_all_pass and motion_ok) else 'FAIL',\r\n        'notes': {\r\n            'endpoint_pass_count': sum(1 for r in endpoint_results if r['ok']),\r\n            'endpoint_total': len(endpoint_results),\r\n            'motion_test': 'PASS' if motion_ok else 'FAIL',\r\n            'capabilities_length': len(cap_text),\r\n            'endpoints': endpoint_results,\r\n        }\r\n    }\r\n\r\n    # Append record to PTZ_CONFIG.json\r\n    append_record(PTZ_CONFIG_FILE, record)\r\n    log_info(f'Record appended to PTZ_CONFIG.json')\r\n    log_info(f'Result: endpoints={\"PASS\" if ep_all_pass else \"FAIL\"}, motion={\"PASS\" if motion_ok else \"FAIL\"}')\r\n\r\n    log_info('========== DONE ==========')\r\n    safe_input('Press Enter to exit...')\r\n\r\nif __name__ == '__main__':\r\n    try:\r\n        main()\r\n    except KeyboardInterrupt:\r\n        log_info('Interrupted, exit')\r\n    except Exception as e:\r\n        log_err(f'MAIN exception: {e}')\r\n"}],"isError":false,"timestamp":1781382092585}}
{"type":"message","id":"b16043f4","parentId":"186bc4d2","timestamp":"2026-06-13T20:21:32.585Z","message":{"role":"toolResult","toolCallId":"call_ec0a72870e364853b20f7ccf","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"\nStep 5: FUNCTION - PTZ 基础运动功能测试 (P5)\nP5.0: HOME preset (preset 10 at 1800/450/10)\nP5.1: Continuous Move (pan=50/tilt=50, 2s, 0.1s sampling)\nP5.2: Absolute Move (P/T +10 from current)\nP5.3: Relative Move (check support)\nP5.4: Pan speed control (1/50/100, 2s each)\nP5.5: ZOOM range (min/max)\nP5.6: Device restore\n\"\"\"\nimport sys, os, time, json, csv\nfrom datetime import datetime\n\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\nfrom ptzhelper import PTZHelper, log_init, log_info, log_done, log_fail, log_warn, wait_stable, PTZ_CONFIG_FILE, safe_read_json, safe_write_json, append_record\n\nDEVICE_IP = '192.168.5.65'\nUSERNAME = 'admin'\nPASSWORD = 'Nftw1357'\nHOME_POS = {'azimuth': 1800, 'elevation': 450, 'zoom': 10}\nRECORD_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'record')\nos.makedirs(RECORD_DIR, exist_ok=True)\n\nptz = PTZHelper(DEVICE_IP, (USERNAME, PASSWORD))\ncsv_file = None\ncsv_writer = None\nall_results = []\n\n\ndef open_csv(name):\n    global csv_file, csv_writer\n    ts = datetime.now().strftime('%Y%m%d_%H%M%S')\n    path = os.path.join(RECORD_DIR, f'{name}_{ts}.csv')\n    csv_file = open(path, 'w', newline='', encoding='utf-8')\n    csv_writer = csv.writer(csv_file)\n    csv_writer.writerow(['timestamp_ms', 'azimuth', 'elevation', 'zoom', 'label'])\n    csv_file.flush()\n    return path\n\n\ndef record_sample(label=''):\n    s = ptz.get_status()\n    ts = int(time.time() * 1000)\n    row = [ts, s['azimuth'], s['elevation'], s['zoom'], label]\n    if csv_writer:\n        csv_writer.writerow(row)\n        csv_file.flush()\n    return s\n\n\ndef close_csv():\n    global csv_file, csv_writer\n    if csv_file:\n        csv_file.close()\n        csv_file = None\n        csv_writer = None\n\n\ndef goto_home_stable():\n    log_info('  -> Go to HOME preset 10')\n    ptz.preset_goto(10)\n    time.sleep(3)\n    wait_stable(ptz)\n    s = ptz.get_status()\n    log_info(f'  HOME: az={s[\"azimuth\"]} el={s[\"elevation\"]} zoom={s[\"zoom\"]}')\n    return s\n\n\ndef test_home_preset():\n    \"\"\"P5.0: Setup preset 10 as HOME (1800/450/10)\"\"\"\n    log_info('\\n--- P5.0: HOME Preset Setup ---')\n    csv_path = open_csv('p50_home_preset')\n\n    # Move to HOME via absolute\n    log_info('  Moving to HOME (1800, 450, 10)...')\n    if not ptz.absolute_move(HOME_POS['azimuth'], HOME_POS['elevation'], HOME_POS['zoom']):\n        log_fail('Absolute move to HOME failed')\n        close_csv()\n        return False\n    time.sleep(5)\n    wait_stable(ptz)\n\n    # Verify position\n    status = record_sample('after_absolute_home')\n    log_info(f'  Position: az={status[\"azimuth\"]} el={status[\"elevation\"]} zoom={status[\"zoom\"]}')\n\n    # Verify position is exactly 1800/450/10 (0 deviation)\n    if status['azimuth'] != HOME_POS['azimuth'] or status['elevation'] != HOME_POS['elevation'] or status['zoom'] != HOME_POS['zoom']:\n        log_warn(f'  Position deviation: expected az=1800 el=450 zoom=10, got az={status[\"azimuth\"]} el={status[\"elevation\"]} zoom={status[\"zoom\"]}')\n\n    # Save as preset 10\n    log_info('  Saving preset 10 as HOME...')\n    if not ptz.save_preset(10, 'HOME'):\n        log_fail('Save preset 10 failed')\n        close_csv()\n        return False\n\n    # Verify by going to preset 10\n    log_info('  Verifying preset 10 goto...')\n    ptz.preset_goto(10)\n    time.sleep(3)\n    wait_stable(ptz)\n    verify = record_sample('after_goto_preset10')\n    log_info(f'  After goto: az={verify[\"azimuth\"]} el={verify[\"elevation\"]} zoom={verify[\"zoom\"]}')\n\n    close_csv()\n    log_done('P5.0: Preset 10 saved as HOME')\n    all_results.append({'test': 'P5.0 HOME preset', 'pass': True,\n                        'position': {'azimuth': verify['azimuth'], 'elevation': verify['elevation'], 'zoom': verify['zoom']},\n                        'csv': csv_path})\n    return True\n\n\ndef test_continuous_move():\n    \"\"\"P5.1: Continuous pan=50/tilt=50 for 2s, 0.1s sampling\"\"\"\n    log_info('\\n--- P5.1: Continuous Move Test ---')\n    goto_home_stable()\n    csv_path = open_csv('p51_continuous_move')\n\n    tests = [\n        ('Pan_Right', {'pan': 50, 'tilt': 0}),\n        ('Pan_Left', {'pan': -50, 'tilt': 0}),\n        ('Tilt_Up', {'pan': 0, 'tilt': 50}),\n        ('Tilt_Down', {'pan': 0, 'tilt': -50}),\n    ]\n\n    for name, params in tests:\n        log_info(f'  Testing: {name}')\n        start = record_sample(f'{name}_start')\n\n        if not ptz.continuous_move(**params):\n            log_fail(f'{name} command failed')\n            close_csv()\n            return False\n\n        # 2s movement with 0.1s sampling = 20 samples\n        for i in range(20):\n            time.sleep(0.1)\n            record_sample(f'{name}_moving_{i}')\n\n        ptz.stop()\n        time.sleep(0.5)\n        end = record_sample(f'{name}_end')\n\n        moved = abs(end['azimuth'] - start['azimuth']) > 0 or abs(end['elevation'] - start['elevation']) > 0\n        log_info(f'    start: az={start[\"azimuth\"]} el={start[\"elevation\"]} -> end: az={end[\"azimuth\"]} el={end[\"elevation\"]} | moved={moved}')\n        if not moved:\n            log_warn(f'    No movement detected for {name}')\n        else:\n            log_info(f'    Movement successful')\n\n    # Return HOME\n    goto_home_stable()\n    close_csv()\n    log_done('P5.1: Continuous Move tests passed')\n    all_results.append({'test': 'P5.1 Continuous Move', 'pass': True, 'csv': csv_path})\n    return True\n\n\ndef test_absolute_move():\n    \"\"\"P5.2: Absolute Move - P/T +10 from current, return HOME\"\"\"\n    log_info('\\n--- P5.2: Absolute Move Test ---')\n    home = goto_home_stable()\n    csv_path = open_csv('p52_absolute_move')\n\n    # Move to offset positions (+10 on P and T)\n    targets = [\n        ('plus_10', home['azimuth'] + 100, home['elevation'] + 50, home['zoom']),\n        ('minus_10', home['azimuth'] - 100, home['elevation'] - 50, home['zoom']),\n    ]\n\n    for label, az, el, zm in targets:\n        log_info(f'  Absolute move {label}: az={az} el={el}')\n        record_sample(f'{label}_start')\n        if not ptz.absolute_move(az, el, zm):\n            log_fail(f'Absolute move {label} failed')\n            close_csv()\n            return False\n        time.sleep(3)\n        wait_stable(ptz)\n        s = record_sample(f'{label}_end')\n        log_info(f'    Result: az={s[\"azimuth\"]} el={s[\"elevation\"]} zoom={s[\"zoom\"]}')\n\n    # Return HOME\n    goto_home_stable()\n    close_csv()\n    log_done('P5.2: Absolute Move tests passed')\n    all_results.append({'test': 'P5.2 Absolute Move', 'pass': True, 'csv': csv_path})\n    return True\n\n\ndef test_relative_move():\n    \"\"\"P5.3: Relative Move - check if device supports it\"\"\"\n    log_info('\\n--- P5.3: Relative Move Test ---')\n    goto_home_stable()\n    csv_path = open_csv('p53_relative_move')\n\n    # Try relative move with +100 azimuth, +50 elevation\n    log_info('  Testing relative move (az=+100, el=+50)...')\n    start = record_sample('relative_start')\n    ok = ptz.relative_move(100, 50, 0)\n    log_info(f'  Relative move command: {\"OK\" if ok else \"NOT SUPPORTED\"}')\n\n    if ok:\n        time.sleep(3)\n        wait_stable(ptz)\n        end = record_sample('relative_end')\n        log_info(f'    start: az={start[\"azimuth\"]} el={start[\"elevation\"]} -> end: az={end[\"azimuth\"]} el={end[\"elevation\"]}')\n\n        # Return HOME\n        goto_home_stable()\n    else:\n        log_info('  Device does not support Relative Move (this is acceptable - no requirement)')\n\n    close_csv()\n    log_done(f'P5.3: Relative Move {\"supported\" if ok else \"not supported\"} (no requirement)')\n    all_results.append({'test': 'P5.3 Relative Move', 'pass': True, 'supported': ok, 'csv': csv_path})\n    return True\n\n\ndef test_pan_speed():\n    \"\"\"P5.4: Pan speed at 1/50/100, 2s each, monitor coordinate change\"\"\"\n    log_info('\\n--- P5.4: Pan Speed Control Test ---')\n    goto_home_stable()\n    csv_path = open_csv('p54_pan_speed')\n\n    speeds = [1, 50, 100]\n    for speed in speeds:\n        log_info(f'  Testing pan speed={speed}')\n        start = record_sample(f'speed_{speed}_start')\n\n        if not ptz.continuous_move(pan=speed, tilt=0):\n            log_fail(f'Pan speed={speed} command failed')\n            close_csv()\n            return False\n\n        # 2s movement, 0.1s sampling\n        for i in range(20):\n            time.sleep(0.1)\n            record_sample(f'speed_{speed}_moving_{i}')\n\n        ptz.stop()\n        time.sleep(0.5)\n        end = record_sample(f'speed_{speed}_end')\n        delta = abs(end['azimuth'] - start['azimuth'])\n        log_info(f'    start={start[\"azimuth\"]} end={end[\"azimuth\"]} delta={delta}')\n        log_info(f'    Speed {speed}: delta_az={delta} in 2s')\n\n        # Return HOME between tests\n        goto_home_stable()\n\n    # Test negative direction\n    for speed in speeds:\n        log_info(f'  Testing pan speed=-{speed}')\n        start = record_sample(f'speed_neg{speed}_start')\n\n        if not ptz.continuous_move(pan=-speed, tilt=0):\n            log_fail(f'Pan speed=-{speed} command failed')\n            close_csv()\n            return False\n\n        for i in range(20):\n            time.sleep(0.1)\n            record_sample(f'speed_neg{speed}_moving_{i}')\n\n        ptz.stop()\n        time.sleep(0.5)\n        end = record_sample(f'speed_neg{speed}_end')\n        delta = abs(end['azimuth'] - start['azimuth'])\n        log_info(f'    start={start[\"azimuth\"]} end={end[\"azimuth\"]} delta={delta}')\n\n        goto_home_stable()\n\n    close_csv()\n    log_done('P5.4: Pan speed control tests passed - device supports speed variation')\n    all_results.append({'test': 'P5.4 Pan Speed Control', 'pass': True, 'csv': csv_path})\n    return True\n\n\ndef test_zoom_range():\n    \"\"\"P5.5: Test ZOOM range - find min/max\"\"\"\n    log_info('\\n--- P5.5: ZOOM Range Test ---')\n    goto_home_stable()\n    csv_path = open_csv('p55_zoom_range')\n\n    # Try zoom to max (320)\n    log_info('  Zoom to max (320)...')\n    record_sample('zoom_max_start')\n    if not ptz.absolute_move_zoom(320):\n        log_warn('  absolute_move_zoom(320) failed, trying lower')\n        for z in [300, 250, 200, 150, 100]:\n            if ptz.absolute_move_zoom(z):\n                log_info(f'  Zoom max found: {z}')\n                break\n    time.sleep(5)\n    s_max = record_sample('zoom_max_end')\n    log_info(f'  Position at max zoom: az={s_max[\"azimuth\"]} el={s_max[\"elevation\"]} zoom={s_max[\"zoom\"]}')\n\n    # Zoom to min (10)\n    log_info('  Zoom to min (10)...')\n    goto_home_stable()\n    if not ptz.absolute_move_zoom(10):\n        log_warn('  absolute_move_zoom(10) failed')\n    time.sleep(5)\n    s_min = record_sample('zoom_min_end')\n    log_info(f'  Position at min zoom: az={s_min[\"azimuth\"]} el={s_min[\"elevation\"]} zoom={s_min[\"zoom\"]}')\n\n    # Zoom to mid\n    mid = (s_min['zoom'] + s_max['zoom']) // 2\n    log_info(f'  Zoom to mid ({mid})...')\n    ptz.absolute_move_zoom(mid)\n    time.sleep(5)\n    s_mid = record_sample('zoom_mid_end')\n    log_info(f'  Position at mid zoom: az={s_mid[\"azimuth\"]} el={s_mid[\"elevation\"]} zoom={s_mid[\"zoom\"]}')\n\n    close_csv()\n    zoom_info = {'min': s_min['zoom'], 'max': s_max['zoom'], 'mid': s_mid['zoom']}\n    log_done(f'P5.5: ZOOM range tested - min={zoom_info[\"min\"]} max={zoom_info[\"max\"]} mid={zoom_info[\"mid\"]}')\n    all_results.append({'test': 'P5.5 ZOOM Range', 'pass': True, 'zoom': zoom_info, 'csv': csv_path})\n    return True\n\n\ndef restore_device():\n    \"\"\"P5.6: Device restore - return to HOME and restore defaults\"\"\"\n    log_info('\\n--- P5.6: Device Restore ---')\n    goto_home_stable()\n    restore_ok = ptz.restore_all_defaults()\n    log_info(f'  Restore defaults: {\"OK\" if restore_ok else \"partial\"}' if isinstance(restore_ok, bool) else f'  Restore defaults results: {restore_ok}')\n    log_done('P5.6: Device restored')\n    all_results.append({'test': 'P5.6 Device Restore', 'pass': True})\n    return True\n\n\ndef print_summary():\n    print(f'\\n{\"=\"*70}')\n    print('  P5 FUNCTION TEST SUMMARY')\n    print(f'{\"=\"*70}')\n    passed = 0\n    failed = 0\n    for r in all_results:\n        status = 'PASS' if r['pass'] else 'FAIL'\n        if r['pass']:\n            passed += 1\n        else:\n            failed += 1\n        print(f'  [{status}] {r[\"test\"]}')\n    print(f'{\"=\"*70}')\n    print(f'  Total: {len(all_results)}, Passed: {passed}, Failed: {failed}')\n    print(f'{\"=\"*70}')\n    return failed == 0\n\n\ndef main():\n    print(f'{\"=\"*70}')\n    print('  Step 5: FUNCTION - PTZ Motion Function Test (P5)')\n    print(f'  Device: {DEVICE_IP} ({USERNAME}@{DEVICE_IP})')\n    print(f'  HOME position: az={HOME_POS[\"azimuth\"]} el={HOME_POS[\"elevation\"]} zoom={HOME_POS[\"zoom\"]}')\n    print(f'{\"=\"*70}')\n\n    overall = True\n\n    # P5.0\n    if overall:\n        overall = test_home_preset()\n    else:\n        log_warn('Skipping P5.1-P5.6 due to prior failure')\n\n    # P5.1\n    if overall:\n        goto_home_stable()\n        overall = test_continuous_move()\n    else:\n        log_warn('Skipping P5.2-P5.6 due to prior failure')\n\n    # P5.2\n    if overall:\n        overall = test_absolute_move()\n    else:\n        log_warn('Skipping P5.3-P5.6 due to prior failure')\n\n    # P5.3\n    if overall:\n        overall = test_relative_move()\n    else:\n        log_warn('Skipping P5.4-P5.6 due to prior failure')\n\n    # P5.4\n    if overall:\n        overall = test_pan_speed()\n    else:\n        log_warn('Skipping P5.5-P5.6 due to prior failure')\n\n    # P5.5\n    if overall:\n        overall = test_zoom_range()\n    else:\n        log_warn('Skipping P5.6 due to prior failure')\n\n    # P5.6\n    restore_device()\n\n    # Summary\n    result = print_summary()\n    print(f'\\n{\"=\"*70}')\n    if result:\n        print('  [PASS] Step 5 FUNCTION - All P5 tests passed')\n    else:\n        print('  [FAIL] Step 5 FUNCTION - Some tests failed')\n    print(f'{\"=\"*70}')\n    return result\n\n\nif __name__ == '__main__':\n    log_init()\n    log_info('START Step 5 FUNCTION test')\n    result = main()\n    log_info(f'Step 5 result: {\"PASS\" if result else \"FAIL\"}')\n    sys.exit(0 if result else 1)\n"}],"isError":false,"timestamp":1781382092585}}
{"type":"message","id":"805cdb87","parentId":"b16043f4","timestamp":"2026-06-13T20:21:38.559Z","message":{"role":"assistant","content":[{"type":"text","text":"让我继续查看 ISAPI 相关文档和当前代码："},{"type":"toolCall","id":"tool-4ba75d1ba4504750b6b71e50b2d204eb","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\advanced\\speed.py"}},{"type":"toolCall","id":"tool-01c45d62407e4ff49347f290a0d46cc9","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\advanced\\function.py"}},{"type":"toolCall","id":"tool-932aeb70a612420b96197822f79f41cb","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\doc\\ptzhelper_source.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":26274,"output":108,"cacheRead":0,"cacheWrite":0,"totalTokens":26382,"cost":{"input":0.026274,"output":0.00034560000000000005,"cacheRead":0,"cacheWrite":0,"total":0.0266196}},"stopReason":"toolUse","timestamp":1781382092586,"responseId":"cht000dc14c@dx19ec2a59bebba5c342"}}
{"type":"message","id":"aed99ee9","parentId":"805cdb87","timestamp":"2026-06-13T20:21:38.582Z","message":{"role":"toolResult","toolCallId":"tool-4ba75d1ba4504750b6b71e50b2d204eb","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nAstroHub v2.0 - 速度测试模块 (Speed Testing)\r\n\r\n实现速度测试:\r\n- measure_speed_single: 单点速度测量\r\n- post_process_csv: 数据后处理\r\n- run_all_tests: 完整测试流程\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport csv\r\nimport time\r\nfrom datetime import datetime\r\nfrom pathlib import Path\r\nfrom typing import Any\r\n\r\nfrom src.advanced.device_path import get_device_info, get_data_path_read, get_data_path_write, get_devices_dir\r\n\r\ndef _print(msg: str = \"\", end: str = \"\\n\"):\r\n    \"\"\"静默可控的print。\"\"\"\r\n    import src.ptz.core.logger as logger_module\r\n    if not getattr(logger_module.LOG, 'silent', False):\r\n        print(msg, end=end)\r\n\r\nSPEED_PROFILES = {\r\n    'lite': [1, 50, 100],\r\n    'medium': [round(1 + i * (100 - 1) / 7) for i in range(8)],  # 1-100 7等分\r\n    'full': [round(1 + i * (100 - 1) / 25) for i in range(26)],  # 1-100 25等分\r\n}\r\n\r\n\r\ndef load_limit_data(model_short: str, mac_clean: str) -> dict:\r\n    \"\"\"从limit.json读取限位数据。\r\n\r\n    Args:\r\n        model_short: 短型号\r\n        mac_clean: MAC地址(无冒号,小写)\r\n\r\n    Returns:\r\n        dict: 限位数据\r\n    \"\"\"\r\n    import json\r\n    limit_path = get_data_path_read(model_short, mac_clean, 'limit')\r\n    if limit_path is None or not limit_path.exists():\r\n        raise FileNotFoundError(\"limit.json不存在\")\r\n    with open(limit_path, \"r\", encoding=\"utf-8\") as f:\r\n        return json.load(f)\r\n\r\n# Pan轴是360度循环,3600=0\r\n# 所以测试Pan轴时,不要使用3600作为起点,使用0或接近0的值\r\n\r\n\r\ndef measure_speed_single(ptz: Any, axis: str, speed_level: int, raw_csv_path: str,\r\n                         direction: int = 1, zoom_val: int = 10, repeat_idx: int = 0,\r\n                         start_position: float | None = None,\r\n                         limit_data: dict | None = None) -> list[float]:\r\n    \"\"\"测量单轴单速度点的位移。\r\n\r\n    Args:\r\n        ptz: PTZController实例\r\n        axis: 轴名称\r\n        speed_level: 速度等级\r\n        raw_csv_path: CSV路径\r\n        direction: 方向 (1=正向, -1=负向)\r\n        zoom_val: Zoom档位\r\n        repeat_idx: 重复索引\r\n        start_position: 起始位置(绝对移动目标)\r\n        limit_data: 限位数据(从limit.json读取)\r\n        actual_tilt_speed: Tilt轴实际运动速度(正负值,从run_all_tests传入)\r\n\r\n    Returns:\r\n        list[float]: 采样点\r\n    \"\"\"\r\n    # 从limit_data读取限位值\r\n    if limit_data is None:\r\n        raise ValueError(\"limit_data不能为空,必须从limit.json读取\")\r\n\r\n    tilt_min = limit_data.get(\"tilt_min\", -200)\r\n    tilt_max = limit_data.get(\"tilt_max\", 900)\r\n    has_flip = limit_data.get(\"has_flip\", False)\r\n    is_infinite = limit_data.get(\"is_infinite\", True)\r\n    pan_min = limit_data.get(\"pan_min\", 0)\r\n    pan_max = limit_data.get(\"pan_max\", 3600)\r\n\r\n    # 所有移动开始前必须判断稳定\r\n    # Pan无限位:从当前位置开始,要求稳定\r\n    # Pan有限位/Tilt:绝对移动到起点,验证稳定\r\n    if start_position is not None:\r\n        # 绝对移动到起点\r\n        ptz.absolute_move(\r\n            pan=int(start_position) if axis == \"pan\" else 1800,\r\n            tilt=int(start_position) if axis == \"tilt\" else 450,\r\n            zoom=zoom_val,\r\n            speed=50\r\n        )\r\n        # 验证稳定:连续20点绝对相等\r\n        stable_count = 0\r\n        for _ in range(300):  # 最多等待30秒\r\n            pos = ptz.get_position()\r\n            actual = pos.get(axis, 0.0)\r\n            if actual == start_position:\r\n                stable_count += 1\r\n                if stable_count >= 20:\r\n                    break\r\n            else:\r\n                stable_count = 0\r\n            time.sleep(0.1)\r\n        if stable_count < 20:\r\n            _print(f\"  警告: 目标{start_position}, 实际{actual:.0f}\")\r\n    else:\r\n        # Pan无限位:从当前位置开始,验证稳定\r\n        stable_count = 0\r\n        last_pos = None\r\n        for _ in range(300):\r\n            pos = ptz.get_position()\r\n            actual = pos.get(axis, 0.0)\r\n            if last_pos is not None and actual == last_pos:\r\n                stable_count += 1\r\n                if stable_count >= 20:\r\n                    break\r\n            else:\r\n                stable_count = 0\r\n            last_pos = actual\r\n            time.sleep(0.1)\r\n        if stable_count < 20:\r\n            _print(f\"  警告: {axis}轴未稳定\")\r\n\r\n    # 连续移动\r\n    # Pan/Tilt轴统一使用 speed_level * direction\r\n    actual_speed = speed_level * direction\r\n\r\n    ptz.continuous_move(\r\n        pan=actual_speed if axis == \"pan\" else 0,\r\n        tilt=actual_speed if axis == \"tilt\" else 0,\r\n    )\r\n\r\n    # 采样(检测限位和翻转)\r\n    samples = []\r\n    hit_limit = False\r\n    flip_detected_sampling = False\r\n\r\n    for _ in range(110):\r\n        position = ptz.get_position()\r\n        pos = position.get(axis, 0.0) if position else 0.0\r\n        samples.append(pos)\r\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S.%f\")[:-3]\r\n        with open(raw_csv_path, \"a\", newline=\"\", encoding=\"utf-8\") as f:\r\n            writer = csv.writer(f)\r\n            writer.writerow([timestamp, axis, direction, speed_level, zoom_val, repeat_idx, pos])\r\n\r\n        # 检测限位停止\r\n        hit_limit = False\r\n\r\n        if axis == \"pan\":\r\n            # Pan有限位:检测到达限位\r\n            if not is_infinite:\r\n                if pos == pan_max or pos == pan_min:\r\n                    if len(samples) >= 20:\r\n                        recent = samples[-20:]\r\n                        if all(p == pos for p in recent):\r\n                            hit_limit = True\r\n            # Pan无限位:不检测跳变,继续采样到110点\r\n\r\n        elif axis == \"tilt\":\r\n            # Tilt轴限位检测:连续20点达到tmin或tmax\r\n            if pos == tilt_min or pos == tilt_max:\r\n                if len(samples) >= 20:\r\n                    recent = samples[-20:]\r\n                    if all(p == pos for p in recent):\r\n                        hit_limit = True\r\n            \r\n            # Tilt轴翻转检测:趋势反转\r\n            # 只检测趋势变化，不检测初始运动方向\r\n            # 需要至少10个点确定初始趋势\r\n            if len(samples) >= 10:\r\n                # 计算初始趋势(前10个点)\r\n                initial_trend = sum(samples[i] - samples[i-1] for i in range(1, 10))\r\n                # 计算最近5个点趋势\r\n                recent_trend = sum(samples[i] - samples[i-1] for i in range(-4, 0))\r\n                \r\n                # 趋势反转:初始趋势和最近趋势符号相反\r\n                if initial_trend > 0 and recent_trend < 0:\r\n                    # 递增→递减:翻转\r\n                    flip_detected_sampling = True\r\n                    break\r\n                elif initial_trend < 0 and recent_trend > 0:\r\n                    # 递减→递增:翻转\r\n                    flip_detected_sampling = True\r\n                    break\r\n\r\n        # 到达限位后立即停止\r\n        if hit_limit:\r\n            break\r\n\r\n        time.sleep(0.1)\r\n\r\n    # 停止并验证稳定(连续20点位置不变)\r\n    ptz.stop_move()\r\n    stable_count = 0\r\n    last_pos = None\r\n    for _ in range(300):\r\n        pos = ptz.get_position()\r\n        actual = pos.get(axis, 0.0)\r\n        if last_pos is not None and actual == last_pos:\r\n            stable_count += 1\r\n            if stable_count >= 20:\r\n                break\r\n        else:\r\n            stable_count = 0\r\n        last_pos = actual\r\n        time.sleep(0.1)\r\n\r\n    return samples\r\n\r\n\r\ndef post_process_csv(raw_csv_path: str, mac: str, limit_data: dict | None = None) -> list[dict[str, Any]]:\r\n    \"\"\"数据后处理:计算速度。\r\n\r\n    Args:\r\n        raw_csv_path: CSV文件路径\r\n        mac: MAC地址\r\n        limit_data: 限位数据(包含direction_info)\r\n\r\n    计算规则:\r\n    - 取第6-105个点(索引5:105)\r\n    - 速度 = |end - start| / 10.0\r\n    \"\"\"\r\n    results = []\r\n\r\n    with open(raw_csv_path, newline=\"\", encoding=\"utf-8\") as f:\r\n        reader = csv.DictReader(f)\r\n        rows = list(reader)\r\n\r\n    # 按组合分组(包含时间戳)\r\n    groups = {}\r\n    for row in rows:\r\n        axis = row.get(\"axis\", \"\").strip()\r\n        direction = int(row.get(\"direction\", 1))\r\n        speed_level = int(row.get(\"speed_level\", 0))\r\n        zoom = int(row.get(\"zoom\", 0))\r\n        repeat_idx = int(row.get(\"repeat_idx\", 0))\r\n        pos = float(row.get(\"position\", 0.0))\r\n        timestamp = row.get(\"timestamp\", \"\")\r\n        key = (axis, direction, speed_level, zoom)\r\n        groups.setdefault(key, []).append({\"position\": pos, \"repeat_idx\": repeat_idx, \"timestamp\": timestamp})\r\n\r\n    for (axis, direction, speed_level, zoom), entries in groups.items():\r\n        # 读取Pan是否无限位\r\n        is_infinite = limit_data.get(\"is_infinite\", True) if limit_data else True\r\n        pan_min = limit_data.get(\"pan_min\", 0) if limit_data else 0\r\n        pan_max = limit_data.get(\"pan_max\", 3600) if limit_data else 3600\r\n        tilt_min = limit_data.get(\"tilt_min\", -200) if limit_data else -200\r\n        tilt_max = limit_data.get(\"tilt_max\", 900) if limit_data else 900\r\n        \r\n        # 按repeat_idx分组(包含时间戳)\r\n        repeat_groups = {}\r\n        for e in entries:\r\n            idx = e.get(\"repeat_idx\", 0)\r\n            repeat_groups.setdefault(idx, []).append({\"position\": e[\"position\"], \"timestamp\": e[\"timestamp\"]})\r\n\r\n        speeds = []\r\n        movement_direction = \"unknown\"\r\n        hit_limit_flag = False\r\n\r\n        for repeat_idx, entries in repeat_groups.items():\r\n            # 跳变测试可能少于110点,最少需要10点\r\n            if len(entries) < 10:\r\n                continue\r\n\r\n            # 提取位置和时间戳\r\n            positions = [e[\"position\"] for e in entries]\r\n            timestamps = [e[\"timestamp\"] for e in entries]\r\n\r\n            # 判断运动方向(前10个点趋势)\r\n            trend_sum = sum(positions[i] - positions[i-1] for i in range(1, 11))\r\n            movement_dir = \"increasing\" if trend_sum > 0 else (\"decreasing\" if trend_sum < 0 else \"stable\")\r\n            movement_direction = movement_dir\r\n\r\n            # 检测限位/翻转\r\n            valid_end = len(positions)\r\n            flip_detected = False\r\n            limit_detected = False\r\n\r\n            # Pan有限位:检测到达限位(连续20点位置相同且等于min或max)\r\n            # Pan无限位:不需要限位检测\r\n            # Tilt轴:后处理阶段检测到达限位位置，排除限位点\r\n            if axis == \"pan\" and not is_infinite:\r\n                # Pan有限位:检测首次到达限位位置\r\n                for i in range(len(positions)):\r\n                    if positions[i] == pan_min or positions[i] == pan_max:\r\n                        valid_end = i  # 限位索引-1\r\n                        limit_detected = True\r\n                        break\r\n            elif axis == \"tilt\":\r\n                # Tilt轴:检测首次到达限位位置\r\n                # 跳过前20点(启动阶段可能就在限位处)\r\n                for i in range(20, len(positions)):\r\n                    if positions[i] == tilt_min or positions[i] == tilt_max:\r\n                        valid_end = i  # 限位索引\r\n                        limit_detected = True\r\n                        break\r\n                \r\n                # Tilt翻转检测:连续5个点趋势与初始趋势相反\r\n                for i in range(10, valid_end):\r\n                    recent_trend = sum(positions[j] - positions[j-1] for j in range(i-4, i+1))\r\n                    \r\n                    if movement_dir == \"increasing\" and recent_trend < 0:\r\n                        flip_detected = True\r\n                        valid_end = i\r\n                        break\r\n                    elif movement_dir == \"decreasing\" and recent_trend > 0:\r\n                        flip_detected = True\r\n                        valid_end = i\r\n                        break\r\n\r\n            # 选择有效数据\r\n            valid_start = 5  # 排除启停前5个点\r\n            \r\n            # 翻转/限位时:不排除后5点(已通过valid_end排除)\r\n            # 无翻转/无限位时:排除后5点\r\n            if not flip_detected and not limit_detected:\r\n                valid_end = len(positions) - 5\r\n\r\n            # 使用限位检测后的valid_end\r\n            valid_positions = positions[valid_start:valid_end]\r\n            valid_timestamps = timestamps[valid_start:valid_end]\r\n\r\n            if len(valid_positions) < 2:\r\n                continue\r\n\r\n            # Pan无限位:检测跳变次数,分段计算距离\r\n            # 其他情况:累加位移\r\n            if axis == \"pan\" and is_infinite:\r\n                # 检测跳变点(相邻两点差值绝对值>1800)\r\n                jump_indices = []\r\n                for i in range(1, len(valid_positions)):\r\n                    diff = valid_positions[i] - valid_positions[i-1]\r\n                    if abs(diff) > 1800:\r\n                        jump_indices.append(i)\r\n                \r\n                # 分段计算距离(绝对值累加)\r\n                total_move = 0.0\r\n                \r\n                if len(jump_indices) == 0:\r\n                    # 无跳变:直接计算起点到终点\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n                \"speed_profile\": speed_profile,\r\n                \"results\": all_results,\r\n                \"csv_path\": str(csv_path)\r\n            }, f, indent=2, ensure_ascii=False)\r\n    except Exception:\r\n        pass\r\n\r\n    return all_results\r\n\r\n\r\n\r\nclass SpeedTester:\r\n    def __init__(self, ptz: Any) -> None:\r\n        self.ptz = ptz\r\n\r\n    def run_all_tests(self, config: Any = None, speed_profile: str = 'lite') -> list[dict[str, Any]]:\r\n        return run_all_tests(self.ptz, config, speed_profile)\r\n\r\n\r\n# ================================================================ #\r\n#  缓存读取函数 (v6.19 新增)\r\n# ================================================================ #\r\n\r\ndef load_cached_speed_results(mac: str) -> dict | None:\r\n    \"\"\"从本地缓存读取速度测试结果。\r\n    \r\n    v6.19: 优先读取本地缓存，避免每次调用设备API。\r\n    \r\n    Args:\r\n        mac: MAC地址（无分隔符小写）\r\n    \r\n    Returns:\r\n        缓存结果字典，不存在返回 None\r\n    \"\"\"\r\n    try:\r\n        cache_path = get_data_path_read(None, mac, 'speed')\r\n        if cache_path is None or not cache_path.exists():\r\n            return None\r\n        import json\r\n        with open(cache_path, 'r', encoding='utf-8') as f:\r\n            return json.load(f)\r\n    except (json.JSONDecodeError, OSError):\r\n        return None\r\n\r\n\r\ndef run_speed_test(\r\n    ip: str = None, \r\n    username: str = None, \r\n    password: str = None, \r\n    port: int = None, \r\n    speed_profile: str = 'lite',\r\n    mac: str = None,\r\n    use_cache: bool = True\r\n) -> dict:\r\n    \"\"\"独立运行Speed测试。\r\n    \r\n    v6.19: 优先读取本地缓存，缓存不存在时调用设备API。\r\n    \r\n    Args:\r\n        ip: 设备IP（可选）\r\n        username: 用户名（可选）\r\n        password: 密码（可选）\r\n        port: 端口（可选，默认80）\r\n        speed_profile: 速度档位模式\r\n        mac: MAC地址（可选，用于读取缓存）\r\n        use_cache: 是否优先使用缓存（默认True）\r\n    \r\n    Returns:\r\n        测试结果\r\n    \"\"\"\r\n    from src.ptz.isapi.client import ISAPIClient\r\n    from src.ptz.isapi.ptz import PTZController\r\n    \r\n    # 1. 优先读取缓存\r\n    if use_cache and mac:\r\n        cached = load_cached_speed_results(mac)\r\n        if cached:\r\n            return {**cached, \"from_cache\": True}\r\n    \r\n    # 2. 检查必需参数\r\n    if not ip:\r\n        return {\"success\": False, \"error\": \"缺少设备IP参数\"}\r\n    \r\n    # 3. 连接设备并运行测试\r\n    username = username or \"admin\"\r\n    password = password or \"\"\r\n    port = port or 80\r\n    \r\n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\r\n    if not client.verify_credentials():\r\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\r\n    \r\n    ptz = PTZController(client)\r\n    results = run_all_tests(ptz, None, speed_profile)\r\n    \r\n    return {\r\n        \"success\": len(results) > 0,\r\n        \"total_tests\": len(results),\r\n        \"results\": results,\r\n        \"from_cache\": False\r\n    }\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    import argparse\r\n    parser = argparse.ArgumentParser(description=\"AstroHub Speed测试\")\r\n    parser.add_argument(\"--ip\", type=str, required=True, help=\"设备IP\")\r\n    parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\r\n    parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\r\n    parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\r\n    parser.add_argument(\"--profile\", type=str, default=\"lite\", choices=['lite', 'medium', 'full'], help=\"速度档位模式\")\r\n    parser.add_argument(\"--mac\", type=str, help=\"MAC地址（用于缓存）\")\r\n    parser.add_argument(\"--no-cache\", action=\"store_true\", help=\"禁用缓存\")\r\n    args = parser.parse_args()\r\n    \r\n    _print(\"=\" * 50)\r\n    _print(\"AstroHub Speed测试\")\r\n    _print(\"=\" * 50)\r\n    \r\n    result = run_speed_test(\r\n        ip=args.ip, \r\n        username=args.username, \r\n        password=args.password, \r\n        port=args.port, \r\n        speed_profile=args.profile,\r\n        mac=args.mac,\r\n        use_cache=not args.no_cache\r\n    )\r\n    \r\n    if result.get(\"success\"):\r\n        cache_note = \" (缓存)\" if result.get(\"from_cache\") else \"\"\r\n        _print(f\"[完成] 速度测试: {result.get('total_tests', 0)} 项{cache_note}\")\r\n    else:\r\n        _print(f\"[失败] {result.get('error', '未知错误')}\")[... 8922 more characters truncated]"}],"isError":false,"timestamp":1781382098582}}
{"type":"message","id":"2e0d04a4","parentId":"aed99ee9","timestamp":"2026-06-13T20:21:38.583Z","message":{"role":"toolResult","toolCallId":"tool-01c45d62407e4ff49347f290a0d46cc9","toolName":"read","content":[{"type":"text","text":"\"\"\"\nAstroHub v2.0 - 功能探测模块 (Function Detection)\n\n实现 P4.1-P4.21 共 18 项设备功能探测 (严格按 doc/review/M1_method.csv):\n- 每一项: GET端点探测 → 读取当前值 → 读取取值范围 → 修改测试 → 恢复原始值 → 结果写入config\n- 基于 ISAPI client 发送请求\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport xml.etree.ElementTree as ET\nfrom dataclasses import dataclass, field\nfrom datetime import datetime, timezone\nfrom typing import Any\n\nfrom src.ptz.isapi.client import ISAPIClient, ISAPIResponse\nfrom src.ptz.constants import ISAPI_CHANNEL, HOME_COORDS\nfrom src.advanced.device_path import get_device_info, get_data_path_write, get_data_path_read, get_devices_dir\n\n\ndef verify_home_preset(client) -> dict:\n    \"\"\"P5.0: Verify or create preset 10 (HOME) before function detection.\n\n    Steps: goto_preset(10) → verify coords=1800/450/10\n    If not matching, set_preset(10) from current position.\n    If preset 10 already exists, ONLY verify, DO NOT overwrite.\n    \"\"\"\n    import time\n    from src.ptz.isapi.ptz import PTZController\n\n    ptz = PTZController(client)\n\n    # First try to goto preset 10 to see if it exists\n    ptz.goto_preset(10)\n    time.sleep(2)\n    pos = ptz.get_position()\n\n    expected = HOME_COORDS  # {pan: 1800, tilt: 450, zoom: 10}\n\n    if pos:\n        pan_ok = abs(pos.get(\"pan\", 0) - expected[\"pan\"]) <= 10\n        tilt_ok = abs(pos.get(\"tilt\", 0) - expected[\"tilt\"]) <= 5\n        zoom_ok = abs(pos.get(\"zoom\", 0) - expected[\"zoom\"]) <= 1\n        if pan_ok and tilt_ok and zoom_ok:\n            return {\n                \"success\": True, \"preset_exists\": True,\n                \"position\": pos, \"message\": \"Preset 10 verified, coords match HOME\"\n            }\n\n    # Preset 10 doesn't match HOME coords - need to set it\n    # Don't blindly overwrite: first verify we're at a reasonable position\n    result = ptz.set_preset(10)\n    if result:\n        time.sleep(1)\n        ptz.goto_preset(10)\n        time.sleep(2)\n        pos = ptz.get_position()\n    return {\n        \"success\": result, \"preset_exists\": False,\n        \"position\": pos or {}, \"message\": \"Preset 10 set\"\n    }\n\n\n# ================================================================ #\n#  功能探测端点定义 (P4.1-P4.21) - 严格按 M1_method.csv\n# ================================================================ #\n\nFUNCTION_ENDPOINTS: dict[str, dict[str, Any]] = {\n    # --- P4.1 IrLED 红外补光 ---\n    \"ir_led\": {\n        \"p_id\": \"P4.1\",\n        \"label\": \"IrLED 红外补光\",\n        \"endpoint\": \"/Image/channels/{ch}/IrLight\",\n        \"test_key\": \"brightnessLimit\",\n        \"test_value\": 50,\n        \"range_min\": 1,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.2 白平衡 ---\n    \"white_balance\": {\n        \"p_id\": \"P4.2\",\n        \"label\": \"白平衡\",\n        \"endpoint\": \"/Image/channels/{ch}/whiteBalance\",\n        \"test_key\": \"WhiteBalanceRed\",\n        \"test_keys\": {\"WhiteBalanceRed\": 200, \"WhiteBalanceBlue\": 200},\n        \"test_value\": 200,\n        \"range_min\": 0,\n        \"range_max\": 255,\n        \"mode\": \"multi_field\",\n    },\n\n    # --- P4.3 Gain 模拟增益 ---\n    \"gain\": {\n        \"p_id\": \"P4.3\",\n        \"label\": \"Gain 模拟增益\",\n        \"endpoint\": \"/Image/channels/{ch}/gain\",\n        \"test_key\": \"GainLevel\",\n        \"test_value\": 50,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.4 Focus 聚焦 ---\n    \"focus\": {\n        \"p_id\": \"P4.4\",\n        \"label\": \"Focus 聚焦\",\n        \"endpoint\": \"/Image/channels/{ch}/focusConfiguration\",\n        \"test_key\": \"focusStyle\",\n        \"test_values\": [\"MANUAL\", \"SEMIAUTOMATIC\", \"AUTOMATIC\"],\n        \"mode\": \"style_switch\",\n    },\n\n    # --- P4.4b Focus+/- 控制 (通过 PTZ continuous) ---\n    \"focus_adjust\": {\n        \"p_id\": \"P4.4b\",\n        \"label\": \"Focus+/- 调节\",\n        \"endpoint\": \"/PTZCtrl/channels/{ch}/continuous\",\n        \"test_key\": \"focus\",\n        \"test_values\": [\"5\", \"-5\", \"0\"],  # +5: 远离, -5: 靠近, 0: 停止\n        \"mode\": \"focus_continuous\",\n        \"description\": \"通过 PTZ continuous 端点控制 focus+/-\",\n    },\n\n    # --- P4.5 快门速度 ---\n    \"shutter\": {\n        \"p_id\": \"P4.5\",\n        \"label\": \"快门速度(手动模式)\",\n        \"endpoint\": \"/Image/channels/{ch}/Shutter\",\n        \"test_key\": \"ShutterLevel\",\n        \"test_value\": \"1/100\",\n        \"range_min\": \"1/30000\",\n        \"range_max\": \"1/25\",\n        \"mode\": \"shutter\",\n    },\n\n    # --- P4.6 慢快门 ---\n    \"slow_shutter\": {\n        \"p_id\": \"P4.6\",\n        \"label\": \"慢快门\",\n        \"endpoint\": \"/Image/channels/{ch}/Shutter\",\n        \"test_key\": \"minShutterLevelLimit\",\n        \"test_value\": None,  # 复用Shutter端点,仅读取不PUT\n        \"range_min\": \"1/30000\",\n        \"range_max\": None,\n        \"mode\": \"read_only\",\n    },\n\n    # --- P4.7 光圈 Iris ---\n    \"iris\": {\n        \"p_id\": \"P4.7\",\n        \"label\": \"光圈 Iris\",\n        \"endpoint\": \"/Image/channels/{ch}/Iris\",\n        \"test_key\": \"IrisLevel\",\n        \"test_value\": 160,  # 使用离散值列表中的值\n        \"values\": [160, 200, 240, 280, 340, 400, 480, 560, 680, 960, 1100, 1400, 1600, 1900, 2200],\n        \"range_min\": 160,  # F1.6 最大光圈\n        \"range_max\": 2200,  # F22 最小光圈\n        \"mode\": \"iris\",  # 绝对值模式,使用PUT设置IrisLevel\n        \"value_mapping\": {\n            \"note\": \"数值越大光圈越小\",\n            \"formula\": \"F数值 = IrisLevel / 100\",\n            \"160\": \"F1.6 (最大光圈)\",\n            \"2200\": \"F22 (最小光圈)\",\n        },\n    },\n\n    # --- P4.8 快门速度 (重复端点) ---\n    \"shutter_repeat\": {\n        \"p_id\": \"P4.8\",\n        \"label\": \"快门速度\",\n        \"endpoint\": \"/Image/channels/{ch}/Shutter\",\n        \"test_key\": \"ShutterLevel\",\n        \"test_value\": \"1/50\",\n        \"range_min\": \"1/30000\",\n        \"range_max\": \"1/25\",\n        \"mode\": \"shutter\",\n    },\n\n    # --- P4.9 数字降噪-时域 ---\n    \"dnr_temporal\": {\n        \"p_id\": \"P4.9\",\n        \"label\": \"数字降噪-时域\",\n        \"endpoint\": \"/Image/channels/{ch}/noiseReduce\",\n        \"test_key\": \"generalLevel\",\n        \"test_value\": 50,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n        \"xml_structure\": \"<mode>general</mode><GeneralMode><generalLevel>{value}</generalLevel></GeneralMode>\",\n    },\n\n    # --- P4.10 数字降噪-空域 ---\n    \"dnr_spatial\": {\n        \"p_id\": \"P4.10\",\n        \"label\": \"数字降噪-空域\",\n        \"endpoint\": \"/Image/channels/{ch}/noiseReduce\",\n        \"test_key\": \"generalLevel\",\n        \"test_value\": 50,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n        \"xml_structure\": \"<mode>general</mode><GeneralMode><generalLevel>{value}</generalLevel></GeneralMode>\",\n    },\n\n    # --- P4.11 IRCUT 滤波片/日夜转换 ---\n    \"ircut\": {\n        \"p_id\": \"P4.11\",\n        \"label\": \"IRCUT 滤波片/日夜转换\",\n        \"endpoint\": \"/Image/channels/{ch}/IrcutFilter\",\n        \"test_key\": \"IrcutFilterAction\",\n        \"test_value\": \"night\",\n        \"test_values\": [\"night\", \"day\"],\n        \"secondary_key\": \"nightToDayFilterLevel\",\n        \"secondary_range_min\": 1,\n        \"secondary_range_max\": 7,\n        \"mode\": \"action_switch\",\n    },\n\n    # --- P4.12 WDR 宽动态 ---\n    \"wdr\": {\n        \"p_id\": \"P4.12\",\n        \"label\": \"WDR 宽动态\",\n        \"endpoint\": \"/Image/channels/{ch}/WDR\",\n        \"test_key\": \"WDRLevel\",\n        \"test_value\": 80,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.13 BLC 背光补偿 ---\n    \"blc\": {\n        \"p_id\": \"P4.13\",\n        \"label\": \"BLC 背光补偿\",\n        \"endpoint\": \"/Image/channels/{ch}/BLC\",\n        \"test_key\": \"enabled\",\n        \"test_values\": [\"true\", \"false\"],\n        \"mode\": \"toggle\",\n    },\n\n    # --- P4.14 Dehaze 除雾 ---\n    \"dehaze\": {\n        \"p_id\": \"P4.14\",\n        \"label\": \"Dehaze 除雾\",\n        \"endpoint\": \"/Image/channels/{ch}/dehaze\",\n        \"test_key\": \"DehazeLevel\",\n        \"test_value\": 80,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.15 Sharpness 锐度 ---\n    \"sharpness\": {\n        \"p_id\": \"P4.15\",\n        \"label\": \"Sharpness 锐度\",\n        \"endpoint\": \"/Image/channels/{ch}/Sharpness\",\n        \"test_key\": \"SharpnessLevel\",\n        \"test_value\": 80,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.16 亮度 ---\n    \"brightness\": {\n        \"p_id\": \"P4.16\",\n        \"label\": \"亮度\",\n        \"endpoint\": \"/Image/channels/{ch}/color\",\n        \"test_key\": \"brightnessLevel\",\n        \"test_value\": 80,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.17 饱和度 ---\n    \"saturation\": {\n        \"p_id\": \"P4.17\",\n        \"label\": \"饱和度\",\n        \"endpoint\": \"/Image/channels/{ch}/color\",\n        \"test_key\": \"saturationLevel\",\n        \"test_value\": 80,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.18 对比度 ---\n    \"contrast\": {\n        \"p_id\": \"P4.18\",\n        \"label\": \"对比度\",\n        \"endpoint\": \"/Image/channels/{ch}/color\",\n        \"test_key\": \"contrastLevel\",\n        \"test_value\": 80,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.19 Sharpness 锐度 (CSV重复项) ---\n    \"sharpness_repeat\": {\n        \"p_id\": \"P4.19\",\n        \"label\": \"Sharpness 锐度 (P4.19)\",\n        \"endpoint\": \"/Image/channels/{ch}/Sharpness\",\n        \"test_key\": \"SharpnessLevel\",\n        \"test_value\": 80,\n        \"range_min\": 0,\n        \"range_max\": 100,\n        \"mode\": \"numeric\",\n    },\n\n    # --- P4.20 Mirror 镜像 ---\n    \"mirror\": {\n        \"p_id\": \"P4.20\",\n        \"label\": \"Mirror 镜像\",\n        \"endpoint\": \"/Image/channels/{ch}/ImageFlip\",\n        \"test_key\": \"ImageFlipStyle\",\n        \"test_values\": [\"LEFTRIGHT\", \"UPDOWN\", \"CENTER\", \"AUTO\"],\n        \"mode\": \"style_switch\",\n    },\n}\n\n# P4.21 设备还原 - 遍历所有端点逐个 PUT 原始 XML\n\n\n@dataclass\nclass FunctionResult:\n    \"\"\"单项功能探测结果。\"\"\"\n    p_id: str = \"\"\n    item: str = \"\"\n    label: str = \"\"\n    supported: bool = False\n    min_val: str | int = 0\n    max_val: str | int = 0\n    current_values: dict[str, Any] = field(default_factory=dict)\n    test_results: list[dict] = field(default_factory=list)\n    restored: bool = True\n    error: str | None = None\n    endpoint: str = \"\"\n    test_key: str = \"\"\n    config_entry: dict = field(default_factory=dict)\n\n\nclass FunctionDetector:\n    \"\"\"设备功能探测器 - P4.1 至 P4.21 共 20 项功能探测 (严格按 CSV)。\n\n    每一项的标准操作流程:\n    1. GET 端点探测是否存在 (PUT+GET验证通过 = 存在)\n    2. 读取当前值 (解析 XML,记录原始值)\n    3. 读取取值范围 (从 XML 中或使用 CSV 定义的范围)\n    4. 执行修改测试 (PUT 测试值 → GET 验证值正确 → PUT 恢复 → GET 验证恢复)\n    5. PUT 恢复原始值 + GET 验证恢复成功 (在 _test_value 中完成)\n    6. 结果写入 config (记录到 device_config.json)\n    \"\"\"\n\n    def __init__(self, client: ISAPIClient, config_path: str | None = None, device_id: str | None = None) -> None:\n        self.client = client\n        self.channel = ISAPI_CHANNEL\n        self._results: dict[str, FunctionResult] = {}\n        self._original_xml: dict[str, str] = {}\n        # v6.03: 使用动态路径 data/devices/{mac}/function.json\n        self._config_path = config_path  # 保留兼容\n        # 设备信息（延迟获取）\n        self._device_info: dict[str, str] | None = None\n        self._model_short: str | None = None\n        self._mac_clean: str | None = None\n\n    def _get_function_path(self) -> str:\n        \"\"\"v6.19: 获取 function.json 的动态路径（统一使用 device_path）。\"\"\"\n        self._init_device_info()\n        device_dir = get_devices_dir() / self._mac_clean\n        device_dir.mkdir(parents=True, exist_ok=True)\n        return str(device_dir / \"function.json\")\n\n    def _init_device_info(self) -> None:\n        \"\"\"初始化设备信息（首次调用时获取）。\"\"\"\n        if self._device_info is None:\n            from src.ptz.isapi.ptz import PTZController\n            ptz = PTZController(self.client)\n            self._device_info = get_device_info(ptz)\n            self._model_short = self._device_info['model_short']\n            self._mac_clean = self._device_info['mac_clean']\n\n    def _endpoint(self, cap_def: dict) -> str:\n        \"\"\"获取带 channel 的端点路径。\"\"\"\n        return cap_def[\"endpoint\"].format(ch=self.channel)\n\n    def _find_xml_element(self, root: ET.Element, key: str) -> ET.Element | None:\n        \"\"\"递归查找 XML 元素(忽略命名空间)。\"\"\"\n        for elem in root.iter():\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n    target_zoom = int(start_pos.get(\"zoom\", 10))\n\n    # 绝对移动\n    ptz.absolute_move(pan=target_pan, tilt=target_tilt, zoom=target_zoom, speed=50)\n    time.sleep(4)  # 等待移动完成\n\n    # 获取移动后位置\n    moved_pos = ptz.get_position()\n\n    # 回到HOME\n    ptz.goto_preset(10)\n    time.sleep(3)\n    end_pos = ptz.get_position()\n\n    # 验证\n    move_success = moved_pos and abs(moved_pos.get(\"pan\", 0) - target_pan) <= 5 and abs(moved_pos.get(\"tilt\", 0) - target_tilt) <= 5\n    home_restored = end_pos and abs(end_pos.get(\"pan\", 0) - HOME_COORDS[\"pan\"]) <= 10 and abs(end_pos.get(\"tilt\", 0) - HOME_COORDS[\"tilt\"]) <= 5\n\n    supported = move_success and home_restored\n\n    return {\n        \"p_id\": \"P5.2\",\n        \"label\": \"Absolute Move\",\n        \"supported\": supported,\n        \"start_pos\": start_pos,\n        \"target_pos\": {\"pan\": target_pan, \"tilt\": target_tilt, \"zoom\": target_zoom},\n        \"moved_pos\": moved_pos,\n        \"end_pos\": end_pos,\n        \"move_success\": move_success,\n        \"home_restored\": home_restored,\n    }\n\n\n# ================================================================ #\n#  缓存读取函数 (v6.19 新增)\n# ================================================================ #\n\ndef load_cached_function_results(mac: str) -> dict | None:\n    \"\"\"从本地缓存读取功能探测结果。\n    \n    v6.19: 优先读取本地缓存，避免每次调用设备API。\n    \n    Args:\n        mac: MAC地址（无分隔符小写）\n    \n    Returns:\n        缓存结果字典，不存在返回 None\n    \"\"\"\n    try:\n        cache_path = get_data_path_read(None, mac, 'function')\n        if cache_path is None or not cache_path.exists():\n            return None\n        with open(cache_path, 'r', encoding='utf-8') as f:\n            return json.load(f)\n    except (json.JSONDecodeError, OSError):\n        return None\n\n\ndef run_function_test(\n    ip: str = None, \n    username: str = None, \n    password: str = None, \n    port: int = None,\n    mac: str = None,\n    use_cache: bool = True\n) -> dict:\n    \"\"\"独立运行Function测试。\n    \n    v6.19: 优先读取本地缓存，缓存不存在时调用设备API。\n    \n    Args:\n        ip: 设备IP（可选，默认从当前设备读取）\n        username: 用户名（可选）\n        password: 密码（可选）\n        port: 端口（可选，默认80）\n        mac: MAC地址（可选，用于读取缓存）\n        use_cache: 是否优先使用缓存（默认True）\n    \n    Returns:\n        测试结果\n    \"\"\"\n    # 1. 优先读取缓存\n    if use_cache and mac:\n        cached = load_cached_function_results(mac)\n        if cached:\n            return {**cached, \"from_cache\": True}\n    \n    # 2. 检查必需参数\n    if not ip:\n        return {\"success\": False, \"error\": \"缺少设备IP参数\"}\n    \n    # 3. 连接设备并运行测试\n    username = username or \"admin\"\n    password = password or \"\"\n    port = port or 80\n    \n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n    if not client.verify_credentials():\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n    \n    # 4. 运行测试\n    detector = FunctionDetector(client)\n    result = detector.run_all()\n    \n    return {**result, \"from_cache\": False}\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"AstroHub Function测试\")\n    parser.add_argument(\"--ip\", type=str, required=True, help=\"设备IP\")\n    parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n    parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n    parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n    parser.add_argument(\"--mac\", type=str, help=\"MAC地址（用于缓存）\")\n    parser.add_argument(\"--no-cache\", action=\"store_true\", help=\"禁用缓存\")\n    args = parser.parse_args()\n    \n    print(\"=\" * 50)\n    print(\"AstroHub Function测试\")\n    print(\"=\" * 50)\n    \n    result = run_function_test(\n        ip=args.ip, \n        username=args.username, \n        password=args.password, \n        port=args.port,\n        mac=args.mac,\n        use_cache=not args.no_cache\n    )\n    \n    if result.get(\"success\"):\n        cache_note = \" (缓存)\" if result.get(\"from_cache\") else \"\"\n        print(f\"[完成] 功能探测: {result.get('supported_count', 0)}/{result.get('total_functions', 0)} 项支持{cache_note}\")\n    else:\n        print(f\"[失败] {result.get('error', '未知错误')}\")\n[... 25206 more characters truncated]"}],"isError":false,"timestamp":1781382098582}}
{"type":"message","id":"68192b8d","parentId":"2e0d04a4","timestamp":"2026-06-13T20:21:38.583Z","message":{"role":"toolResult","toolCallId":"tool-932aeb70a612420b96197822f79f41cb","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"\nptzhelper.py - PTZHelper Device Control Library\nShared by PTZ_STARTUP / PTZ_FUNCTION / PTZ_LIMIT / PTZ_SPEED / PTZ_ASTRO\nP0 Infrastructure: directory creation, LOG system, config, interaction utilities\n\"\"\"\n\nimport os, sys, time, json, re, requests, shutil, getpass\nfrom datetime import datetime\nfrom requests.auth import HTTPDigestAuth\n\n# Simulator override\n_SIMULATOR_IP = os.environ.get('SIMULATOR_IP')\n\n# ===== P0.1 Directory paths =====\nSCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\nCONFIG_FILE = os.path.join(SCRIPT_DIR, 'config.json')\nCREDS_FILE = os.path.join(SCRIPT_DIR, 'device_credentials.json')\nPTZ_CONFIG_FILE = os.path.join(SCRIPT_DIR, 'PTZ_CONFIG.json')\nLOCAL_CONFIG_FILE = os.path.join(SCRIPT_DIR, 'LOCAL_CONFIG.json')\nDEVICE_CONFIG_FILE = os.path.join(SCRIPT_DIR, 'device_config.json')\nLIMIT_MAP_FILE = os.path.join(SCRIPT_DIR, 'data', 'limit_map.json')\n\nREQUIRED_DIRS = ['record', 'log', 'report', 'download']\n\ndef p0_ensure_dirs(base_dir=None):\n    \"\"\"P0.1: Create required directories at script startup\"\"\"\n    base = base_dir or SCRIPT_DIR\n    created = []\n    for d in REQUIRED_DIRS:\n        path = os.path.join(base, d)\n        if not os.path.exists(path):\n            os.makedirs(path, exist_ok=True)\n            created.append(d)\n    return created\n\n# ===== LOG system (P0.2/P0.3) =====\nLOG_FILE = None\nLOG_SEQ = 0\n\ndef log_init():\n    \"\"\"P0.2: Create LOG file with yyyymmdd-NNN naming\"\"\"\n    global LOG_FILE, LOG_SEQ\n    LOG_DIR = os.path.join(SCRIPT_DIR, 'log')\n    os.makedirs(LOG_DIR, exist_ok=True)\n    ts = datetime.now().strftime('%Y%m%d')\n    existing = [f for f in os.listdir(LOG_DIR) if f.startswith(f'log_{ts}-')]\n    LOG_SEQ = len(existing) + 1\n    LOG_FILE = os.path.join(LOG_DIR, f'log_{ts}-{LOG_SEQ:03d}.md')\n    with open(LOG_FILE, 'w', encoding='utf-8') as f:\n        f.write(f'# PTZ_ASTRO Log Session {LOG_SEQ:03d}\\n')\n        f.write(f'Started: {datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")}\\n')\n        f.write(f'{\"=\"*60}\\n\\n')\n    return LOG_FILE\n\ndef _log_write(level, msg):\n    \"\"\"P0.3: Write LOG with [level] yyyy-mm-dd HH:MM:SS.mss format\"\"\"\n    now = datetime.now()\n    ts = now.strftime('%Y-%m-%d %H:%M:%S') + f'.{now.microsecond // 1000:03d}'\n    line = f'[{level.upper():7s}] {ts} {msg}'\n    try:\n        print(line)\n    except UnicodeEncodeError:\n        print(line.encode('gbk', errors='replace').decode('gbk'))\n    if LOG_FILE:\n        try:\n            with open(LOG_FILE, 'a', encoding='utf-8') as f:\n                f.write(line + '\\n')\n        except Exception:\n            pass\n\ndef log_info(msg):   _log_write('info', msg)\ndef log_warn(msg):   _log_write('warning', msg)\ndef log_err(msg):    _log_write('error', msg)\ndef log_done(msg):   _log_write('done', msg)\ndef log_fail(msg):   _log_write('failed', msg)\n\n# ===== P0.4 config.json =====\ndef p0_init_config():\n    \"\"\"P0.4: Initialize config.json with device info list structure\"\"\"\n    if not os.path.exists(CONFIG_FILE):\n        default = {\n            'devices': [],\n            'selected_interface': None,\n            'last_scan': None\n        }\n        safe_write_json(CONFIG_FILE, default)\n        log_info('P0.4: config.json initialized')\n    return safe_read_json(CONFIG_FILE) or {'devices': [], 'selected_interface': None}\n\ndef add_device_to_config(device_info):\n    \"\"\"Add/update device in config.json by MAC as unique key\"\"\"\n    cfg = safe_read_json(CONFIG_FILE) or {'devices': [], 'selected_interface': None}\n    mac = device_info.get('mac', '')\n    for i, dev in enumerate(cfg['devices']):\n        if dev.get('mac', '').lower() == mac.lower():\n            cfg['devices'][i].update(device_info)\n            safe_write_json(CONFIG_FILE, cfg)\n            return i\n    cfg['devices'].append(device_info)\n    safe_write_json(CONFIG_FILE, cfg)\n    return len(cfg['devices']) - 1\n\n# ===== Safe JSON =====\ndef safe_read_json(path):\n    if not os.path.exists(path):\n        return None\n    try:\n        with open(path, 'r', encoding='utf-8') as f:\n            content = f.read()\n            if content.startswith('\\ufeff'):\n                content = content[1:]\n            return json.loads(content)\n    except Exception:\n        return None\n\ndef safe_write_json(path, data):\n    \"\"\"Write .tmp -> verify -> overwrite\"\"\"\n    tmp = path + '.tmp'\n    with open(tmp, 'w', encoding='utf-8') as f:\n        json.dump(data, f, indent=2, ensure_ascii=False)\n    with open(tmp, 'r', encoding='utf-8') as f:\n        verified = json.load(f)\n    shutil.move(tmp, path)\n\ndef append_record(config_path, record):\n    data = safe_read_json(config_path) or {}\n    if 'records' not in data:\n        data['records'] = []\n    data['records'].append(record)\n    safe_write_json(config_path, data)\n\n# ===== P0.6 Interaction Utilities =====\ndef safe_input(prompt=''):\n    try:\n        return input(prompt)\n    except (EOFError, KeyboardInterrupt):\n        return None\n\ndef display_masked(val, visible=2):\n    \"\"\"P0.6: Display masked value for credential display\"\"\"\n    if len(val) <= visible:\n        return val\n    return val[:visible] + '*' * (len(val) - visible)\n\ndef show_device_summary(device_info):\n    \"\"\"P0.5: Display device parameters and usage instructions\"\"\"\n    print()\n    print('=' * 60)\n    print('当前设备参数:')\n    print(f'  MAC地址:  {device_info.get(\"mac\", \"未知\")}')\n    print(f'  型号:     {device_info.get(\"model\", device_info.get(\"device_type\", \"未知\"))}')\n    print(f'  IP地址:   {device_info.get(\"ip\", \"未知\")}')\n    print(f'  序列号:   {device_info.get(\"serial\", \"未知\")}')\n    print(f'  激活状态: {device_info.get(\"activated\", \"未知\")}')\n    print('=' * 60)\n    print('操作说明: 数字键选择序号 | 输入参数 | Q退出 | 回车确认下一步')\n    print()\n\nAUTHOR = '雅痞张@南方天文'\n\ndef show_phase(phase_name, log_file_path, is_done=False):\n    \"\"\"P0.5: Display current phase, log file path, completion time, and author\"\"\"\n    print()\n    print('=' * 70)\n    print(f'  {phase_name}')\n    print(f'  日志文件: {log_file_path}')\n    now = datetime.now()\n    print(f'  完成时间: {now.strftime(\"%Y-%m-%d %H:%M:%S\")}')\n    print(f'  软件作者: {AUTHOR}')\n    if is_done:\n        print(f'  [done] {phase_name} 完成')\n    print('=' * 70)\n    print()\n\n# ===== PTZHelper class =====\nclass PTZHelper:\n    def __init__(self, ip, auth):\n        self.ip = _SIMULATOR_IP if _SIMULATOR_IP else ip\n        self._original_ip = ip\n        self.auth = HTTPDigestAuth(auth[0], auth[1])\n        self.session = requests.Session()\n        self.session.trust_env = False\n        for k in list(os.environ.keys()):\n            if 'proxy' in k.lower():\n                os.environ.pop(k, None)\n\n    def _clear_proxy(self):\n        for k in list(os.environ.keys()):\n            if 'proxy' in k.lower():\n                os.environ.pop(k, None)\n\n    def get_status(self, retries=2):\n        self._clear_proxy()\n        for attempt in range(retries + 1):\n            try:\n                r = self.session.get(\n                    f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/status',\n                    auth=self.auth, timeout=5)\n                if r.status_code != 200:\n                    if attempt < retries:\n                        time.sleep(0.5)\n                        continue\n                    return {'azimuth': 0, 'elevation': 0, 'zoom': 0}\n                text = r.text\n                az_m = re.search(r'<azimuth>(\\d+)</azimuth>', text)\n                el_m = re.search(r'<elevation>(-?\\d+)</elevation>', text)\n                zm_m = re.search(r'<absoluteZoom>(\\d+)</absoluteZoom>', text)\n                return {\n                    'azimuth': int(az_m.group(1)) if az_m else 0,\n                    'elevation': int(el_m.group(1)) if el_m else 0,\n                    'zoom': int(zm_m.group(1)) if zm_m else 0,\n                }\n            except Exception:\n                if attempt < retries:\n                    time.sleep(0.5)\n                    continue\n                return {'azimuth': 0, 'elevation': 0, 'zoom': 0}\n\n    def absolute_move(self, azimuth, elevation, zoom):\n        self._clear_proxy()\n        xml = (f'<PTZData><AbsoluteHigh>'\n              f'<azimuth>{azimuth}</azimuth>'\n              f'<elevation>{elevation}</elevation>'\n              f'<absoluteZoom>{zoom}</absoluteZoom>'\n              f'</AbsoluteHigh></PTZData>').encode('utf-8')\n        r = self.session.put(\n            f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/absolute/',\n            data=xml, auth=self.auth, timeout=5)\n        return r.status_code == 200\n\n    def relative_move(self, azimuth_delta, elevation_delta, zoom_delta=0):\n        \"\"\"P5.3: Relative move - move by delta from current position.\n        PUT /ISAPI/PTZCtrl/channels/1/relative/\n        \"\"\"\n        self._clear_proxy()\n        xml = (f'<PTZData><Relative>'\n              f'<azimuth>{azimuth_delta}</azimuth>'\n              f'<elevation>{elevation_delta}</elevation>'\n              f'<absoluteZoom>{zoom_delta}</absoluteZoom>'\n              f'</Relative></PTZData>').encode('utf-8')\n        try:\n            r = self.session.put(\n                f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/relative/',\n                data=xml, auth=self.auth, timeout=5)\n            return r.status_code == 200\n        except Exception:\n            return False\n\n    def absolute_move_zoom(self, target_zoom):\n        current = self.get_status()\n        azimuth = current['azimuth']\n        elevation = current['elevation']\n        return self.absolute_move(azimuth, elevation, target_zoom)\n\n    def continuous_move(self, pan=0, tilt=0, zoom=0):\n        self._clear_proxy()\n        xml = f'<PTZData><pan>{pan}</pan><tilt>{tilt}</tilt><zoom>{zoom}</zoom></PTZData>'.encode('utf-8')\n        r = self.session.put(\n            f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/continuous/',\n            data=xml, auth=self.auth, timeout=5)\n        return r.status_code == 200\n\n    def stop(self):\n        return self.continuous_move(0, 0, 0)\n\n    def preset_goto(self, preset_num):\n        self._clear_proxy()\n        r = self.session.put(\n            f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/presets/{preset_num}/goto',\n            auth=self.auth, timeout=5)\n        return r.status_code == 200\n\n    def save_preset(self, preset_num, preset_name='HOME'):\n        self._clear_proxy()\n        xml = f'<PTZPreset><enabled>true</enabled><id>{preset_num}</id><presetName>{preset_name}</presetName></PTZPreset>'.encode('utf-8')\n        r = self.session.put(\n            f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/presets/{preset_num}',\n            data=xml, auth=self.auth, timeout=5)\n        return r.status_code == 200\n\n    def get_capabilities(self):\n        self._clear_proxy()\n        try:\n            r = self.session.get(\n                f'http://{self.ip}/ISAPI/PTZCtrl/channels/1/capabilities',\n                auth=self.auth, timeout=5)\n            return r.text if r.status_code == 200 else ''\n        except Exception:\n            return ''\n\n    def restore_all_defaults(self):\n        self._clear_proxy()\n        results = {}\n        endpoints = [\n            ('/ISAPI/Image/channels/1/color',\n             b'<Color><brightnessLevel>50</brightnessLevel><contrastLevel>50</contrastLevel><saturationLevel>50</saturationLevel></Color>'),\n            ('/ISAPI/Image/channels/1/exposure',\n             b'<Exposure><ExposureType>auto</ExposureType><OverexposeSuppress><enabled>false</enabled></OverexposeSuppress></Exposure>'),\n            ('/ISAPI/Image/channels/1/whiteBalance',\n             b'<WhiteBalance><WBMode>auto</WBMode></WhiteBalance>'),\n        ]\n        for ep, data_xml in endpoints:\n            try:\n                r = self.session.put(f'http://{self.ip}{ep}', data=data_xml, auth=self.auth, timeout=5)\n                results[ep] = r.status_code == 200\n            except Exception:\n                results[ep] = False\n        return results\n\n# ===== Device config =====\ndef load_device_config():\n    return safe_read_json(CONFIG_FILE)\n\ndef save_device_config(cfg):\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n        if r.status_code == 200:\n            return True, None, None\n        err_msg = AUTH_ERRORS.get(r.status_code, f'HTTP {r.status_code}: {r.reason}')\n        err_code = None\n        if 'responseCode' in r.text:\n            m = re.search(r'<responseCode>(\\d+)</responseCode>', r.text)\n            if m:\n                err_code = int(m.group(1))\n        if err_code:\n            err_msg = f'错误码 {err_code}: {err_msg}'\n        return False, r.status_code, err_msg\n    except requests.exceptions.Timeout:\n        return False, 'TIMEOUT', f'{ip} 连接超时'\n    except requests.exceptions.ConnectionError as e:\n        return False, 'CONNECTION', f'{ip} 无法连接: {e}'\n    except Exception as e:\n        return False, 'ERROR', f'未知错误: {e}'\n\ndef _get_error_hint(status_code):\n    hints = {\n        401: '请检查密码是否正确，确认设备账号为 admin',\n        403: '请联系设备管理员确认账号权限',\n        404: '请确认设备 IP 是否正确，设备是否在线',\n        500: '设备异常，尝试重启设备后重试',\n        'TIMEOUT': '请确认网络连接正常，设备 IP 是否可达',\n        'CONNECTION': '请确认设备 IP 正确，网线连接正常',\n    }\n    return hints.get(status_code, '')\n\ndef authenticate(ip):\n    creds = load_credentials() or []\n    for c in creds:\n        if c.get('ip') == ip and c.get('password'):\n            acct = c.get('account', 'admin')\n            ok, code, msg = verify_auth(ip, acct, c['password'])\n            if ok:\n                log_done(f'Auth OK (saved) @{ip}')\n                return (acct, c['password'])\n            else:\n                log_warn(f'Saved creds failed @{ip}: {msg}')\n                if code:\n                    hint = _get_error_hint(code)\n                    if hint:\n                        log_warn(f'  提示: {hint}')\n\n    attempt = 0\n    while True:\n        attempt += 1\n        try:\n            pw = getpass.getpass(f'  [{attempt}] Password (admin@{ip}): ')\n        except (EOFError, KeyboardInterrupt):\n            log_err('Input closed, exit')\n            sys.exit(0)\n        if pw.lower() == 'q':\n            log_info('Auth cancelled by user')\n            sys.exit(0)\n        if not pw.strip():\n            continue\n\n        ok, code, msg = verify_auth(ip, 'admin', pw.strip())\n        if ok:\n            save_credentials(ip, 'admin', pw.strip())\n            log_done(f'Auth OK @{ip} (after {attempt} attempt(s))')\n            return ('admin', pw.strip())\n        \n        err_display = msg\n        if code:\n            hint = _get_error_hint(code)\n            if hint:\n                err_display += f' - {hint}'\n        log_err(f'Auth failed @{ip}: {err_display}')\n\n    log_fail(f'Auth failed @{ip}')\n    return None\n\n# ===== PTZ_CONFIG =====\ndef load_ptz_config():\n    return safe_read_json(PTZ_CONFIG_FILE) or {}\n\ndef save_ptz_config(data):\n    safe_write_json(PTZ_CONFIG_FILE, data)\n\n# =====LOCAL_CONFIG =====\ndef load_local_config():\n    return safe_read_json(LOCAL_CONFIG_FILE) or {}\n\ndef save_local_config(data):\n    safe_write_json(LOCAL_CONFIG_FILE, data)\n\n# ===== Wait until azimuth+elevation stable =====\ndef wait_stable(ptz, duration=2):\n    interval = 0.1\n    samples = int(duration / interval)\n    az_prev, el_prev = None, None\n    stable_start = None\n\n    for _ in range(samples):\n        time.sleep(interval)\n        s = ptz.get_status(retries=0)  # fast: one attempt per sample\n        az, el = s['azimuth'], s['elevation']\n\n        if az == az_prev and el == el_prev:\n            if stable_start is None:\n                stable_start = time.time()\n            if time.time() - stable_start >= duration:\n                return True\n        else:\n            az_prev, el_prev = az, el\n            stable_start = None\n\n    return True\n\ndef is_reachable(ip, timeout_ms=500, count=1):\n    \"\"\"P2.4: Check if IP is reachable via ping\"\"\"\n    import subprocess\n    try:\n        r = subprocess.run(\n            ['ping', '-n', str(count), '-w', str(timeout_ms), ip],\n            capture_output=True, text=True\n        )\n        return r.returncode == 0\n    except Exception:\n        return False\n[... 881 more characters truncated]"}],"isError":false,"timestamp":1781382098583}}
{"type":"message","id":"a3aaafa7","parentId":"68192b8d","timestamp":"2026-06-13T20:21:46.729Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我找到了核心代码文件。现在需要查看 ISAPI PTZ 控制的核心实现："},{"type":"toolCall","id":"tool-641bfe4c41a3436ab46f0bc256df42dd","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\ptz\\isapi\\ptz.py"}},{"type":"toolCall","id":"tool-31f31381915248788c0ceab7f0b173b9","name":"exec","arguments":{"command":"Get-ChildItem -Path astrohub\\src\\ptz\\isapi -Recurse -Name","workdir":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":48552,"output":108,"cacheRead":0,"cacheWrite":0,"totalTokens":48660,"cost":{"input":0.048552,"output":0.00034560000000000005,"cacheRead":0,"cacheWrite":0,"total":0.0488976}},"stopReason":"toolUse","timestamp":1781382098584,"responseId":"cht000dc344@dx19ec2a5b477ba5e412"}}
{"type":"message","id":"6f5c8233","parentId":"a3aaafa7","timestamp":"2026-06-13T20:21:47.227Z","message":{"role":"toolResult","toolCallId":"tool-641bfe4c41a3436ab46f0bc256df42dd","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nPTZ_ASTRO v1.1 - ISAPI PTZ 控制模块\r\nPTZ 预设、连续/绝对/相对移动、变焦控制。\r\n\r\n基于 Hikvision ISAPI PTZCtrl 端点的 XML 控制协议。\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nimport time\r\n\r\nfrom .client import ISAPIClient, ISAPIResponse\r\nfrom src.ptz.core.logger import LOG\r\nfrom src.ptz.constants import ISAPI_CHANNEL, DEFAULT_PTZ_PRESET, HOME_COORDS\r\n\r\n\r\nclass PTZController:\r\n    \"\"\"ISAPI PTZ 控制器。\"\"\"\r\n\r\n    def __init__(self, client: ISAPIClient) -> None:\r\n        self.client = client\r\n        self.channel = ISAPI_CHANNEL\r\n        self.home_preset = DEFAULT_PTZ_PRESET  # 预置点 10\r\n        self.home_coords = HOME_COORDS  # {pan: 1800, tilt: 450, zoom: 10}\r\n\r\n    # --- URL helpers ---\r\n\r\n    def _ptz_base(self) -> str:\r\n        return f\"/PTZCtrl/channels/{self.channel}\"\r\n\r\n    # --- Position ---\r\n\r\n    def get_position(self) -> dict:\r\n        \"\"\"获取当前 PTZ 位置。\r\n\r\n        返回:\r\n            {\"pan\": float, \"tilt\": float, \"zoom\": float} 或空字典\r\n        \"\"\"\r\n        LOG.log(\"info\", f\"ISAPI 获取 PTZ 位置\")\r\n\r\n        result = self.client.get(f\"{self._ptz_base()}/status\")\r\n\r\n        if result.status_code != 200:\r\n            LOG.log(\"warning\", f\"获取 PTZ 位置失败: HTTP {result.status_code}\")\r\n            return {}\r\n\r\n        try:\r\n            import xml.etree.ElementTree as ET\r\n            elem = ET.fromstring(result.xml)\r\n\r\n            def find_text(tag: str) -> str:\r\n                for child in elem.iter():\r\n                    if child.tag.endswith(tag):\r\n                        return (child.text or \"\").strip()\r\n                return \"\"\r\n\r\n            pan = self.client.get_xml_float(elem, \"azimuth\", 0)\r\n            tilt = self.client.get_xml_float(elem, \"elevation\", 0)\r\n            zoom = self.client.get_xml_float(elem, \"absoluteZoom\", 0)\r\n            # Hikvision stores azimuth in tenths of degrees (e.g. 1800 = 180.0°)\r\n            # We keep it in the device-native unit\r\n            return {\"pan\": pan, \"tilt\": tilt, \"zoom\": zoom}\r\n        except Exception as e:\r\n            LOG.log(\"warning\", f\"解析 PTZ 位置异常: {e}\")\r\n            return {}\r\n\r\n    # --- Presets ---\r\n\r\n    def goto_preset(self, preset_id: int) -> bool:\r\n        \"\"\"移动到预置点。\r\n\r\n        返回:\r\n            True = 成功\r\n        \"\"\"\r\n        LOG.log(\"info\", f\"ISAPI 移动到预置点: {preset_id}\")\r\n\r\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <presetIndex>{preset_id}</presetIndex>\r\n</PTZData>\"\"\"\r\n\r\n        result = self.client.put(f\"{self._ptz_base()}/presets/{preset_id}/goto\", xml)\r\n        if result.status_code == 200:\r\n            LOG.log(\"done\", f\"预置点 {preset_id} 移动成功\")\r\n            return True\r\n        else:\r\n            LOG.log(\"error\", f\"预置点 {preset_id} 移动失败: HTTP {result.status_code}\")\r\n            return False\r\n\r\n    def list_presets(self) -> list[dict]:\r\n        \"\"\"获取预置点列表。\r\n\r\n        GET /ISAPI/PTZCtrl/channels/{ch}/presetChannels\r\n        返回预置点列表: [{\"id\": int, \"name\": str}, ...]\r\n        \"\"\"\r\n        LOG.log(\"info\", \"ISAPI 获取预置点列表\")\r\n        try:\r\n            result = self.client.get(\"/PTZCtrl/channels/1/presets\")\r\n            if result.status_code != 200:\r\n                LOG.log(\"warning\", f\"获取预置点列表失败: HTTP {result.status_code}\")\r\n                return []\r\n            import xml.etree.ElementTree as ET\r\n            root = ET.fromstring(result.xml)\r\n            presets = []\r\n            ns = {\"hik\": \"http://www.hikvision.com/ver20/XMLSchema\"}\r\n            # 实际XML结构: <PTZPreset><id>10</id><presetName>HOME</presetName>...</PTZPreset>\r\n            for p in root.findall(\".//hik:PTZPreset\", ns) or root.findall(\".//PTZPreset\"):\r\n                preset_id = (p.findtext(\"hik:id\") or p.findtext(\"id\") or \"\").strip()\r\n                preset_name = (p.findtext(\"hik:presetName\") or p.findtext(\"presetName\") or \"\").strip()\r\n                if preset_id:\r\n                    presets.append({\"id\": int(preset_id), \"name\": preset_name or f\"Preset {preset_id}\"})\r\n            # Fallback: some devices return without namespace\r\n            if not presets:\r\n                for elem in root.iter():\r\n                    local = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n                    if local == \"PTZPreset\":\r\n                        pid = \"\"\r\n                        pname = \"\"\r\n                        for child in elem:\r\n                            ctag = child.tag.split(\"}\")[-1] if \"}\" in child.tag else child.tag\r\n                            if ctag == \"id\": pid = (child.text or \"\").strip()\r\n                            if ctag == \"presetName\": pname = (child.text or \"\").strip()\r\n                        if pid:\r\n                            presets.append({\"id\": int(pid), \"name\": pname or f\"Preset {pid}\"})\r\n            LOG.log(\"done\", f\"获取预置点列表: {len(presets)} 个\")\r\n            return presets\r\n        except Exception as e:\r\n            LOG.log(\"error\", f\"获取预置点列表异常: {e}\")\r\n            return []\r\n\r\n    def set_preset(self, preset_id: int, pan: int = None, tilt: int = None, zoom: int = None, name: str = \"\") -> bool:\r\n        \"\"\"设置预置点。\r\n\r\n        参数:\r\n            preset_id: 预置点编号 (1-300)\r\n            pan: 方位角 (可选，不传则设置当前位置)\r\n            tilt: 仰角 (可选)\r\n            zoom: 变倍 (可选)\r\n            name: 预置点名称 (可选)\r\n\r\n        返回:\r\n            True = 成功\r\n        \"\"\"\r\n        LOG.log(\"info\", f\"ISAPI 设置预置点: {preset_id}\")\r\n\r\n        if pan is not None and tilt is not None:\r\n            # 直接设置指定坐标\r\n            xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZPreset>\r\n<enabled>true</enabled>\r\n<id>{preset_id}</id>\r\n<presetName>{name}</presetName>\r\n<AbsoluteHigh>\r\n<elevation>{tilt}</elevation>\r\n<azimuth>{pan}</azimuth>\r\n<absoluteZoom>{zoom if zoom is not None else 10}</absoluteZoom>\r\n</AbsoluteHigh>\r\n</PTZPreset>\"\"\"\r\n        else:\r\n            # 设置当前位置\r\n            xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <presetIndex>{preset_id}</presetIndex>\r\n</PTZData>\"\"\"\r\n\r\n        result = self.client.put(f\"{self._ptz_base()}/presets/{preset_id}\", xml)\r\n        if result.status_code == 200:\r\n            LOG.log(\"done\", f\"预置点 {preset_id} 设置成功\")\r\n            return True\r\n        else:\r\n            LOG.log(\"error\", f\"预置点 {preset_id} 设置失败: HTTP {result.status_code}\")\r\n            return False\r\n\r\n    def goto_home(self) -> bool:\r\n        \"\"\"Move to HOME preset 10.\"\"\"\r\n        if not self.goto_preset(self.home_preset):\r\n            LOG.log(\"error\", \"goto_home: failed to goto preset\")\r\n            return False\r\n        LOG.log(\"done\", \"goto_home: preset 10 sent\")\r\n        return True\r\n\r\n    def wait_stable(self, samples: int = 20, interval: float = 0.1, tolerance: float = 0.0, max_wait: float = 30.0) -> bool:\r\n        \"\"\"Wait until PTZ is stable.\r\n\r\n        评审标准: 发送移动指令后立即采样，直到连续20个点都在目标位置\r\n\r\n        Args:\r\n            samples: 连续稳定采样数 (default: 20)\r\n            interval: 采样间隔 (default: 0.1s)\r\n            tolerance: 允许偏差 (default: 0 = 0误差)\r\n            max_wait: 最大等待时间 (default: 30s)\r\n\r\n        Returns:\r\n            True if stable, False if timeout\r\n        \"\"\"\r\n        start_time = time.time()\r\n        stable_count = 0\r\n        last_values = None\r\n        \r\n        while time.time() - start_time < max_wait:\r\n            pos = self.get_position()\r\n            if not pos:\r\n                time.sleep(interval)\r\n                continue\r\n            \r\n            # 检查是否稳定（当前值与上一次值比较）\r\n            if last_values is None:\r\n                last_values = pos\r\n                stable_count = 1\r\n            else:\r\n                pan_diff = abs(pos[\"pan\"] - last_values[\"pan\"])\r\n                tilt_diff = abs(pos[\"tilt\"] - last_values[\"tilt\"])\r\n                zoom_diff = abs(pos[\"zoom\"] - last_values[\"zoom\"])\r\n                \r\n                if pan_diff <= tolerance and tilt_diff <= tolerance and zoom_diff <= tolerance:\r\n                    stable_count += 1\r\n                    if stable_count >= samples:\r\n                        LOG.log(\"done\", f\"PTZ stable after {stable_count} samples\")\r\n                        return True\r\n                else:\r\n                    stable_count = 0\r\n                \r\n                last_values = pos\r\n            \r\n            time.sleep(interval)\r\n\r\n        LOG.log(\"error\", f\"wait_stable timeout after {max_wait}s, stable_count={stable_count}\")\r\n        return False\r\n\r\n    def continuous_move(self, pan: float = 0, tilt: float = 0, zoom: float = 0, focus: float = 0) -> bool:\r\n        \"\"\"持续移动。\r\n\r\n        CSV要求: Continuous Move, Pan/Tilt 速度由前端传入。\r\n        ISAPI 2.0 格式: Continuous 端点, panSpeed/tiltSpeed 范围 -10~10, zoomSpeed -10~10, focusSpeed -10~10, 0=停止。\r\n\r\n        参数:\r\n            pan: -100 ~ 100（负=左，正=右）\r\n            tilt: -100 ~ 100（负=下，正=上）\r\n            zoom: -100 ~ 100（负=缩小，正=放大）\r\n            focus: -100 ~ 100（负=近焦，正=远焦）\r\n\r\n        返回:\r\n            True = 移动成功\r\n        \"\"\"\r\n        LOG.log(\"info\", f\"ISAPI 持续移动: pan={pan}, tilt={tilt}, zoom={zoom}, focus={focus}\")\r\n\r\n        # 将 0-100 范围映射到 -10~10 (ISAPI 2.0 规范)\r\n        pan_speed = int(pan)\r\n        tilt_speed = int(tilt)\r\n        zoom_speed = int(zoom)\r\n        focus_speed = int(focus)\r\n\r\n        # 停止移动：速度全0\r\n        if pan_speed == 0 and tilt_speed == 0 and zoom_speed == 0 and focus_speed == 0:\r\n            xml = (\r\n                '<?xml version=\"1.0\" encoding=\"UTF-8\"?>'\r\n                '<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">'\r\n                '<ptzSpeed>'\r\n                '<pan>0</pan><tilt>0</tilt><zoom>0</zoom><focus>0</focus>'\r\n                '</ptzSpeed>'\r\n                '</PTZData>'\r\n            )\r\n            result = self.client.put(f\"{self._ptz_base()}/continuous\", xml)\r\n            return result.status_code == 200\r\n\r\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <ptzSpeed>\r\n    <pan>{pan_speed}</pan>\r\n    <tilt>{tilt_speed}</tilt>\r\n    <zoom>{zoom_speed}</zoom>\r\n    <focus>{focus_speed}</focus>\r\n  </ptzSpeed>\r\n</PTZData>\"\"\"\r\n\r\n        result = self.client.put(f\"{self._ptz_base()}/continuous\", xml)\r\n        return result.status_code == 200\r\n\r\n    def focus_move(self, speed: int) -> bool:\r\n        \"\"\"对焦连续移动。\r\n\r\n        参数:\r\n            speed: -10 ~ 10（负=近焦，正=远焦，0=停止）\r\n        \"\"\"\r\n        xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<PTZData version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <ptzSpeed>\r\n    <pan>0</pan><tilt>0</tilt><zoom>0</zoom><focus>{speed}</focus>\r\n  </ptzSpeed>\r\n</PTZData>'''\r\n        result = self.client.put(f\"{self._ptz_base()}/continuous\", xml)\r\n        return result.status_code == 200\r\n\r\n    def stop_move(self) -> bool:\r\n        \"\"\"停止所有移动。\"\"\"\r\n        LOG.log(\"info\", \"ISAPI 停止所有移动\")\r\n        return self.continuous_move(0, 0, 0, 0)\r\n\r\n    def continuous_move_duration(self, pan: float, tilt: float, duration: float) -> list[dict]:\r\n        \"\"\"持续移动指定时长，期间采样位置。\r\n\r\n        参数:\r\n            pan: -100 ~ 100\r\n            tilt: -100 ~ 100\r\n            duration: 秒\r\n\r\n        返回:\r\n            采样位置列表 [{\"pan\": ..., \"tilt\": ..., \"zoom\": ...}, ...]\r\n        \"\"\"\r\n        positions = []\r\n\r\n        # 启动移动\r\n        if not self.continuous_move(pan=pan, tilt=tilt, focus=0):\r\n            LOG.log(\"error\", \"持续移动启动失败\")\r\n            return positions\r\n\r\n        # 采样\r\n        start = time.time()\r\n        sample_interval = 0.1\r\n        while time.time() - start < duration:\r\n            pos = self.get_position()\r\n            if pos:\r\n                positions.append(pos)\r\n            time.sleep(sample_interval)\r\n\r\n        # 停止\r\n        self.stop_move()\r\n        LOG.log(\"done\", f\"持续移动完成: {len(positions)} 个采样点\")\r\n\r\n        return positions\r\n\r\n    def absolute_move(\r\n        self, pan: float, tilt: float, zoom: float | None = None, speed: int = 50\r\n    ) -> bool:\r\n        \"\"\"绝对坐标移动。\r\n\r\n        参数:\r\n            pan: 水平角度 0~3600（1800 = 180°）\r\n            tilt: 垂直角度 -900~900\r\n            zoom: 变焦级别\r\n        \"\"\"\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n            root = ET.fromstring(result.xml)\r\n            # 查找 autoFocusMode / zoom / initPos 等字段\r\n            for elem in root.iter():\r\n                local_name = elem.tag.split(\"}\")[-1].lower() if \"}\" in elem.tag else elem.tag.lower()\r\n                if local_name in (\"initpos\", \"focusposition\", \"zoom\", \"position\"):\r\n                    if elem.text:\r\n                        try:\r\n                            val = int(elem.text.strip())\r\n                            LOG.log(\"done\", f\"当前对焦位置: {val}\")\r\n                            return val\r\n                        except (ValueError, TypeError):\r\n                            pass\r\n            LOG.log(\"warning\", \"无法解析对焦位置XML\")\r\n            return None\r\n        except Exception as e:\r\n            LOG.log(\"warning\", f\"解析对焦XML异常: {e}\")\r\n            return None\r\n\r\n    def set_focus_mode(self, mode: str) -> bool:\r\n        \"\"\"设置对焦模式: 'manual' 或 'auto'。\r\n\r\n        mode: 'manual'=手动对焦, 'auto'=自动对焦\r\n        \"\"\"\r\n        LOG.log(\"info\", f\"设置对焦模式: {mode}\")\r\n        endpoint = f\"/System/Video/inputs/channels/{self.channel}/focus\"\r\n\r\n        mode_mapping = {\r\n            \"manual\": \"Manual\",\r\n            \"auto\": \"autoFocus\",\r\n        }\r\n\r\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<Focus xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <autoFocusMode>{mode_mapping.get(mode, mode)}</autoFocusMode>\r\n</Focus>\"\"\"\r\n\r\n        result = self.client.put(endpoint, xml)\r\n        return result.status_code == 200\r\n\r\n    def focus_move(self, direction: str, speed: int = 50) -> bool:\r\n        \"\"\"对焦马达移动 (近/远)。\r\n\r\n        direction: 'near' (近焦) 或 'far' (远焦)\r\n        speed: 速度 1~100\r\n        \"\"\"\r\n        LOG.log(\"info\", f\"对焦移动: direction={direction}, speed={speed}\")\r\n        endpoint = f\"/System/Video/inputs/channels/{self.channel}/focus\"\r\n\r\n        step_val = -speed if direction == \"near\" else speed\r\n\r\n        xml = f\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<Focus xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <autoFocusMode>Manual</autoFocusMode>\r\n  <manualFocus>\r\n    <step>{step_val}</step>\r\n  </manualFocus>\r\n</Focus>\"\"\"\r\n\r\n        result = self.client.put(endpoint, xml)\r\n        return result.status_code == 200\r\n\r\n    def focus_range_test(self) -> dict:\r\n        \"\"\"测试对焦范围，真实驱动马达验证变化 (P4.4)。\r\n\r\n        返回:\r\n            {\"success\": bool, \"focus_before\": int, \"focus_after\": int,\r\n             \"delta\": int, \"message\": str}\r\n        \"\"\"\r\n        LOG.log(\"info\", \"=== P4.4: 对焦范围验证 (真实马达) ===\")\r\n        result = {\"success\": False, \"focus_before\": None, \"focus_after\": None, \"delta\": 0}\r\n\r\n        # 读取当前对焦位置\r\n        focus_before = self.get_focus_position()\r\n        if focus_before is None:\r\n            LOG.log(\"error\", \"无法获取初始对焦位置\")\r\n            result[\"message\"] = \"无法获取聚焦位置\"\r\n            return result\r\n\r\n        result[\"focus_before\"] = focus_before\r\n        LOG.log(\"info\", f\"对焦移动前位置: {focus_before}\")\r\n\r\n        # 确保在手动模式\r\n        self.set_focus_mode(\"manual\")\r\n\r\n        # 发送聚焦移动命令 (远焦方向)\r\n        self.focus_move(\"far\", speed=50)\r\n        time.sleep(2)\r\n\r\n        # 读取新位置\r\n        focus_after = self.get_focus_position()\r\n        if focus_after is None:\r\n            LOG.log(\"error\", \"移动后无法获取对焦位置\")\r\n            result[\"message\"] = \"移动后无法获取聚焦位置\"\r\n            return result\r\n\r\n        result[\"focus_after\"] = focus_after\r\n        result[\"delta\"] = abs(focus_after - focus_before)\r\n\r\n        LOG.log(\"info\", f\"对焦移动后位置: {focus_after}, 变化量={result['delta']}\")\r\n\r\n        # 验证有变化\r\n        if result[\"delta\"] > 0:\r\n            LOG.log(\"done\", f\"对焦验证通过: {focus_before} → {focus_after}, delta={result['delta']}\")\r\n            result[\"message\"] = f\"聚焦马达有效, 变化={result['delta']}\"\r\n            result[\"success\"] = True\r\n        else:\r\n            LOG.log(\"error\", f\"对焦验证失败: 位置无变化 ({focus_before} → {focus_after})\")\r\n            result[\"message\"] = f\"聚焦马达无变化\"\r\n            result[\"success\"] = False\r\n\r\n        # 恢复到手动模式 (已保持手动)\r\n        return result\r\n\r\n    # --- Focus (对焦 P4.4) ---\r\n[... 3817 more characters truncated]"}],"isError":false,"timestamp":1781382107226}}
{"type":"message","id":"a42c8e8d","parentId":"6f5c8233","timestamp":"2026-06-13T20:21:47.227Z","message":{"role":"toolResult","toolCallId":"tool-31f31381915248788c0ceab7f0b173b9","toolName":"exec","content":[{"type":"text","text":"__pycache__\r\n__init__.py\r\ncapabilities.py\r\nclient.py\r\nptz.py\r\n__pycache__\\__init__.cpython-314.pyc\r\n__pycache__\\client.cpython-314.pyc\r\n__pycache__\\ptz.cpython-314.pyc"}],"details":{"status":"completed","exitCode":0,"durationMs":396,"aggregated":"__pycache__\r\n__init__.py\r\ncapabilities.py\r\nclient.py\r\nptz.py\r\n__pycache__\\__init__.cpython-314.pyc\r\n__pycache__\\client.cpython-314.pyc\r\n__pycache__\\ptz.cpython-314.pyc","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781382107227}}
{"type":"message","id":"98b7ce75","parentId":"a42c8e8d","timestamp":"2026-06-13T20:22:01.511Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我已经找到核心代码了。现在需要分析问题：\n\n## 问题分析\n\n### 问题1：PTZ速度滑动条\n\n查看 `src/ptz/isapi/ptz.py` 的 `continuous_move` 方法：\n\n```python\n# 将 0-100 范围映射到 -10~10 (ISAPI 2.0 规范)\npan_speed = int(pan)  # ❌ 这里直接用int(pan)，没有映射！\n```\n\n**根本问题**：代码注释说\"映射到 -10~10\"，但实际**没有做映射**！直接把前端传的 `pan=100` 当作 `pan_speed=100` 发给设备。\n\n**官方 ISAPI 规范**（从 ptzhelper_source.py 看到的）：\n- `pan/tilt/zoom` 速度范围是 **-10~10**（或 **-100~100**，取决于设备）\n- 官方 Web 端用 **100** 对应设备速度 **100**（直接传递）\n\n**当前问题**：速度慢是因为代码没有做正确的映射。我需要找到官方 ISAPI 文档确认。\n\n让我先搜索官方 ISAPI 文档："},{"type":"toolCall","id":"tool-3a7e07af22ad4b5ea7f654ff22ca53e6","name":"exec","arguments":{"command":"Get-ChildItem -Path astrohub -Recurse -Include \"*.md\",\"*.txt\",\"*.pdf\" -Name | Select-String -Pattern \"ISAPI|PTZ|speed\" -SimpleMatch","workdir":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"}},{"type":"toolCall","id":"tool-7c6610504cd3412fa5a1b0caa6b03b9d","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\ptz\\isapi\\client.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":54173,"output":362,"cacheRead":0,"cacheWrite":0,"totalTokens":54535,"cost":{"input":0.054173,"output":0.0011584000000000002,"cacheRead":0,"cacheWrite":0,"total":0.055331399999999996}},"stopReason":"toolUse","timestamp":1781382107227,"responseId":"cht000da290@dx19ec2a5e030ba5a412"}}
