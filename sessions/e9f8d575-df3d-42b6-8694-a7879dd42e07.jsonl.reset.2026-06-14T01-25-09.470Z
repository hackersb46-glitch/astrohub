{"type":"message","id":"aa46f5d0","parentId":"de2a4c7c","timestamp":"2026-06-13T20:27:36.283Z","message":{"role":"toolResult","toolCallId":"tool-f19db1b8c65549efb5603ebc284d8f3f","toolName":"read","content":[{"type":"text","text":"        return {\r\n            \"success\": success,\r\n            \"message\": f\"PTZ 移动: {direction} (speed={speed})\",\r\n            \"direction\": direction,\r\n            \"speed\": speed,\r\n        }\r\n\r\n    def ptz_home(self, ip: str) -> dict:\r\n        ctrl, err = self._get_controller(ip)\r\n        if err:\r\n            return {\"success\": False, \"message\": err}\r\n\r\n        success = ctrl.goto_preset(10)  # 直接调用 goto_preset(10)\r\n        return {\r\n            \"success\": success,\r\n            \"message\": \"归位成功\" if success else \"归位失败\",\r\n        }\r\n\r\n    def ptz_stop(self, ip: str) -> dict:\r\n        ctrl, err = self._get_controller(ip)\r\n        if err:\r\n            return {\"success\": False, \"message\": err}\r\n\r\n        success = ctrl.stop_move()\r\n        return {\r\n            \"success\": success,\r\n            \"message\": \"停止成功\" if success else \"停止失败\",\r\n        }\r\n\r\n    def ptz_preset(self, ip: str, preset_id: int) -> dict:\r\n        ctrl, err = self._get_controller(ip)\r\n        if err:\r\n            return {\"success\": False, \"message\": err}\r\n\r\n        success = ctrl.goto_preset(preset_id)\r\n        return {\r\n            \"success\": success,\r\n            \"message\": f\"预置位 {preset_id} {'成功' if success else '失败'}\",\r\n            \"preset_id\": preset_id,\r\n        }\r\n\r\n    def set_preset(self, ip: str, preset_id: int) -> dict:\r\n        \"\"\"设置当前位置为预置点。\r\n\r\n        路由: POST /api/v1/ptz/{device_id}/preset/{preset_id}/set\r\n        \"\"\"\r\n        ctrl, err = self._get_controller(ip)\r\n        if err:\r\n            return {\"success\": False, \"message\": err}\r\n\r\n\n[477 more lines in file. Use offset=2415 to continue.]"}],"isError":false,"timestamp":1781382456283}}
{"type":"message","id":"d5f3652a","parentId":"aa46f5d0","timestamp":"2026-06-13T20:27:41.367Z","message":{"role":"assistant","content":[{"type":"text","text":"让我找到 `ptz_move` 方法中 Pan/Tilt 处理部分："},{"type":"toolCall","id":"call_d06620cdd4674f2499d0eeb8","name":"read","arguments":{"limit":40,"offset":2328,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":53070,"output":64,"cacheRead":0,"cacheWrite":0,"totalTokens":53134,"cost":{"input":0.05307,"output":0.00020480000000000002,"cacheRead":0,"cacheWrite":0,"total":0.0532748}},"stopReason":"toolUse","timestamp":1781382456283,"responseId":"cht000d05bf@dx19ec2ab2b04ba5c342"}}
{"type":"message","id":"22db9e80","parentId":"d5f3652a","timestamp":"2026-06-13T20:27:41.383Z","message":{"role":"toolResult","toolCallId":"call_d06620cdd4674f2499d0eeb8","toolName":"read","content":[{"type":"text","text":"        if err:\r\n            LOG.log(\"failed\", f\"PTZ 移动失败: device={ip} reason={err}\")\r\n            return {\"success\": False, \"message\": err}\r\n\r\n        # Zoom operations\r\n        if direction == \"zoom-in\":\r\n            zoom_speed = speed  # Pass speed directly, continuous_move will scale\r\n            success = ctrl.continuous_move(pan=0, tilt=0, zoom=zoom_speed)\r\n            return {\"success\": success, \"message\": f\"PTZ zoom-in (speed={speed})\"}\r\n        elif direction == \"zoom-out\":\r\n            zoom_speed = -speed  # Pass negative speed directly\r\n            success = ctrl.continuous_move(pan=0, tilt=0, zoom=zoom_speed)\r\n            return {\"success\": success, \"message\": f\"PTZ zoom-out (speed={speed})\"}\r\n        elif direction == \"focus-near\":\r\n            success = ctrl.focus_move_continuous('near', speed)\r\n            return {\"success\": success, \"message\": f\"PTZ focus-near (speed={speed})\"}\r\n        elif direction == \"focus-far\":\r\n            success = ctrl.focus_move_continuous('far', speed)\r\n            return {\"success\": success, \"message\": f\"PTZ focus-far (speed={speed})\"}\r\n        elif direction == \"focus-auto\":\r\n            success = ctrl.set_focus_mode(\"auto\")\r\n            return {\"success\": success, \"message\": \"PTZ focus-auto\"}\r\n\r\n        if direction not in self.DIRECTION_MAP:\r\n            LOG.log(\"warning\", f\"PTZ 移动: 未知方向 {direction}\")\r\n            return {\"success\": False, \"message\": f\"未知方向: {direction}\"}\r\n\r\n        # Pan/Tilt operations\r\n        pan_val, tilt_val = self.DIRECTION_MAP[direction]\r\n        pan = int(round(pan_val * speed / 100.0))\r\n        tilt = int(round(tilt_val * speed / 100.0))\r\n\r\n        success = ctrl.continuous_move(pan=pan, tilt=tilt)\r\n        if success:\r\n            LOG.log(\"done\", f\"PTZ 移动成功: device={ip} direction={direction} speed={speed}\")\r\n        else:\r\n            LOG.log(\"failed\", f\"PTZ 移动失败: device={ip} direction={direction}\")\r\n        return {\r\n            \"success\": success,\r\n            \"message\": f\"PTZ 移动: {direction} (speed={speed})\",\r\n\n[524 more lines in file. Use offset=2368 to continue.]"}],"isError":false,"timestamp":1781382461383}}
