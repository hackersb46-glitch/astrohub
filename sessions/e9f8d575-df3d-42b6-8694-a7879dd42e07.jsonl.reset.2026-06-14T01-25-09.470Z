{"type":"message","id":"62daa5a4","parentId":"059956e4","timestamp":"2026-06-14T00:16:35.079Z","message":{"role":"assistant","content":[{"type":"text","text":"服务未启动成功。让我直接测试后端代码逻辑，不依赖服务："},{"type":"toolCall","id":"call_bb17b5c3dbbb41e68bea8fcd","name":"write","arguments":{"content":"\"\"\"直接测试后端代码逻辑\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport sys\nsys.path.insert(0, 'C:/Users/admin/.openclaw/agents/dev-factory/astrohub')\n\n# 模拟后端逻辑\nimport requests\nfrom requests.auth import HTTPDigestAuth\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI'\n\nprint('=== 测试后端逻辑 ===')\nprint()\n\n# ============================================================\n# 测试 1：白平衡后端逻辑模拟\n# ============================================================\nprint('测试 1：白平衡后端逻辑')\nprint()\n\n# 模拟第一次调用：设置 mode=manual, red=100, blue=100\ndef set_whitebalance_logic(data):\n    \"\"\"模拟后端 set_whitebalance 逻辑\"\"\"\n    client = type('Client', (), {\n        'get': lambda path: requests.get(f'{base}{path}', auth=auth, timeout=10, proxies={'http':None,'https':None}),\n        'put': lambda path, xml: requests.put(f'{base}{path}', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    })()\n    \n    mode_input = data.get(\"mode\")\n    red_input = data.get(\"red_gain\")\n    blue_input = data.get(\"blue_gain\")\n    \n    # 获取当前值\n    import re\n    resp = client.get(\"/Image/channels/1/whiteBalance\")\n    current_mode = \"auto\"\n    current_red = 100\n    current_blue = 80\n    if resp.status_code == 200:\n        mode_m = re.search(r'<WhiteBalanceStyle>(\\w+)</WhiteBalanceStyle>', resp.text)\n        red_m = re.search(r'<WhiteBalanceRed>(\\d+)</WhiteBalanceRed>', resp.text)\n        blue_m = re.search(r'<WhiteBalanceBlue>(\\d+)</WhiteBalanceBlue>', resp.text)\n        if mode_m: current_mode = mode_m.group(1).lower()\n        if red_m: current_red = int(red_m.group(1))\n        if blue_m: current_blue = int(blue_m.group(1))\n    \n    # 使用传入值或当前值\n    mode_val = mode_input if mode_input else current_mode\n    red_val = red_input if red_input is not None else current_red\n    blue_val = blue_input if blue_input is not None else current_blue\n    \n    # 构造 XML\n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<WhiteBalanceStyle>{mode_val.lower()}</WhiteBalanceStyle>\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\n</WhiteBalance>'''\n    \n    put_resp = client.put(\"/Image/channels/1/whiteBalance\", xml)\n    return put_resp.status_code == 200, {'mode': mode_val, 'red': red_val, 'blue': blue_val}\n\n# 初始设置\nsuccess, vals = set_whitebalance_logic({'mode': 'manual', 'red_gain': 100, 'blue_gain': 100})\nprint(f'  初始设置: mode=manual, R=100, B=100 -> {\"OK\" if success else \"FAIL\"}')\ntime.sleep(0.5)\n\n# 只改 R\nsuccess, vals = set_whitebalance_logic({'red_gain': 80})\nprint(f'  只改 R=80: {vals} -> {\"OK\" if success else \"FAIL\"}')\ntime.sleep(0.5)\n\n# 验证\nresp = requests.get(f'{base}/Image/channels/1/whiteBalance', auth=auth, timeout=10, proxies={'http':None,'https':None})\nimport re\nred = re.search(r'<WhiteBalanceRed>(\\d+)</WhiteBalanceRed>', resp.text)\nblue = re.search(r'<WhiteBalanceBlue>(\\d+)</WhiteBalanceBlue>', resp.text)\nprint(f'  验证 ISAPI: R={red.group(1)}, B={blue.group(1)}')\n\ntest1 = red.group(1) == '80' and blue.group(1) == '100'\nprint(f'  结果: {\"PASS\" if test1 else \"FAIL\"}')\n\nprint()\n\n# ============================================================\n# 测试 2：降噪后端逻辑模拟\n# ============================================================\nprint('测试 2：降噪后端逻辑')\nprint()\n\nimport time\n\ndef set_noisereduce_logic(data):\n    \"\"\"模拟后端 set_noisereduce 逻辑\"\"\"\n    client = type('Client', (), {\n        'get': lambda path: requests.get(f'{base}{path}', auth=auth, timeout=10, proxies={'http':None,'https':None}),\n        'put': lambda path, xml: requests.put(f'{base}{path}', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    })()\n    \n    # 先获取当前值\n    current_spatial = 50\n    current_temporal = 50\n    \n    resp = client.get(\"/Image/channels/1/noiseReduce\")\n    if resp.status_code == 200:\n        import re\n        spatial_m = re.search(r'<FrameNoiseReduceLevel>(\\d+)</FrameNoiseReduceLevel>', resp.text)\n        temporal_m = re.search(r'<InterFrameNoiseReduceLevel>(\\d+)</InterFrameNoiseReduceLevel>', resp.text)\n        if spatial_m: current_spatial = int(spatial_m.group(1))\n        if temporal_m: current_temporal = int(temporal_m.group(1))\n    \n    spatial = data.get(\"spatial_level\", current_spatial)\n    temporal = data.get(\"temporal_level\", current_temporal)\n    \n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>advanced</mode>\n<AdvancedMode>\n<FrameNoiseReduceLevel>{spatial}</FrameNoiseReduceLevel>\n<InterFrameNoiseReduceLevel>{temporal}</InterFrameNoiseReduceLevel>\n</AdvancedMode>\n</NoiseReduce>'''\n    \n    put_resp = client.put(\"/Image/channels/1/noiseReduce\", xml)\n    return put_resp.status_code == 200, {'spatial': spatial, 'temporal': temporal}\n\n# 初始设置\nsuccess, vals = set_noisereduce_logic({'spatial_level': 50, 'temporal_level': 50})\nprint(f'  初始设置: 空域=50, 时域=50 -> {\"OK\" if success else \"FAIL\"}')\ntime.sleep(0.5)\n\n# 只改空域\nsuccess, vals = set_noisereduce_logic({'spatial_level': 70})\nprint(f'  只改空域=70: {vals} -> {\"OK\" if success else \"FAIL\"}')\ntime.sleep(0.5)\n\n# 验证\nresp = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\nspatial = re.search(r'<FrameNoiseReduceLevel>(\\d+)</FrameNoiseReduceLevel>', resp.text)\ntemporal = re.search(r'<InterFrameNoiseReduceLevel>(\\d+)</InterFrameNoiseReduceLevel>', resp.text)\nprint(f'  验证 ISAPI: 空域={spatia