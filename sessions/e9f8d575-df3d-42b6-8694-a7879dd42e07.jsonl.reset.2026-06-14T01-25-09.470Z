{"type":"message","id":"fe24fa77","parentId":"40267712","timestamp":"2026-06-13T22:59:54.123Z","message":{"role":"toolResult","toolCallId":"call_85ed91fdf8b542c684431df0","toolName":"read","content":[{"type":"text","text":"    client = ctrl.client\r\n    try:\r\n        # 直接构造 XML\r\n        mode_val = data.get(\"mode\", \"auto\")  # 小写！\r\n        red_val = data.get(\"red_gain\", 50)\r\n        blue_val = data.get(\"blue_gain\", 50)\r\n        \r\n        # 获取当前值\r\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\r\n        if resp.status_code == 200:\r\n            import xml.etree.ElementTree as ET\r\n            root = ET.fromstring(resp.xml)\r\n            for elem in root.iter():\r\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n                if tag == \"WhiteBalanceRed\":\r\n                    red_val = int(elem.text or 50)\r\n                elif tag == \"WhiteBalanceBlue\":\r\n                    blue_val = int(elem.text or 50)\r\n        \r\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n<WhiteBalanceStyle>{mode_val}</WhiteBalanceStyle>\r\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\r\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\r\n</WhiteBalance>'''\r\n        \r\n        put_resp = client.put(\"/Image/channels/1/whiteBalance\", xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"白平衡已更新\"}\r\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置白平衡异常: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/noisereduce\", summary=\"获取降噪设置\", tags=[\"Image\"])\r\nasync def get_noisereduce(device_id: str) -> dict:\r\n    \"\"\"获取设备降噪当前设置。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n\n[563 more lines in file. Use offset=2730 to continue.]"}],"isError":false,"timestamp":1781391594123}}
{"type":"message","id":"28a208ef","parentId":"fe24fa77","timestamp":"2026-06-13T23:00:18.115Z","message":{"role":"assistant","content":[{"type":"text","text":"问题确认：\n1. `mode_val` 应该是首字母大写\n2. 只有当 `red_gain` 和 `blue_gain` 未传入时才保留当前值，如果传入应该使用传入的值\n\n修复后端代码："},{"type":"toolCall","id":"tool-e500c73e5e8947b59dc91a69da845f14","name":"edit","arguments":{"edits":[{"newText":"    client = ctrl.client\n    try:\n        # 参数处理\n        mode_input = data.get(\"mode\")\n        red_input = data.get(\"red_gain\")\n        blue_input = data.get(\"blue_gain\")\n        \n        # 获取当前值\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\n        current_mode = \"auto\"\n        current_red = 100\n        current_blue = 80\n        if resp.status_code == 200:\n            import xml.etree.ElementTree as ET\n            root = ET.fromstring(resp.xml)\n            for elem in root.iter():\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n                if tag == \"WhiteBalanceStyle\":\n                    current_mode = (elem.text or \"auto\").lower()\n                elif tag == \"WhiteBalanceRed\":\n                    current_red = int(elem.text or 100)\n                elif tag == \"WhiteBalanceBlue\":\n                    current_blue = int(elem.text or 80)\n        \n        # 使用传入值或当前值\n        mode_val = mode_input if mode_input else current_mode\n        red_val = red_input if red_input is not None else current_red\n        blue_val = blue_input if blue_input is not None else current_blue\n        \n        # ISAPI 要求首字母大写\n        mode_isapi = mode_val.capitalize() if mode_val in [\"auto\", \"manual\"] else \"Manual\"\n        \n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<WhiteBalanceStyle>{mode_isapi}</WhiteBalanceStyle>\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\n</WhiteBalance>'''\n        \n        put_resp = client.put(\"/Image/channels/1/whiteBalance\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": \"白平衡已更新\", \"data\": {\"mode\": mode_val, \"red_gain\": red_val, \"blue_gain\": blue_val}}\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置白平衡异常: {e}\"}","oldText":"    client = ctrl.client\n    try:\n        # 直接构造 XML\n        mode_val = data.get(\"mode\", \"auto\")  # 小写！\n        red_val = data.get(\"red_gain\", 50)\n        blue_val = data.get(\"blue_gain\", 50)\n        \n        # 获取当前值\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\n        if resp.status_code == 200:\n            import xml.etree.ElementTree as ET\n            root = ET.fromstring(resp.xml)\n            for elem in root.iter():\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n                if tag == \"WhiteBalanceRed\":\n                    red_val = int(elem.text or 50)\n                elif tag == \"WhiteBalanceBlue\":\n                    blue_val = int(elem.text or 50)\n        \n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<WhiteBalanceStyle>{mode_val}</WhiteBalanceStyle>\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\n</WhiteBalance>'''\n        \n        put_resp = client.put(\"/Image/channels/1/whiteBalance\", xml_str)\n        if put_resp.status_code == 200:\n            return {\"success\": True, \"message\": \"白平衡已更新\"}\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置白平衡异常: {e}\"}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":132416,"output":1061,"cacheRead":0,"cacheWrite":0,"totalTokens":133477,"cost":{"input":0.132416,"output":0.0033952,"cacheRead":0,"cacheWrite":0,"total":0.1358112}},"stopReason":"toolUse","timestamp":1781391594126,"responseId":"cht000e81c7@dx19ec336951eb893102"}}
