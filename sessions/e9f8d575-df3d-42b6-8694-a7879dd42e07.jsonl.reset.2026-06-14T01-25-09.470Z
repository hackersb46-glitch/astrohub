{"type":"message","id":"3ad09506","parentId":"0d1f375b","timestamp":"2026-06-13T23:31:09.723Z","message":{"role":"assistant","content":[{"type":"text","text":"现在创建完整测试，验证空域/时域分开设置："},{"type":"toolCall","id":"call_6169fca254b64000877e1b77","name":"write","arguments":{"content":"\"\"\"完整测试：空域/时域降噪分开设置\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI'\n\nprint('=== 测试空域/时域降噪分开设置 ===')\nprint()\n\n# 测试用例：空域和时域设置不同值\ntest_cases = [\n    {'spatial': 30, 'temporal': 60},\n    {'spatial': 50, 'temporal': 50},\n    {'spatial': 70, 'temporal': 40},\n    {'spatial': 20, 'temporal': 80},\n    {'spatial': 60, 'temporal': 30},\n]\n\nresults = []\nfor i, vals in enumerate(test_cases):\n    spatial = vals['spatial']\n    temporal = vals['temporal']\n    \n    # 使用 advanced 模式设置\n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>advanced</mode>\n<AdvancedMode>\n<FrameNoiseReduceLevel>{spatial}</FrameNoiseReduceLevel>\n<InterFrameNoiseReduceLevel>{temporal}</InterFrameNoiseReduceLevel>\n</AdvancedMode>\n</NoiseReduce>'''\n    \n    r = requests.put(f'{base}/Image/channels/1/noiseReduce', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    # 验证\n    r2 = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    actual_spatial = re.search(r'<FrameNoiseReduceLevel>(\\d+)</FrameNoiseReduceLevel>', r2.text)\n    actual_temporal = re.search(r'<InterFrameNoiseReduceLevel>(\\d+)</InterFrameNoiseReduceLevel>', r2.text)\n    \n    spatial_match = int(actual_spatial.group(1)) == spatial if actual_spatial else False\n    temporal_match = int(actual_temporal.group(1)) == temporal if actual_temporal else False\n    \n    status = 'PASS' if (r.status_code == 200 and spatial_match and temporal_match) else 'FAIL'\n    results.append(status == 'PASS')\n    \n    print(f'测试 {i+1}: 空域={spatial}, 时域={temporal}')\n    print(f'  PUT: {r.status_code}')\n    print(f'  验证: 空域={actual_spatial.group(1) if actual_spatial else \"N/A\"}, 时域={actual_temporal.group(1) if actual_temporal else \"N/A\"}')\n    print(f'  结果: {status}')\n    print()\n    \n    time.sleep(1)\n\nprint('=== 测试总结 ===')\nprint(f'通过: {sum(results)}/5')\n\nif sum(results) == 5:\n    print()\n    print('所有测试通过！空域/时域降噪分开设置正常工作。')\nelse:\n    print()\n    print('有测试失败！')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_nr_spatial_temporal.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":62815,"output":768,"cacheRead":0,"cacheWrite":0,"totalTokens":63583,"cost":{"input":0.062815,"output":0.0024576000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0652726}},"stopReason":"toolUse","timestamp":1781393440618,"responseId":"cht000db82c@dx19ec352c5f1b85e102"}}
