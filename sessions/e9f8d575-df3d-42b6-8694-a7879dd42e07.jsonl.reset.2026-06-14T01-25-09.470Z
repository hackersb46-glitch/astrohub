{"type":"message","id":"05e7f93f","parentId":"f4874980","timestamp":"2026-06-13T22:30:27.064Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我立即用 Playwright 测试 AstroHub："},{"type":"toolCall","id":"tool-ba5878fc530f40e9aad8ac4deb8a77cc","name":"write","arguments":{"content":"\"\"\"Playwright 测试 AstroHub PTZ 档位\"\"\"\nimport asyncio\nfrom playwright.async_api import async_playwright\n\nasync def test_astrohub_ptz():\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False, slow_mo=500)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print('=== Playwright 测试 AstroHub PTZ 档位 ===')\n        print()\n        \n        # 访问 AstroHub\n        print('1. 访问 AstroHub...')\n        await page.goto('http://localhost:10280/', wait_until='networkidle')\n        await asyncio.sleep(3)\n        \n        # 截图首页\n        await page.screenshot(path='astrohub_home.png')\n        print('   截图: astrohub_home.png')\n        \n        # 查找滑动条\n        print('2. 查找 PTZ 速度滑动条...')\n        slider = await page.query_selector('#ptzSpeed')\n        if slider:\n            min_val = await slider.get_attribute('min')\n            max_val = await slider.get_attribute('max')\n            val = await slider.get_attribute('value')\n            print(f'   滑动条属性: min={min_val}, max={max_val}, value={val}')\n        else:\n            print('   未找到滑动条，需要进入主控台')\n            \n            # 点击主控台菜单\n            console_btn = await page.query_selector('[data-page=\"console\"]')\n            if console_btn:\n                await console_btn.click()\n                print('   点击主控台菜单')\n                await asyncio.sleep(2)\n            \n            # 截图主控台\n            await page.screenshot(path='astrohub_console.png')\n            print('   截图: astrohub_console.png')\n            \n            # 再次查找滑动条\n            slider = await page.query_selector('#ptzSpeed')\n            if slider:\n                min_val = await slider.get_attribute('min')\n                max_val = await slider.get_attribute('max')\n                val = await slider.get_attribute('value')\n                print(f'   滑动条属性: min={min_val}, max={max_val}, value={val}')\n            else:\n                print('   未找到滑动条')\n        \n        # 测试各档位\n        if slider:\n            print()\n            print('3. 测试各档位...')\n            \n            for gear in [1, 4, 7]:\n                # 设置滑动条值\n                await slider.fill(str(gear))\n                \n                # 获取当前值\n                current_val = await slider.input_value()\n                display_val = await page.query_selector('#ptzSpeedVal')\n                if display_val:\n                    display_text = await display_val.inner_text()\n                    print(f'   档位{gear}: 滑动条值={current_val}, 显示值={display_text}')\n                \n                # 截图\n                await page.screenshot(path=f'astrohub_gear_{gear}.png')\n        \n        # 查找 PTZ 控制按钮\n        print()\n        print('4. 查找 PTZ 控制按钮...')\n        \n        # 需要展开 PTZ 控制区域\n        ptz_section = await page.query_selector('#ptzControlSection')\n        if ptz_section:\n            # 点击展开\n            header = await ptz_section.query_selector('.collapsible-header')\n            if header:\n                await header.click()\n                print('   展开 PTZ 控制区域')\n                await asyncio.sleep(1)\n        \n        # 截图展开后\n        await page.screenshot(path='astrohub_ptz_expanded.png')\n        print('   截图: astrohub_ptz_expanded.png')\n        \n        # 查找方向按钮\n        buttons = await page.query_selector_all('.ptz-btn')\n        print(f'   找到 {len(buttons)} 个 PTZ 按钮')\n        \n        for btn in buttons[:9]:\n            text = await btn.inner_text()\n            print(f'   按钮: {text}')\n        \n        print()\n        print('=== 测试完成 ===')\n        print('截图保存:')\n        print('  - astrohub_home.png')\n        print('  - astrohub_console.png')\n        print('  - astrohub_ptz_expanded.png')\n        \n        # 保持浏览器打开\n        print()\n        print('浏览器保持打开 30 秒...')\n        await asyncio.sleep(30)\n        \n        await browser.close()\n\nif __name__ == '__main__':\n    asyncio.run(test_astrohub_ptz())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_astrohub_playwright.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":88892,"output":1008,"cacheRead":0,"cacheWrite":0,"totalTokens":89900,"cost":{"input":0.088892,"output":0.0032256000000000003,"cacheRead":0,"cacheWrite":0,"total":0.0921176}},"stopReason":"toolUse","timestamp":1781389797734,"responseId":"cht000d4f15@dx19ec31b47acb91a742"}}
