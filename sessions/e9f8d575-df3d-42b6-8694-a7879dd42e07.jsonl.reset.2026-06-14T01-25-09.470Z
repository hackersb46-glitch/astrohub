{"type":"message","id":"4a38336a","parentId":"ad66501f","timestamp":"2026-06-13T22:43:51.104Z","message":{"role":"assistant","content":[{"type":"text","text":"..."},{"type":"toolCall","id":"call_667d490b87ea46729b46c796","name":"exec","arguments":{"command":"cd astrohub; python -c \"\nimport os\nimport sys\nsys.path.insert(0, '.')\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nfrom src.core.ptz_manager import PTZManager\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI/PTZCtrl/channels/1'\n\ndef get_pos():\n    r = requests.get(f'{base}/status', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        az = re.search(r'<azimuth>(\\d+)</azimuth>', r.text)\n        return int(az.group(1)) if az else 0\n    return 0\n\ndef abs_move(az):\n    xml = f'<PTZData><AbsoluteHigh><azimuth>{az}</azimuth><elevation>450</elevation><absoluteZoom>10</absoluteZoom></AbsoluteHigh></PTZData>'.encode('utf-8')\n    requests.put(f'{base}/absolute/', data=xml, auth=auth, timeout=10, proxies={'http':None,'https':None})\n    time.sleep(3)\n\nmgr = PTZManager()\n\nprint('Testing ptz_move method...')\nprint()\n\nfor gear in [1, 7]:\n    abs_move(1800)\n    time.sleep(0.5)\n    \n    start = get_pos()\n    print(f'Gear {gear}: start={start}')\n    \n    result = mgr.ptz_move('192.168.5.72', direction='right', speed=gear)\n    isapi = result.get('isapi_speed', 'N/A')\n    print(f'  isapi_speed={isapi}')\n    \n    time.sleep(0.5)\n    mgr.ptz_stop('192.168.5.72')\n    \n    time.sleep(0.5)\n    end = get_pos()\n    \n    delta = abs(end - start)\n    speed = delta * 2\n    print(f'  end={end}, delta={delta}, speed={speed} deg/s')\n    print()\n\" 2>&1","timeout":40,"workdir":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":113397,"output":507,"cacheRead":