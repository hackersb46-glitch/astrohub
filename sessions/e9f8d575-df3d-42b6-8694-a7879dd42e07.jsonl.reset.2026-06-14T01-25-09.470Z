{"type":"message","id":"1ce9f63a","parentId":"7b6f7630","timestamp":"2026-06-13T23:03:24.196Z","message":{"role":"toolResult","toolCallId":"tool-928d77bee066408e9cf509e5b839f925","toolName":"read","content":[{"type":"text","text":"    # Headless 模式\r\n    if args.headless:\r\n        _run_headless(args.host, args.port)\r\n        return\r\n\r\n    # 桌面模式\r\n    app = create_app()\r\n    stop_event = threading.Event()\r\n    open_url = f\"http://{args.host}:{args.port}\"\r\n\r\n    # 启动 uvicorn 在后台线程\r\n    uvicorn_thread = threading.Thread(\r\n        target=_run_uvicorn,\r\n        args=(args.host, args.port, app, stop_event),\r\n        daemon=True,\r\n    )\r\n    uvicorn_thread.start()\r\n\r\n    # 给 uvicorn 一点时间启动\r\n    import time\r\n    time.sleep(1)\r\n\r\n    # 系统托盘 (Windows)\r\n    if sys.platform == \"win32\":\r\n        tray_thread = threading.Thread(\r\n            target=_run_system_tray,\r\n            args=(stop_event, open_url),\r\n            daemon=True,\r\n        )\r\n        tray_thread.start()\r\n\r\n    # 启动 pywebview 桌面窗口 (阻塞直到窗口关闭)\r\n    _run_desktop_window(open_url, stop_event)\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    try:\r\n        main()\r\n    except KeyboardInterrupt:\r\n        log.info(\"用户中断\")\r\n        sys.exit(0)\r\n    except Exception as e:\r\n        log.error(\"程序异常: %s\", e, exc_info=True)\r\n        sys.exit(1)\r\n"}],"isError":false,"timestamp":1781391804196}}
