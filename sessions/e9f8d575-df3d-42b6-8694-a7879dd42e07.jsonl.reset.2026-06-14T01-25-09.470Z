{"type":"message","id":"bb5d26ed","parentId":"f49e171c","timestamp":"2026-06-14T00:14:06.773Z","message":{"role":"toolResult","toolCallId":"call_4c75c02f4130439084f74c25","toolName":"read","content":[{"type":"text","text":"    client = ctrl.client\r\n    try:\r\n        # 参数处理\r\n        mode_input = data.get(\"mode\")\r\n        red_input = data.get(\"red_gain\")\r\n        blue_input = data.get(\"blue_gain\")\r\n        \r\n        # 获取当前值\r\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\r\n        current_mode = \"auto\"\r\n        current_red = 100\r\n        current_blue = 80\r\n        if resp.status_code == 200:\r\n            import xml.etree.ElementTree as ET\r\n            root = ET.fromstring(resp.xml)\r\n            for elem in root.iter():\r\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n                if tag == \"WhiteBalanceStyle\":\r\n                    current_mode = (elem.text or \"auto\").lower()\r\n                elif tag == \"WhiteBalanceRed\":\r\n                    current_red = int(elem.text or 100)\r\n                elif tag == \"WhiteBalanceBlue\":\r\n                    current_blue = int(elem.text or 80)\r\n        \r\n        # 使用传入值或当前值\r\n        mode_val = mode_input if mode_input else current_mode\r\n        red_val = red_input if red_input is not None else current_red\r\n        blue_val = blue_input if blue_input is not None else current_blue\r\n        \r\n        # ISAPI 要求小写\r\n        mode_isapi = mode_val.lower() if mode_val else \"manual\"\r\n        \r\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n<WhiteBalanceStyle>{mode_isapi}</WhiteBalanceStyle>\r\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\r\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\r\n</WhiteBalance>'''\r\n        \r\n        put_resp = client.put(\"/Image/channels/1/whiteBalance\", xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"白平衡已更新\", \"data\": {\"mode\": mode_val, \"red_gain\": red_val, \"blue_gain\": blue_val}}\r\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置白平衡异常: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/noisereduce\", summary=\"获取降噪设置\", tags=[\"Image\"])\r\nasync def get_noisereduce(device_id: str) -> dict:\r\n    \"\"\"获取设备降噪当前设置。\"\"\"\r\n\n[605 more lines in file. Use offset=2730 to continue.]"}],"isError":false,"timestamp":1781396046773}}
{"type":"message","id":"f36cf7a5","parentId":"bb5d26ed","timestamp":"2026-06-14T00:14:25.026Z","message":{"role":"assistant","content":[{"type":"text","text":"后端白平衡逻辑看起来正确：只更新传入的参数，未传入的保持当前值。\n\n让我创建完整 E2E 测试来验证问题："},{"type":"toolCall","id":"call_0e9cff94951b4c8e82c3fa6a","name":"write","arguments":{"content":"\"\"\"E2E 测试：白平衡 R/B 和降噪空域/时域分开设置\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI'\n\ndef get_wb():\n    \"\"\"获取白平衡当前值\"\"\"\n    r = requests.get(f'{base}/Image/channels/1/whiteBalance', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        mode = re.search(r'<WhiteBalanceStyle>(\\w+)</WhiteBalanceStyle>', r.text)\n        red = re.search(r'<WhiteBalanceRed>(\\d+)</WhiteBalanceRed>', r.text)\n        blue = re.search(r'<WhiteBalanceBlue>(\\d+)</WhiteBalanceBlue>', r.text)\n        return {\n            'mode': mode.group(1) if mode else 'auto',\n            'red': int(red.group(1)) if red else 0,\n            'blue': int(blue.group(1)) if blue else 0\n        }\n    return None\n\ndef set_wb(mode=None, red=None, blue=None):\n    \"\"\"设置白平衡\"\"\"\n    # 先获取当前值\n    current = get_wb()\n    mode_val = mode if mode else current['mode']\n    red_val = red if red is not None else current['red']\n    blue_val = blue if blue is not None else current['blue']\n    \n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<WhiteBalanceStyle>{mode_val}</WhiteBalanceStyle>\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\n</WhiteBalance>'''\n    \n    r = requests.put(f'{base}/Image/channels/1/whiteBalance', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    return r.status_code == 200\n\ndef get_nr():\n    \"\"\"获取降噪当前值\"\"\"\n    r = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        spatial = re.search(r'<FrameNoiseReduceLevel>(\\d+)</FrameNoiseReduceLevel>', r.text)\n        temporal = re.search(r'<InterFrameNoiseReduceLevel>(\\d+)</InterFrameNoiseReduceLevel>', r.text)\n        return {\n            'spatial': int(spatial.group(1)) if spatial else 50,\n            'temporal': int(temporal.group(1)) if temporal else 50\n        }\n    return None\n\ndef set_nr(spatial=None, temporal=None):\n    \"\"\"设置降噪\"\"\"\n    current = get_nr()\n    spatial_val = spatial if spatial is not None else current['spatial']\n    temporal_val = temporal if temporal is not None else current['temporal']\n    \n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>advanced</mode>\n<AdvancedMode>\n<FrameNoiseReduceLevel>{spatial_val}</FrameNoiseReduceLevel>\n<InterFrameNoiseReduceLevel>{temporal_val}</InterFrameNoiseReduceLevel>\n</AdvancedMode>\n</NoiseReduce>'''\n    \n    r = requests.put(f'{base}/Image/channels/1/noiseReduce', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    return r.status_code == 200\n\nprint('=== E2E 测试：白平衡 R/B 和降噪空域/时域 ===')\nprint()\n\n# ============================================================\n# 测试 1：白平衡 R/B 分开设置\n# ============================================================\nprint('测试 1：白平衡 R/B 分开设置')\nprint()\n\n# 初始状态：手动模式，R=100, B=100\nset_wb(mode='manual', red=100, blue=100)\ntime.sleep(0.5)\nwb = get_wb()\nprint(f'  初始状态: 模式={wb[\"mode\"]}, R={wb[\"red\"]}, B={wb[\"blue\"]}')\n\n# 只改 R，B 应保持\nset_wb(red=80)\ntime.sleep(0.5)\nwb = get_wb()\ntest1a = wb['red'] == 80 and wb['blue'] == 100\nprint(f'  只改 R=80: R={wb[\"red\"]}, B={wb[\"blue\"]} - {\"PASS\" if test1a else \"FAIL\"}')\n\n# 只改 B，R 应保持\nset_wb(blue=70)\ntime.sleep(0.5)\nwb = get_wb()\ntest1b = wb['red'] == 80 and wb['blue'] == 70\nprint(f'  只改 B=70: R={wb[\"red\"]}, B={wb[\"blue\"]} - {\"PASS\" if test1b else \"FAIL\"}')\n\n# 连续改 R，B 不变\nfor i, r_val in enumerate([60, 50, 40, 30]):\n    set_wb(red=r_val)\n    time.sleep(0.3)\n    wb = get_wb()\n    test = wb['red'] == r_val and wb['blue'] == 70\n    print(f'  连续改 R={r_val}: R={wb[\"red\"]}, B={wb[\"blue\"]} - {\"PASS\" if test else \"FAIL\"}')\n\nprint()\n\n# ============================================================\n# 测试 2：降噪空域/时域分开设置\n# ============================================================\nprint('测试 2：降噪空域/时域分开设置')\nprint()\n\n# 初始状态\nset_nr(spatial=50, temporal=50)\ntime.sleep(0.5)\nnr = get_nr()\nprint(f'  初始状态: 空域={nr[\"spatial\"]}, 时域={nr[\"temporal\"]}')\n\n# 只改空域，时域应保持\nset_nr(spatial=70)\ntime.sleep(0.5)\nnr = get_nr()\ntest2a = nr['spatial'] == 70 and nr['temporal'] == 50\nprint(f'  只改空域=70: 空域={nr[\"spatial\"]}, 时域={nr[\"temporal\"]} - {\"PASS\" if test2a else \"FAIL\"}')\n\n# 只改时域，空域应保持\nset_nr(temporal=80)\ntime.sleep(0.5)\nnr = get_nr()\ntest2b = nr['spatial'] == 70 and nr['temporal'] == 80\nprint(f'  只改时域=80: 空域={nr[\"spatial\"]}, 时域={nr[\"temporal\"]} - {\"PASS\" if test2b else \"FAIL\"}')\n\n# 连续改空域，时域不变\nfor i, s_val in enumerate([60, 50, 40, 30]):\n    set_nr(spatial=s_val)\n    time.sleep(0.3)\n    nr = get_nr()\n    test = nr['spatial'] == s_val and nr['temporal'] == 80\n    print(f'  连续改空域={s_val}: 空域={nr[\"spatial\"]}, 时域={nr[\"temporal\"]} - {\"PASS\" if test else \"FAIL\"}')\n\nprint()\n\n# ============================================================\n# 测试总结\n# ============================================================\nprint('=== 测试总结 ===')\nprint(f'白平衡 R/B 分开: {\"PASS\" if test1a and test1b else \"FAIL\"}')\nprint(f'降噪空域/时域分开: {\"PASS\" if test2a and test2b else \"FAIL\"}')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_e2e_wb_nr.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":73295,"output":1801,"cacheRead":0,"cacheWrite":0,"totalTokens":75096,"cost":{"input":0.073295,"output":0.0057632000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0790582}},"stopReason":"toolUse","timestamp":1781396046775,"responseId":"cht000d42a8@dx19ec37a92ffb8ab282"}}
