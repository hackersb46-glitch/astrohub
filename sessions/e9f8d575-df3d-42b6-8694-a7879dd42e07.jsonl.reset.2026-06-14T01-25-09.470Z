{"type":"message","id":"d517b419","parentId":"be732be8","timestamp":"2026-06-13T20:41:23.698Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，由于前端代码（index.html）是控制端网页，您明确说不要修改它，我需要专注于后端程序的修复。\n\n让我检查画面控制后端 API 的实现是否正确："},{"type":"toolCall","id":"tool-cb62dfb912e641cca30112d46c2a62a8","name":"read","arguments":{"limit":150,"offset":2705,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":85785,"output":86,"cacheRead":0,"cacheWrite":0,"totalTokens":85871,"cost":{"input":0.085785,"output":0.0002752,"cacheRead":0,"cacheWrite":0,"total":0.0860602}},"stopReason":"toolUse","timestamp":1781383269679,"responseId":"cht000df2a0@dx19ec2b79cafb87f702"}}
{"type":"message","id":"3925e743","parentId":"d517b419","timestamp":"2026-06-13T20:41:23.704Z","message":{"role":"toolResult","toolCallId":"tool-cb62dfb912e641cca30112d46c2a62a8","toolName":"read","content":[{"type":"text","text":"\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/noisereduce\", summary=\"获取降噪设置\", tags=[\"Image\"])\r\nasync def get_noisereduce(device_id: str) -> dict:\r\n    \"\"\"获取设备降噪当前设置。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        resp = client.get(\"/Image/channels/1/noiseReduce\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"获取降噪失败: HTTP {resp.status_code}\"}\r\n\r\n        root = ET.fromstring(resp.xml)\r\n        result = {\"success\": True, \"data\": {}}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n            if tag in (\"generalLevel\", \"GeneralLevel\"):\r\n                val = int((elem.text or \"50\").strip())\r\n                result[\"data\"][\"spatial_level\"] = val\r\n                result[\"data\"][\"temporal_level\"] = val\r\n\r\n        return result\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"获取降噪异常: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/image/noisereduce\", summary=\"设置降噪\", tags=[\"Image\"])\r\nasync def set_noisereduce(device_id: str, data: dict) -> dict:\r\n    \"\"\"设置降噪参数。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        # 构造降噪 XML\r\n        spatial = data.get(\"spatial_level\", 50)\r\n        temporal = data.get(\"temporal_level\", 50)\r\n        \r\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n  <generalLevel>{spatial}</generalLevel>\r\n</NoiseReduce>'''\r\n\r\n        put_resp = client.put(\"/Image/channels/1/noiseReduce\", xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"降噪已更新\"}\r\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置降噪异常: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/image/reset\", summary=\"重置画面控制到默认值\", tags=[\"Image\"])\r\nasync def reset_image_controls(device_id: str) -> dict:\r\n    \"\"\"v6.50: 重置设备画面控制到系统默认值。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        # 使用设备恢复默认值 API\r\n        resp = client.put(\r\n            \"/System/restoreToDefaults\",\r\n            '<?xml version=\"1.0\" encoding=\"UTF-8\"?><restore xmlns=\"http://www.hikvision.com/ver20/XMLSchema\"/>'\r\n        )\r\n        if resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"画面控制已重置到系统默认值\"}\r\n        return {\"success\": False, \"message\": f\"重置失败: HTTP {resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"重置异常: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/exposure\", summary=\"获取曝光模式\", tags=[\"Image\"])\r\nasync def get_exposure(device_id: str) -> dict:\r\n    \"\"\"获取设备曝光当前模式。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        resp = client.get(\"/Image/channels/1/exposure\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"获取曝光模式失败: HTTP {resp.status_code}\"}\r\n\r\n        root = ET.fromstring(resp.xml)\r\n        result = {\"success\": True, \"data\": {}}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n            if tag in (\"ExposureMode\", \"exposureMode\"):\r\n                result[\"data\"][\"mode\"] = elem.text or \"auto\"\r\n\r\n        # 如果没有找到曝光模式，默认 auto\r\n        if \"mode\" not in result[\"data\"]:\r\n            result[\"data\"][\"mode\"] = \"auto\"\r\n        return result\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"获取曝光模式异常: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/image/exposure\", summary=\"设置曝光模式\", tags=[\"Image\"])\r\nasync def set_exposure(device_id: str, data: dict) -> dict:\r\n    \"\"\"设置曝光模式。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\n[386 more lines in file. Use offset=2855 to continue.]"}],"isError":false,"timestamp":1781383283704}}
