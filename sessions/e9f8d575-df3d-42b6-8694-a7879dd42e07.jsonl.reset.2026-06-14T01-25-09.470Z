{"type":"message","id":"bf48d838","parentId":"b2eb8996","timestamp":"2026-06-13T22:38:44.589Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，前端代码是正确的：`onmousedown=\"ptzMove('right')\"`\n\n问题可能是 Playwright 的 `dispatch_event('mousedown')` 和真实的 `mousedown` 行为不同。\n\n让我直接用 Playwright 监听 API 请求，检查实际发送的 `speed` 值："},{"type":"toolCall","id":"tool-b43b56302d494067b43c9aadd6ee661f","name":"write","arguments":{"content":"\"\"\"Playwright 监听 API 请求检查 speed 值\"\"\"\nimport asyncio\nfrom playwright.async_api import async_playwright\n\nasync def test_api_request():\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False, slow_mo=100)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        # 监听 API 请求\n        requests_log = []\n        \n        page.on('request', lambda req: None)  # 先不处理\n        \n        def handle_request(req):\n            if '/api/v1/ptz/' in req.url and '/move' in req.url:\n                post_data = req.post_data\n                if post_data:\n                    requests_log.append({\n                        'url': req.url,\n                        'method': req.method,\n                        'data': post_data\n                    })\n                    print(f'API 请求: {req.method} {req.url}')\n                    print(f'  数据: {post_data}')\n        \n        page.on('request', handle_request)\n        \n        print('=== Playwright 监听 API 请求检查 speed 值 ===')\n        print()\n        \n        # 访问 AstroHub\n        await page.goto('http://localhost:10280/', wait_until='networkidle')\n        await asyncio.sleep(2)\n        \n        # 进入主控台\n        console_btn = await page.query_selector('[data-page=\"console\"]')\n        if console_btn:\n            await console_btn.click()\n            await asyncio.sleep(1)\n        \n        # 展开 PTZ 控制区域\n        ptz_section = await page.query_selector('#ptzControlSection')\n        if ptz_section:\n            is_collapsed = await ptz_section.evaluate('el => el.classList.contains(\"collapsed\")')\n            if is_collapsed:\n                header = await ptz_section.query_selector('.collapsible-header')\n                if header:\n                    await header.click()\n                    await asyncio.sleep(0.5)\n        \n        # 测试各档位\n        print('测试各档位 API 请求...')\n        print()\n        \n        slider = await page.query_selector('#ptzSpeed')\n        \n        for gear in [1, 7]:\n            requests_log.clear()\n            \n            # 设置滑动条值\n            await slider.evaluate(f'el => el.value = \"{gear}\"')\n            await slider.evaluate('el => el.dispatchEvent(new Event(\"input\"))')\n            await slider.evaluate('el => el.dispatchEvent(new Event(\"change\"))')\n            \n            print(f'档位 {gear}:')\n            \n            # 找到向右按钮\n            right_btns = await page.query_selector_all('.ptz-btn')\n            right_btn = None\n            for btn in right_btns:\n                text = await btn.inner_text()\n                if '→' in text or text.strip() == '→':\n                    right_btn = btn\n                    break\n            \n            if right_btn:\n                # 模拟 mousedown\n                await right_btn.dispatch_event('mousedown')\n                await asyncio.sleep(0.2)\n                await right_btn.dispatch_event('mouseup')\n            \n            await asyncio.sleep(0.5)\n            \n            # 检查请求日志\n            if requests_log:\n                for log in requests_log:\n                    print(f'  请求: {log[\"data\"]}')\n                    # 解析 JSON\n                    import json\n                    try:\n                        data = json.loads(log['data'])\n                        speed = data.get('speed', 'N/A')\n                        print(f'  speed 值: {speed}')\n                    except:\n                        pass\n            else:\n                print('  未捕获到 API 请求')\n            \n            print()\n        \n        print('浏览器保持打开 10 秒...')\n        await asyncio.sleep(10)\n        \n        await browser.close()\n\nif __name__ == '__main__':\n    asyncio.run(test_api_request())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_api_request.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":100565,"output":885,"cacheRead":0,"cacheWrite":0,"totalTokens":101450,"cost":{"input":0.100565,"output":0.0028320000000000003,"cacheRead":0,"cacheWrite":0,"total":0.103397}},"stopReason":"toolUse","timestamp":1781390298587,"responseId":"cht000d0adc@dx19ec322e2bdb87f702"}}
