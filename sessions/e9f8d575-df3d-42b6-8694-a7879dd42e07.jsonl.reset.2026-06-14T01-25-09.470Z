{"type":"message","id":"c6b932c3","parentId":"37f61b70","timestamp":"2026-06-13T20:37:02.774Z","message":{"role":"toolResult","toolCallId":"tool-b7d3e341299e452cb0c490ae9576fd38","toolName":"read","content":[{"type":"text","text":"\"\"\"AstroHub E2E 测试\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_astrohub():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        errors = []\n        \n        try:\n            # 1. 打开主页\n            print('[TEST] 打开主页...')\n            page.goto('http://localhost:10280/', timeout=10000)\n            page.wait_for_load_state('networkidle', timeout=15000)\n            print('[PASS] 主页加载成功')\n            \n            # 2. 检查版本号\n            version = page.locator('.version').text_content()\n            print(f'[INFO] 版本: {version}')\n            \n            # 3. 检查设备列表\n            print('[TEST] 切换到设备管理...')\n            page.click('button[data-page=\"devices\"]')\n            page.wait_for_timeout(3000)\n            \n            device_rows = page.locator('#deviceTable tr').count()\n            print(f'[INFO] 设备数量: {device_rows}')\n            \n            if device_rows > 0:\n                first_row = page.locator('#deviceTable tr').first\n                row_text = first_row.text_content()\n                print(f'[DEBUG] 第一行: {row_text[:80]}...')\n                print('[PASS] 设备列表渲染正常')\n            else:\n                errors.append('设备列表为空')\n            \n            # 4. 检查设备状态\n            print('[TEST] 检查设备连接按钮...')\n            disconnect_btn = page.locator('button.disconnect-btn').count()\n            if disconnect_btn > 0:\n                print('[PASS] 设备在线，显示断开按钮')\n            else:\n                print('[INFO] 设备离线')\n            \n            # 5. 截图\n            page.screenshot(path='tests/screenshots/e2e_final.png')\n            print('[INFO] 截图已保存')\n            \n        except Exception as e:\n            errors.append(str(e))\n            page.screenshot(path='tests/screenshots/error.png')\n        \n        finally:\n            browser.close()\n        \n        if errors:\n            print('[FAILED] 错误:', errors)\n            return False\n        else:\n            print('[PASS] 所有测试通过')\n            return True\n\nif __name__ == '__main__':\n    test_astrohub()"}],"isError":false,"timestamp":1781383022774}}
{"type":"message","id":"d4195e84","parentId":"c6b932c3","timestamp":"2026-06-13T20:37:12.600Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我需要创建 PTZ 速度测试。但首先，让我先确认服务是否运行："},{"type":"toolCall","id":"call_b387f4b309274866926452d1","name":"exec","arguments":{"command":"Invoke-WebRequest -Uri \"http://localhost:10280/api/v1/health\" -TimeoutSec 5 -UseBasicParsing 2>$null | Select-Object StatusCode,Content","timeout":10,"workdir":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":99275,"output":94,"cacheRead":0,"cacheWrite":0,"totalTokens":99369,"cost":{"input":0.099275,"output":0.00030080000000000005,"cacheRead":0,"cacheWrite":0,"total":0.0995758}},"stopReason":"toolUse","timestamp":1781383022776,"responseId":"cht000dc488@dx19ec2b3db39ba60352"}}
{"type":"message","id":"4f8c4492","parentId":"d4195e84","timestamp":"2026-06-13T20:37:15.136Z","message":{"role":"toolResult","toolCallId":"call_b387f4b309274866926452d1","toolName":"exec","content":[{"type":"text","text":"[32;1mStatusCode[0m[32;1m Content[0m\r\n[32;1m----------[0m [32;1m-------[0m\r\n       200 {\"status\":\"degraded\",\"modules\":{\"ptz_manager\":{\"status\":\"initialized\",\"present\":true},\"device_manager\":{\"st��"}],"details":{"status":"completed","exitCode":0,"durationMs":2529,"aggregated":"[32;1mStatusCode[0m[32;1m Content[0m\r\n[32;1m----------[0m [32;1m-------[0m\r\n       200 {\"status\":\"degraded\",\"modules\":{\"ptz_manager\":{\"status\":\"initialized\",\"present\":true},\"device_manager\":{\"st��","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781383035136}}
{"type":"message","id":"bf61811f","parentId":"4f8c4492","timestamp":"2026-06-13T20:37:47.299Z","message":{"role":"assistant","content":[{"type":"text","text":"服务正在运行。现在让我创建 PTZ 速度端到端测试："},{"type":"toolCall","id":"call_3a9a8511d4ce463e9e575772","name":"write","arguments":{"content":"\"\"\"AstroHub PTZ速度端到端测试\n\n验证 PTZ 速度修复：\n1. 速度值直接传给设备（-100到100）\n2. 不做 /10 或 /100 映射\n\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_ptz_speed():\n    \"\"\"测试 PTZ 速度控制\"\"\"\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        errors = []\n        \n        try:\n            # 1. 打开主页\n            print('[TEST] 打开主页...')\n            page.goto('http://localhost:10280/', timeout=10000)\n            page.wait_for_load_state('networkidle', timeout=15000)\n            print('[PASS] 主页加载成功')\n            \n            # 2. 切换到主控台\n            print('[TEST] 切换到主控台...')\n            page.click('button[data-page=\"console\"]')\n            page.wait_for_timeout(2000)\n            \n            # 3. 检查 PTZ 速度滑动条\n            print('[TEST] 检查 PTZ 速度滑动条...')\n            speed_slider = page.locator('#ptzSpeed')\n            if speed_slider.count() > 0:\n                speed_value = speed_slider.input_value()\n                print(f'[INFO] 当前速度值: {speed_value}')\n                \n                # 检查滑动条范围\n                min_val = speed_slider.get_attribute('min')\n                max_val = speed_slider.get_attribute('max')\n                print(f'[INFO] 速度范围: {min_val} - {max_val}')\n                \n                # 设置速度为 100\n                speed_slider.fill('100')\n                page.wait_for_timeout(500)\n                \n                # 检查显示值\n                speed_display = page.locator('#ptzSpeedVal').text_content()\n                print(f'[INFO] 显示速度: {speed_display}')\n                \n                print('[PASS] PTZ 速度滑动条正常')\n            else:\n                errors.append('PTZ 速度滑动条不存在')\n            \n            # 4. 截图\n            page.screenshot(path='tests/screenshots/ptz_speed_test.png')\n            print('[INFO] 截图已保存')\n            \n        except Exception as e:\n            errors.append(str(e))\n            page.screenshot(path='tests/screenshots/ptz_speed_error.png')\n        \n        finally:\n            browser.close()\n        \n        if errors:\n            print('[FAILED] 错误:', errors)\n            return False\n        else:\n            print('[PASS] 所有测试通过')\n            return True\n\nif __name__ == '__main__':\n    test_ptz_speed()\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_ptz_speed.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":89673,"output":618,"cacheRead":0,"cacheWrite":0,"totalTokens":90291,"cost":{"input":0.089673,"output":0.0019776000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0916506}},"stopReason":"toolUse","timestamp":1781383035137,"responseId":"cht000d7510@dx19ec2b413d0ba5c342"}}
