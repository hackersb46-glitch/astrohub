('=== 直接测试修复后的代码 ===')\nprint()\n\n# 直接测试后端代码逻辑\nimport sys\nsys.path.insert(0, 'C:/Users/admin/.openclaw/agents/dev-factory/astrohub')\n\n# 测试白平衡设置\nprint('1. 测试白平衡 R/B 设置:')\nprint()\n\nfor i in range(5):\n    red_val = 80 + i * 20\n    blue_val = 60 + i * 15\n    \n    # 直接通过 ISAPI 设置\n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<WhiteBalanceStyle>Manual</WhiteBalanceStyle>\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\n</Whi\n... (truncated)"},"isError":false,"timestamp":1781391963320}}
{"type":"message","id":"a2eabcc7","parentId":"38491106","timestamp":"2026-06-13T23:06:25.880Z","message":{"role":"assistant","content":[{"type":"text","text":"修改测试文件使用小写："},{"type":"toolCall","id":"tool-598ba0d97f0847a98ea08e8c932dad8a","name":"write","arguments":{"content":"\"\"\"直接测试 AstroHub API - 白平衡和降噪（使用正确的小写格式）\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nimport re\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase_isapi = f'http://{ip}/ISAPI'\n\nprint('=== 直接测试修复后的代码 ===')\nprint()\n\n# 测试白平衡设置（使用小写 manual）\nprint('1. 测试白平衡 R/B 设置:')\nprint()\n\nwb_results = []\nfor i in range(5):\n    red_val = 80 + i * 20\n    blue_val = 60 + i * 15\n    \n    # 使用小写的 manual\n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<WhiteBalanceStyle>manual</WhiteBalanceStyle>\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\n</WhiteBalance>'''\n    \n    r = requests.put(f'{base_isapi}/Image/channels/1/whiteBalance', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    # 验证\n    r2 = requests.get(f'{base_isapi}/Image/channels/1/whiteBalance', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    actual_red = re.search(r'<WhiteBalanceRed>(\\d+)</WhiteBalanceRed>', r2.text)\n    actual_blue = re.search(r'<WhiteBalanceBlue>(\\d+)</WhiteBalanceBlue>', r2.text)\n    \n    red_match = int(actual_red.group(1)) == red_val if actual_red else False\n    blue_match = int(actual_blue.group(1)) == blue_val if actual_blue else False\n    \n    status = 'PASS' if (r.status_code == 200 and red_match and blue_match) else 'FAIL'\n    wb_results.append(status == 'PASS')\n    \n    print(f'  测试 {i+1}: R={red_val}, B={blue_val} -> PUT={r.status_code}, 验证={status}')\n    \n    time.sleep(1)\n\nprint()\n\n# 测试降噪设置\nprint('2. 测试降噪设置:')\nprint()\n\nnr_results = []\nfor i in range(5):\n    level = 30 + i * 15\n    \n    xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<NoiseReduce version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n<mode>general</mode>\n<GeneralMode>\n<generalLevel>{level}</generalLevel>\n</GeneralMode>\n</NoiseReduce>'''\n    \n    r = requests.put(f'{base_isapi}/Image/channels/1/noiseReduce', data=xml.encode('utf-8'), auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    # 验证\n    r2 = requests.get(f'{base_isapi}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    \n    actual_level = re.search(r'<generalLevel>(\\d+)</generalLevel>', r2.text)\n    level_match = int(actual_level.group(1)) == level if actual_level else False\n    \n    status = 'PASS' if (r.status_code == 200 and level_match) else 'FAIL'\n    nr_results.append(status == 'PASS')\n    \n    print(f'  测试 {i+1}: level={level} -> PUT={r.status_code}, 验证={status}')\n    \n    time.sleep(1)\n\nprint()\nprint('=== 测试总结 ===')\nprint(f'白平衡 R/B: {sum(wb_results)}/5 通过')\nprint(f'降噪设置: {sum(nr_results)}/5 通过')\n\nif sum(wb_results) == 5 and sum(nr_results) == 5:\n    print()\n    print('所有测试通过！')\nelse:\n    print()\n    print('有测试失败！')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_final_image.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":144909,"output":953,"cacheRead":0,"cacheWrite":0,"totalTokens":145862,"cost":{"input":0.14490899999999998,"output":0.0030496000000000004,"cacheRead":0,"cacheWrite":0,"total":0.1479586}},"stopReason":"toolUse","timestamp":1781391963325,"responseId":"cht000ddd5c@dx19ec33c369ab9cb212"}}
