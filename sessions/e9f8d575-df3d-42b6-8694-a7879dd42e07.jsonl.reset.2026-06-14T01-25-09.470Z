{"type":"message","id":"848a0421","parentId":"f7126073","timestamp":"2026-06-13T20:22:39.015Z","message":{"role":"toolResult","toolCallId":"tool-fb1124213e5741fd86c705e39d3966da","toolName":"read","content":[{"type":"text","text":"        var g_bLoggedIn = false;\r\n        var g_bPlaying = false;\r\n        var g_iRtspPort = 554;\r\nvar g_szDeviceIdentify2 = \"\";\r\nvar g_bLoggedIn2 = false;\r\nvar g_bPlaying2 = false;\r\nvar g_iRtspPort2 = 554;\r\nvar g_iWndIndex2 = 0;\r\nvar g_iWebSocketPort = 7681;\r\n        var g_iWndIndex = 0;\r\nvar g_iChannelList = [];\r\nvar g_iChannelID = 1;\r\n        var g_iChannelID = 1;\r\n// Global functions\r\n    (function() {\r\n        'use strict';\r\n        // ================================================================\r\n        //  Configuration\r\n        // ================================================================\r\n        var API_BASE = window.location.origin;\r\n        var WS_URL = (window.location.protocol === 'https:' ? 'wss' : 'ws') + '://' + window.location.host + '/ws';\r\n        // Cached device data\r\n        var allDevices = [];\r\n        var currentModal = null;\r\n        // --- v3: Global connected device state ---\r\n        // Advanced menu state (now sidebar)\r\n        var advMenuActive = false;\r\n        var advCurrentSub = 'calibration';\r\n        // Onboarding wizard state\r\n        var wizardState = {\r\n            step: 0,\r\n            totalSteps: 5,\r\n            mac: '',\r\n            deviceIP: '',\r\n            runningTest: false,\r\n            testResults: { function: null, limit: null, speed: null }\r\n        };\r\n        // ================================================================\r\n        //  Initialization\r\n        // ================================================================\r\n        function init() {\r\n            console.log('[INIT] init() called');\r\n            updateClock();\r\n            setInterval(updateClock, 1000);\r\n            initNav();\r\n            initPtzSpeed();\r\n            initMouseUp();\r\n            refreshDevices();\r\n            // v6.0: 从后端获取连接状态\r\n            restoreConnectionState();\r\n            addLog('info', 'AstroHub 已启动');\r\n            connectWS();\r\n        }\r\n        // v6.0: 从后端恢复连接状态\r\n        function restoreConnectionState() {\r\n            // v6.44: 初始化 WASM 状态为“未连接”\r\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\r\n            \r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.connected && r.device) {\r\n                    window.connectedDevice = r.device;\r\n                    console.log('[v6.0] 已恢复连接:', r.device.ip);\r\n                    \r\n                    // v6.34: 更新状态显示\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus(r.device);\r\n                    \r\n                    // v6.12: 加载图像参数\r\n                    if (window.loadDeviceImageParams) {\r\n                        setTimeout(function() { window.loadDeviceImageParams(r.device.ip); }, 300);\r\n                    }\r\n                    \r\n                    // v6.44: 移除这里的 clickLogin2 调用，让 WASM SDK cbInitPluginComplete 触发\r\n                    // 这样确保 WASM SDK 初始化完成后再登录\r\n                } else if (r && r.success && !r.connected) {\r\n                    // v6.16: 无上次连接设备\r\n                    console.log('[v6.16] 无上次连接设备');\r\n                    // v6.34: 更新状态显示\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus(null);\r\n                    // 显示提示（3秒后自动消失）\r\n                    setTimeout(function() {\r\n                        showToast('info', '无上次连接设备，请执行发现流程');\r\n                    }, 1000);\r\n                }\r\n            }).catch(function(e) {\r\n                console.warn('[v6.0] 获取连接状态失败:', e);\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  Navigation\r\n        // ================================================================\r\n        function initNav() {\r\n            document.querySelectorAll('.nav-btn[data-page]').forEach(function(btn) {\r\n                btn.addEventListener('click', function() {\r\n                    document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n                    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n                    btn.classList.add('active');\r\n                    document.getElementById('page-' + btn.getAttribute('data-page')).classList.add('active');\r\n                    if (btn.getAttribute('data-page') === 'devices') { refreshDevices(); }\r\n                    if (btn.getAttribute('data-page') === 'console') {\r\n                        refreshPtzDeviceList();\r\n                        // v6.12: 预渲染 WASM（如果已连接）\r\n                        if (window.connectedDevice && window.connectedDevice.ip) {\r\n                            var container = document.getElementById('divPlugin');\r\n                            if (container && !container.innerHTML.trim()) {\r\n                                container.innerHTML = '<div style=\"display:flex;align-items:center;justify-content:center;height:100%;color:#6e7681;font-size:14px\">正在加载画面...</div>';\r\n                            }\r\n                        }\r\n                        loadWasmDevices();\r\n                        // Resize WASM player when console becomes visible\r\n                        setTimeout(function() {\r\n                            var container = document.getElementById('divPlugin');\r\n                            if (container && window.WebVideoCtrl) {\r\n                                try { WebVideoCtrl.I_Resize(container.offsetWidth, container.offsetHeight); console.log('[WASM] Resized to', container.offsetWidth, container.offsetHeight); } catch(e) { console.warn('Resize error:', e); }\r\n                            }\r\n                        }, 100);\r\n                        // WASM login if already connected\r\n                        if (window.connectedDevice && window.clickLogin2) {\r\n                            window.clickLogin2();\r\n                        }\r\n                    }\r\n                    if (btn.getAttribute('data-page') === 'advanced') initAdvSidebar();\r\n                    if (btn.getAttribute('data-page')) refreshAdvancedDeviceSelectors();\r\n                });\r\n            });\r\n        }\r\n        // Sidebar click handlers for advanced page sub-items\r\n        function initAdvSidebar() {\r\n            document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(item) {\r\n                item.onclick = function() {\r\n                    var subPage = item.getAttribute('data-sub');\r\n                    // Update sidebar active state\r\n                    document.querySelectorAll('#advSidebar .sidebar-item').forEach(function(b) { b.classList.remove('active'); });\r\n                    item.classList.add('active');\r\n                    // Show sub-page\r\n                    document.querySelectorAll('#advContent .page').forEach(function(p) { p.classList.remove('active'); });\r\n                    var target = document.getElementById('page-' + subPage);\r\n                    if (target) target.classList.add('active');\r\n                    advCurrentSub = subPage;\r\n                };\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  Device Selectors for Advanced Pages\r\n        // ================================================================\r\n        function refreshAdvancedDeviceSelectors() {\r\n            var online = (allDevices || []).filter(function(d) { return d.online; });\r\n            var selectors = ['advFuncDevice', 'advLimitDevice', 'advSpeedDevice', 'calDevice', 'advStreamDevice'];\r\n            selectors.forEach(function(id) {\r\n                var sel = document.getElementById(id);\r\n                if (!sel) return;\r\n                var current = sel.value;\r\n                // Rebuild options\r\n                sel.innerHTML = '';\r\n                if (id === 'calDevice' || id === 'advConnectDevice') {\r\n                    var defaultOpt = document.createElement('option');\r\n                    defaultOpt.textContent = '未选择设备';\r\n                    defaultOpt.value = '';\r\n                    sel.appendChild(defaultOpt);\r\n                }\r\n                online.forEach(function(d) {\r\n                    var option = document.createElement('option');\r\n                    option.value = d.ip;\r\n                    option.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                    sel.appendChild(option);\r\n                });\r\n                if (current) sel.value = current;\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  API helpers - exposed to global scope for console.html\r\n        // ================================================================\r\n        async function apiGet(path) {\r\n            var r = await fetch(API_BASE + path);\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        async function apiPost(path, body) {\r\n            var opts = { method: 'POST', headers: {'Content-Type': 'application/json'} };\r\n            if (body) opts.body = JSON.stringify(body);\r\n            var r = await fetch(API_BASE + path, opts);\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        // Expose to global scope\r\n        window.apiGet = apiGet;\r\n        window.apiPost = apiPost;\r\n        async function apiDelete(path) {\r\n            var r = await fetch(API_BASE + path, { method: 'DELETE' });\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        async function apiPut(path, body) {\r\n            var r = await fetch(API_BASE + path, {\r\n                method: 'PUT',\r\n                headers: { 'Content-Type': 'application/json' },\r\n                body: JSON.stringify(body)\r\n            });\r\n            if (!r.ok) throw new Error('HTTP ' + r.status);\r\n            return r.json();\r\n        }\r\n        window.apiDelete = apiDelete;\r\n        window.apiPut = apiPut;\r\n        // ================================================================\r\n        //  Function Detection (P4.1-P4.21)\r\n        // ================================================================\r\n        function funcDetectRun() {\r\n            if (!window.connectedDevice || !window.connectedDevice.ip) { showToast('warning', '请先在「设备管理」中连接设备'); return; }\r\n            var deviceIp = window.connectedDevice.ip;\r\n            var device = window.connectedDevice;\r\n            var btn = document.getElementById('btnFuncRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 探测中...';\r\n            document.getElementById('funcProgress').style.display = 'block';\r\n            document.getElementById('funcResultArea').innerHTML = '';\r\n            addLog('info', '功能探测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/function/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始探测';\r\n                document.getElementById('funcProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '功能探测完成');\r\n                    addLog('success', '功能探测完成: ' + (resp.message || ''));\r\n                    renderFuncResults(resp.results || {});\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '探测失败');\r\n                    addLog('error', '功能探测失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n                if (barEl) barEl.style.width = pct + '%';\r\n            }, 2000);\r\n        }\r\n        function simulateDirections() {\r\n            var dirs = ['P+ 移动中...', 'P- 移动中...', 'T+ 移动中...', 'T- 移动中...'];\r\n            var i = 0;\r\n            var interval = setInterval(function() {\r\n                var el = document.getElementById('limitDirection');\r\n                if (!el) { clearInterval(interval); return; }\r\n                if (i >= dirs.length) { clearInterval(interval); el.textContent = '测试完成 ✓'; el.style.color = '#3fb950'; return; }\r\n                el.textContent = '当前方向: ' + dirs[i];\r\n                i++;\r\n            }, 3000);\r\n        }\r\n        // ================================================================\r\n        //  Connect Device Page (高级功能 -> 连接设备)\r\n        // ================================================================\r\n        function onConnectDeviceChange() {\r\n            var ip = document.getElementById('advConnectDevice').value;\r\n            var noDevice = document.getElementById('connectNoDevice');\r\n            var controlArea = document.getElementById('connectControlArea');\r\n            var statusSpan = document.getElementById('connectDeviceStatus');\r\n            if (ip) {\r\n                var device = allDevices.find(function(d) { return d.ip === ip; });\r\n                noDevice.style.display = 'none';\r\n                controlArea.style.display = 'block';\r\n                statusSpan.textContent = device ? ('已连接: ' + ip) : ip;\r\n            } else {\r\n                noDevice.style.display = 'block';\r\n                controlArea.style.display = 'none';\r\n                statusSpan.textContent = '';\r\n            }\r\n        }\r\n        // 功能检测（连接设备页面版）\r\n        function connectFuncDetectRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectFuncRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 探测中...';\r\n            document.getElementById('connectFuncProgress').style.display = 'block';\r\n            document.getElementById('connectFuncResultMini').innerHTML = '';\r\n            addLog('info', '功能检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/function/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '功能检测完成');\r\n                    addLog('success', '功能检测完成: ' + (resp.message || ''));\r\n                    renderConnectFuncResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'function');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '探测失败');\r\n                    addLog('error', '功能检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectFuncResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '探测失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectFuncProgress').style.display = 'none';\r\n                showToast('error', '探测异常: ' + e.message);\r\n\n[2136 more lines in file. Use offset=700 to continue.][... 12293 more characters truncated]"}],"isError":false,"timestamp":1781382159015}}
{"type":"message","id":"23b2d3bf","parentId":"848a0421","timestamp":"2026-06-13T20:22:39.015Z","message":{"role":"toolResult","toolCallId":"tool-d72b33ff88da4213a48b252f8a078fd2","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nAstroHub v2.0 - 统一路由聚合\r\n\r\n整合 M1-M11 所有模块路由到 /api/v1/ 下:\r\n- /api/v1/health            - 全局健康检查\r\n- /api/v1/discovery/sadp    - SADP 设备发现\r\n- /api/v1/devices/*         - 设备管理（真实）\r\n- /api/v1/ptz/*             - PTZ 控制（真实）\r\n- /api/v1/streams/*         - 流服务\r\n- /api/v1/calibration/*     - 校准\r\n- /api/v1/ascom/*           - ASCOM 设备\r\n- /api/v1/settings          - 系统设置\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel\r\nfrom fastapi import APIRouter, FastAPI, Query\r\nfrom fastapi.responses import JSONResponse\r\n\r\n# v6.40: 操作日志\r\nfrom src.operation_logger import log_api, log_web, log_error, log_info\r\n\r\n# ================================================================ #\r\n#  核心模块导入\r\n# ================================================================ #\r\n\r\nfrom src.core.ptz_manager import PTZManager\r\nfrom src.core.device_manager import DeviceManager\r\nfrom src.core.stream_manager import StreamManager\r\nfrom src.core.calibration_manager import CalibrationManager\r\nfrom src.core.auth import AuthManager\r\nfrom src.core.ws_manager import WebSocketManager\r\nfrom src.core.ascom_manager import ASCOMManager\r\nfrom src.core.orchestrator import Orchestrator\r\nfrom src.core.health_monitor import HealthMonitor\r\n\r\n\r\n# ================================================================ #\r\n#  路由前缀定义\r\n# ================================================================ #\r\n\r\nAPI_V1_PREFIX = \"/api/v1\"\r\n\r\n# 主 API 路由器\r\napi_router = APIRouter(prefix=API_V1_PREFIX, tags=[\"API v1\"])\r\n\r\n# 健康检查路由器\r\nhealth_router = APIRouter(prefix=\"/api/v1\", tags=[\"System\"])\r\n\r\n\r\n# ================================================================ #\r\n#  v6.40: 操作日志 API\r\n# ================================================================ #\r\n\r\nclass OperationLogRequest(BaseModel):\r\n    \"\"\"操作日志请求.\"\"\"\r\n    level: str = \"INFO\"\r\n    module: str = \"web\"\r\n    action: str = \"\"\r\n    detail: str | dict = \"\"\r\n\r\n@health_router.post(\"/log/operation\", summary=\"记录操作日志\")\r\nasync def log_operation_api(req: OperationLogRequest) -> dict:\r\n    \"\"\"前端发送操作日志到后端.\"\"\"\r\n    from src.operation_logger import log_operation\r\n    log_operation(req.level, req.module, req.action, req.detail)\r\n    return {\"success\": True}\r\n\r\n\r\n# ================================================================ #\r\n#  Pydantic 请求模型\r\n# ================================================================ #\r\n\r\nclass AddDeviceRequest(BaseModel):\r\n    \"\"\"手动添加设备请求。\"\"\"\r\n    ip: str\r\n    port: int = 80\r\n    username: str = \"admin\"\r\n    password: str\r\n    name: str = \"\"\r\n    model: str = \"\"\r\n    mac: str = \"\"\r\n\r\nclass ConnectDeviceRequest(BaseModel):\r\n    \"\"\"连接设备请求。\"\"\"\r\n    username: str = \"admin\"\r\n    password: str\r\n    port: int = 80\r\n\r\nclass ModifyNetworkRequest(BaseModel):\r\n    \"\"\"修改网络配置请求。\"\"\"\r\n    ip: str\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str\r\n\r\nclass SADPIpModifyRequest(BaseModel):\r\n    \"\"\"SADP IP 修改请求 (含循环验证)。\"\"\"\r\n    mac: str\r\n    password: str\r\n    new_ip: str\r\n    original_ip: str = \"\"\r\n    subnet_mask: str = \"255.255.255.0\"\r\n    gateway: str = \"\"\r\n\r\nclass SystemInfoRequest(BaseModel):\r\n    \"\"\"系统信息请求（可选的绑定 ip）。\"\"\"\r\n    nic_index: int | None = None\r\n\r\nclass PTZMoveRequest(BaseModel):\r\n    \"\"\"PTZ 移动请求。\"\"\"\r\n    direction: str\r\n    speed: int = 50\r\n\r\nclass PTZAbsoluteRequest(BaseModel):\r\n    \"\"\"PTZ 绝对移动请求。\"\"\"\r\n    pan: float\r\n    tilt: float\r\n    zoom: float | None = None\r\n    speed: int = 50\r\n\r\nclass PTZPresetRequest(BaseModel):\r\n    \"\"\"PTZ 预置位请求。\"\"\"\r\n    preset_id: int\r\n\r\nclass SADPScanRequest(BaseModel):\r\n    \"\"\"SADP 发现请求。\"\"\"\r\n    bind_ip: str = \"0.0.0.0\"\r\n\r\nclass RemoveDeviceRequest(BaseModel):\r\n    \"\"\"移除设备请求。\"\"\"\r\n    ip: str = \"\"\r\n    mac: str = \"\"\r\n\r\n\r\nclass PTZCaptureRequest(BaseModel):\r\n    \"\"\"PTZ 截图请求。\"\"\"\r\n    stream_url: str = \"\"\r\n    stream_id: str = \"\"\r\n\r\n\r\nclass PTZRecordRequest(BaseModel):\r\n    \"\"\"PTZ 录像请求。\"\"\"\r\n    target_name: str = \"\"\r\n\r\n\r\nclass TelescopeSlewRequest(BaseModel):\r\n    \"\"\"望远镜 Slew 请求。\"\"\"\r\n    ra: float\r\n    dec: float\r\n\r\n\r\nclass TelescopeTrackingRequest(BaseModel):\r\n    \"\"\"望远镜跟踪模式请求。\"\"\"\r\n    mode: str  # trackSidereal / trackLunar / trackSolar / trackOff\r\n\r\n\r\n# ================================================================ #\r\n#  操作日志 (最多 10 条)\r\n# ================================================================ #\r\n\r\noperations_log: list[dict[str, str]] = []\r\nMAX_LOG_ENTRIES = 10\r\n\r\n\r\ndef operation_log(action: str, details: str) -> None:\r\n    \"\"\"追加操作到日志列表（环形缓冲区，最多 MAX_LOG_ENTRIES 条）。\"\"\"\r\n    entry = {\r\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\r\n        \"action\": action,\r\n        \"details\": details,\r\n    }\r\n    operations_log.append(entry)\r\n    if len(operations_log) > MAX_LOG_ENTRIES:\r\n        operations_log.pop(0)\r\n\r\n\r\n# ================================================================ #\r\n#  管理器注入\r\n# ================================================================ #\r\n\r\n_managers: dict[str, Any] = {}\r\n\r\n\r\ndef set_managers(**kwargs: Any) -> None:\r\n    \"\"\"注入所有管理器实例。\"\"\"\r\n    _managers.update(kwargs)\r\n\r\n\r\ndef _resolve_device_id_to_ip(mgr: \"PTZManager\", device_id: str) -> str | None:\r\n    \"\"\"解析 device_id 为实际 IP 地址。\r\n\r\n    device_id 可能是 IP 地址或 MAC 地址。\r\n    - 如果是 IP: 直接返回\r\n    - 如果是 MAC: 从 SADP 发现缓存或已存储设备中查找 IP\r\n    \"\"\"\r\n    import re\r\n    # 判断是否为 MAC 地址格式 (冒号、横杠分隔或无分隔符)\r\n    mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n    # 无分隔符12位十六进制 = MAC\r\n    if len(mac_clean) == 12 and re.match(r'^[0-9a-f]{12}$', mac_clean):\r\n        # 是 MAC 地址，尝试从发现缓存中查找\r\n        discovered = mgr.get_discovered_devices()\r\n        for dev in discovered:\r\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if dev_mac == mac_clean:\r\n                return dev.get(\"ip\")\r\n        # 从已存储设备中查找\r\n        stored = mgr.list_stored_devices()\r\n        for dev in stored:\r\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if dev_mac == mac_clean:\r\n                ip = dev.get(\"ip\", \"\")\r\n                if ip:\r\n                    return ip\r\n        return None\r\n    # 看起来像 IP 地址，直接返回\r\n    return device_id\r\n\r\n\r\n# ================================================================ #\r\n#  健康检查端点\r\n# ================================================================ #\r\n\r\n\r\n@health_router.get(\"/health\", summary=\"全局健康检查\")\r\nasync def global_health() -> dict:\r\n    \"\"\"全局健康检查端点 (GET /api/v1/health)。\"\"\"\r\n    module_keys = (\r\n        \"ptz_manager\",\r\n        \"device_manager\",\r\n        \"stream_manager\",\r\n        \"calibration_manager\",\r\n        \"db_manager\",\r\n        \"auth_service\",\r\n        \"ws_manager\",\r\n        \"ascom_manager\",\r\n        \"health_monitor\",\r\n        \"orchestrator\",\r\n    )\r\n\r\n    module_health: dict[str, dict[str, Any]] = {}\r\n    for key in module_keys:\r\n        module_health[key] = {\r\n            \"status\": \"initialized\" if _managers.get(key) is not None else \"not_initialized\",\r\n            \"present\": key in _managers,\r\n        }\r\n\r\n    all_present = all(m[\"present\"] for m in module_health.values())\r\n    initialized_count = sum(1 for m in module_health.values() if m[\"present\"])\r\n\r\n    return {\r\n        \"status\": \"healthy\" if all_present else \"degraded\",\r\n        \"modules\": module_health,\r\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\r\n    }\r\n\r\n\r\n# ================================================================ #\r\n#  SADP 发现端点\r\n# ================================================================ #\r\n\r\n\r\n@api_router.get(\"/discovery/sadp\", summary=\"SADP 设备发现\", tags=[\"Discovery\"])\r\nasync def sadp_discover(bind_ip: str = \"0.0.0.0\") -> dict:\r\n    \"\"\"通过 SADP 多播发现局域网内 PTZ 设备。\r\n    \r\n    BUG-003 修复: 直接使用 SADPManager，不依赖 PTZManager。\r\n    \"\"\"\r\n    start = time.time()\r\n    \r\n    # 优先使用 PTZManager（如果已初始化）\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if mgr:\r\n        devices = mgr.discover_devices(bind_ip=bind_ip)\r\n    else:\r\n        # 直接使用 SADPManager 不依赖 PTZManager\r\n        try:\r\n            from src.core.sadp_discovery import SADPManager\r\n            sadp_mgr = SADPManager()\r\n            raw_devices = sadp_mgr.discover_devices(timeout=10, bind_ip=bind_ip)\r\n            # 转换为 SADP 标准格式\r\n            devices = []\r\n            for d in raw_devices:\r\n                devices.append({\r\n                    \"mac\": d.get(\"mac\", \"\"),\r\n                    \"ip\": d.get(\"ip\", \"\"),\r\n                    \"subnet_mask\": d.get(\"subnet_mask\", \"\"),\r\n                    \"gateway\": d.get(\"gateway\", \"\"),\r\n                    \"model\": d.get(\"model\", \"\"),\r\n                    \"serial_number\": d.get(\"serial_number\", \"\"),\r\n                    \"device_name\": d.get(\"device_name\", \"\"),\r\n                    \"firmware_version\": d.get(\"firmware_version\", \"\"),\r\n                    \"activated\": d.get(\"activated\", False),\r\n                    \"is_hikvision\": d.get(\"is_hikvision\", False),\r\n                    \"source\": \"sadp\",\r\n                })\r\n        except Exception as e:\r\n            return {\"success\": False, \"message\": f\"SADP 发现异常: {e}\", \"devices\": []}\r\n    \r\n    elapsed = round(time.time() - start, 1)\r\n\r\n    # BUG-015 修复: 统一 MAC 地址格式为横杠小写 (24-0f-9b-76-41-93)\r\n    for dev in devices:\r\n        mac = dev.get(\"mac\", \"\")\r\n        if mac:\r\n            clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if len(clean) == 12:\r\n                dev[\"mac\"] = \"-\".join(clean[i:i+2] for i in range(0, 12, 2))\r\n\r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"发现 {len(devices)} 台设备 (耗时 {elapsed}s)\",\r\n        \"devices\": devices,\r\n        \"count\": len(devices),\r\n    }\r\n\r\n\r\n# ================================================================ #\r\n#  设备管理端点\r\n# ================================================================ #\r\n\r\n\r\n@api_router.get(\"/devices\", summary=\"设备列表\", tags=[\"Devices\"])\r\nasync def list_devices() -> dict:\r\n    \"\"\"获取设备列表（MAC 去重合并 SADP 发现 + 手动存储）.\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"data\": [], \"total\": 0}\r\n\r\n    def _normalize_mac(mac: str) -> str:\r\n        \"\"\"统一 MAC 为无分隔符小写格式 (aabbccddeeff).\r\n\r\n        BUG-016 修复: 增强 MAC 格式校验，拒绝假 MAC 地址（如 IP 地址填入 MAC 字段）。\r\n        \"\"\"\r\n        import re\r\n        clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n        # 验证: 必须是恰好12位十六进制字符\r\n        if len(clean) != 12 or not re.match(r'^[0-9a-f]{12}$', clean):\r\n            return \"\"\r\n        return clean\r\n\r\n    def _has_device_mac(dev: dict) -> bool:\r\n        \"\"\"判断设备是否有有效 MAC.\"\"\"\r\n        return bool(_normalize_mac(dev.get(\"mac\", \"\") or \"\"))\r\n\r\n    stored = mgr.list_stored_devices()\r\n    discovered = mgr.get_discovered_devices()\r\n    online_ips = mgr.list_controllers()\r\n\r\n    # --- Pass 1: 存储设备按 MAC 建索引 ---\r\n    keyed: dict[str, dict[str, Any]] = {}  # normalized_mac -> merged_record\r\n    no_mac: list[dict[str, Any]] = []      # manual entry without MAC\r\n\r\n    for dev in stored:\r\n        mac_norm = _normalize_mac(dev.get(\"mac\", \"\") or \"\")\r\n        if mac_norm:\r\n            keyed[mac_norm] = {\r\n                \"mac\": mac_norm,\r\n                \"ip\": dev.get(\"ip\", \"\"),\r\n                \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),  # 用户设置的名称\r\n                \"model\": dev.get(\"model\", \"\"),  # 设备型号\r\n                \"gateway\": dev.get(\"gateway\", \"\"),  # v6.01\r\n                \"subnet_mask\": dev.get(\"subnet_mask\", \"\"),  # v6.01\r\n                \"source\": \"manual\",\r\n                \"online\": False,  # updated later\r\n                \"activated\": False,\r\n                \"has_credentials\": True,\r\n            }\r\n        else:\r\n            no_mac.append({\r\n                \"mac\": \"\",\r\n                \"ip\": dev.get(\"ip\", \"\"),\r\n                \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),\r\n                \"model\": dev.get(\"model\", \"\"),\r\n                \"source\": \"manual\",\r\n                \"online\": False,\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n    \"\"\"更新画面参数。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    client = mgr._clients.get(target_ip)\r\n    if not client:\r\n        return {\"success\": False, \"message\": f\"ISAPI client not found for {target_ip}\"}\r\n\r\n    try:\r\n        # 先获取当前设置\r\n        resp = client.get(\"/Image/channels/1\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"获取画面设置失败: HTTP {resp.status_code}\"}\r\n\r\n        xml_str = resp.xml\r\n        import xml.etree.ElementTree as ET\r\n        root = ET.fromstring(xml_str)\r\n\r\n        # 修改 Color 节点\r\n        updated = {}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n            if tag == \"Color\":\r\n                for child in elem:\r\n                    ctag = child.tag.split(\"}\")[-1] if \"}\" in child.tag else child.tag\r\n                    if ctag == \"brightnessLevel\" and req.brightness is not None:\r\n                        child.text = str(req.brightness)\r\n                        updated[\"brightness\"] = req.brightness\r\n                    elif ctag == \"contrastLevel\" and req.contrast is not None:\r\n                        child.text = str(req.contrast)\r\n                        updated[\"contrast\"] = req.contrast\r\n                    elif ctag == \"saturationLevel\" and req.saturation is not None:\r\n                        child.text = str(req.saturation)\r\n                        updated[\"saturation\"] = req.saturation\r\n                break\r\n\r\n        # 发送更新\r\n        # 使用 /Image/channels/1/Color 端点，而不是整个 ImageChannel\r\n        color_xml = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<Color version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n<brightnessLevel>{updated.get(\"brightness\", 50)}</brightnessLevel>\r\n<contrastLevel>{updated.get(\"contrast\", 50)}</contrastLevel>\r\n<saturationLevel>{updated.get(\"saturation\", 50)}</saturationLevel>\r\n</Color>'''\r\n        \r\n        put_resp = client.put(\"/Image/channels/1/Color\", color_xml)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"画面设置已更新\", \"data\": updated}\r\n        else:\r\n            return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\r\n\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"更新画面设置异常: {e}\"}\r\n\r\n\r\n@api_router.post(\"/ptz/{device_id}/capture\", summary=\"PTZ 截图（ISAPI 原生）\", tags=[\"PTZ\"])\r\nasync def ptz_capture(device_id: str, req: PTZCaptureRequest | None = None) -> dict:\r\n    \"\"\"通过海康 ISAPI 原生方法截取 PTZ 设备当前视频帧。\r\n\r\n    使用: GET /ISAPI/Streaming/Channels/{channel}/picture\r\n    不再依赖 ffmpeg。\r\n    \"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = mgr._clients.get(target_ip)\r\n    if not client:\r\n        return {\"success\": False, \"message\": f\"ISAPI client not found for {target_ip}\"}\r\n\r\n    try:\r\n        jpeg_bytes = client.capture_picture()\r\n        if not jpeg_bytes:\r\n            return {\"success\": False, \"message\": \"ISAPI 截图失败：设备未返回图像数据\"}\r\n\r\n        # JPEG 头验证\r\n        if jpeg_bytes[:3] != b\"\\xff\\xd8\\xff\":\r\n            return {\"success\": False, \"message\": \"返回的数据不是有效的 JPEG\"}\r\n\r\n        # 保存文件\r\n        from src.stream.constants import DOWNLOAD_IMAGE_DIR\r\n        from src.core.file_naming import generate_filename\r\n\r\n        # 获取设备名称（如有）\r\n\n[Read output capped at 79KB for this call. Use offset=1310 to continue.][... 31033 more characters truncated]"}],"details":{"truncation":{"truncated":true,"truncatedBy":"bytes","totalLines":3240,"totalBytes":127026,"outputLines":1309,"outputBytes":51190,"lastLinePartial":false,"firstLineExceedsLimit":false,"maxLines":2000,"maxBytes":51200}},"isError":false,"timestamp":1781382159015}}
{"type":"message","id":"ca62eca5","parentId":"23b2d3bf","timestamp":"2026-06-13T20:22:48.998Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，我现在明白了整体架构。让我先读取 ISAPI capabilities 端点来了解官方速度规范："},{"type":"toolCall","id":"call_5f2bcc5713ee47d8b23a5b63","name":"read","arguments":{"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\ptz\\isapi\\capabilities.py"}},{"type":"toolCall","id":"call_67bda0eb34c74c58aba5305c","name":"read","arguments":{"limit":300,"offset":700,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":92403,"output":103,"cacheRead":0,"cacheWrite":0,"totalTokens":92506,"cost":{"input":0.092403,"output":0.00032960000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0927326}},"stopReason":"toolUse","timestamp":1781382159016,"responseId":"cht000d2992@dx19ec2a6aadbb828232"}}
{"type":"message","id":"83108172","parentId":"ca62eca5","timestamp":"2026-06-13T20:22:49.012Z","message":{"role":"toolResult","toolCallId":"call_5f2bcc5713ee47d8b23a5b63","toolName":"read","content":[{"type":"text","text":"\"\"\"\r\nPTZ_ASTRO v1.1 - ISAPI 能力探测模块\r\n探测 21 个设备能力端点，获取取值范围，测试后还原。\r\n严格按 doc/review/M1_method.csv P4.1-P4.21 定义。\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nimport xml.etree.ElementTree as ET\r\n\r\nfrom .client import ISAPIClient, ISAPIResponse\r\nfrom src.ptz.core.logger import LOG\r\nfrom src.ptz.constants import ISAPI_CHANNEL\r\n\r\n\r\n# === 能力端点定义 (严格按 M1_method.csv) ===\r\n# 每个能力: 端点, test_key, min, max, test_value, label, mode\r\nCAPABILITIES = {\r\n    # --- P4.1 IrLED 红外补光 ---\r\n    \"ir_led\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/IrLight\",\r\n        \"test_key\": \"brightnessLimit\",\r\n        \"min_val\": 1,\r\n        \"max_val\": 100,\r\n        \"test_val\": 50,\r\n        \"label\": \"IrLED 红外补光\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.2 白光灯 ---\r\n    \"white_balance\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/whiteBalance\",\r\n        \"test_key\": \"WhiteBalanceRed\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 255,\r\n        \"test_val\": 200,\r\n        \"label\": \"白平衡\",\r\n        \"mode\": \"multi_field\",\r\n        \"test_keys\": {\"WhiteBalanceRed\": 200, \"WhiteBalanceBlue\": 200},\r\n    },\r\n    # --- P4.3 Gain 模拟增益 ---\r\n    \"gain\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/gain\",\r\n        \"test_key\": \"GainLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 50,\r\n        \"label\": \"Gain 模拟增益\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.4 Focus 聚焦 ---\r\n    \"focus\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/focusConfiguration\",\r\n        \"test_key\": \"focusStyle\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 0,\r\n        \"test_val\": \"MANUAL\",\r\n        \"label\": \"Focus 聚焦\",\r\n        \"mode\": \"style_switch\",\r\n        \"test_values\": [\"MANUAL\", \"SEMIAUTOMATIC\", \"AUTOMATIC\"],\r\n    },\r\n    # --- P4.5 快门速度（手动模式） ---\r\n    \"shutter\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/Shutter\",\r\n        \"test_key\": \"ShutterLevel\",\r\n        \"min_val\": \"1/30000\",\r\n        \"max_val\": \"1/25\",\r\n        \"test_val\": \"1/100\",\r\n        \"label\": \"快门速度（手动模式）\",\r\n        \"mode\": \"shutter\",\r\n    },\r\n    # --- P4.6 慢快门 ---\r\n    \"slow_shutter\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/Shutter\",\r\n        \"test_key\": \"minShutterLevelLimit\",\r\n        \"min_val\": \"1/30000\",\r\n        \"max_val\": \"1/25\",\r\n        \"test_val\": None,  # 仅读取不PUT\r\n        \"label\": \"慢快门\",\r\n        \"mode\": \"read_only\",\r\n    },\r\n    # --- P4.7 光圈 Iris ---\r\n    \"iris\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/Iris\",\r\n        \"test_key\": \"IrisLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 400,\r\n        \"test_val\": 50,\r\n        \"label\": \"光圈 Iris\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.8 快门速度(重复端点) ---\r\n    \"shutter_repeat\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/Shutter\",\r\n        \"test_key\": \"ShutterLevel\",\r\n        \"min_val\": \"1/30000\",\r\n        \"max_val\": \"1/25\",\r\n        \"test_val\": \"1/50\",\r\n        \"label\": \"快门速度\",\r\n        \"mode\": \"shutter\",\r\n    },\r\n    # --- P4.9 数字降噪-时域 ---\r\n    \"dnr_temporal\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/noiseReduce\",\r\n        \"test_key\": \"mode\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 0,\r\n        \"test_val\": \"auto\",\r\n        \"label\": \"数字降噪-时域\",\r\n        \"mode\": \"style_switch\",\r\n        \"test_values\": [\"auto\", \"close\"],\r\n    },\r\n    # --- P4.10 数字降噪-空域 ---\r\n    \"dnr_spatial\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/noiseReduce\",\r\n        \"test_key\": \"mode\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 0,\r\n        \"test_val\": \"auto\",\r\n        \"label\": \"数字降噪-空域\",\r\n        \"mode\": \"style_switch\",\r\n        \"test_values\": [\"auto\", \"close\"],\r\n    },\r\n    # --- P4.11 IRCUT 滤波片/日夜转换 ---\r\n    \"ircut\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/IrcutFilter\",\r\n        \"test_key\": \"IrcutFilterAction\",\r\n        \"min_val\": 1,\r\n        \"max_val\": 7,  # nightToDayFilterLevel range\r\n        \"test_val\": \"night\",\r\n        \"label\": \"IRCUT 滤波片/日夜转换\",\r\n        \"mode\": \"action_switch\",\r\n        \"test_values\": [\"night\", \"day\"],\r\n    },\r\n    # --- P4.12 WDR 宽动态 ---\r\n    \"wdr\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/WDR\",\r\n        \"test_key\": \"WDRLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 80,\r\n        \"label\": \"WDR 宽动态\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.13 BLC 背光补偿 ---\r\n    \"blc\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/BLC\",\r\n        \"test_key\": \"enabled\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 1,\r\n        \"test_val\": \"true\",\r\n        \"label\": \"BLC 背光补偿\",\r\n        \"mode\": \"toggle\",\r\n        \"test_values\": [\"true\", \"false\"],\r\n    },\r\n    # --- P4.14 Dehaze 除雾 ---\r\n    \"dehaze\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/dehaze\",\r\n        \"test_key\": \"DehazeLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 80,\r\n        \"label\": \"Dehaze 除雾\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.15 Sharpness 锐度 ---\r\n    \"sharpness\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/Sharpness\",\r\n        \"test_key\": \"SharpnessLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 80,\r\n        \"label\": \"Sharpness 锐度\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.16 亮度 ---\r\n    \"brightness\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/color\",\r\n        \"test_key\": \"brightnessLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 80,\r\n        \"label\": \"亮度\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.17 饱和度 ---\r\n    \"saturation\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/color\",\r\n        \"test_key\": \"saturationLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 80,\r\n        \"label\": \"饱和度\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.18 对比度 ---\r\n    \"contrast\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/color\",\r\n        \"test_key\": \"contrastLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 80,\r\n        \"label\": \"对比度\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.19 Sharpness 锐度 (CSV重复项) ---\r\n    \"sharpness_repeat\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/Sharpness\",\r\n        \"test_key\": \"SharpnessLevel\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 100,\r\n        \"test_val\": 80,\r\n        \"label\": \"Sharpness 锐度 (P4.19)\",\r\n        \"mode\": \"numeric\",\r\n    },\r\n    # --- P4.20 Mirror 镜像 ---\r\n    \"mirror\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/ImageFlip\",\r\n        \"test_key\": \"ImageFlipStyle\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 0,\r\n        \"test_val\": \"LEFTRIGHT\",\r\n        \"label\": \"Mirror 镜像\",\r\n        \"mode\": \"style_switch\",\r\n        \"test_values\": [\"LEFTRIGHT\", \"UPDOWN\", \"CENTER\", \"AUTO\"],\r\n    },\r\n    # --- P4.21 设备还原 ---\r\n    \"restore_all\": {\r\n        \"endpoint\": \"N/A (遍历所有端点)\",\r\n        \"test_key\": \"\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 0,\r\n        \"test_val\": None,\r\n        \"label\": \"设备还原\",\r\n        \"mode\": \"restore\",\r\n    },\r\n    # --- P2 OSD 开关 ---\r\n    \"osd_overlay\": {\r\n        \"endpoint\": \"/Image/channels/{ch}/Overlays\",\r\n        \"test_key\": \"enabled\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 1,\r\n        \"test_val\": \"true\",\r\n        \"label\": \"OSD 开关\",\r\n        \"mode\": \"toggle\",\r\n        \"test_values\": [\"true\", \"false\"],\r\n    },\r\n    # --- P4 PTZCtrl 能力探测 ---\r\n    \"ptz_functions\": {\r\n        \"endpoint\": \"/PTZCtrl/capabilities\",\r\n        \"test_key\": \"supportedPTZFunction\",\r\n        \"min_val\": 0,\r\n        \"max_val\": 0,\r\n        \"test_val\": None,\r\n        \"label\": \"PTZ 能力探测\",\r\n        \"mode\": \"read_only\",\r\n    },\r\n}\r\n\r\n\r\nclass CapabilityDetector:\r\n    \"\"\"设备能力探测器。\"\"\"\r\n\r\n    def __init__(self, client: ISAPIClient) -> None:\r\n        self.client = client\r\n        self.channel = ISAPI_CHANNEL\r\n        self.capabilities: dict = {}\r\n        self._original_values: dict = {}\r\n\r\n    def _get_endpoint(self, cap_def: dict) -> str:\r\n        \"\"\"获取带 channel 的端点路径。\"\"\"\r\n        return cap_def[\"endpoint\"].format(ch=self.channel)\r\n\r\n    def _find_xml_range(self, xml_text: str, key: str, cap_def: dict) -> dict:\r\n        \"\"\"从 XML 响应中提取 min/max 范围。\"\"\"\r\n        result = {\r\n            \"supported\": False,\r\n            \"min\": cap_def[\"min_val\"],\r\n            \"max\": cap_def[\"max_val\"],\r\n            \"value\": 0,\r\n        }\r\n\r\n        try:\r\n            root = ET.fromstring(xml_text)\r\n            # 查找包含 key 的元素\r\n            for elem in root.iter():\r\n                tag_lower = elem.tag.split(\"}\")[-1].lower()\r\n                if key.lower() in tag_lower:\r\n                    result[\"supported\"] = True\r\n                    if elem.text:\r\n                        try:\r\n                            result[\"value\"] = int(elem.text.strip())\r\n                        except ValueError:\r\n                            result[\"value\"] = 0\r\n\r\n            # 尝试查找 min/max 范围\r\n            for elem in root.iter():\r\n                tag_lower = elem.tag.split(\"}\")[-1].lower()\r\n                if \"min\" in tag_lower and elem.text:\r\n                    try:\r\n                        result[\"min\"] = int(elem.text.strip())\r\n                    except ValueError:\r\n                        pass\r\n                if \"max\" in tag_lower and elem.text:\r\n                    try:\r\n                        result[\"max\"] = int(elem.text.strip())\r\n                    except ValueError:\r\n                        pass\r\n        except ET.ParseError:\r\n            pass\r\n\r\n        return result\r\n\r\n    def check_endpoint_exists(self, endpoint: str) -> bool:\r\n        \"\"\"检查 ISAPI 端点是否存在（HTTP 200）。\"\"\"\r\n        result = self.client.get(endpoint)\r\n        return result.status_code == 200\r\n\r\n    def detect_capability(self, cap_key: str) -> dict:\r\n        \"\"\"检测单个能力。\r\n\r\n        步骤:\r\n        1. GET 端点，检查是否存在\r\n        2. 解析 min/max 范围\r\n        3. 保存原始值\r\n        4. PUT 测试值 (委托给 test_capability)\r\n        5. PUT 恢复原始值\r\n        \"\"\"\r\n        cap_def = CAPABILITIES.get(cap_key)\r\n        if not cap_def:\r\n            LOG.log(\"warning\", f\"未知能力: {cap_key}\")\r\n            return {\"supported\": False}\r\n\r\n        endpoint = self._get_endpoint(cap_def)\r\n        LOG.log(\"info\", f\"检测能力: {cap_def['label']} ({endpoint})\")\r\n\r\n        mode = cap_def.get(\"mode\", \"numeric\")\r\n\r\n        cap_info = {\r\n            \"label\": cap_def[\"label\"],\r\n            \"supported\": False,\r\n            \"min\": cap_def[\"min_val\"],\r\n            \"max\": cap_def[\"max_val\"],\r\n            \"original_value\": 0,\r\n            \"endpoint\": endpoint,\r\n            \"test_key\": cap_def[\"test_key\"],\r\n            \"mode\": mode,\r\n            \"p_id\": cap_def.get(\"p_id\", \"\"),\r\n        }\r\n\r\n        if mode == \"restore\":\r\n            # P4.21 设备还原 - 跳过端点检测，交给 restore_all 处理\r\n            cap_info[\"supported\"] = True\r\n            self.capabilities[cap_key] = cap_info\r\n            return cap_info\r\n\r\n        # Step 1: GET 端点\r\n        result = self.client.get(endpoint)\r\n\r\n        if result.status_code != 200:\r\n            LOG.log(\"info\", f\"  → {cap_def['label']} 不支持 (HTTP {result.status_code})\")\r\n            cap_info[\"supported\"] = False\r\n            self.capabilities[cap_key] = cap_info\r\n            return cap_info\r\n\r\n        # Step 2: 解析原始值\r\n        range_info = self._find_xml_range(result.xml, cap_def[\"test_key\"], cap_def)\r\n        cap_info[\"original_value\"] = range_info[\"value\"]\r\n        cap_info[\"min\"] = range_info.get(\"min\", cap_def[\"min_val\"])\r\n        cap_info[\"max\"] = range_info.get(\"max\", cap_def[\"max_val\"])\r\n        cap_info[\"supported\"] = True\r\n\r\n        LOG.log(\"info\", f\"  → {cap_def['label']} 支持，当前值={range_info['value']}\")\r\n\r\n        # Step 3: 保存原始值\r\n        self._original_values[cap_key] = result.xml\r\n\r\n        # Step 4 & 5: PUT 测试值 + 恢复原始值\r\n        self.test_capability(cap_key)\r\n\r\n        return cap_info\r\n\r\n    def detect_all(self) -> dict:\r\n        \"\"\"检测所有 21 个能力端点。\r\n\r\n        返回:\r\n            {cap_key: cap_info} 字典\r\n        \"\"\"\r\n        LOG.log(\"info\", \"=== 开始设备能力探测 (21 个端点) ===\")\r\n\r\n        for cap_key, cap_def in CAPABILITIES.items():\r\n            cap_info = self.detect_capability(cap_key)\r\n            status = \"✓\" if cap_info[\"supported\"] else \"✗\"\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n        if not original_xml:\r\n            LOG.log(\"warning\", f\"无原始值可还原: {cap_key}\")\r\n            return False\r\n\r\n        endpoint = cap_info[\"endpoint\"]\r\n        LOG.log(\"info\", f\"测试能力: {cap_def['label']}\")\r\n\r\n        if mode == \"read_only\":\r\n            LOG.log(\"done\", f\"  → {cap_def['label']} 为 read_only，跳过 PUT 测试\")\r\n            return True\r\n\r\n        # PUT 测试值\r\n        test_values = cap_def.get(\"test_values\")\r\n        test_val = test_value if test_value is not None else cap_def.get(\"test_val\")\r\n\r\n        if test_values:\r\n            # style_switch / toggle / action_switch: 测试多个值\r\n            all_ok = True\r\n            for val in test_values:\r\n                xml_body = self._build_xml_from_template(original_xml, cap_def, val)\r\n                result = self.client.put(endpoint, xml_body)\r\n                if result.status_code != 200:\r\n                    all_ok = False\r\n                    LOG.log(\"warning\", f\"  → PUT {val} 失败 (HTTP {result.status_code})\")\r\n            if all_ok:\r\n                LOG.log(\"done\", f\"  → {cap_def['label']} 所有模式测试通过\")\r\n        else:\r\n            # numeric / shutter / multi_field: 测试单个值\r\n            if isinstance(test_val, str) and \"/\" in test_val:\r\n                xml_body = self._build_xml_from_template(original_xml, cap_def, test_val)\r\n            else:\r\n                xml_body = self._build_xml_from_template(original_xml, cap_def, test_val)\r\n            result = self.client.put(endpoint, xml_body)\r\n            if result.status_code == 200:\r\n                LOG.log(\"done\", f\"  → {cap_def['label']} 测试通过\")\r\n            else:\r\n                LOG.log(\"warning\", f\"  → {cap_def['label']} 测试失败 (HTTP {result.status_code})\")\r\n                return False\r\n\r\n        # 还原原始值\r\n        put_result = self.client.put(endpoint, original_xml)\r\n        if put_result.status_code == 200:\r\n            LOG.log(\"done\", f\"  → {cap_def['label']} 已还原\")\r\n            return True\r\n        else:\r\n            LOG.log(\"warning\", f\"  → {cap_def['label']} 还原失败 (HTTP {put_result.status_code})\")\r\n            return False\r\n\r\n    def _build_xml_from_template(self, original_xml: str, cap_def: dict, value) -> str:\r\n        \"\"\"基于原始 XML 模板，修改指定字段后返回新 XML。\"\"\"\r\n        try:\r\n            root = ET.fromstring(original_xml)\r\n\r\n            if \"test_keys\" in cap_def:\r\n                # 多字段模式 (如 whiteBalance)\r\n                for k, v in cap_def[\"test_keys\"].items():\r\n                    for elem in root.iter():\r\n                        local_name = elem.tag.split(\"}\")[-1].lower()\r\n                        if local_name == k.lower():\r\n                            elem.text = str(v)\r\n                            break\r\n            else:\r\n                key = cap_def.get(\"test_key\", \"\")\r\n                for elem in root.iter():\r\n                    local_name = elem.tag.split(\"}\")[-1].lower()\r\n                    if local_name == key.lower():\r\n                        elem.text = str(value)\r\n                        break\r\n\r\n            return ET.tostring(root, encoding=\"unicode\", xml_declaration=False)\r\n        except ET.ParseError:\r\n            return original_xml\r\n\r\n    def restore_all(self) -> bool:\r\n        \"\"\"还原所有能力原始值 (P4.21)。\r\n\r\n        返回:\r\n            True = 全部还原成功\r\n        \"\"\"\r\n        LOG.log(\"info\", \"=== 开始还原所有设备参数 ===\")\r\n\r\n        all_restored = True\r\n        for cap_key, original_xml in self._original_values.items():\r\n            cap_info = self.capabilities.get(cap_key)\r\n            if not cap_info:\r\n                continue\r\n\r\n            result = self.client.put(cap_info[\"endpoint\"], original_xml)\r\n            if result.status_code == 200:\r\n                LOG.log(\"done\", f\"  → {cap_info['label']} 已还原\")\r\n            else:\r\n                LOG.log(\"warning\", f\"  → {cap_info['label']} 还原失败 (HTTP {result.status_code})\")\r\n                all_restored = False\r\n\r\n        if all_restored:\r\n            LOG.log(\"done\", \"所有设备参数已还原\")\r\n        else:\r\n            LOG.log(\"warning\", \"部分设备参数还原失败\")\r\n\r\n        return all_restored\r\n[... 893 more characters truncated]"}],"isError":false,"timestamp":1781382169012}}
{"type":"message","id":"96f6f3b1","parentId":"83108172","timestamp":"2026-06-13T20:22:49.012Z","message":{"role":"toolResult","toolCallId":"call_67bda0eb34c74c58aba5305c","toolName":"read","content":[{"type":"text","text":"            });\r\n            // REMOVED simulateProgress for connectFuncDetectRun\r\n        }\r\n        function renderConnectFuncResultMini(results) {\r\n            var area = document.getElementById('connectFuncResultMini');\r\n            var keys = Object.keys(results);\r\n            var supported = 0, total = keys.length;\r\n            keys.forEach(function(k) { if (results[k] && results[k].supported) supported++; });\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#3fb950\">✅ 支持 ' + supported + '/' + total + ' 项功能</span>';\r\n        }\r\n        // 限位检测（连接设备页面版）\r\n        function connectLimitTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectLimitRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('connectLimitProgress').style.display = 'block';\r\n            document.getElementById('connectLimitResultMini').innerHTML = '';\r\n            addLog('info', '限位检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/limit/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '限位检测完成');\r\n                    addLog('success', '限位检测完成: ' + (resp.message || ''));\r\n                    renderConnectLimitResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'limit');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '限位检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectLimitResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '测试失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectLimitProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectLimitTestRun\r\n        }\r\n        function renderConnectLimitResultMini(results) {\r\n            var area = document.getElementById('connectLimitResultMini');\r\n            var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n            var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#d29922\">P: ' + pLimit[0] + '~' + pLimit[1] + ' | T: ' + tLimit[0] + '~' + tLimit[1] + '</span>';\r\n        }\r\n        // 速度检测（连接设备页面版）\r\n        function connectSpeedTestRun() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnConnectSpeedRun');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 测试中...';\r\n            document.getElementById('connectSpeedProgress').style.display = 'block';\r\n            document.getElementById('connectSpeedResultMini').innerHTML = '';\r\n            addLog('info', '速度检测开始: ' + deviceIp);\r\n            apiPost('/api/v1/advanced/speed/run', {\r\n                device_ip: deviceIp,\r\n                username: (device && device.username) || 'admin',\r\n                password: (device && device.password) || '',\r\n                port: (device && device.port) || 80\r\n            }).then(function(resp) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectSpeedProgress').style.display = 'none';\r\n                if (resp && resp.success) {\r\n                    showToast('success', '速度检测完成');\r\n                    addLog('success', '速度检测完成: ' + (resp.message || ''));\r\n                    renderConnectSpeedResultMini(resp.results || {});\r\n                    renderConnectFullResults(resp.results || {}, 'speed');\r\n                } else {\r\n                    showToast('error', resp ? resp.message : '测试失败');\r\n                    addLog('error', '速度检测失败: ' + (resp ? resp.message : '未知'));\r\n                    document.getElementById('connectSpeedResultMini').innerHTML = '<span style=\"color:#f85149;font-size:12px\">❌ ' + (resp ? resp.message : '测试失败') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '▶ 开始检测';\r\n                document.getElementById('connectSpeedProgress').style.display = 'none';\r\n                showToast('error', '测试异常: ' + e.message);\r\n            });\r\n            // REMOVED simulateProgress for connectSpeedTestRun (was hardcoded: 速度档位 1, 50, 100)\r\n        }\r\n        function renderConnectSpeedResultMini(results) {\r\n            var area = document.getElementById('connectSpeedResultMini');\r\n            var speedMap = results.speed_map || results.speed_mapping || {};\r\n            var count = Object.keys(speedMap).length;\r\n            area.innerHTML = '<span style=\"font-size:12px;color:#f0883e\">✅ 已测试 ' + count + ' 个速度档位</span>';\r\n        }\r\n        // 一键检测（全部）\r\n        var detectionState = { running: false, step: 0, totalSteps: 3, results: {} };\r\n        function startDetection() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var device = allDevices.find(function(d) { return d.ip === deviceIp; });\r\n            var btn = document.getElementById('btnStartDetection');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<span class=\"spinner\" style=\"display:inline-block\"></span> 检测中...';\r\n            document.getElementById('detectionProgress').style.display = 'block';\r\n            document.getElementById('detectionLog').innerHTML = '';\r\n            detectionState = { running: true, step: 0, totalSteps: 3, results: {}, deviceIp: deviceIp, device: device };\r\n            addDetectionLog('info', '开始一键检测: ' + deviceIp);\r\n            runDetectionStep();\r\n        }\r\n        function runDetectionStep() {\r\n            var state = detectionState;\r\n            if (!state.running) return;\r\n            var steps = [\r\n                { name: '功能检测', url: '/api/v1/advanced/function/run', key: 'function' },\r\n                { name: '限位检测', url: '/api/v1/advanced/limit/run', key: 'limit' },\r\n                { name: '速度检测', url: '/api/v1/advanced/speed/run', key: 'speed' }\r\n            ];\r\n            if (state.step >= steps.length) {\r\n                finishDetection();\r\n                return;\r\n            }\r\n            var stepInfo = steps[state.step];\r\n            var pct = Math.round(((state.step) / state.totalSteps) * 100);\r\n            document.getElementById('detectionProgressText').textContent = '步骤 ' + (state.step + 1) + '/' + state.totalSteps + ': ' + stepInfo.name;\r\n            document.getElementById('detectionProgressBar').style.width = pct + '%';\r\n            addDetectionLog('info', '▶ 运行 ' + stepInfo.name + '...');\r\n            apiPost(stepInfo.url, {\r\n                device_ip: state.deviceIp,\r\n                username: (state.device && state.device.username) || 'admin',\r\n                password: (state.device && state.device.password) || '',\r\n                port: (state.device && state.device.port) || 80\r\n            }).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    state.results[stepInfo.key] = resp.results || {};\r\n                    addDetectionLog('success', '✅ ' + stepInfo.name + ' 完成');\r\n                } else {\r\n                    addDetectionLog('error', '❌ ' + stepInfo.name + ' 失败: ' + (resp ? resp.message : '未知'));\r\n                }\r\n                state.step++;\r\n                var newPct = Math.round((state.step / state.totalSteps) * 100);\r\n                document.getElementById('detectionProgressBar').style.width = newPct + '%';\r\n                runDetectionStep();\r\n            }).catch(function(e) {\r\n                addDetectionLog('error', '❌ ' + stepInfo.name + ' 异常: ' + e.message);\r\n                state.step++;\r\n                runDetectionStep();\r\n            });\r\n        }\r\n        function finishDetection() {\r\n            var btn = document.getElementById('btnStartDetection');\r\n            btn.disabled = false;\r\n            btn.innerHTML = '▶ 开始检测（全部）';\r\n            document.getElementById('detectionProgressText').textContent = '检测完成！';\r\n            document.getElementById('detectionProgressBar').style.width = '100%';\r\n            document.getElementById('detectionProgressBar').className = 'progress-fill green';\r\n            var state = detectionState;\r\n            var completed = Object.keys(state.results).length;\r\n            addDetectionLog('info', '=== 检测完成: ' + completed + '/' + state.totalSteps + ' 项通过 ===');\r\n            // 显示完整结果\r\n            if (completed > 0) {\r\n                var allResults = {};\r\n                Object.keys(state.results).forEach(function(k) {\r\n                    Object.keys(state.results[k]).forEach(function(rk) { allResults[rk] = state.results[k][rk]; });\r\n                });\r\n                if (state.results.function) renderConnectFullResults(state.results.function, 'function');\r\n                if (state.results.limit) renderConnectFullResults(state.results.limit, 'limit');\r\n                if (state.results.speed) renderConnectFullResults(state.results.speed, 'speed');\r\n            }\r\n            detectionState.running = false;\r\n        }\r\n        function addDetectionLog(level, msg) {\r\n            var log = document.getElementById('detectionLog');\r\n            if (!log) return;\r\n            var entry = document.createElement('div');\r\n            entry.className = 'log-entry ' + level;\r\n            entry.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\r\n            log.insertBefore(entry, log.firstChild);\r\n        }\r\n        // 预置点管理\r\n        function presetGoto() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var resultDiv = document.getElementById('presetResult');\r\n            resultDiv.textContent = '调用预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId, null).then(function(resp) {\r\n                if (resp && resp.success !== false) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已调用预置点 ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 调用失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        function presetSet() {\r\n            var deviceIp = document.getElementById('advConnectDevice').value;\r\n            var presetId = parseInt(document.getElementById('presetIdInput').value) || 10;\r\n            if (!deviceIp) { showToast('warning', '请先选择设备'); return; }\r\n            var resultDiv = document.getElementById('presetResult');\r\n            resultDiv.textContent = '设置预置点 ' + presetId + '...';\r\n            apiPost('/api/v1/ptz/' + deviceIp + '/preset/' + presetId + '/set', null).then(function(resp) {\r\n                if (resp && resp.success) {\r\n                    resultDiv.innerHTML = '<span style=\"color:#3fb950\">✅ 已设置预置点 ' + presetId + '</span>';\r\n                } else {\r\n                    resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 设置失败: ' + (resp ? resp.message : '未知') + '</span>';\r\n                }\r\n            }).catch(function(e) {\r\n                resultDiv.innerHTML = '<span style=\"color:#f85149\">❌ 异常: ' + e.message + '</span>';\r\n            });\r\n        }\r\n        // 渲染完整检测结果到连接设备页面\r\n        function renderConnectFullResults(results, type) {\r\n            var area = document.getElementById('connectFullResultArea');\r\n            var noResult = document.getElementById('connectNoResult');\r\n            if (!area) return;\r\n            area.style.display = 'block';\r\n            noResult.style.display = 'none';\r\n            var html = '<div style=\"margin-top:16px\">';\r\n            html += '<h4 style=\"font-size:15px;color:#e0e6f0;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #21262d\">';\r\n            if (type === 'function') html += '🔍 功能检测完整结果';\r\n            else if (type === 'limit') html += '📐 限位检测完整结果';\r\n            else if (type === 'speed') html += '⚡ 速度检测完整结果';\r\n            else html += '检测结果';\r\n            html += '</h4>';\r\n            if (type === 'function') {\r\n                html += '<table class=\"result-table\"><thead><tr><th>功能</th><th>支持</th><th>最小值</th><th>最大值</th><th>当前值</th><th>状态</th></tr></thead><tbody>';\r\n                var keys = Object.keys(results);\r\n                if (keys.length === 0) {\r\n                    html += '<tr><td colspan=\"6\" style=\"text-align:center;color:#6e7681\">暂无结果</td></tr>';\r\n                } else {\r\n                    keys.forEach(function(key) {\r\n                        var item = results[key];\r\n                        var supported = item.supported ? '<span class=\"badge yes\">✅</span>' : '<span class=\"badge no\">❌</span>';\r\n                        var status = item.status || '完成';\r\n                        html += '<tr>';\r\n                        html += '<td>' + key + '</td>';\r\n                        html += '<td>' + supported + '</td>';\r\n                        html += '<td>' + (item.min_value != null ? item.min_value : '--') + '</td>';\r\n                        html += '<td>' + (item.max_value != null ? item.max_value : '--') + '</td>';\r\n                        html += '<td>' + (item.current_value != null ? item.current_value : '--') + '</td>';\r\n                        html += '<td><span class=\"badge yes\">' + status + '</span></td>';\r\n                        html += '</tr>';\r\n                    });\r\n                }\r\n                html += '</tbody></table>';\r\n            } else if (type === 'limit') {\r\n                var pLimit = results.pan_range || results.p_limit || [0, 3600];\r\n                var tLimit = results.tilt_range || results.t_limit || [-200, 900];\r\n                html += '<div class=\"advanced-status-panel\">';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">P轴限位</span><span class=\"status-value\">' + pLimit[0] + ' ~ ' + pLimit[1] + '</span></div>';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">T轴限位</span><span class=\"status-value\">' + tLimit[0] + ' ~ ' + tLimit[1] + '</span></div>';\r\n                html += '<div class=\"status-row\"><span class=\"status-label\">翻转</span><span class=\"status-value\">' + (results.flip ? '有' : '无') + '</span></div>';\r[... 3157 more characters truncated]"}],"isError":false,"timestamp":1781382169012}}
