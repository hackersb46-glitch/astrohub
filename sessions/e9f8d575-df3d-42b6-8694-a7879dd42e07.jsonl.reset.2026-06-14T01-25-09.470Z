{"type":"message","id":"18a7c63a","parentId":"a4fb1f73","timestamp":"2026-06-13T22:42:00.688Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，问题依然存在！\n\n**Playwright 测试结果**：\n- 档位 1：1534 度/秒\n- 档位 4：1514 度/秒\n- 档位 7：1492 度/秒\n\n**所有档位速度几乎相同，而且都比直接测试 ISAPI 快很多！**\n\n这说明 Playwright 触发的 `mousedown` 和真实点击行为不同。问题可能是：\n1. Playwright 的 `dispatch_event('mousedown')` 可能触发了多次请求\n2. 或者设备在 Playwright 测试时有缓存/惯性\n\n让我检查 Playwright 触发了多少次 API 请求："},{"type":"toolCall","id":"call_e893b39d8f5a4bfd9df04c2f","name":"write","arguments":{"content":"\"\"\"Playwright 检查触发了几次 API 请求\"\"\"\nimport asyncio\nfrom playwright.async_api import async_playwright\n\nasync def test_request_count():\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False, slow_mo=200)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        # 监听 API 请求\n        request_count = {'count': 0, 'requests': []}\n        \n        def handle_request(req):\n            if '/api/v1/ptz/' in req.url and '/move' in req.url:\n                request_count['count'] += 1\n                request_count['requests'].append({\n                    'url': req.url,\n                    'method': req.method,\n                    'data': req.post_data\n                })\n                print(f'请求 #{request_count[\"count\"]}: {req.post_data}')\n        \n        page.on('request', handle_request)\n        \n        print('=== Playwright 检查触发了几次 API 请求 ===')\n        print()\n        \n        # 访问 AstroHub\n        await page.goto('http://localhost:10280/', wait_until='networkidle')\n        await asyncio.sleep(2)\n        \n        # 进入主控台\n        console_btn = await page.query_selector('[data-page=\"console\"]')\n        if console_btn:\n            await console_btn.click()\n            await asyncio.sleep(1)\n        \n        # 展开 PTZ 控制区域\n        ptz_section = await page.query_selector('#ptzControlSection')\n        if ptz_section:\n            is_collapsed = await ptz_section.evaluate('el => el.classList.contains(\"collapsed\")')\n            if is_collapsed:\n                header = await ptz_section.query_selector('.collapsible-header')\n                if header:\n                    await header.click()\n                    await asyncio.sleep(1)\n        \n        # 设置档位 1\n        print('设置档位 1...')\n        slider = await page.query_selector('#ptzSpeed')\n        if slider:\n            await slider.evaluate('el => el.value = \"1\"')\n            await slider.evaluate('el => el.dispatchEvent(new Event(\"input\"))')\n            await asyncio.sleep(0.3)\n        \n        # 找到向右按钮并触发 mousedown\n        print('触发 mousedown...')\n        request_count['count'] = 0\n        request_count['requests'] = []\n        \n        right_btns = await page.query_selector_all('.ptz-btn')\n        right_btn = None\n        for btn in right_btns:\n            text = await btn.inner_text()\n            if '→' in text:\n                right_btn = btn\n                break\n        \n        if right_btn:\n            await right_btn.dispatch_event('mousedown')\n            await asyncio.sleep(0.5)\n            await right_btn.dispatch_event('mouseup')\n        \n        await asyncio.sleep(1)\n        \n        print()\n        print(f'总共触发了 {request_count[\"count\"]} 次 API 请求')\n        for i, req in enumerate(request_count['requests'], 1):\n            print(f'  请求 {i}: {req[\"data\"]}')\n        \n        print()\n        print('浏览器保持打开 10 秒...')\n        await asyncio.sleep(10)\n        \n        await browser.close()\n\nif __name__ == '__main__':\n    asyncio.run(test_request_count())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_request_count.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":105634,"output":862,"cacheRead":0,"cacheWrite":0,"totalTokens":106496,"cost":{"input":0.10563399999999999,"output":0.0027584