{"type":"message","id":"c886f8b5","parentId":"e7815def","timestamp":"2026-06-13T23:51:01.520Z","message":{"role":"assistant","content":[{"type":"text","text":"前端代码已经有 `showToast` 调用。让我检查降噪和白平衡 R/B 设置的代码："},{"type":"toolCall","id":"call_aeeab606257c4c62b14b25bf","name":"read","arguments":{"limit":30,"offset":950,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":69707,"output":70,"cacheRead":0,"cacheWrite":0,"totalTokens":69777,"cost":{"input":0.06970699999999999,"output":0.00022400000000000002,"cacheRead":0,"cacheWrite":0,"total":0.069931}},"stopReason":"toolUse","timestamp":1781394653303,"responseId":"cht000d8910@dx19ec3654e5fba5c342"}}
{"type":"message","id":"07d3aa7f","parentId":"c886f8b5","timestamp":"2026-06-13T23:51:01.528Z","message":{"role":"toolResult","toolCallId":"call_aeeab606257c4c62b14b25bf","toolName":"read","content":[{"type":"text","text":"// 设置降噪\nfunction setNoiseReduce(type, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    var el = document.getElementById(type === 'spatial' ? 'dnrSpatialVal' : 'dnrTemporalVal');\n    if (el) el.textContent = value;\n    \n    var key = type === 'spatial' ? 'spatial_level' : 'temporal_level';\n    var label = type === 'spatial' ? '空域降噪' : '时域降噪';\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', { [key]: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', label + ': ' + value);\n            }\n        });\n}\n\n// 加载曝光模式\nfunction loadExposure(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\n        if (r && r.success && r.data) {\n            var select = document.getElementById('exposureMode');\n            if (select && r.data.mode) {\n                // v5.47: 只支持 auto/manual，其他模式统一为 manual\n                select.value = (r.data.mode === 'auto') ? 'auto' : 'manual';\n                // 更新快门光圈禁用状态\n                updateShutterIrisState();\n            }\n\n[161 more lines in file. Use offset=980 to continue.]"}],"isError":false,"timestamp":1781394661528}}
