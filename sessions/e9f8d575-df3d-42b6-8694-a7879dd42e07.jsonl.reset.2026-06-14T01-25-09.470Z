{"type":"message","id":"a6983e4c","parentId":"64dd89c2","timestamp":"2026-06-13T23:01:31.963Z","message":{"role":"assistant","content":[{"type":"text","text":"现在创建完整的 Playwright 测试来验证修复："},{"type":"toolCall","id":"call_19f1d1a627d049eb95a28226","name":"write","arguments":{"content":"\"\"\"Playwright 完整测试：白平衡 R/B 和降噪设置\"\"\"\nimport asyncio\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nfrom requests.auth import HTTPDigestAuth\nimport time\nfrom playwright.async_api import async_playwright\n\nip = '192.168.5.72'\nauth = HTTPDigestAuth('admin', 'Nftw1357')\nbase = f'http://{ip}/ISAPI'\n\ndef get_isapi_whitebalance():\n    \"\"\"直接通过 ISAPI 获取白平衡值\"\"\"\n    r = requests.get(f'{base}/Image/channels/1/whiteBalance', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        import re\n        red = re.search(r'<WhiteBalanceRed>(\\d+)</WhiteBalanceRed>', r.text)\n        blue = re.search(r'<WhiteBalanceBlue>(\\d+)</WhiteBalanceBlue>', r.text)\n        mode = re.search(r'<WhiteBalanceStyle>(\\w+)</WhiteBalanceStyle>', r.text)\n        return {\n            'red': int(red.group(1)) if red else 0,\n            'blue': int(blue.group(1)) if blue else 0,\n            'mode': mode.group(1) if mode else 'auto'\n        }\n    return None\n\ndef get_isapi_noisereduce():\n    \"\"\"直接通过 ISAPI 获取降噪值\"\"\"\n    r = requests.get(f'{base}/Image/channels/1/noiseReduce', auth=auth, timeout=10, proxies={'http':None,'https':None})\n    if r.status_code == 200:\n        import re\n        level = re.search(r'<generalLevel>(\\d+)</generalLevel>', r.text)\n        return {'level': int(level.group(1)) if level else 0}\n    return None\n\nasync def test_astrohub_image_controls():\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False, slow_mo=200)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print('=== Playwright 完整测试：白平衡 R/B 和降噪设置 ===')\n        print()\n        \n        # 访问 AstroHub\n        print('1. 访问 AstroHub...')\n        await page.goto('http://localhost:10280/', wait_until='networkidle')\n        await asyncio.sleep(2)\n        \n        # 进入主控台\n        print('2. 进入主控台...')\n        console_btn = await page.query_selector('[data-page=\"console\"]')\n        if console_btn:\n            await console_btn.click()\n            await asyncio.sleep(1)\n        \n        # 展开 PTZ 控制区域\n        print('3. 展开 PTZ 控制区域...')\n        ptz_section = await page.query_selector('#ptzControlSection')\n        if ptz_section:\n            is_collapsed = await ptz_section.evaluate('el => el.classList.contains(\"collapsed\")')\n            if is_collapsed:\n                header = await ptz_section.query_selector('.collapsible-header')\n                if header:\n                    await header.click()\n                    await asyncio.sleep(0.5)\n        \n        # 展开画面控制区域\n        print('4. 展开画面控制区域...')\n        image_section = await page.query_selector('#imageControlSection')\n        if image_section:\n            is_collapsed = await image_section.evaluate('el => el.classList.contains(\"collapsed\")')\n            if is_collapsed:\n                header = await image_section.query_selector('.collapsible-header')\n                if header:\n                    await header.click()\n                    await asyncio.sleep(0.5)\n        \n        # 测试白平衡 R/B 设置\n        print()\n        print('5. 测试白平衡 R/B 设置 (连续5次)...')\n        print()\n        \n        wb_results = []\n        test_values = [\n            {'red': 80, 'blue': 60},\n            {'red': 100, 'blue': 80},\n            {'red': 120, 'blue': 100},\n            {'red': 140, 'blue': 120},\n            {'red': 160, 'blue': 140},\n        ]\n        \n        # 先设置为手动模式\n        wb_mode = await page.query_selector('#wbMode')\n        if wb_mode:\n            await wb_mode.select_option('manual')\n            await asyncio.sleep(0.5)\n        \n        # 启用滑动条\n        wb_red_slider = await page.query_selector('#wbRed')\n        wb_blue_slider = await page.query_selector('#wbBlue')\n        \n        if wb_red_slider:\n            await wb_red_slider.evaluate('el => el.disabled = false')\n        if wb_blue_slider:\n            await wb_blue_slider.evaluate('el => el.disabled = false')\n        \n        for i, vals in enumerate(test_values):\n            # 设置 R 值\n            if wb_red_slider:\n                await wb_red_slider.evaluate(f'el => el.value = \"{vals[\"red\"]}\"')\n                await wb_red_slider.evaluate('el => el.dispatchEvent(new Event(\"input\"))')\n                await wb_red_slider.evaluate('el => el.dispatchEvent(new Event(\"change\"))')\n            \n            # 设置 B 值\n            if wb_blue_slider:\n                await wb_blue_slider.evaluate(f'el => el.value = \"{vals[\"blue\"]}\"')\n                await wb_blue_slider.evaluate('el => el.dispatchEvent(new Event(\"input\"))')\n                await wb_blue_slider.evaluate('el => el.dispatchEvent(new Event(\"change\"))')\n            \n            await asyncio.sleep(1)\n            \n            # 验证 ISAPI 值\n            isapi_vals = get_isapi_whitebalance()\n            \n            print(f'  测试 {i+1}: 设置 R={vals[\"red\"]}, B={vals[\"blue\"]}')\n            print(f'    ISAPI 验证: R={isapi_vals[\"red\"]}, B={isapi_vals[\"blue\"]}, Mode={isapi_vals[\"mode\"]}')\n            \n            red_match = isapi_vals['red'] == vals['red']\n            blue_match = isapi_vals['blue'] == vals['blue']\n            \n            if red_match and blue_match:\n                print(f'    结果: 通过')\n                wb_results.append(True)\n            else:\n                print(f'    结果: 失败 (R: {red_match}, B: {blue_match})')\n                wb_results.append(False)\n        \n        # 测试降噪设置\n        print()\n        print('6. 测试降噪设置 (连续5次)...')\n        print()\n        \n        nr_results = []\n        nr_values = [30, 45, 60, 75, 90]\n        \n        nr_slider = await page.query_selector('#noiseReduceSlider')\n        \n        for i, level in enumerate(nr_values):\n            if nr_slider:\n                await nr_slider.evaluate(f'el => el.value = \"{level}\"')\n                await nr_slider.evaluate('el => el.dispatchEvent(new Event(\"input\"))')\n                await nr_slider.evaluate('el => el.dispatchEvent(new Event(\"change\"))')\n            \n            await asyncio.sleep(1)\n            \n            # 验证 ISAPI 值\n            isapi_vals = get_isapi_noisereduce()\n            \n            print(f'  测试 {i+1}: 设置 level={level}')\n            print(f'    ISAPI 验证: level={isapi_vals[\"level\"]}')\n            \n            if isapi_vals['level'] == level:\n                print(f'    结果: 通过')\n                nr_results.append(True)\n            else:\n                print(f'    结果: 失败')\n                nr_results.append(False)\n        \n        # 总结\n        print()\n        print('=== 测试总结 ===')\n        print(f'白平衡 R/B: {sum(wb_results)}/5 通过')\n        print(f'降噪设置: {sum(nr_results)}/5 通过')\n        \n        if sum(wb_results) == 5 and sum(nr_results) == 5:\n            print()\n            print('所有测试通过！')\n        else:\n            print()\n            print('有测试失败，需要进一步修复。')\n        \n        print()\n        print('浏览器保持打开 10 秒...')\n        await asyncio.sleep(10)\n        \n        await browser.close()\n\nif __name__ == '__main__':\n    asyncio.run(test_astrohub_image_controls())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_image_controls.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":141567,"output":1773,"cacheRead":0,"cacheWrite":0,"totalTokens":143340,"cost":{"input":0.141567,"output":0.005673600000000001,"cacheRead":0,"cacheWrite":0,"total":0.1472406}},"stopReason":"toolUse","timestamp":1781391656633,"responseId":"cht000d9d41@dx19ec33789cfba5b442"}}
