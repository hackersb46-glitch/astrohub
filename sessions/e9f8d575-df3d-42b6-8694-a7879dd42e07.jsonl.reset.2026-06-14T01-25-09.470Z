{"type":"message","id":"04395303","parentId":"5862ead6","timestamp":"2026-06-13T22:59:46.627Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，**ISAPI 端点正常工作！所有 PUT 和 GET 都返回 200，数值正确设置。**\n\n**问题在 AstroHub 后端代码或前端调用。**\n\n让我检查 AstroHub 后端的白平衡设置代码是否有问题："},{"type":"toolCall","id":"call_4d9d45b900fc4c27aa2cd064","name":"read","arguments":{"limit":60,"offset":2664,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":131129,"output":99,"cacheRead":0,"cacheWrite":0,"totalTokens":131228,"cost":{"input":0.131129,"output":0.0003168,"cacheRead":0,"cacheWrite":0,"total":0.1314458}},"stopReason":"toolUse","timestamp":1781391581629,"responseId":"cht000d949d@dx19ec33664d5b958232"}}
{"type":"message","id":"04f35f98","parentId":"04395303","timestamp":"2026-06-13T22:59:46.634Z","message":{"role":"toolResult","toolCallId":"call_4d9d45b900fc4c27aa2cd064","toolName":"read","content":[{"type":"text","text":"@api_router.post(\"/ptz/{device_id}/image/whitebalance\", summary=\"设置白平衡\", tags=[\"Image\"])\r\nasync def set_whitebalance(device_id: str, data: dict) -> dict:\r\n    \"\"\"设置白平衡参数（模式或R/B增益）。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        # 直接构造 XML\r\n        mode_val = data.get(\"mode\", \"auto\")  # 小写！\r\n        red_val = data.get(\"red_gain\", 50)\r\n        blue_val = data.get(\"blue_gain\", 50)\r\n        \r\n        # 获取当前值\r\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\r\n        if resp.status_code == 200:\r\n            import xml.etree.ElementTree as ET\r\n            root = ET.fromstring(resp.xml)\r\n            for elem in root.iter():\r\n                tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n                if tag == \"WhiteBalanceRed\":\r\n                    red_val = int(elem.text or 50)\r\n                elif tag == \"WhiteBalanceBlue\":\r\n                    blue_val = int(elem.text or 50)\r\n        \r\n        xml_str = f'''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<WhiteBalance version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\r\n<WhiteBalanceStyle>{mode_val}</WhiteBalanceStyle>\r\n<WhiteBalanceRed>{red_val}</WhiteBalanceRed>\r\n<WhiteBalanceBlue>{blue_val}</WhiteBalanceBlue>\r\n</WhiteBalance>'''\r\n        \r\n        put_resp = client.put(\"/Image/channels/1/whiteBalance\", xml_str)\r\n        if put_resp.status_code == 200:\r\n            return {\"success\": True, \"message\": \"白平衡已更新\"}\r\n        return {\"success\": False, \"message\": f\"更新失败: HTTP {put_resp.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置白平衡异常: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/noisereduce\", summary=\"获取降噪设置\", tags=[\"Image\"])\r\nasync def get_noisereduce(device_id: str) -> dict:\r\n    \"\"\"获取设备降噪当前设置。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n\n[569 more lines in file. Use offset=2724 to continue.]"}],"isError":false,"timestamp":1781391586634}}
