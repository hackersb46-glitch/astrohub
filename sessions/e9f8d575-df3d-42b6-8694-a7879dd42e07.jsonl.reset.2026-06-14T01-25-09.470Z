{"type":"message","id":"87d94b22","parentId":"fde732c2","timestamp":"2026-06-14T00:15:29.963Z","message":{"role":"assistant","content":[{"type":"text","text":"老板，**ISAPI 层面完全正常！** 白平衡 R/B 和降噪空域/时域都可以分开设置，不会互相覆盖。\n\n**问题在前端或后端 API 层。** 让我检查 AstroHub 后端 API 是否正确处理："},{"type":"toolCall","id":"call_aed2e98c30c9404d8224ca42","name":"write","arguments":{"content":"\"\"\"测试 AstroHub API 层的白平衡和降噪设置\"\"\"\nimport os\nos.environ.pop('http_proxy', None)\nimport requests\nimport time\n\n# 直接调用 AstroHub API（需要服务运行）\nbase_url = 'http://localhost:10280/api/v1'\ndevice_id = '192.168.5.72'\n\nprint('=== 测试 AstroHub API 层 ===')\nprint()\n\n# 先检查服务是否运行\ntry:\n    r = requests.get('http://localhost:10280/', timeout=5)\n    print('AstroHub 服务运行中')\nexcept:\n    print('AstroHub 服务未运行，跳过 API 层测试')\n    exit(0)\n\nprint()\n\n# ============================================================\n# 测试 1：白平衡 R/B 分开设置（通过 AstroHub API）\n# ============================================================\nprint('测试 1：白平衡 R/B 分开设置（AstroHub API）')\nprint()\n\n# 先设置为手动模式，R=100, B=100\nr = requests.post(f'{base_url}/ptz/{device_id}/image/whitebalance', json={'mode': 'manual', 'red_gain': 100, 'blue_gain': 100}, timeout=10)\nprint(f'  初始设置: {r.json()}')\ntime.sleep(0.5)\n\n# 获取当前值\nr = requests.get(f'{base_url}/ptz/{device_id}/image/whitebalance', timeout=10)\nwb = r.json()\nprint(f'  当前值: {wb}')\ntime.sleep(0.5)\n\n# 只改 R，B 应保持\nr = requests.post(f'{base_url}/ptz/{device_id}/image/whitebalance', json={'red_gain': 80}, timeout=10)\nprint(f'  只改 R=80: {r.json()}')\ntime.sleep(0.5)\n\nr = requests.get(f'{base_url}/ptz/{device_id}/image/whitebalance', timeout=10)\nwb = r.json()\nprint(f'  验证: {wb}')\n\nif wb.get('success') and wb.get('data'):\n    red = wb['data'].get('red_gain')\n    blue = wb['data'].get('blue_gain')\n    test1 = red == 80 and blue == 100\n    print(f'  结果: R={red}, B={blue} - {\"PASS\" if test1 else \"FAIL\"}')\nelse:\n    print(f'  结果: FAIL - {wb}')\n    test1 = False\n\nprint()\n\n# ============================================================\n# 测试 2：降噪空域/时域分开设置（通过 AstroHub API）\n# ============================================================\nprint('测试 2：降噪空域/时域分开设置（AstroHub API）')\nprint()\n\n# 初始设置\nr = requests.post(f'{base_url}/ptz/{device_id}/image/noisereduce', json={'spatial_level': 50, 'temporal_level': 50}, timeout=10)\nprint(f'  初始设置: {r.json()}')\ntime.sleep(0.5)\n\n# 只改空域，时域应保持\nr = requests.post(f'{base_url}/ptz/{device_id}/image/noisereduce', json={'spatial_level': 70}, timeout=10)\nprint(f'  只改空域=70: {r.json()}')\ntime.sleep(0.5)\n\nr = requests.get(f'{base_url}/ptz/{device_id}/image/noisereduce', timeout=10)\nnr = r.json()\nprint(f'  验证: {nr}')\n\nif nr.get('success') and nr.get('data'):\n    spatial = nr['data'].get('spatial_level')\n    temporal = nr['data'].get('temporal_level')\n    test2 = spatial == 70 and temporal == 50\n    print(f'  结果: 空域={spatial}, 时域={temporal} - {\"PASS\" if test2 else \"FAIL\"}')\nelse:\n    print(f'  结果: FAIL - {nr}')\n    test2 = False\n\nprint()\nprint('=== 测试总结 ===')\nprint(f'白平衡 R/B 分开: {\"PASS\" if test1 else \"FAIL\"}')\nprint(f'降噪空域/时域分开: {\"PASS\" if test2 else \"FAIL\"}')","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_api_layer.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":75530,"output":1000,"cacheRead":0,"cacheWrite":0,"totalTokens":76530,"cost":{"input":0.07553,"output":0.0032,"cacheRead":0,"cacheWrite":0,"total":0.07873}},"stopReason":"toolUse","timestamp":1781396092635,"responseId":"cht000d4e54@dx19ec37b3e42ba5b442"}}
