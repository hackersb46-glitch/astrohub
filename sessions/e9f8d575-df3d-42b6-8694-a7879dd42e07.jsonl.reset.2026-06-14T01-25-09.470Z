{"type":"message","id":"8c614202","parentId":"c9539630","timestamp":"2026-06-14T01:05:58.242Z","message":{"role":"assistant","content":[{"type":"text","text":"修复白平衡 R/B 设置，只发送增益值："},{"type":"toolCall","id":"call_594dcef81c8245d4b156d47e","name":"edit","arguments":{"edits":[{"newText":"function setWhiteBalanceGain(channel, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // 更新显示\n    if (channel === 'red') {\n        var el = document.getElementById('wbRedVal');\n        if (el) el.textContent = value;\n    } else {\n        var el = document.getElementById('wbBlueVal');\n        if (el) el.textContent = value;\n    }\n    \n    var key = channel === 'red' ? 'red_gain' : 'blue_gain';\n    var label = channel === 'red' ? 'R (红增益)' : 'B (蓝增益)';\n    \n    // v6.56: 只发送增益值，不发送模式（模式已通过下拉菜单切换）\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', label + ': ' + value);\n            }\n        });\n}","oldText":"function setWhiteBalanceGain(channel, value) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    \n    // 更新显示\n    if (channel === 'red') {\n        var el = document.getElementById('wbRedVal');\n        if (el) el.textContent = value;\n    } else {\n        var el = document.getElementById('wbBlueVal');\n        if (el) el.textContent = value;\n    }\n    \n    var key = channel === 'red' ? 'red_gain' : 'blue_gain';\n    var label = channel === 'red' ? 'R (红增益)' : 'B (蓝增益)';\n    \n    // v6.55: 检查是否需要先切换到手动模式\n    var wbModeSelect = document.getElementById('wbMode');\n    if (wbModeSelect && wbModeSelect.value !== 'manual') {\n        // 先切换模式，等待完成后再设置增益\n        wbModeSelect.value = 'manual';\n        apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: 'manual' })\n            .then(function(r) {\n                if (r && r.success) {\n                    // 启用滑动条\n                    var wbRed = document.getElementById('wbRed');\n                    var wbBlue = document.getElementById('wbBlue');\n                    if (wbRed) wbRed.disabled = false;\n                    if (wbBlue) wbBlue.disabled = false;\n                    \n                    // 模式切换完成后再设置增益\n                    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) })\n                        .then(function(r2) {\n                            if (r2 && r2.success) {\n                                showToast('success', label + ': ' + value);\n                            }\n                        });\n                }\n            });\n    } else {\n        // 已经是手动模式，直接设置增益\n        apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) })\n            .then(function(r) {\n                if (r && r.success) {\n                    showToast('success', label + ': ' + value);\n                }\n            });\n    }\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":93552,"output":845,"cacheRead":0,"cacheWrite":0,"totalTokens":94397,"cost":{"input":0.093552,"output":0.0027040000000000002,"cacheRead":0,"cacheWrite":0,"total":0.096256}},"stopReason":"toolUse","timestamp":1781399137893,"responseId":"cht000d1b96@dx19ec3a9b87bb85e102"}}
