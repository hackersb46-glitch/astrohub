{"type":"message","id":"14a1c962","parentId":"a069d25a","timestamp":"2026-06-13T22:32:58.784Z","message":{"role":"assistant","content":[{"type":"text","text":"需要先点击\"主控台\"菜单。让我修改："},{"type":"toolCall","id":"call_f05cb4b683f94d99b1a8a9ed","name":"write","arguments":{"content":"\"\"\"Playwright 测试 AstroHub PTZ 档位\"\"\"\nimport asyncio\nfrom playwright.async_api import async_playwright\n\nasync def test_astrohub_ptz():\n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=False, slow_mo=500)\n        context = await browser.new_context()\n        page = await context.new_page()\n        \n        print('=== Playwright 测试 AstroHub PTZ 档位 ===')\n        print()\n        \n        # 访问 AstroHub\n        print('1. 访问 AstroHub...')\n        await page.goto('http://localhost:10280/', wait_until='networkidle')\n        await asyncio.sleep(3)\n        \n        # 截图首页\n        await page.screenshot(path='astrohub_home.png')\n        print('   截图: astrohub_home.png')\n        \n        # 点击主控台菜单\n        print('2. 进入主控台...')\n        console_btn = await page.query_selector('[data-page=\"console\"]')\n        if console_btn:\n            await console_btn.click()\n            print('   点击主控台菜单')\n            await asyncio.sleep(2)\n        \n        # 截图主控台\n        await page.screenshot(path='astrohub_console.png')\n        print('   截图: astrohub_console.png')\n        \n        # 展开 PTZ 控制区域\n        print('3. 展开 PTZ 控制区域...')\n        ptz_section = await page.query_selector('#ptzControlSection')\n        if ptz_section:\n            # 检查是否已展开\n            is_collapsed = await ptz_section.evaluate('el => el.classList.contains(\"collapsed\")')\n            print(f'   折叠状态: {is_collapsed}')\n            \n            if is_collapsed:\n                header = await ptz_section.query_selector('.collapsible-header')\n                if header:\n                    await header.click()\n                    print('   点击展开')\n                    await asyncio.sleep(1)\n        else:\n            print('   未找到 PTZ 控制区域')\n        \n        # 截图展开后\n        await page.screenshot(path='astrohub_ptz_expanded.png')\n        print('   截图: astrohub_ptz_expanded.png')\n        \n        # 查找滑动条\n        print('4. 查找 PTZ 速度滑动条...')\n        slider = await page.query_selector('#ptzSpeed')\n        if slider:\n            min_val = await slider.get_attribute('min')\n            max_val = await slider.get_attribute('max')\n            val = await slider.get_attribute('value')\n            print(f'   滑动条属性: min={min_val}, max={max_val}, value={val}')\n            \n            # 获取显示值\n            display_val = await page.query_selector('#ptzSpeedVal')\n            if display_val:\n                display_text = await display_val.inner_text()\n                print(f'   显示值: {display_text}')\n            \n            # 测试各档位\n            print()\n            print('5. 测试各档位...')\n            \n            for gear in [1, 4, 7]:\n                # 设置滑动条值\n                await slider.evaluate(f'el => el.value = \"{gear}\"')\n                await slider.evaluate('el => el.dispatchEvent(new Event(\"input\"))')\n                await slider.evaluate('el => el.dispatchEvent(new Event(\"change\"))')\n                \n                # 获取当前值\n                current_val = await slider.evaluate('el => el.value')\n                display_val = await page.query_selector('#ptzSpeedVal')\n                if display_val:\n                    display_text = await display_val.inner_text()\n                    print(f'   档位{gear}: 滑动条值={current_val}, 显示值={display_text}')\n                \n                # 截图\n                await page.screenshot(path=f'astrohub_gear_{gear}.png')\n        else:\n            print('   未找到滑动条')\n        \n        print()\n        print('=== 测试完成 ===')\n        \n        # 保持浏览器打开\n        print('浏览器保持打开 30 秒...')\n        await asyncio.sleep(30)\n        \n        await browser.close()\n\nif __name__ == '__main__':\n    asyncio.run(test_astrohub_ptz())","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\test_astrohub_playwright.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":97718,"output":931,"cacheRead":0,"cacheWrite":0,"totalTokens":98649,"cost":{"input":0.097718,"output":0.0029792000000000004,"cacheRead":0,"cacheWrite":0,"total":0.1006972}},"stopReason":"toolUse","timestamp":1781389958612,"responseId":"cht000d57e5@dx19ec31da378ba5a412"}}
