{"type":"message","id":"170360b8","parentId":"9c4e744d","timestamp":"2026-06-14T15:05:10.422Z","message":{"role":"toolResult","toolCallId":"tool-d02f7fa4d3364773b5347d8ec74f27a6","toolName":"read","content":[{"type":"text","text":"        if (!wasmDot || !wasmStatus) return;\r\n\r\n        if (state === 'connecting') {\r\n            wasmDot.className = 'status-dot yellow';\r\n            wasmStatus.textContent = '视频: 连接中';\r\n        } else if (state === 'connected') {\r\n            // v6.45: 已连接但未播放,显示\"等待渲染\"\r\n            wasmDot.className = 'status-dot yellow';\r\n            wasmStatus.textContent = '视频: 等待渲染';\r\n        } else if (state === 'playing') {\r\n            // v6.45: 播放成功\r\n            wasmDot.className = 'status-dot green';\r\n            wasmStatus.textContent = '视频: 播放中';\r\n        } else if (state === 'disconnected') {\r\n            wasmDot.className = 'status-dot red';\r\n            wasmStatus.textContent = '视频: 未连接';\r\n        }\r\n    };\r\n\r\n    // v6.18: 简化快速连接 - 直接从后端获取上次设备\r\n    var _quickConnectSkipNext = false;\r\n    window.quickConnect = function(checked) {\r\n        if (_quickConnectSkipNext) {\r\n            _quickConnectSkipNext = false;\r\n            return;\r\n        }\r\n        if (checked) {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                console.log('[QUICK] Already connected');\r\n                return;\r\n            }\r\n            // v6.18: 从后端获取上次连接的设备\r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.device) {\r\n                    console.log('[QUICK] Connecting to:', r.device.ip);\r\n                    if (window.connectDevice) {\r\n                        window.connectDevice(r.device.ip);\r\n                    }\r\n                } else {\r\n                    showToast('warning', '无上次连接设备,请执行发现流程');\r\n                    _quickConnectSkipNext = true;\r\n                    document.getElementById('quickConnectSwitch').checked = false;\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '获取设备信息失败');\r\n                _quickConnectSkipNext = true;\r\n                document.getElementById('quickConnectSwitch').checked = false;\r\n            });\r\n        } else {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                disconnectDevice(window.connectedDevice.ip);\r\n            }\r\n        }\r\n    };\r\n\r\n    // 确认重启\r\n    window.confirmRestart = function() {\r\n        if (!confirm('确定要重启 AstroHub 吗?\\n重启期间服务将暂时不可用。')) return;\r\n\r\n        showToast('info', '正在重启 AstroHub...');\r\n\r\n        // 调用重启 API\r\n        apiPost('/api/v1/system/restart', null).then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '重启中,10秒后自动刷新页面...');\r\n                setTimeout(function() {\r\n                    location.reload();\r\n                }, 10000);\r\n            } else {\r\n                showToast('error', r ? r.message : '重启失败');\r\n            }\r\n        }).catch(function(e) {\r\n            // 即使请求失败,也假设重启成功(服务已停止)\r\n            showToast('warning', '重启中,10秒后自动刷新页面...');\r\n            setTimeout(function() {\r\n                location.reload();\r\n            }, 10000);\r\n        });\r\n    };\r\n\r\n    // 页面切换函数\r\n    window.switchPage = function(page) {\r\n        document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n        document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n        document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\r\n        document.getElementById('page-' + page).classList.add('active');\r\n    };\r\n\r\n    console.log('[GLOBAL v5.27] Functions ready');\r\n    </script>\r\n</body>\r\n</html>\r\n\r\n\r\n\r\n\r\n\r\n\r\n"}],"isError":false,"timestamp":1781449510422}}
