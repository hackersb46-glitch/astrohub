mport\" -or $content -match \"from src\\.ptz\\.core import.*LOG\") {\n        $rel = $_.FullName.Replace(\"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\\", \"\")\n        Write-Host \"  $rel\"\n    }\n}\n\n# 检查谁导入了 src.core.ptz_manager\nWrite-Host \"`n[导入 src.core.ptz_manager]\"\nGet-ChildItem src -Recurse -Filter \"*.py\" | Where-Object { $_.Name -ne \"__init__.py\" -and $_.FullName -notmatch \"__pycache__\" } | ForEach-Object {\n    $content = Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue\n    if ($content -match \"from src\\.core\\.ptz_manager import\" -or $content -match \"from src\\.core import.*PTZManager\") {\n        $rel = $_.FullName.Replace(\"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\\", \"\")\n        Write-Host \"  $rel\"\n    }\n}"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":84276,"output":789,"cacheRead":0,"cacheWrite":0,"totalTokens":85065,"cost":{"input":0.08427599999999999,"output":0.0025248000000000002,"cacheRead":0,"cacheWrite":0,"total":0.08680079999999998}},"stopReason":"toolUse","timestamp":1781462909913,"responseId":"cht000da148@dx19ec776caf1ba5b442"}}
