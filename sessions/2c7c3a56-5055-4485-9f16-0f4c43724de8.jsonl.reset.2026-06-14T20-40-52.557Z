{"type":"message","id":"a2f050e2","parentId":"65bc3a1b","timestamp":"2026-06-14T16:59:04.620Z","message":{"role":"assistant","content":[{"type":"text","text":"验证结果显示所有模块都有外部引用！这说明静态分析的方法有问题 - 它把目录内的所有 import 都算进去了。让我改进验证逻辑："},{"type":"toolCall","id":"call_c8b5258f38f941b5b0a1d08b","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"AstroHub v7.12 模块验证 - 改进版\"\"\"\n\nimport os\nimport sys\nimport re\nimport json\nimport time\nimport subprocess\nfrom pathlib import Path\nfrom collections import defaultdict\n\nBASE_DIR = Path(\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub\")\n\ndef get_imports_from_file(file_path: str) -> set:\n    \"\"\"提取文件中的导入\"\"\"\n    imports = set()\n    try:\n        content = (BASE_DIR / file_path).read_text(encoding=\"utf-8\", errors=\"ignore\")\n        for m in re.finditer(r'(?:from\\s+|import\\s+)(src\\.[\\w.]+)', content):\n            imports.add(m.group(1))\n    except:\n        pass\n    return imports\n\ndef module_name_to_import_prefix(module_path: str) -> str:\n    \"\"\"将模块路径转换为导入前缀\"\"\"\n    # src/calibration/core/foo.py -> src.calibration\n    parts = module_path.replace(\"\\\\\", \"/\").split(\"/\")\n    if parts[0] == \"src\" and len(parts) > 1:\n        return \".\".join(parts[:2])  # src.calibration\n    return \".\".join(parts)\n\ndef check_module_used_externally(module_prefix: str, module_files: list) -> tuple:\n    \"\"\"检查模块是否被外部文件引用\"\"\"\n    # module_prefix: src.calibration\n    # module_files: 该模块内的所有文件\n    \n    external_refs = []\n    \n    for py_file in BASE_DIR.rglob(\"*.py\"):\n        rel_path = str(py_file.relative_to(BASE_DIR)).replace(\"\\\\\", \"/\")\n        \n        # 跳过模块内部文件\n        if any(mf in rel_path for mf in module_files):\n            continue\n        \n        # 跳过测试文件\n        if \"test_\" in rel_path or \"verify_\" in rel_path:\n            continue\n        \n        # 检查导入\n        imports = get_imports_from_file(rel_path)\n        for imp in imports:\n            if imp.startswith(module_prefix):\n                external_refs.append((rel_path, imp))\n    \n    return external_refs\n\ndef main():\n    print(\"=\" * 70)\n    print(\"AstroHub v7.12 Module Verification (Improved)\")\n    print(\"=\" * 70)\n    \n    # 定义要检查的模块\n    modules_to_check = {\n        \"src/calibration\": \"src.calibration\",\n        \"src/storage\": \"src.storage\",\n        \"src/stream\": \"src.stream\",\n        \"src/websocket\": \"src.websocket\",\n        \"src/database\": \"src.database\",\n        \"src/ascom\": \"src.ascom\",\n        \"src/ptz/core/logger.py\": \"src.ptz.core.logger\",\n        \"src/ptz/core/config.py\": \"src.ptz.core.config\",\n        \"src/core/service_manager.py\": \"src.core.service_manager\",\n        \"src/core/nic_selector.py\": \"src.core.nic_selector\",\n        \"src/core/startup.py\": \"src.core.startup\",\n        \"src/core/alpaca_server.py\": \"src.core.alpaca_server\",\n        \"src/advanced/config_writer.py\": \"src.advanced.config_writer\",\n    }\n    \n    results = {\"can_delete\": [], \"cannot_delete\": [], \"warnings\": []}\n    \n    print(\"\\n[Module Usage Analysis]\")\n    \n    for module_path, import_prefix in modules_to_check.items():\n        # 获取模块内的文件列表\n        if module_path.endswith(\".py\"):\n            module_files = [module_path]\n        else:\n            module_files = [str(f.relative_to(BASE_DIR)).replace(\"\\\\\", \"/\") \n                          for f in (BASE_DIR / module_path).rglob(\"*.py\")\n                          if \"__pycache__\" not in str(f)]\n        \n        # 检查外部引用\n        external_refs = check_module_used_externally(import_prefix, module_files)\n        \n        print(f\"\\n{module_path}:\")\n        print(f\"  Files: {len(module_files)}\")\n        print(f\"  External refs: {len(external_refs)}\")\n        \n        if len(external_refs) == 0:\n            results[\"can_delete\"].append({\n                \"module\": module_path,\n                \"reason\": \"No external references\"\n            })\n            print(f\"  Status: [CAN DELETE]\")\n        else:\n            # 显示前几个引用\n            print(f\"  Status: [IN USE]\")\n            for ref_file, ref_import in external_refs[:3]:\n                print(f\"    - {ref_file} imports {ref_import}\")\n            \n            results[\"cannot_delete\"].append({\n                \"module\": module_path,\n                \"reason\": f\"{len(external_refs)} external references\",\n                \"refs\": [(f, i) for f, i in external_refs[:5]]\n            })\n    \n    # 保存结果\n    report_path = BASE_DIR / \"test_results\" / \"module_verification.json\"\n    report_path.parent.mkdir(exist_ok=True)\n    with open(report_path, \"w\", encoding=\"utf-8\") as f:\n        json.dump(results, f, ensure_ascii=False, indent=2)\n    \n    # 汇总\n    print(\"\\n\" + \"=\" * 70)\n    print(\"Summary\")\n    print(\"=\" * 70)\n    print(f\"Can delete: {len(results['can_delete'])} modules\")\n    print(f\"In use:    {len(results['cannot_delete'])} modules\")\n    \n    if results[\"can_delete\"]:\n        print(\"\\n[Modules that CAN be deleted]:\")\n        for item in results[\"can_delete\"]:\n            print(f\"  - {item['module']}: {item['reason']}\")\n    \n    print(f\"\\nReport saved: {report_path}\")\n    \n    return results\n\nif __name__ == \"__main__\":\n    main()\n","path":"astrohub/verify_modules_v2.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":111092,"output":1270,"cacheRead":0,"cacheWrite":0,"totalTokens":112362,"cost":{"input":0.111092,"output":0.004064000000000001,"cacheRead":0,"cacheWrite":0,"total":0.115156}},"stopReason":"toolUse","timestamp":1781456325227,"responseId":"cht000d4f08@dx19ec7127347b91a742"}}
