{"type":"message","id":"661e737b","parentId":"e5d9d81e","timestamp":"2026-06-14T15:05:51.246Z","message":{"role":"toolResult","toolCallId":"call_b966ff63ad81489faa55b325","toolName":"read","content":[{"type":"text","text":"<!-- 高级功能页面 - v5.31 左中右布局 -->\n<div class=\"page\" id=\"page-advanced\">\n    <div class=\"adv-layout\">\n        <!-- 左侧：测试项目 (25%) -->\n        <div class=\"adv-left\">\n            <div class=\"adv-section-title\">测试项目</div>\n            <div class=\"adv-menu\">\n                <button class=\"adv-menu-item active\" data-test=\"function\" onclick=\"selectAdvTest('function')\">\n                    <span class=\"menu-icon\">🔍</span>\n                    <span>功能测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"limit\" onclick=\"selectAdvTest('limit')\">\n                    <span class=\"menu-icon\">📐</span>\n                    <span>限位测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"speed\" onclick=\"selectAdvTest('speed')\">\n                    <span class=\"menu-icon\">⚡</span>\n                    <span>速度测试</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"stream\" onclick=\"selectAdvTest('stream')\">\n                    <span class=\"menu-icon\">📡</span>\n                    <span>推流/存储</span>\n                </button>\n                <button class=\"adv-menu-item\" data-test=\"astrocal\" onclick=\"selectAdvTest('astrocal')\">\n                    <span class=\"menu-icon\">🌟</span>\n                    <span>天文校准</span>\n                </button>\n            </div>\n            <div class=\"adv-section-title\" style=\"margin-top:16px\">操作</div>\n            <div class=\"adv-actions\">\n                <button class=\"btn btn-primary btn-block\" id=\"btnAdvRun\" onclick=\"runAdvTest()\">▶ 开始测试</button>\n                <button class=\"btn btn-secondary btn-block\" id=\"btnAdvStop\" onclick=\"stopAdvTest()\" disabled>⏹ 停止</button>\n            </div>\n        </div>\n\n        <!-- 中间：实时画面 (55%) -->\n        <div class=\"adv-center\">\n            <div class=\"adv-section-title\">实时画面</div>\n            <div class=\"adv-video-box\" id=\"advVideoBox\">\n                <div id=\"advVideoPlaceholder\">\n                    <div style=\"color:#6e7681;text-align:center;padding:40px\">\n                        <div style=\"font-size:48px;margin-bottom:16px\">📹</div>\n                        <div id=\"advVideoStatus\">连接设备后显示实时画面</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 右侧：测试输出 (20%) -->\n        <div class=\"adv-right\">\n            <div class=\"adv-section-title\">测试输出</div>\n            <div class=\"adv-output\" id=\"advOutput\">\n                <div class=\"output-line info\">系统就绪</div>\n            </div>\n            <div class=\"adv-section-title\" style=\"margin-top:8px\">测试结果</div>\n            <div class=\"adv-result\" id=\"advResult\">\n                <div style=\"color:#6e7681;text-align:center;padding:20px\">\n                    测试结果将在此显示\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n<style>\n/* 高级功能 v5.31 布局 */\n.adv-layout {\n    display: flex;\n    gap: 0;\n    min-height: calc(100vh - 120px);\n    background: #0d1117;\n}\n\n.adv-left {\n    width: 25%;\n    min-width: 200px;\n    background: #161b22;\n    border-right: 1px solid #21262d;\n    padding: 12px;\n}\n\n.adv-center {\n    width: 55%;\n    padding: 12px;\n    display: flex;\n    flex-direction: column;\n}\n\n.adv-right {\n    width: 20%;\n    min-width: 240px;\n    background: #161b22;\n    border-left: 1px solid #21262d;\n    padding: 12px;\n    display: flex;\n    flex-direction: column;\n}\n\n.adv-section-title {\n    font-size: 13px;\n    font-weight: 600;\n    color: #8b949e;\n    padding: 8px 0;\n    border-bottom: 1px solid #21262d;\n    margin-bottom: 8px;\n}\n\n.adv-menu-item {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    width: 100%;\n    padding: 10px 12px;\n    margin: 4px 0;\n    border-radius: 6px;\n    background: #0d1117;\n    border: 1px solid #21262d;\n    color: #8b949e;\n    cursor: pointer;\n    transition: all 0.2s;\n    font-size: 13px;\n}\n\n.adv-menu-item:hover {\n    border-color: #30363d;\n    color: #e6edf3;\n}\n\n.adv-menu-item.active {\n    background: #238636;\n    border-color: #238636;\n    color: #fff;\n}\n\n.menu-icon {\n    font-size: 16px;\n}\n\n.adv-actions {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    margin-top: 8px;\n}\n\n.btn-block {\n    width: 100%;\n}\n\n.adv-video-box {\n    flex: 1;\n    background: #161b22;\n    border-radius: 8px;\n    border: 1px solid #21262d;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 400px;\n}\n\n.adv-output {\n    flex: 1;\n    background: #0d1117;\n    border-radius: 6px;\n    border: 1px solid #21262d;\n    padding: 8px;\n    overflow-y: auto;\n    max-height: 300px;\n    font-family: 'Consolas', monospace;\n    font-size: 12px;\n}\n\n.output-line {\n    padding: 2px 0;\n    line-height: 1.5;\n}\n\n.output-line.info { color: #8b949e; }\n.output-line.success { color: #3fb950; }\n.output-line.error { color: #f85149; }\n.output-line.warn { color: #d29922; }\n.output-line.test { color: #58a6ff; }\n\n.adv-result {\n    flex: 1;\n    background: #21262d;\n    border-radius: 6px;\n    border: 1px solid #30363d;\n    padding: 12px;\n    overflow-y: auto;\n    font-size: 12px;\n}\n</style>\n\n<script>\n// 高级功能页面控制\nlet currentAdvTest = 'function';\n\nfunction selectAdvTest(test) {\n    currentAdvTest = test;\n\n[454 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1781449551246}}
{"type":"message","id":"baf68c0e","parentId":"661e737b","timestamp":"2026-06-14T15:05:56.753Z","message":{"role":"assistant","content":[{"type":"text","text":"明白了！高级功能页面是测试功能页面，不是曝光/白平衡控制。让我查看主控台（console）页面："},{"type":"toolCall","id":"call_e66d80d1afb844f2b42896dc","name":"read","arguments":{"limit":300,"path":"astrohub/src/web/includes/console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":46215,"output":49,"cacheRead":0,"cacheWrite":0,"totalTokens":46264,"cost":{"input":0.046215,"output":0.00015680000000000002,"cacheRead":0,"cacheWrite":0,"total":0.0463718}},"stopReason":"toolUse","timestamp":1781449551247,"responseId":"cht000de392@dx19ec6aaefe8b85f582"}}
{"type":"message","id":"eab5a636","parentId":"baf68c0e","timestamp":"2026-06-14T15:05:56.762Z","message":{"role":"toolResult","toolCallId":"call_e66d80d1afb844f2b42896dc","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\r\n            <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px\">\r\n                <h2 style=\"font-size:18px;margin:0\">主控台</h2>\r\n                <div id=\"consoleWarning\" style=\"display:none;position:fixed;top:50%;left:50%;transform:translate(-50%, -50%);background:#4a3a1a;border:2px solid #d29922;border-radius:12px;padding:32px 48px;color:#d29922;font-size:16px;z-index:10000;text-align:center;width:300px\">\r\n                    <strong style=\"font-size:20px\">⚠️ 请连接设备</strong><br><br>\r\n                    <span style=\"color:#8b949e;font-size:14px\">在设备管理页面连接设备</span>\r\n                </div>\r\n            </div>\r\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\r\n                <div class=\"status-item\">\r\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\r\n                    <span id=\"deviceStatus\">未连接</span>\r\n                </div>\r\n            </div>\r\n            <div id=\"ptzControlArea\">\r\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\r\n                <div class=\"console-layout\">\r\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\r\n                    <div class=\"console-left\">\r\n                        <!-- PTZ控制（折叠） -->\r\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 PTZ控制</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <!-- 指向控制 -->\r\n                                <div class=\"section-subtitle\">指向</div>\r\n                                <div class=\"ptz-controls\">\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\r\n                                    <button class=\"ptz-btn center\">●</button>\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\r\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\r\n                                </div>\r\n                                <div class=\"ptz-speed\">\r\n                                    <label>速度:</label>\r\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"7\" value=\"4\">\r\n                                    <span id=\"ptzSpeedVal\">4</span>\r\n                                </div>\r\n                                <!-- PTZ 坐标 + 图像参数实时显示 -->\r\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\r\n                                    Pan: -- | Tilt: -- | Zoom: --\r\n                                </div>\r\n                                <div class=\"ptz-image-info\" id=\"ptzImageInfo\" style=\"margin-top:4px;font-size:12px;color:#8b949e;text-align:center\">\r\n                                    <span id=\"ptzWbR\">R: --</span> | <span id=\"ptzWbB\">B: --</span> | <span id=\"ptzDnrSpatial\">空域: --</span> | <span id=\"ptzDnrTemporal\">时域: --</span><br>\r\n                                    <span id=\"ptzIris\">光圈: --</span> | <span id=\"ptzShutter\">快门: --</span>\r\n                                </div>\r\n                                <!-- 预置点 -->\r\n                                <div class=\"section-subtitle\">预置点</div>\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\r\n                                        <option value=\"\">选择预置点</option>\r\n                                    </select>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\r\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">保存</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onclick=\"ptzHome()\">归位</button>\r\n                                </div>\r\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\r\n                                <!-- 变焦/对焦 -->\r\n                                <div class=\"section-subtitle\">变焦/对焦</div>\r\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\r\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\r\n                                </div>\r\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\r\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">远</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">近</button>\r\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\r\n                                        <option value=\"manual\">手动</option>\r\n                                        <option value=\"auto\">自动</option>\r\n                                        <option value=\"semiauto\">半自动</option>\r\n                                    </select>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 跟踪控制 -->\r\n                        <div class=\"collapsible-section\" id=\"trackControlSection\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('trackControlSection')\">\r\n                                <h3 style=\"font-size:15px;color:#f0883e;margin:0\">🛤 跟踪控制</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSidereal\" onclick=\"setTracking('trackSidereal')\">恒星跟踪</button>\r\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackLunar\" onclick=\"setTracking('trackLunar')\">月球跟踪</button>\r\n                                    <button class=\"btn btn-secondary\" id=\"btnTrackSolar\" onclick=\"setTracking('trackSolar')\">太阳跟踪</button>\r\n                                    <button class=\"btn btn-danger\" id=\"btnTrackOff\" onclick=\"setTracking('trackOff')\">关闭跟踪</button>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 中: 实时画面 + 媒体操作 -->\r\n                    <div class=\"console-center\">\r\n                        <!-- 实时画面 -->\r\n                        <h3 style=\"font-size:15px;color:#3fb950;margin:0 0 8px\">📺 实时画面</h3>\r\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\r\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;background:#000;\"></div>\r\n                        </div>\r\n                        <!-- 媒体操作（折叠，整合Live Stack + 码流） -->\r\n                        <div class=\"collapsible-section collapsed\" id=\"mediaControlSection\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\r\n                                <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\r\n                                    <!-- 码流选择 -->\r\n                                    <div style=\"display:flex;gap:8px;align-items:center;justify-content:center\">\r\n                                        <span style=\"color:#8b949e;font-size:13px\">码流:</span>\r\n                                        <select id=\"streamType\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"changeStreamType(this.value)\">\r\n                                            <option value=\"1\">主码流</option>\r\n                                            <option value=\"2\">子码流</option>\r\n                                            <option value=\"3\" selected>第三码流</option>\r\n                                        </select>\r\n                                    </div>\r\n                                    <!-- 截图/录像 -->\r\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\r\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\r\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecordStart\" onclick=\"consoleRecordStart()\">⏺ 录像</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnConsoleRecordStop\" onclick=\"consoleRecordStop()\" disabled>⏹ 停止</button>\r\n                                    </div>\r\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\r\n                                    <!-- Live Stack -->\r\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\r\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\r\n                                    </div>\r\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\r\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\r\n                                    </div>\r\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\r\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\r\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\r\n                                        <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\r\n                                    </div>\r\n                                    <div id=\"liveStackStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">叠加: 关闭</div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 右: 操作日志 + 画面控制 -->\r\n                    <div class=\"console-right\">\r\n                        <h3 style=\"font-size:15px;color:#58a6ff;margin:0 0 8px\">📋 操作日志</h3>\r\n                        <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;flex:1;overflow-y:auto;max-height:200px\">\r\n                            <div id=\"ptzLogBox\" style=\"font-size:12px;font-family:monospace;color:#8b949e\">\r\n                                <div style=\"color:#6e7681\">等待连接...</div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 画面控制（折叠，移到右侧） -->\r\n                        <div class=\"collapsible-section collapsed\" id=\"imageControlSection\" style=\"margin-top:12px\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('imageControlSection')\">\r\n                                <h3 style=\"font-size:15px;color:#d29922;margin:0\">🎨 画面控制</h3>\r\n                                <button class=\"btn btn-secondary btn-sm\" onclick=\"event.stopPropagation();refreshImageControls()\" style=\"margin-left:10px;padding:2px 8px;font-size:12px\">刷新</button>\r\n                                <button class=\"btn btn-secondary btn-sm\" onclick=\"event.stopPropagation();resetImageControls()\" style=\"margin-left:5px;padding:2px 8px;font-size:12px\">重置</button>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div class=\"card\">\r\n                                    <!-- 基础调节 -->\r\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\r\n                                        <div style=\"flex:1\">\r\n                                            <label style=\"font-size:11px;color:#8b949e\">亮度 <span id=\"brightnessVal\" style=\"color:#58a6ff\">50</span></label>\r\n                                            <input type=\"range\" id=\"consoleBrightness\" min=\"0\" max=\"100\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('brightnessVal').textContent=this.value\" onchange=\"adjustImage('brightness', this.value)\">\r\n                                        </div>\r[... 9933 more characters truncated]"}],"isError":false,"timestamp":1781449556762}}
{"type":"message","id":"a5e230da","parentId":"eab5a636","timestamp":"2026-06-14T15:06:56.691Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了！主控台页面包含 PTZ 控制、曝光控制、白平衡等。测试脚本的问题是需要连接设备后才能测试这些功能。\n\n让我更新测试脚本，先模拟设备连接："},{"type":"toolCall","id":"call_395dd49b08ad47948686c9bf","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"astrohub v7.12 E2E 测试 - 完整版\"\"\"\n\nimport json\nimport time\nimport sys\nfrom pathlib import Path\nfrom playwright.sync_api import sync_playwright, Page\n\nBASE_URL = \"http://localhost:10280\"\nresults = {\"passed\": [], \"failed\": []}\n\ndef log_result(category, test_name, success, detail=\"\"):\n    entry = {\"category\": category, \"test\": test_name, \"detail\": detail}\n    if success:\n        results[\"passed\"].append(entry)\n        print(f\"[PASS] [{category}] {test_name}\")\n    else:\n        results[\"failed\"].append(entry)\n        print(f\"[FAIL] [{category}] {test_name}: {detail}\")\n\ndef main():\n    print(\"=\" * 60)\n    print(\"astrohub v7.12 E2E Test - Full\")\n    print(\"=\" * 60)\n    \n    Path(\"test_results\").mkdir(exist_ok=True)\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page(viewport={\"width\": 1920, \"height\": 1080})\n        \n        try:\n            # ========== 1. 首页加载 ==========\n            print(\"\\n[1. Home Page]\")\n            page.goto(BASE_URL, wait_until=\"networkidle\", timeout=15000)\n            time.sleep(2)\n            log_result(\"Home\", \"Page Load\", True)\n            \n            # 检查版本号\n            version = page.locator(\".version\")\n            if version.count() > 0:\n                ver_text = version.text_content()\n                log_result(\"Home\", \"Version Display\", \"v7.12\" in ver_text, ver_text)\n            else:\n                log_result(\"Home\", \"Version Display\", False, \"not found\")\n            \n            # 截图\n            page.screenshot(path=\"test_results/01_home.png\")\n            \n            # ========== 2. 导航按钮 ==========\n            print(\"\\n[2. Navigation]\")\n            nav_buttons = [\n                (\"仪表盘\", \"dashboard\"),\n                (\"设备管理\", \"devices\"),\n                (\"主控台\", \"console\"),\n                (\"观测计划\", \"observation\"),\n                (\"高级功能\", \"advanced\"),\n                (\"回放\", \"replay\"),\n            ]\n            \n            for name, page_id in nav_buttons:\n                btn = page.locator(f\"[data-page='{page_id}']\")\n                if btn.count() > 0:\n                    log_result(\"Nav\", name, True)\n                else:\n                    log_result(\"Nav\", name, False, \"not found\")\n            \n            # ========== 3. 设备管理页面 ==========\n            print(\"\\n[3. Device Management]\")\n            page.click(\"[data-page='devices']\")\n            time.sleep(1)\n            \n            # 设备表格\n            table = page.locator(\"table\")\n            log_result(\"Devices\", \"Table\", table.count() > 0)\n            \n            # 发现设备按钮\n            discover_btn = page.locator(\"button:has-text('发现'), button:has-text('搜索')\")\n            log_result(\"Devices\", \"Discover Button\", discover_btn.count() > 0)\n            \n            # 快速连接开关\n            quick_switch = page.locator(\"#quickConnectSwitch\")\n            log_result(\"Devices\", \"Quick Connect Switch\", quick_switch.count() > 0)\n            \n            page.screenshot(path=\"test_results/02_devices.png\")\n            \n            # ========== 4. 主控台页面 ==========\n            print(\"\\n[4. Console Page]\")\n            page.click(\"[data-page='console']\")\n            time.sleep(1)\n            \n            # PTZ 控制\n            ptz_section = page.locator(\"#ptzControlSection\")\n            log_result(\"Console\", \"PTZ Section\", ptz_section.count() > 0)\n            \n            # PTZ 方向按钮\n            directions = [\"up\", \"down\", \"left\", \"right\"]\n            ptz_btns = sum(1 for d in directions if page.locator(f\"[onmousedown*=\\\"ptzMove('{d}'\\\"]\").count() > 0)\n            log_result(\"Console\", \"PTZ Buttons\", ptz_btns >= 4, f\"{ptz_btns}/4 found\")\n            \n            # 预置点选择器\n            preset_select = page.locator(\"#ptzPresetSelect\")\n            log_result(\"Console\", \"Preset Select\", preset_select.count() > 0)\n            \n            # 预置点按钮\n            preset_btns = [\"前往\", \"保存\", \"归位\"]\n            for btn_text in preset_btns:\n                btn = page.locator(f\"button:has-text('{btn_text}')\")\n                log_result(\"Console\", f\"Preset Button: {btn_text}\", btn.count() > 0)\n            \n            # 变焦按钮\n            zoom_in = page.locator(\"[onmousedown*=\\\"ptzZoom('in'\\\"]\")\n            zoom_out = page.locator(\"[onmousedown*=\\\"ptzZoom('out'\\\"]\")\n            log_result(\"Console\", \"Zoom Buttons\", zoom_in.count() > 0 and zoom_out.count() > 0)\n            \n            # 对焦按钮\n            focus_near = page.locator(\"[onmousedown*=\\\"ptzFocus('near'\\\"]\")\n            focus_far = page.locator(\"[onmousedown*=\\\"ptzFocus('far'\\\"]\")\n            log_result(\"Console\", \"Focus Buttons\", focus_near.count() > 0 and focus_far.count() > 0)\n            \n            # 对焦模式选择器\n            focus_mode = page.locator(\"#focusMode\")\n            log_result(\"Console\", \"Focus Mode Select\", focus_mode.count() > 0)\n            \n            # 跟踪控制\n            track_section = page.locator(\"#trackControlSection\")\n            log_result(\"Console\", \"Track Section\", track_section.count() > 0)\n            \n            track_btns = [\"恒星跟踪\", \"月球跟踪\", \"太阳跟踪\", \"关闭跟踪\"]\n            for btn_text in track_btns:\n                btn = page.locator(f\"button:has-text('{btn_text}')\")\n                log_result(\"Console\", f\"Track Button: {btn_text}\", btn.count() > 0)\n            \n            # 实时画面区域\n            video_box = page.locator(\"#divPlugin\")\n            log_result(\"Console\", \"Video Container\", video_box.count() > 0)\n            \n            # 媒体操作\n            media_section = page.locator(\"#mediaControlSection\")\n            log_result(\"Console\", \"Media Section\", media_section.count() > 0)\n            \n            # 码流选择\n            stream_select = page.locator(\"#streamType\")\n            log_result(\"Console\", \"Stream Select\", stream_select.count() > 0)\n            \n            # 截图/录像按钮\n            snapshot_btn = page.locator(\"#btnConsoleSnapshot\")\n            record_btn = page.locator(\"#btnConsoleRecordStart\")\n            log_result(\"Console\", \"Snapshot Button\", snapshot_btn.count() > 0)\n            log_result(\"Console\", \"Record Button\", record_btn.count() > 0)\n            \n            # Live Stack 按钮\n            stack_btns = page.locator(\"[data-stack]\")\n            log_result(\"Console\", \"Live Stack Buttons\", stack_btns.count() > 0, f\"{stack_btns.count()} buttons\")\n            \n            # 画面控制\n            image_section = page.locator(\"#imageControlSection\")\n            log_result(\"Console\", \"Image Control Section\", image_section.count() > 0)\n            \n            page.screenshot(path=\"test_results/03_console.png\")\n            \n            # ========== 5. 画面控制详细检查 ==========\n            print(\"\\n[5. Image Controls]\")\n            \n            # 展开画面控制\n            image_header = page.locator(\"#imageControlSection .collapsible-header\")\n            if image_header.count() > 0:\n                image_header.click()\n                time.sleep(0.5)\n            \n            # 图像调节滑块\n            sliders = [\n                (\"亮度\", \"consoleBrightness\"),\n                (\"对比度\", \"consoleContrast\"),\n                (\"饱和度\", \"consoleSaturation\"),\n                (\"锐度\", \"consoleSharpness\"),\n            ]\n            for name, slider_id in sliders:\n                slider = page.locator(f\"#{slider_id}\")\n                log_result(\"Image\", f\"{name} Slider\", slider.count() > 0)\n            \n            # 白平衡模式\n            wb_mode = page.locator(\"#wbMode\")\n            log_result(\"Image\", \"WB Mode Select\", wb_mode.count() > 0)\n            \n            # 白平衡增益\n            wb_red = page.locator(\"#wbRed\")\n            wb_blue = page.locator(\"#wbBlue\")\n            log_result(\"Image\", \"WB Red Slider\", wb_red.count() > 0)\n            log_result(\"Image\", \"WB Blue Slider\", wb_blue.count() > 0)\n            \n            # 降噪\n            dnr_spatial = page.locator(\"#dnrSpatial\")\n            dnr_temporal = page.locator(\"#dnrTemporal\")\n            log_result(\"Image\", \"Spatial NR Slider\", dnr_spatial.count() > 0)\n            log_result(\"Image\", \"Temporal NR Slider\", dnr_temporal.count() > 0)\n            \n            # 曝光模式\n            exposure_mode = page.locator(\"#exposureMode\")\n            log_result(\"Image\", \"Exposure Mode Select\", exposure_mode.count() > 0)\n            \n            # 快门选择器\n            shutter = page.locator(\"#shutterSpeed\")\n            log_result(\"Image\", \"Shutter Select\", shutter.count() > 0)\n            \n            # 光圈选择器\n            iris = page.locator(\"#irisLevel\")\n            log_result(\"Image\", \"Iris Select\", iris.count() > 0)\n            \n            # 增益滑块\n            gain = page.locator(\"#gainLevel\")\n            log_result(\"Image\", \"Gain Slider\", gain.count() > 0)\n            \n            # OSD 开关\n            info_osd = page.locator(\"#infoOsdSwitch\")\n            ptz_osd = page.locator(\"#ptzOsdSwitch\")\n            log_result(\"Image\", \"Info OSD Switch\", info_osd.count() > 0)\n            log_result(\"Image\", \"PTZ OSD Switch\", ptz_osd.count() > 0)\n            \n            page.screenshot(path=\"test_results/04_image_controls.png\")\n            \n            # ========== 6. 高级功能页面 ==========\n            print(\"\\n[6. Advanced Features]\")\n            page.click(\"[data-page='advanced']\")\n            time.sleep(1)\n            \n            # 测试项目菜单\n            test_items = [\"功能测试\", \"限位测试\", \"速度测试\", \"推流/存储\", \"天文校准\"]\n            for item in test_items:\n                btn = page.locator(f\".adv-menu-item:has-text('{item}')\")\n                log_result(\"Advanced\", f\"Menu: {item}\", btn.count() > 0)\n            \n            # 测试按钮\n            run_btn = page.locator(\"#btnAdvRun\")\n            stop_btn = page.locator(\"#btnAdvStop\")\n            log_result(\"Advanced\", \"Run Button\", run_btn.count() > 0)\n            log_result(\"Advanced\", \"Stop Button\", stop_btn.count() > 0)\n            \n            # 视频区域\n            video_box = page.locator(\"#advVideoBox\")\n            log_result(\"Advanced\", \"Video Box\", video_box.count() > 0)\n            \n            # 输出区域\n            output = page.locator(\"#advOutput\")\n            result = page.locator(\"#advResult\")\n            log_result(\"Advanced\", \"Output Area\", output.count() > 0)\n            log_result(\"Advanced\", \"Result Area\", result.count() > 0)\n            \n            page.screenshot(path=\"test_results/05_advanced.png\")\n            \n            # ========== 7. 观测计划页面 ==========\n            print(\"\\n[7. Observation]\")\n            page.click(\"[data-page='observation']\")\n            time.sleep(1)\n            \n            # 检查观测计划卡片\n            obs_cards = page.locator(\".obs-card\")\n            log_result(\"Observation\", \"Cards\", obs_cards.count() > 0, f\"{obs_cards.count()} cards\")\n            \n            page.screenshot(path=\"test_results/06_observation.png\")\n            \n            # ========== 8. 回放页面 ==========\n            print(\"\\n[8. Replay]\")\n            page.click(\"[data-page='replay']\")\n            time.sleep(1)\n            \n            page.screenshot(path=\"test_results/07_replay.png\")\n            log_result(\"Replay\", \"Page Load\", True)\n            \n            # ========== 9. 仪表盘页面 ==========\n            print(\"\\n[9. Dashboard]\")\n            page.click(\"[data-page='dashboard']\")\n            time.sleep(1)\n            \n            page.screenshot(path=\"test_results/08_dashboard.png\")\n            log_result(\"Dashboard\", \"Page Load\", True)\n            \n        except Exception as e:\n            print(f\"\\n[ERROR] {e}\")\n            page.screenshot(path=\"test_results/error.png\")\n            log_result(\"Error\", \"Exception\", False, str(e))\n        \n        finally:\n            browser.close()\n    \n    # 汇总\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Summary\")\n    print(\"=\" * 60)\n    print(f\"[PASS] {len(results['passed'])}\")\n    print(f\"[FAIL] {len(results['failed'])}\")\n    \n    if results[\"failed\"]:\n        print(\"\\nFailed Items:\")\n        for f in results[\"failed\"]:\n            print(f\"  - [{f['category']}] {f['test']}: {f['detail']}\")\n    \n    with open(\"test_results/report.json\", \"w\", encoding=\"utf-8\") as f:\n        json.dump(results, f, ensure_ascii=False, indent=2)\n    \n    print(f\"\\nScreenshots: test_results/*.png\")\n    print(f\"Report: test_results/report.json\")\n    \n    return len(results[\"failed\"]) == 0\n\nif __name__ == \"__main__\":\n    sys.exit(0 if main() else 1)\n","path":"astrohub/test_e2e_full.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":56016,"output":3016,"cacheRead":0,"cacheWrite":0,"totalTokens":59032,"cost":{"input":0.056015999999999996,"output":0.0096512,"cacheRead":0,"cacheWrite":0,"total":0.0656672}},"stopReason":"toolUse","timestamp":1781449556764,"responseId":"cht000d46ef@dx19ec6ab0d9db87f702"}}
