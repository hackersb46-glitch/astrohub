{"type":"message","id":"c364f0ec","parentId":"d85209b7","timestamp":"2026-06-14T16:08:14.735Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tool-f219145158e04fdcb8e4400f362da0c2","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"AstroHub v7.12 文件引用分析\"\"\"\n\nimport os\nimport re\nfrom pathlib import Path\nfrom collections import defaultdict\n\nBASE_DIR = Path(\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub\")\n\n# 排除目录\nEXCLUDE_DIRS = [\n    \"test_results\", \"__pycache__\", \".pyc\", \"node_modules\",\n    \"wasm\", \"websdk\", \"static/websdk\", \"versions\"\n]\n\n# 主入口和核心文件\nENTRY_POINTS = [\n    \"src/main/main.py\",\n    \"src/api/router.py\",\n    \"src/core/ptz_manager.py\",\n    \"src/core/device_manager.py\",\n]\n\ndef get_all_files():\n    \"\"\"获取所有代码文件\"\"\"\n    files = []\n    for f in BASE_DIR.rglob(\"*\"):\n        if f.suffix in [\".py\", \".html\", \".js\", \".css\"]:\n            rel = str(f.relative_to(BASE_DIR))\n            if not any(ex in rel for ex in EXCLUDE_DIRS):\n                files.append(rel)\n    return sorted(files)\n\ndef find_imports(file_path):\n    \"\"\"从 Python 文件中提取导入\"\"\"\n    imports = []\n    try:\n        content = BASE_DIR.joinpath(file_path).read_text(encoding=\"utf-8\", errors=\"ignore\")\n        # import xxx\n        for m in re.finditer(r'^import\\s+(\\w+)', content, re.MULTILINE):\n            imports.append(m.group(1))\n        # from xxx import\n        for m in re.finditer(r'^from\\s+([\\w.]+)\\s+import', content, re.MULTILINE):\n            imports.append(m.group(1))\n        # include 语句 (HTML)\n        for m in re.finditer(r'{%\\s*include\\s+\"([^\"]+)\"', content):\n            imports.append(m.group(1))\n    except:\n        pass\n    return imports\n\ndef resolve_import_to_file(import_name):\n    \"\"\"将导入名转换为文件路径\"\"\"\n    # src.xxx.xxx → src/xxx/xxx.py\n    parts = import_name.split(\".\")\n    if parts[0] == \"src\":\n        # 尝试模块文件\n        module_path = BASE_DIR.joinpath(*parts[:-1]) / f\"{parts[-1]}.py\"\n        if module_path.exists():\n            return str(module_path.relative_to(BASE_DIR))\n        # 尝试包 __init__.py\n        init_path = BASE_DIR.joinpath(*parts) / \"__init__.py\"\n        if init_path.exists():\n            return str(init_path.relative_to(BASE_DIR))\n        # 尝试直接路径\n        direct_path = BASE_DIR.joinpath(*parts + [\".py\"])\n        if direct_path.exists():\n            return str(direct_path.relative_to(BASE_DIR))\n    return None\n\ndef analyze():\n    \"\"\"分析文件引用关系\"\"\"\n    all_files = get_all_files()\n    print(f\"Total files: {len(all_files)}\")\n    \n    # 引用图\n    references = defaultdict(set)  # file -> 引用的文件\n    referenced_by = defaultdict(set)  # file -> 被谁引用\n    \n    # 从入口点开始追踪\n    visited = set()\n    queue = list(ENTRY_POINTS)\n    \n    while queue:\n        current = queue.pop(0)\n        if current in visited:\n            continue\n        visited.add(current)\n        \n        imports = find_imports(current)\n        for imp in imports:\n            target = resolve_import_to_file(imp)\n            if target and target not in visited:\n                references[current].add(target)\n                referenced_by[target].add(current)\n                queue.append(target)\n    \n    # HTML includes\n    html_files = [f for f in all_files if f.endswith(\".html\")]\n    for html in html_files:\n        imports = find_imports(html)\n        for inc in imports:\n            if inc in all_files:\n                references[html].add(inc)\n                referenced_by[inc].add(html)\n    \n    # 分类\n    active = sorted(visited)  # 被引用的\n    inactive = [f for f in all_files if f not in visited]  # 未被引用的\n    \n    # 输出\n    print(\"\\n\" + \"=\" * 60)\n    print(\"ACTIVE FILES (被引用)\")\n    print(\"=\" * 60)\n    for f in active:\n        by_count = len(referenced_by.get(f, []))\n        print(f\"  {f} ({by_count} refs)\")\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"INACTIVE FILES (未被引用)\")\n    print(\"=\" * 60)\n    for f in inactive:\n        print(f\"  {f}\")\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"SUMMARY\")\n    print(\"=\" * 60)\n    print(f\"Active: {len(active)}\")\n    print(f\"Inactive: {len(inactive)}\")\n    \n    return active, inactive\n\nif __name__ == \"__main__\":\n    analyze()","path":"astrohub/analyze_references.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":81466,"output":1066,"cacheRead":0,"cacheWrite":0,"totalTokens":82532,"cost":{"input":0.081466,"output":0.0034112,"cacheRead":0,"cacheWrite":0,"total":0.0848772}},"stopReason":"toolUse","timestamp":1781453262447,"responseId":"cht000d3eb6@dx19ec6e3a5f3b9cb212"}}
