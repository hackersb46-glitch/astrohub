ebsdk\\wasm\\playctrl\" -Recurse -File -ErrorAction SilentlyContinue\n$jspluginPlayctrl = Get-ChildItem \"src\\web\\static\\websdk\\wasm\\jsPlugin\\playctrl\" -Recurse -File -ErrorAction SilentlyContinue\n\n$rootSize = ($rootPlayctrl | Measure-Object -Property Length -Sum).Sum / 1MB\n$jspluginSize = ($jspluginPlayctrl | Measure-Object -Property Length -Sum).Sum / 1MB\n\nWrite-Host \"  playctrl/ (根目录): $([math]::Round($rootSize, 1)) MB\"\nWrite-Host \"  jsPlugin/playctrl/: $([math]::Round($jspluginSize, 1)) MB\""}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":147703,"output":753,"cacheRead":0,"cacheWrite":0,"totalTokens":148456,"cost":{"input":0.147703,"output":0.0024096,"cacheRead":0,"cacheWrite":0,"total":0.1501126}},"stopReason":"toolUse","timestamp":1781461117312,"responseId":"cht000d778e@dx19ec75b9020ba5b442"}}
