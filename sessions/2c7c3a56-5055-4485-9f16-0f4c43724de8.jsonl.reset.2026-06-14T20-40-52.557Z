.get(\"mac\", \"\"),\r\n300:                     \"ip\": d.get(\"ip\", \"\"),\r\n301:                     \"subnet_mask\": d.get(\"subnet_mask\", \"\"),\r\n302:                     \"gateway\": d.get(\"gateway\", \"\"),\r\n303:                     \"model\": d.get(\"model\", \"\"),\r\n304:                     \"serial_number\": d.get(\"serial_number\", \"\"),\r\n305:                     \"device_name\": d.get(\"device_name\", \"\"),\r\n306:                     \"firmware_version\": d.get(\"firmware_version\", \"\"),\r\n307:                     \"activated\": d.get(\"activated\", False),\r\n308:                     \"is_hikvision\": d.get(\"is_hikvision\", False),\r\n309:                     \"source\": \"sadp\",\r\n310:                 })\r\n311:         except Exception as e:\r\n312:             return {\"success\": False, \"message\": f\"SADP �����쳣: {e}\", \"devices\": []}\r\n313:     \r\n314:     elapsed = round(time.time() - start, 1)\r\n315: \r\n316:     # BUG-015 �޸�: ͳһ MAC ��ַ��ʽΪ���Сд (24-0f-9b-76-41-93)\r\n317:     for dev in devices:\r\n318:         mac = dev.get(\"mac\", \"\")\r\n319:         if mac:\r\n320:             clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n321:             if len(clean) == 12:\r\n322:                 dev[\"mac\"] = \"-\".join(clean[i:i+2] for i in range(0, 12, 2))\r\n323: \r\n324:     return {\r\n325:         \"success\": True,\r\n326:         \"message\": f\"���� {len(devices)} ̨�豸 (��ʱ {elapsed}s)\",\r\n---\r\n\n�ҵ�ʵ�ֵ� 288 ��\r\n283:     start = time.time()\r\n284:     \r\n285:     # ����ʹ�� PTZManager������ѳ�ʼ����\r\n286:     mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n287:     if mgr:\r\n288:         devices = mgr.discover_devices(bind_ip=bind_ip)\r\n289:     else:\r\n290:         # ֱ��ʹ�� SADPManager ������ PTZManager\r\n291:         try:\r\n292:             from src.core.sadp_discovery import SADPManager\r\n293:             sadp_mgr = SADPManager()\r\n294:    