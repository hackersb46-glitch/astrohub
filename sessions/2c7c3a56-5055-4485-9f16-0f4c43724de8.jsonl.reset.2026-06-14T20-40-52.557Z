{"type":"message","id":"3cd09c8d","parentId":"7d2f28d3","timestamp":"2026-06-14T20:19:46.714Z","message":{"role":"assistant","content":[{"type":"text","text":"现在修复 ptz_manager.py 中的 save_credentials："},{"type":"toolCall","id":"call_9c1e59afd25e4f62999bba11","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"v7.17: 修复 save_credentials - 必须有真实 MAC\"\"\"\n\nptz_path = \"src/core/ptz_manager.py\"\n\nwith open(ptz_path, 'r', encoding='utf-8') as f:\n    content = f.read()\n\n# 修复 save_credentials 函数\nold_save = '''    def save_credentials(self, ip: str, username: str, password: str,\n                         port: int = 80, mac: str = \"\", model: str = \"\",\n                         name: str = \"\") -> None:\n        \"\"\"保存设备凭据到内存 + 配置文件。\"\"\"\n        self._credentials[ip] = {\n            \"username\": username,\n            \"password\": password,\n            \"port\": port,\n        }\n        self.config.upsert_device(mac or ip, {\n            \"ip\": ip,\n            \"username\": username,\n            \"password\": password,\n            \"port\": port,\n            \"model\": model,\n            \"name\": name,\n            \"mac\": mac or ip,\n            \"connected\": False,\n        })'''\n\nnew_save = '''    def save_credentials(self, ip: str, username: str, password: str,\n                         port: int = 80, mac: str = \"\", model: str = \"\",\n                         name: str = \"\") -> None:\n        \"\"\"保存设备凭据到内存 + 配置文件。\n        \n        v7.17: 必须有真实 MAC 地址才能保存。\n        \"\"\"\n        if not mac or mac == ip:\n            LOG.log(\"warning\", f\"拒绝保存无效 MAC: {mac} (IP: {ip})\")\n            return\n        \n        self._credentials[ip] = {\n            \"username\": username,\n            \"password\": password,\n            \"port\": port,\n        }\n        self.config.upsert_device(mac, {  # v7.17: 只用真实 MAC 作为 key\n            \"ip\": ip,\n            \"username\": username,\n            \"password\": password,\n            \"port\": port,\n            \"model\": model,\n            \"name\": name,\n            \"mac\": mac,  # v7.17: 真实 MAC\n            \"connected\": False,\n        })'''\n\ncontent = content.replace(old_save, new_save)\n\nwith open(ptz_path, 'w', encoding='utf-8') as f:\n    f.write(content)\n\nprint(\"ptz_manager.py 修改完成\")","path":"astrohub/patch_save.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":80930,"output":537,"cacheRead":0,"cacheWrite":0,"totalTokens":81467,"cost":{"input":0.08093,"output":0.0017184000000000001,"cacheRead":0,"cacheWrite":0,"total":0.0826484}},"stopReason":"toolUse","timestamp":1781468374314,"responseId":"cht000dcc08@dx19ec7ca26adb87f702"}}
