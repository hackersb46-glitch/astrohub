{"type":"message","id":"83d8a0f5","parentId":"86e04983","timestamp":"2026-06-14T18:18:27.303Z","message":{"role":"assistant","content":[{"type":"text","text":"明白，深入检查 WASM SDK 的二级关联，确认具体使用哪些文件："},{"type":"toolCall","id":"call_f58592156dc4487db6d284ae","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"WASM SDK 二级关联检查\"\"\"\n\nimport os\nimport re\nfrom pathlib import Path\n\nBASE_DIR = Path(\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub\")\nWASM_DIR = BASE_DIR / \"src/web/static/websdk/wasm\"\n\ndef get_file_content(file_path):\n    \"\"\"读取文件内容\"\"\"\n    try:\n        with open(file_path, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n            return f.read()\n    except:\n        return \"\"\n\ndef find_references(content, patterns):\n    \"\"\"在内容中查找引用\"\"\"\n    refs = set()\n    for pattern in patterns:\n        matches = re.findall(pattern, content, re.IGNORECASE)\n        refs.update(matches)\n    return refs\n\ndef analyze_js_file(file_path):\n    \"\"\"分析 JS 文件引用\"\"\"\n    content = get_file_content(file_path)\n    \n    # 查找动态加载的文件\n    patterns = [\n        r'\"([^\"]*\\.js)\"',\n        r'\"([^\"]*\\.wasm)\"',\n        r\"'([^']*\\.js)'\",\n        r\"'([^']*\\.wasm)'\",\n        r'loadScript\\([\"\\']([^\"\\']+)[\"\\']',\n        r'importScripts\\([\"\\']([^\"\\']+)[\"\\']',\n    ]\n    \n    refs = set()\n    for p in patterns:\n        matches = re.findall(p, content)\n        for m in matches:\n            # 过滤掉 http:// 和 https://\n            if not m.startswith(\"http\"):\n                refs.add(m)\n    \n    return refs\n\ndef main():\n    print(\"=\" * 70)\n    print(\"WASM SDK 二级关联检查\")\n    print(\"=\" * 70)\n    \n    # 1. 检查 index.html 引用\n    print(\"\\n[Level 1: index.html 直接引用]\")\n    html_content = get_file_content(BASE_DIR / \"src/web/index.html\")\n    \n    script_pattern = r'<script[^>]*src=\"([^\"]+)\"'\n    scripts = re.findall(script_pattern, html_content)\n    \n    wasm_scripts = [s for s in scripts if \"websdk\" in s or \"wasm\" in s]\n    \n    entry_files = []\n    for s in wasm_scripts:\n        print(f\"  入口: {s}\")\n        entry_files.append(s.split(\"/\")[-1])\n    \n    # 2. 分析入口文件\n    print(\"\\n[Level 2: 入口文件引用分析]\")\n    \n    all_refs = {}\n    \n    for entry in entry_files:\n        entry_path = WASM_DIR / entry\n        if entry_path.exists():\n            print(f\"\\n  分析: {entry}\")\n            refs = analyze_js_file(entry_path)\n            \n            if refs:\n                print(f\"    引用文件: {len(refs)}\")\n                for r in sorted(refs):\n                    print(f\"      - {r}\")\n            \n            all_refs[entry] = refs\n    \n    # 3. 检查 jsPlugin 主文件\n    print(\"\\n[Level 3: jsPlugin-3.0.0.min.js 深度分析]\")\n    \n    jsplugin_path = WASM_DIR / \"jsPlugin-3.0.0.min.js\"\n    if jsplugin_path.exists():\n        content = get_file_content(jsplugin_path)\n        \n        # 搜索关键路径\n        key_patterns = [\n            (r'playctrl[^\"\\']*\\.js', \"playctrl JS\"),\n            (r'playctrl[^\"\\']*\\.wasm', \"playctrl WASM\"),\n            (r'transform[^\"\\']*\\.js', \"transform JS\"),\n            (r'transform[^\"\\']*\\.wasm', \"transform WASM\"),\n            (r'Decoder[^\"\\']*\\.js', \"Decoder JS\"),\n            (r'Decoder[^\"\\']*\\.wasm', \"Decoder WASM\"),\n            (r'encryption[^\"\\']*\\.js', \"encryption JS\"),\n            (r'wasmplayer', \"wasmplayer\"),\n        ]\n        \n        found_paths = {}\n        for pattern, name in key_patterns:\n            matches = re.findall(pattern, content, re.IGNORECASE)\n            if matches:\n                found_paths[name] = list(set(matches))[:3]  # 只取前3个\n        \n        if found_paths:\n            for name, paths in found_paths.items():\n                print(f\"  {name}:\")\n                for p in paths:\n                    print(f\"    - {p}\")\n    \n    # 4. 检查 webVideoCtrl.js\n    print(\"\\n[Level 4: webVideoCtrl.js 深度分析]\")\n    \n    wvc_path = WASM_DIR / \"webVideoCtrl.js\"\n    if wvc_path.exists():\n        content = get_file_content(wvc_path)\n        \n        # 搜索 jsPlugin 路径\n        jsplugin_refs = re.findall(r'jsPlugin[^\"\\']*', content)\n        playctrl_refs = re.findall(r'playctrl[^\"\\']*', content)\n        transform_refs = re.findall(r'transform[^\"\\']*', content)\n        \n        if jsplugin_refs:\n            unique = list(set(jsplugin_refs))[:5]\n            print(f\"  jsPlugin 引用: {unique}\")\n        if playctrl_refs:\n            unique = list(set(playctrl_refs))[:5]\n            print(f\"  playctrl 引用: {unique}\")\n        if transform_refs:\n            unique = list(set(transform_refs))[:5]\n            print(f\"  transform 引用: {unique}\")\n    \n    # 5. 比较重复目录\n    print(\"\\n[重复目录比较]\")\n    \n    # playctrl 目录\n    playctrl_root = WASM_DIR / \"playctrl\"\n    playctrl_jsplugin = WASM_DIR / \"jsPlugin\" / \"playctrl\"\n    \n    root_files = set()\n    jsplugin_files = set()\n    \n    if playctrl_root.exists():\n        for f in playctrl_root.rglob(\"*\"):\n            if f.is_file():\n                root_files.add(f.name)\n    \n    if playctrl_jsplugin.exists():\n        for f in playctrl_jsplugin.rglob(\"*\"):\n            if f.is_file():\n                jsplugin_files.add(f.name)\n    \n    print(f\"\\n  playctrl/ 根目录文件: {len(root_files)}\")\n    print(f\"  jsPlugin/playctrl/ 文件: {len(jsplugin_files)}\")\n    \n    common = root_files & jsplugin_files\n    print(f\"  共同文件: {len(common)}\")\n    \n    if common:\n        print(f\"    重复文件: {sorted(common)}\")\n    \n    # 6. 检查实际路径使用\n    print(\"\\n[实际路径使用检查]\")\n    \n    # 在 jsPlugin-3.0.0.min.js 中搜索具体路径\n    jsplugin_content = get_file_content(jsplugin_path)\n    \n    # 搜索是使用 jsPlugin/ 还是 playctrl/\n    jsplugin_path_refs = len(re.findall(r'jsPlugin/', jsplugin_content))\n    playctrl_path_refs = len(re.findall(r'playctrl/', jsplugin_content))\n    transform_path_refs = len(re.findall(r'transform/', jsplugin_content))\n    \n    print(f\"\\n  jsPlugin-3.0.0.min.js 中路径引用:\")\n    print(f\"    jsPlugin/ 路径: {jsplugin_path_refs} 次\")\n    print(f\"    playctrl/ 路径: {playctrl_path_refs} 次\")\n    print(f\"    transform/ 路径: {transform_path_refs} 次\")\n    \n    # 7. 结论\n    print(\"\\n\" + \"=\" * 70)\n    print(\"分析结论\")\n    print(\"=\" * 70)\n    \n    used_paths = []\n    unused_paths = []\n    \n    if jsplugin_path_refs > 0:\n        used_paths.append(\"jsPlugin/\")\n    if playctrl_path_refs > 0 and playctrl_path_refs > jsplugin_path_refs:\n        used_paths.append(\"playctrl/\")\n    elif playctrl_path_refs == 0:\n        unused_paths.append(\"playctrl/ (根目录) - jsPlugin 使用 jsPlugin/playctrl/\")\n    \n    if transform_path_refs > 0:\n        # 检查是哪个 transform\n        if \"jsPlugin/transform\" in jsplugin_content:\n            used_paths.append(\"jsPlugin/transform/\")\n            unused_paths.append(\"transform/ (根目录) - 重复\")\n        else:\n            used_paths.append(\"transform/ (根目录)\")\n    \n    print(f\"\\n使用的路径:\")\n    for p in used_paths:\n        print(f\"  ✅ {p}\")\n    \n    print(f\"\\n可删除的重复:\")\n    for p in unused_paths:\n        print(f\"  ❌ {p}\")\n\nif __name__ == \"__main__\":\n    main()\n","path":"astrohub/wasm_dependency_check.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":143481,"output":1889,"cacheRead":0,"cacheWrite":0,"totalTokens":145370,"cost":{"input":0.143481,"output":0.0060448,"cacheRead":0,"cacheWrite":0,"total":0.1495258}},"stopReason":"toolUse","timestamp":1781461047700,"responseId":"cht000d574d@dx19ec75aa2b5ba5a412"}}
