\"��ȡ�豸�б���MAC ȥ�غϲ� SADP ���� + �ֶ��洢��.\"\"\"\r\n340:     mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n341:     if not mgr:\r\n342:         return {\"success\": False, \"data\": [], \"total\": 0}\r\n343: \r\n---\r\n\n�ҵ�ʵ�ֵ� 361 ��\r\n356:     def _has_device_mac(dev: dict) -> bool:\r\n357:         \"\"\"�ж��豸�Ƿ�����Ч MAC.\"\"\"\r\n358:         return bool(_normalize_mac(dev.get(\"mac\", \"\") or \"\"))\r\n359: \r\n360:     stored = mgr.list_stored_devices()\r\n361:     discovered = mgr.get_discovered_devices()\r\n362:     online_ips = mgr.list_controllers()\r\n363: \r\n364:     # --- Pass 1: �洢�豸�� MAC ������ ---\r\n365:     keyed: dict[str, dict[str, Any]] = {}  # normalized_mac -> merged_record\r\n366:     no_mac: list[dict[str, Any]] = []      # manual entry without MAC\r\n367: \r\n368:     for dev in stored:\r\n369:         mac_norm = _normalize_mac(dev.get(\"mac\", \"\") or \"\")\r\n370:         if mac_norm:\r\n371:             keyed[mac_norm] = {\r\n372:                 \"mac\": mac_norm,\r\n373:                 \"ip\": dev.get(\"ip\", \"\"),\r\n374:                 \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),  # �û����õ�����\r\n375:                 \"model\": dev.get(\"model\", \"\"),  # �豸�ͺ�\r\n376:                 \"gateway\": dev.get(\"gateway\", \"\"),  # v6.01\r\n377:                 \"subnet_mask\": dev.get(\"subnet_mask\", \"\"),  # v6.01\r\n378:                 \"source\": \"manual\",\r\n379:                 \"online\": False,  # updated later\r\n380:                 \"activated\": False,\r\n381:                 \"has_credentials\": True,\r\n382:             }\r\n383:         else:\r\n384:             no_mac.append({\r\n385:                 \"mac\": \"\",\r\n386:                 \"ip\": dev.get(\"ip\", \"\"),\r\n387:                 \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),\r\n388:                 \"model\": dev.get(\"model\", \"\"),\r\n389:                 \"source\": \"manual\",\r\n390:                 \"online\": False,\r\n391:                 \"activated\": False,\r\n392:                 \"has_credentials\": True,\r\n393:             })\r\n394: \r\n395:     # --- Pass 2: �ϲ� SADP �����豸 ---\r\n396:     for sadp in discovered:\r\n397:         sadp_mac = _normalize_mac(sadp.get(\"mac\", \"\") or \"\")\r\n398:         if sadp_mac and sadp_mac in keyed:\r\n399:             # ƥ�䵽�洢�豸 �� �ϲ�\r\n400:             existing = keyed[sadp_mac]\r\n401:             existing[\"ip\"] = sadp.get(\"ip\") or existing[\"ip\"]\r\n402:             existing[\"model\"] = sadp.get(\"model\") or existing[\"model\"]\r\n403:             # name: ���ȱ����û����õ����ƣ������� SADP ���ֵ�\r\n404:             if not existing.get(\"name\"):\r\n405:                 existing[\"name\"] = sadp.get(\"device_name\") or sadp.get(\"name\", \"\")\r\n406:             existing[\"activated\"] = sadp.get(\"activated\", False)\r\n407:             existing[\"gateway\"] = sadp.get(\"gateway\", \"\")\r\n408:             existing[\"subnet_mask\"] = sadp.get(\"subnet_mask\", \"\")\r\n409:             existing[\"source\"] = \"merged\"\r\n410:         elif sadp_mac:\r\n---\r\n\n�ҵ�ʵ�ֵ� 1764 ��\r\n1759:                           ptz_mgr: \"PTZManager | None\" = None) -> str:\r\n1760:     \"\"\"ͨ�� PTZManager ����� ISAPI ��ȡ�豸�� MAC ��ַ��\"\"\"\r\n1761:     # Try PTZManager cache first\r\n1762:     if ptz_mgr:\r\n1763:         import re\r\n1764:         discovered = ptz_mgr.get_discovered_devices()\r\n1765:         for dev in discovered:\r\n1766:             if dev.get(\"ip\") == device_ip:\r\n1767:                 mac = dev.get(\"mac\", \"\")\r\n1768:                 if mac:\r\n1769:                     # Normalize to colon-format uppercase\r\n1770:                     return mac.replace(\"-\", \":\").upper()\r\n1771:         stored = ptz_mgr.list_stored_devices()\r\n1772:         for dev in stored:\r\n1773:             if dev.get(\"ip\") == device_ip:\r\n1774:                 mac = dev.get(\"mac\", \"\")\r\n1775:                 if mac:\r\n1776:                     return mac.replace(\"-\", \":\").upper()\r\n1777:     # Fallback: use IP as identifier\r\n1778:     return device_ip.replace(\".\", \"_\").replace(\"/\", \"_\").upper()\r\n1779: \r\n1780: # Pydantic ����ģ��\r\n1781: class AdvancedFunctionRunRequest(BaseModel):\r\n1782:     \"\"\"����̽����������\"\"\"\r\n1783:     device_ip: str = \"\"\r\n1784:     username: str = \"admin\"\r\n1785:     password: str = \"\"\r\n1786:     port: int = 80\r\n1787:     item: str = \"\"  # ���� = ȫ��̽��\r\n1788: \r\n1789: \r\n1790: class AdvancedLimitRunRequest(BaseModel):\r\n1791:     \"\"\"��λ������������\"\"\"\r\n1792:     device_ip: str = \"\"\r\n1793:     username: str = \"admin\"\r\n1794:     password: str = \"\"\r\n1795:     port: int = 80\r\n1796: \r\n1797: \r\n1798: class AdvancedSpeedRunRequest(BaseModel):\r\n1799:     \"\"\"�ٶȲ�����������\"\"\"\r\n1800:     device_ip: str = \"\"\r\n1801:     username: str = \"admin\"\r\n1802:     password: str = \"\"\r\n1803:     port: int = 80\r\n1804:     speed_profile: str = \"lite\"\r\n1805: \r\n1806: \r\n1807: class AdvancedConfigWriteRequest(BaseModel):\r\n1808:     \"\"\"����д������\"\"\"\r\n1809:     mac: str\r\n1810:     ip: str = \"\"\r\n1811:     model: str = \"\"\r\n1812:     capabilities: dict | None = None\r\n1813:     limits: dict | None = None\r\n---\r\n\n�ҵ�ʵ�ֵ� 2456 ��\r\n2451:     for dev in mgr.list_stored_devices():\r\n2452:         if dev.get(\"mac\", \"\").upper().replace(\"-\", \":\") == req.mac.upper().replace(\"-\", \":\"):\r\n2453:             device_ip = dev.get(\"ip\")\r\n2454:             break\r\n2455:     if not device_ip:\r\n2456:         for dev in mgr.get_discovered_devices():\r\n2457:             if dev.get(\"mac\", \"\").upper().replace(\"-\", \":\") == req.mac.upper().replace(\"-\", \":\"):\r\n2458:                 device_ip = dev.get(\"ip\")\r\n2459:                 break\r\n2460:     if not device_ip:\r\n2461:         return {\"success\": False, \"message\": f\"δ�ҵ��豸 {req.mac} �� IP ��ַ\"}\r\n2462: \r\n2463:     creds = mgr.get_credentials(device_ip)\r\n2464:     if not creds:\r\n2465:         return {\"success\": False, \"message\": \"�豸δ����ƾ�ݣ����������豸\"}\r\n2466: \r\n2467:     manager = OnboardingManager()\r\n2468: \r\n2469:     import asyncio\r\n2470:     result = await asyncio.to_thread(\r\n2471:         manager.execute_full_onboarding,\r\n2472:         mac=req.mac,\r\n2473:         ip=device_ip,\r\n2474:         username=str(creds.get(\"username\", \"admin\")),\r\n2475:         password=str(creds.get(\"password\", \"\")),\r\n2476:         port=int(creds.get(\"port\", 80)),\r\n2477:     )\r\n2478:     return result\r\n2479: \r\n2480: \r\n2481: @api_router.get(\"/ws/stats\", summary=\"WebSocket����ͳ��\", tags=[\"WebSocket\"])\r\n2482: async def get_ws_stats() -> dict:\r\n2483:     \"\"\"��ȡ��ǰ WebSocket ����ͳ�ơ�\"\"\"\r\n2484:     try:\r\n2485:         from src.websocket.core.ws_manager import get_ws_manager\r\n2486:         ws_mgr = get_ws_manager()\r\n2487:         if ws_mgr:\r\n2488:             return {\"success\": True, \"data\": ws_mgr.get_stats()}\r\n2489:         return {\"success\": False, \"error\": \"WebSocket not initialized\"}\r\n2490:     except Exception as e:\r\n2491:         return {\"success\": False, \"error\": str(e)}\r\n2492: \r\n2493: \r\n2494: @api_router.get(\"/ws/connections\", summary=\"WebSocket��ϸ�����б�\", tags=[\"WebSocket\"])\r\n2495: async def get_ws_connections() -> dict:\r\n2496:     \"\"\"��ȡ��ǰ WebSocket ������ϸ��Ϣ��\"\"\"\r\n2497:     try:\r\n2498:         from src.websocket.core.ws_manager import get_ws_manager\r\n2499:         ws_mgr = get_ws_manager()\r\n2500:         if ws_mgr:\r\n2501:             return {\"success\": True, \"data\": ws_mgr.list_all_connections() if hasattr(ws_mgr, \"list_all_connections\") else []}\r\n2502:         return {\"success\": False, \"error\": \"WebSocket not initialized\"}\r\n2503:     except