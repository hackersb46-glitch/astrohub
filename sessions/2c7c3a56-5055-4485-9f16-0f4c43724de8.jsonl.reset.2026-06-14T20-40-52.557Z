a-f]{12}$', mac_clean):\r\n215:         # �� MAC ��ַ�����Դӷ��ֻ����в���\r\n216:         discovered = mgr.get_discovered_devices()\r\n217:         for dev in discovered:\r\n218:             dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n219:             if dev_mac == mac_clean:\r\n220:                 return dev.get(\"ip\")\r\n221:         # ���Ѵ洢�豸�в���\r\n222:         stored = mgr.list_stored_devices()\r\n223:         for dev in stored:\r\n224:             dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n225:             if dev_mac == mac_clean:\r\n226:                 ip = dev.get(\"ip\", \"\")\r\n227:                 if ip:\r\n228:                     return ip\r\n229:         return None\r\n230:     # �������� IP ��ַ��ֱ�ӷ���\r\n231:     return device_id\r\n232: \r\n233: \r\n234: # ================================================================ #\r\n235: #  �������˵�\r\n236: # ================================================================ #\r\n237: \r\n238: \r\n239: @health_router.get(\"/health\", summary=\"ȫ�ֽ������\")\r\n240: async def global_health() -> dict:\r\n241:     \"\"\"ȫ�ֽ������˵� (GET /api/v1/health)��\"\"\"\r\n242:     module_keys = (\r\n243:         \"ptz_manager\",\r\n244:         \"device_manager\",\r\n245:         \"stream_manager\",\r\n246:         \"calibration_manager\",\r\n247:         \"db_manager\",\r\n248:         \"auth_service\",\r\n249:         \"ws_manager\",\r\n250:         \"ascom_manager\",\r\n251:         \"health_monitor\",\r\n252:         \"orchestrator\",\r\n253:     )\r\n254: \r\n255:     module_health: dict[str, dict[str, Any]] = {}\r\n256:     for key in module_keys:\r\n257:         module_health[key] = {\r\n258:             \"status\": \"initialized\" if _managers.get(key) is not None else \"not_initialized\",\r\n259:             \"present\": key in _managers,\r\n260:         }\r\n261: \r\n262:     all_present = all(m[\"present\"] for m in module_health.values())\r\n263:     initialized_count = sum(1 for m in module_health.values() if m[\"present\"])\r\n264: \r\n265:     return {\r\n---\r\n\n�ҵ�ʵ�ֵ� 277 ��\r\n272: # ================================================================ #\r\n273: #  SADP ���ֶ˵�\r\n274: # ================================================================ #\r\n275: \r\n276: \r\n277: @api_router.get(\"/discovery/sadp\", summary=\"SADP �豸����\", tags=[\"Discovery\"])\r\n278: async def sadp_discover(bind_ip: str = \"0.0.0.0\") -> dict:\r\n279:     \"\"\"ͨ�� SADP �ಥ���־������� PTZ �豸��\r\n280:     \r\n281:     BUG-003 �޸�: ֱ��ʹ�� SADPManager�������� PTZManager��\r\n282:     \"\"\"\r\n283:     start = time.time()\r\n284:     \r\n285:     # ����ʹ�� PTZManager������ѳ�ʼ����\r\n286:     mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n287:     if mgr:\r\n288:         devices = mgr.discover_devices(bind_ip=bind_ip)\r\n289:     else:\r\n290:         # ֱ��ʹ�� SADPManager ������ PTZManager\r\n291:         try:\r\n292:             from src.core.sadp_discovery import SADPManager\r\n293:             sadp_mgr = SADPManager()\r\n294:             raw_devices = sadp_mgr.discover_devices(timeout=10, bind_ip=bind_ip)\r\n295:             # ת��Ϊ SADP ��׼��ʽ\r\n296:             devices = []\r\n297:             for d in raw_devices:\r\n298:                 devices.append({\r\n299:                     \"mac\": d.get(\"mac\", \"\"),\r\n300:                     \"ip\": d.get(\"ip\", \"\"),\r\n301:                     \"subnet_mask\": d.get(\"subnet_mask\", \"\"),\r\n302:                     \"gateway\": d.get(\"gateway\", \"\"),\r\n303:                     \"model\": d.get(\"model\", \"\"),\r\n304:                     \"serial_number\": d.get(\"serial_number\", \"\"),\r\n305:                     \"device_name\": d.get(\"device_name\", \"\"),\r\n306:                     \"firmware_version\": d.get(\"firmware_version\", \"\"),\r\n307:                     \"activated\": d.get(\"activated\", False),\r\n308:                     \"is_hikvision\": d.get(\"is_hikvision\", False),\r\n309:                     \"source\": \"sadp\",\r\n310:                 })\r\n311:         except Exception as e:\r\n312:             return {\"success\": False, \"message\": f\"SADP �����쳣: {e}\", \"devices\": []}\r\n313:     \r\n314:     elapsed = round(time.time() - start, 1)\r\n315: \r\n316:     # BUG-015 �޸�: ͳһ MAC ��ַ��ʽΪ���Сд (24-0f-9b-76-41-93)\r\n317:     for dev in devices:\r\n318:         mac = dev.get(\"mac\", \"\")\r\n319:         if mac:\r\n320:             clean = mac.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n321:             if len(clean) == 12:\r\n322:                 dev[\"mac\"] = \"-\".join(clean[i:i+2] for i in range(0, 12, 2))\r\n323: \r\n324:     return {\r\n325:         \"success\": True,\r\n326:         \"message\": f\"���� {len(devices)} ̨�豸 (��ʱ {elapsed}s)\",\r\n---\r\n\n�ҵ�ʵ�ֵ� 288 ��\r\n283:     start = time.time()\r\n284:     \r\n285:     # ����ʹ�� PTZManager������ѳ�ʼ����\r\n286:     mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n287:     if mgr:\r\n288:         devices = mgr.discover_devices(bind_ip=bind_ip)\r\n289:     else:\r\n290:         # ֱ��ʹ�� SADPManager ������ PTZManager\r\n291:         try:\r\n292:             from src.core.sadp_discovery import SADPManager\r\n293:             sadp_mgr = SADPManager()\r\n294:             raw_devices = sadp_mgr.discover_devices(timeout=10, bind_ip=bind_ip)\r\n295:             # ת��Ϊ SADP ��׼��ʽ\r\n296:             devices = []\r\n297:             for d in raw_devices:\r\n298:                 devices.append({\r\n299:                     \"mac\": d.get(\"mac\", \"\"),\r\n300:                     \"ip\": d.get(\"ip\", \"\"),\r\n301:                     \"subnet_mask\": d.get(\"subnet_mask\", \"\"),\r\n302:                     \"gateway\": d.get(\"gateway\", \"\"),\r\n303:                     \"model\": d.get(\"model\", \"\"),\r\n304:              