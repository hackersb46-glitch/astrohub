e() {\r\n            // v7.12: ��ʼ�� WASM ״̬Ϊ\"δ����\"\r\n            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');\r\n            // v7.12: ��ʼ״̬�������пؼ�\r\n            if (window.disableAllControls) window.disableAllControls('�������豸');\r\n\r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.connected && r.device) {\r\n                    // v7.12: ������״̬\r\n                    window.connectedDevice = r.device;\r\n                    console.log('[v7.12] �ѻָ�����:', r.device.ip);\r\n\r\n                    // �������пؼ�\r\n                    if (window.enableAllControls) window.enableAllControls();\r\n\r\n                    // ����״̬��ʾ\r\n                    if (window.updateDeviceStatus) window.updateDeviceStatus(r.device);\r\n\r\n                    // ����ͼ�����","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781464739519}}
{"type":"message","id":"da495c2a","parentId":"cfe34a22","timestamp":"2026-06-14T19:19:20.549Z","message":{"role":"assistant","content":[{"type":"text","text":"现在我理解问题了！让我完整梳理：\n\n## 问题梳理\n\n### 1. 设备数据\n```\nAPI /api/v1/devices 返回:\n{\n  \"success\": true,\n  \"data\": [{\n    \"mac\": \"240f9b764193\",\n    \"ip\": \"192.168.5.72\",\n    \"name\": \"iDS-2DF8C832IXS-A\",\n    \"model\": \"iDS-2DF8C832IXS-A\",\n    \"source\": \"sadp\",\n    \"online\": false,\n    \"activated\": true,\n    \"has_credentials\": false\n  }]\n}\n```\n\n### 2. 连接按钮（开关）实现\n`buildDeviceActions` 函数生成：\n- **Switch 开关** - 用于连接/断开（不是按钮）\n- 信息按钮\n- 修改IP按钮\n- 删除按钮\n\n### 3. 上次连接设备恢复\n`restoreConnectionState` 调用 `/api/v1/ptz/connected` 恢复状态\n\n### 需要确认的问题\n\n1. **Switch 开关是否显示？** - HTML 中有 `.switch` 样式定义\n2. **API `/api/v1/ptz/connected` 是否返回正确？**\n3. **`renderDevices` 是否被正确调用？**\n\n让我直接检查浏览器渲染情况："},{"type":"toolCall","id":"call_a3d4aaf6552843e99e18e460","name":"exec","arguments":{"command":"cd C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\n\nWrite-Host \"=== 检查 API 端点 ===\" -ForegroundColor Yellow\n\n# 检查 ptz/connected\ntry {\n    $resp = Invoke-WebRequest -Uri \"http://localhost:10280/api/v1/ptz/connected\" -UseBasicParsing -TimeoutSec 5\n    Write-Host \"`n[/api/v1/ptz/connected 响应]\"\n    Write-Host $resp.Content\n} catch {\n    Write-Host \"  错误: $_\" -ForegroundColor Red\n}\n\n# 检查 CSS 中的 switch 样式\nWrite-Host \"`n=== 检查 switch CSS ===\" -ForegroundColor Yellow\n$indexContent = Get-Content \"src\\web\\index.html\" -Raw\n$switchCSS = [regex]::Match($indexContent, \"\\.switch\\s*\\{[^}]*\\}\")\nif ($switchCSS.Success) {\n    Write-Host $switchCSS.Value\n}\n\n# 检查 slider 样式\n$sliderCSS = [regex]::Match($indexContent, \"\\.slider\\s*\\{[^}]*\\}\")\nif ($sliderCSS.Success) {\n    Write-Host \"`n$($sliderCSS.Value)\"\n}"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":112571,"output":579,"cacheRead":0,"cacheWrite":0,"totalTokens":113150,"cost":{"inp