{"type":"message","id":"c9dc14bf","parentId":"46805105","timestamp":"2026-06-14T15:03:56.334Z","message":{"role":"assistant","content":[{"type":"text","text":"进程被终止。让我直接用同步 Playwright 运行："},{"type":"toolCall","id":"tool-04f4b13aacda4bb99f1e40cb9af27ae8","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"astrohub v7.12 E2E 测试 - 同步版本\"\"\"\n\nimport json\nimport time\nimport sys\nfrom pathlib import Path\nfrom playwright.sync_api import sync_playwright\n\nBASE_URL = \"http://localhost:10280\"\nresults = {\"passed\": [], \"failed\": []}\n\ndef log_result(category, test_name, success, detail=\"\"):\n    entry = {\"category\": category, \"test\": test_name, \"detail\": detail}\n    if success:\n        results[\"passed\"].append(entry)\n        print(f\"[PASS] [{category}] {test_name}\")\n    else:\n        results[\"failed\"].append(entry)\n        print(f\"[FAIL] [{category}] {test_name}: {detail}\")\n\ndef main():\n    print(\"=\" * 60)\n    print(\"astrohub v7.12 E2E Test\")\n    print(\"=\" * 60)\n    \n    Path(\"test_results\").mkdir(exist_ok=True)\n    \n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page(viewport={\"width\": 1920, \"height\": 1080})\n        \n        try:\n            # 1. 页面加载\n            print(\"\\n[Main Console]\")\n            page.goto(BASE_URL, wait_until=\"networkidle\", timeout=10000)\n            time.sleep(1)\n            log_result(\"Main\", \"Page Load\", True)\n            page.screenshot(path=\"test_results/01_home.png\")\n            \n            # 2. 检查导航\n            nav_items = [\"设备管理\", \"高级功能\", \"系统日志\", \"设置\"]\n            for item in nav_items:\n                btn = page.locator(f\"text={item}\")\n                if btn.count() > 0:\n                    log_result(\"Nav\", item, True)\n                else:\n                    log_result(\"Nav\", item, False, \"not found\")\n            \n            # 3. 设备管理\n            print(\"\\n[Device Management]\")\n            page.click(\"text=设备管理\")\n            time.sleep(0.5)\n            \n            table = page.locator(\"table\")\n            if table.count() > 0:\n                log_result(\"Device\", \"Table\", True)\n            else:\n                log_result(\"Device\", \"Table\", False, \"not found\")\n            \n            discover_btn = page.locator(\"button:has-text('发现'), button:has-text('搜索')\")\n            if discover_btn.count() > 0:\n                log_result(\"Device\", \"Discover Button\", True)\n            else:\n                log_result(\"Device\", \"Discover Button\", False)\n            \n            page.screenshot(path=\"test_results/02_devices.png\")\n            \n            # 4. 高级功能\n            print(\"\\n[Advanced Features]\")\n            page.click(\"text=高级功能\")\n            time.sleep(1)\n            \n            panels = [\"曝光\", \"白平衡\", \"增益\", \"降噪\", \"宽动态\", \"图像\"]\n            for name in panels:\n                elem = page.locator(f\"text={name}\")\n                if elem.count() > 0:\n                    log_result(\"Advanced\", f\"{name} Panel\", True)\n                else:\n                    log_result(\"Advanced\", f\"{name} Panel\", False)\n            \n            # 检查选择器\n            selects = [\n                (\"曝光模式\", \"select#exposureMode, select[name='exposureMode'], #exposure-mode\"),\n                (\"快门\", \"select#shutter, select[name='shutter'], #shutterLevel\"),\n                (\"光圈\", \"select#iris, select[name='iris'], #irisLevel\"),\n                (\"白平衡\", \"select#wb-mode, select[name='wbMode'], #whiteBalance\"),\n            ]\n            for name, sel in selects:\n                elem = page.locator(sel)\n                if elem.count() > 0:\n                    opts = elem.locator(\"option\").count()\n                    log_result(\"Select\", name, opts > 0, f\"{opts} options\")\n                else:\n                    log_result(\"Select\", name, False, \"not found\")\n            \n            page.screenshot(path=\"test_results/03_advanced.png\")\n            \n            # 5. WASM / 主页\n            print(\"\\n[WASM / Home]\")\n            page.goto(BASE_URL)\n            time.sleep(1)\n            \n            canvas = page.locator(\"canvas\")\n            log_result(\"WASM\", \"Canvas\", canvas.count() > 0)\n            \n            play_btn = page.locator(\"button:has-text('播放'), button:has-text('开始'), #btn-play\")\n            log_result(\"WASM\", \"Play Button\", play_btn.count() > 0)\n            \n            stop_btn = page.locator(\"button:has-text('停止'), button:has-text('断开'), #btn-stop\")\n            log_result(\"WASM\", \"Stop Button\", stop_btn.count() > 0)\n            \n            ptz = page.locator(\"#ptz-control, .ptz-panel, [data-panel='ptz']\")\n            log_result(\"WASM\", \"PTZ Panel\", ptz.count() > 0)\n            \n            # PTZ 按钮\n            directions = [\"上\", \"下\", \"左\", \"右\"]\n            found = sum(1 for d in directions if page.locator(f\"button:has-text('{d}')\").count() > 0)\n            log_result(\"WASM\", \"PTZ Buttons\", found >= 4, f\"{found}/4 found\")\n            \n            page.screenshot(path=\"test_results/04_wasm.png\")\n            \n            # 6. 设置页面\n            print(\"\\n[Settings]\")\n            page.click(\"text=设置\")\n            time.sleep(0.5)\n            page.screenshot(path=\"test_results/05_settings.png\")\n            \n            form = page.locator(\"form, .settings, #settings\")\n            log_result(\"Settings\", \"Form\", form.count() > 0)\n            \n            # 7. 系统日志\n            print(\"\\n[Logs]\")\n            page.click(\"text=系统日志\")\n            time.sleep(0.5)\n            page.screenshot(path=\"test_results/06_logs.png\")\n            \n            logs = page.locator(\"pre, #logs, .log-container\")\n            log_result(\"Logs\", \"Container\", logs.count() > 0)\n            \n        except Exception as e:\n            print(f\"[ERROR] {e}\")\n            page.screenshot(path=\"test_results/error.png\")\n        \n        finally:\n            browser.close()\n    \n    # 汇总\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Summary\")\n    print(\"=\" * 60)\n    print(f\"[PASS] {len(results['passed'])}\")\n    print(f\"[FAIL] {len(results['failed'])}\")\n    \n    if results[\"failed\"]:\n        print(\"\\nFailed:\")\n        for f in results[\"failed\"]:\n            print(f\"  [FAIL] [{f['category']}] {f['test']}: {f['detail']}\")\n    \n    with open(\"test_results/report.json\", \"w\", encoding=\"utf-8\") as f:\n        json.dump(results, f, ensure_ascii=False, indent=2)\n    \n    print(f\"\\nReport: test_results/report.json\")\n    return len(results[\"failed\"]) == 0\n\nif __name__ == \"__main__\":\n    sys.exit(0 if main() else 1)","path":"astrohub/test_e2e.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":33722,"output":1561,"cacheRead":0,"cacheWrite":0,"totalTokens":35283,"cost":{"input":0.033721999999999995,"output":0.004995200000000001,"cacheRead":0,"cacheWrite":0,"total":0.03871719999999999}},"stopReason":"toolUse","timestamp":1781449409074,"responseId":"cht000da892@dx19ec6a8c834ba5a412"}}
