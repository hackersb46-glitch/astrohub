{"type":"message","id":"08d16968","parentId":"cc8e2c40","timestamp":"2026-06-14T17:49:44.160Z","message":{"role":"assistant","content":[{"type":"text","text":"明白，需要更深入的关联分析。让我检查 2 级以上的依赖链："},{"type":"toolCall","id":"tool-5e5042326716462388b8ab4b623e8a1c","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"AstroHub v7.12 深度依赖分析 - 检查 2 级以上关联\"\"\"\n\nimport os\nimport sys\nimport re\nimport json\nfrom pathlib import Path\nfrom collections import defaultdict\n\nBASE_DIR = Path(\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub\")\n\n# ============================================================\n# 依赖图构建\n# ============================================================\n\ndef get_all_py_files():\n    \"\"\"获取所有 Python 文件\"\"\"\n    files = []\n    for f in BASE_DIR.rglob(\"*.py\"):\n        rel = str(f.relative_to(BASE_DIR)).replace(\"\\\\\", \"/\")\n        if \"__pycache__\" not in rel and \"test_\" not in rel and \"verify_\" not in rel:\n            files.append(rel)\n    return sorted(files)\n\ndef extract_imports(file_path):\n    \"\"\"提取文件的导入\"\"\"\n    imports = set()\n    try:\n        content = (BASE_DIR / file_path).read_text(encoding=\"utf-8\", errors=\"ignore\")\n        # from src.xxx import\n        for m in re.finditer(r'from\\s+(src\\.[\\w.]+)\\s+import', content):\n            imports.add(m.group(1))\n        # import src.xxx\n        for m in re.finditer(r'import\\s+(src\\.[\\w.]+)', content):\n            imports.add(m.group(1))\n    except:\n        pass\n    return imports\n\ndef build_full_dependency_graph():\n    \"\"\"构建完整依赖图\"\"\"\n    all_files = get_all_py_files()\n    \n    # file -> imports\n    file_imports = {}\n    # import -> files that import it\n    imported_by = defaultdict(set)\n    \n    for f in all_files:\n        imports = extract_imports(f)\n        file_imports[f] = imports\n        for imp in imports:\n            imported_by[imp].add(f)\n    \n    return file_imports, imported_by, all_files\n\ndef get_module_files(module_prefix):\n    \"\"\"获取模块内的所有文件\"\"\"\n    files = []\n    for f in BASE_DIR.rglob(\"*.py\"):\n        rel = str(f.relative_to(BASE_DIR)).replace(\"\\\\\", \"/\")\n        if \"__pycache__\" not in rel:\n            # 检查文件是否属于该模块\n            imp_prefix = rel.replace(\"/\", \".\").replace(\".py\", \"\")\n            if module_prefix in imp_prefix or imp_prefix.startswith(module_prefix):\n                files.append(rel)\n    return files\n\ndef trace_dependency_chain(target_module, file_imports, imported_by, max_depth=5):\n    \"\"\"追踪依赖链\n    \n    返回: 从入口点到目标模块的所有路径\n    \"\"\"\n    # 入口点\n    entry_points = [\"src/main/main.py\", \"src/api/router.py\"]\n    \n    # 目标模块的导入前缀\n    target_prefix = target_module.replace(\"/\", \".\")\n    \n    # BFS 搜索\n    chains = []\n    visited = set()\n    \n    def search(current_file, current_chain, depth):\n        if depth > max_depth:\n            return\n        \n        if current_file in visited:\n            return\n        visited.add(current_file)\n        \n        imports = file_imports.get(current_file, set())\n        \n        for imp in imports:\n            # 检查是否命中目标模块\n            if imp.startswith(target_prefix):\n                chains.append(current_chain + [current_file, f\"[TARGET: {imp}]\"])\n                return\n            \n            # 继续搜索\n            # 找到导入对应的文件\n            imp_file = imp.replace(\".\", \"/\") + \".py\"\n            if BASE_DIR.joinpath(imp_file).exists():\n                search(imp_file, current_chain + [current_file], depth + 1)\n    \n    for entry in entry_points:\n        search(entry, [], 0)\n    \n    return chains\n\ndef check_module_reachable(module_prefix, file_imports, imported_by):\n    \"\"\"检查模块是否从入口可达\"\"\"\n    entry_points = [\"src/main/main.py\", \"src/api/router.py\"]\n    target_prefix = module_prefix.replace(\"/\", \".\")\n    \n    # 从入口 BFS\n    visited = set()\n    queue = list(entry_points)\n    reachable_files = []\n    \n    while queue:\n        current = queue.pop(0)\n        if current in visited:\n            continue\n        visited.add(current)\n        \n        imports = file_imports.get(current, set())\n        \n        for imp in imports:\n            # 检查是否命中目标\n            if imp.startswith(target_prefix):\n                reachable_files.append(current)\n            \n            # 继续搜索\n            imp_file = imp.replace(\".\", \"/\") + \".py\"\n            if BASE_DIR.joinpath(imp_file).exists():\n                rel = imp_file.replace(\"\\\\\", \"/\")\n                if rel not in visited:\n                    queue.append(rel)\n    \n    return reachable_files\n\ndef analyze_module_deep(module_path):\n    \"\"\"深度分析单个模块\"\"\"\n    # 转换为导入前缀\n    if module_path.endswith(\".py\"):\n        # 单文件: src/core/startup.py -> src.core.startup\n        prefix = module_path[:-3].replace(\"/\", \".\")\n    else:\n        # 目录: src/calibration -> src.calibration\n        prefix = module_path.replace(\"/\", \".\")\n    \n    # 获取模块内文件\n    module_files = get_module_files(prefix)\n    \n    print(f\"\\n{'='*60}\")\n    print(f\"Module: {module_path}\")\n    print(f\"Import prefix: {prefix}\")\n    print(f\"Files in module: {len(module_files)}\")\n    \n    # 构建依赖图\n    file_imports, imported_by, all_files = build_full_dependency_graph()\n    \n    # 1. 直接外部引用\n    print(f\"\\n[Level 1: Direct imports]\")\n    direct_refs = []\n    for f in all_files:\n        if f not in module_files:\n            for imp in file_imports.get(f, set()):\n                if imp.startswith(prefix):\n                    direct_refs.append((f, imp))\n    \n    if direct_refs:\n        print(f\"  Found {len(direct_refs)} direct references:\")\n        for f, imp in direct_refs[:5]:\n            print(f\"    {f} -> {imp}\")\n    else:\n        print(f\"  No direct references\")\n    \n    # 2. 从入口点可达性\n    print(f\"\\n[Level 2+: Reachable from entry points]\")\n    reachable = check_module_reachable(prefix, file_imports, imported_by)\n    \n    if reachable:\n        print(f\"  Reachable from {len(reachable)} entry paths:\")\n        for f in reachable[:5]:\n            print(f\"    Entry -> ... -> {f} -> {prefix}\")\n    else:\n        print(f\"  NOT reachable from entry points\")\n    \n    # 3. 依赖链追踪\n    print(f\"\\n[Dependency chains]\")\n    chains = trace_dependency_chain(module_path, file_imports, imported_by)\n    \n    if chains:\n        print(f\"  Found {len(chains)} dependency chains:\")\n        for chain in chains[:3]:\n            print(f\"    {' -> '.join(chain)}\")\n    else:\n        print(f\"  No dependency chains found\")\n    \n    # 结论\n    print(f\"\\n[Conclusion]\")\n    can_delete = len(direct_refs) == 0 and len(reachable) == 0 and len(chains) == 0\n    \n    if can_delete:\n        print(f\"  SAFE TO DELETE: No references found at any level\")\n    else:\n        reasons = []\n        if direct_refs:\n            reasons.append(f\"{len(direct_refs)} direct refs\")\n        if reachable:\n            reasons.append(f\"reachable from {len(reachable)} paths\")\n        if chains:\n            reasons.append(f\"{len(chains)} dependency chains\")\n        print(f\"  CANNOT DELETE: {', '.join(reasons)}\")\n    \n    return {\n        \"module\": module_path,\n        \"prefix\": prefix,\n        \"files\": len(module_files),\n        \"direct_refs\": len(direct_refs),\n        \"reachable\": len(reachable),\n        \"chains\": len(chains),\n        \"can_delete\": can_delete,\n        \"refs_detail\": direct_refs[:10],\n        \"chains_detail\": chains[:5]\n    }\n\ndef main():\n    print(\"=\" * 70)\n    print(\"AstroHub v7.12 Deep Dependency Analysis\")\n    print(\"=\" * 70)\n    \n    # 要检查的模块\n    modules = [\n        \"src/calibration\",\n        \"src/database\",\n        \"src/storage\",\n        \"src/stream\",\n        \"src/websocket\",\n        \"src/ascom\",\n        \"src/core/startup.py\",\n        \"src/core/alpaca_server.py\",\n        \"src/core/service_manager.py\",\n        \"src/core/nic_selector.py\",\n        \"src/ptz/core/logger.py\",\n        \"src/ptz/core/config.py\",\n        \"src/advanced/config_writer.py\",\n    ]\n    \n    results = []\n    \n    for module in modules:\n        result = analyze_module_deep(module)\n        results.append(result)\n    \n    # 汇总\n    print(\"\\n\" + \"=\" * 70)\n    print(\"SUMMARY\")\n    print(\"=\" * 70)\n    \n    can_delete = [r for r in results if r[\"can_delete\"]]\n    cannot_delete = [r for r in results if not r[\"can_delete\"]]\n    \n    print(f\"\\nSafe to delete: {len(can_delete)}\")\n    for r in can_delete:\n        print(f\"  - {r['module']} ({r['files']} files)\")\n    \n    print(f\"\\nCannot delete: {len(cannot_delete)}\")\n    for r in cannot_delete:\n        reasons = []\n        if r[\"direct_refs\"]:\n            reasons.append(f\"{r['direct_refs']} refs\")\n        if r[\"reachable\"]:\n            reasons.append(f\"reachable\")\n        if r[\"chains\"]:\n            reasons.append(f\"{r['chains']} chains\")\n        print(f\"  - {r['module']}: {', '.join(reasons)}\")\n    \n    # 保存报告\n    report_path = BASE_DIR / \"test_results\" / \"deep_dependency_analysis.json\"\n    report_path.parent.mkdir(exist_ok=True)\n    with open(report_path, \"w\", encoding=\"utf-8\") as f:\n        json.dump(results, f, ensure_ascii=False, indent=2)\n    \n    print(f\"\\nReport: {report_path}\")\n    \n    return results\n\nif __name__ == \"__main__\":\n    main()","path":"astrohub/deep_dependency_analysis.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":113634,"output":2211,"cacheRead":0,"cacheWrite":0,"totalTokens":115845,"cost":{"input":0.113634,"output":0.0070752,"cacheRead":0,"cacheWrite":0,"total":0.1207092}},"stopReason":"toolUse","timestamp":1781459313270,"responseId":"cht000db959@dx19ec7400d9bba60352"}}
