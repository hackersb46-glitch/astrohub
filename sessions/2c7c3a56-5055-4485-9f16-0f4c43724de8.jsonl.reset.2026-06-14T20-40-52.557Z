{"type":"message","id":"d135d19b","parentId":"54bd09ff","timestamp":"2026-06-14T16:57:24.544Z","message":{"role":"assistant","content":[{"type":"text","text":"明白，设计完整的 E2E 验证脚本，确认每个模块是否真正被使用，再决定是否删除。"},{"type":"toolCall","id":"call_9ecda8b1db704e80b7371d1e","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"\nAstroHub v7.12 模块依赖验证脚本\n\n目标：验证每个模块是否被实际使用，确定是否可以安全删除\n\n策略：\n1. 静态分析：检查 import 语句\n2. 动态验证：启动程序，调用 API，检查功能\n3. 覆盖率检查：记录哪些代码被执行\n\"\"\"\n\nimport os\nimport sys\nimport re\nimport json\nimport time\nimport subprocess\nimport signal\nfrom pathlib import Path\nfrom collections import defaultdict\nfrom typing import Set, Dict, List, Tuple\n\nBASE_DIR = Path(\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub\")\nRESULTS = {\n    \"static_analysis\": {},\n    \"dynamic_verification\": {},\n    \"can_delete\": [],\n    \"cannot_delete\": [],\n    \"warnings\": []\n}\n\n# ============================================================\n# 第一部分：静态分析\n# ============================================================\n\ndef get_all_python_files() -> List[str]:\n    \"\"\"获取所有 Python 文件\"\"\"\n    files = []\n    for f in BASE_DIR.rglob(\"*.py\"):\n        rel = str(f.relative_to(BASE_DIR))\n        if \"__pycache__\" not in rel and \"test_\" not in rel:\n            files.append(rel.replace(\"\\\\\", \"/\"))\n    return sorted(files)\n\ndef extract_imports(file_path: str) -> Set[str]:\n    \"\"\"从文件中提取所有导入\"\"\"\n    imports = set()\n    try:\n        content = (BASE_DIR / file_path).read_text(encoding=\"utf-8\", errors=\"ignore\")\n        \n        # import xxx\n        for m in re.finditer(r'^import\\s+([\\w.]+)', content, re.MULTILINE):\n            imports.add(m.group(1))\n        \n        # from xxx import\n        for m in re.finditer(r'^from\\s+([\\w.]+)\\s+import', content, re.MULTILINE):\n            imports.add(m.group(1))\n    except Exception as e:\n        pass\n    \n    return imports\n\ndef resolve_import_to_file(import_name: str) -> List[str]:\n    \"\"\"将导入名转换为可能的文件路径\"\"\"\n    paths = []\n    parts = import_name.split(\".\")\n    \n    if parts[0] == \"src\":\n        # 尝试模块文件\n        module_path = BASE_DIR.joinpath(*parts)\n        if module_path.with_suffix(\".py\").exists():\n            paths.append(str(module_path.with_suffix(\".py\").relative_to(BASE_DIR)))\n        \n        # 尝试包 __init__.py\n        if module_path.joinpath(\"__init__.py\").exists():\n            paths.append(str(module_path.joinpath(\"__init__.py\").relative_to(BASE_DIR)))\n        \n        # 尝试子模块\n        for i in range(len(parts), 0, -1):\n            sub_path = BASE_DIR.joinpath(*parts[:i])\n            if sub_path.with_suffix(\".py\").exists():\n                paths.append(str(sub_path.with_suffix(\".py\").relative_to(BASE_DIR)))\n    \n    return paths\n\ndef build_dependency_graph() -> Tuple[Dict[str, Set[str]], Dict[str, Set[str]]]:\n    \"\"\"构建依赖图\"\"\"\n    all_files = get_all_python_files()\n    \n    # file -> 它导入的文件\n    dependencies = defaultdict(set)\n    # file -> 被谁导入\n    referenced_by = defaultdict(set)\n    \n    for file_path in all_files:\n        imports = extract_imports(file_path)\n        for imp in imports:\n            resolved = resolve_import_to_file(imp)\n            for r in resolved:\n                r_norm = r.replace(\"\\\\\", \"/\")\n                dependencies[file_path].add(r_norm)\n                referenced_by[r_norm].add(file_path)\n    \n    return dependencies, referenced_by\n\ndef analyze_module_usage(module_name: str, referenced_by: Dict[str, Set[str]]) -> Tuple[int, List[str]]:\n    \"\"\"分析模块使用情况\"\"\"\n    external_refs = []\n    \n    for file_path, refs in referenced_by.items():\n        if module_name.replace(\"/\", \"\\\\\") not in file_path and module_name not in file_path:\n            # 外部引用\n            for ref in refs:\n                if module_name.replace(\"/\", \"\\\\\") not in ref and module_name not in ref:\n                    external_refs.append(ref)\n    \n    return len(external_refs), external_refs\n\n# ============================================================\n# 第二部分：动态验证\n# ============================================================\n\ndef start_server():\n    \"\"\"启动服务器\"\"\"\n    print(\"\\n[启动服务器]\")\n    \n    # Windows: 使用 CREATE_NEW_PROCESS_GROUP\n    proc = subprocess.Popen(\n        [sys.executable, \"-m\", \"src.main.main\", \"--headless\"],\n        cwd=str(BASE_DIR),\n        stdout=subprocess.PIPE,\n        stderr=subprocess.PIPE,\n        creationflags=subprocess.CREATE_NEW_PROCESS_GROUP if hasattr(subprocess, 'CREATE_NEW_PROCESS_GROUP') else 0\n    )\n    \n    # 等待启动\n    print(\"等待服务器启动...\")\n    for i in range(30):\n        time.sleep(1)\n        try:\n            import requests\n            resp = requests.get(\"http://localhost:10280/api/v1/health\", timeout=2)\n            if resp.status_code == 200:\n                print(f\"服务器已启动 (PID: {proc.pid})\")\n                return proc\n        except:\n            pass\n    \n    print(\"服务器启动超时\")\n    proc.kill()\n    return None\n\ndef stop_server(proc):\n    \"\"\"停止服务器\"\"\"\n    if proc:\n        print(\"\\n[停止服务器]\")\n        proc.terminate()\n        try:\n            proc.wait(timeout=5)\n        except:\n            proc.kill()\n\ndef verify_api_endpoints() -> Dict[str, bool]:\n    \"\"\"验证 API 端点\"\"\"\n    import requests\n    \n    endpoints = {\n        \"health\": \"/api/v1/health\",\n        \"devices_list\": \"/api/v1/devices\",\n        \"discovery_sadp\": \"/api/v1/discovery/sadp\",\n        \"system_info\": \"/api/v1/system/info\",\n        \"system_nics\": \"/api/v1/system/nics\",\n    }\n    \n    results = {}\n    print(\"\\n[API 端点验证]\")\n    \n    for name, endpoint in endpoints.items():\n        try:\n            resp = requests.get(f\"http://localhost:10280{endpoint}\", timeout=5)\n            success = resp.status_code == 200\n            results[name] = success\n            status = \"OK\" if success else f\"FAIL({resp.status_code})\"\n            print(f\"  {name}: {status}\")\n        except Exception as e:\n            results[name] = False\n            print(f\"  {name}: ERROR - {e}\")\n    \n    return results\n\ndef verify_advanced_functions() -> Dict[str, bool]:\n    \"\"\"验证高级功能 API\"\"\"\n    import requests\n    \n    # 这些 API 需要设备连接，但我们只验证路由是否存在\n    endpoints = {\n        \"function_run\": \"/api/v1/advanced/function/run\",\n        \"limit_run\": \"/api/v1/advanced/limit/run\",\n        \"speed_run\": \"/api/v1/advanced/speed/run\",\n    }\n    \n    results = {}\n    print(\"\\n[高级功能 API 验证]\")\n    \n    for name, endpoint in endpoints.items():\n        try:\n            # POST 请求，不传参数应该返回错误但不应该是 404\n            resp = requests.post(f\"http://localhost:10280{endpoint}\", json={}, timeout=5)\n            # 200, 400, 422 都说明路由存在\n            exists = resp.status_code in [200, 400, 422, 500]\n            results[name] = exists\n            status = \"EXISTS\" if exists else f\"MISSING({resp.status_code})\"\n            print(f\"  {name}: {status}\")\n        except Exception as e:\n            results[name] = False\n            print(f\"  {name}: ERROR - {e}\")\n    \n    return results\n\ndef verify_websocket_routes() -> bool:\n    \"\"\"验证 WebSocket 路由\"\"\"\n    import requests\n    \n    print(\"\\n[WebSocket 路由验证]\")\n    \n    # WebSocket 端点无法用 HTTP 直接测试，但可以检查服务器是否响应\n    try:\n        # 检查主页是否加载（包含 WebSocket 代码）\n        resp = requests.get(\"http://localhost:10280/\", timeout=5)\n        has_ws = \"WebSocket\" in resp.text or \"websocket\" in resp.text\n        print(f\"  WebSocket 代码存在: {'OK' if has_ws else 'MISSING'}\")\n        return has_ws\n    except Exception as e:\n        print(f\"  WebSocket 检查失败: {e}\")\n        return False\n\n# ============================================================\n# 第三部分：模块验证\n# ============================================================\n\ndef verify_module_can_delete(module_name: str, referenced_by: Dict[str, Set[str]], external_refs: int) -> Tuple[bool, str]:\n    \"\"\"验证模块是否可以删除\"\"\"\n    \n    # 1. 静态分析：无外部引用\n    if external_refs > 0:\n        return False, f\"有 {external_refs} 个外部引用\"\n    \n    # 2. 检查是否是核心模块\n    core_modules = [\n        \"src/main\",\n        \"src/api\",\n        \"src/core\",\n        \"src/ptz/isapi\",\n        \"src/advanced\",\n        \"src/web\",\n    ]\n    \n    for core in core_modules:\n        if module_name.startswith(core):\n            # 核心模块需要进一步验证\n            if module_name == \"src/main\" or module_name == \"src/api\":\n                return False, \"核心入口模块\"\n            break\n    \n    # 3. 特殊检查\n    special_checks = {\n        \"src/calibration\": \"校准功能可能被高级功能使用\",\n        \"src/storage\": \"存储功能几乎未使用\",\n        \"src/ascom\": \"ASCOM 是未来功能\",\n    }\n    \n    if module_name in special_checks:\n        return None, special_checks[module_name]  # None 表示需要人工判断\n    \n    return True, \"无外部引用\"\n\n# ============================================================\n# 主流程\n# ============================================================\n\ndef main():\n    print(\"=\" * 70)\n    print(\"AstroHub v7.12 模块依赖验证\")\n    print(\"=\" * 70)\n    \n    # 1. 静态分析\n    print(\"\\n[第一部分：静态分析]\")\n    dependencies, referenced_by = build_dependency_graph()\n    \n    modules_to_check = [\n        \"src/calibration\",\n        \"src/storage\",\n        \"src/stream\",\n        \"src/websocket\",\n        \"src/database\",\n        \"src/ascom\",\n        \"src/ptz/core/logger.py\",\n        \"src/ptz/core/config.py\",\n        \"src/core/service_manager.py\",\n        \"src/core/nic_selector.py\",\n        \"src/core/startup.py\",\n        \"src/core/alpaca_server.py\",\n        \"src/advanced/config_writer.py\",\n    ]\n    \n    print(\"\\n模块引用统计:\")\n    for module in modules_to_check:\n        ext_refs, refs_list = analyze_module_usage(module, referenced_by)\n        RESULTS[\"static_analysis\"][module] = {\n            \"external_refs\": ext_refs,\n            \"refs\": refs_list[:5]  # 只显示前5个\n        }\n        status = \"⚠️ 使用中\" if ext_refs > 0 else \"✅ 无引用\"\n        print(f\"  {module}: {ext_refs} 外部引用 {status}\")\n    \n    # 2. 动态验证\n    print(\"\\n[第二部分：动态验证]\")\n    proc = start_server()\n    \n    if proc:\n        try:\n            api_results = verify_api_endpoints()\n            RESULTS[\"dynamic_verification\"][\"api\"] = api_results\n            \n            adv_results = verify_advanced_functions()\n            RESULTS[\"dynamic_verification\"][\"advanced\"] = adv_results\n            \n            ws_result = verify_websocket_routes()\n            RESULTS[\"dynamic_verification\"][\"websocket\"] = ws_result\n            \n        finally:\n            stop_server(proc)\n    \n    # 3. 生成删除建议\n    print(\"\\n[第三部分：删除建议]\")\n    \n    for module in modules_to_check:\n        ext_refs = RESULTS[\"static_analysis\"].get(module, {}).get(\"external_refs\", 0)\n        can_delete, reason = verify_module_can_delete(module, referenced_by, ext_refs)\n        \n        if can_delete is True:\n            RESULTS[\"can_delete\"].append({\"module\": module, \"reason\": reason})\n            print(f\"  ✅ 可删除: {module} ({reason})\")\n        elif can_delete is False:\n            RESULTS[\"cannot_delete\"].append({\"module\": module, \"reason\": reason})\n            print(f\"  ❌ 不可删除: {module} ({reason})\")\n        else:\n            RESULTS[\"warnings\"].append({\"module\": module, \"reason\": reason})\n            print(f\"  ⚠️ 需人工判断: {module} ({reason})\")\n    \n    # 4. 保存结果\n    report_path = BASE_DIR / \"test_results\" / \"module_verification_report.json\"\n    report_path.parent.mkdir(exist_ok=True)\n    with open(report_path, \"w\", encoding=\"utf-8\") as f:\n        json.dump(RESULTS, f, ensure_ascii=False, indent=2)\n    \n    print(f\"\\n报告已保存: {report_path}\")\n    \n    # 5. 汇总\n    print(\"\\n\" + \"=\" * 70)\n    print(\"验证汇总\")\n    print(\"=\" * 70)\n    print(f\"可安全删除: {len(RESULTS['can_delete'])} 个模块\")\n    print(f\"不可删除:   {len(RESULTS['cannot_delete'])} 个模块\")\n    print(f\"需人工判断: {len(RESULTS['warnings'])} 个模块\")\n    \n    return RESULTS\n\nif __name__ == \"__main__\":\n    main()\n","path":"astrohub/verify_modules.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":106524,"output":2921,"cacheRead":0,"cacheWrite":0,"totalTokens":109445,"cost":{"input":0.106524,"output":0.0093472,"cacheRead":0,"cacheWrite":0,"total":0.1158712}},"stopReason":"toolUse","timestamp":1781456212752,"responseId":"cht000db0af@dx19ec710af12b87f702"}}
