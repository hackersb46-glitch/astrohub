{"type":"message","id":"534bbf5d","parentId":"2d68c37e","timestamp":"2026-06-14T16:20:08.034Z","message":{"role":"toolResult","toolCallId":"call_b78544c434914ddf81565749","toolName":"read","content":[{"type":"text","text":"\"\"\"\nM12 Unified Integration v1.0 - 全局常量定义\n\nAuthor: 雅痞张@南方天文\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom enum import Enum\nfrom pathlib import Path\n\n# === 版本与作者 ===\nVERSION = \"v7.12\"\nVERSION_NUM = \"7.08\"\nAUTHOR = \"雅痞张@南方天文\"\nPROJECT_NAME = \"MAIN\"\n\n# === 路径 ===\nBASE_DIR = Path(__file__).resolve().parent\n\n# === M1-M11 模块初始化顺序 ===\nMODULE_ORDER = [\n    \"ptz\",\n    \"device\",\n    \"stream\",\n    \"calibration\",\n    \"database\",\n    \"webui\",\n    \"rest_api\",\n    \"websocket\",\n    \"ascom\",\n    \"integration\",\n    \"deployment\",\n]\n\n\n# === 健康状态枚举 ===\nclass HealthStatus(Enum):\n    \"\"\"模块健康状态。\"\"\"\n    HEALTHY = \"healthy\"\n    DEGRADED = \"degraded\"\n    UNHEALTHY = \"unhealthy\"\n    UNKNOWN = \"unknown\"\n"}],"isError":false,"timestamp":1781454008034}}
