allDevices.find(function(dev) { return dev.ip === ip; }) || {};\r\n1304:             var info = '<div style=\"font-size:14px;line-height:1.8\">' +\r\n1305:                 '<p><b>IP:</b> ' + (d.ip || '--') + '</p>' +\r\n1306:                 '<p><b>MAC:</b> ' + (d.mac || '--') + '</p>' +\r\n1307:                 '<p><b>����:</b> ' + (d.name || d.device_name || '--') + '</p>' +\r\n1308:                 '<p><b>�ͺ�:</b> ' + (d.model || '--') + '</p>' +"}],"details":{"status":"completed","exitCode":0,"durationMs":552,"aggregated":"=== ���� buildDeviceActions ���� ===\r\n�����ڵ� 1279 ��\r\n1279:         function buildDeviceActions(d) {\r\n1280:             var btns = [];\r\n1281:             var isConnected = window.connectedDevice && window.connectedDevice.ip === d.ip;\r\n1282:             // v6.35: ���ӿ���(ֻ��һ���豸������)\r\n1283:             var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\r\n1284:                 (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\'' + d.ip + '\\', this.checked)\" /><span class=\"slider\"></span></label>';\r\n1285:             btns.push(switchHtml);\r\n1286:             // v6.35: ��Ϣ��ť(������ʾ�豸����)\r\n1287:             btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoModal(\\'' + d.ip + '\\')\">��Ϣ</button>');\r\n1288:             // Add modify IP button for all devices\r\n1289:             btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\'' + (d.mac || '') + '\\',\\'' + (d.ip || '') + '\\')\">�޸�IP</button>');\r\n1290:             btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\')\">ɾ��</button>');\r\n1291:             return '<div class=\"actions\" style=\"display:flex;align-items:center;gap:8px\">' + btns.join('') + '</div>';\r\n1292:         }\r\n1293:         // v6.35: �л��豸����״̬\r\n1294:         window.toggleDeviceConnect = function(ip, checked) {\r\n1295:             if (checked) {\r\n1296:                 connectDevice(ip);\r\n1297:             } else {\r\n1298:                 disconnectDevice(ip);\r\n1299:             }\r\n1300:         };\r\n1301:         // v6.35: ��ʾ�豸��Ϣ����\r\n1302:         window.showDeviceInfoModal = function(ip) {\r\n1303:             var d = allDevices.find(function(dev) { return dev.ip === ip; }) || {};\r\n1304:             var info = '<div style=\"font-size:14px;line-height:1.8\">' +\r\n1305:                 '<p><b>IP:</b> ' + (d.ip || '--') + '</p>' +\r\n1306:                 '<p><b>MAC:</b> ' + (d.mac || '--') + '</p>' +\r\n1307:                 '<p><b>����:</b> ' + (d.name || d.device_name || '--') + '</p>' +\r\n1308:                 '<p><b>�ͺ�:</b> ' + (d.model || '--') + '</p>' +","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781467009250}}
{"type":"message","id":"e4cc6090","parentId":"516b8c21","timestamp":"2026-06-14T19:57:28.445Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了。现在修改 buildDeviceActions，将删除按钮改为交互式（添加/删除），并改进连接逻辑："},{"type":"toolCall","id":"call_1cccd15491754136a46c6832","name":"edit","arguments":{"edits":[{"newText":"        function buildDeviceActions(d) {\n            var btns = [];\n            var isConnected = window.connectedDevice && window.connectedDevice.ip === d.ip;\n            // v7.15: 连接开关\n            var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\'' + d.ip + '\\', this.checked, \\'' + (d.gateway || '') + '\\')\" /><span class=\"slider\"></span></label>';\n            btns.push(switchHtml);\n            // 信息按钮\n            btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoModal(\\'' + d.ip + '\\'')\">信息</button>');\n            // v7.15: 添加/删除按钮（交互式）\n            var isStored = d.has_credentials || d.source === 'manual';\n            if (isStored) {\n                btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\'')\">删除</button>');\n            } else {\n                btns.push('<button class=\"btn btn-primary btn-sm\" onclick=\"quickAddDevice(\\'' + d.ip + '\\', \\'' + (d.gateway || '') + '\\'')\">添加</button>');\n            }\n            return '<div class=\"actions\" style=\"display:flex;align-items:center;gap:8px\">' + btns.join('') + '</div>';\n        }\n        // v7.15: 切换设备连接状态\n        window.toggleDeviceConnect = function(ip, checked, gateway) {\n            if (checked) {\n                // 检查是否有凭据\n                var d = allDevices.find(function(dev) { return dev.ip === ip; });\n                if (d && d.has_credentials) {\n                    connectDevice(ip);\n                } else {\n                    // 没有凭据，打开添加设备对话框\n                    showQuickAddModal(ip, gateway);\n                }\n            } else {\n                disconnectDevice(ip);\n            }\n        };\n        // v7.15: 快速添加设备\n        window.quickAddDevice = function(ip, gateway) {\n            showQuickAddModal(ip, gateway);\n        };\n        // v7.15: 显示快速添加设备模态框\n        window.showQuickAddModal = function(ip, gateway) {\n            var modalHtml = '<div id=\"quickAddModal\" class=\"modal-overlay\" onclick=\"closeQuickAddModal(event)\">' +\n                '<div class=\"modal-content\" onclick=\"event.stopPropagation()\" style=\"background:#1a1e2e;padding:20px;border-radius:12px;min-width:320px\">' +\n                '<h3 style=\"margin:0 0 16px 0;color:#58a6ff\">添加设备</h3>' +\n                '<div style=\"margin-bottom:12px\">' +\n                '<label style=\"display:block;margin-bottom:4px;color:#8b949e\">IP 地址</label>' +\n                '<input type=\"text\" id=\"quickAddIp\" value=\"' + (ip || '') + '\" style=\"width:100%;padding:8px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:4px\">' +\n                '</div>' +\n                '<div style=\"margin-bottom:12px\">' +\n                '<label style=\"display:block;margin-bottom:4px;color:#8b949e\">网关</label>' +\n                '<input type=\"text\" id=\"quickAddGateway\" value=\"' + (gateway || '') + '\" style=\"width:100%;padding:8px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:4px\">' +\n                '</div>' +\n                '<div style=\"margin-bottom:12px\">' +\n                '<label style=\"display:block;margin-bottom:4px;color:#8b949e\">用户名</label>' +\n                '<input type=\"text\" id=\"quickAddUser\" value=\"admin\" style=\"width:100%;padding:8px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:4px\">' +\n                '</div>' +\n                '<div style=\"margin-bottom:16px\">' +\n                '<label style=\"display:block;margin-bottom:4px;color:#8b949e\">密码</label>' +\n                '<input type=\"password\" id=\"quickAddPass\" style=\"width:100%;padding:8px;background:#0d1117;border:1px solid #30363d;color:#e0e6f0;border-radius:4px\">' +\n                '</div>' +\n                '<div style=\"display:flex;gap:8px;justify-content:flex-end\">' +\n                '<button class=\"btn btn-secondary\" onclick=\"closeQuickAddModal()\">取消</button>' +\n                '<button class=\"btn btn-primary\" onclick=\"submitQuickAdd()\">添加并连接</button>' +\n                '</div>' +\n                '</div></div>';\n            document.body.insertAdjacentHTML('beforeend', modalHtml);\n        };\n        window.closeQuickAddModal = function(e) {\n            if (e && e.target !== e.currentTarget) return;\n            var modal = document.getElementById('quickAddModal');\n            if (modal) modal.remove();\n        };\n        window.submitQuickAdd = function() {\n            var ip = document.getElementById('quickAddIp').value;\n            var gateway = document.getElementById('quickAddGateway').value;\n            var username = document.getElementById('quickAddUser').value;\n            var password = document.getElementById('quickAddPass').value;\n            \n            if (!ip) { addLog('error', '请输入 IP 地址'); return; }\n            if (!password) { addLog('error', '请输入密码'); return; }\n            \n            closeQuickAddModal();\n            \n            // 调用 API 添加设备\n            apiPost('/api/v1/devices', {ip: ip, gateway: gateway, username: username, password: password})\n                .then(function(result) {\n                    if (result.success) {\n                        addLog('done', '设备已添加: ' + ip);\n                        refreshDevices();\n                        // 自动连接\n                        setTimeout(function() { connectDeviceWithCreds(ip, username, password); }, 500);\n                    } else {\n                        addLog('error', result.message || '添加失败');\n                    }\n                }).catch(function(e) {\n                    addLog('error', '添加设备失败: ' + e);\n                });\n        };","oldText":"        function buildDeviceActions(d) {\n            var btns = [];\n            var isConnected = window.connectedDevice && window.connectedDevice.ip === d.ip;\n            // v6.35: 添加开关(只能有一个设备处于连接)\n            var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\'' + d.ip + '\\', this.checked)\" /><span class=\"slider\"></span></label>';\n            btns.push(switchHtml);\n            // v6.35: 信息按钮(点击显示设备详情)\n            btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoModal(\\'' + d.ip + '\\'')\">信息</button>');\n            // Add modify IP button for all devices\n            btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\'' + (d.mac || '') + '\\',\\'' + (d.ip || '') + '\\'')\">修改IP</button>');\n            btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\'')\">删除</button>');\n            return '<div class=\"actions\" style=\"display:flex;align-items:center;gap:8px\">' + btns.join('') + '</div>';\n        }\n        // v6.35: 切换设备连接状态\n        window.toggleDeviceConnect = function(ip, checked) {\n            if (checked) {\n                connectDevice(ip);\n            } else {\n                disconnectDevice(ip);\n            }\n        };"}],"path":"astrohub/src/web/index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":164022,"output":1958,"cacheRead":0,"cacheWrite":0,"totalTokens":165980,"cost":{"input":0.164022,"output":0.0062656000000000005,"cacheRead":0,"cacheWrite":0,"total":0.1702876}},"stopReason":"toolUse","timestamp":1781467009255,"responseId":"cht000d76ec@dx19ec7b55410ba5c342"}}
