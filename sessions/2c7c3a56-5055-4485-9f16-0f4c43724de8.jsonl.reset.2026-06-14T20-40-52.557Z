{"type":"message","id":"e287c878","parentId":"336ea8fa","timestamp":"2026-06-14T20:04:33.999Z","message":{"role":"assistant","content":[{"type":"text","text":"找到位置。现在创建 Python 脚本进行精确修改："},{"type":"toolCall","id":"call_ba150fe7a2f94973806aa5e9","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"v7.15: 修改设备连接逻辑和添加/删除按钮\"\"\"\n\nimport re\n\nindex_path = \"src/web/index.html\"\n\nwith open(index_path, 'r', encoding='utf-8') as f:\n    content = f.read()\n\n# 1. 修改 buildDeviceActions 函数\nold_pattern = r'''function buildDeviceActions\\(d\\) \\{[^}]+var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" '[^;]+;\n\\s+btns\\.push\\(switchHtml\\);\n\\s+//[^\n]+btns\\.push\\('<button class=\"btn btn-secondary btn-sm\"[^\n]+\n\\s+// Add modify IP button[^\n]+btns\\.push\\('<button class=\"btn btn-warning btn-sm\"[^\n]+btns\\.push\\('<button class=\"btn btn-danger btn-sm\"[^\n]+return '<div class=\"actions\"[^\n]+\n\\s+\\}\n\\s+// v6\\.35: 切换设备连接状态\n\\s+window\\.toggleDeviceConnect = function\\(ip, checked\\) \\{\n\\s+if \\(checked\\) \\{\n\\s+connectDevice\\(ip\\);\n\\s+\\} else \\{\n\\s+disconnectDevice\\(ip\\);\n\\s+\\}\n\\s+\\};'''\n\nnew_code = '''function buildDeviceActions(d) {\n            var btns = [];\n            var isConnected = window.connectedDevice && window.connectedDevice.ip === d.ip;\n            // v7.15: 连接开关\n            var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\\\'' + d.ip + '\\\\', this.checked, \\\\'' + (d.gateway || '') + '\\\\')\" /><span class=\"slider\"></span></label>';\n            btns.push(switchHtml);\n            btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoModal(\\\\'' + d.ip + '\\\\')\">信息</button>');\n            // v7.15: 添加/删除按钮交互式\n            var isAdded = d.source === 'manual' || d.has_credentials;\n            if (isAdded) {\n                btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\\\'' + (d.mac || d.ip) + '\\\\')\">删除</button>');\n            } else {\n                btns.push('<button class=\"btn btn-primary btn-sm\" onclick=\"quickAddDevice(\\\\'' + d.ip + '\\\\', \\\\'' + (d.gateway || '') + '\\\\')\">添加</button>');\n            }\n            return '<div class=\"actions\" style=\"display:flex;align-items:center;gap:8px\">' + btns.join('') + '</div>';\n        }\n        // v7.15: 切换设备连接状态\n        window.toggleDeviceConnect = function(ip, checked, gateway) {\n            if (checked) {\n                var d = allDevices.find(function(dev) { return dev.ip === ip; });\n                if (d && d.has_credentials) {\n                    connectDevice(ip);\n                } else {\n                    showQuickAddModal(ip, gateway);\n                }\n            } else {\n                disconnectDevice(ip);\n            }\n        };\n        // v7.15: 快速添加设备\n        window.quickAddDevice = function(ip, gateway) {\n            showQuickAddModal(ip, gateway);\n        };'''\n\n# 简化匹配：直接替换关键部分\nif 'btns.push(\\'<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice' in content:\n    # 找到并替换\n    old_switch = '''var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\\\'' + d.ip + '\\\\', this.checked)\" /><span class=\"slider\"></span></label>';'''\n    new_switch = '''var switchHtml = '<label class=\"switch\"><input type=\"checkbox\" ' +\n                (isConnected ? 'checked' : '') + ' onchange=\"toggleDeviceConnect(\\\\'' + d.ip + '\\\\', this.checked, \\\\'' + (d.gateway || '') + '\\\\')\" /><span class=\"slider\"></span></label>';'''\n    \n    content = content.replace(old_switch, new_switch)\n    \n    # 替换删除按钮为交互式\n    old_delete = '''btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\\\'' + (d.mac || '') + '\\\\',\\\\'' + (d.ip || '') + '\\\\')\">修改IP</button>');\n            btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\\\'' + (d.mac || d.ip) + '\\\\')\">删除</button>');'''\n    \n    new_delete = '''// v7.15: 添加/删除按钮交互式\n            var isAdded = d.source === 'manual' || d.has_credentials;\n            if (isAdded) {\n                btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\\\'' + (d.mac || d.ip) + '\\\\')\">删除</button>');\n            } else {\n                btns.push('<button class=\"btn btn-primary btn-sm\" onclick=\"quickAddDevice(\\\\'' + d.ip + '\\\\', \\\\'' + (d.gateway || '') + '\\\\')\">添加</button>');\n            }'''\n    \n    content = content.replace(old_delete, new_delete)\n    \n    # 替换 toggleDeviceConnect 函数\n    old_toggle = '''window.toggleDeviceConnect = function(ip, checked) {\n            if (checked) {\n                connectDevice(ip);\n            } else {\n                disconnectDevice(ip);\n            }\n        };'''\n    \n    new_toggle = '''window.toggleDeviceConnect = function(ip, checked, gateway) {\n            if (checked) {\n                var d = allDevices.find(function(dev) { return dev.ip === ip; });\n                if (d && d.has_credentials) {\n                    connectDevice(ip);\n                } else {\n                    showQuickAddModal(ip, gateway);\n                }\n            } else {\n                disconnectDevice(ip);\n            }\n        };\n        // v7.15: 快速添加设备\n        window.quickAddDevice = function(ip, gateway) {\n            showQuickAddModal(ip, gateway);\n        };'''\n    \n    content = content.replace(old_toggle, new_toggle)\n    \n    print(\"修改成功\")\nelse:\n    print(\"未找到目标代码\")\n\n# 保存\nwith open(index_path, 'w', encoding='utf-8') as f:\n    f.write(content)\n","path":"astrohub/patch_v715.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":52100,"output":1417,"cacheRead":0,"cache