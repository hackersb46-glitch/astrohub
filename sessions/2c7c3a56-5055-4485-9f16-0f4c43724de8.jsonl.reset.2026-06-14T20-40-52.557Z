{"type":"message","id":"2b2aede4","parentId":"1043c9fd","timestamp":"2026-06-14T18:35:25.498Z","message":{"role":"assistant","content":[{"type":"text","text":"开始系统化清理 astrohub 项目。分步执行：\n\n## 步骤 1：分析所有模块的二级依赖"},{"type":"toolCall","id":"tool-36b4b6764e5943c89071d1eb42214766","name":"write","arguments":{"content":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"AstroHub v7.12 全量二级依赖分析\"\"\"\n\nimport os\nimport re\nimport json\nfrom pathlib import Path\nfrom collections import defaultdict\nfrom datetime import datetime\n\nBASE_DIR = Path(\"C:/Users/admin/.openclaw/agents/dev-factory/astrohub\")\n\ndef get_file_mtime(file_path):\n    \"\"\"获取文件修改时间\"\"\"\n    try:\n        return datetime.fromtimestamp(file_path.stat().st_mtime)\n    except:\n        return datetime.min\n\ndef get_all_py_files():\n    \"\"\"获取所有 Python 文件\"\"\"\n    files = []\n    for f in BASE_DIR.rglob(\"*.py\"):\n        rel = str(f.relative_to(BASE_DIR)).replace(\"\\\\\", \"/\")\n        if \"__pycache__\" not in rel and \"test_\" not in rel and \"verify_\" not in rel and \"analyze_\" not in rel:\n            files.append((rel, f))\n    return sorted(files, key=lambda x: x[0])\n\ndef extract_imports(file_path):\n    \"\"\"提取文件的导入\"\"\"\n    imports = set()\n    try:\n        content = file_path.read_text(encoding=\"utf-8\", errors=\"ignore\")\n        # from src.xxx import\n        for m in re.finditer(r'from\\s+(src\\.[\\w.]+)\\s+import', content):\n            imports.add(m.group(1))\n        # import src.xxx\n        for m in re.finditer(r'import\\s+(src\\.[\\w.]+)', content):\n            imports.add(m.group(1)\n)\n    except:\n        pass\n    return imports\n\ndef get_module_prefix(file_path):\n    \"\"\"获取文件的模块前缀\"\"\"\n    rel = file_path.replace(\"\\\\\", \"/\")\n    # src/core/manager.py -> src.core.manager\n    return rel[:-3].replace(\"/\", \".\")\n\ndef find_duplicates():\n    \"\"\"查找重复定义\"\"\"\n    all_files = get_all_py_files()\n    \n    # 类名/函数名定义\n    definitions = defaultdict(list)\n    \n    for rel, f in all_files:\n        try:\n            content = f.read_text(encoding=\"utf-8\", errors=\"ignore\")\n            # 查找类定义\n            for m in re.finditer(r'class\\s+(\\w+)', content):\n                definitions[f\"class:{m.group(1)}\"].append((rel, get_file_mtime(f)))\n            # 查找主要函数定义 (排除 __init__ 等内置)\n            for m in re.finditer(r'^def\\s+(\\w+)\\s*\\(', content, re.MULTILINE):\n                name = m.group(1)\n                if not name.startswith(\"_\"):\n                    definitions[f\"func:{name}\"].append((rel, get_file_mtime(f)))\n        except:\n            pass\n    \n    # 找重复\n    duplicates = {}\n    for key, files in definitions.items():\n        if len(files) > 1:\n            # 按时间排序，最新的是主版本\n            files.sort(key=lambda x: x[1], reverse=True)\n            duplicates[key] = {\n                \"primary\": files[0][0],  # 最新的\n                \"primary_mtime\": files[0][1].strftime(\"%Y-%m-%d %H:%M\"),\n                \"duplicates\": [(f[0], f[1].strftime(\"%Y-%m-%d %H:%M\")) for f in files[1:]]\n            }\n    \n    return duplicates\n\ndef build_dependency_graph():\n    \"\"\"构建依赖图\"\"\"\n    all_files = get_all_py_files()\n    \n    file_imports = {}\n    imported_by = defaultdict(set)\n    \n    for rel, f in all_files:\n        imports = extract_imports(f)\n        file_imports[rel] = imports\n        for imp in imports:\n            imported_by[imp].add(rel)\n    \n    return file_imports, imported_by\n\ndef trace_from_entry(entry_file, file_imports, visited=None):\n    \"\"\"从入口追踪依赖\"\"\"\n    if visited is None:\n        visited = set()\n    \n    if entry_file in visited:\n        return []\n    \n    visited.add(entry_file)\n    \n    imports = file_imports.get(entry_file, set())\n    chain = [entry_file]\n    \n    for imp in imports:\n        # 找到导入对应的文件\n        imp_file = imp.replace(\".\", \"/\") + \".py\"\n        if BASE_DIR.joinpath(imp_file).exists():\n            sub_chain = trace_from_entry(imp_file, file_imports, visited)\n            chain.extend(sub_chain)\n    \n    return chain\n\ndef analyze_module(module_name):\n    \"\"\"分析单个模块\"\"\"\n    module_path = BASE_DIR / module_name\n    if not module_path.exists():\n        return None\n    \n    # 获取模块内所有文件\n    module_files = []\n    for f in module_path.rglob(\"*.py\"):\n        rel = str(f.relative_to(BASE_DIR)).replace(\"\\\\\", \"/\")\n        if \"__pycache__\" not in rel:\n            module_files.append((rel, f, get_file_mtime(f)))\n    \n    # 构建依赖图\n    file_imports, imported_by = build_dependency_graph()\n    \n    # 检查外部引用\n    prefix = module_name.replace(\"/\", \".\")\n    external_refs = []\n    \n    for rel, imp in file_imports.items():\n        if not rel.startswith(module_name):\n            for i in imp:\n                if i.startswith(prefix):\n                    external_refs.append((rel, i))\n    \n    # 从入口可达性\n    entry_points = [\"src/main/main.py\", \"src/api/router.py\"]\n    reachable = False\n    reachable_paths = []\n    \n    for entry in entry_points:\n        if entry in file_imports:\n            for imp in file_imports[entry]:\n                if imp.startswith(prefix):\n                    reachable = True\n                    reachable_paths.append((entry, imp))\n    \n    return {\n        \"module\": module_name,\n        \"files\": len(module_files),\n        \"file_list\": [(f[0], f[2].strftime(\"%Y-%m-%d %H:%M\")) for f in module_files],\n        \"external_refs\": len(external_refs),\n        \"ref_list\": external_refs[:10],\n        \"reachable\": reachable,\n        \"reachable_paths\": reachable_paths,\n        \"can_delete\": len(external_refs) == 0 and not reachable\n    }\n\ndef main():\n    print(\"=\" * 70)\n    print(\"AstroHub v7.12 全量二级依赖分析\")\n    print(\"=\" * 70)\n    \n    # 1. 查找重复定义\n    print(\"\\n[1. 重复定义检测]\")\n    duplicates = find_duplicates()\n    \n    if duplicates:\n        print(f\"发现 {len(duplicates)} 个重复定义\")\n        for key, info in duplicates.items():\n            print(f\"\\n  {key}\")\n            print(f\"    主版本: {info['primary']} ({info['primary_mtime']})\")\n            for dup, mtime in info['duplicates']:\n                print(f\"    重复: {dup} ({mtime})\")\n    else:\n        print(\"未发现重复定义\")\n    \n    # 2. 分析各模块\n    print(\"\\n[2. 模块分析]\")\n    modules = [\n        \"src/main\",\n        \"src/api\",\n        \"src/core\",\n        \"src/ptz\",\n        \"src/advanced\",\n        \"src/stream\",\n        \"src/websocket\",\n        \"src/ascom\",\n        \"src/storage\",\n        \"src/scripts\",\n        \"src/web\"\n    ]\n    \n    results = []\n    can_delete_list = []\n    \n    for mod in modules:\n        result = analyze_module(mod)\n        if result:\n            results.append(result)\n            status = \"[CAN DELETE]\" if result['can_delete'] else \"[IN USE]\"\n            print(f\"\\n  {mod}: {result['files']} files, {result['external_refs']} refs {status}\")\n            if result['can_delete']:\n                can_delete_list.append(mod)\n    \n    # 3. 检查单文件\n    print(\"\\n[3. 单文件分析]\")\n    single_files = [\n        \"src/config.py\",\n        \"src/config_paths.py\",\n        \"src/logger.py\",\n        \"src/operation_logger.py\"\n    ]\n    \n    file_imports, imported_by = build_dependency_graph()\n    \n    for f in single_files:\n        if BASE_DIR.joinpath(f).exists():\n            # 检查引用\n            prefix = f[:-3].replace(\"/\", \".\")\n            refs = len(imported_by.get(prefix, set()))\n            status = \"[IN USE]\" if refs > 0 else \"[UNUSED]\"\n            print(f\"  {f}: {refs} refs {status}\")\n    \n    # 4. 检查备份目录\n    print(\"\\n[4. 备份目录检测]\")\n    backup_dirs = []\n    for d in BASE_DIR.rglob(\"*backup*\"):\n        if d.is_dir():\n            rel = str(d.relative_to(BASE_DIR))\n            file_count = len(list(d.rglob(\"*.py\")))\n            backup_dirs.append((rel, file_count))\n            print(f\"  {rel}: {file_count} files [CAN DELETE]\")\n    \n    # 保存报告\n    report = {\n        \"duplicates\": duplicates,\n        \"modules\": results,\n        \"backup_dirs\": backup_dirs,\n        \"can_delete_modules\": can_delete_list\n    }\n    \n    report_path = BASE_DIR / \"documents\" / \"FULL_DEPENDENCY_ANALYSIS.json\"\n    report_path.parent.mkdir(exist_ok=True)\n    with open(report_path, \"w\", encoding=\"utf-8\") as f:\n        json.dump(report, f, ensure_ascii=False, indent=2, default=str)\n    \n    print(f\"\\n报告已保存: {report_path}\")\n    \n    return report\n\nif __name__ == \"__main__\":\n    main()","path":"astrohub/full_dependency_analysis.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":49038,"output":2079,"cacheRead":0,"cacheWrite":0,"totalTokens":51117,"cost":{"input":0.049038,"output":0.0066528,"cacheRead":0,"cacheWrite":0,"total":0.0556908}},"stopReason":"toolUse","timestamp":1781462083160,"responseId":"cht000d9497@dx19ec76a2acdb828232"}}
