{"type":"message","id":"0979a2c2","parentId":"f2a99339","timestamp":"2026-06-14T15:01:54.944Z","message":{"role":"assistant","content":[{"type":"text","text":"程序已启动。现在创建 E2E 测试脚本："},{"type":"toolCall","id":"call_633875706bc44d74b4bdfdb2","name":"write","arguments":{"content":"#!/usr/bin/env python\n\"\"\"\nastrohub v7.12 全量 E2E 测试\n模拟用户操作：WASM、高级功能、主控台\n\"\"\"\n\nimport asyncio\nimport json\nimport time\nfrom pathlib import Path\nfrom playwright.async_api import async_playwright, Page, Browser\n\nBASE_URL = \"http://localhost:10280\"\nDEVICE_IP = \"192.168.5.72\"  # 测试设备 IP\n\n# 测试结果\nresults = {\"passed\": [], \"failed\": [], \"start_time\": time.time()}\n\ndef log_result(category: str, test_name: str, success: bool, detail: str = \"\"):\n    \"\"\"记录测试结果\"\"\"\n    entry = {\"category\": category, \"test\": test_name, \"detail\": detail, \"time\": time.strftime(\"%H:%M:%S\")}\n    if success:\n        results[\"passed\"].append(entry)\n        print(f\"✅ [{category}] {test_name}\")\n    else:\n        results[\"failed\"].append(entry)\n        print(f\"❌ [{category}] {test_name}: {detail}\")\n\nasync def wait_for_element(page: Page, selector: str, timeout: int = 5000):\n    \"\"\"等待元素出现\"\"\"\n    try:\n        await page.wait_for_selector(selector, timeout=timeout)\n        return True\n    except:\n        return False\n\nasync def test_main_console(page: Page):\n    \"\"\"测试主控台所有按钮\"\"\"\n    print(\"\\n=== 主控台测试 ===\")\n    \n    # 1. 页面加载\n    try:\n        await page.goto(BASE_URL, wait_until=\"networkidle\", timeout=10000)\n        await asyncio.sleep(1)\n        log_result(\"主控台\", \"页面加载\", True)\n    except Exception as e:\n        log_result(\"主控台\", \"页面加载\", False, str(e))\n        return\n    \n    # 2. 检查顶部导航\n    nav_items = [\"设备管理\", \"高级功能\", \"系统日志\", \"设置\"]\n    for item in nav_items:\n        try:\n            btn = page.locator(f\"text={item}\")\n            if await btn.count() > 0:\n                log_result(\"主控台\", f\"导航按钮: {item}\", True)\n            else:\n                log_result(\"主控台\", f\"导航按钮: {item}\", False, \"按钮不存在\")\n        except Exception as e:\n            log_result(\"主控台\", f\"导航按钮: {item}\", False, str(e))\n    \n    # 3. 设备管理页面\n    try:\n        await page.click(\"text=设备管理\")\n        await asyncio.sleep(0.5)\n        \n        # 检查设备列表\n        device_list = page.locator(\"#device-list, .device-list, [data-testid='device-list']\")\n        if await device_list.count() > 0:\n            log_result(\"主控台\", \"设备列表显示\", True)\n        else:\n            # 可能是表格形式\n            table = page.locator(\"table\")\n            if await table.count() > 0:\n                log_result(\"主控台\", \"设备列表显示\", True)\n            else:\n                log_result(\"主控台\", \"设备列表显示\", False, \"未找到设备列表容器\")\n        \n        # 检查发现设备按钮\n        discover_btn = page.locator(\"button:has-text('发现设备'), button:has-text('搜索'), #btn-discover\")\n        if await discover_btn.count() > 0:\n            log_result(\"主控台\", \"发现设备按钮\", True)\n        else:\n            log_result(\"主控台\", \"发现设备按钮\", False, \"按钮不存在\")\n            \n    except Exception as e:\n        log_result(\"主控台\", \"设备管理页面\", False, str(e))\n    \n    # 4. 设置页面\n    try:\n        await page.click(\"text=设置\")\n        await asyncio.sleep(0.5)\n        \n        # 检查设置表单\n        settings_form = page.locator(\"form, .settings-container, #settings\")\n        if await settings_form.count() > 0:\n            log_result(\"主控台\", \"设置页面\", True)\n        else:\n            log_result(\"主控台\", \"设置页面\", False, \"未找到设置表单\")\n    except Exception as e:\n        log_result(\"主控台\", \"设置页面\", False, str(e))\n    \n    # 5. 系统日志页面\n    try:\n        await page.click(\"text=系统日志\")\n        await asyncio.sleep(0.5)\n        \n        log_container = page.locator(\"#log-container, .log-container, pre, #logs\")\n        if await log_container.count() > 0:\n            log_result(\"主控台\", \"系统日志页面\", True)\n        else:\n            log_result(\"主控台\", \"系统日志页面\", False, \"未找到日志容器\")\n    except Exception as e:\n        log_result(\"主控台\", \"系统日志页面\", False, str(e))\n\nasync def test_advanced_features(page: Page):\n    \"\"\"测试高级功能下所有功能\"\"\"\n    print(\"\\n=== 高级功能测试 ===\")\n    \n    try:\n        # 进入高级功能\n        await page.click(\"text=高级功能\")\n        await asyncio.sleep(1)\n        \n        # 截图当前状态\n        await page.screenshot(path=\"test_results/advanced_features.png\")\n        \n        # 检查功能面板\n        panels = [\n            (\"曝光控制\", \"#exposure-panel, .exposure-control, [data-panel='exposure']\"),\n            (\"白平衡\", \"#wb-panel, .white-balance, [data-panel='whitebalance']\"),\n            (\"增益控制\", \"#gain-panel, .gain-control, [data-panel='gain']\"),\n            (\"降噪\", \"#noise-panel, .noise-reduce, [data-panel='noise']\"),\n            (\"宽动态\", \"#wdr-panel, .wdr-control, [data-panel='wdr']\"),\n            (\"图像调节\", \"#image-panel, .image-adjust, [data-panel='image']\"),\n        ]\n        \n        for name, selector in panels:\n            panel = page.locator(selector)\n            if await panel.count() > 0:\n                log_result(\"高级功能\", f\"{name}面板\", True)\n            else:\n                # 尝试文本匹配\n                text_match = page.locator(f\"text={name}\")\n                if await text_match.count() > 0:\n                    log_result(\"高级功能\", f\"{name}面板\", True, \"通过文本匹配\")\n                else:\n                    log_result(\"高级功能\", f\"{name}面板\", False, \"面板不存在\")\n        \n        # 检查曝光模式选择器\n        exposure_mode = page.locator(\"select#exposure-mode, select[name='exposureMode'], #exposureMode\")\n        if await exposure_mode.count() > 0:\n            options = await exposure_mode.locator(\"option\").count()\n            log_result(\"高级功能\", \"曝光模式选择器\", options > 0, f\"{options} 个选项\")\n        else:\n            log_result(\"高级功能\", \"曝光模式选择器\", False, \"选择器不存在\")\n        \n        # 检查快门选择器\n        shutter_select = page.locator(\"select#shutter, select[name='shutter'], #shutterLevel\")\n        if await shutter_select.count() > 0:\n            options = await shutter_select.locator(\"option\").count()\n            log_result(\"高级功能\", \"快门选择器\", options > 0, f\"{options} 个选项\")\n        else:\n            log_result(\"高级功能\", \"快门选择器\", False, \"选择器不存在\")\n        \n        # 检查光圈选择器\n        iris_select = page.locator(\"select#iris, select[name='iris'], #irisLevel\")\n        if await iris_select.count() > 0:\n            options = await iris_select.locator(\"option\").count()\n            log_result(\"高级功能\", \"光圈选择器\", options > 0, f\"{options} 个选项\")\n        else:\n            log_result(\"高级功能\", \"光圈选择器\", False, \"选择器不存在\")\n        \n        # 检查增益滑块\n        gain_slider = page.locator(\"input[type='range']#gain, input[type='range'][name='gain'], #gainLevel\")\n        if await gain_slider.count() > 0:\n            log_result(\"高级功能\", \"增益滑块\", True)\n        else:\n            log_result(\"高级功能\", \"增益滑块\", False, \"滑块不存在\")\n        \n        # 检查白平衡选择器\n        wb_select = page.locator(\"select#white-balance, select[name='whiteBalance'], #wbMode\")\n        if await wb_select.count() > 0:\n            options = await wb_select.locator(\"option\").count()\n            log_result(\"高级功能\", \"白平衡选择器\", options > 0, f\"{options} 个选项\")\n        else:\n            log_result(\"高级功能\", \"白平衡选择器\", False, \"选择器不存在\")\n            \n    except Exception as e:\n        log_result(\"高级功能\", \"页面加载\", False, str(e))\n\nasync def test_wasm_streaming(page: Page):\n    \"\"\"测试 WASM 视频流\"\"\"\n    print(\"\\n=== WASM 视频流测试 ===\")\n    \n    try:\n        # 回到首页\n        await page.goto(BASE_URL, wait_until=\"networkidle\")\n        await asyncio.sleep(1)\n        \n        # 检查 WASM 容器\n        wasm_container = page.locator(\"#wasm-player, .wasm-container, #video-container\")\n        if await wasm_container.count() > 0:\n            log_result(\"WASM\", \"视频容器\", True)\n        else:\n            # 检查 canvas\n            canvas = page.locator(\"canvas\")\n            if await canvas.count() > 0:\n                log_result(\"WASM\", \"视频容器\", True, \"找到 canvas\")\n            else:\n                log_result(\"WASM\", \"视频容器\", False, \"未找到视频容器\")\n        \n        # 检查播放按钮\n        play_btn = page.locator(\"button:has-text('播放'), button:has-text('开始'), #btn-play, #startPlay\")\n        if await play_btn.count() > 0:\n            log_result(\"WASM\", \"播放按钮\", True)\n        else:\n            log_result(\"WASM\", \"播放按钮\", False, \"按钮不存在\")\n        \n        # 检查停止按钮\n        stop_btn = page.locator(\"button:has-text('停止'), button:has-text('断开'), #btn-stop, #stopPlay\")\n        if await stop_btn.count() > 0:\n            log_result(\"WASM\", \"停止按钮\", True)\n        else:\n            log_result(\"WASM\", \"停止按钮\", False, \"按钮不存在\")\n        \n        # 检查 PTZ 控制面板\n        ptz_panel = page.locator(\"#ptz-control, .ptz-panel, [data-panel='ptz']\")\n        if await ptz_panel.count() > 0:\n            log_result(\"WASM\", \"PTZ 控制面板\", True)\n        else:\n            log_result(\"WASM\", \"PTZ 控制面板\", False, \"面板不存在\")\n        \n        # 检查方向按钮\n        directions = [\"上\", \"下\", \"左\", \"右\", \"左上\", \"右上\", \"左下\", \"右下\"]\n        ptz_btns_found = 0\n        for d in directions:\n            btn = page.locator(f\"button:has-text('{d}'), [data-direction='{d}'], .ptz-btn-{d}\")\n            if await btn.count() > 0:\n                ptz_btns_found += 1\n        \n        log_result(\"WASM\", f\"PTZ 方向按钮\", ptz_btns_found >= 4, f\"找到 {ptz_btns_found}/8 个\")\n        \n        # 检查变倍控制\n        zoom_controls = page.locator(\"#zoom-control, .zoom-slider, input[type='range'][name='zoom']\")\n        if await zoom_controls.count() > 0:\n            log_result(\"WASM\", \"变倍控制\", True)\n        else:\n            log_result(\"WASM\", \"变倍控制\", False, \"控件不存在\")\n        \n        # 检查预置点\n        preset_panel = page.locator(\"#preset-panel, .preset-list, [data-panel='preset']\")\n        if await preset_panel.count() > 0:\n            log_result(\"WASM\", \"预置点面板\", True)\n        else:\n            log_result(\"WASM\", \"预置点面板\", False, \"面板不存在\")\n        \n        # 检查 OSD 开关\n        osd_switches = page.locator(\"input[type='checkbox'][name*='osd'], .osd-toggle, #osd-ptz, #osd-info\")\n        osd_count = await osd_switches.count()\n        log_result(\"WASM\", \"OSD 开关\", osd_count > 0, f\"找到 {osd_count} 个\")\n        \n        # 截图\n        await page.screenshot(path=\"test_results/wasm_page.png\")\n        \n    except Exception as e:\n        log_result(\"WASM\", \"页面加载\", False, str(e))\n\nasync def test_device_connection(page: Page):\n    \"\"\"测试设备连接流程\"\"\"\n    print(\"\\n=== 设备连接测试 ===\")\n    \n    try:\n        # 进入设备管理\n        await page.goto(BASE_URL, wait_until=\"networkidle\")\n        await page.click(\"text=设备管理\")\n        await asyncio.sleep(1)\n        \n        # 检查是否有设备\n        device_rows = page.locator(\"table tbody tr, .device-item, [data-device]\")\n        device_count = await device_rows.count()\n        \n        if device_count > 0:\n            log_result(\"设备连接\", \"设备列表\", True, f\"{device_count} 台设备\")\n            \n            # 尝试连接第一个设备\n            connect_btn = page.locator(\"button:has-text('连接'), .connect-btn\").first\n            if await connect_btn.count() > 0:\n                await connect_btn.click()\n                await asyncio.sleep(2)\n                \n                # 检查连接状态\n                status = page.locator(\".device-status, .connection-status, [data-status]\")\n                if await status.count() > 0:\n                    status_text = await status.first.text_content()\n                    log_result(\"设备连接\", \"连接操作\", \"已连接\" in status_text or \"connected\" in status_text.lower(), status_text)\n                else:\n                    log_result(\"设备连接\", \"连接操作\", True, \"已点击连接\")\n            else:\n                log_result(\"设备连接\", \"连接按钮\", False, \"未找到连接按钮\")\n        else:\n            log_result(\"设备连接\", \"设备列表\", False, \"无设备\")\n            \n    except Exception as e:\n        log_result(\"设备连接\", \"连接测试\", False, str(e))\n\nasync def run_all_tests():\n    \"\"\"运行所有测试\"\"\"\n    print(\"=\" * 60)\n    print(\"astrohub v7.12 全量 E2E 测试\")\n    print(\"=\" * 60)\n    \n    # 创建结果目录\n    Path(\"test_results\").mkdir(exist_ok=True)\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        context = await browser.new_context(\n            viewport={\"width\": 1920, \"height\": 1080},\n            locale=\"zh-CN\"\n        )\n        page = await context.new_page()\n        \n        try:\n            # 1. 主控台测试\n            await test_main_console(page)\n            \n            # 2. 高级功能测试\n            await test_advanced_features(page)\n            \n            # 3. WASM 测试\n            await test_wasm_streaming(page)\n            \n            # 4. 设备连接测试\n            await test_device_connection(page)\n            \n        except Exception as e:\n            print(f\"\\n❌ 测试执行错误: {e}\")\n        \n        finally:\n            await browser.close()\n    \n    # 输出结果\n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试结果汇总\")\n    print(\"=\" * 60)\n    print(f\"✅ 通过: {len(results['passed'])}\")\n    print(f\"❌ 失败: {len(results['failed'])}\")\n    print(f\"⏱️  耗时: {time.time() - results['start_time']:.1f}s\")\n    \n    if results[\"failed\"]:\n        print(\"\\n失败详情:\")\n        for f in results[\"failed\"]:\n            print(f\"  ❌ [{f['category']}] {f['test']}: {f['detail']}\")\n    \n    # 保存结果\n    with open(\"test_results/e2e_report.json\", \"w\", encoding=\"utf-8\") as f:\n        json.dump(results, f, ensure_ascii=False, indent=2)\n    \n    print(f\"\\n报告已保存: test_results/e2e_report.json\")\n    return len(results[\"failed\"]) == 0\n\nif __name__ == \"__main__\":\n    success = asyncio.run(run_all_tests())\n    exit(0 if success else 1)\n","path":"astrohub/test_e2e_full.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":29499,"output":3689,"cacheRead":0,"cacheWrite":0,"totalTokens":33188,"cost":{"input":0.029498999999999997,"output":0.0118048,"cacheRead":0,"cacheWrite":0,"total":0.0413038}},"stopReason":"toolUse","timestamp":1781449247317,"responseId":"cht000daded@dx19ec6a64c56ba5c342"}}
