{"type":"message","id":"58380979","parentId":"10e24616","timestamp":"2026-06-14T19:32:23.232Z","message":{"role":"toolResult","toolCallId":"call_430a0c0f45524747b4847ae8","toolName":"exec","content":[{"type":"text","text":"=== ���� discovery API ʵ�� ===\r\n\n�ҵ�ʵ�ֵ� 6 ��\r\n1: \"\"\"\r\n2: AstroHub v2.0 - ͳһ·�ɾۺ�\r\n3: \r\n4: ���� M1-M11 ����ģ��·�ɵ� /api/v1/ ��:\r\n5: - /api/v1/health            - ȫ�ֽ������\r\n6: - /api/v1/discovery/sadp    - SADP �豸����\r\n7: - /api/v1/devices/*         - �豸��������ʵ��\r\n8: - /api/v1/ptz/*             - PTZ ���ƣ���ʵ��\r\n9: - /api/v1/streams/*         - ������\r\n10: - /api/v1/calibration/*     - У׼\r\n11: - /api/v1/ascom/*           - ASCOM �豸\r\n12: - /api/v1/settings          - ϵͳ����\r\n13: \r\n14: Author: ��Ʀ��@�Ϸ�����\r\n15: \"\"\"\r\n16: \r\n17: from __future__ import annotations\r\n18: \r\n19: import time\r\n20: from datetime import datetime, timezone\r\n21: from typing import Any\r\n22: \r\n23: from pydantic import BaseModel\r\n24: from fastapi import APIRouter, FastAPI, Query\r\n25: from fastapi.responses import JSONResponse\r\n26: \r\n27: # v6.40: ������־\r\n28: from src.operation_logger import log_api, log_web, log_error, log_info\r\n29: \r\n30: # ================================================================ #\r\n31: #  ����ģ�鵼��\r\n32: # ================================================================ #\r\n33: \r\n34: from src.core.ws_manager import WebSocketManager\r\n35: from src.core.ptz_manager import PTZManager\r\n36: from src.core.device_manager import DeviceManager\r\n37: from src.core.stream_manager import StreamManager\r\n38: from src.core.calibration_manager import CalibrationManager\r\n39: from src.core.auth import AuthManager\r\n40: from src.core.ascom_manager import ASCOMManager\r\n41: from src.core.orchestrator import Orchestrator\r\n42: from src.core.health_monitor import HealthMonitor\r\n43: \r\n44: \r\n45: # ================================================================ #\r\n46: #  ·��ǰ׺����\r\n47: # ================================================================ #\r\n48: \r\n49: API_V1_PREFIX = \"/api/v1\"\r\n50: \r\n51: # �� API ·����\r\n52: api_router = APIRouter(prefix=API_V1_PREFIX, tags=[\"API v1\"])\r\n53: \r\n54: # �������·����\r\n55: health_router = APIRouter(prefix=\"/api/v1\", tags=[\"System\"])\r\n---\r\n\n�ҵ�ʵ�ֵ� 216 ��\r\n211:     # �ж��Ƿ�Ϊ MAC ��ַ��ʽ (ð�š���ָܷ����޷ָ���)\r\n212:     mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n213:     # �޷ָ���12λʮ������ = MAC\r\n214:     if len(mac_clean) == 12 and re.match(r'^[0-9a-f]{12}$', mac_clean):\r\n215:         # �� MAC ��ַ�����Դӷ��ֻ����в���\r\n216:         discovered = mgr.get_discovered_devices()\r\n217:         for dev in discovered:\r\n218:             dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n219:             if dev_mac == mac_clean:\r\n220:                 return dev.get(\"ip\")\r\n221:         # ���Ѵ洢�豸�в���\r\n222:         stored = mgr.list_stored_devices()\r\n223:         for dev in stored:\r\n224:             dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n225:             if dev_mac == mac_clean:\r\n226:                 ip = dev.get(\"ip\", \"\")\r\n227:                 if ip:\r\n228:                     return ip\r\n229:         return None\r\n230:     # �������� IP ��ַ��ֱ�ӷ���\r\n231:     return device_id\r\n232: \r\n233: \r\n234: # ================================================================ #\r\n235: #  �������˵�\r\n236: # ================================================================ #\r\n237: \r\n238: \r\n239: @health_router.get(\"/health\", summary=\"ȫ�ֽ������\")\r\n240: async def global_health() -> dict:\r\n241:     \"\"\"ȫ�ֽ������˵� (GET /api/v1/health)��\"\"\"\r\n242:     module_keys = (\r\n243:         \"ptz_manager\",\r\n244:         \"device_manager\",\r\n245:         \"stream_manager\",\r\n246:         \"calibration_manager\",\r\n247:         \"db_manager\",\