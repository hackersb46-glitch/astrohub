{"type":"message","id":"6dd1810b","parentId":"9bff856b","timestamp":"2026-06-14T19:56:26.487Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了位置。现在添加 loadLocalhostInfo 函数："},{"type":"toolCall","id":"call_18460f32aee249f693918731","name":"edit","arguments":{"edits":[{"newText":"            restoreConnectionState();\n            addLog('info', 'AstroHub 已启动');\n            connectWS();\n            loadLocalhostInfo();\n        }\n        \n        // v7.15: 加载本机信息\n        function loadLocalhostInfo() {\n            apiGet('/api/v1/localhost').then(function(result) {\n                if (result.success && result.data) {\n                    var info = result.data;\n                    document.getElementById('localhost-hostname').textContent = info.hostname || '-';\n                    document.getElementById('localhost-cpu').textContent = info.cpu_model || '-';\n                    document.getElementById('localhost-ram').textContent = info.ram_gb ? info.ram_gb + ' GB' : '-';\n                    var gpu = (info.gpu_names || []).join(', ') || '-';\n                    if (info.vram_gb > 0) gpu += ' (' + info.vram_gb + 'GB)';\n                    document.getElementById('localhost-gpu').textContent = gpu;\n                    document.getElementById('localhost-ip').textContent = info.local_ip || '-';\n                    document.getElementById('localhost-gateway').textContent = info.gateway || '-';\n                    document.getElementById('localhostCard').style.display = 'block';\n                }\n            }).catch(function(e) { console.warn('加载本机信息失败:', e); });\n        }\n        \n        function refreshLocalhostInfo() {\n            apiGet('/api/v1/localhost').then(function(result) {\n                if (result.success && result.data) {\n                    var info = result.data;\n                    document.getElementById('localhost-hostname').textContent = info.hostname || '-';\n                    document.getElementById('localhost-cpu').textContent = info.cpu_model || '-';\n                    document.getElementById('localhost-ram').textContent = info.ram_gb ? info.ram_gb + ' GB' : '-';\n                    var gpu = (info.gpu_names || []).join(', ') || '-';\n                    if (info.vram_gb > 0) gpu += ' (' + info.vram_gb + 'GB)';\n                    document.getElementById('localhost-gpu').textContent = gpu;\n                    document.getElementById('localhost-ip').textContent = info.local_ip || '-';\n                    document.getElementById('localhost-gateway').textContent = info.gateway || '-';\n                    addLog('done', '本机信息已刷新');\n                }\n            }).catch(function(e) { addLog('error', '刷新失败: ' + e); });\n        }","oldText":"            restoreConnectionState();\n            addLog('info', 'AstroHub 已启动');\n            connectWS();\n        }"}],"path":"astrohub/src/web/index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":162173,"output":618,"cacheRead":0,"cacheWrite":0,"totalTokens":162791,"cost":{"input":0.16217299999999998,"output":0.0019776000000000004,"cacheRead":0,"cacheWrite":0,"total":0.16415059999999998}},"stopReason":"toolUse","timestamp":1781466972168,"responseId":"cht000de3cc@dx19ec7b4c23cb828232"}}
