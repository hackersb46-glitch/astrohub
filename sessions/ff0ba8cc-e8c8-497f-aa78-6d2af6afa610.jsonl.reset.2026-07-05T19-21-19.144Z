{"type":"message","id":"e4bf9f5f","parentId":"624becb4","timestamp":"2026-07-05T18:30:31.851Z","message":{"role":"toolResult","toolCallId":"toolu_42111b7ffca24622904f3e89","toolName":"read","content":[{"type":"text","text":"                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamMain\" onclick=\"switchAndPlay(1)\" title=\"主码流\">主</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamSub\" onclick=\"switchAndPlay(2)\" title=\"子码流\">子</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamThird\" onclick=\"switchAndPlay(3)\" title=\"第三码流\">三</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamStop\" onclick=\"doStopPreview()\" title=\"停止预览\">⏹</button>\r\n                                </div>\r\n                                <!-- 预置点 -->\r\n                                <div class=\"section-subtitle\">预置点</div>\r\n                                <div style=\"display:flex;gap:4px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:100px\">\r\n                                        <option value=\"\">选择预置点</option>\r\n                                    </select>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzWritePreset()\">写入</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onclick=\"ptzHome()\">归位</button>\r\n                                </div>\r\n                                <!-- PTZ OSD 开关 -->\r\n                                <div class=\"section-subtitle\">OSD</div>\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <span style=\"color:#8b949e;font-size:11px\">PTZ OSD</span>\r\n                                    <label class=\"toggle-switch\">\r\n                                        <input type=\"checkbox\" id=\"ptzOsdSwitchInPtz\" checked onchange=\"togglePtzOsdSwitch(this.checked)\">\r\n                                        <span class=\"toggle-slider\"></span>\r\n                                    </label>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 媒体信息(折叠,默认展开) -->\r\n                        <div class=\"collapsible-section\" id=\"mediaLogSection\" style=\"margin-top:12px\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaLogSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">📡 媒体信息</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;overflow-y:auto;height:200px\" class=\"hide-scrollbar\">\r\n                                    <div id=\"mediaLogBox\" style=\"font-size:11px;font-family:monospace;color:#8b949e\">\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 中: 实时画面 + 媒体操作 -->\r\n                    <div class=\"console-center\">\r\n                        <div class=\"console-video-wrap\" style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\r\n                            <!-- v7.98: WASM 播放器占位区域,保留16:9比例 -->\r\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;margin:0 auto\"></div>\r\n                            <!-- v8.10: 框选区域 overlay(默认隐藏) -->\r\n                            <div id=\"regionOverlay\" style=\"display:none;position:absolute;top:0;left:0;width:100%;height:100%;cursor:crosshair;z-index:100\">\r\n                                <div id=\"regionBox\" style=\"position:absolute;border:2px dashed #3fb950;background:rgba(63,185,80,0.15);display:none;pointer-events:none\"></div>\r\n                            </div>\r\n                        </div>\r\n\n[1677 more lines in file. Use offset=110 to continue.]"}],"isError":false,"timestamp":1783276231851}}
{"type":"message","id":"facef98c","parentId":"e4bf9f5f","timestamp":"2026-07-05T18:30:31.851Z","message":{"role":"toolResult","toolCallId":"toolu_eb12a298979e47108a9a7fc0","toolName":"read","content":[{"type":"text","text":"                                    <!-- 快门/光圈整合一行 -->\r\n                                    <div style=\"display:flex;gap:8px;margin-bottom:4px\">\r\n                                        <div style=\"flex:1\">\r\n                                            <label style=\"font-size:11px;color:#8b949e\">快门</label>\r\n                                            <select id=\"shutterSpeed\" style=\"width:100%;padding:3px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\" onchange=\"setShutterSpeed(this.value)\" disabled>\r\n                                                <option value=\"\">--</option>\r\n                                            </select>\r\n                                        </div>\r\n                                        <div style=\"flex:1\">\r\n                                            <label style=\"font-size:11px;color:#8b949e\">光圈</label>\r\n                                            <select id=\"irisLevel\" style=\"width:100%;padding:3px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\" onchange=\"setIris(this.value)\" disabled>\r\n                                                <option value=\"\">--</option>\r\n                                            </select>\r\n                                        </div>\r\n                                    </div>\r\n                                    <!-- v7.03: 增益控制 -->\r\n                                    <div style=\"margin-bottom:8px\">\r\n                                        <label style=\"font-size:11px;color:#8b949e\">增益 <span id=\"gainVal\" style=\"color:#58a6ff\">--</span></label>\r\n                                        <input type=\"range\" id=\"gainLevel\" min=\"0\" max=\"100\" value=\"0\" style=\"width:100%\" oninput=\"document.getElementById('gainVal').textContent=this.value\" onchange=\"setGain(this.value)\" disabled>\r\n                                    </div>\r\n                                    <!-- OSD 控制 - 仅信息开关（PTZ OSD已移至运动控制） -->\r\n                                    <div class=\"form-group\" style=\"margin-bottom:8px;display:flex;justify-content:space-between;align-items:center\">\r\n                                        <label style=\"font-size:12px;margin:0\">信息</label>\r\n                                        <div style=\"display:flex;gap:16px\">\r\n                                            <div style=\"display:flex;align-items:center;gap:6px\">\r\n                                                <span style=\"font-size:11px;color:#8b949e\">OSD</span>\r\n                                                <label class=\"toggle-switch\">\r\n                                                    <input type=\"checkbox\" id=\"infoOsdSwitch\" onchange=\"toggleInfoOsdSwitch(this.checked)\">\r\n                                                    <span class=\"toggle-slider\"></span>\r\n                                                </label>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n<style>\r\n/* v7.30: 模块禁用样式 - 保留折叠展开功能 */\r\n.section-disabled .collapsible-content {\r\n    opacity: 0.4;\r\n    pointer-events: none;\r\n}\r\n.section-disabled .collapsible-header {\r\n    opacity: 0.6;\r\n}\r\n.section-disabled .collapsible-header:hover {\r\n    cursor: pointer;\r\n}\r\n\r\n/* v6.02: 拨杆开关样式 */\r\n.toggle-switch {\r\n    position: relative;\r\n    display: inline-block;\r\n    width: 40px;\r\n  