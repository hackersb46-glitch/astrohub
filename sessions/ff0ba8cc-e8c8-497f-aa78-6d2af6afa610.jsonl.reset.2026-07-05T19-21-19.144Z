{"type":"message","id":"3d475c4f","parentId":"64641942","timestamp":"2026-07-05T17:33:48.283Z","message":{"role":"toolResult","toolCallId":"toolu_40eb41417c4d4e0d9ff6da42","toolName":"exec","content":[{"type":"text","text":"def get_connected_device(self) -> dict | None:\r\n        \"\"\"v7.10: ���� last_connected �豸��Ϣ�����ڿ������ӣ���\r\n        \r\n        ע�⣺�˷������ص���\"�ϴ����ӵ��豸\"����һ����\"��ǰ���ӵ��豸\"��\r\n        ǰ��Ӧ��ͨ����� IP �Ƿ��� _controllers ���ж��Ƿ�ʵ�����ӡ�\r\n        \"\"\"\r\n        import json\r\n        from src.config_paths import REGISTRY_FILE, DEVICES_DIR\r\n        \r\n        try:\r\n            # v7.10: ��ȡ last_connected�����ڿ������ӣ�\r\n            if REGISTRY_FILE.exists():\r\n                registry = json.loads(REGISTRY_FILE.read_text(encoding='utf-8'))\r\n                last_mac = registry.get('last_connected', '').strip()\r\n                \r\n                # last_connected Ϊ�ձ�ʾ��δ���ӹ�\r\n            print(f'[PTZDeviceController] get_connected_device error: {e}')\r\n        \r\n        return None\r\n\r\n    # ================================================================\r\n    #  �豸��Ϣ��ȡ\r\n    # ================================================================\r\n\r\n    def get_device_info(self, ip: str) -> dict:\r\n        \"\"\"ͨ�� ISAPI ��ȡ�豸��ϸ��Ϣ��\"\"\"\r\n        if ip not in self._clients:\r\n            # �����Զ�����\r\n            creds = self.get_credentials(ip)\r\n            if creds:\r\n                client = ISAPIClient(ip=ip, username=creds[\"username\"],\r\n                                     password=creds[\"password\"], port=creds.get(\"port\", 80))"}],"details":{"status":"completed","exitCode":0,"durationMs":499,"aggregated":"def get_connected_device(self) -> dict | None:\r\n        \"\"\"v7.10: ���� last_connected �豸��Ϣ�����ڿ������ӣ���\r\n        \r\n        ע�⣺�˷������ص���\"�ϴ����ӵ��豸\"����һ����\"��ǰ���ӵ��豸\"��\r\n        ǰ��Ӧ��ͨ����� IP �Ƿ��� _controllers ���ж��Ƿ�ʵ�����ӡ�\r\n        \"\"\"\r\n        import json\r\n        from src.config_paths import REGISTRY_FILE, DEVICES_DIR\r\n        \r\n        try:\r\n            # v7.10: ��ȡ last_connected�����ڿ������ӣ�\r\n            if REGISTRY_FILE.exists():\r\n                registry = json.loads(REGISTRY_FILE.read_text(encoding='utf-8'))\r\n                last_mac = registry.get('last_connected', '').strip()\r\n                \r\n                # last_connected Ϊ�ձ�ʾ��δ���ӹ�\r\n            print(f'[PTZDeviceController] get_connected_device error: {e}')\r\n        \r\n        return None\r\n\r\n    # ================================================================\r\n    #  �豸��Ϣ��ȡ\r\n    # ================================================================\r\n\r\n    def get_device_info(self, ip: str) -> dict:\r\n        \"\"\"ͨ�� ISAPI ��ȡ�豸��ϸ��Ϣ��\"\"\"\r\n        if ip not in self._clients:\r\n            # �����Զ�����\r\n            creds = self.get_credentials(ip)\r\n            if creds:\r\n                client = ISAPIClient(ip=ip, username=creds[\"username\"],\r\n                                     password=creds[\"password\"], port=creds.get(\"port\", 80))","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783272828283}}
