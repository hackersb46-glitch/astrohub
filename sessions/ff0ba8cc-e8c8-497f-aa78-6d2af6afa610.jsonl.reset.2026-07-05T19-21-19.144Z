                      \"duration\": 0.05,\r\n<=                        \"message\": f\"�������(����={contrast:.1f},Ŀ��={self._best1_value:.1f}),���뾫��\"\r\n<=                    \"\"\"�����׶Σ��޲������ƣ�Խ��best�����������ޱƽ���\"\"\"\r\n<=                    # ����best2��best3\r\n<=                    if contrast > self._best3_value:\r\n<=                    # best2 >= best1 �� �ɹ�\r\n<=                            \"best3\": self._best3_value\r\n<=                    # Խ��best �� �������򣨷���ӷ�ֵ�½�1��������\r\n<=                    if contrast < self._best2_value:\r\n<=                        action = \"focus_near\" if self._fine_direction < 0 else \"focus_far\"\r\n<=                            \"action\": action, \"duration\": 0.05,\r\n<=                            \"message\": f\"Խ��best����(��{self._approach_step},best2={self._best2_value:.1f},Ŀ��={se��\r\n<=                        \"stage\": \"approach\", \"contrast\": round(contrast, 2),\r\n<=                    \"\"\"���ƽ̹����\"\"\"\r\n<=                    \"\"\"ִ������\"\"\"\r\n<=                \"\"\"�Խ�����ִ����\"\"\"\r\n<=                def __init__(self, mgr, device_ip, client, x, y, w, h, capture_func, cleanup_func, mac_clean=\"\"):\r\n<=                    self._interrupted = False  # v8.41: �жϱ�־\r\n<=                    self._mac_clean = mac_clean  # v8.47: ���ڱ�������\r\n<=                def _interrupt(self):\r\n<=                    \"\"\"v8.41: �ж϶Խ�����\"\"\"\r\n<=                    self._interrupted = True\r\n<=                        # v8.41: ����ж�\r\n<=                        if self._interrupted:\r\n<=                            await asyncio.to_thread(self._stop_focus)\r\n<=                            yield f\"data: {json.dumps({\r\n<=                                'type': 'interrupt',\r\n<=                                'message': '�û�ֹͣ'\r\n<=                            })}\\n\\n\"\r\n<=                            # ��֤\r\n<=                            # v8.47: ����Խ�ģʽ\r\n<=           