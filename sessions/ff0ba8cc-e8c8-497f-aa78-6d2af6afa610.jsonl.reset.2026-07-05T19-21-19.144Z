lse, \"message\": f\"设置对焦模式失败: {result.status_code}\"}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": f\"设置对焦模式失败: {e}\"}\r\n\n[3360 more lines in file. Use offset=1020 to continue.]"}],"isError":false,"timestamp":1783273199768}}
