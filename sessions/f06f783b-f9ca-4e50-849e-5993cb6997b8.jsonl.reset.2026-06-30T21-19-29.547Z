{"type":"message","id":"0a4da96e","parentId":"7a91c77b","timestamp":"2026-06-30T12:32:23.562Z","message":{"role":"toolResult","toolCallId":"tool-6fdcbfa1d3004c7782e60ad362f4b2b0","toolName":"read","content":[{"type":"text","text":"    } else if (results.speed_map !== undefined || results.pan_speed !== undefined) {\r\n        // 速度测试结果\r\n        let html = '<div style=\"font-size:12px\">';\r\n        html += '<div style=\"margin-bottom:8px;font-weight:600;color:#58a6ff\">⚡ 速度测试结果</div>';\r\n        html += '<div style=\"margin-bottom:8px;color:#8b949e\">';\r\n        html += '档位: <b>' + (results.speed_profile || '-') + '</b> | ';\r\n        html += '测试数: <b>' + (results.total_tests || 0) + '</b>';\r\n        html += '</div>';\r\n        \r\n        // Speed table\r\n        if (results.pan_speed || results.tilt_speed) {\r\n            html += '<table style=\"width:100%;font-size:11px;border-collapse:collapse;margin-top:8px\">';\r\n            html += '<tr style=\"border-bottom:1px solid #30363d\"><th style=\"text-align:left;padding:4px\">速度档位</th><th style=\"text-align:center;padding:4px\">Pan (°/s)</th><th style=\"text-align:right;padding:4px\">Tilt (°/s)</th></tr>';\r\n            \r\n            const panSpeed = results.pan_speed || {};\r\n            const tiltSpeed = results.tilt_speed || {};\r\n            const allLevels = new Set([...Object.keys(panSpeed), ...Object.keys(tiltSpeed)]);\r\n            \r\n            for (const level of Array.from(allLevels).sort((a,b) => a - b)) {\r\n                html += '<tr style=\"border-bottom:1px solid #21262d\">';\r\n                html += '<td style=\"padding:4px\">' + level + '</td>';\r\n                html += '<td style=\"text-align:center;padding:4px\">' + (panSpeed[level] || '-') + '</td>';\r\n                html += '<td style=\"text-align:right;padding:4px\">' + (tiltSpeed[level] || '-') + '</td>';\r\n                html += '</tr>';\r\n            }\r\n            html += '</table>';\r\n        }\r\n        html += '</div>';\r\n        resultEl.innerHTML = html;\r\n    } else {\r\n        // 功能测试结果\r\n        let html = '<table style=\"width:100%;font-size:11px;border-collapse:collapse\">';\r\n        html += '<tr style=\"border-bottom:1px solid #30363d\"><th style=\"text-align:left;padding:4px\">项目</th><th style=\"text-align:center;padding:4px\">支持</th><th style=\"text-align:right;padding:4px\">范围</th></tr>';\r\n\r\n        for (const [key, val] of Object.entries(results)) {\r\n            if (typeof val === 'object' && val !== null) {\r\n                const label = val.label || key;\r\n                const supported = val.supported ? 'Y' : 'N';\r\n                // v7.52: 兼容两种字段名：min/min_val, max/max_val\r\n                const range = (val.min || val.min_val || '-') + '~' + (val.max || val.max_val || '-');\r\n                html += '<tr style=\"border-bottom:1px solid #21262d\"><td style=\"padding:4px\">' + label + '</td><td style=\"text-align:center;padding:4px\">' + supported + '</td><td style=\"text-align:right;padding:4px\">' + range + '</td></tr>';\r\n            }\r\n        }\r\n\r\n        html += '</table>';\r\n        resultEl.innerHTML = html;\r\n    }\r\n}\r\n\r\n// 更新视频状态\r\n\n[409 more lines in file. Use offset=451 to continue.]"}],"isError":false,"timestamp":1782822743562}}
