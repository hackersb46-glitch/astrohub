基础\n+ 389     devices: dict[str, dict[str, Any]] = {}\n  401     for dev in stored:\n- 402         mac_norm = _normalize_mac(dev.get(\"mac\", \"\") or \"\")\n- 403         if mac_norm:\n- 404             keyed[mac_norm] = {\n- 405                 \"mac\": mac_norm,\n+ 391         mac = _normalize_mac(dev.get(\"mac\", \"\") or \"\")\n+ 392         if mac:\n+ 393             devices[mac] = {\n+ 394                 \"mac\": mac,\n  406                 \"ip\": dev.get(\"ip\", \"\"),\n- 407                 \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),  # 用户设置的名称\n- 408                 \"model\": dev.get(\"model\", \"\"),  # 设备型号\n- 409                 \"gateway\": dev.get(\"gateway\", \"\"),  # v6.01\n- 410                 \"subnet_mask\": dev.get(\"subnet_mask\", \"\"),  # v6.01\n- 411                 \"source\": \"manual\",\n- 412                 \"online\": False,  # updated later\n- 413                 \"activated\": False,\n+ 396                 \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\"),\n+ 397                 \"model\": dev.get(\"model\", \"\"),\n+ 398                 \"gateway\": dev.get(\"gateway\", \"\"),\n+ 399                 \"subnet_mask\": dev.get(\"subnet_mask\", \"\"),\n  414                 \"has_credentials\": True,\n  415             }\n- 416         else:\n- 417             no_mac.append({\n- 418                 \"mac\": \"\",\n- 419                 \"ip\": dev.get(\"ip\", \"\"),\n- 420                 \"name\": dev.get(\"name\", \"\") or dev.get(\"device_name\", \"\") or f\"PTZ-{dev.get('ip', '')}\",  # v7.16: 简化名称\n- 421                 \"model\": dev.get(\"model\", \"\") or \"PTZ\",  # v7.16: 简化型号\n- 422                 \"source\": \"manual\",\n- 423                 \"online\": False,\n- 424                 \"activated\": False,\n- 425                 \"has_credentials\": True,\n- 426             })\n  427 \n- 428     # --- Pass 2: 合并 SADP 发现设备 ---\n+ 403     # SADP发现：更新或新增\n  429     for sadp in discovered:\n- 430         sadp_mac = _normalize_mac(sadp.get(\"mac\", \"\") or \"\")\n- 431         if sadp_mac and sadp_mac in keyed:\n- 432             # 匹配到存储设备 → 合并\n- 433             existing = keyed[sadp_mac]\n- 434             existing[\"ip\"] = sadp.get(\"ip\") or existing[\"ip\"]\n- 435             existing[\"model\"] = sadp.get(\"model\") or existing[\"model\"]\n- 436             # name: 优先保留用户设置的名称,否则用 SADP 发现的\n- 437             if not existing.get(\"name\"):\n- 438                 existing[\"name\"] = sadp.get(\"device_name\") or sadp.get(\"name\", \"\")\n- 439             existing[\"activated\"] = sadp.get(\"activated\", False)\n- 440             existing[\"gateway\"] = sadp.get(\"gateway\", \"\")\n- 441             existing[\"subnet_mask\"] = sadp.get(\"subnet_mask\", \"\")\n- 442             existing[\"source\"] = \"merged\"\n- 443         elif sadp_mac:\n- 444             # 新发现设备\n- 445             keyed[sadp_mac] = {\n- 446                 \"mac\": sadp_mac,\n+ 405         mac = _normalize_mac(sadp.get(\"mac\", \"\") or \"\")\n+ 406         if not mac:\n+ 407             continue\n+ 408         if mac in devices:\n+ 409             # 更新：SADP数据为准（IP可能变了）\n+ 410             devices[mac][\"ip\"] = sadp.get(\"ip\", \"\") or devices[mac][\"ip\"]\n+ 411             devices[mac][\"model\"] = sadp.get(\"model\", \"\") or devices[mac][\"model\"]\n+ 412             devices[mac][\"gateway\"] = sadp.get(\"gateway\", \"\")\n+ 413             devices[mac][\"subnet_mask\"] = sadp.get(\"subnet_mask\", \"\")\n+ 414         else:\n+ 415             # 新增：首次发现\n+ 416             devices[mac] = {\n+ 417                 \"mac\": mac,\n  447                 \"ip\": sadp.get(\"ip\", \"\"),\n- 448                 \"name\": sadp.get(\"device_name\") or sadp.get(\"name\", \"\") or f\"PTZ-{sadp.get('ip', '')}\",  # v7.16: 简化名称\n- 449                 \"model\": sadp.get(\"model\", \"\") or \"PTZ\",  # v7.16: 简化型号\n- 450                 \"source\": \"sadp\",\n- 451                 \"online\": False,\n- 452                 \"activated\": sadp.get(\"activated\", False),\n- 453                 \"has_credentials\": False,\n+ 419                 \"name\": sadp.get(\"device_name\", \"\") or sadp.get(\"name\", \"\"),\n+ 420                 \"model\": sadp.get(\"model\", \"\") or \"PTZ\",\n  454                 \"gateway\": sadp.get(\"gateway\", \"\"),\n  455                 \"subnet_mask\": sadp.get(\"subnet_mask\", \"\"),\n+ 423                 \"has_credentials\": False,\n  456             }\n  457 \n- 458     # --- 构建最终列表 + 在线状态 + v7.16: 按 IP 去重 ---\n- 459     # 优先保留有 MAC 的记录,无 MAC 的作为补充\n- 460     ip_to_device: dict[str, dict[str, Any]] = {}\n+ 426     return {\"success\": True, \"data\": list(devices.values()), \"total\": len(devices)}\n  461 \n- 462     # 先添加有 MAC 的设备\n- 463     for dev in keyed.values():\n- 464         ip = dev.get(\"ip\", \"\")\n- 465         if ip:\n- 466             ip_to_device[ip] = dev\n  467 \n- 468     # 再添加无 MAC 的设备(如果 IP 不重复)\n- 469     for dev in no_mac:\n- 470         ip = dev.get(\"ip\", \"\")\n- 471         if ip and ip not in ip_to_device:\n- 472             ip_to_device[ip] = dev\n- 473 \n- 474     all_devices = list(ip_to_device.values())\n- 475     for dev in all_devices:\n- 476         ip = dev.get(\"ip\", \"\")\n- 477         dev[\"online\"] = ip in online_ips\n- 478 \n- 479     return {\"success\": True, \"data\": all_devices, \"total\": len(all_devices)}\n- 480 \n- 481 \n  482 @api_router.get(\"/devices/active\", summary=\"获取上次连接的设备\", tags=[\"Devices\"])\n  483 async def get_active_device() -> dict:\n  484     \"\"\"v6.30: 获取上次连接的设备(用于快速连接)。\"\"\"\n  485     mgr: PTZDeviceController | None = _managers.get(\"ptz_controller\")  # type: ignore[assignment]\n      ...","firstChangedLine":372},"isError":false,"timestamp":1782835428514}}
