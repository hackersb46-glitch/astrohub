{"type":"message","id":"973fc60e","parentId":"e4573dff","timestamp":"2026-06-13T18:06:54.652Z","message":{"role":"assistant","content":[{"type":"text","text":"жүҫеҲ° API и·Ҝз”ұ `/ptz/{device_id}/function`гҖӮжҹҘзңӢе®Ңж•ҙе®һзҺ°пјҡ"},{"type":"toolCall","id":"call_632564f467c34537a5ee3ef1","name":"read","arguments":{"limit":80,"offset":2558,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":119639,"output":66,"cacheRead":0,"cacheWrite":0,"totalTokens":119705,"cost":{"input":0.119639,"output":0.0002112,"cacheRead":0,"cacheWrite":0,"total":0.11985019999999999}},"stopReason":"toolUse","timestamp":1781373994569,"responseId":"cht000dbe85@dx19ec22a2dd5b894142"}}
{"type":"message","id":"dac8f9e2","parentId":"973fc60e","timestamp":"2026-06-13T18:06:54.662Z","message":{"role":"toolResult","toolCallId":"call_632564f467c34537a5ee3ef1","toolName":"read","content":[{"type":"text","text":"# ================================================================ #\r\n\r\n@api_router.get(\"/ptz/{device_id}/function\", summary=\"иҺ·еҸ–и®ҫеӨҮеҠҹиғҪжҺўжөӢз»“жһң\", tags=[\"Image\"])\r\nasync def get_device_function(device_id: str) -> dict:\r\n    \"\"\"v6.33: д»Һ data/devices/{mac}/ иҜ»еҸ–и®ҫеӨҮеҠҹиғҪжҺўжөӢз»“жһңгҖӮ\r\n    \r\n    1. йҖҡиҝҮ IP жүҫеҲ°еҜ№еә”и®ҫеӨҮзҡ„ MAC\r\n    2. дҪҝз”Ё MAC иҜ»еҸ– data/devices/{mac}/function.json жҲ– function_*.json\r\n    3. дјҳе…ҲжңҖж–°ж—¶й—ҙжҲіж–Үд»¶пјҢе…¶ж¬Ўеӣәе®ҡеҗҚз§°\r\n    4. MAC дёҚеҢ№й…ҚеҲҷиҝ”еӣһй”ҷиҜҜ\r\n    \"\"\"\r\n    import json\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\", \"data\": None}\r\n    \r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ж— жі•и§Јжһҗи®ҫеӨҮж ҮиҜҶ: {device_id}\", \"data\": None}\r\n    \r\n    # v6.33: йҖҡиҝҮ IP жүҫеҲ° MACпјҢзЎ®дҝқж•°жҚ®еҢ№й…ҚжӯЈзЎ®и®ҫеӨҮ\r\n    from src.advanced.device_path import get_devices_dir, get_data_path_read\r\n    devices_dir = get_devices_dir()\r\n    \r\n    target_mac = None\r\n    for device_dir in devices_dir.iterdir():\r\n        if device_dir.is_dir():\r\n            info_file = device_dir / \"info.json\"\r\n            if info_file.exists():\r\n                try:\r\n                    info = json.loads(info_file.read_text(encoding=\"utf-8\"))\r\n                    if info.get(\"ip\") == target_ip:\r\n                        target_mac = device_dir.name  # MAC = зӣ®еҪ•еҗҚ\r\n                        break\r\n                except Exception:\r\n                    continue\r\n    \r\n    if not target_mac:\r\n        return {\"success\": False, \"message\": \"жңӘжүҫеҲ°иҜҘи®ҫеӨҮзҡ„и®ҫеӨҮзӣ®еҪ•\", \"data\": None}\r\n    \r\n    # v6.33: дҪҝз”Ё MAC иҜ»еҸ–еҠҹиғҪжҺўжөӢж•°жҚ®пјҲдјҳе…Ҳж—¶й—ҙжҲіж–Үд»¶пјү\r\n    func_file = get_data_path_read(None, target_mac, \"function\")\r\n    if func_file and func_file.exists():\r\n        try:\r\n            func_data = json.loads(func_file.read_text(encoding=\"utf-8\"))\r\n            return {\"success\": True, \"data\": func_data}\r\n        except Exception as e:\r\n            return {\"success\": False, \"message\": f\"иҜ»еҸ–еҠҹиғҪжҺўжөӢж•°жҚ®еӨұиҙҘ: {e}\", \"data\": None}\r\n    else:\r\n        return {\"success\": False, \"message\": \"жңӘжүҫеҲ°еҠҹиғҪжҺўжөӢж•°жҚ®пјҢиҜ·е…Ҳе®ҢжҲҗеҠҹиғҪжөӢиҜ•\", \"data\": None}\r\n\r\n\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/whitebalance\", summary=\"иҺ·еҸ–зҷҪе№іиЎЎи®ҫзҪ®\", tags=[\"Image\"])\r\nasync def get_whitebalance(device_id: str) -> dict:\r\n    \"\"\"иҺ·еҸ–и®ҫеӨҮзҷҪе№іиЎЎеҪ“еүҚи®ҫзҪ®гҖӮ\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ж— жі•и§Јжһҗи®ҫеӨҮж ҮиҜҶ: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"иҺ·еҸ–зҷҪе№іиЎЎеӨұиҙҘ: HTTP {resp.status_code}\"}\r\n\r\n        root = ET.fromstring(resp.xml)\r\n        result = {\"success\": True, \"data\": {}}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n\n[574 more lines in file. Use offset=2638 to continue.]"}],"isError":false,"timestamp":1781374014662}}
