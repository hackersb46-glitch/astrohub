{"type":"message","id":"1fe05e2c","parentId":"ff96077f","timestamp":"2026-06-13T19:31:50.781Z","message":{"role":"toolResult","toolCallId":"call_989f1f158a4e4408b2e37c82","toolName":"read","content":[{"type":"text","text":"\r\ndef _resolve_device_id_to_ip(mgr: \"PTZManager\", device_id: str) -> str | None:\r\n    \"\"\"и§Јжһҗ device_id дёәе®һйҷ… IP ең°еқҖгҖӮ\r\n\r\n    device_id еҸҜиғҪжҳҜ IP ең°еқҖжҲ– MAC ең°еқҖгҖӮ\r\n    - еҰӮжһңжҳҜ IP: зӣҙжҺҘиҝ”еӣһ\r\n    - еҰӮжһңжҳҜ MAC: д»Һ SADP еҸ‘зҺ°зј“еӯҳжҲ–е·ІеӯҳеӮЁи®ҫеӨҮдёӯжҹҘжүҫ IP\r\n    \"\"\"\r\n    import re\r\n    # еҲӨж–ӯжҳҜеҗҰдёә MAC ең°еқҖж јејҸ (еҶ’еҸ·гҖҒжЁӘжқ еҲҶйҡ”жҲ–ж— еҲҶйҡ”з¬Ұ)\r\n    mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n    # ж— еҲҶйҡ”з¬Ұ12дҪҚеҚҒе…ӯиҝӣеҲ¶ = MAC\r\n    if len(mac_clean) == 12 and re.match(r'^[0-9a-f]{12}$', mac_clean):\r\n        # жҳҜ MAC ең°еқҖпјҢе°қиҜ•д»ҺеҸ‘зҺ°зј“еӯҳдёӯжҹҘжүҫ\r\n        discovered = mgr.get_discovered_devices()\r\n        for dev in discovered:\r\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if dev_mac == mac_clean:\r\n                return dev.get(\"ip\")\r\n        # д»Һе·ІеӯҳеӮЁи®ҫеӨҮдёӯжҹҘжүҫ\r\n        stored = mgr.list_stored_devices()\r\n        for dev in stored:\r\n            dev_mac = dev.get(\"mac\", \"\").replace(\":\", \"\").replace(\"-\", \"\").lower()\r\n            if dev_mac == mac_clean:\r\n                ip = dev.get(\"ip\", \"\")\r\n                if ip:\r\n                    return ip\r\n        return None\r\n    # зңӢиө·жқҘеғҸ IP ең°еқҖпјҢзӣҙжҺҘиҝ”еӣһ\r\n    return device_id\r\n\r\n\r\n# ================================================================ #\r\n#  еҒҘеә·жЈҖжҹҘз«ҜзӮ№\r\n# ================================================================ #\r\n\r\n\r\n@health_router.get(\"/health\", summary=\"е…ЁеұҖеҒҘеә·жЈҖжҹҘ\")\r\nasync def global_health() -> dict:\r\n    \"\"\"е…ЁеұҖеҒҘеә·жЈҖжҹҘз«ҜзӮ№ (GET /api/v1/health)гҖӮ\"\"\"\r\n\n[3006 more lines in file. Use offset=235 to continue.]"}],"isError":false,"timestamp":1781379110781}}
