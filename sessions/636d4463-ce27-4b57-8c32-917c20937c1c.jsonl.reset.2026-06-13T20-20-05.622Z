{"type":"message","id":"ef2ac199","parentId":"b5abe324","timestamp":"2026-06-13T19:36:36.175Z","message":{"role":"toolResult","toolCallId":"call_c03baa2d1efc4a12b8962836","toolName":"read","content":[{"type":"text","text":"# ================================================================\r\n\r\n@api_router.get(\"/ptz/connected\", summary=\"иҺ·еҸ–е·ІиҝһжҺҘи®ҫеӨҮзҠ¶жҖҒ (v6.15)\", tags=[\"PTZ\"])\r\nasync def get_connected_device() -> dict:\r\n    \"\"\"v6.15: д»Һ registry.json иҺ·еҸ–еҪ“еүҚжҙ»и·ғи®ҫеӨҮдҝЎжҒҜгҖӮ\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\", \"connected\": False}\r\n    device = mgr.get_connected_device()\r\n    if not device:\r\n        return {\"success\": True, \"connected\": False, \"device\": None}\r\n    return {\"success\": True, \"connected\": True, \"device\": device}\r\n\r\n@api_router.get(\"/system/info\", summary=\"зі»з»ҹзЎ¬д»¶дҝЎжҒҜ (P1.1)\", tags=[\"System\"])\r\nasync def get_system_info() -> dict:\r\n    \"\"\"иҺ·еҸ–жң¬жңәзі»з»ҹзЎ¬д»¶дҝЎжҒҜ (hostname/CPU/RAM/GPU/VRAM)гҖӮ\"\"\"\r\n    try:\r\n        from src.ptz.core.system_info import collect_system_info\r\n        info = collect_system_info()\r\n        return {\"success\": True, \"data\": info}\r\n    except Exception as e:\r\n        return {\"success\": False, \"message\": str(e)}\r\n\r\n\r\n@api_router.get(\"/system/nics\", summary=\"зҪ‘з»ңжҺҘеҸЈеҲ—иЎЁ (P1.2)\", tags=[\"System\"])\r\n\n[2512 more lines in file. Use offset=729 to continue.]"}],"isError":false,"timestamp":1781379396175}}
{"type":"message","id":"4f706e78","parentId":"ef2ac199","timestamp":"2026-06-13T19:36:52.542Z","message":{"role":"assistant","content":[{"type":"text","text":"дҝ®еӨҚ `/ptz/connected` APIпјҢжЈҖжҹҘзңҹе®һиҝһжҺҘзҠ¶жҖҒпјҡ"},{"type":"toolCall","id":"call_796771d1e4ae405182ba4347","name":"edit","arguments":{"edits":[{"newText":"@api_router.get(\"/ptz/connected\", summary=\"иҺ·еҸ–е·ІиҝһжҺҘи®ҫеӨҮзҠ¶жҖҒ (v6.15)\", tags=[\"PTZ\"])\nasync def get_connected_device() -> dict:\n    \"\"\"v6.51: жЈҖжҹҘзңҹе®һиҝһжҺҘзҠ¶жҖҒпјҢиҝ”еӣһе·ІиҝһжҺҘи®ҫеӨҮдҝЎжҒҜгҖӮ\n    \n    иҝһжҺҘзҠ¶жҖҒеҲӨж–ӯпјҡжЈҖжҹҘ PTZManager._controllers жҳҜеҗҰеҢ…еҗ«иҜҘ IPгҖӮ\n    active_device з”ЁдәҺжүҖжңүеҠҹиғҪеӨҚз”ЁпјҢlast_connected д»…з”ЁдәҺеҝ«йҖҹиҝһжҺҘгҖӮ\n    \"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\", \"connected\": False}\n    \n    # жЈҖжҹҘжҳҜеҗҰжңүзңҹе®һиҝһжҺҘзҡ„жҺ§еҲ¶еҷЁ\n    connected_ips = list(mgr._controllers.keys())\n    if not connected_ips:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    \n    # иҺ·еҸ–з¬¬дёҖдёӘе·ІиҝһжҺҘи®ҫеӨҮзҡ„дҝЎжҒҜ\n    ip = connected_ips[0]\n    device_info = mgr.get_connected_device()\n    \n    # йӘҢиҜҒи®ҫеӨҮдҝЎжҒҜдёӯзҡ„ IP жҳҜеҗҰзңҹзҡ„е·ІиҝһжҺҘ\n    if device_info and device_info.get(\"ip\") in mgr._controllers:\n        return {\"success\": True, \"connected\": True, \"device\": device_info}\n    \n    # иҝ”еӣһе·ІиҝһжҺҘзҡ„ IP дҝЎжҒҜ\n    return {\n        \"success\": True, \n        \"connected\": True, \n        \"device\": {\n            \"ip\": ip,\n            \"mac\": \"\",\n            \"name\": \"\",\n            \"model\": \"\",\n            \"username\": \"\",\n            \"password\": \"\",\n            \"port\": 80,\n            \"device_name\": None\n        }\n    }","oldText":"@api_router.get(\"/ptz/connected\", summary=\"иҺ·еҸ–е·ІиҝһжҺҘи®ҫеӨҮзҠ¶жҖҒ (v6.15)\", tags=[\"PTZ\"])\nasync def get_connected_device() -> dict:\n    \"\"\"v6.15: д»Һ registry.json иҺ·еҸ–еҪ“еүҚжҙ»и·ғи®ҫеӨҮдҝЎжҒҜгҖӮ\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\", \"connected\": False}\n    device = mgr.get_connected_device()\n    if not device:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    return {\"success\": True, \"connected\": True, \"device\": device}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":97175,"output":650,"cacheRead":0,"cacheWrite":0,"totalTokens":97825,"cost":{"input":0.097175,"output":0.0020800000000000003,"cacheRead":0,"cacheWrite":0,"total":0.099255}},"stopReason":"toolUse","timestamp":1781379396176,"responseId":"cht000d9f10@dx19ec27c7babb91a742"}}
