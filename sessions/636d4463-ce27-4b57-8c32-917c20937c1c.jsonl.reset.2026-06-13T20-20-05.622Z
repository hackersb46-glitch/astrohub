{"type":"message","id":"8ed11ff5","parentId":"b102bf07","timestamp":"2026-06-13T19:45:42.539Z","message":{"role":"toolResult","toolCallId":"call_b1c2b90956a9443aa421783e","toolName":"read","content":[{"type":"text","text":"    \r\n    // v6.18: з®ҖеҢ–еҝ«йҖҹиҝһжҺҘ - зӣҙжҺҘд»ҺеҗҺз«ҜиҺ·еҸ–дёҠж¬Ўи®ҫеӨҮ\r\n    var _quickConnectSkipNext = false;\r\n    window.quickConnect = function(checked) {\r\n        if (_quickConnectSkipNext) {\r\n            _quickConnectSkipNext = false;\r\n            return;\r\n        }\r\n        if (checked) {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                console.log('[QUICK] Already connected');\r\n                return;\r\n            }\r\n            // v6.18: д»ҺеҗҺз«ҜиҺ·еҸ–дёҠж¬ЎиҝһжҺҘзҡ„и®ҫеӨҮ\r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.device) {\r\n                    console.log('[QUICK] Connecting to:', r.device.ip);\r\n                    if (window.connectDevice) {\r\n                        window.connectDevice(r.device.ip);\r\n                    }\r\n                } else {\r\n                    showToast('warning', 'ж— дёҠж¬ЎиҝһжҺҘи®ҫеӨҮпјҢиҜ·жү§иЎҢеҸ‘зҺ°жөҒзЁӢ');\r\n                    _quickConnectSkipNext = true;\r\n                    document.getElementById('quickConnectSwitch').checked = false;\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', 'иҺ·еҸ–и®ҫеӨҮдҝЎжҒҜеӨұиҙҘ');\r\n                _quickConnectSkipNext = true;\r\n                document.getElementById('quickConnectSwitch').checked = false;\r\n            });\r\n        } else {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                disconnectDevice(window.connectedDevice.ip);\r\n            }\r\n        }\r\n    };\r\n    \r\n    // зЎ®и®ӨйҮҚеҗҜ\r\n    window.confirmRestart = function() {\r\n        if (!confirm('зЎ®е®ҡиҰҒйҮҚеҗҜ AstroHub еҗ—пјҹ\\nйҮҚеҗҜжңҹй—ҙжңҚеҠЎе°ҶжҡӮж—¶дёҚеҸҜз”ЁгҖӮ')) return;\r\n        \r\n        showToast('info', 'жӯЈеңЁйҮҚеҗҜ AstroHub...');\r\n        \r\n        // и°ғз”ЁйҮҚеҗҜ API\r\n        apiPost('/api/v1/system/restart', null).then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', 'йҮҚеҗҜдёӯпјҢ10з§’еҗҺиҮӘеҠЁеҲ·ж–°йЎөйқў...');\r\n                setTimeout(function() {\r\n                    location.reload();\r\n                }, 10000);\r\n            } else {\r\n                showToast('error', r ? r.message : 'йҮҚеҗҜеӨұиҙҘ');\r\n            }\r\n        }).catch(function(e) {\r\n            // еҚідҪҝиҜ·жұӮеӨұиҙҘпјҢд№ҹеҒҮи®ҫйҮҚеҗҜжҲҗеҠҹпјҲжңҚеҠЎе·ІеҒңжӯўпјү\r\n            showToast('warning', 'йҮҚеҗҜдёӯпјҢ10з§’еҗҺиҮӘеҠЁеҲ·ж–°йЎөйқў...');\r\n            setTimeout(function() {\r\n                location.reload();\r\n            }, 10000);\r\n        });\r\n\n[21 more lines in file. Use offset=2723 to continue.]"}],"isError":false,"timestamp":1781379942539}}
{"type":"message","id":"51e84812","parentId":"8ed11ff5","timestamp":"2026-06-13T19:46:11.379Z","message":{"role":"assistant","content":[{"type":"text","text":"жүҫеҲ°й—®йўҳпјҒеҝ«йҖҹиҝһжҺҘи°ғз”Ё `/api/v1/ptz/connected`пјҢдҪҶжҲ‘зҡ„дҝ®ж”№и®©иҝҷдёӘ API еңЁи®ҫеӨҮжңӘиҝһжҺҘж—¶иҝ”еӣһ `connected: false`пјҢеҜјиҮҙеҝ«йҖҹиҝһжҺҘж— жі•е·ҘдҪңгҖӮ\n\n**й—®йўҳеҲҶжһҗ**пјҡ\n- `quickConnect` йңҖиҰҒ `last_connected` и®ҫеӨҮдҝЎжҒҜиҝӣиЎҢеҝ«йҖҹйҮҚиҝһ\n- дҪҶ `/ptz/connected` зҺ°еңЁжЈҖжҹҘзңҹе®һиҝһжҺҘзҠ¶жҖҒпјҢжңӘиҝһжҺҘж—¶иҝ”еӣһ `device: null`\n- еҜјиҮҙеҝ«йҖҹиҝһжҺҘж— жі•иҺ·еҸ–дёҠж¬ЎиҝһжҺҘзҡ„и®ҫеӨҮдҝЎжҒҜ\n\n**и§ЈеҶіж–№жЎҲ**пјҡж–°еўһдёҖдёӘ API иҝ”еӣһ `last_connected` и®ҫеӨҮдҝЎжҒҜпјҢжҲ–дҝ®ж”№зҺ°жңүйҖ»иҫ‘гҖӮ\n\nжӯЈзЎ®зҡ„еҒҡжі•жҳҜпјҡ\n1. `/ptz/connected` иҝ”еӣһ**зңҹе®һиҝһжҺҘзҠ¶жҖҒ**пјҲеҪ“еүҚе·ІиҝһжҺҘзҡ„и®ҫеӨҮпјү\n2. ж–°еўһ `/ptz/last_connected` иҝ”еӣһдёҠж¬ЎиҝһжҺҘзҡ„и®ҫеӨҮдҝЎжҒҜпјҲз”ЁдәҺеҝ«йҖҹиҝһжҺҘпјү\n\nеӨҮд»Ҫе№¶дҝ®еӨҚпјҡ"},{"type":"toolCall","id":"call_db7dc4d68c6f482f87574cd3","name":"edit","arguments":{"edits":[{"newText":"@api_router.get(\"/ptz/connected\", summary=\"иҺ·еҸ–е·ІиҝһжҺҘи®ҫеӨҮзҠ¶жҖҒ (v6.15)\", tags=[\"PTZ\"])\nasync def get_connected_device() -> dict:\n    \"\"\"v6.51: жЈҖжҹҘзңҹе®һиҝһжҺҘзҠ¶жҖҒпјҢиҝ”еӣһе·ІиҝһжҺҘи®ҫеӨҮдҝЎжҒҜгҖӮ\n    \n    иҝһжҺҘзҠ¶жҖҒеҲӨж–ӯпјҡжЈҖжҹҘ PTZManager._controllers жҳҜеҗҰеҢ…еҗ«иҜҘ IPгҖӮ\n    active_device з”ЁдәҺжүҖжңүеҠҹиғҪеӨҚз”ЁпјҢlast_connected д»…з”ЁдәҺеҝ«йҖҹиҝһжҺҘгҖӮ\n    \"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\", \"connected\": False}\n    \n    # жЈҖжҹҘжҳҜеҗҰжңүзңҹе®һиҝһжҺҘзҡ„жҺ§еҲ¶еҷЁ\n    connected_ips = list(mgr._controllers.keys())\n    if not connected_ips:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    \n    # иҺ·еҸ–з¬¬дёҖдёӘе·ІиҝһжҺҘи®ҫеӨҮзҡ„дҝЎжҒҜ\n    ip = connected_ips[0]\n    device_info = mgr.get_connected_device()\n    \n    # йӘҢиҜҒи®ҫеӨҮдҝЎжҒҜдёӯзҡ„ IP жҳҜеҗҰзңҹзҡ„е·ІиҝһжҺҘ\n    if device_info and device_info.get(\"ip\") in mgr._controllers:\n        return {\"success\": True, \"connected\": True, \"device\": device_info}\n    \n    # иҝ”еӣһе·ІиҝһжҺҘзҡ„ IP дҝЎжҒҜ\n    return {\n        \"success\": True, \n        \"connected\": True, \n        \"device\": {\n            \"ip\": ip,\n            \"mac\": \"\",\n            \"name\": \"\",\n            \"model\": \"\",\n            \"username\": \"\",\n            \"password\": \"\",\n            \"port\": 80,\n            \"device_name\": None\n        }\n    }\n\n\n@api_router.get(\"/ptz/last_connected\", summary=\"иҺ·еҸ–дёҠж¬ЎиҝһжҺҘзҡ„и®ҫеӨҮдҝЎжҒҜ\", tags=[\"PTZ\"])\nasync def get_last_connected_device() -> dict:\n    \"\"\"v6.52: иҺ·еҸ–дёҠж¬ЎиҝһжҺҘзҡ„и®ҫеӨҮдҝЎжҒҜпјҲз”ЁдәҺеҝ«йҖҹиҝһжҺҘпјүгҖӮ\"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\", \"device\": None}\n    \n    device_info = mgr.get_connected_device()\n    if not device_info:\n        return {\"success\": True, \"device\": None}\n    \n    return {\"success\": True, \"device\": device_info}","oldText":"@api_router.get(\"/ptz/connected\", summary=\"иҺ·еҸ–е·ІиҝһжҺҘи®ҫеӨҮзҠ¶жҖҒ (v6.15)\", tags=[\"PTZ\"])\nasync def get_connected_device() -> dict:\n    \"\"\"v6.51: жЈҖжҹҘзңҹе®һиҝһжҺҘзҠ¶жҖҒпјҢиҝ”еӣһе·ІиҝһжҺҘи®ҫеӨҮдҝЎжҒҜгҖӮ\n    \n    иҝһжҺҘзҠ¶жҖҒеҲӨж–ӯпјҡжЈҖжҹҘ PTZManager._controllers жҳҜеҗҰеҢ…еҗ«иҜҘ IPгҖӮ\n    active_device з”ЁдәҺжүҖжңүеҠҹиғҪеӨҚз”ЁпјҢlast_connected д»…з”ЁдәҺеҝ«йҖҹиҝһжҺҘгҖӮ\n    \"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\", \"connected\": False}\n    \n    # жЈҖжҹҘжҳҜеҗҰжңүзңҹе®һиҝһжҺҘзҡ„жҺ§еҲ¶еҷЁ\n    connected_ips = list(mgr._controllers.keys())\n    if not connected_ips:\n        return {\"success\": True, \"connected\": False, \"device\": None}\n    \n    # иҺ·еҸ–з¬¬дёҖдёӘе·ІиҝһжҺҘи®ҫеӨҮзҡ„дҝЎжҒҜ\n    ip = connected_ips[0]\n    device_info = mgr.get_connected_device()\n    \n    # йӘҢиҜҒи®ҫеӨҮдҝЎжҒҜдёӯзҡ„ IP жҳҜеҗҰзңҹзҡ„е·ІиҝһжҺҘ\n    if device_info and device_info.get(\"ip\") in mgr._controllers:\n        return {\"success\": True, \"connected\": True, \"device\": device_info}\n    \n    # иҝ”еӣһе·ІиҝһжҺҘзҡ„ IP дҝЎжҒҜ\n    return {\n        \"success\": True, \n        \"connected\": True, \n        \"device\": {\n            \"ip\": ip,\n            \"mac\": \"\",\n            \"name\": \"\",\n            \"model\": \"\",\n            \"username\": \"\",\n            \"password\": \"\",\n            \"port\": 80,\n            \"device_name\": None\n        }\n    }"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":106706,"output":1221,"cacheRead":0,"cacheWrite":0,"totalTokens":107927,"cost":{"input":0.106706,"output":0.0039072,"cacheRead":0,"cacheWrite":0,"total":0.1106132}},"stopReason":"toolUse","timestamp":1781379942541,"responseId":"cht000d1ec2@dx19ec284d6cdba5c342"}}
