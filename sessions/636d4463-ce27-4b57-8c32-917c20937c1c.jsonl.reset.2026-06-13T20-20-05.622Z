{"type":"message","id":"51a8ffec","parentId":"6df42537","timestamp":"2026-06-13T18:59:26.052Z","message":{"role":"toolResult","toolCallId":"call_2ac49dd38fcd47dba241347c","toolName":"read","content":[{"type":"text","text":"\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/whitebalance\", summary=\"иҺ·еҸ–зҷҪе№іиЎЎи®ҫзҪ®\", tags=[\"Image\"])\r\nasync def get_whitebalance(device_id: str) -> dict:\r\n    \"\"\"иҺ·еҸ–и®ҫеӨҮзҷҪе№іиЎЎеҪ“еүҚи®ҫзҪ®гҖӮ\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"ж— жі•и§Јжһҗи®ҫеӨҮж ҮиҜҶ: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"иҺ·еҸ–зҷҪе№іиЎЎеӨұиҙҘ: HTTP {resp.status_code}\"}\r\n\r\n        root = ET.fromstring(resp.xml)\r\n        result = {\"success\": True, \"data\": {}}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n            if tag == \"WhiteBalanceStyle\":\r\n                result[\"data\"][\"mode\"] = (elem.text or \"manual\").lower()\r\n\n[572 more lines in file. Use offset=2640 to continue.]"}],"isError":false,"timestamp":1781377166052}}
