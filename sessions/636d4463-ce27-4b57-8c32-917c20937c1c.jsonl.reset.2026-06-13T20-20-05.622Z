{"type":"message","id":"2a996e33","parentId":"248062b3","timestamp":"2026-06-13T17:11:16.582Z","message":{"role":"toolResult","toolCallId":"tool-a5bdceddac5c4e928d75a94a5806ec13","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\n            <h2 style=\"font-size:18px;margin-bottom:8px\">дё»жҺ§еҸ°</h2>\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px\">\n                <div class=\"status-item\">\n                    <span class=\"status-dot red\" id=\"deviceDot\"></span>\n                    <span id=\"deviceStatus\">жңӘиҝһжҺҘ</span>\n                </div>\n            </div>\n            <div id=\"ptzControlArea\">\n                <!-- е·ҰеҸіеёғеұҖ: е·ҰжҺ§еҲ¶, дёӯй—ҙз”»йқў+еӘ’дҪ“, еҸіж—Ҙеҝ—+з”»йқўжҺ§еҲ¶ -->\n                <div class=\"console-layout\">\n                    <!-- е·Ұ: PTZжҺ§еҲ¶пјҲж•ҙеҗҲпјҡжҢҮеҗ‘+йў„зҪ®зӮ№+еҸҳз„Ұ/еҜ№з„Ұпјү -->\n                    <div class=\"console-left\">\n                        <!-- PTZжҺ§еҲ¶пјҲжҠҳеҸ пјү -->\n                        <div class=\"collapsible-section collapsed\" id=\"ptzControlSection\">\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">рҹҺҜ PTZжҺ§еҲ¶</h3>\n                                <span class=\"collapse-icon\">в–ј</span>\n                            </div>\n                            <div class=\"collapsible-content\">\n                                <!-- жҢҮеҗ‘жҺ§еҲ¶ -->\n                                <div class=\"section-subtitle\">жҢҮеҗ‘</div>\n                                <div class=\"ptz-controls\">\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">вҶ–</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">вҶ‘</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">вҶ—</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">вҶҗ</button>\n                                    <button class=\"ptz-btn center\">в—Ҹ</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">вҶ’</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">вҶҷ</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">вҶ“</button>\n                                    <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">вҶҳ</button>\n                                </div>\n                                <div class=\"ptz-speed\">\n                                    <label>йҖҹеәҰ:</label>\n                                    <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"100\" value=\"50\">\n                                    <span id=\"ptzSpeedVal\">50</span>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;margin-top:8px\">\n                                    <button class=\"btn btn-primary\" onclick=\"ptzHome()\">еҪ’дҪҚ</button>\n                                    <button class=\"btn btn-warning\" onclick=\"ptzStop()\">еҒңжӯў</button>\n                                </div>\n                                <div class=\"ptz-position\" id=\"ptzPosition\" style=\"margin-top:8px\">\n                                    Pan: -- | Tilt: -- | Zoom: --\n                                </div>\n                                <!-- йў„зҪ®зӮ№ -->\n                                <div class=\"section-subtitle\">йў„зҪ®зӮ№</div>\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:120px\">\n                                        <option value=\"\">йҖүжӢ©йў„зҪ®зӮ№</option>\n                                    </select>\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">еүҚеҫҖ</button>\n                                    <button class=\"btn btn-warning btn-sm\" onclick=\"ptzSetSelectedPreset()\">дҝқеӯҳ</button>\n                                </div>\n                                <div id=\"ptzPresetResult\" style=\"font-size:12px;color:#8b949e;text-align:center\"></div>\n                                <!-- еҸҳз„Ұ/еҜ№з„Ұ -->\n                                <div class=\"section-subtitle\">еҸҳз„Ұ/еҜ№з„Ұ</div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b949e;font-size:13px\">з„Ұи·қ:</span>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">рҹ”Қ+</button>\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">рҹ”Қ-</button>\n                                </div>\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\n                                    <span style=\"color:#8b9