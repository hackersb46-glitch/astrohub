{"type":"message","id":"c6381657","parentId":"a4ceb61b","timestamp":"2026-06-13T18:18:39.577Z","message":{"role":"toolResult","toolCallId":"call_c398570026d3428087476227","toolName":"read","content":[{"type":"text","text":"    if (el) el.textContent = value;\n    \n    var key = type === 'spatial' ? 'spatial_level' : 'temporal_level';\n    var label = type === 'spatial' ? 'з©әеҹҹйҷҚеҷӘ' : 'ж—¶еҹҹйҷҚеҷӘ';\n    \n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', { [key]: parseInt(value) })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', label + ': ' + value);\n            }\n        });\n}\n\n// еҠ иҪҪжӣқе…үжЁЎејҸ\nfunction loadExposure(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\n        if (r && r.success && r.data) {\n            var select = document.getElementById('exposureMode');\n            if (select && r.data.mode) {\n                // v5.47: еҸӘж”ҜжҢҒ auto/manualпјҢе…¶д»–жЁЎејҸз»ҹдёҖдёә manual\n                select.value = (r.data.mode === 'auto') ? 'auto' : 'manual';\n                // жӣҙж–°еҝ«й—Ёе…үеңҲзҰҒз”ЁзҠ¶жҖҒ\n                updateShutterIrisState();\n            }\n        }\n    }).catch(function(e) {\n        console.warn('[Exposure] Load failed:', e);\n    });\n}\n\n// и®ҫзҪ®жӣқе…үжЁЎејҸ\nfunction setExposureMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) showToast('success', 'жӣқе…үжЁЎејҸ: ' + (mode === 'manual' ? 'жүӢеҠЁ' : 'иҮӘеҠЁ'));\n        });\n    // v5.47: иҮӘеҠЁжЁЎејҸдёӢзҰҒз”Ёеҝ«й—Ёе…үеңҲ\n    updateShutterIrisState();\n}\n\n// v5.47: жӣҙж–°еҝ«й—Ёе…үеңҲзҰҒз”ЁзҠ¶жҖҒ\nfunction updateShutterIrisState() {\n    var exposureMode = document.getElementById('exposureMode');\n    var shutterSelect = document.getElementById('shutterSpeed');\n    var irisSelect = document.getElementById('irisLevel');\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\n    \n    var isManual = exposureMode.value === 'manual';\n\n[135 more lines in file. Use offset=940 to continue.]"}],"isError":false,"timestamp":1781374719577}}
