False, \"message\": f\"и®ҫзҪ®йҷҚеҷӘејӮеёё: {e}\"}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/exposure\", summary=\"иҺ·еҸ–жӣқе…үжЁЎејҸ\", tags=[\"Image\"])\r\nasync def get_exposure(device_id: str) -> dict:\r\n    \"\"\"иҺ·еҸ–и®ҫеӨҮжӣқе…үеҪ“еүҚжЁЎејҸгҖӮ\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager жңӘеҲқе§ӢеҢ–\"}\r\n\n[427 more lines in file. Use offset=2785 to continue.]"}],"isError":false,"timestamp":1781377171165}}
