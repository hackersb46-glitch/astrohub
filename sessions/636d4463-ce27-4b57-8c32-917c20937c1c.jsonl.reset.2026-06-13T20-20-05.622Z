t.getElementById('wasmDot');\r\n        var wasmStatus = document.getElementById('wasmStatus');\r\n        if (!wasmDot || !wasmStatus) return;\r\n        \r\n        if (state === 'connecting') {\r\n            wasmDot.className = 'status-dot yellow';\r\n            wasmStatus.textContent = 'и§Ҷйў‘: иҝһжҺҘдёӯ';\r\n        } else if (state === 'connected') {\r\n            // v6.45: е·ІиҝһжҺҘдҪҶжңӘж’ӯж”ҫпјҢжҳҫзӨәвҖңзӯүеҫ…жёІжҹ“вҖқ\r\n            wasmDot.className = 'status-dot yellow';\r\n            wasmStatus.textContent = 'и§Ҷйў‘: зӯүеҫ…жёІжҹ“';\r\n        } else if (state === 'playing') {\r\n            // v6.45: ж’ӯж”ҫжҲҗеҠҹ\r\n            wasmDot.className = 'status-dot green';\r\n            wasmStatus.textContent = 'и§Ҷйў‘: ж’ӯж”ҫдёӯ';\r\n        } else if (state === 'disconnected') {\r\n            wasmDot.className = 'status-dot red';\r\n            wasmStatus.textContent = 'и§Ҷйў‘: жңӘиҝһжҺҘ';\r\n        }\r\n    };\r\n    \r\n    // v6.18: з®ҖеҢ–еҝ«йҖҹиҝһжҺҘ - зӣҙжҺҘд»ҺеҗҺз«ҜиҺ·еҸ–дёҠж¬Ўи®ҫеӨҮ\r\n    var _quickConnectSkipNext = false;\r\n    window.quickConnect = function(checked) {\r\n        if (_quickConnectSkipNext) {\r\n            _quickConnectSkipNext = false;\r\n            return;\r\n        }\r\n        if (checked) {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                console.log('[QUICK] Already connected');\r\n                return;\r\n            }\r\n            // v6.18: д»ҺеҗҺз«ҜиҺ·еҸ–дёҠж¬ЎиҝһжҺҘзҡ„и®ҫеӨҮ\r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.device) {\r\n                    console.log('[QUICK] Connecting to:', r.device.ip);\r\n\n[64 more lines in file. Use offset=2680 to continue.]"}],"isError":false,"timestamp":1781373622707}}
