{"type":"message","id":"52dbc998","parentId":"d07098b7","timestamp":"2026-06-13T17:59:46.821Z","message":{"role":"toolResult","toolCallId":"tool-8cdd91c25cf94011a4accef3b3b04db8","toolName":"read","content":[{"type":"text","text":"        }\r\n        // еҜ№з„ҰжҺ§еҲ¶пјҡзӣҙжҺҘеҸ‘йҖҒз§»еҠЁжҢҮд»ӨпјҢдёҚејәеҲ¶еҲҮжҚўжЁЎејҸ\r\n        function ptzFocus(mode) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', 'иҜ·е…ҲйҖүжӢ©и®ҫеӨҮ'); return; }\r\n            \r\n            var dir = mode === 'near' ? 'focus-near' : mode === 'far' ? 'focus-far' : 'focus-auto';\r\n            // Focus еӣәе®ҡдҪҝз”Ё speed=60пјҢдёҚдҪҝз”Ёж»‘еқ—\r\n            var speed = 60;\r\n            \r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir,\r\n                speed: speed\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', 'еҜ№з„Ұ: ' + mode);\r\n                } else {\r\n                    showToast('error', result ? result.message : 'еҜ№з„ҰеӨұиҙҘ');\r\n                }\r\n            }).catch(function(e) { showToast('error', 'еҜ№з„ҰејӮеёё: ' + e.message); });\r\n        }\r\n        function setFocusMode(mode) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', 'иҜ·е…ҲйҖүжӢ©и®ҫеӨҮ'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/focus/mode', { mode: mode }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', 'еҜ№з„ҰжЁЎејҸ: ' + mode);\r\n                } else {\r\n                    showToast('error', result ? result.message : 'и®ҫзҪ®еӨұиҙҘ');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', 'и®ҫзҪ®ејӮеёё: ' + e.message);\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  BUG-017 дҝ®еӨҚ: жҡҙйңІеҮҪж•°еҲ°е…ЁеұҖ windowпјҢдҪҝ HTML onclick еҸҜи°ғз”Ё\r\n        //  и®ҫеӨҮз®ЎзҗҶйЎөйқўжҢүй’®пјҲеҸ‘зҺ°/ж·»еҠ /еҲ·ж–°пјүд»ҘеҸҠе…¶д»–йЎөйқўдәӨдә’зҡ„\r\n        //  onclick еӨ„зҗҶзЁӢеәҸе®ҡд№үеңЁ IIFE еҶ…йғЁпјҢеҝ…йЎ»жҳҫејҸжҡҙйңІеҲ°е…ЁеұҖгҖӮ\r\n        // ================================================================\r\n        var _expose = [\r\n            discoverDevices, refreshDevices,\r\n            connectDevice, disconnectDevice, deleteDevice,\r\n            ptzMove, ptzHome, ptzStop, getPtzPosition, onPtzDeviceChange,\r\n            calibrate, saveSettings,\r\n            funcDetectRun, funcDetectRestore,\r\n            limitTestRun, speedTestRun,\r\n            streamStart, streamStop, recordStart, recordStop, snapshotCapture,\r\n            onStreamDeviceChange, resetStreamButtons,\r\n            presetGoto, presetSet, startDetection,\r\n            connectFuncDetectRun, connectLimitTestRun, connectSpeedTestRun,\r\n            // дё»жҺ§еҸ°ж–°еўһ (дҝ®еӨҚ6)\r\n            setTracking, consoleSnapshot, consoleRecordStart, consoleRecordStop,\r\n             adjustImage, adjustImageStep, togglePtzOsd, toggleInfoOsd,\r\n            ptzZoom, ptzFocus, setFocusMode,\r\n            // йў„зҪ®зӮ№еҲ—иЎЁз®ЎзҗҶ\r\n            loadPresetList, ptzGotoSelectedPreset, ptzSetSelectedPreset,\r\n            addDeviceInline, modifyIpPrompt, showDeviceInfoInline,\r\n            // WASM logout\r\n            wasmLogout,\r\n            // е·Ҙе…·еҮҪж•°\r\n            showToast, addLog,\r\n            // Live Stack е®һж—¶еҸ еҠ \r\n            setLiveStackMode, startLiveStack, stopLiveStack, saveLiveStack,\r\n        ];\r\n        _expose.forEach(function(fn) { window[fn.name] = fn; });\r\n        // Go! - init() executes immediately for instant page interaction\r\n        init();\r\n        function loadWasmDevices() {\r\n            var sel = document.getElementById('device-select');\r\n            if (!sel) return;\r\n            var currentVal = sel.value;\r\n            apiGet('/api/v1/devices').then(function(resp) {\r\n                var devices = resp && resp.success ? (resp.data || resp.devices || []) : [];\r\n                // v6.16: дёҚиҰҒиҰҶзӣ– allDevicesпјҢеҸӘз”ЁдәҺдёӢжӢүеҲ—иЎЁ\r\n                // allDevices = devices;  // еҲ йҷӨиҝҷиЎҢ\r\n                var ptzDevices = devices.filter(function(d) { return d.online && (d.type === 'ptz' || d.ptz === true); });\r\n                sel.innerHTML = '<option value=\"\">-- йҖүжӢ© PTZ и®ҫеӨҮ --</option>';\r\n                ptzDevices.forEach(function(d) {\r\n                    var opt = document.createElement('option');\r\n                    opt.value = d.ip;\r\n                    opt.textContent = ((d.model ? d.model + ' ' : '') + (d.name || d.device_name || d.ip)).trim() + ' (' + d.ip + ')';\r\n                    sel.appendChild(opt);\r\n                });\r\n                if (currentVal && sel.querySelector('option[value=\"' + currentVal + '\"]')) {\r\n                    sel.value = currentVal;\r\n                }\r\n            }).catch(function(e) {\r\n                console.warn('[WASM] Failed to load devices:', e);\r\n                sel.innerHTML = '<option value=\"\">-- еҠ иҪҪеӨұиҙҘ --</option>';\r\n            });\r\n        }\r\n        function wasmLogout() {\r\n            // v5.47: еҚідҪҝжңӘзҷ»еҪ•д№ҹе°қиҜ•еҒңжӯўж’ӯж”ҫпјҢзЎ®дҝқз”»йқўжё…зҗҶ\r\n            try {\r\n                // Stop playback first\r\n                if (g_bPlaying2) {\r\n                    WebVideoCtrl.I_Stop();\r\n                    g_bPlaying2 = false;\r\n                }\r\n                // Logout from device\r\n\n[579 more lines in file. Use offset=2165 to continue.]"}],"isError":false,"timestamp":1781373586821}}
