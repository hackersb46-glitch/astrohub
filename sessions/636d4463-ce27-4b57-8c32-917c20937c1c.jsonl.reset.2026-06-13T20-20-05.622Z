{"type":"message","id":"28d8965a","parentId":"3010f5d7","timestamp":"2026-06-13T18:58:28.130Z","message":{"role":"assistant","content":[{"type":"text","text":"еңЁ `refreshImageControls` еҗҺж·»еҠ  `resetImageControls` еҮҪж•°пјҡ"},{"type":"toolCall","id":"tool-f2a1229043ae4eb09a473a988a9e4852","name":"edit","arguments":{"edits":[{"newText":"// v6.43: еҲ·ж–°з”»йқўжҺ§еҲ¶жҢүй’®\nfunction refreshImageControls() {\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\n        console.warn('[IMAGE] No device connected');\n        return;\n    }\n    console.log('[IMAGE] Refreshing image controls...');\n    loadDeviceImageParams(window.connectedDevice.ip);\n}\n\n// v6.50: йҮҚзҪ®з”»йқўжҺ§еҲ¶еҲ°зі»з»ҹй»ҳи®ӨеҖј\nfunction resetImageControls() {\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\n        console.warn('[IMAGE] No device connected');\n        return;\n    }\n    \n    // еј№еҮәзЎ®и®ӨеҜ№иҜқжЎҶ\n    if (!confirm('зЎ®и®ӨйҮҚзҪ®з”»йқўжҺ§еҲ¶еҲ°зі»з»ҹй»ҳи®ӨеҖјпјҹ')) {\n        return;\n    }\n    \n    var dev = window.connectedDevice.ip;\n    console.log('[IMAGE] Resetting image controls to defaults...');\n    \n    // зі»з»ҹй»ҳи®ӨеҖј\n    var defaults = {\n        brightness: 50,\n        contrast: 50,\n        saturation: 50,\n        sharpness: 50,\n        wbRed: 100,\n        wbBlue: 100,\n        dnrSpatial: 50,\n        dnrTemporal: 50,\n        exposureMode: 'auto',\n        shutterSpeed: '1/100',\n        irisLevel: 1600\n    };\n    \n    // жӣҙж–° UI\n    document.getElementById('consoleBrightness').value = defaults.brightness;\n    document.getElementById('brightnessVal').textContent = defaults.brightness;\n    document.getElementById('consoleContrast').value = defaults.contrast;\n    document.getElementById('contrastVal').textContent = defaults.contrast;\n    document.getElementById('consoleSaturation').value = defaults.saturation;\n    document.getElementById('saturationVal').textContent = defaults.saturation;\n    document.getElementById('consoleSharpness').value = defaults.sharpness;\n    document.getElementById('sharpnessVal').textContent = defaults.sharpness;\n    document.getElementById('wbRed').value = defaults.wbRed;\n    document.getElementById('wbRedVal').textContent = defaults.wbRed;\n    document.getElementById('wbBlue').value = defaults.wbBlue;\n    document.getElementById('wbBlueVal').textContent = defaults.wbBlue;\n    document.getElementById('dnrSpatial').value = defaults.dnrSpatial;\n    document.getElementById('dnrSpatialVal').textContent = defaults.dnrSpatial;\n    document.getElementById('dnrTemporal').value = defaults.dnrTemporal;\n    document.getElementById('dnrTemporalVal').textContent = defaults.dnrTemporal;\n    document.getElementById('exposureMode').value = defaults.exposureMode;\n    document.getElementById('shutterSpeed').value = defaults.shutterSpeed;\n    document.getElementById('irisLevel').value = defaults.irisLevel;\n    \n    // еҸ‘йҖҒ API иҜ·жұӮйҮҚзҪ®и®ҫеӨҮ\n    apiPost('/api/v1/ptz/' + dev + '/image/reset', {})\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', 'з”»йқўжҺ§еҲ¶е·ІйҮҚзҪ®еҲ°зі»з»ҹй»ҳи®ӨеҖј');\n            } else {\n                showToast('error', 'йҮҚзҪ®еӨұиҙҘ: ' + (r.message || 'жңӘзҹҘй”ҷиҜҜ'));\n            }\n        })\n        .catch(function(e) {\n            showToast('error', 'йҮҚзҪ®иҜ·жұӮеӨұиҙҘ');\n        });\n}","oldText":"// v6.43: еҲ·ж–°з”»йқўжҺ§еҲ¶жҢүй’®\nfunction refreshImageControls() {\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\n        console.warn('[IMAGE] No device connected');\n        return;\n    }\n    console.log('[IMAGE] Refreshing image controls...');\n    loadDeviceImageParams(window.connectedDevice.ip);\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":54700,"output":895,"cacheRead":0,"cacheWrite":0,"t