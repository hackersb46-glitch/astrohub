{"type":"message","id":"c07d1197","parentId":"09cfc39a","timestamp":"2026-06-13T17:35:00.938Z","message":{"role":"toolResult","toolCallId":"call_960942c02c07467aba8afd72","toolName":"read","content":[{"type":"text","text":"\"\"\"AstroHub E2E жөӢиҜ•\"\"\"\nfrom playwright.sync_api import sync_playwright\nimport time\n\ndef test_astrohub():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        errors = []\n        \n        try:\n            # 1. жү“ејҖдё»йЎө\n            print('[TEST] жү“ејҖдё»йЎө...')\n            page.goto('http://localhost:10280/', timeout=10000)\n            page.wait_for_load_state('networkidle', timeout=15000)\n            print('[PASS] дё»йЎөеҠ иҪҪжҲҗеҠҹ')\n            \n            # 2. жЈҖжҹҘзүҲжң¬еҸ·\n            version = page.locator('.version').text_content()\n            print(f'[INFO] зүҲжң¬: {version}')\n            \n            # 3. жЈҖжҹҘи®ҫеӨҮеҲ—иЎЁ\n            print('[TEST] еҲҮжҚўеҲ°и®ҫеӨҮз®ЎзҗҶ...')\n            page.click('button[data-page=\"devices\"]')\n            page.wait_for_timeout(3000)\n            \n            device_rows = page.locator('#deviceTable tr').count()\n            print(f'[INFO] и®ҫеӨҮж•°йҮҸ: {device_rows}')\n            \n            if device_rows > 0:\n                first_row = page.locator('#deviceTable tr').first\n                row_text = first_row.text_content()\n                print(f'[DEBUG] з¬¬дёҖиЎҢ: {row_text[:80]}...')\n                print('[PASS] и®ҫеӨҮеҲ—иЎЁжёІжҹ“жӯЈеёё')\n            else:\n                errors.append('и®ҫеӨҮеҲ—иЎЁдёәз©ә')\n            \n            # 4. жЈҖжҹҘи®ҫеӨҮзҠ¶жҖҒ\n            print('[TEST] жЈҖжҹҘи®ҫеӨҮиҝһжҺҘжҢүй’®...')\n            disconnect_btn = page.locator('button.disconnect-btn').count()\n            if disconnect_btn > 0:\n                print('[PASS] и®ҫеӨҮеңЁзәҝпјҢжҳҫзӨәж–ӯејҖжҢүй’®')\n            else:\n                print('[INFO] и®ҫеӨҮзҰ»зәҝ')\n            \n            # 5. жҲӘеӣҫ\n            page.screenshot(path='tests/screenshots/e2e_final.png')\n            print('[INFO] жҲӘеӣҫе·Ідҝқеӯҳ')\n            \n\n[16 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1781372100938}}
