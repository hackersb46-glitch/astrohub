)\n 144 \n 145     Returns:\n-146         Path: 文件路径 data/devices/{mac_clean}/{test_type}_{YYYYMMDD_HHMMSS}.json\n+153         Path: 文件路径 data/devices/{mac_clean}/{test_type}.json\n 147     \"\"\"\n 148     device_dir = get_device_dir(mac_clean)\n 149     device_dir.mkdir(parents=True, exist_ok=True)\n 150 \n-151     timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n-152     return device_dir / f'{test_type}_{timestamp}.json'\n+158     return device_dir / f'{test_type}.json'","firstChangedLine":107},"isError":false,"timestamp":1781296857683}}
