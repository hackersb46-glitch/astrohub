reams/*         - 流服务\r\n- /api/v1/calibration/*     - 校准\r\n- /api/v1/ascom/*           - ASCOM 设备\r\n- /api/v1/settings          - 系统设置\r\n\r\nAuthor: 雅痞张@南方天文\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport time\r\nfrom datetime import datetime, timezone\r\nfrom typing import Any\r\n\r\nfrom pydantic import BaseModel\r\nfrom fastapi import APIRouter, FastAPI, Query\r\nfrom fastapi.responses import JSONResponse\r\n\r\n# v6.40: 操作日志\r\nfrom src.operation_logger import log_api, log_web, log_error, log_info\r\n\r\n# ================================================================ #\r\n#  \n... (truncated)"},"isError":false,"timestamp":1781361431395}}
{"type":"message","id":"a49e5ef2","parentId":"a3b3f88b","timestamp":"2026-06-13T14:37:18.761Z","message":{"role":"assistant","content":[{"type":"text","text":"CRLF 问题。用 Python 脚本修复："},{"type":"toolCall","id":"call_4c25873297694a7892db939b","name":"write","arguments":{"content":"from pathlib import Path\n\nfile_path = Path(\"src/api/router.py\")\ncontent = file_path.read_text(encoding='utf-8')\n\n# 查找 connect_device 函数\nold_text = '''async def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\n    \"\"\"连接 PTZ 设备并认证。\n\n    device_id 可以是 IP 地址或 MAC 地址。如果是 MAC，自动解析为 IP。\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\n    \n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\n    \"\"\"\n    \"\"\"\n    log_api(\"connect\", {\"device_id\": device_id})'''\n\nnew_text = '''async def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\n    \"\"\"连接 PTZ 设备并认证。\n\n    device_id 必须是 MAC 地址。\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\n    \n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\n    \"\"\"\n    # v6.40: device_id 统一使用 MAC 地址\n    log_api(\"connect\", {\"mac\": device_id})'''\n\nif old_text in content:\n    content = content.replace(old_text, new_text)\n    file_path.write_text(content, encoding='utf-8')\n    print(\"OK: connect_device fixed\")\nelse:\n    print(\"ERROR: pattern not found\")\n    # 尝试另一种模式\n    old_text2 = 'log_api(\"connect\", {\"device_id\": device_id})'\n    if old_text2 in content:\n        content = content.replace(old_text2, 'log_api(\"connect\", {\"mac\": device_id})')\n        file_path.write_text(content, encoding='utf-8')\n        print(\"OK: device_id -> mac fixed\")\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\fix_log.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":125626,"output":458,"cacheRead":0,"cacheWrite":0,"totalTokens":126084,"cost":{"input":0.125626,"output":0.0014656,"cacheRead":0,"cacheWrite":0,"total":0.1270916}},"stop