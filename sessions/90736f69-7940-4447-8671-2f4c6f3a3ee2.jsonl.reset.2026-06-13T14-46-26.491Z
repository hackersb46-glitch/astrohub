:1347:            if (window.wasmLogout) window.wasmLogout();[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1348:            // v6.16: ��� WASM ״̬[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1349:            if (window.updateWasmStatus) window.updateWasmStatus('disconnected');[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1350:            [0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1351:            apiPost('/api/v1/devices/' + ip + '/disconnect', null).then(function() {[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1352:                showToast('success', '�豸�ѶϿ�: ' + ip);[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1353:                addLog('info', '�豸�ѶϿ�: ' + ip);[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1354:                // --- Clear global window.connectedDevice first, before refresh ---[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1355:                if (window.connectedDevice && window.connectedDevice.ip === ip) {[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1356:                    window.connectedDevice = null;[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1357:                    addLog('info', '����������豸״̬');[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1358:                }[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1359:                if (window.updateDeviceStatus) window.updateDeviceStatus();[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1360:                refreshDevices();[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1361:                refreshPtzDeviceList();[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1362:                refreshAdvancedDeviceSelectors();[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1363:                var panel = document.getElementById('deviceInfoPanel');[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1364:                if (panel) panel.style.display = 'none';[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1365:            }).catch(function(e) {[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1366:                showToast('error', '�Ͽ��쳣: ' + e.message);[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1367:            });[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1368:        }[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1369:        function deleteDevice(identifier) {[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1370:            if (!confirm('ȷ��ɾ���豸 ' + identifier + '��')) return;[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1371:            apiDelete('/api/v1/devices/' + identifier).then(function() {[0m\r\n[7m[0m  astrohub\\src\\web\\index.html:1372:                showToast('success', '�豸��ɾ��');[0m","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1781332263366}}
