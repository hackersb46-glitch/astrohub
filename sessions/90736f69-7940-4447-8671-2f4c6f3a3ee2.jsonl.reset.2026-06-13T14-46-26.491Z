{"type":"message","id":"8ddb38a3","parentId":"fe4b598e","timestamp":"2026-06-12T20:42:36.638Z","message":{"role":"toolResult","toolCallId":"call_9e2e44de5ccc494ba77e04b9","toolName":"read","content":[{"type":"text","text":"                \"csv_path\": str(csv_path)\r\n            }, f, indent=2, ensure_ascii=False)\r\n    except Exception:\r\n        pass\r\n\r\n    return all_results\r\n\r\n\r\n\r\nclass SpeedTester:\r\n    def __init__(self, ptz: Any) -> None:\r\n        self.ptz = ptz\r\n\r\n    def run_all_tests(self, config: Any = None, speed_profile: str = 'lite') -> list[dict[str, Any]]:\r\n        return run_all_tests(self.ptz, config, speed_profile)\r\n\r\n\r\n# ================================================================ #\r\n#  独立运行入口\r\n# ================================================================ #\r\n\r\ndef run_speed_test(ip: str = None, username: str = None, password: str = None, port: int = None, speed_profile: str = 'lite') -> dict:\r\n    \"\"\"独立运行Speed测试。\r\n    \r\n    自动读取设备配置（IP/用户名/密码/端口），无需指定参数。\r\n    \r\n    Args:\r\n        ip: 设备IP（可选，默认从配置读取）\r\n        username: 用户名（可选，默认从配置读取）\r\n        password: 密码（可选，默认从配置读取）\r\n        port: 端口（可选，默认从配置读取）\r\n        speed_profile: 速度档位模式\r\n    \r\n    Returns:\r\n        测试结果\r\n    \"\"\"\r\n    from src.ptz.isapi.client import ISAPIClient\r\n    from src.ptz.isapi.ptz import PTZController\r\n    from src.advanced.config_writer import load_device_config\r\n    \r\n    # 读取设备配置文件\r\n    device_config = load_device_config('240f9b764193')\r\n    if device_config is None:\r\n        return {\"success\": False, \"error\": \"未找到设备配置文件，请先运行 onboarding\"}\r\n    \r\n    # 从配置读取连接参数\r\n    if ip is None:\r\n        ip = device_config.ip or \"\"\r\n    if port is None:\r\n        port = device_config.port or 80\r\n    if username is None:\r\n        username = device_config.username or \"admin\"\r\n    if password is None:\r\n        password = device_config.password or \"\"\r\n    \r\n    if not ip:\r\n        return {\"success\": False, \"error\": \"设备配置未配置IP\"}\r\n    \r\n    # 连接设备\r\n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\r\n    if not client.verify_credentials():\r\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\r\n    \r\n    ptz = PTZController(client)\r\n    \r\n    # 运行测试\r\n    results = run_all_tests(ptz, None, speed_profile)\r\n    \r\n    # 更新设备信息\r\n    from src.advanced.config_writer import load_device_config, save_device_config, DeviceConfig\r\n\n[32 more lines in file. Use offset=650 to continue.]"}],"isError":false,"timestamp":1781296956638}}
{"type":"message","id":"ad519610","parentId":"8ddb38a3","timestamp":"2026-06-12T20:43:19.132Z","message":{"role":"assistant","content":[{"type":"text","text":"修复 `speed.py` 的独立运行入口："},{"type":"toolCall","id":"tool-bf8de93103984d509f1ff0d17042c17b","name":"edit","arguments":{"edits":[{"newText":"# ================================================================ #\n#  缓存读取函数 (v6.19 新增)\n# ================================================================ #\n\ndef load_cached_speed_results(mac: str) -> dict | None:\n    \"\"\"从本地缓存读取速度测试结果。\n    \n    v6.19: 优先读取本地缓存，避免每次调用设备API。\n    \n    Args:\n        mac: MAC地址（无分隔符小写）\n    \n    Returns:\n        缓存结果字典，不存在返回 None\n    \"\"\"\n    try:\n        cache_path = get_data_path_read(None, mac, 'speed')\n        if cache_path is None or not cache_path.exists():\n            return None\n        import json\n        with open(cache_path, 'r', encoding='utf-8') as f:\n            return json.load(f)\n    except (json.JSONDecodeError, OSError):\n        return None\n\n\ndef run_speed_test(\n    ip: str = None, \n    username: str = None, \n    password: str = None, \n    port: int = None, \n    speed_profile: str = 'lite',\n    mac: str = None,\n    use_cache: bool = True\n) -> dict:\n    \"\"\"独立运行Speed测试。\n    \n    v6.19: 优先读取本地缓存，缓存不存在时调用设备API。\n    \n    Args:\n        ip: 设备IP（可选）\n        username: 用户名（可选）\n        password: 密码（可选）\n        port: 端口（可选，默认80）\n        speed_profile: 速度档位模式\n        mac: MAC地址（可选，用于读取缓存）\n        use_cache: 是否优先使用缓存（默认True）\n    \n    Returns:\n        测试结果\n    \"\"\"\n    from src.ptz.isapi.client import ISAPIClient\n    from src.ptz.isapi.ptz import PTZController\n    \n    # 1. 优先读取缓存\n    if use_cache and mac:\n        cached = load_cached_speed_results(mac)\n        if cached:\n            return {**cached, \"from_cache\": True}\n    \n    # 2. 检查必需参数\n    if not ip:\n        return {\"success\": False, \"error\": \"缺少设备IP参数\"}\n    \n    # 3. 连接设备并运行测试\n    username = username or \"admin\"\n    password = password or \"\"\n    port = port or 80\n    \n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n    if not client.verify_credentials():\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n    \n    ptz = PTZController(client)\n    results = run_all_tests(ptz, None, speed_profile)\n    \n    return {\n        \"success\": len(results) > 0,\n        \"total_tests\": len(results),\n        \"results\": results,\n        \"from_cache\": False\n    }\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"AstroHub Speed测试\")\n    parser.add_argument(\"--ip\", type=str, required=True, help=\"设备IP\")\n    parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n    parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n    parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n    parser.add_argument(\"--profile\", type=str, default=\"lite\", choices=['lite', 'medium', 'full'], help=\"速度档位模式\")\n    parser.add_argument(\"--mac\", type=str, help=\"MAC地址（用于缓存）\")\n    parser.add_argument(\"--no-cache\", action=\"store_true\", help=\"禁用缓存\")\n    args = parser.parse_args()\n    \n    _print(\"=\" * 50)\n    _print(\"AstroHub Speed测试\")\n    _print(\"=\" * 50)\n    \n    result = run_speed_test(\n        ip=args.ip, \n        username=args.username, \n        password=args.password, \n        port=args.port, \n        speed_profile=args.profile,\n        mac=args.mac,\n        use_cache=not args.no_cache\n    )\n    \n    if result.get(\"success\"):\n        cache_note = \" (缓存)\" if result.get(\"from_cache\") else \"\"\n        _print(f\"[完成] 速度测试: {result.get('total_tests', 0)} 项{cache_note}\")\n    else:\n        _print(f\"[失败] {result.get('error', '未知错误')}\")","oldText":"# ================================================================ #\n#  独立运行入口\n# ================================================================ #\n\ndef run_speed_test(ip: str = None, username: str = None, password: str = None, port: int = None, speed_profile: str = 'lite') -> dict:\n    \"\"\"独立运行Speed测试。\n    \n    自动读取设备配置（IP/用户名/密码/端口），无需指定参数。\n    \n    Args:\n        ip: 设备IP（可选，默认从配置读取）\n        username: 用户名（可选，默认从配置读取）\n        password: 密码（可选，默认从配置读取）\n        port: 端口（可选，默认从配置读取）\n        speed_profile: 速度档位模式\n    \n    Returns:\n        测试结果\n    \"\"\"\n    from src.ptz.isapi.client import ISAPIClient\n    from src.ptz.isapi.ptz import PTZController\n    from src.advanced.config_writer import load_device_config\n    \n    # 读取设备配置文件\n    device_config = load_device_config('240f9b764193')\n    if device_config is None:\n        return {\"success\": False, \"error\": \"未找到设备配置文件，请先运行 onboarding\"}\n    \n    # 从配置读取连接参数\n    if ip is None:\n        ip = device_config.ip or \"\"\n    if port is None:\n        port = device_config.port or 80\n    if username is None:\n        username = device_config.username or \"admin\"\n    if password is None:\n        password = device_config.password or \"\"\n    \n    if not ip:\n        return {\"success\": False, \"error\": \"设备配置未配置IP\"}\n    \n    # 连接设备\n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n    if not client.verify_credentials():\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n    \n    ptz = PTZController(client)\n    \n    # 运行测试\n    results = run_all_tests(ptz, None, speed_profile)\n    \n    # 更新设备信息\n    from src.advanced.config_writer import load_device_config, save_device_config, DeviceConfig\n    config = load_device_config('240f9b764193')\n    if config:\n        config.speed = {\"last_test\": len(results)}\n        save_device_config(config)\n    \n    return {\n        \"success\": len(results) > 0,\n        \"total_tests\": len(results),\n        \"results\": results\n    }\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"AstroHub Speed测试\")\n    parser.add_argument(\"--ip\", type=str, help=\"设备IP (默认从配置读取)\")\n    parser.add_argument(\"--username\", type=str, help=\"用户名 (默认从配置读取)\")\n    parser.add_argument(\"--password\", type=str, help=\"密码 (默认从配置读取)\")\n    parser.add_argument(\"--port\", type=int, help=\"端口 (默认从配置读取)\")\n    parser.add_argument(\"--profile\", type=str, default=\"lite\", choices=['lite', 'medium', 'full'], help=\"速度档位模式\")\n    args = parser.parse_args()\n    \n    _print(\"=\" * 50)\n    _print(\"AstroHub Speed测试\")\n    _print(\"=\" * 50)\n    \n    result = run_speed_test(ip=args.ip, username=args.username, password=args.password, port=args.port, speed_profile=args.profile)\n    \n    if result.get(\"success\"):\n        _print(f\"[完成] 速度测试: {result.get('total_tests', 0)} 项\")\n    else:\n        _print(f\"[失败] {result.get('error', '未知错误')}\")"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\advanced\\speed.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":91154,"output":2073,"cacheRead":0,"cacheWrite":0,"totalTokens":93227,"cost":{"input":0.091154,"output":0.006633600000000001,"cacheRead":0,"cacheWrite":0,"total":0.0977876}},"stopReason":"toolUse","timestamp":1781296956639,"responseId":"cht000e6745@dx19ebd9286e2b893102"}}
