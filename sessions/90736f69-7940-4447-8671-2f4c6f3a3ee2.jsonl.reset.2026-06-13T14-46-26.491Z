{"type":"message","id":"01a5627e","parentId":"d741fb9e","timestamp":"2026-06-13T06:34:58.758Z","message":{"role":"toolResult","toolCallId":"call_8d4f2d09a4f74715a51182d3","toolName":"read","content":[{"type":"text","text":"@api_router.get(\"/ptz/{device_id}/function\", summary=\"获取设备function.json\", tags=[\"Image\"])\r\nasync def get_device_function(device_id: str) -> dict:\r\n    \"\"\"从 data/{device_model}/*/function.json 读取设备功能参数范围。\"\"\"\r\n    import json\r\n    from pathlib import Path\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n    \r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n    \r\n    # 从 data 目录查找 function.json\r\n    data_dir = Path(__file__).resolve().parent.parent.parent / \"data\"\r\n    if not data_dir.exists():\r\n        return {\"success\": False, \"message\": \"data 目录不存在\", \"data\": None}\r\n    \r\n    # 遍历所有子目录查找 function.json\r\n    for subdir in data_dir.iterdir():\r\n        if subdir.is_dir():\r\n            for f in subdir.rglob(\"function.json\"):\r\n                try:\r\n                    with open(f, \"r\", encoding=\"utf-8\") as fh:\r\n                        func_data = json.load(fh)\r\n                    # 检查 IP 是否匹配\r\n                    if func_data.get(\"device_info\", {}).get(\"ip\") == target_ip:\r\n                        return {\"success\": True, \"data\": func_data}\r\n                except Exception:\r\n                    continue\r\n    \r\n    return {\"success\": False, \"message\": \"未找到该设备的 function.json\", \"data\": None}\r\n\r\n\r\n@api_router.get(\"/ptz/{device_id}/image/whitebalance\", summary=\"获取白平衡设置\", tags=[\"Image\"])\r\nasync def get_whitebalance(device_id: str) -> dict:\r\n    \"\"\"获取设备白平衡当前设置。\"\"\"\r\n    import xml.etree.ElementTree as ET\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\r\n\r\n    ctrl, err = mgr._get_controller(target_ip)\r\n    if err:\r\n        return {\"success\": False, \"message\": err}\r\n\r\n    client = ctrl.client\r\n    try:\r\n        resp = client.get(\"/Image/channels/1/whiteBalance\")\r\n        if resp.status_code != 200:\r\n            return {\"success\": False, \"message\": f\"获取白平衡失败: HTTP {resp.status_code}\"}\r\n\r\n        root = ET.fromstring(resp.xml)\r\n        result = {\"success\": True, \"data\": {}}\r\n        for elem in root.iter():\r\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\r\n\n[572 more lines in file. Use offset=2587 to continue.]"}],"isError":false,"timestamp":1781332498758}}
{"type":"message","id":"6fc9d607","parentId":"01a5627e","timestamp":"2026-06-13T06:35:18.414Z","message":{"role":"assistant","content":[{"type":"text","text":"我发现问题了！`get_device_function` API 的逻辑有问题：\n\n1. 它遍历 `data/*/function.json`，但正确的路径是 `data/devices/{mac}/function.json`\n2. 它检查 `func_data.get(\"device_info\", {}).get(\"ip\")`，但 `function.json` 可能没有这个字段\n\n让我检查实际的 `function.json` 文件："},{"type":"toolCall","id":"call_b80246bb267946309f47b412","name":"exec","arguments":{"command":"Get-ChildItem -Path \"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\data\" -Recurse -Filter \"function*.json\" | ForEach-Object { Write-Host \"`n=== $($_.FullName) ===\" ; Get-Content $_.FullName -Raw | ConvertFrom-Json | ConvertTo-Json -Depth 2 }"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":129209,"output":166,"cacheRead":0,"cacheWrite":0,"totalTokens":129375,"cost":{"input":0.129209,"output":0.0005312,"cacheRead":0,"cacheWrite":0,"total":0.1297402}},"stopReason":"toolUse","timestamp":1781332498761,"responseId":"cht000da2f3@dx19ebfb0fcedba5a412"}}
