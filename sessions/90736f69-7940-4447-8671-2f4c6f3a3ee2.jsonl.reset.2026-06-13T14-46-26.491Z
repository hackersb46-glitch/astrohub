��[0m\r\n[7m[0m    #[0m\r\n[7m[0m    #  �ܹ�˵����[0m\r\n[7m[0m    #  ֮ǰ�� /ContentMgmt/Storage/control �˵㷵�� 404���������� iDS-2DF8C832IXS-A �����[0m\r\n[7m[0m    #  ��ȷʹ��:[0m\r\n[7m[0m    #    PUT /ISAPI/ContentMgmt/record/control/manual/start/tracks/{trackID} �� ����¼��[0m\r\n[7m[0m    #    PUT /ISAPI/ContentMgmt/record/control/manual/stop/tracks/{trackID}  �� ֹͣ¼��[0m\r\n[7m[0m    #    POST /ISAPI/ContentMgmt/search �� �����豸��¼��[0m\r\n[7m[0m    #    POST /ISAPI/ContentMgmt/download �� ����¼�񵽱���[0m\r\n[7m[0m    #  Track ID = channel * 100 + 1��101=ͨ��1��������[0m\r\n[7m[0m    #  �豸��Ҫ���ô洢���ʣ�NAS/SD������������Ӳ��ʱ hddList Ϊ�յ��Կ�¼�� NAS��[0m\r\n[7m[0m    # ================================================================[0m\r\n[7m[0m\r\n[7m[0m    def _get_isapi_client(self, ip: str) -> ISAPIClient | None:[0m\r\n[7m[0m        \"\"\"��ȡ�����ӵ� ISAPIClient�����ƾ�ݴ�����ʱʵ����\"\"\"[0m\r\n[7m[0m        if ip in self._clients:[0m\r\n[7m[0m            return self._clients[ip][0m\r\n[7m[0m        creds = self.get_credentials(ip)[0m\r\n[7m[0m        if not creds:[0m\r\n[7m[0m            return None[0m\r\n[7m[0m        port = int(creds.get(\"port\", 80))[0m\r\n[7m[0m        username = str(creds.get(\"username\", \"admin\"))[0m\r\n[7m[0m        password = str(creds.get(\"password\", \"\"))[0m\r\n[7m[0m        client = ISAPIClient(ip=ip, username=username, password=password, port=port)[0m\r\n[7m[0m        if client.verify_credentials():[0m\r\n[7m[0m            self._clients[ip] = client[0m\r\n[7m[0m            return client[0m\r\n[7m[0m        return None[0m\r\n[7m[0m\r\n[7m[0m\r\n[7m[0m    # ================================================================[0m\r\n[7m[0m    #  ¼����ƣ�FFmpeg ��ȡ RTSP �� �� ���� record/ Ŀ¼[0m\r\n[7m[0m    #  ����˵����[0m\r\n[7m[0m    #    1. �豸��¼����Ҫ HDD/NAS/SD��������[0m\r\n[7m[0m    #    2. AstroHub ͨ�� FFmpeg ������ȡ RTSP ����¼�Ƶ����� record/ Ŀ¼[0m\r\n[7m[0m    #    3. ֹͣ¼�ƺ��ѡͨ�� FTP �ϴ���Զ�˷�������AstroHub �������� FTP��[0m\r\n[7m[0m    #    4. ¼��״̬ʹ�� _recording_state ���� FFmpeg ����[0m\r\n[7m[0m    # ================================================================[0m\r\n[7m[0m\r\n[7m[0m    def start_recording(self, ip: str, channel: int = ISAPI_CHANNEL, target_name: str = \"\") -> dict:[0m\r\n[7m[0m        \"\"\"ͨ�� FFmpeg ¼�� RTSP �������� record/ Ŀ¼��\"\"\"[0m\r\n[7m[0m        from src.config_paths import RECORD_DIR[0m\r\n[7m[0m        from src.stream.constants import RTSP_DEFAULT_PORT[0m\r\n[7m[0m        creds = self.get_credentials(ip)[0m\r\n[7m[0m        if not creds:[0m\r\n[7m[0m            return {\"success\": False, \"message\": f\"�豸 {ip} δ����ƾ�ݣ����������豸\"}[0m\r\n[7m[0m\r\n[7m[0m        username = creds.get(\"username\", \"admin\")[0m\r\n[7m[0m        password = creds.get(\"password\", \"\")[0m\r\n[7m[0m        rtsp_port = creds.get(\"rtsp_port\", RTSP_DEFAULT_PORT)[0m\r\n[7m[0m        rtsp_url = f\"rtsp://{username}:{password}@{ip}:{rtsp_port}/Streaming/Channels/101\"[0m\r\n[7m[0m\r\n[7m[0m        RECORD_DIR.mkdir(parents=True, exist_ok=True)[0m\r\n[7m[0m        filename = generate_filename(device_ip=ip, extension='.mp4')[0m\r\n[7m[0m        filepath = RECORD_DIR / filename[0m\r\n[7m[0m\r\n[7m[0m        cmd = [[0m\r\n[7m[0m            \"ffmpeg\", \"-y\",[0m\r\n[7m[0m            \"-rtsp_transport\", \"tcp\",[0m\r\n[7m[0m            \"-timeout\", \"5000000\",[0m\r\n[7m[0m            \"-i\", rtsp_url,[0m\r\n[7m[0m            \"-c\", \"copy\",[0m\r\n[7m[0m            \"-an\",  # ȥ����Ƶ��pcm_alaw ��֧�� MP4��[0m\r\n[7m[0m            \"-f\", \"mp4\",[0m\r\n[7m[0m            \"-movflags\", \"+frag_keyframe+empty_moov\",[0m\r\n[7m[0m            str(filepath),[0m\r\n[7m[0m        ][0m\r\n[7m[0m\r\n[7m[0m        try:[0m\r\n[7m[0m            # Check if already recording[0m\r\n[7m[0m            if ip in self._recording_state:[0m\r\n[7m[0m                return {\"success\": False, \"message\": f\"�豸 {ip} ����¼����\"}[0m\r\n[7m[0m\r\n[7m[0m            proc = subprocess.Popen([0m\r\n[7m[0m                cmd,[0m\r\n[7m[0m                stdout=subprocess.DEVNULL,[0m\r\n[7m[0m                stderr=subprocess.DEVNULL,[0m\r\n[7m[0m                creationflags=subprocess.CREATE_NO_WINDOW if hasattr(subprocess, 'CREATE_NO_WINDOW') else 0,[0m\r\n[7m[0m            )[0m\r\n[7m[0m\r\n[7m[0m            # Health check: wait 2 seconds to ensure FFmpeg doesn't crash immediately[0m\r\n[7m[0m            time.sleep(2)[0m\r\n[7m[0m            if proc.poll() is not None:[0m\r\n[7m[0m                exit_code = proc.poll()[0m\r\n[7m[0m                LOG.log(\"failed\", f\"FFmpeg �����������˳�: {ip}, exit_code={exit_code}\")[0m\r\n[7m[0m                return {\"success\": False, \"message\": f\"FFmpeg ����ʧ�� (exit={exit_code})������ RTSP ���Ƿ�ɴ�\"}[0m\r\n[7m[0m\r\n[7m[0m            start_time = time.time()[0m\r\n[7m[0m            self._recording_state[ip] = {[0m\r\n[7m[0m                \"pid\": proc.pid,[0m\r\n[7m[0m                \"process\": proc,[0m\r\n[7m[0m                \"started_at\": start_time,[0m\r\n[7m[0m                \"filepath\": str(filepath),[0m\r\n[7m[0m            }[0m\r\n[7m[0m            LOG.log(\"done\", f\"¼��������: {ip} PID={proc.pid} �� {filepath}\")[0m\r\n[7m[0m            return {[0m\r\n[7m[0m                \"success\": True,[0m\r\n[7m[0m                \"message\": f\"¼��������: {ip}\",[0m\r\n[7m[0m                \"data\": {[0m\r\n[7m[0m                    \"pid\": proc.pid,[0m\r\n[7m[0m                    \"filepath\": str(filepath),[0m\r\n[7m[0m                    \"filename\": filename,[0m\r\n[7m[0m                    \"started_at\": start_time,[0m\r\n[7m[0m                },[0m\r\n[7m[0m            }[0m\r\n[7m[0m        except Exception as e:[0m\r\n[7m[0m            LOG.log(\"failed\", f\"���� FFmpeg ʧ��: {e}\")[0m\r\n[7m[0m            return {\"success\": False, \"message\": f\"����¼��ʧ��: {e}\"}[0m\r\n[7m[0m\r\n[7m[0m    def stop_recording(self, ip: str) -> dict:[0m\r\n[7m[0m        \"\"\"ֹͣ FFmpeg ¼�ƽ��̣���ѡ�ϴ��� FTP ��������\"\"\"[0m\r\n[7m[0m        if ip not in self._recording_state:[0m\r\n[7m[0m            return {\"success\": False, \"message\": f\"�豸 {ip} ��ǰδ��¼��\"}[0m\r\n[7m[0m\r\n[7m[0m        state = self._recording_state[ip][0m\r\n[7m[0m        proc = state.get(\"process\")[0m\r\n[7m[0m        started_at = state.get(\"started_at\", time.time())[0m\r\n[7m[0m        filepath = state.get(\"filepath\", \"\")[0m\r\n[7m[0m\r\n[7m[0m        if not proc:[0m\r\n[7m[0m            del self._recording_state[ip][0m\r\n[7m[0m            return {\"success\": False, \"message\": \"¼�ƽ��̲�����\"}[0m\r\n[7m[0m\r\n[7m[0m        # ��ֹ FFmpeg ����[0m\r\n[7m[0m        try:[0m\r\n[7m[0m            proc.terminate()[0m\r\n[7m[0m            try:[0m\r\n[7m[0m                proc.wait(timeout=3)[0m\r\n[7m[0m            except subprocess.TimeoutExpired:[0m\r\n[7m[0m                proc.kill()[0m\r\n[7m[0m                proc.wait(timeout=5)[0m\r\n[7m[0m        except Exception as e:[0m\r\n[7m[0m            LOG.log(\"warning\", f\"��ֹ FFmpeg �����쳣: {e}\")[0m\r\n[7m[0m            try:[0m\r\n[7m[0m                proc.kill()[0m\r\n[7m[0m            except Exception:[0m\r\n[7m[0m                pass[0m\r\n[7m[0m\r\n[7m[0m        if proc.returncode is not None:[0m\r\n[7m[0m            LOG.log(\"info\", f\"FFmpeg �����˳���: {proc.returncode}\")[0m\r\n[7m[0m\r\n[7m[0m        duration = round(time.time() - started_at, 1)[0m\r\n[7m[0m        file_size = 0[0m\r\n[7m[0m        if filepath and os.path.exists(filepath):[0m\r\n[7m[0m            file_size = os.path.getsize(filepath)[0m\r\n[7m[0m\r\n[7m[0m        del self._recording_state[ip][0m\r\n[7m[0m\r\n[7m[0m        # FTP �ϴ�����������ˣ�[0m\r\n[7m[0m        ftp_result = None[0m\r\n[7m[0m        if getattr(self, '_ftp_config', None) and self._ftp_config.get(\"enabled\"):[0m\r\n[7m[0m            ftp_result = self._upload_to_ftp(filepath)[0m\r\n[7m[0m\r\n[7m[0m        filename_out = os.path.basename(filepath) if filepath else \"\"[0m\r\n[7m[0m        result = {[0m\r\n[7m[0m            \"success\": True,[0m\r\n[7m[0m            \"message\": f\"¼����ֹͣ: {ip}\",[0m\r\n[7m[0m            \"data\": {[0m\r\n[7m[0m                \"filepath\": filepath,[0m\r\n[7m[0m                \"filename\": filename_out,[0m\r\n[7m[0m                \"size\": file_size,[0m\r\n[7m[0m                \"duration_seconds\": duration,[0m\r\n[7m[0m            },[0m\r\n[7m[0m        }[0m\r\n[7m[0m        if ftp_result:[0m\r\n[7m[0m            result[\"data\"][\"ftp\"] = ftp_result[0m\r\n[7m[0m\r\n[7m[0m        if filepath and file_size > 0:[0m\r\n[7m[0m            LOG.log(\"done\", f\"¼���ļ�: {filepath} ({file_size} bytes, {duration}s)\")[0m\r\n[7m[0m\r\n[7m[0m        return result[0m\r\n[7m[0m\r\n[7m[0m    # ================================================================[0m\r\n[7m[0m    #  FTP ¼���ϴ���AstroHub �������� FTP ��������[0m\r\n[7m[0m    # ================================================================[0m\r\n[7m[0m\r\n[7m[0m    def configure_ftp(self, host: str, port: int = 21, username: str = \"\",[0m\r\n[7m[0m                      password: str = \"\", remote_dir: str = \"/recordings\",[0m\r\n[7m[0m                      enabled: bool = True) -> dict:[0m\r\n[7m[0m        \"\"\"���� FTP ������������Ϣ��\"\"\"[0m\r\n[7m[0m        self._ftp_config = {[0m\r\n[7m[0m            \"enabled\": enabled,[0m\r\n[7m[0m            \"host\": host,[0m\r\n[7m[0m            \"port\": port,[0m\r\n[7m[0m            \"username\": username,[0m\r\n[7m[0m            \"password\": password,[0m\r\n[7m[0m            \"remote_dir\": remote_dir,[0m\r\n[7m[0m        }[0m\r\n[7m[0m        LOG.log(\"info\", f\"FTP ������: {host}:{port}/{remote_dir}\")[0m\r\n[7m[0m        return {\"success\": True, \"message\": f\"FTP ������: {host}:{port}\"}[0m\r\n[7m[0m\r\n[7m[0m    def _upload_to_ftp(self, filepath: str) -> dict:[0m\r\n[7m[0m        \"\"\"�ϴ�¼���ļ��� FTP ��������\"\"\"[0m\r\n[7m[0m        if not filepath or not os.path.exists(filepath):[0m\r\n[7m[0m            return {\"success\": False, \"message\": \"�ļ�������\"}[0m\r\n[7m[0m\r\n[7m[0m        if not getattr(self, '_ftp_config', None) or not self._ftp_config.get(\"enabled\"):[0m\r\n[7m[0m            return {\"success\": False, \"message\": \"FTP δ����\"}[0m\r\n[7m[0m\r\n[7m[0m        from ftplib import FTP[0m\r\n[7m[0m\r\n[7m[0m        config = self._ftp_config[0m\r\n[7m[0m        try:[0m\r\n[7m[0m            ftp = FTP()[0m\r\n[7m[0m            ftp.connect(config[\"host\"], config[\"port\"], timeout=30)[0m\r\n[7m[0m            ftp.login(config.get(\"username\", \"\"), config.get(\"password\", \"\"))[0m\r\n[7m[0m\r\n[7m[0m            remote_dir = config.get(\"remote_dir\", \"/recordings\")[0m\r\n[7m[0m            try:[0m\r\n[7m[0m                ftp.cwd(remote_dir)[0m\r\n[7m[0m            except Exception:[0m\r\n[7m[0m                # Ŀ¼�������򴴽�[0m\r\n[7m[0m                dirs = remote_dir.strip(\"/\").split(\"/\")[0m\r\n[7m[0m                current = \"\"[0m\r\n[7m[0m                for d in dirs:[0m\r\n[7m[0m                    current += \"/\" + d[0m\r\n[7m[0m                    try:[0m\r\n[7m[0m                        ftp.cwd(current)[0m\r\n[7m[0m                    except Exception:[0m\r\n[7m[0m                        ftp.mkd(current)[0m\r\n[7m[0m                ftp.cwd(remote_dir)[0m\r\n[7m[0m\r\n[7m[0m            filename = os.path.basename(filepath)[0m\r\n[7m[0m            with open(filepath, \"rb\") as f:[0m\r\n[7m[0m                ftp.storbinary(f\"STOR {filename}\", f)[0m\r\n[7m[0m\r\n[7m[0m            file_size = os.path.getsize(filepath)[0m\r\n[7m[0m            ftp.quit()[0m\r\n[7m[0m\r\n[7m[0m            LOG.log(\"done\", f\"FTP �ϴ��ɹ�: {filename} ({file_size} bytes)\")[0m\r\n[7m[0m            return {[0m\r\n[7m[0m                \"success\": True,[0m\r\n[7m[0m                \"message\": f\"FTP �ϴ��ɹ�: {filename}\",[0m\r\n[7m[0m                \"remote_path\": f\"{remote_dir}/{filename}\",[0m\r\n[7m[0m                \"size\": file_size,[0m\r\n[7m[0m            }[0m