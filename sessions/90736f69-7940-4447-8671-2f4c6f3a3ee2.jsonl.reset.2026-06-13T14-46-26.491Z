o.get(\"model_short\", \"\")\n-1170         update_device_info(mac, model=model_short, ip=ip, port=port)\n-1171     \n-1172     return result\n+1190     return {**result, \"from_cache\": False}\n 1173 \n 1174 \n 1175 if __name__ == \"__main__\":\n 1176     import argparse\n      ...","firstChangedLine":1120},"isError":false,"timestamp":1781296782794}}
