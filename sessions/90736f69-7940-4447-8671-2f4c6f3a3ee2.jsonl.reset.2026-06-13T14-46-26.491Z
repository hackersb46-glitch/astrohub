{"type":"message","id":"f775b331","parentId":"5eba1795","timestamp":"2026-06-13T14:17:20.943Z","message":{"role":"toolResult","toolCallId":"tool-b0368fb2f909447196be0cdcd2e5ad6e","toolName":"read","content":[{"type":"text","text":"async def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\r\n    \"\"\"连接 PTZ 设备并认证。\r\n\r\n    device_id 可以是 IP 地址或 MAC 地址。如果是 MAC，自动解析为 IP。\r\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\r\n    \r\n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\r\n    \"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # 解析 device_id: 如果看起来像 MAC，从发现缓存中解析 IP\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}，请提供 IP 地址或确保设备已通过 SADP 发现\"}\r\n\r\n    # 如果未提供凭据，尝试从存储获取\r\n    if req is None:\r\n        creds = mgr.get_credentials(target_ip)\r\n        if not creds:\r\n            return {\"success\": False, \"message\": \"设备未保存凭据，请先提供用户名和密码\"}\r\n        username = creds[\"username\"]\r\n        password = creds[\"password\"]\r\n        port = creds.get(\"port\", 80)\r\n    else:\r\n        username = req.username or \"admin\"\r\n        if not req.password:\r\n            return {\"success\": False, \"message\": \"请提供密码\"}\r\n        password = req.password\r\n        port = req.port\r\n\r\n    result = mgr.connect_device(target_ip, username, password, port)\r\n    if result and result.get(\"success\"):\r\n        # 更新 DeviceManager 状态（使用 device_id 保持前端一致）\r\n        dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n        if dm:\r\n            dm.update_status(device_id, \"online\")\r\n        return result\r\n    return result or {\"success\": False, \"message\": \"连接失败\"}\r\n\r\n\r\n@api_router.post(\"/devices/{device_id}/disconnect\", summary=\"断开设备\", tags=[\"Devices\"])\r\nasync def disconnect_device(device_id: str) -> dict:\r\n    \"\"\"断开 PTZ 设备连接。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    mgr.disconnect_device(device_id)\r\n\r\n    dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n    if dm:\r\n        dm.update_status(device_id, \"offline\")\r\n\r\n    return {\"success\": True, \"message\": f\"设备已断开: {device_id}\"}\r\n\r\n\r\n@api_router.delete(\"/devices/{device_id}\", summary=\"删除设备\", tags=[\"Devices\"])\r\nasync def delete_device(device_id: str) -> dict:\r\n    \"\"\"删除设备。\"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # 先断开\r\n    mgr.disconnect_device(device_id)\r\n\r\n    # 移除凭据\r\n    removed = mgr.remove_credentials(device_id)\r\n\r\n    dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n    if dm:\r\n        dm.unregister_device(device_id)\r\n\r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"设备已删除: {device_id}\",\r\n    }\r\n\r\n\n[2606 more lines in file. Use offset=574 to continue.]"}],"isError":false,"timestamp":1781360240943}}
{"type":"message","id":"a12e4bd8","parentId":"f775b331","timestamp":"2026-06-13T14:18:03.829Z","message":{"role":"assistant","content":[{"type":"text","text":"在 connect_device 函数中添加日志："},{"type":"toolCall","id":"call_185aa0e01de54939a756f4c2","name":"edit","arguments":{"edits":[{"newText":"async def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\n    \"\"\"连接 PTZ 设备并认证。\n\n    device_id 可以是 IP 地址或 MAC 地址。如果是 MAC，自动解析为 IP。\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\n    \n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\n    \"\"\"\n    log_api(\"connect\", {\"device_id\": device_id})\n    \n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        log_error(\"connect\", {\"device_id\": device_id, \"error\": \"PTZManager 未初始化\"})\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    # 解析 device_id: 如果看起来像 MAC，从发现缓存中解析 IP\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        log_error(\"connect\", {\"device_id\": device_id, \"error\": \"无法解析设备标识\"})\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}，请提供 IP 地址或确保设备已通过 SADP 发现\"}\n\n    # 如果未提供凭据，尝试从存储获取\n    if req is None:\n        creds = mgr.get_credentials(target_ip)\n        if not creds:\n            log_error(\"connect\", {\"device_id\": device_id, \"error\": \"设备未保存凭据\"})\n            return {\"success\": False, \"message\": \"设备未保存凭据，请先提供用户名和密码\"}\n        username = creds[\"username\"]\n        password = creds[\"password\"]\n        port = creds.get(\"port\", 80)\n    else:\n        username = req.username or \"admin\"\n        if not req.password:\n            return {\"success\": False, \"message\": \"请提供密码\"}\n        password = req.password\n        port = req.port\n\n    result = mgr.connect_device(target_ip, username, password, port)\n    if result and result.get(\"success\"):\n        log_info(\"connect\", {\"device_id\": device_id, \"ip\": target_ip, \"status\": \"success\"})\n        # 更新 DeviceManager 状态（使用 device_id 保持前端一致）\n        dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\n        if dm:\n            dm.update_status(device_id, \"online\")\n        return result\n    \n    log_error(\"connect\", {\"device_id\": device_id, \"ip\": target_ip, \"status\": \"failed\"})\n    return result or {\"success\": False, \"message\": \"连接失败\"}","oldText":"async def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\n    \"\"\"连接 PTZ 设备并认证。\n\n    device_id 可以是 IP 地址或 MAC 地址。如果是 MAC，自动解析为 IP。\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\n    \n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\n    \"\"\"\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    # 解析 device_id: 如果看起来像 MAC，从发现缓存中解析 IP\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}，请提供 IP 地址或确保设备已通过 SADP 发现\"}\n\n    # 如果未提供凭据，尝试从存储获取\n    if req is None:\n        creds = mgr.get_credentials(target_ip)\n        if not creds:\n            return {\"success\": False, \"message\": \"设备未保存凭据，请先提供用户名和密码\"}\n        username = creds[\"username\"]\n        password = creds[\"password\"]\n        port = creds.get(\"port\", 80)\n    else:\n        username = req.username or \"admin\"\n        if not req.password:\n            return {\"success\": False, \"message\": \"请提供密码\"}\n        password = req.password\n        port = req.port\n\n    result = mgr.connect_device(target_ip, username, password, port)\n    if result and result.get(\"success\"):\n        # 更新 DeviceManager 状态（使用 device_id 保持前端一致）\n        dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\n        if dm:\n            dm.update_status(device_id, \"online\")\n        return result\n    return result or {\"success\": False, \"message\": \"连接失败\"}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":114075,"output":1238,"cacheRead":0,"cacheWrite":0,"totalTokens":115313,"cost":{"input":0.114075,"output":0.0039616,"cacheRead":0,"cacheWrite":0,"total":0.11803659999999999}},"stopReason":"toolUse","timestamp":1781360240945,"responseId":"cht000d767a@dx19ec1585fdfb828232"}}
