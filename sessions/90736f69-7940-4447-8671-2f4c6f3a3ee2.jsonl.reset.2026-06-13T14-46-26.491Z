t.get('pan_min', 0)}-{result.get('pan_max', 3600)}, Tilt={result.get('tilt_min', -200)}-{result.get('tilt_max', 900)}\")\r\n    else:\r\n        print(f\"[失败] {result.get('error', result.get('message', '未知错误'))}\")\r\n"}],"isError":false,"timestamp":1781296880206}}
