)\r\n        return result\r\n    \r\n    log_error(\"connect\", {\"device_id\": device_id, \"ip\": target_ip, \"status\": \"failed\"})\r\n    return result or {\"success\": False, \"message\": \"连接失败\"}\r\n\r\n\r\n@api_router.post(\"/devices/{device_id}/disconnect\", summary=\"断开设备\", tags=[\"Devices\"])\r\nasync def disconnect_device(device_id: str) -> dict:\r\n    \"\"\"断开 PTZ 设备连接.\"\"\"\r\n    log_api(\"disconnect\", {\"device_id\": device_id})\r\n    \r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n\n[2640 more lines in file. Use offset=570 to continue.]"}],"isError":false,"timestamp":1781361396002}}
{"type":"message","id":"795e54ad","parentId":"fb2a8432","timestamp":"2026-06-13T14:37:11.376Z","message":{"role":"assistant","content":[{"type":"text","text":"问题在于 `device_id` 参数可能是 IP 或 MAC。需要统一转换成 MAC。修改 `connect_device` 函数："},{"type":"toolCall","id":"call_19bcf7e899e1448094c20761","name":"edit","arguments":{"edits":[{"newText":"async def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\n    \"\"\"连接 PTZ 设备并认证。\n\n    device_id 必须是 MAC 地址。\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\n    \n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\n    \"\"\"\n    # v6.40: device_id 统一使用 MAC 地址\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        log_error(\"connect\", {\"mac\": device_id, \"error\": \"PTZManager 未初始化\"})\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    # 解析 device_id 获取 IP\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        log_error(\"connect\", {\"mac\": device_id, \"error\": \"无法解析设备标识\"})\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}，请提供 MAC 地址或确保设备已通过 SADP 发现\"}\n\n    # 获取设备 MAC（统一标识）\n    device_mac = device_id\n    # 如果传入的是 IP，转换为 MAC\n    if \".\" in device_id:  # IP 地址格式\n        device_mac = mgr.get_mac_by_ip(target_ip) or device_id.replace(\".\", \"\")\n    \n    log_api(\"connect\", {\"mac\": device_mac})\n\n    # 如果未提供凭据，尝试从存储获取\n    if req is None:\n        creds = mgr.get_credentials(target_ip)\n        if not creds:\n            log_error(\"connect\", {\"mac\": device_mac, \"error\": \"设备未保存凭据\"})\n            return {\"success\": False, \"message\": \"设备未保存凭据，请先提供用户名和密码\"}\n        username = creds[\"username\"]\n        password = creds[\"password\"]\n        port = creds.get(\"port\", 80)\n    else:\n        username = req.username or \"admin\"\n        if not req.password:\n            return {\"success\": False, \"message\": \"请提供密码\"}\n        password = req.password\n        port = req.port\n\n    result = mgr.connect_device(target_ip, username, password, port)\n    if result and result.get(\"success\"):\n        log_info(\"connect\", {\"mac\": device_mac, \"ip\": target_ip, \"status\": \"success\"})\n        # 更新 DeviceManager 状态\n        dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\n        if dm:\n            dm.update_status(device_mac, \"online\")\n        return result\n    \n    log_error(\"connect\", {\"mac\": device_mac, \"ip\": target_ip, \"status\": \"failed\"})\n    return result or {\"success\": False, \"message\": \"连接失败\"}","oldText":"async def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\n    \"\"\"连接 PTZ 设备并认证。\n\n    device_id 可以是 IP 地址或 MAC 地址。如果是 MAC，自动解析为 IP。\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\n    \n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\n    \"\"\"\n    \"\"\"\n    log_api(\"connect\", {\"device_id\": device_id})\n    \n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\n    if not mgr:\n        log_error(\"connect\", {\"device_id\": device_id, \"error\": \"PTZManager 未初始化\"})\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n\n    # 解析 device_id: 如果看起来像 MAC，从发现缓存中解析 IP\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        log_error(\"connect\", {\"device_id\": device_id, \"error\": \"无法解析设备标识\"})\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}，请提供 IP 地址或确保设备已通过 SADP 发现\"}\n\n    # 如果未提供凭据，尝试从存储获取\n    if req is None:\n        creds = mgr.get_credentials(target_ip)\n        if not creds:\n            log_error(\"connect\", {\"device_id\": device_id, \"error\": \"设备未保存凭据\"})\n            return {\"success\": False, \"message\": \"设备未保存凭据，请先提供用户名和密码\"}\n        username = creds[\"username\"]\n        password = creds[\"password\"]\n        port = creds.get(\"port\", 80)\n    else:\n        username = req.username or \"admin\"\n        if not req.password:\n            return {\"success\": False, \"message\": \"请提供密码\"}\n        password = req.password\n        port = req.port\n\n    result = mgr.connect_device(target_ip, username, password, port)\n    if result and result.get(\"success\"):\n        log_info(\"connect\", {\"device_id\": device_id, \"ip\": target_ip, \"status\": \"success\"})\n        # 更新 DeviceManager 状态（使用 device_id 保持前端一致）\n        dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\n        if dm:\n            dm.update_status(device_id, \"online\")\n        return result\n    \n    log_error(\"connect\", {\"device_id\": device_id, \"ip\": target_ip, \"status\": \"failed\"})\n    return result or {\"success\": False, \"message\": \"连接失败\"}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":131838,"output":1472,"cacheRead":0,"cacheWrite":0,"totalTokens":133310,"cost":{"input":0.13183799999999998,"output":0.0047104,"cacheRead":0,"cacheWrite":0,"total":0.1365484}},"stopReason":"toolUse","timestamp":1781361396004,"responseId":"cht000d1a93@dx19ec169d4b2ba60352"}}
