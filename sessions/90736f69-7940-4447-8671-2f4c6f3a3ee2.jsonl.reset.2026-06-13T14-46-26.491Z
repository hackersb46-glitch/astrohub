{"type":"message","id":"640156de","parentId":"ec572b8a","timestamp":"2026-06-13T06:42:11.955Z","message":{"role":"assistant","content":[{"type":"text","text":"现在修复后端 API `/ptz/{device_id}/function` - 使用正确的路径读取 `function.json`："},{"type":"toolCall","id":"tool-5366f873a78f4630b6e3513f6285dc39","name":"edit","arguments":{"edits":[{"newText":"@api_router.get(\"/ptz/{device_id}/function\", summary=\"获取设备function.json\", tags=[\"Image\"])\nasync def get_device_function(device_id: str) -> dict:\n    \"\"\"v6.20: 从 data/devices/{mac}/function.json 读取设备功能参数范围。\"\"\"\n    import json\n    from pathlib import Path\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\", \"data\": None}\n    \n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\", \"data\": None}\n    \n    # v6.20: 使用正确的路径 data/devices/{mac}/function.json\n    from src.advanced.device_path import get_devices_dir\n    devices_dir = get_devices_dir()\n    \n    # 遍历所有设备目录查找 function.json\n    for device_dir in devices_dir.iterdir():\n        if device_dir.is_dir():\n            # 检查 info.json 中的 IP 是否匹配\n            info_file = device_dir / \"info.json\"\n            if info_file.exists():\n                try:\n                    info = json.loads(info_file.read_text(encoding=\"utf-8\"))\n                    if info.get(\"ip\") == target_ip:\n                        # IP 匹配，读取 function.json\n                        func_file = device_dir / \"function.json\"\n                        if func_file.exists():\n                            func_data = json.loads(func_file.read_text(encoding=\"utf-8\"))\n                            return {\"success\": True, \"data\": func_data}\n                        else:\n                            return {\"success\": False, \"message\": \"未找到 function.json，请先完成功能测试\", \"data\": None}\n                except Exception as e:\n                    continue\n    \n    return {\"success\": False, \"message\": \"未找到该设备的设备目录\", \"data\": None}","oldText":"@api_router.get(\"/ptz/{device_id}/function\", summary=\"获取设备function.json\", tags=[\"Image\"])\nasync def get_device_function(device_id: str) -> dict:\n    \"\"\"从 data/{device_model}/*/function.json 读取设备功能参数范围。\"\"\"\n    import json\n    from pathlib import Path\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\n    \n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n    \n    # 从 data 目录查找 function.json\n    data_dir = Path(__file__).resolve().parent.parent.parent / \"data\"\n    if not data_dir.exists():\n        return {\"success\": False, \"message\": \"data 目录不存在\", \"data\": None}\n    \n    # 遍历所有子目录查找 function.json\n    for subdir in data_dir.iterdir():\n        if subdir.is_dir():\n            for f in subdir.rglob(\"function.json\"):\n                try:\n                    with open(f, \"r\", encoding=\"utf-8\") as fh:\n                        func_data = json.load(fh)\n                    # 检查 IP 是否匹配\n                    if func_data.get(\"device_info\", {}).get(\"ip\") == target_ip:\n                        return {\"success\": True, \"data\": func_data}\n                except Exception:\n                    continue\n    \n    return {\"success\": False, \"message\": \"未找到该设备的 function.json\", \"data\": None}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":117142,"output":935,"cacheRead":0,"cacheWrite":0,"totalTokens":118077,"cost":{"input":0.117142,"output":0.0029920000000000003,"cacheRead":0,"cacheWrite":0,"total":0.12013399999999999}},"stopReason":"toolUse","timestamp":1781332901473,"responseId":"cht000df414@dx19ebfb71acdb85e102"}}
