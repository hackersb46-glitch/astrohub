{"type":"message","id":"a2d1dcc3","parentId":"5bfb888f","timestamp":"2026-06-12T20:41:23.346Z","message":{"role":"toolResult","toolCallId":"call_2608f7b05fce4633b237214f","toolName":"read","content":[{"type":"text","text":"            \"zoom_limits\": self._zoom_limits,\r\n            \"has_flip\": self._has_flip,\r\n        }\r\n\r\n\r\n# ================================================================ #\r\n#  独立运行入口\r\n# ================================================================ #\r\n\r\ndef run_limit_test(ip: str = None, username: str = None, password: str = None, port: int = None) -> dict:\r\n    \"\"\"独立运行Limit测试。\r\n    \r\n    自动读取设备配置，无需指定参数。\r\n    \r\n    Args:\r\n        ip: 设备IP（可选，默认从配置读取）\r\n        username: 用户名（可选，默认从配置读取）\r\n        password: 密码（可选，默认从配置读取）\r\n        port: 端口（可选，默认从配置读取）\r\n    \r\n    Returns:\r\n        测试结果\r\n    \"\"\"\r\n    from src.advanced.config_writer import load_device_config\r\n    \r\n    # 读取设备配置文件\r\n    device_config = load_device_config('240f9b764193')\r\n    if device_config is None:\r\n        return {\"success\": False, \"error\": \"未找到设备配置文件\"}\r\n    \r\n    # 从配置读取连接参数\r\n    if ip is None:\r\n        ip = device_config.ip or \"\"\r\n    if port is None:\r\n        port = device_config.port or 80\r\n    if username is None:\r\n        username = device_config.username or \"admin\"\r\n    if password is None:\r\n        password = device_config.password or \"\"\r\n    \r\n    if not ip:\r\n        return {\"success\": False, \"error\": \"设备配置未配置IP\"}\r\n    \r\n    # 连接设备\r\n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\r\n    if not client.verify_credentials():\r\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\r\n    \r\n    # 运行测试\r\n    tester = LimitTester(client)\r\n    result = tester.run_all_tests()\r\n    \r\n    # 更新设备信息\r\n    if tester._device_info:\r\n        mac = tester._device_info.get(\"mac_clean\", \"\")\r\n        model_short = tester._device_info.get(\"model_short\", \"\")\r\n        update_device_info(mac, model=model_short, ip=ip, port=port)\r\n    \r\n    return result\r\n\r\n\n[21 more lines in file. Use offset=1000 to continue.]"}],"isError":false,"timestamp":1781296883346}}
{"type":"message","id":"269f5a0e","parentId":"a2d1dcc3","timestamp":"2026-06-12T20:42:06.139Z","message":{"role":"assistant","content":[{"type":"text","text":"修复 `limit.py` 的独立运行入口："},{"type":"toolCall","id":"tool-657f9e34514643cba7a8078ba4c059db","name":"edit","arguments":{"edits":[{"newText":"# ================================================================ #\n#  缓存读取函数 (v6.19 新增)\n# ================================================================ #\n\ndef load_cached_limit_results(mac: str) -> dict | None:\n    \"\"\"从本地缓存读取限位测试结果。\n    \n    v6.19: 优先读取本地缓存，避免每次调用设备API。\n    \n    Args:\n        mac: MAC地址（无分隔符小写）\n    \n    Returns:\n        缓存结果字典，不存在返回 None\n    \"\"\"\n    try:\n        cache_path = get_data_path_read(None, mac, 'limit')\n        if cache_path is None or not cache_path.exists():\n            return None\n        import json\n        with open(cache_path, 'r', encoding='utf-8') as f:\n            return json.load(f)\n    except (json.JSONDecodeError, OSError):\n        return None\n\n\ndef run_limit_test(\n    ip: str = None, \n    username: str = None, \n    password: str = None, \n    port: int = None,\n    mac: str = None,\n    use_cache: bool = True\n) -> dict:\n    \"\"\"独立运行Limit测试。\n    \n    v6.19: 优先读取本地缓存，缓存不存在时调用设备API。\n    \n    Args:\n        ip: 设备IP（可选）\n        username: 用户名（可选）\n        password: 密码（可选）\n        port: 端口（可选，默认80）\n        mac: MAC地址（可选，用于读取缓存）\n        use_cache: 是否优先使用缓存（默认True）\n    \n    Returns:\n        测试结果\n    \"\"\"\n    # 1. 优先读取缓存\n    if use_cache and mac:\n        cached = load_cached_limit_results(mac)\n        if cached:\n            return {**cached, \"from_cache\": True}\n    \n    # 2. 检查必需参数\n    if not ip:\n        return {\"success\": False, \"error\": \"缺少设备IP参数\"}\n    \n    # 3. 连接设备并运行测试\n    username = username or \"admin\"\n    password = password or \"\"\n    port = port or 80\n    \n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n    if not client.verify_credentials():\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n    \n    tester = LimitTester(client)\n    result = tester.run_all_tests()\n    \n    return {**result, \"from_cache\": False}\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"AstroHub Limit测试\")\n    parser.add_argument(\"--ip\", type=str, required=True, help=\"设备IP\")\n    parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n    parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n    parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n    parser.add_argument(\"--mac\", type=str, help=\"MAC地址（用于缓存）\")\n    parser.add_argument(\"--no-cache\", action=\"store_true\", help=\"禁用缓存\")\n    args = parser.parse_args()\n    \n    print(\"=\" * 50)\n    print(\"AstroHub Limit测试\")\n    print(\"=\" * 50)\n    \n    result = run_limit_test(\n        ip=args.ip, \n        username=args.username, \n        password=args.password, \n        port=args.port,\n        mac=args.mac,\n        use_cache=not args.no_cache\n    )\n    \n    if result.get(\"success\"):\n        cache_note = \" (缓存)\" if result.get(\"from_cache\") else \"\"\n        print(f\"[完成] 限位测试: Pan={result.get('pan_min', 0)}-{result.get('pan_max', 3600)}, Tilt={result.get('tilt_min', -200)}-{result.get('tilt_max', 900)}{cache_note}\")\n    else:\n        print(f\"[失败] {result.get('error', result.get('message', '未知错误'))}\")","oldText":"# ================================================================ #\n#  独立运行入口\n# ================================================================ #\n\ndef run_limit_test(ip: str = None, username: str = None, password: str = None, port: int = None) -> dict:\n    \"\"\"独立运行Limit测试。\n    \n    自动读取设备配置，无需指定参数。\n    \n    Args:\n        ip: 设备IP（可选，默认从配置读取）\n        username: 用户名（可选，默认从配置读取）\n        password: 密码（可选，默认从配置读取）\n        port: 端口（可选，默认从配置读取）\n    \n    Returns:\n        测试结果\n    \"\"\"\n    from src.advanced.config_writer import load_device_config\n    \n    # 读取设备配置文件\n    device_config = load_device_config('240f9b764193')\n    if device_config is None:\n        return {\"success\": False, \"error\": \"未找到设备配置文件\"}\n    \n    # 从配置读取连接参数\n    if ip is None:\n        ip = device_config.ip or \"\"\n    if port is None:\n        port = device_config.port or 80\n    if username is None:\n        username = device_config.username or \"admin\"\n    if password is None:\n        password = device_config.password or \"\"\n    \n    if not ip:\n        return {\"success\": False, \"error\": \"设备配置未配置IP\"}\n    \n    # 连接设备\n    client = ISAPIClient(ip=ip, username=username, password=password, port=port)\n    if not client.verify_credentials():\n        return {\"success\": False, \"error\": f\"设备认证失败: {ip}\"}\n    \n    # 运行测试\n    tester = LimitTester(client)\n    result = tester.run_all_tests()\n    \n    # 更新设备信息\n    if tester._device_info:\n        mac = tester._device_info.get(\"mac_clean\", \"\")\n        model_short = tester._device_info.get(\"model_short\", \"\")\n        update_device_info(mac, model=model_short, ip=ip, port=port)\n    \n    return result\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"AstroHub Limit测试\")\n    parser.add_argument(\"--ip\", type=str, help=\"设备IP (默认从配置读取)\")\n    parser.add_argument(\"--username\", type=str, help=\"用户名 (默认从配置读取)\")\n    parser.add_argument(\"--password\", type=str, help=\"密码 (默认从配置读取)\")\n    parser.add_argument(\"--port\", type=int, help=\"端口 (默认从配置读取)\")\n    args = parser.parse_args()\n    \n    print(\"=\" * 50)\n    print(\"AstroHub Limit测试\")\n    print(\"=\" * 50)\n    \n    result = run_limit_test(ip=args.ip, username=args.username, password=args.password, port=args.port)\n    \n    if result.get(\"success\"):\n        print(f\"[完成] 限位测试: Pan={result.get('pan_min', 0)}-{result.get('pan_max', 3600)}, Tilt={result.get('tilt_min', -200)}-{result.get('tilt_max', 900)}\")\n    else:\n        print(f\"[失败] {result.get('error', result.get('message', '未知错误'))}\")"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\advanced\\limit.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":87320,"output":1868,"cacheRead":0,"cacheWrite":0,"totalTokens":89188,"cost":{"input":0.08732,"output":0.0059776000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0932976}},"stopReason":"toolUse","timestamp":1781296883347,"responseId":"cht000d7836@dx19ebd916dc0b85f582"}}
