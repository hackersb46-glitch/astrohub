{"type":"message","id":"2e6b9dc4","parentId":"00fe558c","timestamp":"2026-06-13T06:30:21.935Z","message":{"role":"toolResult","toolCallId":"call_f4bacbf62d8e4f9094e62ede","toolName":"read","content":[{"type":"text","text":"            wasmStatus.textContent = '视频: WASM';\r\n        } else if (state === 'disconnected') {\r\n            wasmDot.className = 'status-dot red';\r\n            wasmStatus.textContent = '视频: 未连接';\r\n        }\r\n    };\r\n    \r\n    // v6.18: 简化快速连接 - 直接从后端获取上次设备\r\n    var _quickConnectSkipNext = false;\r\n    window.quickConnect = function(checked) {\r\n        if (_quickConnectSkipNext) {\r\n            _quickConnectSkipNext = false;\r\n            return;\r\n        }\r\n        if (checked) {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                console.log('[QUICK] Already connected');\r\n                return;\r\n            }\r\n            // v6.18: 从后端获取上次连接的设备\r\n            apiGet('/api/v1/ptz/connected').then(function(r) {\r\n                if (r && r.success && r.device) {\r\n                    console.log('[QUICK] Connecting to:', r.device.ip);\r\n                    if (window.connectDevice) {\r\n                        window.connectDevice(r.device.ip);\r\n                    }\r\n                } else {\r\n                    showToast('warning', '无上次连接设备，请执行发现流程');\r\n                    _quickConnectSkipNext = true;\r\n                    document.getElementById('quickConnectSwitch').checked = false;\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '获取设备信息失败');\r\n                _quickConnectSkipNext = true;\r\n                document.getElementById('quickConnectSwitch').checked = false;\r\n            });\r\n        } else {\r\n            if (window.connectedDevice && window.connectedDevice.ip) {\r\n                disconnectDevice(window.connectedDevice.ip);\r\n            }\r\n        }\r\n    };\r\n    \r\n    // 确认重启\r\n    window.confirmRestart = function() {\r\n        if (!confirm('确定要重启 AstroHub 吗？\\n重启期间服务将暂时不可用。')) return;\r\n        \r\n        showToast('info', '正在重启 AstroHub...');\r\n        \r\n        // 调用重启 API\r\n        apiPost('/api/v1/system/restart', null).then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '重启中，10秒后自动刷新页面...');\r\n                setTimeout(function() {\r\n                    location.reload();\r\n                }, 10000);\r\n            } else {\r\n                showToast('error', r ? r.message : '重启失败');\r\n            }\r\n        }).catch(function(e) {\r\n            // 即使请求失败，也假设重启成功（服务已停止）\r\n            showToast('warning', '重启中，10秒后自动刷新页面...');\r\n            setTimeout(function() {\r\n                location.reload();\r\n            }, 10000);\r\n        });\r\n    };\r\n    \r\n    // 页面切换函数\r\n    window.switchPage = function(page) {\r\n        document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });\r\n        document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\r\n        document.querySelector('[data-page=\"' + page + '\"]').classList.add('active');\r\n        document.getElementById('page-' + page).classList.add('active');\r\n    };\r\n    \r\n    console.log('[GLOBAL v5.27] Functions ready');\r\n    </script>\r\n</body>\r\n</html>\r\n\r\n\r\n\r\n\r\n\r\n\r\n"}],"isError":false,"timestamp":1781332221935}}
{"type":"message","id":"549879ae","parentId":"2e6b9dc4","timestamp":"2026-06-13T06:30:41.440Z","message":{"role":"assistant","content":[{"type":"text","text":"让我检查前端 `refreshDevices` 函数和断开连接后的状态："},{"type":"toolCall","id":"tool-31836bbba774433d97a92dc5a11ddf54","name":"read","arguments":{"limit":80,"offset":1150,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":89955,"output":60,"cacheRead":0,"cacheWrite":0,"totalTokens":90015,"cost":{"input":0.089955,"output":0.000192,"cacheRead":0,"cacheWrite":0,"total":0.09014699999999999}},"stopReason":"toolUse","timestamp":1781332221936,"responseId":"cht000d9175@dx19ebfacb1bbba5c342"}}
{"type":"message","id":"32bd53ae","parentId":"549879ae","timestamp":"2026-06-13T06:30:41.447Z","message":{"role":"toolResult","toolCallId":"tool-31836bbba774433d97a92dc5a11ddf54","toolName":"read","content":[{"type":"text","text":"        function autoSadpDiscover() {\r\n            if (_sadpAutoRunning) return;\r\n            _sadpAutoRunning = true;\r\n            apiGet('/api/v1/discovery/sadp').then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', 'SADP 发现 ' + (result.count || 0) + ' 台设备');\r\n                }\r\n                refreshDevices();  // 刷新设备列表（含网关信息）\r\n                _sadpAutoRunning = false;\r\n            }).catch(function(e) {\r\n                _sadpAutoRunning = false;\r\n            });\r\n        }\r\n        function refreshDevices() {\r\n            console.log('[REFRESH] refreshDevices called');\r\n            return apiGet('/api/v1/devices').then(function(result) {\r\n                console.log('[REFRESH] API response:', result);\r\n                if (!result.success) {\r\n                    allDevices = [];\r\n                    renderDevices([]);\r\n                    return;\r\n                }\r\n                allDevices = result.data || [];\r\n                renderDevices(allDevices);\r\n                // Update dashboard counters\r\n                var online = allDevices.filter(function(d) { return d.online; }).length;\r\n                var countEl = document.getElementById('devCount');\r\n                if (countEl) countEl.textContent = allDevices.length;\r\n                var onlineEl = document.getElementById('devOnline');\r\n                if (onlineEl) onlineEl.textContent = online;\r\n                var totalEl = document.getElementById('devTotal');\r\n                if (totalEl) totalEl.textContent = allDevices.length;\r\n                // Update PTZ & advanced device dropdowns\r\n                refreshPtzDeviceList();\r\n                refreshAdvancedDeviceSelectors();\r\n            }).catch(function(e) {\r\n                console.warn('Failed to refresh devices:', e);\r\n            });\r\n        }\r\n        function renderDevices(devices) {\r\n            var tb = document.getElementById('deviceTable');\r\n            if (!tb) return;\r\n            if (!devices.length) {\r\n                tb.innerHTML = '<tr><td colspan=\"8\" style=\"text-align:center;color:#6e7681\">暂无设备</td></tr>';\r\n                return;\r\n            }\r\n            var html = devices.map(function(d) {\r\n                var sourceBadge = d.source === 'sadp'\r\n                    ? '<span class=\"badge sadp\">SADP</span>'\r\n                    : '<span class=\"badge manual\">手动</span>';\r\n                var onlineBadge = d.online\r\n                    ? '<span class=\"badge online\">在线</span>'\r\n                    : '<span class=\"badge offline\">离线</span>';\r\n                var actions = buildDeviceActions(d);\r\n                return '<tr>'\r\n                    + '<td>' + sourceBadge + '</td>'\r\n                    + '<td>' + (d.mac || '--') + '</td>'\r\n                    + '<td>' + (d.ip || '--') + '</td>'\r\n                    + '<td>' + (d.gateway || '--') + '</td>'\r\n                    + '<td>' + (d.name || d.device_name || '--') + '</td>'\r\n                    + '<td>' + (d.model || '--') + '</td>'\r\n                    + '<td>' + onlineBadge + '</td>'\r\n                    + '<td>' + actions + '</td>'\r\n                    + '</tr>';\r\n            }).join('');\r\n            tb.innerHTML = html;\r\n        }\r\n        function buildDeviceActions(d) {\r\n            var btns = [];\r\n            if (d.online) {\r\n                btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"disconnectDevice(\\'' + d.ip + '\\')\">断开</button>');\r\n                btns.push('<button class=\"btn btn-secondary btn-sm\" onclick=\"showDeviceInfoInline(\\'' + d.ip + '\\')\">信息</button>');\r\n                // Add \"引导\" button for new devices\r\n            } else {\r\n                btns.push('<button class=\"btn btn-primary btn-sm\" onclick=\"connectDevice(\\'' + d.ip + '\\')\">连接</button>');\r\n            }\r\n            // Add modify IP button for all devices\r\n            btns.push('<button class=\"btn btn-warning btn-sm\" onclick=\"modifyIpPrompt(\\'' + (d.mac || '') + '\\',\\'' + (d.ip || '') + '\\')\">修改IP</button>');\r\n            btns.push('<button class=\"btn btn-danger btn-sm\" onclick=\"deleteDevice(\\'' + (d.mac || d.ip) + '\\')\">删除</button>');\r\n            return '<div class=\"actions\">' + btns.join('') + '</div>';\r\n\n[1457 more lines in file. Use offset=1230 to continue.]"}],"isError":false,"timestamp":1781332241447}}
