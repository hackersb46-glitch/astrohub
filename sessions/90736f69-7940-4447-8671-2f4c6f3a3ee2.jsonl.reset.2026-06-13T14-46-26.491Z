{"type":"message","id":"a7893726","parentId":"e4b760b4","timestamp":"2026-06-13T06:43:27.930Z","message":{"role":"assistant","content":[{"type":"text","text":"文件使用 CRLF 换行符。让我用 Python 脚本来修改："},{"type":"toolCall","id":"call_0c908d11b61f4e6d96f4eff6","name":"exec","arguments":{"command":"python -c \"\nimport re\n\nwith open('src/core/ptz_manager.py', 'r', encoding='utf-8') as f:\n    content = f.read()\n\n# 找到 disconnect_device 函数\nold_code = '''def disconnect_device(self, ip: str) -> None:\n        self._controllers.pop(ip, None)\n        client = self._clients.pop(ip, None)\n        if client:\n            try:\n                client.session.close()\n            except Exception:\n                pass\n        # 更新状态\n        ptz_cfg = self.config.load_ptz_config()\n        for key, dev in ptz_cfg.get(\\\"devices\\\", {}).items():\n            if dev.get(\\\"ip\\\") == ip:\n                dev[\\\"connected\\\"] = False\n                self.config.save_ptz_config(ptz_cfg)\n                break\n\n    def list_controllers(self) -> list[str]:\n        return list(self._controllers.keys())'''\n\nnew_code = '''def disconnect_device(self, ip: str) -> None:\n        \\\"\\\"\\\"v6.20: 断开设备连接，清除 registry.json 的 active_device。\\\"\\\"\\\"\n        self._controllers.pop(ip, None)\n        client = self._clients.pop(ip, None)\n        if client:\n            try:\n                client.session.close()\n            except Exception:\n                pass\n        \n        # 更新设备状态\n        ptz_cfg = self.config.load_ptz_config()\n        disconnected_mac = None\n        for key, dev in ptz_cfg.get(\\\"devices\\\", {}).items():\n            if dev.get(\\\"ip\\\") == ip:\n                dev[\\\"connected\\\"] = False\n                disconnected_mac = key\n                self.config.save_ptz_config(ptz_cfg)\n                break\n        \n        # v6.20: 清除 registry.json 的 active_device\n        if disconnected_mac and self._registry_file.exists():\n            try:\n                registry = json.loads(self._registry_file.read_text(encoding='utf-8'))\n                if registry.get('active_device') == disconnected_mac:\n                    registry['active_device'] = \\\"\\\"\n                    _atomic_write(self._registry_file, registry)\n                    LOG.log(\\\"info\\\", f\\\"registry.json active_device cleared for {disconnected_mac}\\\")\n            except Exception as e:\n                LOG.log(\\\"warning\\\", f\\\"更新 registry.json 失败: {e}\\\")\n\n    def list_controllers(self) -> list[str]:\n        return list(self._controllers.keys())'''\n\nif old_code in content:\n    content = content.replace(old_code, new_code)\n    with open('src/core/ptz_manager.py', 'w', encoding='utf-8') as f:\n        f.write(content)\n    print('OK: disconnect_device updated')\nelse:\n    print('ERROR: old_code not found')\n\"","workdir":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":136342,"output":610,"cacheRead":0,"cacheWrite":0,"totalTokens":136952,"cost":{"input":0.136342,"output":0.0019520000000000002,"cacheRead":0,"cacheWrite":0,"total":0.138294}},"stopReason":"toolUse","timestamp":1781332988605,"responseId":"cht000d5b68@dx19ebfb85566ba60352"}}
