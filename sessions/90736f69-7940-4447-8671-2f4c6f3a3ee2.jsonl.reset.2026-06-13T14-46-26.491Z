{"type":"message","id":"82430c2f","parentId":"60a95b40","timestamp":"2026-06-13T06:42:47.290Z","message":{"role":"assistant","content":[{"type":"text","text":"修复 `disconnect_device` 函数 - 添加清除 `registry.json` 的 `active_device`："},{"type":"toolCall","id":"tool-ddd333642873416a99bdf54276f56fd7","name":"edit","arguments":{"edits":[{"newText":"    def disconnect_device(self, ip: str) -> None:\n        \"\"\"v6.20: 断开设备连接，清除 registry.json 的 active_device。\"\"\"\n        self._controllers.pop(ip, None)\n        client = self._clients.pop(ip, None)\n        if client:\n            try:\n                client.session.close()\n            except Exception:\n                pass\n        \n        # 更新设备状态\n        ptz_cfg = self.config.load_ptz_config()\n        for key, dev in ptz_cfg.get(\"devices\", {}).items():\n            if dev.get(\"ip\") == ip:\n                dev[\"connected\"] = False\n                self.config.save_ptz_config(ptz_cfg)\n                break\n        \n        # v6.20: 清除 registry.json 的 active_device\n        import json\n        if self._registry_file.exists():\n            try:\n                registry = json.loads(self._registry_file.read_text(encoding='utf-8'))\n                # 如果当前断开的设备是活跃设备，清除 active_device\n                if registry.get('active_device') == key:\n                    registry['active_device'] = \"\"\n                    _atomic_write(self._registry_file, registry)\n                    LOG.log(\"info\", f\"registry.json active_device cleared for {key}\")\n            except Exception as e:\n                LOG.log(\"warning\", f\"更新 registry.json 失败: {e}\")","oldText":"    def disconnect_device(self, ip: str) -> None:\n        self._controllers.pop(ip, None)\n        client = self._clients.pop(ip, None)\n        if client:\n            try:\n                client.session.close()\n            except Exception:\n                pass\n        # 更新状态\n        ptz_cfg = self.config.load_ptz_config()\n        for key, dev in ptz_cfg.get(\"devices\", {}).items():\n            if dev.get(\"ip\") == ip:\n                dev[\"connected\"] = False\n                self.config.save_ptz_config(ptz_cfg)\n                break"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\core\\ptz_manager.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":119791,"output":515,"cacheRead":0,"cacheWrite":0,"totalTokens":120306,"cost":{"input":0.119791,"output":0.0016480000000000002,"cacheRead":0,"cacheWrite":0,"total":0.12143899999999999}},"stopReason":"toolUse","timestamp":1781332949859,"responseId":"cht000d7dab@dx19ebfb7be84b958232"}}
