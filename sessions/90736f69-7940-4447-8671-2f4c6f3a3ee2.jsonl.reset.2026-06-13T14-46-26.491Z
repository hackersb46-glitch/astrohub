e') == disconnected_mac:\n                    registry['active_device'] = \"\"\n                    _atomic_write(self._registry_file, registry)\n                    LOG.log(\"info\", f\"registry.json active_device cleared for {disconnected_mac}\")\n            except Exception as e:\n                LOG.log(\"warning\", f\"更新 registry.json 失败: {e}\")\n\n    def list_controllers(self) -> list[str]:\n        return list(self._controllers.keys())'''\n\nif old_code in content:\n    content = content.replace(old_code, new_code)\n    with open('src/core/ptz_manager.py', 'w', encoding='utf-8') as f:\n        f.write(content)\n    print('OK: disconnect_device updated')\nelse:\n    print('ERROR: old_code not found')\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\fix_disconnect.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":122548,"output":570,"cacheRead":0,"cacheWrite":0,"totalTokens":123118,"cost":{"input":0.12254799999999999,"output":0.001824,"cacheRead":0,"cacheWrite":0,"total":0.124372}},"stopReason":"toolUse","timestamp":1781333008414,"responseId":"cht000d1143@dx19ebfb8b91eb9cb212"}}
