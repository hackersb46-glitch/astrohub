{"type":"message","id":"45f465d3","parentId":"f96606d7","timestamp":"2026-06-13T07:45:07.191Z","message":{"role":"toolResult","toolCallId":"call_05402cb58a334174af4cff37","toolName":"read","content":[{"type":"text","text":"                \"name\": device_name,\r\n                \"model\": model,\r\n            }\r\n        LOG.log(\"failed\", f\"PTZ 设备认证失败: {ip}\")\r\n        return {\"success\": False, \"message\": \"认证失败，请检查凭据\"}\r\n\r\n    def disconnect_device(self, ip: str) -> None:\r\n        \"\"\"v6.30: 断开设备连接。清除 active_device，保留 last_connected 用于下次快速连接。\"\"\"\r\n        self._controllers.pop(ip, None)\r\n        client = self._clients.pop(ip, None)\r\n        if client:\r\n            try:\r\n                client.session.close()\r\n            except Exception:\r\n                pass\r\n        \r\n        # 更新设备状态\r\n        ptz_cfg = self.config.load_ptz_config()\r\n        disconnected_mac = None\r\n        for key, dev in ptz_cfg.get(\"devices\", {}).items():\r\n            if dev.get(\"ip\") == ip:\r\n                dev[\"connected\"] = False\r\n                disconnected_mac = key\r\n                self.config.save_ptz_config(ptz_cfg)\r\n                break\r\n        \r\n        # v6.30: 清除 active_device，保留 last_connected\r\n        if disconnected_mac and self._registry_file.exists():\r\n            try:\r\n                registry = json.loads(self._registry_file.read_text(encoding='utf-8'))\r\n\n[1178 more lines in file. Use offset=1700 to continue.]"}],"isError":false,"timestamp":1781336707191}}
