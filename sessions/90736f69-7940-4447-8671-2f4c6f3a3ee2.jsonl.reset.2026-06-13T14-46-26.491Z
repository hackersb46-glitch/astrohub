{"type":"message","id":"8678120a","parentId":"c5a2d75b","timestamp":"2026-06-13T08:45:49.625Z","message":{"role":"toolResult","toolCallId":"call_9af2133963f54ab28be675cb","toolName":"read","content":[{"type":"text","text":"\n// v6.20: 功能支持状态\nvar deviceFunctionData = null;\nvar functionCacheLoaded = false;\n\n// v6.20: 禁用画面控制所有控件\nfunction disableImageControls(reason) {\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = true;\n            el.style.opacity = '0.5';\n            el.style.cursor = 'not-allowed';\n        }\n    });\n    \n    // 显示提示文字\n    var section = document.getElementById('imageControlSection');\n    if (section) {\n        var content = section.querySelector('.collapsible-content');\n        if (content && !document.getElementById('functionCacheWarning')) {\n            var warning = document.createElement('div');\n            warning.id = 'functionCacheWarning';\n            warning.style.cssText = 'background:#4a3a1a;border:1px solid #d29922;border-radius:6px;padding:12px;margin:8px 0;color:#d29922;font-size:12px;text-align:center';\n            warning.innerHTML = '<strong>⚠️ ' + reason + '</strong><br><span style=\"color:#8b949e\">请在「高级功能 → 功能探测」中完成测试</span>';\n            content.insertBefore(warning, content.firstChild);\n        }\n    }\n}\n\n// v6.20: 启用画面控制\nfunction enableImageControls() {\n    var controls = [\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\n        'exposureMode', 'shutterSpeed', 'irisLevel',\n        'infoOsdSwitch', 'ptzOsdSwitch'\n    ];\n    controls.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) {\n            el.disabled = false;\n            el.style.opacity = '1';\n            el.style.cursor = 'pointer';\n        }\n    });\n    \n    // 移除警告\n    var warning = document.getElementById('functionCacheWarning');\n    if (warning) warning.remove();\n}\n\n// 连接设备时加载图像参数（从function.json读取范围，从ISAPI读取当前值）\n// v6.20: 优先读取缓存，无缓存时禁用控件\nfunction loadDeviceImageParams(deviceIp) {\n    if (!deviceIp) return;\n    \n    if (typeof apiGet === 'undefined') {\n        console.error('[IMAGE] apiGet not defined');\n        return;\n    }\n    \n    console.log('[IMAGE] Loading image params for:', deviceIp);\n    \n    // v6.20: 重置状态\n    functionCacheLoaded = false;\n    deviceFunctionData = null;\n    \n    // v6.20: 使用 async/await 确保顺序但不阻塞 UI\n    (async function() {\n        // 1. 先尝试加载 function.json 缓存\n        try {\n            var r = await apiGet('/api/v1/ptz/' + deviceIp + '/function');\n            if (r && r.success && r.data && r.data.results) {\n\n[608 more lines in file. Use offset=460 to continue.]"}],"isError":false,"timestamp":1781340349625}}
{"type":"message","id":"1000cceb","parentId":"8678120a","timestamp":"2026-06-13T08:46:05.949Z","message":{"role":"assistant","content":[{"type":"text","text":"检查后端 API `/api/v1/ptz/{device_id}/function` 是否正确读取："},{"type":"toolCall","id":"call_70ba4d063c5e471296c2b672","name":"read","arguments":{"limit":40,"offset":490,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5.1","usage":{"input":109521,"output":67,"cacheRead":0,"cacheWrite":0,"totalTokens":109588,"cost":{"input":0.109521,"output":0.0002144,"cacheRead":0,"cacheWrite":0,"total":0.1097354}},"stopReason":"toolUse","timestamp":1781340349627,"responseId":"cht000d6ffc@dx19ec028c9a9ba60352"}}
{"type":"message","id":"13b94aa1","parentId":"1000cceb","timestamp":"2026-06-13T08:46:05.959Z","message":{"role":"toolResult","toolCallId":"call_70ba4d063c5e471296c2b672","toolName":"read","content":[{"type":"text","text":"@api_router.post(\"/devices/{device_id}/connect\", summary=\"连接设备\", tags=[\"Devices\"])\r\nasync def connect_device(device_id: str, req: ConnectDeviceRequest | None = None) -> dict:\r\n    \"\"\"连接 PTZ 设备并认证。\r\n\r\n    device_id 可以是 IP 地址或 MAC 地址。如果是 MAC，自动解析为 IP。\r\n    使用 admin 作为默认用户名，密码必须由用户提供或已保存在配置中。\r\n    \r\n    BUG-014 修复: ISAPI 连接前 socket 预检，5 秒超时快速失败。\r\n    \"\"\"\r\n    mgr: PTZManager | None = _managers.get(\"ptz_manager\")  # type: ignore[assignment]\r\n    if not mgr:\r\n        return {\"success\": False, \"message\": \"PTZManager 未初始化\"}\r\n\r\n    # 解析 device_id: 如果看起来像 MAC，从发现缓存中解析 IP\r\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\r\n    if not target_ip:\r\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}，请提供 IP 地址或确保设备已通过 SADP 发现\"}\r\n\r\n    # 如果未提供凭据，尝试从存储获取\r\n    if req is None:\r\n        creds = mgr.get_credentials(target_ip)\r\n        if not creds:\r\n            return {\"success\": False, \"message\": \"设备未保存凭据，请先提供用户名和密码\"}\r\n        username = creds[\"username\"]\r\n        password = creds[\"password\"]\r\n        port = creds.get(\"port\", 80)\r\n    else:\r\n        username = req.username or \"admin\"\r\n        if not req.password:\r\n            return {\"success\": False, \"message\": \"请提供密码\"}\r\n        password = req.password\r\n        port = req.port\r\n\r\n    result = mgr.connect_device(target_ip, username, password, port)\r\n    if result and result.get(\"success\"):\r\n        # 更新 DeviceManager 状态（使用 device_id 保持前端一致）\r\n        dm: DeviceManager | None = _managers.get(\"device_manager\")  # type: ignore[assignment]\r\n        if dm:\r\n            dm.update_status(device_id, \"online\")\r\n        return result\r\n\n[2634 more lines in file. Use offset=530 to continue.]"}],"isError":false,"timestamp":1781340365959}}
