8     # 更新设备信息\n-649     from src.advanced.config_writer import load_device_config, save_device_config, DeviceConfig\n-650     config = load_device_config('240f9b764193')\n-651     if config:\n-652         config.speed = {\"last_test\": len(results)}\n-653         save_device_config(config)\n-654     \n 655     return {\n 656         \"success\": len(results) > 0,\n 657         \"total_tests\": len(results),\n-658         \"results\": results\n+676         \"results\": results,\n+677         \"from_cache\": False\n 659     }\n 660 \n 661 \n 662 if __name__ == \"__main__\":\n 663     import argparse\n 664     parser = argparse.ArgumentParser(description=\"AstroHub Speed测试\")\n-665     parser.add_argument(\"--ip\", type=str, help=\"设备IP (默认从配置读取)\")\n-666     parser.add_argument(\"--username\", type=str, help=\"用户名 (默认从配置读取)\")\n-667     parser.add_argument(\"--password\", type=str, help=\"密码 (默认从配置读取)\")\n-668     parser.add_argument(\"--port\", type=int, help=\"端口 (默认从配置读取)\")\n+684     parser.add_argument(\"--ip\", type=str, required=True, help=\"设备IP\")\n+685     parser.add_argument(\"--username\", type=str, default=\"admin\", help=\"用户名\")\n+686     parser.add_argument(\"--password\", type=str, default=\"\", help=\"密码\")\n+687     parser.add_argument(\"--port\", type=int, default=80, help=\"端口\")\n 669     parser.add_argument(\"--profile\", type=str, default=\"lite\", choices=['lite', 'medium', 'full'], help=\"速度档位模式\")\n+689     parser.add_argument(\"--mac\", type=str, help=\"MAC地址（用于缓存）\")\n+690     parser.add_argument(\"--no-cache\", action=\"store_true\", help=\"禁用缓存\")\n 670     args = parser.parse_args()\n 671     \n 672     _print(\"=\" * 50)\n 673     _print(\"AstroHub Speed测试\")\n 674     _print(\"=\" * 50)\n 675     \n-676     result = run_speed_test(ip=args.ip, username=args.username, password=args.password, port=args.port, speed_profile=args.profile)\n+697     result = run_speed_test(\n+698         ip=args.ip, \n+699         username=args.username, \n+700         password=args.password, \n+701         port=args.port, \n+702         speed_profile=args.profile,\n+703         mac=args.mac,\n+704         use_cache=not args.no_cache\n+705     )\n 677     \n 678     if result.get(\"success\"):\n-679         _print(f\"[完成] 速度测试: {result.get('total_tests', 0)} 项\")\n+708         cache_note = \" (缓存)\" if result.get(\"from_cache\") else \"\"\n+709         _print(f\"[完成] 速度测试: {result.get('total_tests', 0)} 项{cache_note}\")\n 680     else:\n 681         _print(f\"[失败] {result.get('error', '未知错误')}\")","firstChangedLine":598},"isError":false,"timestamp":1781296999147}}
