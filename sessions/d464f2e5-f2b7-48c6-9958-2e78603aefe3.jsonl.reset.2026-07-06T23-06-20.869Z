{"type":"message","id":"69f444f2","parentId":"59840aa0","timestamp":"2026-07-06T19:01:14.430Z","message":{"role":"toolResult","toolCallId":"call_8f463450e53f43edb18c3663","toolName":"exec","content":[{"type":"text","text":"Checking for Playwright browsers...\r\nChromium: Error - 'BrowserType' object has no attribute 'launchers'\r\nFirefox: Error - 'BrowserType' object has no attribute 'launchers'\r\nWebkit: Error - 'BrowserType' object has no attribute 'launchers'\r\n\r\nSystem Chrome/Edge: C:/Program Files/Google/Chrome/Application/chrome.exe"}],"details":{"status":"completed","exitCode":0,"durationMs":1066,"aggregated":"Checking for Playwright browsers...\r\nChromium: Error - 'BrowserType' object has no attribute 'launchers'\r\nFirefox: Error - 'BrowserType' object has no attribute 'launchers'\r\nWebkit: Error - 'BrowserType' object has no attribute 'launchers'\r\n\r\nSystem Chrome/Edge: C:/Program Files/Google/Chrome/Application/chrome.exe","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783364474430}}
{"type":"message","id":"e8bdc989","parentId":"69f444f2","timestamp":"2026-07-06T19:01:49.342Z","message":{"role":"assistant","content":[{"type":"text","text":"Chrome 在！`C:/Program Files/Google/Chrome/Application/chrome.exe`。直接用 Playwright + channel=chrome 启动："},{"type":"toolCall","id":"call_d086b739c8414dbd99e65ca1","name":"write","arguments":{"content":"\"\"\"AstroHub 自动对焦测试 - Playwright 模拟用户操作\n\n操作流程：\n1. 打开 http://localhost:10280\n2. 等待主控台加载\n3. 切换对焦模式到\"局部\"\n4. 点击\"框选\"按钮\n5. 在画面中间30%区域拖拽选择\n6. 等待自动对焦完成（SSE事件）\n7. 截图 + 抓取操作日志\n\"\"\"\nimport time\nimport json\nfrom playwright.sync_api import sync_playwright\n\nBASE_URL = 'http://localhost:10280'\n\ndef main():\n    with sync_playwright() as p:\n        # 使用系统 Chrome\n        browser = p.chromium.launch(\n            channel='chrome',\n            headless=True,\n            args=['--no-sandbox', '--disable-gpu', '--disable-web-security']\n        )\n        page = browser.new_page(viewport={'width': 1920, 'height': 1080})\n        \n        print(\"=== AstroHub v8.59 自动对焦测试 ===\")\n        print(f\"开始: {time.strftime('%H:%M:%S')}\")\n        \n        # 1. 访问主控台\n        page.goto(BASE_URL, wait_until='networkidle', timeout=15000)\n        print(f\"[1] 页面加载完成\")\n        \n        # 2. 检查设备是否已连接\n        connected = page.evaluate(\"window.connectedDevice && window.connectedDevice.ip\")\n        print(f\"[2] 设备: {connected}\")\n        \n        if not connected:\n            print(\"[!] 设备未连接，尝试通过API连接...\")\n            # 通过 API 连接设备\n            page.evaluate(\"\"\"\n                fetch('/api/v1/ptz/connect', {\n                    method: 'POST',\n                    headers: {'Content-Type': 'application/json'},\n                    body: JSON.stringify({ip: '192.168.5.72'})\n                })\n            \"\"\")\n            page.wait_for_timeout(3000)\n            connected = page.evaluate(\"window.connectedDevice && window.connectedDevice.ip\")\n            print(f\"    设备连接后: {connected}\")\n        \n        if not connected:\n            print(\"[ERROR] 无法连接设备\")\n            browser.close()\n            return\n        \n        # 3. 切换到\"局部\"对焦模式\n        focus_mode = page.loc('#focusMode')\n        focus_mode.select_option('local')\n        page.wait_for_timeout(500)\n        print(f\"[3] 对焦模式: 局部\")\n        \n        # 4. 点击\"框选\"按钮\n        region_btn = page.loc('#btnFocusRegionSelect')\n        region_btn.click()\n        page.wait_for_timeout(500)\n        print(f\"[4] 点击框选按钮\")\n        \n        # 5. 在画面中间30%区域拖拽\n        overlay = page.loc('#regionOverlay')\n        box = overlay.bounding_box()\n        if not box:\n            print(\"[ERROR] 找不到 regionOverlay\")\n            browser.close()\n            return\n        \n        # 画面中间30%\n        start_x = box['x'] + box['width'] * 0.35\n        start_y = box['y'] + box['height'] * 0.35\n        end_x = box['x'] + box['width'] * 0.65\n        end_y = box['y'] + box['height'] * 0.65\n        \n        print(f\"[5] 框选区域: ({start_x:.0f},{start_y:.0f}) -> ({end_x:.0f},{end_y:.0f})\")\n        print(f\"    overlay: x={box['x']:.0f} y={box['y']:.0f} w={box['width']:.0f} h={box['height']:.0f}\")\n        \n        page.mouse.move(start_x, start_y)\n        page.mouse.down()\n        page.mouse.move(end_x, end_y, steps=10)\n        page.mouse.up()\n        \n        # 6. 等待自动对焦完成\n        print(f\"[6] 等待自动对焦完成...\")\n        \n        # 监听 operationLog 输出\n        logs = []\n        start_time = time.time()\n        timeout = 120  # 120秒超时\n        \n        while time.time() - start_time < timeout:\n            # 读取操作日志\n            log_el = page.loc('#operationLog')\n            if log_el:\n                log_text = log_el.inner_text()\n                new_lines = [l for l in log_text.split('\\n') if l.strip() and l not in logs]\n                for line in new_lines:\n                    logs.append(line)\n                    print(f\"    {line}\")\n            \n            # 检查是否完成\n            if any('完成' in l or '失败' in l or '错误' in l for l in logs[-5:]):\n                break\n            \n            page.wait_for_timeout(1000)\n        \n        elapsed = time.time() - start_time\n        print(f\"\\n[7] 耗时: {elapsed:.1f}s\")\n        \n        # 8. 截图\n        screenshot_path = 'tmp_af_screenshot.png'\n        page.screenshot(path=screenshot_path, full_page=True)\n        print(f\"[8] 截图: {screenshot_path}\")\n        \n        # 9. 最终日志\n        log_el = page.loc('#operationLog')\n        if log_el:\n            print(f\"\\n=== 操作日志 ===\")\n            print(log_el.inner_text())\n        \n        browser.close()\n        print(f\"\\n结束: {time.strftime('%H:%M:%S')}\")\n\nif __name__ == '__main__':\n    main()\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tmp_test_pw.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":112965,"output":1256,"cacheRead":0,"cacheWrite":0,"totalTokens":114221,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783364474433,"responseId":"cht000ddccb@dx19f38ce6d532871503"}}
