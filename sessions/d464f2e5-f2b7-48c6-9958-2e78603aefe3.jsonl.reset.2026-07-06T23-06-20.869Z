{"type":"message","id":"76159c6a","parentId":"5ee0c1c0","timestamp":"2026-07-06T19:13:20.141Z","message":{"role":"toolResult","toolCallId":"call_f514ec7ea89d4429940b49d2","toolName":"read","content":[{"type":"text","text":"            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"done\", \"contrast\": round(self._best_value, 2),\n                \"message\": f\"对焦成功(数据不足,使用best={self._best_value:.1f})\",\n                \"best\": self._best_value\n            }\n\n        # 拟合样条\n        spline = CubicSpline(x_vals, y_vals)\n        if spline._coeffs is None:\n            self._state = self.DONE\n            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"done\", \"contrast\": round(self._best_value, 2),\n                \"message\": f\"对焦成功(样条拟合失败,使用best={self._best_value:.1f})\",\n                \"best\": self._best_value\n            }\n\n        # 黄金分割搜索（3个区间取最优）\n        x_low = x_vals[0]\n        x_up = x_vals[-1]\n        x_mid = (x_low + x_up) / 2\n\n        candidates = []\n        for (lo, hi) in [(x_low, x_mid), (x_mid, x_up), (x_low, x_up)]:\n            try:\n                opt = golden_section_search(spline, lo, hi)\n                candidates.append(opt)\n            except Exception:\n                pass\n\n        if not candidates:\n            self._state = self.DONE\n            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"done\", \"contrast\": round(self._best_value, 2),\n                \"message\": f\"对焦成功(搜索失败,使用best={self._best_value:.1f})\",\n                \"best\": self._best_value\n            }\n\n        opt_x, opt_y = max(candidates, key=lambda c: c[1])\n        self._best_value = opt_y\n        self._optimal_pos = opt_x\n\n        # 计算移动到峰值位置的参数\n        current_pos = x_vals[-1]\n        delta = current_pos - opt_x  # 需要回退的步数\n\n        if abs(delta) < 0.1:\n            # 已在峰值附近\n            self._state = self.DONE\n            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"done\", \"contrast\": round(opt_y, 2),\n                \"message\": f\"对焦成功(峰值={opt_y:.1f}@pos={opt_x:.2f},已在峰值)\",\n                \"best\": opt_y\n            }\n\n        # 计算移动参数：回退 delta 步，每步 0.2s\n        move_dir = -self._direction  # 回退方向\n\n[194 more lines in file. Use offset=370 to continue.]"}],"isError":false,"timestamp":1783365200141}}
