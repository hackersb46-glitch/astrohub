{"type":"message","id":"bcfaec33","parentId":"076ef162","timestamp":"2026-07-06T18:52:11.580Z","message":{"role":"toolResult","toolCallId":"call_ad1b02c2cbc642b5a3f90e00","toolName":"exec","content":[{"type":"text","text":"C:\\Python\\Lib\\site-packages\\requests\\__init__.py:113: RequestsDependencyWarning: urllib3 (2.1.0) or chardet (7.2.0)/charset_normalizer (3.4.6) doesn't match a supported version!\r\n  warnings.warn(\r\n\r\n=== /api/v1/devices ===\r\nStatus: 200\r\nResponse: {\r\n  \"success\": true,\r\n  \"data\": [\r\n    {\r\n      \"mac\": \"240f9b764193\",\r\n      \"ip\": \"192.168.5.72\",\r\n      \"name\": \"4k 32X DC\",\r\n      \"model\": \"iDS-2DF8C832IXS-A\",\r\n      \"gateway\": \"\",\r\n      \"subnet_mask\": \"\",\r\n      \"has_credentials\": true\r\n    }\r\n  ],\r\n  \"total\": 1\r\n}\r\n\r\n=== /api/v1/ptz/connected ===\r\nStatus: 200\r\nResponse: {\r\n  \"success\": true,\r\n  \"connected\": true,\r\n  \"device\": {\r\n    \"ip\": \"192.168.5.72\",\r\n    \"mac\": \"240f9b764193\",\r\n    \"name\": \"4k 32X DC\",\r\n    \"model\": \"iDS-2DF8C832IXS-A\",\r\n    \"username\": \"admin\",\r\n    \"password\": \"Nftw1357\",\r\n    \"port\": 80,\r\n    \"device_name\": null\r\n  }\r\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":636,"aggregated":"C:\\Python\\Lib\\site-packages\\requests\\__init__.py:113: RequestsDependencyWarning: urllib3 (2.1.0) or chardet (7.2.0)/charset_normalizer (3.4.6) doesn't match a supported version!\r\n  warnings.warn(\r\n\r\n=== /api/v1/devices ===\r\nStatus: 200\r\nResponse: {\r\n  \"success\": true,\r\n  \"data\": [\r\n    {\r\n      \"mac\": \"240f9b764193\",\r\n      \"ip\": \"192.168.5.72\",\r\n      \"name\": \"4k 32X DC\",\r\n      \"model\": \"iDS-2DF8C832IXS-A\",\r\n      \"gateway\": \"\",\r\n      \"subnet_mask\": \"\",\r\n      \"has_credentials\": true\r\n    }\r\n  ],\r\n  \"total\": 1\r\n}\r\n\r\n=== /api/v1/ptz/connected ===\r\nStatus: 200\r\nResponse: {\r\n  \"success\": true,\r\n  \"connected\": true,\r\n  \"device\": {\r\n    \"ip\": \"192.168.5.72\",\r\n    \"mac\": \"240f9b764193\",\r\n    \"name\": \"4k 32X DC\",\r\n    \"model\": \"iDS-2DF8C832IXS-A\",\r\n    \"username\": \"admin\",\r\n    \"password\": \"Nftw1357\",\r\n    \"port\": 80,\r\n    \"device_name\": null\r\n  }\r\n}","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783363931580}}
{"type":"message","id":"6a65c7e6","parentId":"bcfaec33","timestamp":"2026-07-06T18:52:35.550Z","message":{"role":"assistant","content":[{"type":"text","text":"设备已连接：`192.168.5.72`。现在我要直接通过 API 模拟前端操作——发送 focus-search 请求，使用画面中间 30% 区域："},{"type":"toolCall","id":"call_e1e1141fd7e24464a3429546","name":"write","arguments":{"content":"\"\"\"模拟用户操作：画面中间30%自动对焦\n\n前端逻辑（index.html _finishRegion）：\n1. 用户框选区域 → 归一化坐标 (x, y, w, h)\n2. POST /api/v1/vision/focus-search\n3. 读取 SSE 事件流\n\n画面中间30% = x=0.35, y=0.35, w=0.30, h=0.30\n\"\"\"\nimport requests\nimport json\nimport time\n\nBASE_URL = 'http://localhost:10280'\n\n# 画面中间30%\nregion = {\n    \"x\": 0.35,\n    \"y\": 0.35,\n    \"w\": 0.30,\n    \"h\": 0.30\n}\n\nprint(f\"=== AstroHub v8.59 自动对焦测试 ===\")\nprint(f\"设备: 192.168.5.72 (4k 32X DC)\")\nprint(f\"区域: 画面中间30% (x={region['x']}, y={region['y']}, w={region['w']}, h={region['h']})\")\nprint(f\"开始时间: {time.strftime('%H:%M:%S')}\")\nprint(f\"=\" * 60)\n\n# POST 请求，读取 SSE 流\nurl = f'{BASE_URL}/api/v1/vision/focus-search'\nheaders = {'Content-Type': 'application/json'}\nbody = json.dumps(region)\n\ntry:\n    resp = requests.post(url, headers=headers, data=body, stream=True, timeout=120)\n    print(f\"HTTP {resp.status_code}\")\n    \n    if resp.status_code != 200:\n        print(f\"Error: {resp.text[:200]}\")\n    else:\n        # 读取 SSE 事件\n        buffer = \"\"\n        step_count = 0\n        start_time = time.time()\n        \n        for chunk in resp.iter_content(chunk_size=512, decode_unicode=True):\n            if chunk:\n                buffer += chunk\n                # 按 \\n\\n 分割事件\n                parts = buffer.split('\\n\\n')\n                buffer = parts.pop()  # 最后一段可能不完整\n                \n                for part in parts:\n                    if not part.startswith('data: '):\n                        continue\n                    try:\n                        ev = json.loads(part[6:])\n                        ev_type = ev.get('type', '')\n                        \n                        if ev_type == 'start':\n                            print(f\"[START] 裁剪区域: {ev.get('crop', '')}\")\n                        \n                        elif ev_type == 'focus':\n                            step_count += 1\n                            stage = ev.get('stage', '')\n                            action = ev.get('action', '')\n                            contrast = ev.get('contrast', 0)\n                            duration = ev.get('duration', 0)\n                            msg = ev.get('message', '')\n                            print(f\"  #{step_count:2d} [{stage:8s}] {action:12s} contrast={contrast:8.1f} dur={duration:.3f}s | {msg}\")\n                        \n                        elif ev_type == 'done':\n                            final_c = ev.get('final_contrast', 0)\n                            best_c = ev.get('best_contrast', 0)\n                            total = ev.get('total_steps', 0)\n                            verified = ev.get('verified', False)\n                            elapsed = time.time() - start_time\n                            print(f\"\\n[DONE] 最终反差={final_c} 峰值={best_c} 总步数={total} 验证={'PASS' if verified else 'FAIL'}\")\n                            print(f\"[TIME] 耗时 {elapsed:.1f}s\")\n                        \n                        elif ev_type == 'error':\n                            print(f\"[ERROR] {ev.get('message', '')}\")\n                        \n                        elif ev_type == 'interrupt':\n                            print(f\"[INTERRUPT] {ev.get('message', '')}\")\n                        \n                        elif ev_type == 'cleanup':\n                            print(f\"[CLEANUP] 清理完成\")\n                        \n                        elif ev_type == 'warning':\n                            print(f\"[WARNING] {ev.get('message', '')}\")\n                        \n                    except json.JSONDecodeError:\n                        pass\n        \n        print(f\"\\n结束时间: {time.strftime('%H:%M:%S')}\")\n        \nexcept requests.exceptions.Timeout:\n    print(\"[TIMEOUT] 对焦搜索超时（120s）\")\nexcept Exception as e:\n    print(f\"[EXCEPTION] {e}\")\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tmp_test_focus.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":110640,"output":990,"cacheRead":0,"cacheWrite":0,"totalTokens":111630,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783363931582,"responseId":"cht000d12c8@dx19f38c62b1c29c2503"}}
