{"type":"message","id":"1e365680","parentId":"ee8b78cf","timestamp":"2026-07-06T20:25:45.696Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_8e33c5ff9add4ed5b9737643","name":"write","arguments":{"content":"import sys\nsys.stdout.reconfigure(encoding='utf-8')\nfrom src.controlpanel.autofocus import ContrastAF\n\n# Test: 老板数据 (best at pos 4, scan to pos 7)\naf = ContrastAF()\ncontrasts = [79.97, 87.71, 97.49, 160.00, 329.41, 120.70, 94.01, 329.41]\nfor i, c in enumerate(contrasts):\n    cmd = af.step(c)\n    action = cmd['action']\n    stage = cmd['stage']\n    dur = cmd['duration']\n    msg = cmd['message'].encode('ascii', 'replace').decode()\n    print(f\"step {i+1}: c={c} -> {action}, {stage}, dur={dur}, msg={msg}\")\n    if cmd['action'] == 'stop':\n        break\n    if stage in ('approach1', 'approach2'):\n        print(f\"  --- {stage} phase ---\")\n        for j in range(15):\n            sim_c = 329.0 + (j * 2 if stage == 'approach2' else 0)\n            cmd = af.step(sim_c)\n            action = cmd['action']\n            stage2 = cmd['stage']\n            msg = cmd['message'].encode('ascii', 'replace').decode()\n            print(f\"  {stage} {j+1}: c={sim_c} -> {action}, {stage2}, msg={msg}\")\n            if cmd['action'] == 'stop':\n                break\n        break\n\n# Test: 阈值50检查\nprint(\"\\n=== Threshold test ===\")\naf2 = ContrastAF()\n# best=45 < 50, should not trigger fit\nlow_contrasts = [30, 35, 45, 40, 38, 35, 33]\nfor i, c in enumerate(low_contrasts):\n    cmd = af2.step(c)\n    stage = cmd['stage']\n    msg = cmd['message'].encode('ascii', 'replace').decode()\n    print(f\"  step {i+1}: c={c} -> {stage}, msg={msg}\")\n    if cmd['action'] == 'stop':\n        break\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tmp_test_v60.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":169441,"output":514,"cacheRead":0,"cacheWrite":0,"totalTokens":169955,"cost":{"input"