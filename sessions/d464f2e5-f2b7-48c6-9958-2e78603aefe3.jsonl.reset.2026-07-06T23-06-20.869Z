{"type":"message","id":"8056736b","parentId":"e25983fd","timestamp":"2026-07-06T20:22:04.671Z","message":{"role":"toolResult","toolCallId":"call_03a305ee6f024f4ea25e314c","toolName":"read","content":[{"type":"text","text":"function onFocusModeChange(mode) {\r\n    var moveControls = document.getElementById('focusMoveControls');\r\n    var localControls = document.getElementById('focusLocalControls');\r\n\r\n    if (mode === 'manual') {\r\n        if (moveControls) moveControls.style.display = 'block';\r\n        if (localControls) localControls.style.display = 'none';\r\n        setFocusMode('manual');\r\n    } else if (mode === 'local') {\r\n        if (moveControls) moveControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'block';\r\n        // v8.39: 局部模式自动切换到手动模式\r\n        setFocusMode('manual');\r\n    } else {\r\n        // 自动\r\n        if (moveControls) moveControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'none';\r\n        setFocusMode('auto');\r\n    }\r\n}\r\n\n[754 more lines in file. Use offset=1324 to continue.]"}],"isError":false,"timestamp":1783369324671}}
