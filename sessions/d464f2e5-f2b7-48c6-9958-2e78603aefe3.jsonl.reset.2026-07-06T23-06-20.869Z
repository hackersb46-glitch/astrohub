{"type":"message","id":"5ff4255a","parentId":"0087be14","timestamp":"2026-07-06T20:23:43.589Z","message":{"role":"assistant","content":[{"type":"text","text":"任务1完成。现在任务2和3：重写 autofocus.py 的 APPROACH 逻辑（两阶段逼近 + 阈值50）："},{"type":"toolCall","id":"call_8c010ba1753c4deaa5b1dd93","name":"write","arguments":{"content":"\"\"\"AstroHub v8.60 - 反差对焦模块（黄金分割+三次样条+两阶段逼近）\n\n算法流程：\n1. 扫描：等步长0.2s移动焦点，每步截图计算反差 → 收集 (position, contrast) 数据点\n2. 峰值检测：反差下降N步后确认峰值，停止扫描\n3. 三次样条拟合：对数据点拟合自然三次样条\n4. 黄金分割搜索：在样条曲线上精确找峰\n5. 粗逼近 APPROACH1：0.2s步进回退到峰值位置，获得 best2\n6. 精逼近 APPROACH2：0.1s步进微调，最多10步，获得 best3（必须 > best2）\n\n参考：github.com/russwong89/sharpness_detection_autofocus\n\"\"\"\n\nimport json\nimport asyncio\nimport math\nimport numpy as np\nfrom .region_base import calc_contrast, calc_stable_delay\n\n# 黄金分割比例\nGR = (math.sqrt(5) - 1) / 2\n\n# 反差阈值\nCONTRAST_THRESHOLD = 50\n\n\nclass CubicSpline:\n    \"\"\"自然三次样条插值。\n\n    在数据点之间拟合三次多项式段，\n    端点处二阶导数=0（自然样条）。\n    \"\"\"\n\n    def __init__(self, x_vals, y_vals):\n        self.x_vals = np.array(x_vals, dtype=float)\n        self.y_vals = np.array(y_vals, dtype=float)\n        self.n = len(x_vals) - 1\n        self._coeffs = None\n        self._fit()\n\n    def _fit(self):\n        \"\"\"求解三次样条系数。\"\"\"\n        n = self.n\n        if n < 1:\n            return\n\n        size = 4 * n\n        A = np.zeros((size, size))\n        b = np.zeros(size)\n\n        row = 0\n        for i in range(n):\n            A[row][4*i] = self.x_vals[i]**3\n            A[row][4*i+1] = self.x_vals[i]**2\n            A[row][4*i+2] = self.x_vals[i]\n            A[row][4*i+3] = 1\n            b[row] = self.y_vals[i]\n            row += 1\n\n            A[row][4*i] = self.x_vals[i+1]**3\n            A[row][4*i+1] = self.x_vals[i+1]**2\n            A[row][4*i+2] = self.x_vals[i+1]\n            A[row][4*i+3] = 1\n            b[row] = self.y_vals[i+1]\n            row += 1\n\n        for i in range(n-1):\n            A[row][4*i] = 3*self.x_vals[i+1]**2\n            A[row][4*i+1] = 2*self.x_vals[i+1]\n            A[row][4*i+2] = 1\n            A[row][4*i+4] = -3*self.x_vals[i+1]**2\n            A[row][4*i+5] = -2*self.x_vals[i+1]\n            A[row][4*i+6] = -1\n            row += 1\n\n        for i in range(n-1):\n            A[row][4*i] = 6*self.x_vals[i+1]\n            A[row][4*i+1] = 2\n            A[row][4*i+4] = -6*self.x_vals[i+1]\n            A[row][4*i+5] = -2\n            row += 1\n\n        A[row][0] = 6*self.x_vals[0]\n        A[row][1] = 2\n        row += 1\n        A[row][4*(n-1)] = 6*self.x_vals[n]\n        A[row][4*(n-1)+1] = 2\n\n        try:\n            self._coeffs = np.linalg.solve(A, b)\n        except np.linalg.LinAlgError:\n            self._coeffs = None\n\n    def evaluate(self, x):\n        \"\"\"计算样条在 x 处的值。\"\"\"\n        if self._coeffs is None:\n            return 0.0\n\n        idx = 0\n        for i in range(self.n):\n            if self.x_vals[i] <= x <= self.x_vals[i+1]:\n                idx = i\n                break\n\n        a = self._coeffs[4*idx]\n        b = self._coeffs[4*idx+1]\n        c = self._coeffs[4*idx+2]\n        d = self._coeffs[4*idx+3]\n        return float(a*x**3 + b*x**2 + c*x + d)\n\n\ndef golden_section_search(spline, x_low, x_up, req_err=0.01):\n    \"\"\"黄金分割法在样条曲线上搜索峰值。\"\"\"\n    d = GR * abs(x_up - x_low)\n    x1 = x_low + d\n    x2 = x_up - d\n\n    while True:\n        d = GR * d\n        y1 = spline.evaluate(x1)\n        y2 = spline.evaluate(x2)\n\n        if y1 >= y2:\n            max_err = max(abs(x_up - x1), abs(x1 - x2))\n            if max_err < req_err:\n                return (x1, y1)\n            x_low = x2\n            x1 = x_low + d\n            x2 = x_up - d\n        else:\n            max_err = max(abs(x1 - x2), abs(x2 - x_low))\n            if max_err < req_err:\n                return (x2, y2)\n            x_up = x1\n            x1 = x_low + d\n            x2 = x_up - d\n\n\nclass ContrastAF:\n    \"\"\"反差对焦 - 黄金分割+三次样条+两阶段逼近。\n\n    状态：SCAN → APPROACH1(0.2s粗逼近) → APPROACH2(0.1s精逼近) → DONE/FAILED\n    \"\"\"\n\n    SCAN = \"scan\"\n    APPROACH1 = \"approach1\"   # 0.2s 步进回退\n    APPROACH2 = \"approach2\"   # 0.1s 步进微调\n    DONE = \"done\"\n    FAILED = \"failed\"\n\n    def __init__(self):\n        self._state = self.SCAN\n        self._direction = -1  # -1=near, 1=far\n        self._attempt = 0\n\n        # 扫描数据\n        self._points = []\n        self._step_count = 0\n        self._best_value = 0.0\n        self._best_pos = 0\n        self._decline_count = 0\n        self._decline_after_best = 0\n\n        # 平坦区域\n        self._flat_reversed = False\n\n        # 粗逼近 (0.2s)\n        self._approach1_remaining = 0\n        self._approach1_dir = 1\n        self._best2_value = 0.0\n\n        # 精逼近 (0.1s)\n        self._approach2_step = 0\n        self._approach2_dir = 1\n        self._best3_value = 0.0\n        self._approach2_max_steps = 10\n\n    def step(self, contrast: float) -> dict:\n        if self._state == self.SCAN:\n            return self._step_scan(contrast)\n        elif self._state == self.APPROACH1:\n            return self._step_approach1(contrast)\n        elif self._state == self.APPROACH2:\n            return self._step_approach2(contrast)\n        elif self._state == self.DONE:\n            return {\"action\": \"stop\", \"duration\": 0, \"stage\": \"done\",\n                    \"contrast\": round(self._best3_value or self._best_value, 2),\n                    \"message\": \"对焦成功\",\n                    \"best\": self._best3_value or self._best_value}\n        else:\n            return {\"action\": \"stop\", \"duration\": 0, \"stage\": \"error\",\n                    \"contrast\": 0, \"message\": \"对焦失败\"}\n\n    def _step_scan(self, contrast):\n        \"\"\"扫描阶段：等步长0.2s移动，收集数据点。\"\"\"\n        pos = len(self._points)\n        self._points.append((pos, contrast))\n        self._step_count += 1\n\n        is_new_best = False\n        if contrast > self._best_value:\n            self._best_value = contrast\n            self._best_pos = pos\n            self._decline_after_best = 0\n            is_new_best = True\n\n        if pos > 0:\n            prev = self._points[pos-1][1]\n            if contrast < prev:\n                self._decline_count += 1\n            else:\n                self._decline_count = 0\n            if not is_new_best:\n                self._decline_after_best += 1\n\n        action = \"focus_near\" if self._direction < 0 else \"focus_far\"\n        dir_name = '近' if self._direction < 0 else '远'\n\n        if pos == 0:\n            return {\n                \"action\": action, \"duration\": 0.2,\n                \"stage\": \"scan\", \"contrast\": round(contrast, 2),\n                \"message\": f\"开始对焦(方向={dir_name},尝试{self._attempt+1}/3)\"\n            }\n\n        # 峰值确认：best>阈值 + 下降≥3步 → 样条拟合+黄金分割\n        if self._decline_after_best >= 3 and self._best_value > CONTRAST_THRESHOLD:\n            return self._fit_and_search(contrast)\n\n        # 反向：连续5步下降\n        if self._decline_count >= 5:\n            if not self._do_retry():\n                self._state = self.FAILED\n                return {\n                    \"action\": \"stop\", \"duration\": 0,\n                    \"stage\": \"error\", \"contrast\": round(contrast, 2),\n                    \"message\": \"对焦失败(3次重试耗尽)\"\n                }\n            action = \"focus_near\" if self._direction < 0 else \"focus_far\"\n            dir_name = '近' if self._direction < 0 else '远'\n            return {\n                \"action\": action, \"duration\": 0.2,\n                \"stage\": \"scan\", \"contrast\": round(contrast, 2),\n                \"message\": f\"反向(方向={dir_name},尝试{self._attempt+1}/3)\"\n            }\n\n        # 平坦区域: 10步无变化 → 反向\n        if self._step_count >= 10 and self._check_flat():\n            if not self._flat_reversed:\n                self._flat_reversed = True\n                if not self._do_retry():\n                    self._state = self.FAILED\n                    return {\n                        \"action\": \"stop\", \"duration\": 0,\n                        \"stage\": \"error\", \"contrast\": round(contrast, 2),\n                        \"message\": \"对焦失败(3次重试耗尽)\"\n                    }\n                action = \"focus_near\" if self._direction < 0 else \"focus_far\"\n                return {\n                    \"action\": action, \"duration\": 0.2,\n                    \"stage\": \"scan\", \"contrast\": round(contrast, 2),\n                    \"message\": f\"平坦区({self._step_count}步),反向\"\n                }\n            else:\n                return {\n                    \"action\": action, \"duration\": 0.5,\n                    \"stage\": \"scan\", \"contrast\": round(contrast, 2),\n                    \"message\": f\"平坦区持续,加速({self._step_count}步,best={self._best_value:.1f})\"\n                }\n\n        # R²检测\n        if self._step_count % 5 == 0:\n            r2 = self._calc_r2()\n            if r2 is not None and r2 >= 0.8 and self._best_value <= CONTRAST_THRESHOLD:\n                if not self._do_retry():\n                    self._state = self.FAILED\n                    return {\n                        \"action\": \"stop\", \"duration\": 0,\n                        \"stage\": \"error\", \"contrast\": round(contrast, 2),\n                        \"message\": f\"对焦失败(R²={r2:.2f},best={self._best_value:.1f}<={CONTRAST_THRESHOLD})\"\n                    }\n                action = \"focus_near\" if self._direction < 0 else \"focus_far\"\n                return {\n                    \"action\": action, \"duration\": 0.2,\n                    \"stage\": \"scan\", \"contrast\": round(contrast, 2),\n                    \"message\": f\"峰值过低,反向(尝试{self._attempt+1}/3)\"\n                }\n\n        if self._step_count >= 90:\n            self._state = self.FAILED\n            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"error\", \"contrast\": round(contrast, 2),\n                \"message\": f\"扫描超时({self._step_count}步)\"\n            }\n\n        return {\n            \"action\": action, \"duration\": 0.2,\n            \"stage\": \"scan\", \"contrast\": round(contrast, 2),\n            \"message\": f\"采样(best={self._best_value:.1f},方向={dir_name})\"\n        }\n\n    def _start_approach1(self, target_steps, source_msg):\n        \"\"\"启动0.2s粗逼近。\"\"\"\n        self._approach1_remaining = target_steps\n        self._approach1_dir = -self._direction\n        self._best2_value = 0.0\n        action = \"focus_near\" if self._approach1_dir < 0 else \"focus_far\"\n        self._state = self.APPROACH1\n        return {\n            \"action\": action,\n            \"duration\": 0.2,\n            \"stage\": \"approach1\",\n            \"contrast\": round(self._points[-1][1], 2),\n            \"message\": f\"{source_msg},粗逼近{target_steps}步(0.2s)\"\n        }\n\n    def _fit_and_search(self, contrast: float):\n        \"\"\"三次样条拟合 + 黄金分割搜索。\"\"\"\n        x_vals = [p[0] for p in self._points]\n        y_vals = [p[1] for p in self._points]\n\n        # 数据点不足 → 回退到 best_pos\n        if len(x_vals) < 4:\n            current_pos = len(self._points) - 1\n            delta = abs(current_pos - self._best_pos)\n            if delta < 1:\n                self._state = self.DONE\n                return {\n                    \"action\": \"stop\", \"duration\": 0,\n                    \"stage\": \"done\", \"contrast\": round(self._best_value, 2),\n                    \"message\": f\"对焦成功(数据不足,已在best={self._best_value:.1f})\",\n                    \"best\": self._best_value\n                }\n            return self._start_approach1(delta, f\"数据不足,best={self._best_value:.1f}\")\n\n        # R²质量检验 → 低质量：回退到 best_pos（不拟合样条）\n        r2 = self._calc_r2()\n        if r2 is not None and r2 < 0.6:\n            current_pos = len(self._points) - 1\n            delta = abs(current_pos - self._best_pos)\n            if delta < 1:\n                self._state = self.DONE\n                return {\n                    \"action\": \"stop\", \"duration\": 0,\n                    \"stage\": \"done\", \"contrast\": round(self._best_value, 2),\n                    \"message\": f\"对焦成功(R²={r2:.2f}<0.6,已在best={self._best_value:.1f})\",\n                    \"best\": self._best_value\n                }\n            return self._start_approach1(delta, f\"R²={r2:.2f}<0.6,best={self._best_value:.1f}\")\n\n        # 拟合样条\n        spline = CubicSpline(x_vals, y_vals)\n        if spline._coeffs is None:\n            current_pos = len(self._points) - 1\n            delta = abs(current_pos - self._best_pos)\n            if delta < 1:\n                self._state = self.DONE\n                return {\n                    \"action\": \"stop\", \"duration\": 0,\n                    \"stage\": \"done\", \"contrast\": round(self._best_value, 2),\n                    \"message\": f\"对焦成功(样条拟合失败,已在best={self._best_value:.1f})\",\n                    \"best\": self._best_value\n                }\n            return self._start_approach1(delta, f\"样条拟合失败,best={self._best_value:.1f}\")\n\n        # 黄金分割搜索（缩小到峰值附近±2步）\n        best_idx = self._best_pos\n        x_low = max(x_vals[0], best_idx - 2)\n        x_up = min(x_vals[-1], best_idx + 2)\n\n        try:\n            opt_x, opt_y = golden_section_search(spline, x_low, x_up)\n        except Exception:\n            current_pos = len(self._points) - 1\n            delta = abs(current_pos - self._best_pos)\n            if delta < 1:\n                self._state = self.DONE\n                return {\n                    \"action\": \"stop\", \"duration\": 0,\n                    \"stage\": \"done\", \"contrast\": round(self._best_value, 2),\n                    \"message\": f\"对焦成功(搜索失败,已在best={self._best_value:.1f})\",\n                    \"best\": self._best_value\n                }\n            return self._start_approach1(delta, f\"搜索失败,best={self._best_value:.1f}\")\n\n        self._best_value = opt_y\n\n        # 计算回退步数\n        current_pos = x_vals[-1]\n        delta = abs(current_pos - opt_x)\n\n        if delta < 0.5:\n            self._state = self.DONE\n            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"done\", \"contrast\": round(opt_y, 2),\n                \"message\": f\"对焦成功(峰值={opt_y:.1f}@pos={opt_x:.2f},已在峰值)\",\n                \"best\": opt_y\n            }\n\n        return self._start_approach1(int(round(delta)), f\"样条峰值={opt_y:.1f}@pos={opt_x:.2f}\")\n\n    def _step_approach1(self, contrast):\n        \"\"\"粗逼近阶段：0.2s步进回退到峰值位置。\"\"\"\n        # 追踪 best2\n        if contrast > self._best2_value:\n            self._best2_value = contrast\n\n        self._approach1_remaining -= 1\n\n        if self._approach1_remaining <= 0:\n            # 粗逼近完成，进入精逼近\n            self._approach2_step = 0\n            self._best3_value = self._best2_value\n            # 精逼近初始方向 = 粗逼近方向\n            self._approach2_dir = self._approach1_dir\n            self._state = self.APPROACH2\n            action = \"focus_near\" if self._approach2_dir < 0 else \"focus_far\"\n            return {\n                \"action\": action,\n                \"duration\": 0.1,\n                \"stage\": \"approach2\",\n                \"contrast\": round(contrast, 2),\n                \"message\": f\"粗逼近完成(best2={self._best2_value:.1f}),开始精逼近(0.1s)\"\n            }\n\n        # 继续粗逼近\n        action = \"focus_near\" if self._approach1_dir < 0 else \"focus_far\"\n        return {\n            \"action\": action,\n            \"duration\": 0.2,\n            \"stage\": \"approach1\",\n            \"contrast\": round(contrast, 2),\n            \"message\": f\"粗逼近(剩余{self._approach1_remaining}步,best2={self._best2_value:.1f})\"\n        }\n\n    def _step_approach2(self, contrast):\n        \"\"\"精逼近阶段：0.1s步进微调，最多10步，best3必须>best2。\"\"\"\n        self._approach2_step += 1\n\n        # 追踪 best3\n        if contrast > self._best3_value:\n            self._best3_value = contrast\n\n        # best3 > best2 → 成功\n        if self._best3_value > self._best2_value:\n            self._state = self.DONE\n            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"done\", \"contrast\": round(contrast, 2),\n                \"message\": f\"对焦成功(best3={self._best3_value:.1f}>best2={self._best2_value:.1f})\",\n                \"best\": self._best3_value\n            }\n\n        # 趋势下降 → 反向\n        if contrast < self._best3_value:\n            self._approach2_dir = -self._approach2_dir\n\n        # 达到最大步数\n        if self._approach2_step >= self._approach2_max_steps:\n            # best3 未超过 best2，但取 best3 作为最终值\n            self._state = self.DONE\n            best = max(self._best3_value, self._best2_value)\n            return {\n                \"action\": \"stop\", \"duration\": 0,\n                \"stage\": \"done\", \"contrast\": round(contrast, 2),\n                \"message\": f\"对焦完成(精逼近{self._approach2_step}步,best3={self._best3_value:.1f},best2={self._best2_value:.1f})\",\n                \"best\": best\n            }\n\n        # 继续精逼近\n        action = \"focus_near\" if self._approach2_dir < 0 else \"focus_far\"\n        return {\n            \"action\": action,\n            \"duration\": 0.1,\n            \"stage\": \"approach2\",\n            \"contrast\": round(contrast, 2),\n            \"message\": f\"精逼近(步{self._approach2_step}/{self._approach2_max_steps},best3={self._best3_value:.1f},best2={self._best2_value:.1f})\"\n        }\n\n    def _check_flat(self):\n        if len(self._points) < 5:\n            return False\n        recent = [p[1] for p in self._points[-5:]]\n        max_v, min_v = max(recent), min(recent)\n        if max_v <= 0:\n            return False\n        return (max_v - min_v) / max_v < 0.10\n\n    def _calc_r2(self):\n        if len(self._points) < 8:\n            return None\n        best_idx = max(range(len(self._points)), key=lambda i: self._points[i][1])\n        left, right = best_idx, len(self._points) - best_idx - 1\n        if left < 4 or right < 3:\n            return None\n        xs = np.array([p[0] for p in self._points])\n        ys = np.array([p[1] for p in self._points])\n        ys_safe = np.maximum(ys, 0.1)\n        ln_y = np.log(ys_safe)\n        try:\n            A, B, C = np.polyfit(xs, ln_y, 2)\n            if A >= 0:\n                return None\n            ln_y_pred = A * xs**2 + B * xs + C\n            ss_res = np.sum((ln_y - ln_y_pred)**2)\n            ss_tot = np.sum((ln_y - np.mean(ln_y))**2)\n            return 1 - (ss_res / ss_tot) if ss_tot > 0 else 0\n        except Exception:\n            return None\n\n    def _do_retry(self):\n        self._attempt += 1\n        if self._attempt >= 3:\n            return False\n        self._direction *= -1\n        self._points = []\n        self._best_value = 0.0\n        self._best_pos = 0\n        self._decline_count = 0\n        self._decline_after_best = 0\n        self._step_count = 0\n        return True\n\n\nclass FocusSearcher:\n    \"\"\"对焦搜索执行器。\"\"\"\n\n    def __init__(self, mgr, device_ip, client, x, y, w, h, capture_func, cleanup_func, mac_clean=\"\"):\n        self.mgr = mgr\n        self.device_ip = device_ip\n        self.client = client\n        self.x = x\n        self.y = y\n        self.w = w\n        self.h = h\n        self._capture_func = capture_func\n        self._cleanup_func = cleanup_func\n        self._interrupted = False\n        self._mac_clean = mac_clean\n\n    def _interrupt(self):\n        self._interrupted = True\n\n    def _set_manual_focus(self):\n        try:\n            ctrl, err = self.mgr._get_controller(self.device_ip)\n            if not err and ctrl.client:\n                xml = '''<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<FocusConfiguration version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">\n  <focusStyle>MANUAL</focusStyle>\n  <focusLimited>300</focusLimited>\n</FocusConfiguration>'''\n                result = ctrl.client.put(\"/Image/channels/1/focusConfiguration\", xml)\n                return result.status_code == 200\n        except Exception:\n            pass\n        return False\n\n    def _capture(self):\n        bgr, crop_path, info = self._capture_func(\n            self.client, self.mgr, self.device_ip, \"Focus\",\n            self.x, self.y, self.w, self.h\n        )\n        return bgr, info\n\n    def _move_focus(self, direction: str, duration: float):\n        ptz_dir = \"focus-far\" if direction == \"focus_far\" else \"focus-near\"\n        self.mgr.ptz_move(self.device_ip, direction=ptz_dir, speed=60)\n\n    def _stop_focus(self):\n        self.mgr.ptz_stop(self.device_ip)\n\n    async def run(self):\n        \"\"\"运行对焦搜索，产生 SSE 事件。\"\"\"\n\n        ok = await asyncio.to_thread(self._set_manual_focus)\n        if not ok:\n            yield f\"data: {json.dumps({'type': 'warning', 'message': '设置手动对焦失败'})}\\n\\n\"\n\n        bgr, info = await asyncio.to_thread(self._capture)\n        if bgr is None:\n            yield f\"data: {json.dumps({'type': 'error', 'message': '截图失败'})}\\n\\n\"\n            return\n\n        crop_msg = f\"X={info['crop_x1']}~{info['crop_x2']}, Y={info['crop_y1']}~{info['crop_y2']}, 共{info['pixels']}像素\"\n        yield f\"data: {json.dumps({'type': 'start', 'crop': crop_msg})}\\n\\n\"\n\n        af = ContrastAF()\n        step_count = 0\n\n        while True:\n            if self._interrupted:\n                await asyncio.to_thread(self._stop_focus)\n                yield f\"data: {json.dumps({'type': 'interrupt', 'message': '用户停止'})}\\n\\n\"\n                break\n\n            contrast = calc_contrast(bgr)\n            cmd = af.step(contrast)\n            step_count += 1\n\n            event = {\n                \"type\": \"focus\",\n                \"step\": step_count,\n                \"stage\": cmd.get(\"stage\", \"\"),\n                \"action\": cmd[\"action\"],\n                \"contrast\": cmd[\"contrast\"],\n                \"duration\": cmd[\"duration\"],\n                \"message\": cmd[\"message\"]\n            }\n            yield f\"data: {json.dumps(event)}\\n\\n\"\n\n            if cmd[\"action\"] == \"stop\":\n                bgr2, _ = await asyncio.to_thread(self._capture)\n                final_contrast = calc_contrast(bgr2) if bgr2 is not None else cmd[\"contrast\"]\n                best = cmd.get(\"best\", cmd[\"contrast\"])\n                verified = final_contrast >= best * 0.85\n\n                yield f\"data: {json.dumps({'type': 'done', 'final_contrast': round(final_contrast, 2), 'best_contrast': round(best, 2), 'total_steps': step_count, 'verified': verified})}\\n\\n\"\n                break\n\n            await asyncio.to_thread(self._move_focus, cmd[\"action\"], cmd[\"duration\"])\n            await asyncio.sleep(cmd[\"duration\"])\n            await asyncio.to_thread(self._stop_focus)\n            delay = await asyncio.to_thread(calc_stable_delay, self.client)\n            await asyncio.sleep(delay)\n\n            bgr, _ = await asyncio.to_thread(self._capture)\n            if bgr is None:\n                yield f\"data: {json.dumps({'type': 'error', 'message': '截图失败'})}\\n\\n\"\n                break\n\n        await asyncio.to_thread(self._cleanup_func, \"Focus\", self.device_ip)\n        yield f\"data: {json.dumps({'type': 'cleanup'})}\\n\\n\"\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\controlpanel\\autofocus.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":162780,"output":6442,"cacheRead":0,"cacheWrite":0,"totalTokens":169222,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783369341776,"responseId":"cht000db441@dx19f3918a3912871503"}}
