{"type":"message","id":"aaecd58f","parentId":"966309d6","timestamp":"2026-07-06T20:17:35.050Z","message":{"role":"toolResult","toolCallId":"call_47e7a3ef1d5b43579b50c9c5","toolName":"read","content":[{"type":"text","text":"function onFocusModeChange(mode) {\r\n    var moveControls = document.getElementById('focusMoveControls');\r\n    var localControls = document.getElementById('focusLocalControls');\r\n\r\n    if (mode === 'manual') {\r\n        if (moveControls) moveControls.style.display = 'block';\r\n        if (localControls) localControls.style.display = 'none';\r\n        setFocusMode('manual');\r\n    } else if (mode === 'local') {\r\n        if (moveControls) moveControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'block';\r\n        // v8.39: 局部模式自动切换到手动模式\r\n        setFocusMode('manual');\r\n    } else {\r\n        // 自动\r\n        if (moveControls) moveControls.style.display = 'none';\r\n        if (localControls) localControls.style.display = 'none';\r\n        setFocusMode('auto');\r\n    }\r\n}\r\n\r\n// 停止自动对焦\r\nfunction stopAutoFocus() {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    if (typeof operationLog === 'function') operationLog('用户停止', 'warning');\r\n    apiPost('/api/v1/vision/focus-stop', {}).then(function(r) {\r\n        if (r && r.success) {\r\n            showToast('success', '已停止对焦搜索');\r\n        }\r\n\n[744 more lines in file. Use offset=1334 to continue.]"}],"isError":false,"timestamp":1783369055050}}
