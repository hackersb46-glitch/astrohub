ent to be visible and enabled[0m\r\n[31;1m      - element is not visible[0m\r\n[31;1m    - retrying select option action[0m\r\n[31;1m    - waiting 20ms[0m\r\n[31;1m    2 �� waiting for element to be visible and enabled[0m\r\n[31;1m      - element is not visible[0m\r\n[31;1m    - retrying select option action[0m\r\n[31;1m      - waiting 100ms[0m\r\n[31;1m    59 �� waiting for element to be visible and enabled[0m\r\n[31;1m       - element is not visible[0m\r\n[31;1m     - retrying select option action[0m\r\n[31;1m       - waiting 500ms[0m\r\n[31;1m[0m\n\n(Command exited with code 1)","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783364580507}}
{"type":"message","id":"1de907a0","parentId":"03d18ab1","timestamp":"2026-07-06T19:03:29.986Z","message":{"role":"assistant","content":[{"type":"text","text":"元素不可见 — focusMode select 可能在页面折叠区。让我改用 JavaScript 直接操作："},{"type":"toolCall","id":"call_1520fa44a5da48a8a5b2cbe6","name":"write","arguments":{"content":"\"\"\"AstroHub v8.59 自动对焦测试 - Playwright\n\n策略：用 JS 直接调用前端函数，跳过 UI 交互\n\"\"\"\nimport time\nimport json\nfrom playwright.sync_api import sync_playwright\n\nBASE_URL = 'http://localhost:10280'\n\ndef main():\n    with sync_playwright() as p:\n        browser = p.chromium.launch(channel='chrome', headless=True,\n                                    args=['--no-sandbox', '--disable-gpu'])\n        page = browser.new_page(viewport={'width': 1920, 'height': 1080})\n        \n        print(\"=== AstroHub v8.59 AF Test ===\")\n        print(f\"Start: {time.strftime('%H:%M:%S')}\")\n        \n        page.goto(BASE_URL, wait_until='networkidle', timeout=15000)\n        print(\"[1] Page loaded\")\n        \n        connected = page.evaluate(\"window.connectedDevice && window.connectedDevice.ip\")\n        print(f\"[2] Device: {connected}\")\n        \n        # 3. 直接调用 _finishRegion 的核心逻辑：POST focus-search\n        # 画面中间30%\n        region = {\"x\": 0.35, \"y\": 0.35, \"w\": 0.30, \"h\": 0.30}\n        print(f\"[3] Region: center 30% (x={region['x']}, y={region['y']}, w={region['w']}, h={region['h']})\")\n        \n        # 用 JS 发起 fetch + SSE 读取，结果写入 window.__afResult\n        page.evaluate(\"\"\"\n        async () => {\n            window.__afEvents = [];\n            window.__afDone = false;\n            const region = {x: 0.35, y: 0.35, w: 0.30, h: 0.30};\n            const resp = await fetch('/api/v1/vision/focus-search', {\n                method: 'POST',\n                headers: {'Content-Type': 'application/json'},\n                body: JSON.stringify(region)\n            });\n            if (!resp.ok) {\n                window.__afEvents.push({type: 'error', message: 'HTTP ' + resp.status});\n                window.__afDone = true;\n                return;\n            }\n            const reader = resp.body.getReader();\n            const decoder = new TextDecoder();\n            let buf = '';\n            while (true) {\n                const {done, value} = await reader.read();\n                if (done) break;\n                buf += decoder.decode(value, {stream: true});\n                const parts = buf.split('\\\\n\\\\n');\n                buf = parts.pop();\n                for (const part of parts) {\n                    if (!part.startsWith('data: ')) continue;\n                    try {\n                        const ev = JSON.parse(part.slice(6));\n                        window.__afEvents.push(ev);\n                        if (ev.type === 'done' || ev.type === 'error' || ev.type === 'cleanup') {\n                            window.__afDone = true;\n                        }\n                    } catch(e) {}\n                }\n            }\n            window.__afDone = true;\n        }\n        \"\"\")\n        \n        # 4. 轮询事件\n        print(f\"[4] Waiting for autofocus...\")\n        start = time.time()\n        last_count = 0\n        timeout = 120\n        \n        while time.time() - start < timeout:\n            done = page.evaluate(\"window.__afDone\")\n            events = page.evaluate(\"window.__afEvents || []\")\n            \n            # 打印新事件\n            for ev in events[last_count:]:\n                etype = ev.get('type', '')\n                if etype == 'start':\n                    print(f\"  [START] crop={ev.get('crop', '')}\")\n                elif etype == 'focus':\n                    step = ev.get('step', 0)\n                    stage = ev.get('stage', '')\n                    action = ev.get('action', '')\n                    contrast = ev.get('contrast', 0)\n                    dur = ev.get('duration', 0)\n                    msg = ev.get('message', '')\n                    print(f\"  #{step:2d} [{stage:8s}] {action:12s} contrast={contrast:8.1f} dur={dur:.3f}s | {msg}\")\n                elif etype == 'done':\n                    fc = ev.get('final_contrast', 0)\n                    bc = ev.get('best_contrast', 0)\n                    ts = ev.get('total_steps', 0)\n                    v = ev.get('verified', False)\n                    print(f\"\\n  [DONE] final={fc} best={bc} steps={ts} verified={'PASS' if v else 'FAIL'}\")\n                elif etype == 'error':\n                    print(f\"  [ERROR] {ev.get('message', '')}\")\n                elif etype == 'warning':\n                    print(f\"  [WARN] {ev.get('message', '')}\")\n                elif etype == 'cleanup':\n                    print(f\"  [CLEANUP]\")\n            \n            last_count = len(events)\n            \n            if done:\n                break\n            \n            time.sleep(0.5)\n        \n        elapsed = time.time() - start\n        print(f\"\\n[5] Elapsed: {elapsed:.1f}s\")\n        \n        # 6. 截图\n        page.screenshot(path='tmp_af_screenshot.png', full_page=True)\n        print(f\"[6] Screenshot: tmp_af_screenshot.png\")\n        \n        browser.close()\n        print(f\"End: {time.strftime('%H:%M:%S')}\")\n\nif __name__ == '__main__':\n    main()\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tmp_test_pw.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":116025,"output":1219,"cacheRead":0,"cacheWrite":0,"totalTokens":117244,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783364580510,"responseId":"cht000dbb02@dx19f38d0229e29bb503"}}
