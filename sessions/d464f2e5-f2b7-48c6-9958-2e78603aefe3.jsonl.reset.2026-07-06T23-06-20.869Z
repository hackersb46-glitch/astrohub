{"type":"message","id":"2ec70d3d","parentId":"1556e5a2","timestamp":"2026-07-06T17:43:22.716Z","message":{"role":"toolResult","toolCallId":"call_c6d7bf73f4244fb788787015","toolName":"read","content":[{"type":"text","text":"                                            <option value=\"auto\">自动</option>\r\n                                            <option value=\"manual\">手动</option>\r\n                                            <option value=\"local\">局部</option>\r\n                                        </select>\r\n                                    </div>\r\n                                    <!-- 焦点移动按钮(仅手动模式显示) -->\r\n                                    <div id=\"focusMoveControls\" style=\"display:none;margin-bottom:4px\">\r\n                                        <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\r\n                                            <span style=\"color:#8b949e;font-size:11px\">焦点:</span>\r\n                                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">远</button>\r\n                                            <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">近</button>\r\n                                        </div>\r\n                                    </div>\r\n                                    <!-- 局部对焦控制(仅局部模式显示) -->\r\n                                    <div id=\"focusLocalControls\" style=\"display:none;margin-bottom:4px\">\r\n                                        <div style=\"display:flex;align-items:center;gap:4px;width:100%\">\r\n                                            <button id=\"btnFocusRegionSelect\" class=\"btn btn-secondary btn-sm\" onclick=\"toggleRegionMode('focus')\" style=\"flex-shrink:0;padding:4px 8px\">框选</button>\r\n                                            <input type=\"text\" id=\"focusTimerInput\" value=\"\" placeholder=\"定时\" style=\"flex:1;min-width:0;padding:4px 6px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:10px\" oninput=\"updateFocusTimerInput(this)\">\r\n                                            <span style=\"color:#8b949e;font-size:10px;white-space:nowrap\">min</span>\r\n                                            <label class=\"switch\" style=\"flex-shrink:0\" title=\"打开应用定时\">\r\n                                                <input type=\"checkbox\" id=\"focusTimerToggle\" onchange=\"toggleFocusTimer()\">\r\n                                                <span class=\"slider\"></span>\r\n                                            </label>\r\n                                            <button id=\"btnFocusLocalStop\" class=\"btn btn-danger btn-sm\" onclick=\"stopAutoFocus()\" disabled style=\"opacity:0.5;flex-shrink:0;padding:4px 8px\">停止</button>\r\n                                        </div>\r\n                                        <div id=\"focusTimerDisplay\" style=\"color:#f85149;font-size:11px;text-align:center;margin-top:2px\"></div>\r\n                                    </div>\r\n                                    <!-- 曝光模式 + 快门/光圈 (v5.47: 整合到一行) -->\r\n                                    <div class=\"form-group\" style=\"margin-bottom:4px\">\r\n                                        <label style=\"font-size:11px;color:#8b949e\">曝光模式</label>\r\n\n[1753 more lines in file. Use offset=325 to continue.]"}],"isError":false,"timestamp":1783359802716}}
{"type":"message","id":"ccc903c0","parentId":"2ec70d3d","timestamp":"2026-07-06T17:43:22.716Z","message":{"role":"toolResult","toolCallId":"call_1f8360ae00164f0b902d77d8","toolName":"read","content":[{"type":"text","text":"        return;\r\n    }\r\n    var dev = window.connectedDevice;\r\n    if (!dev || !dev.ip) { showToast('error', '未连接设备'); return; }\r\n    var region = JSON.parse(regionStr);\r\n    var endpoint = mode === 'whitebalance' ? '/api/v1/vision/whitebalance-search' : '/api/v1/vision/focus-search';\r\n    var label = mode === 'whitebalance' ? '白平衡' : '对焦';\r\n    showToast('info', label + '定时执行中...');\r\n    operationLog('── ' + label + '定时执行 ──', 'info');\r\n    var body = JSON.stringify({ x: region.x, y: region.y, w: region.w, h: region.h });\r\n    fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })\r\n        .then(function(resp) {\r\n            if (!resp.ok) throw new Error('HTTP ' + resp.status);\r\n            var reader = resp.body.getReader();\r\n            var decoder = new TextDecoder();\r\n            var buf = '';\r\n            function pump() {\r\n                return reader.read().then(function(r) {\r\n                    if (r.done) return;\r\n                    buf += decoder.decode(r.value, { stream: true });\r\n                    var parts = buf.split('\\n\\n');\r\n                    buf = parts.pop();\r\n                    for (var i = 0; i < parts.length; i++) {\r\n                        var line = parts[i];\r\n                        if (!line.startsWith('data: ')) continue;\r\n                        try {\r\n                            var ev = JSON.parse(line.slice(6));\r\n                            if (ev.type === 'wb' || ev.type === 'focus') {\r\n                                operationLog('调整 #' + ev.step + ': ' + ev.stage + ' R=' + ev.red_gain + ' B=' + ev.blue_gain + ' Δ=' + ev.delta, 'info');\r\n                            } else if (ev.type === 'done') {\r\n                                operationLog('── ' + label + '完成: R=' + ev.final_red + ' B=' + ev.final_blue + ' (' + ev.total_steps + '步) ──', 'success');\r\n                            } else if (ev.type === 'error') {\r\n                                operationLog(label + '错误: ' + ev.message, 'error');\r\n                            }\r\n                        } catch (e) {}\r\n                    }\r\n                    return pump();\r\n                });\r\n            }\r\n            return pump();\r\n        })\r\n        .then(function() {\r\n            // 执行完成后，重新启动定时器\r\n            if (mode === 'whitebalance' && wbTimerId === null) {\r\n                var minutes = parseInt(document.getElementById('wbTimerInput').value) || 0;\r\n                if (minutes > 0) {\r\n                    wbTimerSeconds = minutes * 60;\r\n                    updateWbTimerDisplay();\r\n                    wbTimerId = setInterval(function() {\r\n                        wbTimerSeconds--;\r\n                        updateWbTimerDisplay();\r\n                        if (wbTimerSeconds <= 0) {\r\n                            clearInterval(wbTimerId);\r\n                            wbTimerId = null;\r\n                            executeScheduledSearch('whitebalance');\r\n                        }\r\n                    }, 1000);\r\n                }\r\n            }\r\n            if (mode === 'focus' && focusTimerId === null) {\r\n                var minutes = parseInt(document.getElementById('focusTimerInput').value) || 0;\r\n                if (minutes > 0) {\r\n                    focusTimerSeconds = minutes * 60;\r\n                    updateFocusTimerDisplay();\r\n                    focusTimerId = setInterval(function() {\r\n                        focusTimerSeconds--;\r\n                        updateFocusTimerDisplay();\r\n                        if (focusTimerSeconds <= 0) {\r\n                            clearInterval(focusTimerId);\r\n                            focusTimerId = null;\r\n                            executeScheduledSearch('focus');\r\n                        }\r\n                    }, 1000);\r\n                }\r\n            }\r\n        })\r\n        .catch(function(e) {\r\n            showToast('error', label + '定时执行失败: ' + e.message);\r\n        });\r\n}\r\n\n[548 more lines in file. Use offset=1530 to continue.]"}],"isError":false,"timestamp":1783359802716}}
