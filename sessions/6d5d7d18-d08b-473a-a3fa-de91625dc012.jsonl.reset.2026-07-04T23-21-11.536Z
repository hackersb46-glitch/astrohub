{"type":"message","id":"b681a8ff","parentId":"29082fc6","timestamp":"2026-07-03T22:58:21.915Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_0a58ac56bd97464d83a8bfeb","name":"read","arguments":{"limit":100,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":88857,"output":41,"cacheRead":0,"cacheWrite":0,"totalTokens":88898,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783119491742,"responseId":"cht000d697f@dx19f2a34374c2871503"}}
{"type":"message","id":"30654ca8","parentId":"b681a8ff","timestamp":"2026-07-03T22:58:21.947Z","message":{"role":"toolResult","toolCallId":"call_0a58ac56bd97464d83a8bfeb","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\r\n            <div id=\"consoleWarning\" style=\"display:none;position:fixed;top:50%;left:50%;transform:translate(-50%, -50%);background:#4a3a1a;border:2px solid #d29922;border-radius:12px;padding:32px 48px;color:#d29922;font-size:16px;z-index:10000;text-align:center;width:300px\">\r\n                <strong style=\"font-size:20px\">⚠️ 请连接设备</strong><br><br>\r\n                <span style=\"color:#8b949e;font-size:14px\">在设备管理页面连接设备</span>\r\n            </div>\r\n            <div id=\"ptzControlArea\">\r\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\r\n                <div class=\"console-layout\">\r\n                    <!-- 左: PTZ控制(整合:指向+预置点+变焦/对焦) -->\r\n                    <div class=\"console-left\">\r\n                        <!-- PTZ控制(折叠) -->\r\n                        <div class=\"collapsible-section\" id=\"ptzControlSection\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 运动控制</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <!-- 指向控制 + 信息展示 -->\r\n                                <div style=\"display:flex;gap:8px;align-items:stretch\">\r\n                                    <!-- 左侧:方向控制 + 速度 -->\r\n                                    <div style=\"flex:0 0 auto;display:flex;flex-direction:column;justify-content:space-between\">\r\n                                        <div class=\"ptz-controls\">\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\r\n                                            <button class=\"ptz-btn center\">●</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\r\n                                        </div>\r\n                                        <div class=\"ptz-speed\" style=\"width:170px;font-size:11px;margin-top:8px\">\r\n                                            <label style=\"font-size:11px\">速度:</label>\r\n                                            <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"7\" value=\"4\" style=\"width:90px\">\r\n                                            <span id=\"ptzSpeedVal\" style=\"font-size:11px\">4</span>\r\n                                        </div>\r\n                                    </div>\r\n                                    <!-- 右侧:光圈快门 + P/T/Z(竖排,宽度减少15%) -->\r\n                                    <div style=\"flex:0 0 110px;display:flex;flex-direction:column;gap:0\">\r\n                                        <div class=\"info-block\" style=\"flex:1\">\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">光圈</span><span class=\"info-value\" id=\"ptzIris\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">快门</span><span class=\"info-value\" id=\"ptzShutter\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">R</span><span class=\"info-value\" id=\"ptzWbR\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">B</span><span class=\"info-value\" id=\"ptzWbB\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">空域</span><span class=\"info-value\" id=\"ptzDnrSpatial\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"padding:1px 4px;font-size:12px\"><span class=\"info-label\">时域</span><span class=\"info-value\" id=\"ptzDnrTemporal\">--</span></div>\r\n                                        </div>\r\n                                        <div style=\"border-top:2px solid #30363d;margin-top:2px;padding-top:2px\"></div>\r\n                                        <div class=\"info-block\" style=\"flex:1\">\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">Pan</span><span class=\"info-value\" id=\"ptzPan\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">Tilt</span><span class=\"info-value\" id=\"ptzTilt\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"padding:1px 4px;font-size:12px\"><span class=\"info-label\">Zoom</span><span class=\"info-value\" id=\"ptzZoom\">--</span></div>\r\n                                        </div>\r\n                                    </div>\r\n                                </div>\r\n                                <!-- 码流控制 -->\r\n                                <div class=\"section-subtitle\">码流</div>\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamMain\" onclick=\"switchAndPlay(1)\" title=\"主码流\">主</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamSub\" onclick=\"switchAndPlay(2)\" title=\"子码流\">子</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamThird\" onclick=\"switchAndPlay(3)\" title=\"第三码流\">三</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamStop\" onclick=\"doStopPreview()\" title=\"停止预览\">⏹</button>\r\n                                </div>\r\n                                <!-- 预置点 -->\r\n                                <div class=\"section-subtitle\">预置点</div>\r\n                                <div style=\"display:flex;gap:4px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:100px\">\r\n                                        <option value=\"\">选择预置点</option>\r\n                                    </select>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzWritePreset()\">写入</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onclick=\"ptzHome()\">归位</button>\r\n                                </div>\r\n                                <!-- PTZ OSD 开关 -->\r\n                                <div class=\"section-subtitle\">OSD</div>\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <span style=\"color:#8b949e;font-size:11px\">PTZ OSD</span>\r\n                                    <label class=\"toggle-switch\">\r\n                                        <input type=\"checkbox\" id=\"ptzOsdSwitchInPtz\" checked onchange=\"togglePtzOsdSwitch(this.checked)\">\r\n                                        <span class=\"toggle-slider\"></span>\r\n                                    </label>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 媒体信息(折叠,默认展开) -->\r\n                        <div class=\"collapsible-section\" id=\"mediaLogSection\" style=\"margin-top:12px\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaLogSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">📡 媒体信息</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;overflow-y:auto;height:200px\" class=\"hide-scrollbar\">\r\n                                    <div id=\"mediaLogBox\" style=\"font-size:11px;font-family:monospace;color:#8b949e\">\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 中: 实时画面 + 媒体操作 -->\r\n\n[1577 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1783119501947}}
{"type":"message","id":"13099d43","parentId":"30654ca8","timestamp":"2026-07-03T22:59:34.508Z","message":{"role":"assistant","content":[{"type":"text","text":"好，HTML结构确认正确。现在写 Playwright 验证脚本，模拟用户操作验证所有修改。"},{"type":"toolCall","id":"call_27f9127ef31240558120f69b","name":"write","arguments":{"content":"\"\"\"\nv8.38 Playwright E2E 验证脚本\n验证主控台界面修改：\n1. 左侧运动控制：PTZ OSD 开关存在，变焦/对焦区已移除\n2. 右侧画面控制：布局顺序正确\n3. 白平衡下拉：3选项（自动/手动/局部）\n4. 白平衡手动模式：R/B滑动条显示\n5. 白平衡局部模式：框选+定时显示\n6. 对焦下拉：3选项（自动/手动/局部）\n7. 对焦手动模式：焦点移动按钮显示\n8. 对焦局部模式：框选+定时显示\n9. 降噪位于饱和度/锐度下方\n10. OSD控制区无PTZ开关（仅信息）\n\"\"\"\nimport asyncio\nimport sys\nimport os\n\nasync def main():\n    from playwright.async_api import async_playwright\n    \n    errors = []\n    passed = []\n    \n    async with async_playwright() as p:\n        browser = await p.chromium.launch(headless=True)\n        page = await browser.new_page()\n        \n        # 拦截 console 错误\n        console_errors = []\n        page.on(\"console\", lambda msg: console_errors.append(f\"[{msg.type}] {msg.text}\") if msg.type == \"error\" else None)\n        \n        # 拦截 request 失败\n        request_errors = []\n        page.on(\"requestfailed\", lambda req: request_errors.append(f\"{req.url} - {req.failure}\"))\n        \n        # 导航到主控台页面\n        await page.goto(\"http://127.0.0.1:10280/\", wait_until=\"networkidle\", timeout=15000)\n        \n        # 切换到主控台页面\n        console_btn = page.locator('[data-page=\"console\"]')\n        if await console_btn.count() > 0:\n            await console_btn.click()\n            await page.wait_for_timeout(500)\n        else:\n            errors.append(\"无法找到主控台导航按钮\")\n        \n        # ========== 测试1: 左侧运动控制 - PTZ OSD 开关存在 ==========\n        try:\n            ptz_osd_switch = page.locator('#ptzOsdSwitchInPtz')\n            if await ptz_osd_switch.count() > 0:\n                passed.append(\"✅ 测试1: 左侧面板 PTZ OSD 开关存在\")\n            else:\n                errors.append(\"❌ 测试1: 左侧面板未找到 PTZ OSD 开关 (ptzOsdSwitchInPtz)\")\n        except Exception as e:\n            errors.append(f\"❌ 测试1异常: {e}\")\n        \n        # ========== 测试2: 左侧运动控制 - 旧的变焦/对焦区已移除 ==========\n        try:\n            # 检查运动控制区内不应有 focusMode select（旧的）\n            ptz_section = page.locator('#ptzControlSection')\n            old_focus_select = ptz_section.locator('select#focusMode')\n            if await old_focus_select.count() == 0:\n                passed.append(\"✅ 测试2: 左侧面板变焦/对焦区已移除（无focusMode select）\")\n            else:\n                errors.append(\"❌ 测试2: 左侧面板仍存在 focusMode select\")\n        except Exception as e:\n            errors.append(f\"❌ 测试2异常: {e}\")\n        \n        # ========== 测试3: 左侧运动控制 - 旧的焦距按钮已移除 ==========\n        try:\n            ptz_section = page.locator('#ptzControlSection')\n            # 检查不应该有 ptzZoom 调用（焦距按钮）\n            zoom_btns = ptz_section.locator('button[onmousedown*=\"ptzZoom\"]')\n            if await zoom_btns.count() == 0:\n                passed.append(\"✅ 测试3: 左侧面板焦距按钮已移除\")\n            else:\n                errors.append(f\"❌ 测试3: 左侧面板仍存在 {await zoom_btns.count()} 个焦距按钮\")\n        except Exception as e:\n            errors.append(f\"❌ 测试3异常: {e}\")\n        \n        # ========== 测试4: 右侧画面控制 - 白平衡下拉3选项 ==========\n        try:\n            wb_select = page.locator('#wbMode')\n            if await wb_select.count() > 0:\n                options = await wb_select.locator('option').all()\n                opt_values = []\n                for opt in options:\n                    opt_values.append(await opt.get_attribute('value'))\n                \n                expected = ['auto', 'manual', 'local']\n                if opt_values == expected:\n                    passed.append(f\"✅ 测试4: 白平衡下拉选项正确: {opt_values}\")\n                else:\n                    errors.append(f\"❌ 测试4: 白平衡下拉选项不符: 期望{expected}, 实际{opt_values}\")\n            else:\n                errors.append(\"❌ 测试4: 未找到白平衡下拉 (wbMode)\")\n        except Exception as e:\n            errors.append(f\"❌ 测试4异常: {e}\")\n        \n        # ========== 测试5: 白平衡 - R/B滑动条默认隐藏 ==========\n        try:\n            wb_manual = page.locator('#wbManualControls')\n            if await wb_manual.count() > 0:\n                display_val = await wb_manual.get_attribute('style')\n                if 'display:none' in display_val or 'display: none' in display_val:\n                    passed.append(\"✅ 测试5: 白平衡R/B滑动条默认隐藏\")\n                else:\n                    errors.append(f\"❌ 测试5: 白平衡R/B滑动条未隐藏: style={display_val}\")\n            else:\n                errors.append(\"❌ 测试5: 未找到 wbManualControls\")\n        except Exception as e:\n            errors.append(f\"❌ 测试5异常: {e}\")\n        \n        # ========== 测试6: 白平衡 - 局部控制默认隐藏 ==========\n        try:\n            wb_local = page.locator('#wbLocalControls')\n            if await wb_local.count() > 0:\n                display_val = await wb_local.get_attribute('style')\n                if 'display:none' in display_val or 'display: none' in display_val:\n                    passed.append(\"✅ 测试6: 白平衡局部控制默认隐藏\")\n                else:\n                    errors.append(f\"❌ 测试6: 白平衡局部控制未隐藏: style={display_val}\")\n            else:\n                errors.append(\"❌ 测试6: 未找到 wbLocalControls\")\n        except Exception as e:\n            errors.append(f\"❌ 测试6异常: {e}\")\n        \n        # ========== 测试7: 白平衡 - 切换到手动模式，R/B显示 ==========\n        try:\n            await page.select_option('#wbMode', 'manual')\n            await page.wait_for_timeout(300)\n            \n            wb_manual = page.locator('#wbManualControls')\n            display_val = await wb_manual.get_attribute('style')\n            if 'display:none' not in display_val and 'display: none' not in display_val:\n                passed.append(\"✅ 测试7: 白平衡手动模式 → R/B滑动条显示\")\n            else:\n                errors.append(f\"❌ 测试7: 白平衡手动模式 R/B仍未显示: style={display_val}\")\n            \n            # 同时验证局部控制隐藏\n            wb_local = page.locator('#wbLocalControls')\n            local_display = await wb_local.get_attribute('style')\n            if 'display:none' in local_display or 'display: none' in local_display:\n                pass  # 正确：局部应隐藏\n            else:\n                errors.append(f\"❌ 测试7b: 白平衡手动模式 → 局部控制未隐藏\")\n        except Exception as e:\n            errors.append(f\"❌ 测试7异常: {e}\")\n        \n        # ========== 测试8: 白平衡 - 切换到局部模式 ==========\n        try:\n            await page.select_option('#wbMode', 'local')\n            await page.wait_for_timeout(300)\n            \n            wb_local = page.locator('#wbLocalControls')\n            local_display = await wb_local.get_attribute('style')\n            if 'display:none' not in local_display and 'display: none' not in local_display:\n                passed.append(\"✅ 测试8: 白平衡局部模式 → 局部控制显示\")\n            else:\n                errors.append(f\"❌ 测试8: 白平衡局部模式 控制未显示: style={local_display}\")\n            \n            # R/B 应隐藏\n            wb_manual = page.locator('#wbManualControls')\n            manual_display = await wb_manual.get_attribute('style')\n            if 'display:none' in manual_display or 'display: none' in manual_display:\n                pass  # 正确\n            else:\n                errors.append(f\"❌ 测试8b: 白平衡局部模式 → R/B未隐藏\")\n            \n            # 验证框选按钮存在\n            btn_wb_region = page.locator('#btnWbRegionSelect')\n            if await btn_wb_region.count() > 0:\n                btn_text = await btn_wb_region.text_content()\n                if '框选' in btn_text:\n                    pass  # 正确\n                else:\n                    errors.append(f\"❌ 测试8c: 白平衡框选按钮文字错误: '{btn_text}'\")\n            else:\n                errors.append(\"❌ 测试8c: 未找到白平衡框选按钮\")\n            \n            # 验证定时输入框存在\n            wb_timer = page.locator('#wbTimerInput')\n            if await wb_timer.count() > 0:\n                timer_val = await wb_timer.get_attribute('value')\n                if timer_val == '0':\n                    pass  # 正确：默认0\n                else:\n                    errors.append(f\"❌ 测试8d: 白平衡定时默认值错误: {timer_val}\")\n            else:\n                errors.append(\"❌ 测试8d: 未找到白平衡定时输入框\")\n            \n            # 验证停止按钮存在且隐藏\n            wb_stop = page.locator('#btnWbLocalStop')\n            if await wb_stop.count() > 0:\n                stop_display = await wb_stop.get_attribute('style')\n                if 'display:none' in stop_display or 'display: none' in stop_display:\n                    pass  # 正确：默认隐藏\n                else:\n                    errors.append(f\"❌ 测试8e: 白平衡停止按钮未隐藏\")\n            else:\n                errors.append(\"❌ 测试8e: 未找到白平衡停止按钮\")\n                \n        except Exception as e:\n            errors.append(f\"❌ 测试8异常: {e}\")\n        \n        # ========== 测试9: 白平衡 - 切回自动，所有附加控件隐藏 ==========\n        try:\n            await page.select_option('#wbMode', 'auto')\n            await page.wait_for_timeout(300)\n            \n            wb_manual = page.locator('#wbManualControls')\n            manual_display = await wb_manual.get_attribute('style')\n            wb_local = page.locator('#wbLocalControls')\n            local_display = await wb_local.get_attribute('style')\n            \n            if ('display:none' in manual_display or 'display: none' in manual_display) and \\\n               ('display:none' in local_display or 'display: none' in local_display):\n                passed.append(\"✅ 测试9: 白平衡自动模式 → 所有附加控件隐藏\")\n            else:\n                errors.append(f\"❌ 测试9: 白平衡自动模式 控件未全部隐藏\")\n        except Exception as e:\n            errors.append(f\"❌ 测试9异常: {e}\")\n        \n        # ========== 测试10: 对焦下拉3选项 ==========\n        try:\n            focus_select = page.locator('#focusMode')\n            if await focus_select.count() > 0:\n                options = await focus_select.locator('option').all()\n                opt_values = []\n                for opt in options:\n                    opt_values.append(await opt.get_attribute('value'))\n                \n                expected = ['auto', 'manual', 'local']\n                if opt_values == expected:\n                    passed.append(f\"✅ 测试10: 对焦下拉选项正确: {opt_values}\")\n                else:\n                    errors.append(f\"❌ 测试10: 对焦下拉选项不符: 期望{expected}, 实际{opt_values}\")\n            else:\n                errors.append(\"❌ 测试10: 未找到对焦下拉 (focusMode)\")\n        except Exception as e:\n            errors.append(f\"❌ 测试10异常: {e}\")\n        \n        # ========== 测试11: 对焦 - 焦点移动按钮默认隐藏 ==========\n        try:\n            focus_move = page.locator('#focusMoveControls')\n            if await focus_move.count() > 0:\n                display_val = await focus_move.get_attribute('style')\n                if 'display:none' in display_val or 'display: none' in display_val:\n                    passed.append(\"✅ 测试11: 对焦焦点移动按钮默认隐藏\")\n                else:\n                    errors.append(f\"❌ 测试11: 焦点移动按钮未隐藏: style={display_val}\")\n            else:\n                errors.append(\"❌ 测试11: 未找到 focusMoveControls\")\n        except Exception as e:\n            errors.append(f\"❌ 测试11异常: {e}\")\n        \n        # ========== 测试12: 对焦 - 切换到手动模式，焦点按钮显示 ==========\n        try:\n            await page.select_option('#focusMode', 'manual')\n            await page.wait_for_timeout(300)\n            \n            focus_move = page.locator('#focusMoveControls')\n            display_val = await focus_move.get_attribute('style')\n            if 'display:none' not in display_val and 'display: none' not in display_val:\n                passed.append(\"✅ 测试12: 对焦手动模式 → 焦点移动按钮显示\")\n            else:\n                errors.append(f\"❌ 测试12: 对焦手动模式 焦点按钮未显示: style={display_val}\")\n            \n            # 验证按钮文字\n            far_btn = page.locator('#focusMoveControls button:has-text(\"远\")')\n            near_btn = page.locator('#focusMoveControls button:has-text(\"近\")')\n            if await far_btn.count() > 0 and await near_btn.count() > 0:\n                pass  # 正确\n            else:\n                errors.append(\"❌ 测试12b: 焦点移动按钮文字不正确（远/近）\")\n            \n            # 局部控制应隐藏\n            focus_local = page.locator('#focusLocalControls')\n            local_display = await focus_local.get_attribute('style')\n            if 'display:none' in local_display or 'display: none' in local_display:\n                pass\n            else:\n                errors.append(f\"❌ 测试12c: 对焦手动模式 → 局部控制未隐藏\")\n        except Exception as e:\n            errors.append(f\"❌ 测试12异常: {e}\")\n        \n        # ========== 测试13: 对焦 - 切换到局部模式 ==========\n        try:\n            await page.select_option('#focusMode', 'local')\n            await page.wait_for_timeout(300)\n            \n            focus_local = page.locator('#focusLocalControls')\n            local_display = await focus_local.get_attribute('style')\n            if 'display:none' not in local_display and 'display: none' not in local_display:\n                passed.append(\"✅ 测试13: 对焦局部模式 → 局部控制显示\")\n            else:\n                errors.append(f\"❌ 测试13: 对焦局部模式 控制未显示: style={local_display}\")\n            \n            # 焦点移动应隐藏\n            focus_move = page.locator('#focusMoveControls')\n            move_display = await focus_move.get_attribute('style')\n            if 'display:none' in move_display or 'display: none' in move_display:\n                pass\n            else:\n                errors.append(f\"❌ 测试13b: 对焦局部模式 → 焦点按钮未隐藏\")\n            \n            # 验证框选按钮\n            btn_focus_region = page.locator('#btnFocusRegionSelect')\n            if await btn_focus_region.count() > 0:\n                btn_text = await btn_focus_region.text_content()\n                if '框选' in btn_text:\n                    pass\n                else:\n                    errors.append(f\"❌ 测试13c: 对焦框选按钮文字错误: '{btn_text}'\")\n            else:\n                errors.append(\"❌ 测试13c: 未找到对焦框选按钮\")\n            \n            # 验证定时输入框\n            focus_timer = page.locator('#focusTimerInput')\n            if await focus_timer.count() > 0:\n                timer_val = await focus_timer.get_attribute('value')\n                if timer_val == '0':\n                    pass\n                else:\n                    errors.append(f\"❌ 测试13d: 对焦定时默认值错误: {timer_val}\")\n            else:\n                errors.append(\"❌ 测试13d: 未找到对焦定时输入框\")\n            \n            # 验证停止按钮\n            focus_stop = page.locator('#btnFocusLocalStop')\n            if await focus_stop.count() > 0:\n                stop_display = await focus_stop.get_attribute('style')\n                if 'display:none' in stop_display or 'display: none' in stop_display:\n                    pass\n                else:\n                    errors.append(f\"❌ 测试13e: 对焦停止按钮未隐藏\")\n            else:\n                errors.append(\"❌ 测试13e: 未找到对焦停止按钮\")\n                \n        except Exception as e:\n            errors.append(f\"❌ 测试13异常: {e}\")\n        \n        # ========== 测试14: 对焦 - 切回自动 ==========\n        try:\n            await page.select_option('#focusMode', 'auto')\n            await page.wait_for_timeout(300)\n            \n            focus_move = page.locator('#focusMoveControls')\n            move_display = await focus_move.get_attribute('style')\n            focus_local = page.locator('#focusLocalControls')\n            local_display = await focus_local.get_attribute('style')\n            \n            if ('display:none' in move_display or 'display: none' in move_display) and \\\n               ('display:none' in local_display or 'display: none' in local_display):\n                passed.append(\"✅ 测试14: 对焦自动模式 → 所有附加控件隐藏\")\n            else:\n                errors.append(f\"❌ 测试14: 对焦自动模式 控件未全部隐藏\")\n        except Exception as e:\n            errors.append(f\"❌ 测试14异常: {e}\")\n        \n        # ========== 测试15: 降噪位于饱和度/锐度下方 ==========\n        try:\n            # 获取所有 section-subtitle 和关键元素的顺序\n            image_section = page.locator('#imageControlSection .collapsible-content .card')\n            \n            # 获取饱和度、降噪、白平衡的Y坐标位置\n            saturation = page.locator('#consoleSaturation')\n            dnr_spatial = page.locator('#dnrSpatial')\n            wb_mode = page.locator('#wbMode')\n            \n            if await saturation.count() > 0 and await dnr_spatial.count() > 0 and await wb_mode.count() > 0:\n                sat_box = await saturation.bounding_box()\n                dnr_box = await dnr_spatial.bounding_box()\n                wb_box = await wb_mode.bounding_box()\n                \n                if sat_box and dnr_box and wb_box:\n                    # 降噪Y坐标应大于饱和度Y坐标（在下方）\n                    # 白平衡Y坐标应大于降噪Y坐标（在下方）\n                    if dnr_box['y'] > sat_box['y'] and wb_box['y'] > dnr_box['y']:\n                        passed.append(\"✅ 测试15: 降噪位于饱和度下方，白平衡位于降噪下方\")\n                    else:\n                        errors.append(f\"❌ 测试15: 位置错误 - 饱和度Y={sat_box['y']:.0f}, 降噪Y={dnr_box['y']:.0f}, 白平衡Y={wb_box['y']:.0f}\")\n                else:\n                    errors.append(\"❌ 测试15: 无法获取元素位置\")\n            else:\n                errors.append(\"❌ 测试15: 关键元素不存在\")\n        except Exception as e:\n            errors.append(f\"❌ 测试15异常: {e}\")\n        \n        # ========== 测试16: OSD控制区无PTZ开关 ==========\n        try:\n            # 在画面控制区查找 ptzOsdSwitch（旧的ID，不应该存在）\n            old_ptz_switch = page.locator('#imageControlSection #ptzOsdSwitch')\n            if await old_ptz_switch.count() == 0:\n                passed.append(\"✅ 测试16: 画面控制区已移除PTZ OSD开关\")\n            else:\n                errors.append(\"❌ 测试16: 画面控制区仍存在旧的ptzOsdSwitch\")\n        except Exception as e:\n            errors.append(f\"❌ 测试16异常: {e}\")\n        \n        # ========== 测试17: OSD控制区保留信息开关 ==========\n        try:\n            info_switch = page.locator('#imageControlSection #infoOsdSwitch')\n            if await info_switch.count() > 0:\n                passed.append(\"✅ 测试17: 画面控制区保留信息OSD开关\")\n            else:\n                errors.append(\"❌ 测试17: 信息OSD开关不存在\")\n        except Exception as e:\n            errors.append(f\"❌ 测试17异常: {e}\")\n        \n        # ========== 测试18: 右侧面板元素顺序完整验证 ==========\n        try:\n            # 获取右侧画面控制区所有关键元素的Y坐标，验证顺序\n            elements_to_check = [\n                ('consoleBrightness', '亮度'),\n                ('consoleSaturation', '饱和度'),\n                ('dnrSpatial', '空域降噪'),\n                ('wbMode', '白平衡模式'),\n                ('focusMode', '对焦模式'),\n                ('exposureMode', '曝光模式'),\n                ('gainLevel', '增益'),\n            ]\n            \n            prev_y = 0\n            order_ok = True\n            for elem_id, label in elements_to_check:\n                elem = page.locator('#' + elem_id)\n                if await elem.count() > 0:\n                    box = await elem.bounding_box()\n                    if box:\n                        if box['y'] < prev_y - 5:  # 允许5px误差\n                            errors.append(f\"❌ 测试18: {label}({elem_id}) Y={box['y']:.0f} 在前一个元素 Y={prev_y:.0f} 之上\")\n                            order_ok = False\n                        prev_y = box['y']\n                    else:\n                        errors.append(f\"❌ 测试18: {label}({elem_id}) 无法获取位置\")\n                        order_ok = False\n                else:\n                    errors.append(f\"❌ 测试18: {label}({elem_id}) 不存在\")\n                    order_ok = False\n            \n            if order_ok:\n                passed.append(\"✅ 测试18: 右侧面板元素顺序正确（亮度→饱和度→降噪→白平衡→对焦→曝光→增益）\")\n        except Exception as e:\n            errors.append(f\"❌ 测试18异常: {e}\")\n        \n        # ========== 测试19: 定时输入框可以修改值 ==========\n        try:\n            # 切到局部白平衡\n            await page.select_option('#wbMode', 'local')\n            await page.wait_for_timeout(300)\n            \n            wb_timer = page.locator('#wbTimerInput')\n            await wb_timer.fill('5')\n            val = await wb_timer.input_value()\n            if val == '5':\n                passed.append(\"✅ 测试19: 白平衡定时输入框可修改值（0→5）\")\n            else:\n                errors.append(f\"❌ 测试19: 定时输入框值错误: 期望5, 实际{val}\")\n        except Exception as e:\n            errors.append(f\"❌ 测试19异常: {e}\")\n        \n        # ========== 测试20: 定时输入框 min=0 ==========\n        try:\n            wb_timer = page.locator('#wbTimerInput')\n            min_val = await wb_timer.get_attribute('min')\n            if min_val == '0':\n                passed.append(\"✅ 测试20: 白平衡定时输入框 min=0（0=不执行定时）\")\n            else:\n                errors.append(f\"❌ 测试20: 定时输入框 min={min_val}（应为0）\")\n        except Exception as e:\n            errors.append(f\"❌ 测试20异常: {e}\")\n        \n        # ========== 测试21: 对焦定时输入框 ==========\n        try:\n            await page.select_option('#focusMode', 'local')\n            await page.wait_for_timeout(300)\n            \n            focus_timer = page.locator('#focusTimerInput')\n            await focus_timer.fill('10')\n            val = await focus_timer.input_value()\n            min_val = await focus_timer.get_attribute('min')\n            \n            if val == '10' and min_val == '0':\n                passed.append(\"✅ 测试21: 对焦定时输入框可修改值且min=0\")\n            else:\n                errors.append(f\"❌ 测试21: 对焦定时 val={val}, min={min_val}\")\n        except Exception as e:\n            errors.append(f\"❌ 测试21异常: {e}\")\n        \n        # ========== 测试22: JS函数存在性检查 ==========\n        try:\n            functions_check = await page.evaluate(\"\"\"() => {\n                return {\n                    onWbModeChange: typeof onWbModeChange === 'function',\n                    onFocusModeChange: typeof onFocusModeChange === 'function',\n                    stopAutoWhiteBalance: typeof stopAutoWhiteBalance === 'function',\n                    stopAutoFocus: typeof stopAutoFocus === 'function',\n                    togglePtzOsdSwitch: typeof togglePtzOsdSwitch === 'function',\n                    toggleRegionMode: typeof toggleRegionMode === 'function'\n                };\n            }\"\"\")\n            \n            missing = [k for k, v in functions_check.items() if !v]\n            if len(missing) == 0:\n                passed.append(\"✅ 测试22: 所有JS函数已定义\")\n            else:\n                errors.append(f\"❌ 测试22: 缺失JS函数: {missing}\")\n        except Exception as e:\n            errors.append(f\"❌ 测试22异常: {e}\")\n        \n        # ========== 输出结果 ==========\n        print(\"\\n\" + \"=\" * 60)\n        print(\"Playwright E2E 验证结果 — v8.38 主控台界面重构\")\n        print(\"=\" * 60)\n        print(f\"\\n✅ 通过: {len(passed)}\")\n        for p_item in passed:\n            print(f\"  {p_item}\")\n        \n        print(f\"\\n❌ 失败: {len(errors)}\")\n        for e_item in errors:\n            print(f\"  {e_item}\")\n        \n        if console_errors:\n            print(f\"\\n⚠️ Console错误 ({len(console_errors)}):\")\n            for ce in console_errors[:5]:\n                print(f\"  {ce}\")\n        \n        print(f\"\\n总计: {len(passed)} 通过 / {len(errors)} 失败\")\n        print(\"=\" * 60)\n        \n        await browser.close()\n        \n        # 退出码\n        sys.exit(0 if len(errors) == 0 else 1)\n\nif __name__ == '__main__':\n    asyncio.run(main())\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\tests\\e2e_v838_ui.py"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":91120,"output":5896,"cacheRead":0,"cacheWrite":0,"totalTokens":97016,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783119501949,"responseId":"cht000dee48@dx19f2a345dd22872503"}}
