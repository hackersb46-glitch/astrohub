-->\n+ 328                                     <!-- OSD 控制 - 仅信息开关（PTZ OSD已移至运动控制） -->\n  285                                     <div class=\"form-group\" style=\"margin-bottom:8px;display:flex;justify-content:space-between;align-items:center\">\n  286                                         <label style=\"font-size:12px;margin:0\">信息</label>\n  287                                         <div style=\"display:flex;gap:16px\">\n  288                                             <div style=\"display:flex;align-items:center;gap:6px\">\n      ...\n  291                                                     <input type=\"checkbox\" id=\"infoOsdSwitch\" onchange=\"toggleInfoOsdSwitch(this.checked)\">\n  292                                                     <span class=\"toggle-slider\"></span>\n  293                                                 </label>\n  294                                             </div>\n- 295                                             <div style=\"display:flex;align-items:center;gap:6px\">\n- 296                                                 <span style=\"font-size:11px;color:#8b949e\">PTZ</span>\n- 297                                                 <label class=\"toggle-switch\">\n- 298                                                     <input type=\"checkbox\" id=\"ptzOsdSwitch\" onchange=\"togglePtzOsdSwitch(this.checked)\">\n- 299                                                     <span class=\"toggle-slider\"></span>\n- 300                                                 </label>\n- 301                                             </div>\n  302                                         </div>\n  303                                     </div>\n  304                                 </div>\n  305                             </div>\n      ...","firstChangedLine":229},"isError":false,"timestamp":1783118018700}}
