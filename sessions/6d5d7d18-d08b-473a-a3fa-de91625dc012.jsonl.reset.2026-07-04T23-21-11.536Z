{"type":"message","id":"d0810ea7","parentId":"bc758075","timestamp":"2026-07-03T21:53:34.433Z","message":{"role":"toolResult","toolCallId":"call_5ce176c828e911b392349c9b","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\r\n            <div id=\"consoleWarning\" style=\"display:none;position:fixed;top:50%;left:50%;transform:translate(-50%, -50%);background:#4a3a1a;border:2px solid #d29922;border-radius:12px;padding:32px 48px;color:#d29922;font-size:16px;z-index:10000;text-align:center;width:300px\">\r\n                <strong style=\"font-size:20px\">⚠️ 请连接设备</strong><br><br>\r\n                <span style=\"color:#8b949e;font-size:14px\">在设备管理页面连接设备</span>\r\n            </div>\r\n            <div id=\"ptzControlArea\">\r\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\r\n                <div class=\"console-layout\">\r\n                    <!-- 左: PTZ控制（整合：指向+预置点+变焦/对焦） -->\r\n                    <div class=\"console-left\">\r\n                        <!-- PTZ控制（折叠） -->\r\n                        <div class=\"collapsible-section\" id=\"ptzControlSection\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 运动控制</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <!-- 指向控制 + 信息展示 -->\r\n                                <div style=\"display:flex;gap:8px;align-items:stretch\">\r\n                                    <!-- 左侧：方向控制 + 速度 -->\r\n                                    <div style=\"flex:0 0 auto;display:flex;flex-direction:column;justify-content:space-between\">\r\n                                        <div class=\"ptz-controls\">\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\r\n                                            <button class=\"ptz-btn center\">●</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\r\n                                        </div>\r\n                                        <div class=\"ptz-speed\" style=\"width:170px;font-size:11px;margin-top:8px\">\r\n                                            <label style=\"font-size:11px\">速度:</label>\r\n                                            <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"7\" value=\"4\" style=\"width:90px\">\r\n                                            <span id=\"ptzSpeedVal\" style=\"font-size:11px\">4</span>\r\n                                        </div>\r\n                                    </div>\r\n                                    <!-- 右侧：光圈快门 + P/T/Z（竖排，宽度减少15%） -->\r\n                                    <div style=\"flex:0 0 110px;display:flex;flex-direction:column;gap:0\">\r\n                                        <div class=\"info-block\" style=\"flex:1\">\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">光圈</span><span class=\"info-value\" id=\"ptzIris\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">快门</span><span class=\"info-value\" id=\"ptzShutter\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">R</span><span class=\"info-value\" id=\"ptzWbR\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">B</span><span class=\"info-value\" id=\"ptzWbB\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">空域</span><span class=\"info-value\" id=\"ptzDnrSpatial\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"padding:1px 4px;font-size:12px\"><span class=\"info-label\">时域</span><span class=\"info-value\" id=\"ptzDnrTemporal\">--</span></div>\r\n                                        </div>\r\n                                        <div style=\"border-top:2px solid #30363d;margin-top:2px;padding-top:2px\"></div>\r\n                                        <div class=\"info-block\" style=\"flex:1\">\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">Pan</span><span class=\"info-value\" id=\"ptzPan\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">Tilt</span><span class=\"info-value\" id=\"ptzTilt\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"padding:1px 4px;font-size:12px\"><span class=\"info-label\">Zoom</span><span class=\"info-value\" id=\"ptzZoom\">--</span></div>\r\n                                        </div>\r\n                                    </div>\r\n                                </div>\r\n                                <!-- 码流控制 -->\r\n                                <div class=\"section-subtitle\">码流</div>\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamMain\" onclick=\"switchAndPlay(1)\" title=\"主码流\">主</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamSub\" onclick=\"switchAndPlay(2)\" title=\"子码流\">子</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamThird\" onclick=\"switchAndPlay(3)\" title=\"第三码流\">三</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamStop\" onclick=\"doStopPreview()\" title=\"停止预览\">⏹</button>\r\n                                </div>\r\n                                <!-- 预置点 -->\r\n                                <div class=\"section-subtitle\">预置点</div>\r\n                                <div style=\"display:flex;gap:4px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:100px\">\r\n                                        <option value=\"\">选择预置点</option>\r\n                                    </select>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzWritePreset()\">写入</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onclick=\"ptzHome()\">归位</button>\r\n                                </div>\r\n                                <!-- 变焦/对焦 -->\r\n                                <div class=\"section-subtitle\">变焦/对焦</div>\r\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\r\n                                    <span style=\"color:#8b949e;font-size:13px\">焦距:</span>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('in')\" ontouchend=\"ptzStop()\">🔍+</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzZoom('out')\" ontouchend=\"ptzStop()\">🔍-</button>\r\n                                </div>\r\n                                <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin-bottom:8px\">\r\n                                    <span style=\"color:#8b949e;font-size:13px\">对焦:</span>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('near')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('near')\" ontouchend=\"ptzStop()\">远</button>\r\n                                    <button class=\"btn btn-secondary btn-sm\" onmousedown=\"ptzFocus('far')\" onmouseup=\"ptzStop()\" ontouchstart=\"ptzFocus('far')\" ontouchend=\"ptzStop()\">近</button>\r\n                                    <select id=\"focusMode\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:12px\" onchange=\"setFocusMode(this.value)\">\r\n                                        <option value=\"manual\">手动</option>\r\n                                        <option value=\"auto\">自动</option>\r\n                                        <option value=\"semiauto\">半自动</option>\r\n                                    </select>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 媒体信息（折叠，默认展开） -->\r\n                        <div class=\"collapsible-section\" id=\"mediaLogSection\" style=\"margin-top:12px\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaLogSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">📡 媒体信息</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;overflow-y:auto;height:200px\" class=\"hide-scrollbar\">\r\n                                    <div id=\"mediaLogBox\" style=\"font-size:11px;font-family:monospace;color:#8b949e\">\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 中: 实时画面 + 媒体操作 -->\r\n                    <div class=\"console-center\">\r\n                        <div class=\"console-video-wrap\" style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\r\n                            <!-- v7.98: WASM 播放器占位区域，保留16:9比例 -->\r\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;margin:0 auto\"></div>\r\n                            <!-- v8.10: 框选区域 overlay（默认隐藏） -->\r\n                            <div id=\"regionOverlay\" style=\"display:none;position:absolute;top:0;left:0;width:100%;height:100%;cursor:crosshair;z-index:100\">\r\n                                <div id=\"regionBox\" style=\"position:absolute;border:2px dashed #3fb950;background:rgba(63,185,80,0.15);display:none;pointer-events:none\"></div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 媒体操作 + 跟踪控制 并排 -->\r\n                        <div style=\"display:flex;gap:12px;width:100%\">\r\n                            <div style=\"flex:1\">\r\n                                <div class=\"collapsible-section\" id=\"mediaControlSection\">\r\n                                    <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\r\n                                        <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\r\n                                        <span class=\"collapse-icon\">▼</span>\r\n                                    </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\r\n                                    <!-- 截图/录像 -->\r\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\r\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\r\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecord\" onclick=\"toggleRecord()\">⏺ 录像</button>\r\n                                    </div>\r\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\r\n                                    <!-- v8.10: 框选分析 -->\r\n                                    <div class=\"section-subtitle\">框选分析</div>\r\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\r\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnRegionWB\" onclick=\"toggleRegionMode('whitebalance')\">🎨 白平衡</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" id=\"btnRegionAF\" onclick=\"toggleRegionMode('focus')\">🔍 对焦</button>\r\n                                    </div>\r\n                                    <!-- Live Stack -->\r\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\r\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\r\n                                    </div>\r\n                                    <div style=\"font-size:12px;color:#8b949e;text-align:center;margin-bottom:8px\">\r\n                                        硬件曝光: <input type=\"number\" id=\"hardwareExposureMs\" value=\"100\" style=\"width:60px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\"> ms\r\n                                    </div>\r\n                                    <div class=\"btn-group\" style=\"justify-content:center\">\r\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnLiveStackStart\" onclick=\"startLiveStack()\">▶ 开始</button>\r\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnLiveStackStop\" onclick=\"stopLiveStack()\" disabled>⏹ 停止</button>\r\n                                        <button class=\"btn btn-success btn-sm\" id=\"btnLiveStackSave\" onclick=\"saveLiveStack()\" disabled>💾 保存</button>\r\n                                    </div>\r[... 13663 more characters truncated]"}],"isError":false,"timestamp":1783115614433}}
{"type":"message","id":"a98268f1","parentId":"d0810ea7","timestamp":"2026-07-03T21:53:44.459Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see the structure now. Let me continue reading to get more context on the focus controls and the rest of the image controls. The key sections I need to understand:\n\n1. 运动控制 section (console-left):\n   - 方向控制, 速度, 光圈快门信息\n   - 码流控制\n   - 预置点\n   - 变焦/对焦 section - this is where focus controls are\n\n2. 画面控制 section (console-right):\n   - 亮度/对比度\n   - 饱和度/锐度\n   - 白平衡模式 + R/B sliders\n   - 降噪 (空域/时域)\n   - 曝光模式 + 快门/光圈\n   - 增益\n   - OSD 控制 (信息/PTZ)\n\nLet me continue reading to see the complete structure.","thinkingSignature":""},{"type":"text","text":"Let me continue reading the rest of console.html:"},{"type":"toolCall","id":"tool-80d9f2ba21684d01b67488dd97f6c11a","name":"read","arguments":{"limit":150,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html","offset":300}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":52769,"output":239,"cacheRead":0,"cacheWrite":0,"totalTokens":53008,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783115614434,"responseId":"cht000db32c@dx19f29f909d62871503"}}
{"type":"message","id":"07e16399","parentId":"a98268f1","timestamp":"2026-07-03T21:53:44.482Z","message":{"role":"toolResult","toolCallId":"tool-80d9f2ba21684d01b67488dd97f6c11a","toolName":"read","content":[{"type":"text","text":"                                                </label>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n<style>\r\n/* v7.30: 模块禁用样式 - 保留折叠展开功能 */\r\n.section-disabled .collapsible-content {\r\n    opacity: 0.4;\r\n    pointer-events: none;\r\n}\r\n.section-disabled .collapsible-header {\r\n    opacity: 0.6;\r\n}\r\n.section-disabled .collapsible-header:hover {\r\n    cursor: pointer;\r\n}\r\n\r\n/* v6.02: 拨杆开关样式 */\r\n.toggle-switch {\r\n    position: relative;\r\n    display: inline-block;\r\n    width: 40px;\r\n    height: 22px;\r\n}\r\n.toggle-switch input {\r\n    opacity: 0;\r\n    width: 0;\r\n    height: 0;\r\n}\r\n.toggle-slider {\r\n    position: absolute;\r\n    cursor: pointer;\r\n    top: 0;\r\n    left: 0;\r\n    right: 0;\r\n    bottom: 0;\r\n    background-color: #30363d;\r\n    transition: 0.3s;\r\n    border-radius: 22px;\r\n}\r\n.toggle-slider:before {\r\n    position: absolute;\r\n    content: \"\";\r\n    height: 16px;\r\n    width: 16px;\r\n    left: 3px;\r\n    bottom: 3px;\r\n    background-color: #e0e6f0;\r\n    transition: 0.3s;\r\n    border-radius: 50%;\r\n}\r\ninput:checked + .toggle-slider {\r\n    background-color: #238636;\r\n}\r\ninput:checked + .toggle-slider:before {\r\n    transform: translateX(18px);\r\n}\r\n\r\n/* 折叠面板样式 */\r\n.collapsible-section {\r\n    background: #161b22;\r\n    border: 1px solid #21262d;\r\n    border-radius: 8px;\r\n    margin-bottom: 12px;\r\n    overflow: hidden;\r\n}\r\n.collapsible-header {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    padding: 10px 12px;\r\n    cursor: pointer;\r\n    background: #0d1117;\r\n    transition: background 0.2s;\r\n}\r\n.collapsible-header:hover {\r\n    background: #161b22;\r\n}\r\n.collapse-icon {\r\n    color: #8b949e;\r\n    font-size: 12px;\r\n    transition: transform 0.2s;\r\n}\r\n.collapsible-section.collapsed .collapse-icon {\r\n    transform: rotate(-90deg);\r\n}\r\n.collapsible-content {\r\n    padding: 12px;\r\n    max-height: 1000px;\r\n    overflow: hidden;\r\n    transition: max-height 0.3s ease-out, padding 0.3s;\r\n}\r\n.collapsible-section.collapsed .collapsible-content {\r\n    max-height: 0;\r\n    padding: 0 12px;\r\n}\r\n.section-subtitle {\r\n    font-size: 12px;\r\n    color: #6e7681;\r\n    margin: 8px 0 4px;\r\n    padding-top: 8px;\r\n    border-top: 1px solid #21262d;\r\n}\r\n.section-subtitle:first-child {\r\n    border-top: none;\r\n    padding-top: 0;\r\n}\r\n\r\n/* v7.55: PTZ信息方块样式 */\r\n.info-block {\r\n    background: #0d1117;\r\n    border: 1px solid #30363d;\r\n    border-radius: 6px;\r\n    padding: 6px;\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 4px;\r\n}\r\n.info-row {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    padding: 4px 8px;\r\n    font-size: 13px;\r\n}\r\n.info-row-2val {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    gap: 8px;\r\n}\r\n.info-row-2val > div {\r\n    flex: 1;\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    padding: 3px 6px;\r\n    font-size: 11px;\r\n}\r\n.info-label {\r\n    color: #8b949e;\r\n    font-weight: 500;\r\n}\r\n\n[1136 more lines in file. Use offset=450 to continue.]"}],"isError":false,"timestamp":1783115624482}}
{"type":"message","id":"f2cf730e","parentId":"07e16399","timestamp":"2026-07-03T21:53:52.116Z","message":{"role":"assistant","content":[{"type":"text","text":"我来读取一下 `console.html` 的剩余内容，以了解其中的 JS 函数："},{"type":"toolCall","id":"call_f840a04886904c0eafd958cd","name":"read","arguments":{"limit":200,"offset":450,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":53735,"output":65,"cacheRead":0,"cacheWrite":0,"totalTokens":53800,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783115624483,"responseId":"cht000d4db3@dx19f29f936b529bb503"}}
{"type":"message","id":"9c43bfab","parentId":"f2cf730e","timestamp":"2026-07-03T21:53:52.138Z","message":{"role":"toolResult","toolCallId":"call_f840a04886904c0eafd958cd","toolName":"read","content":[{"type":"text","text":".info-value {\r\n    color: #58a6ff;\r\n    font-weight: 600;\r\n}\r\n.info-label-sm {\r\n    color: #8b949e;\r\n    font-size: 10px;\r\n}\r\n.info-value-sm {\r\n    color: #58a6ff;\r\n    font-size: 10px;\r\n}\r\n/* v7.57: PTZ信息横向一行 */\r\n.info-row-h {\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    gap: 4px;\r\n    background: #0d1117;\r\n    border: 1px solid #30363d;\r\n    border-radius: 6px;\r\n    padding: 4px 6px;\r\n    margin-top: 4px;\r\n}\r\n.info-row-h .info-label {\r\n    font-size: 12px;\r\n    color: #8b949e;\r\n}\r\n.info-row-h .info-value {\r\n    font-size: 12px;\r\n    color: #58a6ff;\r\n    font-weight: 600;\r\n    min-width: 28px;\r\n    text-align: right;\r\n}\r\n.info-divider {\r\n    width: 1px;\r\n    height: 14px;\r\n    background: #30363d;\r\n    margin: 0 2px;\r\n}\r\n</style>\r\n\r\n<script>\r\n// 等待 apiGet/apiPost 可用后再定义函数\r\n(function() {\r\n    // 检查 apiGet 是否已定义\r\n    if (typeof apiGet === 'undefined') {\r\n        console.warn('[CONSOLE] apiGet not yet defined, will retry on DOMContentLoaded');\r\n        document.addEventListener('DOMContentLoaded', function() {\r\n            // DOM 加载完成后重新执行\r\n            if (typeof apiGet !== 'undefined') {\r\n                console.log('[CONSOLE] apiGet now available');\r\n            }\r\n        });\r\n    }\r\n})();\r\n\r\n// 折叠/展开控制\r\nfunction toggleSection(sectionId) {\r\n    var section = document.getElementById(sectionId);\r\n    if (section) {\r\n        section.classList.toggle('collapsed');\r\n    }\r\n}\r\n\r\n// ==================== 动态加载设备图像参数 ====================\r\nvar deviceImageParams = {};\r\nvar deviceFunctionData = null; // v5.42: 存储function.json数据\r\n\r\n// v6.20: 功能支持状态\r\nvar deviceFunctionData = null;\r\nvar functionCacheLoaded = false;\r\n\r\n// v7.59: 初始化加载标志位（防止初始化时触发操作日志）\r\nvar _isInitializingImageParams = false;\r\n\r\n// v6.20 + v7.0: 禁用所有控制区域（PTZ + 媒体 + 跟踪 + 画面）\r\nfunction disableImageControls(reason) {\r\n    // v7.30: 模块级别禁用灰色样式\r\n    var sections = ['ptzControlSection', 'trackControlSection', 'mediaControlSection', 'imageControlSection', 'logControlSection'];\r\n    sections.forEach(function(sectionId) {\r\n        var section = document.getElementById(sectionId);\r\n        if (section) {\r\n            section.classList.add('section-disabled');\r\n        }\r\n    });\r\n    \r\n    // v7.11: 禁用画面控制控件（包括增益）\r\n    var controls = [\r\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\r\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\r\n        'exposureMode', 'shutterSpeed', 'irisLevel', 'gainLevel',  // v7.11: 添加 gainLevel\r\n        'infoOsdSwitch', 'ptzOsdSwitch'\r\n    ];\r\n    controls.forEach(function(id) {\r\n        var el = document.getElementById(id);\r\n        if (el) {\r\n            el.disabled = true;\r\n            el.style.opacity = '0.5';\r\n            el.style.cursor = 'not-allowed';\r\n        }\r\n    });\r\n    \r\n    // v7.0: 禁用 PTZ 控制按钮\r\n    var ptzSection = document.getElementById('ptzControlSection');\r\n    if (ptzSection) {\r\n        var ptzBtns = ptzSection.querySelectorAll('.btn, .ptz-btn');\r\n        ptzBtns.forEach(function(btn) {\r\n            if (btn.id !== 'ptzSpeed') {\r\n                btn.disabled = true;\r\n                btn.style.opacity = '0.5';\r\n                btn.style.cursor = 'not-allowed';\r\n            }\r\n        });\r\n    }\r\n    \r\n    // v7.0: 禁用媒体操作按钮\r\n    var mediaButtons = ['btnConsoleSnapshot', 'btnConsoleRecord', 'btnLiveStackStart', 'btnLiveStackStop', 'btnLiveStackSave'];\r\n    mediaButtons.forEach(function(id) {\r\n        var el = document.getElementById(id);\r\n        if (el) {\r\n            el.disabled = true;\r\n            el.style.opacity = '0.5';\r\n            el.style.cursor = 'not-allowed';\r\n        }\r\n    });\r\n    \r\n    // v7.0: 禁用跟踪控制按钮\r\n    var trackButtons = ['btnTrackSidereal', 'btnTrackLunar', 'btnTrackSolar', 'btnTrackOff'];\r\n    trackButtons.forEach(function(id) {\r\n        var el = document.getElementById(id);\r\n        if (el) {\r\n            el.disabled = true;\r\n            el.style.opacity = '0.5';\r\n            el.style.cursor = 'not-allowed';\r\n        }\r\n    });\r\n    \r\n    // v7.01: 显示主控台提示框，移除画面控制区的提示\r\n    var consoleWarning = document.getElementById('consoleWarning');\r\n    if (consoleWarning) {\r\n        consoleWarning.style.display = 'block';\r\n    }\r\n    \r\n    // 移除画面控制区的旧提示（如果存在）\r\n    var oldWarning = document.getElementById('functionCacheWarning');\r\n    if (oldWarning) oldWarning.remove();\r\n    \r\n    // v7.0: 停止 PTZ 坐标刷新\r\n    if (window.stopPtzImagePoll) window.stopPtzImagePoll();\r\n}\r\n\r\n// v6.20 + v7.0: 启用所有控制区域\r\nfunction enableImageControls() {\r\n    // v7.30: 移除模块禁用样式\r\n    var sections = ['ptzControlSection', 'trackControlSection', 'mediaControlSection', 'imageControlSection', 'logControlSection'];\r\n    sections.forEach(function(sectionId) {\r\n        var section = document.getElementById(sectionId);\r\n        if (section) {\r\n            section.classList.remove('section-disabled');\r\n        }\r\n    });\r\n    \r\n    // v7.11: 启用画面控制控件（包括增益）\r\n    var controls = [\r\n        'consoleBrightness', 'consoleContrast', 'consoleSaturation', 'consoleSharpness',\r\n        'wbMode', 'wbRed', 'wbBlue', 'dnrSpatial', 'dnrTemporal',\r\n        'exposureMode', 'shutterSpeed', 'irisLevel', 'gainLevel',  // v7.11: 添加 gainLevel\r\n        'infoOsdSwitch', 'ptzOsdSwitch'\r\n    ];\r\n    controls.forEach(function(id) {\r\n        var el = document.getElementById(id);\r\n        if (el) {\r\n            el.disabled = false;\r\n            el.style.opacity = '1';\r\n            el.style.cursor = 'pointer';\r\n        }\r\n    });\r\n    \r\n    // v7.0: 启用 PTZ 控制按钮\r\n    var ptzSection = document.getElementById('ptzControlSection');\r\n    if (ptzSection) {\r\n        var ptzBtns = ptzSection.querySelectorAll('.btn, .ptz-btn');\r\n        ptzBtns.forEach(function(btn) {\r\n            if (btn.id !== 'ptzSpeed') {\r\n                btn.disabled = false;\r\n                btn.style.opacity = '1';\r\n                btn.style.cursor = 'pointer';\r\n            }\r\n        });\r\n    }\r\n    \r\n    // v7.0: 启用媒体操作按钮\r\n    var mediaButtons = ['btnConsoleSnapshot', 'btnConsoleRecord', 'btnLiveStackStart', 'btnLiveStackStop', 'btnLiveStackSave'];\r\n    mediaButtons.forEach(function(id) {\r\n        var el = document.getElementById(id);\r\n        if (el) {\r\n            el.disabled = false;\r\n            el.style.opacity = '1';\r\n\n[936 more lines in file. Use offset=650 to continue.]"}],"isError":false,"timestamp":1783115632138}}
{"type":"message","id":"57fb395d","parentId":"9c43bfab","timestamp":"2026-07-03T21:53:56.732Z","message":{"role":"assistant","content":[{"type":"text","text":"我继续阅读 console.html 以了解其余功能，特别是白平衡和对焦相关的功能："},{"type":"toolCall","id":"call_f4389c3bd5fb48c9b74cb32a","name":"read","arguments":{"limit":300,"offset":650,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":55502,"output":65,"cacheRead":0,"cacheWrite":0,"totalTokens":55567,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783115632139,"responseId":"cht000d506c@dx19f29f9529929bb503"}}
{"type":"message","id":"e12611ef","parentId":"57fb395d","timestamp":"2026-07-03T21:53:56.759Z","message":{"role":"toolResult","toolCallId":"call_f4389c3bd5fb48c9b74cb32a","toolName":"read","content":[{"type":"text","text":"            el.style.cursor = 'pointer';\r\n        }\r\n    });\r\n    \r\n    // v7.0: 启用跟踪控制按钮\r\n    var trackButtons = ['btnTrackSidereal', 'btnTrackLunar', 'btnTrackSolar', 'btnTrackOff'];\r\n    trackButtons.forEach(function(id) {\r\n        var el = document.getElementById(id);\r\n        if (el) {\r\n            el.disabled = false;\r\n            el.style.opacity = '1';\r\n            el.style.cursor = 'pointer';\r\n        }\r\n    });\r\n    \r\n    // v7.01: 隐藏主控台提示框\r\n    var consoleWarning = document.getElementById('consoleWarning');\r\n    if (consoleWarning) {\r\n        consoleWarning.style.display = 'none';\r\n    }\r\n    \r\n    // v7.0: 启动 PTZ 坐标刷新\r\n    if (window.startPtzImagePoll) window.startPtzImagePoll();\r\n}\r\n\r\n// 连接设备时加载图像参数（从function.json读取范围，从ISAPI读取当前值）\r\n// v6.20: 优先读取缓存，无缓存时禁用控件\r\n// v6.41: 修复下拉菜单加载中问题\r\n// 当 function.json 不存在时，仍然加载基础参数（使用默认范围）\r\n// v6.43: 刷新画面控制按钮\r\nfunction refreshImageControls() {\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        console.warn('[IMAGE] No device connected');\r\n        return;\r\n    }\r\n    console.log('[IMAGE] Refreshing image controls...');\r\n    loadDeviceImageParams(window.connectedDevice.ip);\r\n}\r\n\r\n// v6.50: 重置画面控制到系统默认值\r\nfunction resetImageControls() {\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        console.warn('[IMAGE] No device connected');\r\n        return;\r\n    }\r\n    \r\n    // v7.117: 使用统一弹窗确认\r\n    showModal({\r\n        type: 'confirm',\r\n        title: '重置',\r\n        message: '确认重置画面控制到系统默认值？',\r\n        onConfirm: function() {\r\n            var dev = window.connectedDevice.ip;\r\n            console.log('[IMAGE] Resetting image controls to defaults...');\r\n\r\n            // 系统默认值\r\n            var defaults = {\r\n                brightness: 50,\r\n                contrast: 50,\r\n                saturation: 50,\r\n                sharpness: 50,\r\n                wbRed: 100,\r\n                wbBlue: 100,\r\n                dnrSpatial: 50,\r\n                dnrTemporal: 50,\r\n                exposureMode: 'auto',\r\n                shutterSpeed: '1/100',\r\n                irisLevel: 1600\r\n            };\r\n\r\n            // 更新 UI\r\n            document.getElementById('consoleBrightness').value = defaults.brightness;\r\n            document.getElementById('brightnessVal').textContent = defaults.brightness;\r\n            document.getElementById('consoleContrast').value = defaults.contrast;\r\n            document.getElementById('contrastVal').textContent = defaults.contrast;\r\n            document.getElementById('consoleSaturation').value = defaults.saturation;\r\n            document.getElementById('saturationVal').textContent = defaults.saturation;\r\n            document.getElementById('consoleSharpness').value = defaults.sharpness;\r\n            document.getElementById('sharpnessVal').textContent = defaults.sharpness;\r\n            document.getElementById('wbRed').value = defaults.wbRed;\r\n            document.getElementById('wbRedVal').textContent = defaults.wbRed;\r\n            document.getElementById('wbBlue').value = defaults.wbBlue;\r\n            document.getElementById('wbBlueVal').textContent = defaults.wbBlue;\r\n            document.getElementById('dnrSpatial').value = defaults.dnrSpatial;\r\n            document.getElementById('dnrSpatialVal').textContent = defaults.dnrSpatial;\r\n            document.getElementById('dnrTemporal').value = defaults.dnrTemporal;\r\n            document.getElementById('dnrTemporalVal').textContent = defaults.dnrTemporal;\r\n            document.getElementById('exposureMode').value = defaults.exposureMode;\r\n            document.getElementById('shutterSpeed').value = defaults.shutterSpeed;\r\n            document.getElementById('irisLevel').value = defaults.irisLevel;\r\n\r\n            // 发送 API 请求重置设备\r\n            apiPost('/api/v1/ptz/' + dev + '/image/reset', {})\r\n                .then(function(r) {\r\n                    if (r && r.success) {\r\n                        showToast('success', '画面控制已重置到系统默认值');\r\n                        if (typeof operationLog === 'function') operationLog('画面重置', 'success');\r\n                    } else {\r\n                        showToast('error', '重置失败: ' + (r.message || '未知错误'));\r\n                    }\r\n                })\r\n                .catch(function(e) {\r\n                    showToast('error', '重置请求失败');\r\n                });\r\n        }\r\n    });\r\n}\r\n\r\nfunction loadDeviceImageParams(deviceIp) {\r\n    if (!deviceIp) return;\r\n    \r\n    if (typeof apiGet === 'undefined') {\r\n        console.error('[IMAGE] apiGet not defined');\r\n        return;\r\n    }\r\n    \r\n    console.log('[IMAGE] Loading image params for:', deviceIp);\r\n    \r\n    // v6.41: 重置状态\r\n    functionCacheLoaded = false;\r\n    deviceFunctionData = null;\r\n    \r\n    // v7.32: 必须有 function.json 才能启用画面控制\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/function').then(function(r) {\r\n        if (r && r.success && r.data && r.data.functions) {\r\n            deviceFunctionData = r.data;\r\n            functionCacheLoaded = true;\r\n            console.log('[IMAGE] function.json loaded, detected_at:', r.data.detected_at);\r\n            enableImageControls();\r\n            // 移除覆盖层\r\n            removeFunctionOverlay();\r\n            // 加载图像参数\r\n            loadAllImageParams(deviceIp);\r\n        } else {\r\n            console.warn('[IMAGE] function.json not found - disabling image controls');\r\n            // 禁用画面控制\r\n            disableImageControls('请执行功能检测，以启用此功能');\r\n            // 显示覆盖层\r\n            showFunctionOverlay();\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[IMAGE] function.json failed:', e);\r\n        disableImageControls('请执行功能检测，以启用此功能');\r\n        showFunctionOverlay();\r\n    });\r\n}\r\n\r\n// v7.32: 加载所有图像参数\r\nfunction loadAllImageParams(deviceIp) {\r\n    _isInitializingImageParams = true;  // v7.59: 开始初始化，禁止记录日志\r\n    loadExposure(deviceIp);\r\n    loadOsdStatus(deviceIp);\r\n    loadWhiteBalance(deviceIp);\r\n    loadNoiseReduce(deviceIp);\r\n    loadShutter(deviceIp);\r\n    loadIris(deviceIp);\r\n    loadSharpness(deviceIp);\r\n    loadColorParams(deviceIp);\r\n    loadGain(deviceIp);\r\n    // v7.59: 延迟结束初始化标志（等待异步加载完成）\r\n    setTimeout(function() { _isInitializingImageParams = false; }, 3000);\r\n}\r\n\r\n// v7.32: 显示功能检测覆盖层\r\nfunction showFunctionOverlay() {\r\n    var section = document.getElementById('imageControlSection');\r\n    if (!section) return;\r\n    \r\n    // 移除旧覆盖层\r\n    var oldOverlay = document.getElementById('function-required-overlay');\r\n    if (oldOverlay) oldOverlay.remove();\r\n    \r\n    // 创建覆盖层\r\n    var overlay = document.createElement('div');\r\n    overlay.id = 'function-required-overlay';\r\n    overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(13,17,23,0.9);z-index:100;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;padding:20px;';\r\n    overlay.innerHTML = '<div style=\"color:#f0883e;font-size:14px;text-align:center\">请执行功能检测</div><div style=\"color:#8b949e;font-size:12px;text-align:center\">以启用此功能</div><button class=\"btn btn-primary btn-sm\" onclick=\"goToFunctionTest()\" style=\"margin-top:8px\">前往功能检测</button>';\r\n    \r\n    section.style.position = 'relative';\r\n    section.appendChild(overlay);\r\n}\r\n\r\n// v7.32: 移除功能检测覆盖层\r\nfunction removeFunctionOverlay() {\r\n    var overlay = document.getElementById('function-required-overlay');\r\n    if (overlay) overlay.remove();\r\n}\r\n\r\n// v7.32: 跳转到功能检测页面\r\nfunction goToFunctionTest() {\r\n    // 移除覆盖层\r\n    removeFunctionOverlay();\r\n    // 跳转到高级功能页面\r\n    document.querySelector('[data-page=\"advanced\"]').click();\r\n    // 选择功能检测\r\n    setTimeout(function() {\r\n        document.querySelector('[data-test=\"function\"]').click();\r\n    }, 500);\r\n}\r\n\r\n// 加载 OSD 状态\r\nfunction loadOsdStatus(deviceIp) {\r\n    // PTZ OSD\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/ptz').then(function(r) {\r\n        if (r && r.success) {\r\n            var enabled = r.enabled || r.data?.enabled || false;\r\n            updatePtzOsdButtons(enabled);\r\n            // 保存到 localStorage\r\n            localStorage.setItem('osd_ptz_' + deviceIp, enabled ? '1' : '0');\r\n        } else {\r\n            // 从 localStorage 读取上次设置\r\n            var saved = localStorage.getItem('osd_ptz_' + deviceIp);\r\n            if (saved !== null) {\r\n                updatePtzOsdButtons(saved === '1');\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        var saved = localStorage.getItem('osd_ptz_' + deviceIp);\r\n        if (saved !== null) {\r\n            updatePtzOsdButtons(saved === '1');\r\n        }\r\n    });\r\n    \r\n    // Info OSD\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/osd/info').then(function(r) {\r\n        if (r && r.success) {\r\n            var enabled = r.enabled || r.data?.enabled || false;\r\n            updateInfoOsdButtons(enabled);\r\n            localStorage.setItem('osd_info_' + deviceIp, enabled ? '1' : '0');\r\n        } else {\r\n            var saved = localStorage.getItem('osd_info_' + deviceIp);\r\n            if (saved !== null) {\r\n                updateInfoOsdButtons(saved === '1');\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        var saved = localStorage.getItem('osd_info_' + deviceIp);\r\n        if (saved !== null) {\r\n            updateInfoOsdButtons(saved === '1');\r\n        }\r\n    });\r\n}\r\n\r\nfunction updatePtzOsdButtons(enabled) {\r\n    var btnOn = document.getElementById('btnPtzOsdOn');\r\n    var btnOff = document.getElementById('btnPtzOsdOff');\r\n    if (btnOn && btnOff) {\r\n        if (enabled) {\r\n            btnOn.className = 'btn btn-sm btn-primary';\r\n            btnOff.className = 'btn btn-sm btn-secondary';\r\n        } else {\r\n            btnOn.className = 'btn btn-sm btn-secondary';\r\n            btnOff.className = 'btn btn-sm btn-primary';\r\n        }\r\n    }\r\n    // v6.14: 同步开关状态\r\n    var sw = document.getElementById('ptzOsdSwitch');\r\n    if (sw) sw.checked = enabled;\r\n}\r\n\r\nfunction updateInfoOsdButtons(enabled) {\r\n    var btnOn = document.getElementById('btnInfoOsdOn');\r\n    var btnOff = document.getElementById('btnInfoOsdOff');\r\n    if (btnOn && btnOff) {\r\n        if (enabled) {\r\n            btnOn.className = 'btn btn-sm btn-primary';\r\n            btnOff.className = 'btn btn-sm btn-secondary';\r\n        } else {\r\n            btnOn.className = 'btn btn-sm btn-secondary';\r\n            btnOff.className = 'btn btn-sm btn-primary';\r\n        }\r\n    }\r\n    // v6.14: 同步开关状态\r\n    var sw = document.getElementById('infoOsdSwitch');\r\n    if (sw) sw.checked = enabled;\r\n}\r\n\r\n// 加载白平衡\r\nfunction loadWhiteBalance(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/whitebalance').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var wb = r.data;\r\n            deviceImageParams.whiteBalance = wb;\r\n            \r\n            // 更新模式下拉 - v5.40: 自动(官方)/自动(Astrohub)/手动\r\n            var wbModeSelect = document.getElementById('wbMode');\r\n            if (wbModeSelect) {\r\n                wbModeSelect.innerHTML = '';\r\n                \r\n                // 选项1: 自动（官方）\r\n                var opt1 = document.createElement('option');\r\n                opt1.value = 'auto_official';\r\n                opt1.textContent = '自动（官方）';\r\n                if (wb.mode === 'auto') opt1.selected = true;\r\n                wbModeSelect.appendChild(opt1);\r\n                \r\n                // 选项2: 自动\r\n                var opt2 = document.createElement('option');\r\n                opt2.value = 'auto_astrohub';\r\n                opt2.textContent = '自动';\r\n\n[636 more lines in file. Use offset=950 to continue.]"}],"isError":false,"timestamp":1783115636759}}
{"type":"message","id":"aee65be3","parentId":"e12611ef","timestamp":"2026-07-03T21:54:02.825Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me continue reading to understand the focus mode and white balance logic better. I need to see the setFocusMode, setWhiteBalanceMode, and related functions.","thinkingSignature":""},{"type":"text","text":"Let me continue reading to find the focus mode functions:"},{"type":"toolCall","id":"call_eb1529906172479e8bb51c6f","name":"read","arguments":{"limit":400,"offset":950,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":58368,"output":92,"cacheRead":0,"cacheWrite":0,"totalTokens":58460,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783115636760,"responseId":"cht000dba07@dx19f29f964fc2871503"}}
{"type":"message","id":"78b59836","parentId":"aee65be3","timestamp":"2026-07-03T21:54:02.859Z","message":{"role":"toolResult","toolCallId":"call_eb1529906172479e8bb51c6f","toolName":"read","content":[{"type":"text","text":"                wbModeSelect.appendChild(opt2);\r\n                \r\n                // 选项3: 手动\r\n                var opt3 = document.createElement('option');\r\n                opt3.value = 'manual';\r\n                opt3.textContent = '手动';\r\n                if (wb.mode === 'manual') opt3.selected = true;\r\n                wbModeSelect.appendChild(opt3);\r\n            }\r\n            \r\n            // 更新 R/B 滑动条\r\n            var wbRed = document.getElementById('wbRed');\r\n            var wbBlue = document.getElementById('wbBlue');\r\n            var wbRedVal = document.getElementById('wbRedVal');\r\n            var wbBlueVal = document.getElementById('wbBlueVal');\r\n            \r\n            if (wbRed && wb.red_gain !== undefined) {\r\n                wbRed.value = wb.red_gain;\r\n                if (wbRedVal) wbRedVal.textContent = wb.red_gain;\r\n            }\r\n            if (wbBlue && wb.blue_gain !== undefined) {\r\n                wbBlue.value = wb.blue_gain;\r\n                if (wbBlueVal) wbBlueVal.textContent = wb.blue_gain;\r\n            }\r\n            \r\n            // 设置范围\r\n            if (wb.min !== undefined && wb.max !== undefined) {\r\n                if (wbRed) { wbRed.min = wb.min; wbRed.max = wb.max; }\r\n                if (wbBlue) { wbBlue.min = wb.min; wbBlue.max = wb.max; }\r\n            }\r\n            \r\n            // v5.40: 只有手动模式时 R/B 滑动条才可用\r\n            var isManual = wb.mode === 'manual';\r\n            if (wbRed) wbRed.disabled = !isManual;\r\n            if (wbBlue) wbBlue.disabled = !isManual;\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[WB] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 加载降噪\r\nfunction loadNoiseReduce(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/noisereduce').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var nr = r.data;\r\n            deviceImageParams.noiseReduce = nr;\r\n            \r\n            var dnrSpatial = document.getElementById('dnrSpatial');\r\n            var dnrTemporal = document.getElementById('dnrTemporal');\r\n            var dnrSpatialVal = document.getElementById('dnrSpatialVal');\r\n            var dnrTemporalVal = document.getElementById('dnrTemporalVal');\r\n            \r\n            if (dnrSpatial && nr.spatial_level !== undefined) {\r\n                dnrSpatial.value = nr.spatial_level;\r\n                if (dnrSpatialVal) dnrSpatialVal.textContent = nr.spatial_level;\r\n            }\r\n            if (dnrTemporal && nr.temporal_level !== undefined) {\r\n                dnrTemporal.value = nr.temporal_level;\r\n                if (dnrTemporalVal) dnrTemporalVal.textContent = nr.temporal_level;\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[DNR] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 加载快门\r\nfunction loadShutter(deviceIp) {\r\n    // v7.32: 必须有 function.json\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.shutter) {\r\n        console.warn('[Shutter] No function.json data available');\r\n        return;\r\n    }\r\n    \r\n    var shutterValues = deviceFunctionData.functions.shutter.opt_values;\r\n    if (!shutterValues || !Array.isArray(shutterValues) || shutterValues.length === 0) {\r\n        console.warn('[Shutter] shutter not supported');\r\n        var shutterSelect = document.getElementById('shutterSpeed');\r\n        if (shutterSelect) {\r\n            shutterSelect.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            shutterSelect.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n    \r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/shutter').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var sh = r.data;\r\n            deviceImageParams.shutter = sh;\r\n            \r\n            var shutterSelect = document.getElementById('shutterSpeed');\r\n            if (shutterSelect) {\r\n                shutterSelect.innerHTML = '';\r\n                shutterSelect.disabled = false;\r\n                \r\n                shutterValues.forEach(function(p) {\r\n                    var opt = document.createElement('option');\r\n                    opt.value = p;\r\n                    opt.textContent = p;\r\n                    if (p === sh.current_level) opt.selected = true;\r\n                    shutterSelect.appendChild(opt);\r\n                });\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Shutter] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 加载光圈\r\nfunction loadIris(deviceIp) {\r\n    // v7.32: 必须有 function.json\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.iris) {\r\n        console.warn('[Iris] No function.json data available');\r\n        return;\r\n    }\r\n    \r\n    var irisValues = deviceFunctionData.functions.iris.opt_values;\r\n    if (!irisValues || !Array.isArray(irisValues) || irisValues.length === 0) {\r\n        console.warn('[Iris] iris not supported');\r\n        var irisSelect = document.getElementById('irisLevel');\r\n        if (irisSelect) {\r\n            irisSelect.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            irisSelect.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n    \r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/iris').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var ir = r.data;\r\n            deviceImageParams.iris = ir;\r\n            \r\n            var irisSelect = document.getElementById('irisLevel');\r\n            if (irisSelect) {\r\n                irisSelect.innerHTML = '';\r\n                irisSelect.disabled = false;\r\n                \r\n                var current = ir.current_level;\r\n                \r\n                irisValues.forEach(function(val) {\r\n                    var numVal = parseInt(val);\r\n                    var opt = document.createElement('option');\r\n                    opt.value = numVal;\r\n                    var fNum = numVal / 100;\r\n                    opt.textContent = 'F' + fNum.toFixed(1);\r\n                    if (numVal === current) opt.selected = true;\r\n                    irisSelect.appendChild(opt);\r\n                });\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Iris] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 加载锐度\r\nfunction loadSharpness(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/sharpness').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var sp = r.data;\r\n            deviceImageParams.sharpness = sp;\r\n            \r\n            var slider = document.getElementById('consoleSharpness');\r\n            var range = document.getElementById('sharpnessRange');\r\n            \r\n            if (slider) {\r\n                slider.min = sp.min || 0;\r\n                slider.max = sp.max || 100;\r\n                slider.value = sp.current_level || 50;\r\n            }\r\n            if (range) {\r\n                range.textContent = '(' + (sp.min || 0) + '~' + (sp.max || 100) + ')';\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Sharpness] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 加载亮度/对比度/饱和度\r\nfunction loadColorParams(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/color').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var c = r.data;\r\n            deviceImageParams.color = c;\r\n            \r\n            var brightness = document.getElementById('consoleBrightness');\r\n            var contrast = document.getElementById('consoleContrast');\r\n            var saturation = document.getElementById('consoleSaturation');\r\n            \r\n            if (brightness && c.brightness !== undefined) brightness.value = c.brightness;\r\n            if (contrast && c.contrast !== undefined) contrast.value = c.contrast;\r\n            if (saturation && c.saturation !== undefined) saturation.value = c.saturation;\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Color] Load failed:', e);\r\n    });\r\n}\r\n\r\n// ==================== 设置函数 ====================\r\n\r\n// 设置锐度\r\nfunction setSharpness(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/sharpness', { level: parseInt(value) })\r\n        .then(function(r) { if (r && r.success && typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('锐度: ' + value, 'success'); });\r\n}\r\n\r\n// 设置白平衡模式\r\nfunction setWhiteBalanceMode(mode) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    \r\n    // v5.40: 处理三种模式\r\n    var actualMode = mode;\r\n    if (mode === 'auto_official') {\r\n        actualMode = 'auto';\r\n    } else if (mode === 'auto_astrohub') {\r\n        // 暂未实现\r\n        showToast('warning', '自动暂未实现');\r\n        return;\r\n    }\r\n    \r\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: actualMode })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '白平衡: ' + (actualMode === 'auto' ? '自动（官方）' : '手动'));\r\n                // v5.40: 更新 R/B 滑动条状态\r\n                var wbRed = document.getElementById('wbRed');\r\n                var wbBlue = document.getElementById('wbBlue');\r\n                if (wbRed) wbRed.disabled = actualMode !== 'manual';\r\n                if (wbBlue) wbBlue.disabled = actualMode !== 'manual';\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('白平衡: ' + (actualMode === 'auto' ? '自动' : '手动'), 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置白平衡增益 R/B\r\nfunction setWhiteBalanceGain(channel, value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    \r\n    // 更新显示\r\n    if (channel === 'red') {\r\n        var el = document.getElementById('wbRedVal');\r\n        if (el) el.textContent = value;\r\n    } else {\r\n        var el = document.getElementById('wbBlueVal');\r\n        if (el) el.textContent = value;\r\n    }\r\n    \r\n    var key = channel === 'red' ? 'red_gain' : 'blue_gain';\r\n    var label = channel === 'red' ? 'R (红增益)' : 'B (蓝增益)';\r\n    \r\n    // v6.56: 只发送增益值，不发送模式（模式已通过下拉菜单切换）\r\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { [key]: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', label + ': ' + value);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('白平衡' + label + ': ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置降噪\r\nfunction setNoiseReduce(type, value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    \r\n    var el = document.getElementById(type === 'spatial' ? 'dnrSpatialVal' : 'dnrTemporalVal');\r\n    if (el) el.textContent = value;\r\n    \r\n    var key = type === 'spatial' ? 'spatial_level' : 'temporal_level';\r\n    var label = type === 'spatial' ? '空域降噪' : '时域降噪';\r\n    \r\n    apiPost('/api/v1/ptz/' + dev + '/image/noisereduce', { [key]: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', label + ': ' + value);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog(label + ': ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 加载曝光模式\r\nfunction loadExposure(deviceIp) {\r\n    // v7.54: 从 function.json 加载曝光模式选项\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.exposure_mode) {\r\n        console.warn('[Exposure] No function.json data available');\r\n        return;\r\n    }\r\n    \r\n    var exposureValues = deviceFunctionData.functions.exposure_mode.opt_values;\r\n    if (!exposureValues || !Array.isArray(exposureValues) || exposureValues.length === 0) {\r\n        console.warn('[Exposure] exposure_mode not supported');\r\n        var select = document.getElementById('exposureMode');\r\n        if (select) {\r\n            select.innerHTML = '<option value=\"\">-- 不支持 --</option>';\r\n            select.disabled = true;\r\n        }\r\n        return;\r\n    }\r\n    \r\n    // 填充选项\r\n    var select = document.getElementById('exposureMode');\r\n    if (select) {\r\n        select.innerHTML = '';\r\n        select.disabled = false;\r\n        \r\n        exposureValues.forEach(function(p) {\r\n            var opt = document.createElement('option');\r\n            opt.value = p;\r\n            // 中文标签\r\n            var labelMap = {\r\n                'manual': '手动',\r\n                'auto': '自动',\r\n                'IrisFirst': '光圈优先',\r\n                'ShutterFirst': '快门优先'\r\n            };\r\n            opt.textContent = labelMap[p] || p;\r\n            select.appendChild(opt);\r\n        });\r\n    }\r\n    \r\n    // 获取当前值\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/exposure').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            if (select && r.data.mode) {\r\n                select.value = r.data.mode;\r\n                // 更新快门光圈禁用状态\r\n                updateShutterIrisState();\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Exposure] Load failed:', e);\r\n    });\r\n}\r\n\r\n// 设置曝光模式\r\nfunction setExposureMode(mode) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    // v7.54: 支持多种曝光模式的中文显示\r\n    var labelMap = {\r\n        'manual': '手动',\r\n        'auto': '自动',\r\n        'IrisFirst': '光圈优先',\r\n        'ShutterFirst': '快门优先'\r\n    };\r\n    apiPost('/api/v1/ptz/' + dev + '/image/exposure', { mode: mode })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '曝光模式: ' + (labelMap[mode] || mode));\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('曝光: ' + (labelMap[mode] || mode), 'success');\r\n            }\r\n        });\r\n    // v5.47: 更新快门光圈禁用状态\r\n    updateShutterIrisState();\r\n}\r\n\r\n// v5.47: 更新快门光圈禁用状态\r\nfunction updateShutterIrisState() {\r\n    // v7.30: 检查设备是否连接\r\n    if (!window.connectedDevice || !window.connectedDevice.ip) {\r\n        // 设备未连接，所有控件保持禁用\r\n        return;\r\n    }\r\n    \r\n    var exposureMode = document.getElementById('exposureMode');\r\n    var shutterSelect = document.getElementById('shutterSpeed');\r\n    var irisSelect = document.getElementById('irisLevel');\r\n    var gainSlider = document.getElementById('gainLevel');\r\n    if (!exposureMode || !shutterSelect || !irisSelect) return;\r\n    \r\n    // v7.54: 支持多种曝光模式\r\n    var mode = exposureMode.value;\r\n    var shutterEnabled = (mode === 'manual' || mode === 'ShutterFirst');\r\n    var irisEnabled = (mode === 'manual' || mode === 'IrisFirst');\r\n    var gainEnabled = (mode === 'manual' || mode === 'ShutterFirst' || mode === 'IrisFirst');\r\n    shutterSelect.disabled = !shutterEnabled;\r\n    irisSelect.disabled = !irisEnabled;\r\n    if (gainSlider) gainSlider.disabled = !gainEnabled;\r\n    \r\n    // 禁用时灰色样式\r\n    shutterSelect.style.opacity = shutterEnabled ? '1' : '0.5';\r\n    irisSelect.style.opacity = irisEnabled ? '1' : '0.5';\r\n    if (gainSlider) gainSlider.style.opacity = gainEnabled ? '1' : '0.5';\r\n}\r\n\r\n// 设置快门\r\nfunction setShutterSpeed(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/shutter', { level: value })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '快门: ' + value);\r\n\n[236 more lines in file. Use offset=1350 to continue.]"}],"isError":false,"timestamp":1783115642859}}
