{"type":"message","id":"d228fc28","parentId":"9fb35070","timestamp":"2026-07-04T22:43:26.637Z","message":{"role":"toolResult","toolCallId":"call_80c71916a4f145a3aa09fc2b","toolName":"read","content":[{"type":"text","text":"            const entry = document.createElement('div');\r\n            entry.style.cssText = 'color:' + color + ';margin:1px 0;padding:1px 6px;font-size:11px;font-family:monospace;line-height:1.3';\r\n            entry.textContent = '[' + time + '] ' + icon + ' ' + msg;\r\n            box.insertBefore(entry, box.firstChild);\r\n            if (box.children.length > 50) box.removeChild(box.lastChild);\r\n            console.log('[operationLog]', msg, type);\r\n\r\n            // v6.40: 发送操作日志到后端\r\n            if (typeof apiPost === 'function') {\r\n                try {\r\n                    apiPost('/api/v1/log/operation', {\r\n                        level: type.toUpperCase(),\r\n                        module: 'web',\r\n                        action: 'ptz',\r\n                        detail: msg\r\n                    }).catch(function(e) { console.warn('[LOG] send failed:', e); });\r\n                } catch(e) {}\r\n            }\r\n        }\r\n        window.operationLog = operationLog;\r\n\n[1476 more lines in file. Use offset=1626 to continue.]"}],"isError":false,"timestamp":1783205006637}}
