{"type":"message","id":"79be3ceb","parentId":"431a4d2b","timestamp":"2026-07-03T22:37:17.332Z","message":{"role":"assistant","content":[{"type":"text","text":"好的。让我顺便检查一下 index.html 中的 `setFocusMode` 和 `loadFocusMode` 函数，看看是否需要更新它们以处理新的 'local' 模式："},{"type":"toolCall","id":"call_9f7ba0e50d854f7c93aba60d","name":"read","arguments":{"limit":60,"offset":2228,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\index.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":73522,"output":85,"cacheRead":0,"cacheWrite":0,"totalTokens":73607,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783118233345,"responseId":"cht000d072d@dx19f2a21005a29bb503"}}
{"type":"message","id":"bfdcc656","parentId":"79be3ceb","timestamp":"2026-07-03T22:37:17.365Z","message":{"role":"toolResult","toolCallId":"call_9f7ba0e50d854f7c93aba60d","toolName":"read","content":[{"type":"text","text":"        function setFocusMode(mode) {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/focus/mode', { mode: mode }).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', '对焦模式: ' + mode);\r\n                    if (typeof operationLog === 'function') operationLog('对焦模式: ' + mode, 'success');\r\n                } else {\r\n                    showToast('error', result ? result.message : '设置失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '设置异常: ' + e.message);\r\n            });\r\n        }\r\n        function loadFocusMode() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiGet('/api/v1/ptz/' + dev + '/focus/mode').then(function(result) {\r\n                if (result && result.success && result.mode) {\r\n                    var select = document.getElementById('focusMode');\r\n                    if (select) {\r\n                        select.value = result.mode;\r\n                    }\r\n                }\r\n            }).catch(function(e) {\r\n                console.error('获取对焦模式失败:', e);\r\n            });\r\n        }\r\n        // ================================================================\r\n        //  v6.54: 连接状态控制函数\r\n        // ================================================================\r\n        window.setConnectionButtonsEnabled = function(enabled) {\r\n            // 禁用/启用连接相关按钮\r\n            var quickSwitch = document.getElementById('quickConnectSwitch');\r\n            if (quickSwitch) {\r\n                quickSwitch.disabled = !enabled;\r\n                quickSwitch.style.opacity = enabled ? '1' : '0.5';\r\n            }\r\n        };\r\n\r\n        window.disableAllControls = function(reason) {\r\n            // 禁用主控台控件\r\n            if (typeof disableImageControls === 'function') {\r\n                disableImageControls(reason);\r\n            }\r\n            // 禁用高级功能控件\r\n            var advButtons = ['btnConnectFuncRun', 'btnConnectSpeedRun', 'btnStartDetection'];\r\n            advButtons.forEach(function(id) {\r\n                var btn = document.getElementById(id);\r\n                if (btn) {\r\n                    btn.disabled = true;\r\n                    btn.style.opacity = '0.5';\r\n                }\r\n            });\r\n        };\r\n\r\n        window.enableAllControls = function() {\r\n            // 启用主控台控件\r\n            if (typeof enableImageControls === 'function') {\r\n                enableImageControls();\r\n\n[774 more lines in file. Use offset=2288 to continue.]"}],"isError":false,"timestamp":1783118237365}}
