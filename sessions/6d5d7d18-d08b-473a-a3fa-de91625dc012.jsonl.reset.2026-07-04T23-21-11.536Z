{"type":"message","id":"6d60e7ed","parentId":"b6af7dec","timestamp":"2026-07-03T22:34:54.767Z","message":{"role":"assistant","content":[{"type":"text","text":"现在我需要同时更新 `loadWhiteBalance` 和 `setWhiteBalanceMode` 函数，并添加新的 `onWbModeChange`、`onFocusModeChange`、`stopAutoWhiteBalance` 和 `stopAutoFocus` 函数。我还需要同步两个 PTZ OSD 开关（一个在左侧面板，一个正从右侧面板移除）。等等，我已经从右侧移除了 PTZ OSD 开关，但 `updatePtzOsdButtons` 仍然引用了 `ptzOsdSwitch`。我需要更新该函数，使其改为引用 `ptzOsdSwitchInPtz`。"},{"type":"toolCall","id":"call_65f3a3a008434d1fb0656e55","name":"edit","arguments":{"edits":[{"newText":"function updatePtzOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnPtzOsdOn');\n    var btnOff = document.getElementById('btnPtzOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n    // 同步运动控制区的 PTZ OSD 开关\n    var sw = document.getElementById('ptzOsdSwitchInPtz');\n    if (sw) sw.checked = enabled;\n}","oldText":"function updatePtzOsdButtons(enabled) {\n    var btnOn = document.getElementById('btnPtzOsdOn');\n    var btnOff = document.getElementById('btnPtzOsdOff');\n    if (btnOn && btnOff) {\n        if (enabled) {\n            btnOn.className = 'btn btn-sm btn-primary';\n            btnOff.className = 'btn btn-sm btn-secondary';\n        } else {\n            btnOn.className = 'btn btn-sm btn-secondary';\n            btnOff.className = 'btn btn-sm btn-primary';\n        }\n    }\n    // v6.14: 同步开关状态\n    var sw = document.getElementById('ptzOsdSwitch');\n    if (sw) sw.checked = enabled;\n}"},{"newText":"// 加载白平衡\nfunction loadWhiteBalance(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/whitebalance').then(function(r) {\n        if (r && r.success && r.data) {\n            var wb = r.data;\n            deviceImageParams.whiteBalance = wb;\n\n            var wbModeSelect = document.getElementById('wbMode');\n            if (wbModeSelect) {\n                // 根据设备返回的模式设置下拉菜单\n                if (wb.mode === 'manual') {\n                    wbModeSelect.value = 'manual';\n                } else {\n                    wbModeSelect.value = 'auto';\n                }\n                // 触发显示/隐藏逻辑\n                onWbModeChange(wbModeSelect.value);\n            }\n\n            // 更新 R/B 滑动条\n            var wbRed = document.getElementById('wbRed');\n            var wbBlue = document.getElementById('wbBlue');\n            var wbRedVal = document.getElementById('wbRedVal');\n            var wbBlueVal = document.getElementById('wbBlueVal');\n\n            if (wbRed && wb.red_gain !== undefined) {\n                wbRed.value = wb.red_gain;\n                if (wbRedVal) wbRedVal.textContent = wb.red_gain;\n            }\n            if (wbBlue && wb.blue_gain !== undefined) {\n                wbBlue.value = wb.blue_gain;\n                if (wbBlueVal) wbBlueVal.textContent = wb.blue_gain;\n            }\n\n            // 设置范围\n            if (wb.min !== undefined && wb.max !== undefined) {\n                if (wbRed) { wbRed.min = wb.min; wbRed.max = wb.max; }\n                if (wbBlue) { wbBlue.min = wb.min; wbBlue.max = wb.max; }\n            }\n\n            // 只有手动模式时 R/B 滑动条才可用\n            var isManual = wb.mode === 'manual';\n            if (wbRed) wbRed.disabled = !isManual;\n            if (wbBlue) wbBlue.disabled = !isManual;\n        }\n    }).catch(function(e) {\n        console.warn('[WB] Load failed:', e);\n    });\n}","oldText":"// 加载白平衡\nfunction loadWhiteBalance(deviceIp) {\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/whitebalance').then(function(r) {\n        if (r && r.success && r.data) {\n            var wb = r.data;\n            deviceImageParams.whiteBalance = wb;\n\n            // 更新模式下拉 - v5.40: 自动(官方)/自动(Astrohub)/手动\n            var wbModeSelect = document.getElementById('wbMode');\n            if (wbModeSelect) {\n                wbModeSelect.innerHTML = '';\n\n                // 选项1: 自动(官方)\n                var opt1 = document.createElement('option');\n                opt1.value = 'auto_official';\n                opt1.textContent = '自动(官方)';\n                if (wb.mode === 'auto') opt1.selected = true;\n                wbModeSelect.appendChild(opt1);\n\n                // 选项2: 自动\n                var opt2 = document.createElement('option');\n                opt2.value = 'auto_astrohub';\n                opt2.textContent = '自动';\n                wbModeSelect.appendChild(opt2);\n\n                // 选项3: 手动\n                var opt3 = document.createElement('option');\n                opt3.value = 'manual';\n                opt3.textContent = '手动';\n                if (wb.mode === 'manual') opt3.selected = true;\n                wbModeSelect.appendChild(opt3);\n            }\n\n            // 更新 R/B 滑动条\n            var wbRed = document.getElementById('wbRed');\n            var wbBlue = document.getElementById('wbBlue');\n            var wbRedVal = document.getElementById('wbRedVal');\n            var wbBlueVal = document.getElementById('wbBlueVal');\n\n            if (wbRed && wb.red_gain !== undefined) {\n                wbRed.value = wb.red_gain;\n                if (wbRedVal) wbRedVal.textContent = wb.red_gain;\n            }\n            if (wbBlue && wb.blue_gain !== undefined) {\n                wbBlue.value = wb.blue_gain;\n                if (wbBlueVal) wbBlueVal.textContent = wb.blue_gain;\n            }\n\n            // 设置范围\n            if (wb.min !== undefined && wb.max !== undefined) {\n                if (wbRed) { wbRed.min = wb.min; wbRed.max = wb.max; }\n                if (wbBlue) { wbBlue.min = wb.min; wbBlue.max = wb.max; }\n            }\n\n            // v5.40: 只有手动模式时 R/B 滑动条才可用\n            var isManual = wb.mode === 'manual';\n            if (wbRed) wbRed.disabled = !isManual;\n            if (wbBlue) wbBlue.disabled = !isManual;\n        }\n    }).catch(function(e) {\n        console.warn('[WB] Load failed:', e);\n    });\n}"},{"newText":"// 白平衡模式切换：显示/隐藏对应控件\nfunction onWbModeChange(mode) {\n    var manualControls = document.getElementById('wbManualControls');\n    var localControls = document.getElementById('wbLocalControls');\n    var wbRed = document.getElementById('wbRed');\n    var wbBlue = document.getElementById('wbBlue');\n\n    if (mode === 'manual') {\n        if (manualControls) manualControls.style.display = 'flex';\n        if (localControls) localControls.style.display = 'none';\n        if (wbRed) wbRed.disabled = false;\n        if (wbBlue) wbBlue.disabled = false;\n        setWhiteBalanceMode('manual');\n    } else if (mode === 'local') {\n        if (manualControls) manualControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'block';\n        if (wbRed) wbRed.disabled = true;\n        if (wbBlue) wbBlue.disabled = true;\n    } else {\n        // 自动\n        if (manualControls) manualControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'none';\n        if (wbRed) wbRed.disabled = true;\n        if (wbBlue) wbBlue.disabled = true;\n        setWhiteBalanceMode('auto');\n    }\n}\n\n// 停止自动白平衡\nfunction stopAutoWhiteBalance() {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    // 调用后端停止接口\n    apiPost('/api/v1/ptz/' + dev + '/whitebalance/stop', {}).then(function(r) {\n        if (r && r.success) {\n            showToast('success', '已停止自动白平衡');\n            if (typeof operationLog === 'function') operationLog('停止自动白平衡', 'success');\n        }\n    }).catch(function(e) {\n        showToast('error', '停止失败');\n    });\n    // 恢复按钮状态\n    var stopBtn = document.getElementById('btnWbLocalStop');\n    var selectBtn = document.getElementById('btnWbRegionSelect');\n    if (stopBtn) stopBtn.style.display = 'none';\n    if (selectBtn) { selectBtn.textContent = '框选'; selectBtn.classList.remove('btn-danger'); selectBtn.classList.add('btn-secondary'); }\n}\n\n// 对焦模式切换：显示/隐藏对应控件\nfunction onFocusModeChange(mode) {\n    var moveControls = document.getElementById('focusMoveControls');\n    var localControls = document.getElementById('focusLocalControls');\n\n    if (mode === 'manual') {\n        if (moveControls) moveControls.style.display = 'block';\n        if (localControls) localControls.style.display = 'none';\n        setFocusMode('manual');\n    } else if (mode === 'local') {\n        if (moveControls) moveControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'block';\n    } else {\n        // 自动\n        if (moveControls) moveControls.style.display = 'none';\n        if (localControls) localControls.style.display = 'none';\n        setFocusMode('auto');\n    }\n}\n\n// 停止自动对焦\nfunction stopAutoFocus() {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPost('/api/v1/ptz/' + dev + '/focus/stop', {}).then(function(r) {\n        if (r && r.success) {\n            showToast('success', '已停止自动对焦');\n            if (typeof operationLog === 'function') operationLog('停止自动对焦', 'success');\n        }\n    }).catch(function(e) {\n        showToast('error', '停止失败');\n    });\n    var stopBtn = document.getElementById('btnFocusLocalStop');\n    var selectBtn = document.getElementById('btnFocusRegionSelect');\n    if (stopBtn) stopBtn.style.display = 'none';\n    if (selectBtn) { selectBtn.textContent = '框选'; selectBtn.classList.remove('btn-danger'); selectBtn.classList.add('btn-secondary'); }\n}\n\n// 设置白平衡模式\nfunction setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: mode })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', '白平衡: ' + (mode === 'auto' ? '自动' : '手动'));\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('白平衡: ' + (mode === 'auto' ? '自动' : '手动'), 'success');\n            }\n        });\n}","oldText":"function setWhiteBalanceMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n\n    // v5.40: 处理三种模式\n    var actualMode = mode;\n    if (mode === 'auto_official') {\n        actualMode = 'auto';\n    } else if (mode === 'auto_astrohub') {\n        // 暂未实现\n        showToast('warning', '自动暂未实现');\n        return;\n    }\n\n    apiPost('/api/v1/ptz/' + dev + '/image/whitebalance', { mode: actualMode })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', '白平衡: ' + (actualMode === 'auto' ? '自动(官方)' : '手动'));\n                // v5.40: 更新 R/B 滑动条状态\n                var wbRed = document.getElementById('wbRed');\n                var wbBlue = document.getElementById('wbBlue');\n                if (wbRed) wbRed.disabled = actualMode !== 'manual';\n                if (wbBlue) wbBlue.disabled = actualMode !== 'manual';\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('白平衡: ' + (actualMode === 'auto' ? '自动' : '手动'), 'success');\n            }\n        });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":66604,"output":3149,"cacheRead":0,"cacheWrite":0,"totalTokens":69753,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783118061570,"responseId":"cht000dd5b4@dx19f2a1e622229bb503"}}
