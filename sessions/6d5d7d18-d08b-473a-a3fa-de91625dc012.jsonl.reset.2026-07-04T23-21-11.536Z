ve', {\r\n                direction: dir,\r\n                speed: speed\r\n            }).then(function(result) {\r\n                if (result && result.success) {\r\n                    addLog('info', '对焦: ' + mode);\r\n                } else {\r\n                    showToast('error', result ? result.message : '对焦失败');\r\n\n[848 more lines in file. Use offset=2225 to continue.]"}],"isError":false,"timestamp":1783196544606}}
