ocusTimer()\" disabled style=\"opacity:0.5\">❎</button>\n- 302                                                 <button id=\"btnFocusLocalStop\" class=\"btn btn-danger btn-sm\" onclick=\"stopAutoFocus()\" disabled style=\"opacity:0.5;min-width:72px\">⏹️</button>\n- 303                                             </div>\n+ 295                                         <div style=\"display:flex;justify-content:center;margin-bottom:4px\">\n+ 296                                             <button id=\"btnFocusRegionSelect\" class=\"btn btn-secondary btn-sm\" onclick=\"toggleRegionMode('focus')\">框选</button>\n  304                                         </div>\n+ 298                                         <div style=\"display:flex;align-items:center;gap:6px;width:100%\">\n+ 299                                             <span style=\"color:#8b949e;font-size:12px;white-space:nowrap\">定时</span>\n+ 300                                             <input type=\"text\" id=\"focusTimerInput\" value=\"0\" style=\"flex:1;padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:12px\" oninput=\"this.value=this.value.replace(/[^0-9]/g,'');updateFocusToggle()\">\n+ 301                                             <span style=\"color:#8b949e;font-size:12px;white-space:nowrap\">分钟</span>\n+ 302                                             <label class=\"switch\" style=\"flex-shrink:0\" title=\"打开应用定时\">\n+ 303                                                 <input type=\"checkbox\" id=\"focusTimerToggle\" onchange=\"toggleFocusTimer()\">\n+ 304                                                 <span class=\"slider\"></span>\n+ 305                                             </label>\n+ 306                                             <button id=\"btnFocusLocalStop\" class=\"btn btn-danger btn-sm\" onclick=\"stopAutoFocus()\" disabled style=\"opacity:0.5\">⏹️</button>\n+ 307                                         </div>\n+ 308                  