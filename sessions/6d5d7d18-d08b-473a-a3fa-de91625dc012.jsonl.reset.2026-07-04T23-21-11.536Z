{"type":"message","id":"5f4c7bef","parentId":"89550d63","timestamp":"2026-07-04T22:32:54.386Z","message":{"role":"toolResult","toolCallId":"call_e28818632b22469c8b64803b","toolName":"exec","content":[{"type":"text","text":"[32;1mPath                                                                     [0m[32;1m LineNumber[0m[32;1m Line[0m\r\n[32;1m----                                                                     [0m [32;1m----------[0m [32;1m----[0m\r\nC:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\ptz\\isapi\\ptz.py         90     def list_presets(self) -> lis��"}],"details":{"status":"completed","exitCode":0,"durationMs":391,"aggregated":"[32;1mPath                                                                     [0m[32;1m LineNumber[0m[32;1m Line[0m\r\n[32;1m----                                                                     [0m [32;1m----------[0m [32;1m----[0m\r\nC:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\ptz\\isapi\\ptz.py         90     def list_presets(self) -> lis��","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783204374386}}
