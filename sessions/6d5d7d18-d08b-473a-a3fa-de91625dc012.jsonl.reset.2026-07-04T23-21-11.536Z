{"type":"message","id":"d6324e40","parentId":"e215fd21","timestamp":"2026-07-04T17:38:34.870Z","message":{"role":"toolResult","toolCallId":"call_2ffb82031caa4502a98da4f4","toolName":"read","content":[{"type":"text","text":"                                            <input type=\"range\" id=\"wbBlue\" min=\"0\" max=\"255\" value=\"50\" style=\"width:100%\" oninput=\"document.getElementById('wbBlueVal').textContent=this.value\" onchange=\"setWhiteBalanceGain('blue', this.value)\" disabled>\r\n                                        </div>\r\n                                    </div>\r\n                                    <!-- 局部白平衡控制(仅局部模式显示) -->\r\n                                    <div id=\"wbLocalControls\" style=\"display:none;margin-bottom:4px\">\r\n                                        <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:4px\">\r\n                                            <button class=\"btn btn-secondary btn-sm\" id=\"btnWbRegionSelect\" onclick=\"toggleRegionMode('whitebalance')\">框选</button>\r\n                                            <div style=\"display:flex;align-items:center;gap:4px\">\r\n                                                <span style=\"color:#8b949e;font-size:11px\">定时:</span>\r\n                                                <input type=\"number\" id=\"wbTimerInput\" value=\"0\" min=\"0\" style=\"width:50px;padding:2px 4px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px\">\r\n                                                <span style=\"color:#8b949e;font-size:11px\">分钟</span>\r\n                                            </div>\r\n                                        </div>\r\n                                        <button class=\"btn btn-danger btn-sm\" id=\"btnWbLocalStop\" onclick=\"stopAutoWhiteBalance()\" style=\"display:none;width:100%\">停止</button>\r\n                                    </div>\r\n                            