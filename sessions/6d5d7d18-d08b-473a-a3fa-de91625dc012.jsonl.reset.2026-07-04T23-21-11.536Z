{"type":"message","id":"bace8306","parentId":"d1c89767","timestamp":"2026-07-03T21:54:17.135Z","message":{"role":"toolResult","toolCallId":"call_0d1695584cef40d2a173303c","toolName":"read","content":[{"type":"text","text":"                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('快门: ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// 设置光圈\r\nfunction setIris(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev || !value) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/iris', { level: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                var select = document.getElementById('irisLevel');\r\n                var label = select.options[select.selectedIndex].text;\r\n                showToast('success', '光圈: ' + label);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('光圈: ' + label, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// v7.03: 设置增益\r\nfunction setGain(value) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/gain', { level: parseInt(value) })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '增益: ' + value);\r\n                if (typeof operationLog === 'function' && !_isInitializingImageParams) operationLog('增益: ' + value, 'success');\r\n            }\r\n        });\r\n}\r\n\r\n// v7.03: 加载增益\r\nfunction loadGain(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/gain').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            var g = r.data;\r\n            deviceImageParams.gain = g;\r\n            \r\n            var slider = document.getElementById('gainLevel');\r\n            var valEl = document.getElementById('gainVal');\r\n            \r\n            if (slider) {\r\n                slider.min = 0;\r\n                slider.max = g.limit || 100;\r\n                slider.value = g.current_level || 0;\r\n            }\r\n            if (valEl) valEl.textContent = g.current_level || 0;\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[Gain] Load failed:', e);\r\n    });\r\n}\r\n\r\n// v6.02: PTZ OSD 开关\r\nfunction togglePtzOsdSwitch(enabled) {\r\n    ptzOsdEnabled = enabled;\r\n    togglePtzOsd(enabled);\r\n}\r\n\r\n// v6.02: Info OSD 开关\r\nfunction toggleInfoOsdSwitch(enabled) {\r\n    infoOsdEnabled = enabled;\r\n    toggleInfoOsd(enabled);\r\n}\r\n\r\n// 切换 PTZ OSD\r\nfunction togglePtzOsd(enabled) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    \r\n    updatePtzOsdButtons(enabled);\r\n    localStorage.setItem('osd_ptz_' + dev, enabled ? '1' : '0');\r\n    \r\n    apiPost('/api/v1/ptz/' + dev + '/osd/ptz', { enabled: enabled })\r\n        .then(function(r) {\r\n            if (r && r.success) showToast('success', 'PTZ OSD: ' + (enabled ? '显示' : '关闭'));\r\n        });\r\n}\r\n\r\n// 切换 Info OSD\r\nfunction toggleInfoOsd(enabled) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    \r\n    updateInfoOsdButtons(enabled);\r\n    localStorage.setItem('osd_info_' + dev, enabled ? '1' : '0');\r\n    \r\n    apiPost('/api/v1/ptz/' + dev + '/osd/info', { enabled: enabled })\r\n        .then(function(r) {\r\n            if (r && r.success) showToast('success', 'Info OSD: ' + (enabled ? '显示' : '关闭'));\r\n        });\r\n}\r\n\r\n// v5.42: 开关式 OSD 切换\r\nvar ptzOsdEnabled = false;\r\nvar infoOsdEnabled = false;\r\n\r\nfunction togglePtzOsdToggle() {\r\n    ptzOsdEnabled = !ptzOsdEnabled;\r\n    var btn = document.getElementById('btnPtzOsd');\r\n    if (btn) {\r\n        btn.textContent = ptzOsdEnabled ? '显示' : '关闭';\r\n        btn.className = 'btn btn-sm ' + (ptzOsdEnabled ? 'btn-primary' : 'btn-secondary');\r\n    }\r\n    togglePtzOsd(ptzOsdEnabled);\r\n}\r\n\r\nfunction toggleInfoOsdToggle() {\r\n    infoOsdEnabled = !infoOsdEnabled;\r\n    var btn = document.getElementById('btnInfoOsd');\r\n    if (btn) {\r\n        btn.textContent = infoOsdEnabled ? '显示' : '关闭';\r\n        btn.className = 'btn btn-sm ' + (infoOsdEnabled ? 'btn-primary' : 'btn-secondary');\r\n    }\r\n    toggleInfoOsd(infoOsdEnabled);\r\n}\r\n\r\n// 更新按钮状态\r\nfunction updatePtzOsdButtons(enabled) {\r\n    // v7.01: 更新 toggle switch\r\n    var switchEl = document.getElementById('ptzOsdSwitch');\r\n    if (switchEl) {\r\n        switchEl.checked = enabled;\r\n    }\r\n    ptzOsdEnabled = enabled;\r\n}\r\n\r\nfunction updateInfoOsdButtons(enabled) {\r\n    // v7.01: 更新 toggle switch\r\n    var switchEl = document.getElementById('infoOsdSwitch');\r\n    if (switchEl) {\r\n        switchEl.checked = enabled;\r\n    }\r\n    infoOsdEnabled = enabled;\r\n}\r\n\r\n// ==================== v7.0: PTZ 坐标 + 图像参数实时刷新 ====================\r\nvar _ptzImagePollInterval = null;\r\n\r\nfunction startPtzImagePoll() {\r\n    if (_ptzImagePollInterval) return; // 已在运行\r\n    \r\n    _ptzImagePollInterval = setInterval(function() {\r\n        if (!window.connectedDevice || !window.connectedDevice.ip) return;\r\n        \r\n        var dev = window.connectedDevice.ip;\r\n        \r\n        // 1. PTZ 坐标 - v7.55: 分别更新三个元素\r\n        apiGet('/api/v1/ptz/' + dev + '/position').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var panEl = document.getElementById('ptzPan');\r\n                var tiltEl = document.getElementById('ptzTilt');\r\n                var zoomEl = document.getElementById('ptzZoom');\r\n                if (panEl) panEl.textContent = r.data.pan || 0;\r\n                if (tiltEl) tiltEl.textContent = r.data.tilt || 0;\r\n                if (zoomEl) zoomEl.textContent = r.data.zoom || 0;\r\n            }\r\n        }).catch(function(e) {});\r\n        \r\n        // 2. 白平衡 R/B - v7.55: 只显示数值\r\n        apiGet('/api/v1/ptz/' + dev + '/image/whitebalance').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var wb = r.data;\r\n                var rEl = document.getElementById('ptzWbR');\r\n                var bEl = document.getElementById('ptzWbB');\r\n                if (rEl) rEl.textContent = wb.red_gain || '--';\r\n                if (bEl) bEl.textContent = wb.blue_gain || '--';\r\n            }\r\n        }).catch(function(e) {});\r\n        \r\n        // 3. 降噪空域/时域 - v7.55: 只显示数值\r\n        apiGet('/api/v1/ptz/' + dev + '/image/noisereduce').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var nr = r.data;\r\n                var sEl = document.getElementById('ptzDnrSpatial');\r\n                var tEl = document.getElementById('ptzDnrTemporal');\r\n                var spatialVal = (nr.spatial_level !== undefined && nr.spatial_level !== null) ? nr.spatial_level : '--';\r\n                var temporalVal = (nr.temporal_level !== undefined && nr.temporal_level !== null) ? nr.temporal_level : '--';\r\n                if (sEl) sEl.textContent = spatialVal;\r\n                if (tEl) tEl.textContent = temporalVal;\r\n            }\r\n        }).catch(function(e) {});\r\n        \r\n        // 4. 光圈 - v7.55: 只显示数值\r\n        apiGet('/api/v1/ptz/' + dev + '/image/iris').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var ir = r.data;\r\n                var iEl = document.getElementById('ptzIris');\r\n                if (iEl) iEl.textContent = ir.current_level || '--';\r\n            }\r\n        }).catch(function(e) {});\r\n        \r\n        // 5. 快门 - v7.55: 只显示数值\r\n        apiGet('/api/v1/ptz/' + dev + '/image/shutter').then(function(r) {\r\n            if (r && r.success && r.data) {\r\n                var sh = r.data;\r\n                var sEl = document.getElementById('ptzShutter');\r\n                if (sEl) sEl.textContent = sh.current_level || '--';\r\n            }\r\n        }).catch(function(e) {});\r\n    }, 1000);\r\n}\r\n\r\nfunction stopPtzImagePoll() {\r\n    if (_ptzImagePollInterval) {\r\n        clearInterval(_ptzImagePollInterval);\r\n        _ptzImagePollInterval = null;\r\n    }\r\n}\r\n\r\n// 暴露到全局\r\nwindow.startPtzImagePoll = startPtzImagePoll;\r\nwindow.stopPtzImagePoll = stopPtzImagePoll;\r\n\r\n// ==================== 暴露到全局 ====================\r\nwindow.toggleSection = toggleSection;\r\nwindow.loadDeviceImageParams = loadDeviceImageParams;\r\nwindow.setSharpness = setSharpness;\r\nwindow.setWhiteBalanceMode = setWhiteBalanceMode;\r\nwindow.setWhiteBalanceGain = setWhiteBalanceGain;\r\nwindow.setNoiseReduce = setNoiseReduce;\r\nwindow.setShutterSpeed = setShutterSpeed;\r\nwindow.setIris = setIris;\r\nwindow.setExposureMode = setExposureMode;\r\nwindow.togglePtzOsd = togglePtzOsd;\r\nwindow.toggleInfoOsd = toggleInfoOsd;\r\nwindow.updatePtzOsdButtons = updatePtzOsdButtons;\r\nwindow.updateInfoOsdButtons = updateInfoOsdButtons;\r\n// v7.32: 新增功能检测相关函数\r\nwindow.goToFunctionTest = goToFunctionTest;\r\nwindow.showFunctionOverlay = showFunctionOverlay;\r\nwindow.removeFunctionOverlay = removeFunctionOverlay;\r\n</script>\r\n"}],"isError":false,"timestamp":1783115657135}}
