{"type":"message","id":"0cf0c563","parentId":"4e46425e","timestamp":"2026-07-04T17:49:09.798Z","message":{"role":"toolResult","toolCallId":"call_f4f2d32becf145698a7e77ef","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 1 block(s) in C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html."}],"details":{"diff":"      ...\n  547 \n  548 // v7.59: 初始化加载标志位(防止初始化时触发操作日志)\n  549 var _isInitializingImageParams = false;\n  550 \n+ 551 // v8.40: 定时器状态\n+ 552 var wbTimerId = null;\n+ 553 var wbTimerSeconds = 0;\n+ 554 var focusTimerId = null;\n+ 555 var focusTimerSeconds = 0;\n+ 556 \n  551 // v6.20 + v7.0: 禁用所有控制区域(PTZ + 媒体 + 跟踪 + 画面)\n  552 function disableImageControls(reason) {\n  553     // v7.30: 模块级别禁用灰色样式\n  554     var sections = ['ptzControlSection', 'trackControlSection', 'mediaControlSection', 'imageControlSection', 'logControlSection'];\n      ...","firstChangedLine":551},"isError":false,"timestamp":1783187349798}}
{"type":"message","id":"652f7185","parentId":"0cf0c563","timestamp":"2026-07-04T17:50:25.299Z","message":{"role":"assistant","content":[{"type":"text","text":"现在添加定时器函数。在 `stopAutoFocus` 函数后面添加："},{"type":"toolCall","id":"call_b2cdc211ec3c4652af5ca839","name":"edit","arguments":{"edits":[{"newText":"    if (selectBtn) { selectBtn.textContent = '框选'; selectBtn.classList.remove('btn-danger'); selectBtn.classList.add('btn-secondary'); }\n}\n\n// v8.40: 白平衡定时器\nfunction confirmWbTimer() {\n    var input = document.getElementById('wbTimerInput');\n    if (!input) return;\n    var minutes = parseInt(input.value) || 0;\n    if (minutes <= 0) {\n        stopWbTimer();\n        showToast('warning', '请输入大于0的分钟数');\n        return;\n    }\n    var region = localStorage.getItem('region_whitebalance');\n    if (!region) {\n        showToast('warning', '请先框选区域');\n        return;\n    }\n    stopWbTimer();\n    wbTimerSeconds = minutes * 60;\n    updateWbTimerDisplay();\n    wbTimerId = setInterval(function() {\n        wbTimerSeconds--;\n        updateWbTimerDisplay();\n        if (wbTimerSeconds <= 0) {\n            clearInterval(wbTimerId);\n            wbTimerId = null;\n            executeScheduledSearch('whitebalance');\n        }\n    }, 1000);\n    showToast('success', '白平衡定时已启动: ' + minutes + '分钟');\n}\n\nfunction stopWbTimer() {\n    if (wbTimerId) { clearInterval(wbTimerId); wbTimerId = null; }\n    wbTimerSeconds = 0;\n    var display = document.getElementById('wbTimerDisplay');\n    if (display) display.textContent = '';\n}\n\nfunction updateWbTimerDisplay() {\n    var display = document.getElementById('wbTimerDisplay');\n    if (!display) return;\n    if (wbTimerSeconds <= 0) { display.textContent = ''; return; }\n    var m = Math.floor(wbTimerSeconds / 60);\n    var s = wbTimerSeconds % 60;\n    display.textContent = '(' + m + ':' + (s < 10 ? '0' : '') + s + ')';\n}\n\n// v8.40: 对焦定时器\nfunction confirmFocusTimer() {\n    var input = document.getElementById('focusTimerInput');\n    if (!input) return;\n    var minutes = parseInt(input.value) || 0;\n    if (minutes <= 0) {\n        stopFocusTimer();\n        showToast('warning', '请输入大于0的分钟数');\n        return;\n    }\n    var region = localStorage.getItem('region_focus');\n    if (!region) {\n        showToast('warning', '请先框选区域');\n        return;\n    }\n    stopFocusTimer();\n    focusTimerSeconds = minutes * 60;\n    updateFocusTimerDisplay();\n    focusTimerId = setInterval(function() {\n        focusTimerSeconds--;\n        updateFocusTimerDisplay();\n        if (focusTimerSeconds <= 0) {\n            clearInterval(focusTimerId);\n            focusTimerId = null;\n            executeScheduledSearch('focus');\n        }\n    }, 1000);\n    showToast('success', '对焦定时已启动: ' + minutes + '分钟');\n}\n\nfunction stopFocusTimer() {\n    if (focusTimerId) { clearInterval(focusTimerId); focusTimerId = null; }\n    focusTimerSeconds = 0;\n    var display = document.getElementById('focusTimerDisplay');\n    if (display) display.textContent = '';\n}\n\nfunction updateFocusTimerDisplay() {\n    var display = document.getElementById('focusTimerDisplay');\n    if (!display) return;\n    if (focusTimerSeconds <= 0) { display.textContent = ''; return; }\n    var m = Math.floor(focusTimerSeconds / 60);\n    var s = focusTimerSeconds % 60;\n    display.textContent = '(' + m + ':' + (s < 10 ? '0' : '') + s + ')';\n}\n\n// v8.40: 定时触发执行（使用保存的选区）\nfunction executeScheduledSearch(mode) {\n    var regionStr = localStorage.getItem('region_' + mode);\n    if (!regionStr) {\n        showToast('warning', (mode === 'whitebalance' ? '白平衡' : '对焦') + '无保存选区');\n        return;\n    }\n    var dev = window.connectedDevice;\n    if (!dev || !dev.ip) { showToast('error', '未连接设备'); return; }\n    var region = JSON.parse(regionStr);\n    var endpoint = mode === 'whitebalance' ? '/api/v1/vision/whitebalance-search' : '/api/v1/vision/focus-search';\n    var label = mode === 'whitebalance' ? '白平衡' : '对焦';\n    showToast('info', label + '定时执行中...');\n    operationLog('── ' + label + '定时执行 ──', 'info');\n    var body = JSON.stringify({ x: region.x, y: region.y, w: region.w, h: region.h });\n    fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })\n        .then(function(resp) {\n            if (!resp.ok) throw new Error('HTTP ' + resp.status);\n            var reader = resp.body.getReader();\n            var decoder = new TextDecoder();\n            var buf = '';\n            function pump() {\n                return reader.read().then(function(r) {\n                    if (r.done) return;\n                    buf += decoder.decode(r.value, { stream: true });\n                    var parts = buf.split('\\n\\n');\n                    buf = parts.pop();\n                    for (var i = 0; i < parts.length; i++) {\n                        var line = parts[i];\n                        if (!line.startsWith('data: ')) continue;\n                        try {\n                            var ev = JSON.parse(line.slice(6));\n                            if (ev.type === 'wb' || ev.type === 'focus') {\n                                operationLog('调整 #' + ev.step + ': ' + ev.stage + ' R=' + ev.red_gain + ' B=' + ev.blue_gain + ' Δ=' + ev.delta, 'info');\n                            } else if (ev.type === 'done') {\n                                operationLog('── ' + label + '完成: R=' + ev.final_red + ' B=' + ev.final_blue + ' (' + ev.total_steps + '步) ──', 'success');\n                            } else if (ev.type === 'error') {\n                                operationLog(label + '错误: ' + ev.message, 'error');\n                            }\n                        } catch (e) {}\n                    }\n                    return pump();\n                });\n            }\n            return pump();\n        })\n        .then(function() {\n            // 执行完成后，重新启动定时器\n            if (mode === 'whitebalance' && wbTimerId === null) {\n                var minutes = parseInt(document.getElementById('wbTimerInput').value) || 0;\n                if (minutes > 0) {\n                    wbTimerSeconds = minutes * 60;\n                    updateWbTimerDisplay();\n                    wbTimerId = setInterval(function() {\n                        wbTimerSeconds--;\n                        updateWbTimerDisplay();\n                        if (wbTimerSeconds <= 0) {\n                            clearInterval(wbTimerId);\n                            wbTimerId = null;\n                            executeScheduledSearch('whitebalance');\n                        }\n                    }, 1000);\n                }\n            }\n            if (mode === 'focus' && focusTimerId === null) {\n                var minutes = parseInt(document.getElementById('focusTimerInput').value) || 0;\n                if (minutes > 0) {\n                    focusTimerSeconds = minutes * 60;\n                    updateFocusTimerDisplay();\n                    focusTimerId = setInterval(function() {\n                        focusTimerSeconds--;\n                        updateFocusTimerDisplay();\n                        if (focusTimerSeconds <= 0) {\n                            clearInterval(focusTimerId);\n                            focusTimerId = null;\n                            executeScheduledSearch('focus');\n                        }\n                    }, 1000);\n                }\n            }\n        })\n        .catch(function(e) {\n            showToast('error', label + '定时执行失败: ' + e.message);\n        });\n}","oldText":"    if (selectBtn) { selectBtn.textContent = '框选'; selectBtn.classList.remove('btn-danger'); selectBtn.classList.add('btn-secondary'); }\n}\n\n// 设置白平衡模式"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"glm-5.2","usage":{"input":71996,"output":1990,"cacheRead":0,"cacheWrite":0,"totalTokens":739