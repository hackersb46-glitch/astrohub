{"type":"message","id":"f7f481e9","parentId":"749efd53","timestamp":"2026-07-04T21:05:31.502Z","message":{"role":"toolResult","toolCallId":"call_1d9812e0b0c24e09911b96e5","toolName":"read","content":[{"type":"text","text":"                                <!-- 指向控制 + 信息展示 -->\r\n                                <div style=\"display:flex;gap:8px;align-items:stretch\">\r\n                                    <!-- 左侧:方向控制 + 速度 -->\r\n                                    <div style=\"flex:0 0 auto;display:flex;flex-direction:column;justify-content:space-between\">\r\n                                        <div class=\"ptz-controls\">\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\r\n                                            <button class=\"ptz-btn\" onclick=\"ptzHome()\" title=\"归位\">🏠</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\r\n                 