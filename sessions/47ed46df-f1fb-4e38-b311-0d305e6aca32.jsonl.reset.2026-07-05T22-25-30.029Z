{"type":"message","id":"41e5956e","parentId":"223e4d0d","timestamp":"2026-07-05T19:24:34.045Z","message":{"role":"toolResult","toolCallId":"call_4f362e9af1cf4f40b76e8f8b","toolName":"read","content":[{"type":"text","text":"            }\r\n        });\r\n}\r\n\r\n// v8.44: 慢快门\r\nfunction loadSlowShutter(deviceIp) {\r\n    var sel = document.getElementById('slowShutterSelect');\r\n    if (!sel) return;\r\n    \r\n    // v8.45: 从function.json读取DSS支持倍率\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.slow_shutter) {\r\n        sel.disabled = true;\r\n        sel.innerHTML = '<option value=\"\">设备不支持</option>';\r\n        return;\r\n    }\r\n    \r\n    var dss = deviceFunctionData.functions.slow_shutter;\r\n    if (!dss.supported) {\r\n        sel.disabled = true;\r\n        sel.innerHTML = '<option value=\"\">设备不支持</option>';\r\n        return;\r\n    }\r\n    \r\n    sel.disabled = false;\r\n    sel.innerHTML = '';\r\n    \r\n    // 添加\"关闭\"选项\r\n    var offOpt = document.createElement('option');\r\n    offOpt.value = 'off';\r\n    offOpt.textContent = '关闭';\r\n    sel.appendChild(offOpt);\r\n    \r\n    // 从opt_values添加倍率选项\r\n    if (dss.opt_values && Array.isArray(dss.opt_values)) {\r\n        dss.opt_values.forEach(function(level) {\r\n            var opt = document.createElement('option');\r\n            opt.value = level;\r\n            opt.textContent = level;\r\n            sel.appendChild(opt);\r\n        });\r\n    }\r\n    \r\n    // 获取当前DSS状态并设置选中项\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/slow-shutter').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            if (r.data.enabled && r.data.dss_level) {\r\n                sel.value = r.data.dss_level;\r\n            } else {\r\n                sel.value = 'off';\r\n            }\r\n        }\r\n    });\r\n}\r\n\r\nfunction setSlowShutter(val) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPut('/api/v1/ptz/' + dev + '/image/slow-shutter', { dss_level: val }).then(function(r) {\r\n        if (r && r.success) {\r\n            showToast('success', r.message);\r\n            if (typeof operationLog === 'function') operationLog('慢快门: ' + r.message, 'success');\r\n        }\r\n    });\r\n}\r\n// v8.43: 三段式开关 - 更新高亮\r\nfunction updateSwitchHighlight(switchId, selectedValue) {\r\n    var switchEl = document.getElementById(switchId);\r\n    if (!switchEl) return;\r\n    var buttons = switchEl.querySelectorAll('.ts-btn');\r\n    buttons.forEach(function(btn) {\r\n        if (btn.dataset.value === selectedValue) {\r\n            btn.classList.add('active');\r\n        } else {\r\n            btn.classList.remove('active');\r\n        }\r\n    });\r\n}\r\n\r\n// v8.43: 设置日夜模式\r\nfunction setDayNightMode(mode) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/filter', { dayNightMode: mode })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', '日夜模式: ' + mode);\r\n                if (typeof operationLog === 'function') operationLog('日夜模式: ' + mode, 'success');\r\n                updateSwitchHighlight('dayNightSwitch', mode);\r\n            }\r\n        });\r\n}\r\n\r\n// v8.43: 设置IR滤镜\r\nfunction setIRCutFilter(filter) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPost('/api/v1/ptz/' + dev + '/image/filter', { irCutFilter: filter })\r\n        .then(function(r) {\r\n            if (r && r.success) {\r\n                showToast('success', 'IR滤镜: ' + filter);\r\n                if (typeof operationLog === 'function') operationLog('IR滤镜: ' + filter, 'success');\r\n                updateSwitchHighlight('irCutSwitch', filter);\r\n            }\r\n        });\r\n}\r\n\r\n// v8.43: 加载滤镜状态\r\nfunction loadFilterStatus(deviceIp) {\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/filter').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            updateSwitchHighlight('dayNightSwitch', r.data.dayNightMode);\r\n            updateSwitchHighlight('irCutSwitch', r.data.irCutFilter);\r\n        }\r\n    });\r\n}\r\n\r\n// 加载曝光模式\r\nfunction loadExposure(deviceIp) {\r\n    // v7.54: 从 function.json 加载曝光模式选项\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.exposure_mode) {\r\n\n[364 more lines in file. Use offset=1720 to continue.]"}],"isError":false,"timestamp":1783279474045}}
