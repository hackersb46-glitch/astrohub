{"type":"message","id":"b442900a","parentId":"72992bde","timestamp":"2026-07-05T22:02:53.016Z","message":{"role":"toolResult","toolCallId":"functions.read:205","toolName":"read","content":[{"type":"text","text":"}\r\n\r\n// v8.44: 慢快门\r\nfunction loadSlowShutter(deviceIp) {\r\n    var sel = document.getElementById('slowShutterSelect');\r\n    if (!sel) return;\r\n    \r\n    // v8.45: 从function.json读取DSS支持倍率\r\n    if (!deviceFunctionData || !deviceFunctionData.functions || !deviceFunctionData.functions.slow_shutter) {\r\n        sel.disabled = true;\r\n        sel.innerHTML = '<option value=\"\">设备不支持</option>';\r\n        return;\r\n    }\r\n    \r\n    var dss = deviceFunctionData.functions.slow_shutter;\r\n    if (!dss.supported) {\r\n        sel.disabled = true;\r\n        sel.innerHTML = '<option value=\"\">设备不支持</option>';\r\n        return;\r\n    }\r\n    \r\n    sel.disabled = false;\r\n    sel.innerHTML = '';\r\n    \r\n    // 添加\"关闭\"选项\r\n    var offOpt = document.createElement('option');\r\n    offOpt.value = 'off';\r\n    offOpt.textContent = '关闭';\r\n    sel.appendChild(offOpt);\r\n    \r\n    // 从opt_values添加倍率选项\r\n    if (dss.opt_values && Array.isArray(dss.opt_values)) {\r\n        dss.opt_values.forEach(function(level) {\r\n            var opt = document.createElement('option');\r\n            opt.value = level;\r\n            opt.textContent = level;\r\n            sel.appendChild(opt);\r\n        });\r\n    }\r\n    \r\n    // 获取当前DSS状态并设置选中项\r\n    apiGet('/api/v1/ptz/' + deviceIp + '/image/slow-shutter').then(function(r) {\r\n        if (r && r.success && r.data) {\r\n            if (r.data.enabled && r.data.dss_level) {\r\n                sel.value = r.data.dss_level;\r\n            } else {\r\n                sel.value = 'off';\r\n            }\r\n        }\r\n    });\r\n}\r\n\r\nfunction setSlowShutter(val) {\r\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n    if (!dev) return;\r\n    apiPut('/api/v1/ptz/' + dev + '/image/slow-shutter', { dss_level: val }).then(function(r) {\r\n        if (r && r.success) {\r\n            showToast('success', r.message);\r\n            if (typeof operationLog === 'function') operationLog('慢快门: ' + r.message, 'success');\r\n            if (typeof mediaLog === 'function') mediaLog('慢快门设置: ' + r.message, 'success');\r\n\n[446 more lines in file. Use offset=1690 to continue.]"}],"isError":false,"timestamp":1783288973016}}
