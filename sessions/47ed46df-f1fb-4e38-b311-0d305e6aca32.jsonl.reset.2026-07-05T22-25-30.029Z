{"type":"message","id":"da155c0b","parentId":"fb5fff65","timestamp":"2026-07-05T20:40:11.288Z","message":{"role":"toolResult","toolCallId":"toolu_5a27bca91e6a4f0982e2b4db","toolName":"read","content":[{"type":"text","text":"                apiPost('/api/v1/devices/' + ip + '/connect', { username: username, password: password, port: port }).then(function(result) {\r\n                    if (result && result.success) {\r\n                        showToast('success', '设备已连接: ' + ip);\r\n                        addLog('success', result.message || '连接成功');\r\n                        // Set connectedDevice BEFORE refreshDevices\r\n                        var dev = allDevices.find(function(d) { return d.ip === ip; }) || { ip: ip };\r\n                        window.connectedDevice = {\r\n                            ip: dev.ip, model: dev.model || '', name: dev.name || '', device_name: dev.device_name || '',\r\n                            mac: dev.mac || '', username: username, password: password, port: port, online: true\r\n                        };\r\n                        // Update button immediately\r\n                        if (window.updateDeviceStatus) window.updateDeviceStatus();\r\n                        // v7.31: 连接成功后立即启用所有控件\r\n                        if (window.enableAllControls) window.enableAllControls();\r\n                        // WASM SDK: 同步登录设备\r\n                        if (typeof onDeviceConnected === 'function') onDeviceConnected();\r\n                        // 动态加载设备图像参数(白平衡、快门、光圈、降噪、锐度、OSD)\r\n                        // v5.42: 增加延迟确保设备连接完成\r\n                        setTimeout(function() {\r\n                            console.log('[CONNECT] Calling loadDeviceImageParams for:', ip);\r\n                            if (typeof loadDeviceImageParams === 'function') {\r\n                                loadDeviceImageParams(ip);\r\n                                console.log('[CONNECT] loadDeviceImageParams called');\r\n                            } else {\r\n                                console.error('[CONNECT] loadDeviceImageParams not found');\r\n                            }\r\n                            // 加载对焦模式\r\n                            if (typeof loadFocusMode === 'function') {\r\n                                loadFocusMode();\r\n                            }\r\n                        }, 500);\r\n                        // v6.54: 等待视频播放后启用按钮\r\n                        setTimeout(function() {\r\n                            _connectionOperationInProgress = false;\r\n                            if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n                        }, 3000);\r\n                    } else if (result && result.message && result.message.indexOf('凭证') >= 0) {\r\n                        // credentials 错误,提示用户输入\r\n                        _connectionOperationInProgress = false;\r\n                        if (window.setConnectionButtonsEnabled) window.setConnectionButtonsEnabled(true);\r\n\n[1718 more lines in file. Use offset=1390 to continue.]"}],"isError":false,"timestamp":1783284011288}}
