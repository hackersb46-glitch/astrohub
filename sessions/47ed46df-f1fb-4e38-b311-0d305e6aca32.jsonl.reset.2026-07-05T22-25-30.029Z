{"type":"message","id":"b0715eab","parentId":"e5d665dc","timestamp":"2026-07-05T19:24:16.209Z","message":{"role":"toolResult","toolCallId":"call_1db16fbd2f4b42c68036095d","toolName":"read","content":[{"type":"text","text":"        <div class=\"page\" id=\"page-console\">\r\n            <div id=\"consoleWarning\" style=\"display:none;position:fixed;top:50%;left:50%;transform:translate(-50%, -50%);background:#4a3a1a;border:2px solid #d29922;border-radius:12px;padding:32px 48px;color:#d29922;font-size:16px;z-index:10000;text-align:center;width:300px\">\r\n                <strong style=\"font-size:20px\">⚠️ 请连接设备</strong><br><br>\r\n                <span style=\"color:#8b949e;font-size:14px\">在设备管理页面连接设备</span>\r\n            </div>\r\n            <div id=\"ptzControlArea\">\r\n                <!-- 左右布局: 左控制, 中间画面+媒体, 右日志+画面控制 -->\r\n                <div class=\"console-layout\">\r\n                    <!-- 左: PTZ控制(整合:指向+预置点+变焦/对焦) -->\r\n                    <div class=\"console-left\">\r\n                        <!-- PTZ控制(折叠) -->\r\n                        <div class=\"collapsible-section\" id=\"ptzControlSection\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('ptzControlSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">🎯 运动控制</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <!-- 指向控制 + 信息展示 -->\r\n                                <div style=\"display:flex;gap:8px;align-items:stretch\">\r\n                                    <!-- 左侧:方向控制 + 速度 -->\r\n                                    <div style=\"flex:0 0 auto;display:flex;flex-direction:column;justify-content:space-between\">\r\n                                        <div class=\"ptz-controls\">\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-left')\" ontouchstart=\"ptzMove('up-left')\">↖</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up')\" ontouchstart=\"ptzMove('up')\">↑</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('up-right')\" ontouchstart=\"ptzMove('up-right')\">↗</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('left')\" ontouchstart=\"ptzMove('left')\">←</button>\r\n                                            <button class=\"ptz-btn\" onclick=\"ptzHome()\" title=\"归位\">🏠</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('right')\" ontouchstart=\"ptzMove('right')\">→</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-left')\" ontouchstart=\"ptzMove('down-left')\">↙</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down')\" ontouchstart=\"ptzMove('down')\">↓</button>\r\n                                            <button class=\"ptz-btn\" onmousedown=\"ptzMove('down-right')\" ontouchstart=\"ptzMove('down-right')\">↘</button>\r\n                                        </div>\r\n                                        <div class=\"ptz-speed\" style=\"width:170px;font-size:11px;margin-top:8px\">\r\n                                            <label style=\"font-size:11px\">速度:</label>\r\n                                            <input type=\"range\" id=\"ptzSpeed\" min=\"1\" max=\"7\" value=\"4\" style=\"width:90px\">\r\n                                            <span id=\"ptzSpeedVal\" style=\"font-size:11px\">4</span>\r\n                                        </div>\r\n                                        <div style=\"width:154px;display:flex;gap:4px;margin-left:auto;margin-right:auto;margin-top:4px\">\r\n                                            <button class=\"ptz-btn\" style=\"flex:1;width:auto;height:24px;padding:1px;font-size:11px;line-height:1.2\" onmousedown=\"ptzZoom('out')\" ontouchstart=\"ptzZoom('out')\" onmouseup=\"ptzStop()\" onmouseleave=\"ptzStop()\" title=\"变焦-\">变焦-</button>\r\n                                            <button class=\"ptz-btn\" style=\"flex:1;width:auto;height:24px;padding:1px;font-size:11px;line-height:1.2\" onmousedown=\"ptzZoom('in')\" ontouchstart=\"ptzZoom('in')\" onmouseup=\"ptzStop()\" onmouseleave=\"ptzStop()\" title=\"变焦+\">变焦+</button>\r\n                                        </div>\r\n                                    </div>\r\n                                    <!-- 右侧:光圈快门 + P/T/Z(竖排,宽度减少15%) -->\r\n                                    <div style=\"flex:0 0 110px;display:flex;flex-direction:column;gap:0\">\r\n                                        <div class=\"info-block\" style=\"flex:1\">\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">光圈</span><span class=\"info-value\" id=\"ptzIris\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">快门</span><span class=\"info-value\" id=\"ptzShutter\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">R</span><span class=\"info-value\" id=\"ptzWbR\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">B</span><span class=\"info-value\" id=\"ptzWbB\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">空域</span><span class=\"info-value\" id=\"ptzDnrSpatial\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"padding:1px 4px;font-size:12px\"><span class=\"info-label\">时域</span><span class=\"info-value\" id=\"ptzDnrTemporal\">--</span></div>\r\n                                        </div>\r\n                                        <div style=\"border-top:2px solid #30363d;margin-top:2px;padding-top:2px\"></div>\r\n                                        <div class=\"info-block\" style=\"flex:1\">\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">Pan</span><span class=\"info-value\" id=\"ptzPan\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"border-bottom:1px solid #30363d;padding:1px 4px;font-size:12px\"><span class=\"info-label\">Tilt</span><span class=\"info-value\" id=\"ptzTilt\">--</span></div>\r\n                                            <div class=\"info-row\" style=\"padding:1px 4px;font-size:12px\"><span class=\"info-label\">Zoom</span><span class=\"info-value\" id=\"ptzZoom\">--</span></div>\r\n                                        </div>\r\n                                    </div>\r\n                                </div>\r\n                                <!-- 码流控制 -->\r\n                                <div class=\"section-subtitle\">码流</div>\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamMain\" onclick=\"switchAndPlay(1)\" title=\"主码流\">主</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamSub\" onclick=\"switchAndPlay(2)\" title=\"子码流\">子</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamThird\" onclick=\"switchAndPlay(3)\" title=\"第三码流\">三</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" id=\"btnStreamStop\" onclick=\"doStopPreview()\" title=\"停止预览\">⏹</button>\r\n                                </div>\r\n                                <!-- 预置点 -->\r\n                                <div class=\"section-subtitle\">预置点</div>\r\n                                <div style=\"display:flex;gap:4px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <select id=\"ptzPresetSelect\" style=\"padding:6px 8px;background:#0d1117;border:1px solid #30363d;border-radius:6px;color:#e0e6f0;font-size:13px;min-width:100px\">\r\n                                        <option value=\"\">选择预置点</option>\r\n                                    </select>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzGotoSelectedPreset()\">前往</button>\r\n                                    <button class=\"btn btn-primary btn-sm\" onclick=\"ptzWritePreset()\">写入</button>\r\n                                </div>\r\n                                <!-- 信息显示开关 -->\r\n                                <div class=\"section-subtitle\">信息显示</div>\r\n                                <div style=\"display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:8px\">\r\n                                    <div style=\"display:flex;align-items:center;gap:6px\">\r\n                                        <span style=\"color:#8b949e;font-size:11px\">OSD</span>\r\n                                        <label class=\"toggle-switch\">\r\n                                            <input type=\"checkbox\" id=\"infoOsdSwitch\" onchange=\"toggleInfoOsdSwitch(this.checked)\">\r\n                                            <span class=\"toggle-slider\"></span>\r\n                                        </label>\r\n                                    </div>\r\n                                    <div style=\"display:flex;align-items:center;gap:6px\">\r\n                                        <span style=\"color:#8b949e;font-size:11px\">PTZ</span>\r\n                                        <label class=\"toggle-switch\">\r\n                                            <input type=\"checkbox\" id=\"ptzOsdSwitch\" checked onchange=\"togglePtzOsdSwitch(this.checked)\">\r\n                                            <span class=\"toggle-slider\"></span>\r\n                                        </label>\r\n                                    </div>\r\n                                </div>\r\n                                <!-- v8.44: 慢快门 -->\r\n                                <div class=\"section-subtitle\">慢快门</div>\r\n                                <div style=\"display:flex;gap:6px;justify-content:center;align-items:center;margin-bottom:8px\">\r\n                                    <select id=\"slowShutterSelect\" style=\"padding:4px 8px;background:#0d1117;border:1px solid #30363d;border-radius:4px;color:#e0e6f0;font-size:11px;min-width:100px\" onchange=\"setSlowShutter(this.value)\">\r\n                                        <option value=\"0\">关闭</option>\r\n                                    </select>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 媒体信息(折叠,默认展开) -->\r\n                        <div class=\"collapsible-section\" id=\"mediaLogSection\" style=\"margin-top:12px\">\r\n                            <div class=\"collapsible-header\" onclick=\"toggleSection('mediaLogSection')\">\r\n                                <h3 style=\"font-size:15px;color:#58a6ff;margin:0\">📡 媒体信息</h3>\r\n                                <span class=\"collapse-icon\">▼</span>\r\n                            </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;padding:8px;overflow-y:auto;height:200px\" class=\"hide-scrollbar\">\r\n                                    <div id=\"mediaLogBox\" style=\"font-size:11px;font-family:monospace;color:#8b949e\">\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <!-- 中: 实时画面 + 媒体操作 -->\r\n                    <div class=\"console-center\">\r\n                        <div class=\"console-video-wrap\" style=\"background:#0d1117;border:1px solid #30363d;border-radius:8px;margin-bottom:12px;overflow:hidden;position:relative;width:100%;\">\r\n                            <!-- v7.98: WASM 播放器占位区域,保留16:9比例 -->\r\n                            <div id=\"divPlugin\" style=\"width:100%;aspect-ratio:16/9;display:block;margin:0 auto\"></div>\r\n                            <!-- v8.10: 框选区域 overlay(默认隐藏) -->\r\n                            <div id=\"regionOverlay\" style=\"display:none;position:absolute;top:0;left:0;width:100%;height:100%;cursor:crosshair;z-index:100\">\r\n                                <div id=\"regionBox\" style=\"position:absolute;border:2px dashed #3fb950;background:rgba(63,185,80,0.15);display:none;pointer-events:none\"></div>\r\n                            </div>\r\n                        </div>\r\n                        <!-- 媒体操作 + 跟踪控制 并排 -->\r\n                        <div style=\"display:flex;gap:12px;width:100%\">\r\n                            <div style=\"flex:1\">\r\n                                <div class=\"collapsible-section\" id=\"mediaControlSection\">\r\n                                    <div class=\"collapsible-header\" onclick=\"toggleSection('mediaControlSection')\">\r\n                                        <h3 style=\"font-size:15px;color:#3fb950;margin:0\">📷 媒体操作</h3>\r\n                                        <span class=\"collapse-icon\">▼</span>\r\n                                    </div>\r\n                            <div class=\"collapsible-content\">\r\n                                <div style=\"display:flex;flex-direction:column;gap:12px\">\r\n                                    <!-- 截图/录像 -->\r\n                                    <div style=\"display:flex;gap:8px;justify-content:center;flex-wrap:wrap\">\r\n                                        <button class=\"btn btn-primary btn-sm\" id=\"btnConsoleSnapshot\" onclick=\"consoleSnapshot()\">📷 截图</button>\r\n                                        <button class=\"btn btn-warning btn-sm\" id=\"btnConsoleRecord\" onclick=\"toggleRecord()\">⏺ 录像</button>\r\n                                    </div>\r\n                                    <div id=\"consoleRecordStatus\" style=\"font-size:11px;color:#8b949e;text-align:center\">未录像</div>\r\n\r\n                                    <!-- Live Stack -->\r\n                                    <div class=\"section-subtitle\">Live Stack 实时叠加</div>\r\n                                    <div style=\"display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:8px\">\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"off\" onclick=\"setLiveStackMode('off')\">关闭</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"2s\" onclick=\"setLiveStackMode('2s')\">2s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"5s\" onclick=\"setLiveStackMode('5s')\">5s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"10s\" onclick=\"setLiveStackMode('10s')\">10s</button>\r\n                                        <button class=\"btn btn-secondary btn-sm\" data-stack=\"30s\" onclick=\"setLiveStackMode('30s')\">30s</button>\