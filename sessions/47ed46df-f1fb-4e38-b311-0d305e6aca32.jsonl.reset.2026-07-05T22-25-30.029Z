und: #30363d;\n    margin: 0 2px;\n}\n</style>"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}}],"api":"anthropic-messages","provider":"HP","model":"qwen-3.7-max","usage":{"input":6,"output":712,"cacheRead":0,"cacheWrite":228198,"totalTokens":228916,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783284516957,"responseId":"msg_57530ccf-220d-4ec5-a226-b007c5086cd6"}}
