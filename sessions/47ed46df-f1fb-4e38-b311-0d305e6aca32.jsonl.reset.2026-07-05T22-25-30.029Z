{"type":"message","id":"3624d0c5","parentId":"9335a241","timestamp":"2026-07-05T20:32:36.665Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"老板要求我立即修复，不要绕弯路，不要过度开发。\n\n我已经修复了：\n1. console.html 添加了 CSS 样式和 .catch() 错误处理\n2. 现在需要修复 router.py 中的同步阻塞问题\n\n让我继续修复 router.py。需要在 `set_filter_settings` 和 `set_slow_shutter` 中使用 `asyncio.to_thread` 包装同步的 ISAPI 调用。\n\n让我读取 router.py 中的相关代码并进行修改。","thinkingSignature":""},{"type":"text","text":"现在修复 `router.py` 中的同步阻塞问题："},{"type":"toolCall","id":"functions.read:76","name":"read","arguments":{"limit":80,"offset":3712,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}},{"type":"text","text":"Now let me fix the router.py backend to wrap the synchronous ISAPI calls with `asyncio.to_thread` to prevent blocking the event loop.</think>"},{"type":"toolCall","id":"functions.edit:77","name":"edit","arguments":{"edits":[{"newText":"    client = ctrl.client\n    try:\n        resp = await asyncio.to_thread(client.get, \"/Image/channels/1\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取滤镜设置失败: HTTP {resp.status_code}\"}\n\n        root = ET.fromstring(resp.xml)\n        day_night = \"unknown\"\n        ir_cut = \"unknown\"\n        for elem in root.iter():\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n            if tag == \"dayNightMode\":\n                day_night = (elem.text or \"\").strip()\n            elif tag == \"irCutFilter\":\n                ir_cut = (elem.text or \"\").strip()\n\n        return {\n            \"success\": True,\n            \"data\": {\n                \"dayNightMode\": day_night,\n                \"irCutFilter\": ir_cut\n            }\n        }\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"获取滤镜设置异常: {e}\"}\n\n\n@api_router.put(\"/ptz/{device_id}/image/filter\", summary=\"设置滤镜与日夜模式\", tags=[\"Image\"])\nasync def set_filter_settings(device_id: str, body: dict) -> dict:\n    \"\"\"设置 dayNightMode 和/或 irCutFilter。\n\n    请求体:\n        {\"dayNightMode\": \"day|night|auto\", \"irCutFilter\": \"on|off|auto\"}\n    \"\"\"\n    mgr: PTZDeviceController | None = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    day_night = body.get(\"dayNightMode\", \"\")\n    ir_cut = body.get(\"irCutFilter\", \"\")\n\n    # 先 GET 当前完整 XML，再修改对应字段后 PUT\n    try:\n        resp = await asyncio.to_thread(client.get, \"/Image/channels/1\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取当前设置失败: HTTP {resp.status_code}\"}\n\n        xml_str = resp.xml\n        import re\n\n        if day_night:\n            xml_str = re.sub(\n                r'(<dayNightMode>)[^<]*(</dayNightMode>)',\n                f'\\\\g<1>{day_night}\\\\g<2>',\n                xml_str\n            )\n        if ir_cut:\n            xml_str = re.sub(\n                r'(<irCutFilter>)[^<]*(</irCutFilter>)',\n                f'\\\\g<1>{ir_cut}\\\\g<2>',\n                xml_str\n            )\n\n        put_resp = await asyncio.to_thread(client.put, \"/Image/channels/1\", xml_str)\n        if put_resp.status_code == 200:\n            log_info(\"image\", \"filter\", {\"device\": device_id, \"dayNight\": day_night, \"irCut\": ir_cut})\n            return {\"success\": True, \"message\": \"滤镜设置成功\"}\n        else:\n            return {\"success\": False, \"message\": f\"设置失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置滤镜异常: {e}\"}\n\n\n# === 慢快门 DSS (v8.45) ===\n\n@api_router.get(\"/ptz/{device_id}/image/slow-shutter\", summary=\"获取慢快门设置\", tags=[\"Image\"])\nasync def get_slow_shutter(device_id: str) -> dict:\n    mgr = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n    client = ctrl.client\n    try:\n        resp = await asyncio.to_thread(client.get, \"/Image/channels/1/DSS\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取DSS失败: HTTP {resp.status_code}\"}\n        import xml.etree.ElementTree as ET\n        root = ET.fromstring(resp.xml)\n        enabled = False\n        dss_level = \"\"\n        for elem in root.iter():\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n            if tag == \"enabled\":\n                enabled = (elem.text or \"\").strip().lower() == \"true\"\n            elif tag == \"DSSLevel\":\n                dss_level = (elem.text or \"\").strip()\n        return {\"success\": True, \"data\": {\"supported\": True, \"enabled\": enabled, \"dss_level\": dss_level}}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"获取DSS异常: {e}\"}\n\n@api_router.put(\"/ptz/{device_id}/image/slow-shutter\", summary=\"设置慢快门\", tags=[\"Image\"])\nasync def set_slow_shutter(device_id: str, body: dict) -> dict:\n    mgr = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n    client = ctrl.client\n    dss_level = body.get(\"dss_level\", \"\")\n    try:\n        if dss_level == \"off\":\n            enabled = \"false\"\n            level_str = \"*1\"\n        else:\n            enabled = \"true\"\n            level_str = dss_level\n        xml_str = '<?xml version=\"1.0\" encoding=\"UTF-8\"?>' + chr(10) + '<DSS version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">' + chr(10) + '  <enabled>' + enabled + '</enabled>' + chr(10) + '  <DSSLevel>' + level_str + '</DSSLevel>' + chr(10) + '</DSS>'\n        put_resp = await asyncio.to_thread(client.put, \"/Image/channels/1/DSS\", xml_str)\n        if put_resp.status_code == 200:\n            log_info(\"image\", \"dss\", {\"device\": device_id, \"level\": dss_level})\n            try:\n                mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\n                if len(mac_clean) == 12:\n                    save_device_settings(mac_clean, {\"slow_shutter\": {\"dss_level\": dss_level, \"enabled\": dss_level != \"off\"}})\n            except Exception:\n                pass\n            return {\"success\": True, \"message\": \"慢快门: \" + (\"关闭\" if dss_level == \"off\" else dss_level)}\n        return {\"success\": False, \"message\": f\"设置失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置DSS异常: {e}\"}\n","oldText":"    client = ctrl.client\n    try:\n        resp = client.get(\"/Image/channels/1\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取滤镜设置失败: HTTP {resp.status_code}\"}\n\n        root = ET.fromstring(resp.xml)\n        day_night = \"unknown\"\n        ir_cut = \"unknown\"\n        for elem in root.iter():\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n            if tag == \"dayNightMode\":\n                day_night = (elem.text or \"\").strip()\n            elif tag == \"irCutFilter\":\n                ir_cut = (elem.text or \"\").strip()\n\n        return {\n            \"success\": True,\n            \"data\": {\n                \"dayNightMode\": day_night,\n                \"irCutFilter\": ir_cut\n            }\n        }\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"获取滤镜设置异常: {e}\"}\n\n\n@api_router.put(\"/ptz/{device_id}/image/filter\", summary=\"设置滤镜与日夜模式\", tags=[\"Image\"])\nasync def set_filter_settings(device_id: str, body: dict) -> dict:\n    \"\"\"设置 dayNightMode 和/或 irCutFilter。\n\n    请求体:\n        {\"dayNightMode\": \"day|night|auto\", \"irCutFilter\": \"on|off|auto\"}\n    \"\"\"\n    mgr: PTZDeviceController | None = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n\n    client = ctrl.client\n    day_night = body.get(\"dayNightMode\", \"\")\n    ir_cut = body.get(\"irCutFilter\", \"\")\n\n    # 先 GET 当前完整 XML，再修改对应字段后 PUT\n    try:\n        resp = client.get(\"/Image/channels/1\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取当前设置失败: HTTP {resp.status_code}\"}\n\n        xml_str = resp.xml\n        import re\n\n        if day_night:\n            xml_str = re.sub(\n                r'(<dayNightMode>)[^<]*(</dayNightMode>)',\n                f'\\\\g<1>{day_night}\\\\g<2>',\n                xml_str\n            )\n        if ir_cut:\n            xml_str = re.sub(\n                r'(<irCutFilter>)[^<]*(</irCutFilter>)',\n                f'\\\\g<1>{ir_cut}\\\\g<2>',\n                xml_str\n            )\n\n        put_resp = client.put(\"/Image/channels/1\", xml_str)\n        if put_resp.status_code == 200:\n            log_info(\"image\", \"filter\", {\"device\": device_id, \"dayNight\": day_night, \"irCut\": ir_cut})\n            return {\"success\": True, \"message\": \"滤镜设置成功\"}\n        else:\n            return {\"success\": False, \"message\": f\"设置失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置滤镜异常: {e}\"}\n\n\n# === 慢快门 DSS (v8.45) ===\n\n@api_router.get(\"/ptz/{device_id}/image/slow-shutter\", summary=\"获取慢快门设置\", tags=[\"Image\"])\nasync def get_slow_shutter(device_id: str) -> dict:\n    mgr = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n    client = ctrl.client\n    try:\n        resp = client.get(\"/Image/channels/1/DSS\")\n        if resp.status_code != 200:\n            return {\"success\": False, \"message\": f\"获取DSS失败: HTTP {resp.status_code}\"}\n        import xml.etree.ElementTree as ET\n        root = ET.fromstring(resp.xml)\n        enabled = False\n        dss_level = \"\"\n        for elem in root.iter():\n            tag = elem.tag.split(\"}\")[-1] if \"}\" in elem.tag else elem.tag\n            if tag == \"enabled\":\n                enabled = (elem.text or \"\").strip().lower() == \"true\"\n            elif tag == \"DSSLevel\":\n                dss_level = (elem.text or \"\").strip()\n        return {\"success\": True, \"data\": {\"supported\": True, \"enabled\": enabled, \"dss_level\": dss_level}}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"获取DSS异常: {e}\"}\n\n@api_router.put(\"/ptz/{device_id}/image/slow-shutter\", summary=\"设置慢快门\", tags=[\"Image\"])\nasync def set_slow_shutter(device_id: str, body: dict) -> dict:\n    mgr = _managers.get(\"ptz_controller\")\n    if not mgr:\n        return {\"success\": False, \"message\": \"PTZDeviceController未初始化\"}\n    target_ip = _resolve_device_id_to_ip(mgr, device_id)\n    if not target_ip:\n        return {\"success\": False, \"message\": f\"无法解析设备标识: {device_id}\"}\n    ctrl, err = mgr._get_controller(target_ip)\n    if err:\n        return {\"success\": False, \"message\": err}\n    client = ctrl.client\n    dss_level = body.get(\"dss_level\", \"\")\n    try:\n        if dss_level == \"off\":\n            enabled = \"false\"\n            level_str = \"*1\"\n        else:\n            enabled = \"true\"\n            level_str = dss_level\n        xml_str = '<?xml version=\"1.0\" encoding=\"UTF-8\"?>' + chr(10) + '<DSS version=\"2.0\" xmlns=\"http://www.hikvision.com/ver20/XMLSchema\">' + chr(10) + '  <enabled>' + enabled + '</enabled>' + chr(10) + '  <DSSLevel>' + level_str + '</DSSLevel>' + chr(10) + '</DSS>'\n        put_resp = client.put(\"/Image/channels/1/DSS\", xml_str)\n        if put_resp.status_code == 200:\n            log_info(\"image\", \"dss\", {\"device\": device_id, \"level\": dss_level})\n            try:\n                mac_clean = device_id.replace(\":\", \"\").replace(\"-\", \"\").lower()\n                if len(mac_clean) == 12:\n                    save_device_settings(mac_clean, {\"slow_shutter\": {\"dss_level\": dss_level, \"enabled\": dss_level != \"off\"}})\n            except Exception:\n                pass\n            return {\"success\": True, \"message\": \"慢快门: \" + (\"关闭\" if dss_level == \"off\" else dss_level)}\n        return {\"success\": False, \"message\": f\"设置失败: HTTP {put_resp.status_code}\"}\n    except Exception as e:\n        return {\"success\": False, \"message\": f\"设置DSS异常: {e}\"}\n"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"