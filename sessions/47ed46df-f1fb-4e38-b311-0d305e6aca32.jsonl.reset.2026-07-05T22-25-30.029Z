{"type":"message","id":"99d809fe","parentId":"5607a314","timestamp":"2026-07-05T21:52:30.694Z","message":{"role":"toolResult","toolCallId":"functions.read:183","toolName":"read","content":[{"type":"text","text":"        }\r\n        // v7.59: Operation log display (user actions)\r\n        function operationLog(msg, type='info') {\r\n            const box = document.getElementById('operationLogBox');\r\n            if (!box) { console.warn('[operationLog] operationLogBox not found'); return; }\r\n            const time = new Date().toLocaleTimeString();\r\n            const colors = {\r\n                'info': '#8b949e',\r\n                'success': '#3fb950',\r\n                'error': '#f85149',\r\n                'warning': '#d29922',\r\n                'debug': '#58a6ff'\r\n            };\r\n            const icons = {\r\n                'info': '○',\r\n                'success': '●',\r\n                'error': '×',\r\n                'warning': '△',\r\n                'debug': '◇'\r\n            };\r\n            const color = colors[type] || '#8b949e';\r\n            const icon = icons[type] || '○';\r\n            const entry = document.createElement('div');\r\n            entry.style.cssText = 'color:' + color + ';margin:1px 0;padding:1px 6px;font-size:11px;font-family:monospace;line-height:1.3';\r\n            entry.textContent = '[' + time + '] ' + icon + ' ' + msg;\r\n            box.appendChild(entry);\r\n            if (box.children.length > 50) box.removeChild(box.firstChild);\r\n            console.log('[operationLog]', msg, type);\r\n\r\n            // v6.40: 发送操作日志到后端\r\n            if (typeof apiPost === 'function') {\r\n                try {\r\n                    apiPost('/api/v1/log/operation', {\r\n                        level: type.toUpperCase(),\r\n                        module: 'web',\r\n                        action: 'ptz',\r\n                        detail: msg\r\n                    }).catch(function(e) { console.warn('[LOG] send failed:', e); });\r\n                } catch(e) {}\r\n            }\r\n        }\r\n        window.operationLog = operationLog;\r\n        // PTZ Controls\r\n        function ptzMove(dir) {\r\n            var dev = window.connectedDevice.ip;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            var speed = parseInt(document.getElementById('ptzSpeed').value);\r\n            apiPost('/api/v1/ptz/' + dev + '/move', {\r\n                direction: dir, speed: speed\r\n            }).then(function(result) {\r\n                if (result && !result.success) {\r\n                    showToast('error', result.message || '移动失败');\r\n                    addLog('error', 'PTZ 移动失败: ' + (result.message || ''));\r\n                }\r\n            }).catch(function(e) {\r\n                addLog('info', 'PTZ 移动: ' + dir);\r\n            });\r\n        }\r\n        function ptzHome() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) { showToast('warning', '请先选择设备'); return; }\r\n            apiPost('/api/v1/ptz/' + dev + '/home', null).then(function(result) {\r\n                if (result && result.success) {\r\n                    showToast('success', result.message || '归位成功');\r\n                    if (typeof operationLog === 'function') operationLog('归位', 'success');\r\n                } else if (result) {\r\n                    showToast('error', result.message || '归位失败');\r\n                }\r\n            }).catch(function(e) {\r\n                showToast('error', '归位异常: ' + e.message);\r\n            });\r\n        }\r\n        function ptzStop() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n            apiPost('/api/v1/ptz/' + dev + '/stop', null).catch(function(e) {});\r\n        }\r\n        function getPtzPosition() {\r\n            var dev = window.connectedDevice ? window.connectedDevice.ip : null;\r\n            if (!dev) return;\r\n\n[1438 more lines in file. Use offset=1670 to continue.]"}],"isError":false,"timestamp":1783288350694}}
