ound: #0d1117;\n        border: 1px solid #30363d;\n        border-radius: 6px;\n        overflow: hidden;\n        width: 100%;\n    }\n    .triple-switch .ts-btn {\n        flex: 1;\n        padding: 4px 2px;\n        border: none;\n        background: transparent;\n        color: #8b949e;\n        font-size: 11px;\n        cursor: pointer;\n        transition: all 0.2s;\n        border-right: 1px solid #30363d;\n    }\n    .triple-switch .ts-btn:last-child {\n        border-right: none;\n    }\n    .triple-switch .ts-btn.active {\n        background: #58a6ff;\n        color: #0d1117;\n        font-weight: bold;\n    }\n    .triple-switch .ts-btn:hover:not(.active) {\n        background: #21262d;\n        color: #c9d1d9;\n    }\n</style>","oldText":"    </style>"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}},{"type":"text","text":"Now I need to fix the JS functions to add `.catch()` error handling. Let me do that.</think>"},{"type":"toolCall","id":"functions.edit:90","name":"edit","arguments":{"edits":[{"newText":"function setSlowShutter(val) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPut('/api/v1/ptz/' + dev + '/image/slow-shutter', { dss_level: val }).then(function(r) {\n        if (r && r.success) {\n            showToast('success', r.message);\n            if (typeof operationLog === 'function') operationLog('慢快门: ' + r.message, 'success');\n            var sel = document.getElementById('slowShutterSelect');\n            if (sel) sel.value = val;\n        }\n    }).catch(function(e) {\n        showToast('error', '慢快门设置失败: ' + e.message);\n        console.error('setSlowShutter error:', e);\n    });\n}","oldText":"function setSlowShutter(val) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPut('/api/v1/ptz/' + dev + '/image/slow-shutter', { dss_level: val }).then(function(r) {\n        if (r && r.success) {\n            showToast('success', r.message);\n            if (typeof operationLog === 'function') operationLog('慢快门: ' + r.message, 'success');\n            var sel = document.getElementById('slowShutterSelect');\n            if (sel) sel.value = val;\n        }\n    });\n}"},{"newText":"function setDayNightMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPut('/api/v1/ptz/' + dev + '/image/filter', { dayNightMode: mode })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', '日夜模式: ' + mode);\n                if (typeof operationLog === 'function') operationLog('日夜模式: ' + mode, 'success');\n                updateSwitchHighlight('dayNightSwitch', mode);\n            }\n        }).catch(function(e) {\n            showToast('error', '日夜模式设置失败: ' + e.message);\n            console.error('setDayNightMode error:', e);\n        });\n}","oldText":"function setDayNightMode(mode) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPut('/api/v1/ptz/' + dev + '/image/filter', { dayNightMode: mode })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', '日夜模式: ' + mode);\n                if (typeof operationLog === 'function') operationLog('日夜模式: ' + mode, 'success');\n                updateSwitchHighlight('dayNightSwitch', mode);\n            }\n        });\n}"},{"newText":"function setIRCutFilter(filter) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPut('/api/v1/ptz/' + dev + '/image/filter', { irCutFilter: filter })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', 'IR滤镜: ' + filter);\n                if (typeof operationLog === 'function') operationLog('IR滤镜: ' + filter, 'success');\n                updateSwitchHighlight('irCutSwitch', filter);\n            }\n        }).catch(function(e) {\n            showToast('error', 'IR滤镜设置失败: ' + e.message);\n            console.error('setIRCutFilter error:', e);\n        });\n}","oldText":"function setIRCutFilter(filter) {\n    var dev = window.connectedDevice ? window.connectedDevice.ip : null;\n    if (!dev) return;\n    apiPut('/api/v1/ptz/' + dev + '/image/filter', { irCutFilter: filter })\n        .then(function(r) {\n            if (r && r.success) {\n                showToast('success', 'IR滤镜: ' + filter);\n                if (typeof operationLog === 'function') operationLog('IR滤镜: ' + filter, 'success');\n                updateSwitchHighlight('irCutSwitch', filter);\n            }\n        });\n}"}],"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\web\\includes\\console.html"}},{"type":"text","text":"Now I need to fix the backend sync blocking issue in router.py. I need to wrap `client.get()` and `client.put()` calls with `asyncio.to_thread`.\n\nLet me read the router.py code to find the exact lines to modify.</think>"},{"type":"toolCall","id":"functions.read:91","name":"read","arguments":{"limit":50,"offset":3669,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}},{"type":"text","text":"Now I need to fix the backend sync blocking in router.py. I need to wrap `client.get()` and `client.put()` calls with `asyncio.to_thread`. Let me read the relevant code sections to make precise edits.</think>"},{"type":"toolCall","id":"functions.read:92","name":"read","arguments":{"limit":50,"offset":3680,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}},{"type":"text","text":"I need to fix the backend sync blocking in router.py. The issue is that `client.get()` and `client.put()` are synchronous calls inside `async def` functions, which blocks the event loop.\n\nThe minimal fix is to wrap them with `asyncio.to_thread`. Let me make the edits.\n\nI 