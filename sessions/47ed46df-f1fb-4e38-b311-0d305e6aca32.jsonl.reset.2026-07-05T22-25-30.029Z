{"type":"message","id":"a52f3295","parentId":"149656a6","timestamp":"2026-07-05T21:42:36.783Z","message":{"role":"toolResult","toolCallId":"toolu_05e5d257e1774085977c5409","toolName":"read","content":[{"type":"text","text":"                    }\r\n                }\r\n            }\r\n            // 恢复慢快门\r\n            if (s.slow_shutter && s.slow_shutter.dss_level) {\r\n                var ssSelect = document.getElementById('slowShutterSelect');\r\n                if (ssSelect) {\r\n                    ssSelect.value = s.slow_shutter.dss_level;\r\n                    onSlowShutterChange(s.slow_shutter.dss_level);\r\n                }\r\n            }\r\n        }\r\n    }).catch(function(e) {\r\n        console.warn('[RESTORE] 恢复设置失败:', e);\r\n    });\r\n}\r\n\r\n// v7.32: 显示功能检测覆盖层\r\nfunction showFunctionOverlay() {\r\n    var section = document.getElementById('imageControlSection');\r\n    if (!section) return;\r\n\r\n    // 移除旧覆盖层\r\n    var oldOverlay = document.getElementById('function-required-overlay');\r\n    if (oldOverlay) oldOverlay.remove();\r\n\r\n    // 创建覆盖层\r\n    var overlay = document.createElement('div');\r\n    overlay.id = 'function-required-overlay';\r\n    overlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(13,17,23,0.9);z-index:100;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;padding:20px;';\r\n\n[1161 more lines in file. Use offset=970 to continue.]"}],"isError":false,"timestamp":1783287756782}}
