int(f\"{'='*80}\")\n            print(text[:3000])\n            if len(text) > 3000:\n                print(f\"... [truncated, total {len(text)} chars]\")\n","path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\read_isapi_pdf.py"}}],"api":"anthropic-messages","provider":"HP","model":"qwen-3.7-max","usage":{"input":79372,"output":602,"cacheRead":0,"cacheWrite":0,"totalTokens":79974,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783280867464,"responseId":"cht000d2cf6@dx19f33d2a0552872503"}}
