{"type":"message","id":"d7776bfb","parentId":"93094898","timestamp":"2026-07-07T18:06:02.855Z","message":{"role":"toolResult","toolCallId":"toolu_0b1b6fb32eb74f35bcd364ac","toolName":"exec","content":[{"type":"text","text":"3996: def _cleanup_temp(category: str, device_ip: str):\r\n4004: def _capture_and_crop(client, mgr, device_ip: str, category: str,"}],"details":{"status":"completed","exitCode":0,"durationMs":371,"aggregated":"3996: def _cleanup_temp(category: str, device_ip: str):\r\n4004: def _capture_and_crop(client, mgr, device_ip: str, category: str,","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1783447562855}}
{"type":"message","id":"bba2edcb","parentId":"d7776bfb","timestamp":"2026-07-07T18:06:19.620Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me read the capture function to see exactly what ISAPI calls it makes in detail.","thinkingSignature":""},{"type":"text","text":"Let me read the capture function to see exactly what it does."},{"type":"toolCall","id":"call_e90f573f53e54fa8923f5555","name":"read","arguments":{"limit":60,"offset":3996,"path":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory\\astrohub\\src\\api\\router.py"}}],"api":"anthropic-messages","provider":"HP","model":"qwen-3.7-max","usage":{"input":59702,"output":79,"cacheRead":0,"cacheWrite":0,"totalTokens":59781,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783447562857,"responseId":"cht000dcecc@dx19f3dc23b212872503"}}
{"type":"message","id":"96ddbfc9","parentId":"bba2edcb","timestamp":"2026-07-07T18:06:19.631Z","message":{"role":"toolResult","toolCallId":"call_e90f573f53e54fa8923f5555","toolName":"read","content":[{"type":"text","text":"def _cleanup_temp(category: str, device_ip: str):\r\n    \"\"\"清理指定设备指定类别的临时文件。\"\"\"\r\n    import shutil\r\n    d = os.path.join(_TEMP_ROOT, category, device_ip.replace(\".\", \"_\"))\r\n    if os.path.exists(d):\r\n        shutil.rmtree(d, ignore_errors=True)\r\n\r\n\r\ndef _capture_and_crop(client, mgr, device_ip: str, category: str,\r\n                      x: float, y: float, w: float, h: float,\r\n                      skip_delay: bool = False) -> tuple:\r\n    \"\"\"ISAPI 截图 → 按比例裁剪 → 返回 (bgr, 截图路径, 裁剪信息dict)。\r\n\r\n    统一入口，白平衡和对焦共用。\r\n    v8.64: skip_delay=True 时跳过 calc_stable_delay（调用方已等待）。\r\n    \"\"\"\r\n    import time as _time\r\n    if not skip_delay:\r\n        from src.controlpanel.region_base import calc_stable_delay\r\n        delay = calc_stable_delay(client)\r\n        _time.sleep(delay)\r\n    jpg = client.capture_picture()\r\n    if not jpg:\r\n        return None, \"\", {\"error\": \"ISAPI截图失败\"}\r\n\r\n    # 保存全图\r\n    ts = int(_time.time() * 1000)\r\n    temp_dir = _temp_dir(category, device_ip)\r\n    full_path = os.path.join(temp_dir, f\"full_{ts}.jpg\")\r\n    with open(full_path, \"wb\") as f:\r\n        f.write(jpg)\r\n\r\n    bgr = cv2.imdecode(np.frombuffer(jpg, np.uint8), cv2.IMREAD_COLOR)\r\n    if bgr is None:\r\n        return None, full_path, {\"error\": \"图像解码失败\"}\r\n\r\n    full_h, full_w = bgr.shape[:2]\r\n\r\n    # 裁剪\r\n    if w > 0 and h > 0:\r\n        x1 = max(0, int(x * full_w))\r\n        y1 = max(0, int(y * full_h))\r\n        x2 = min(full_w, int((x + w) * full_w))\r\n        y2 = min(full_h, int((y + h) * full_h))\r\n        if x2 <= x1 or y2 <= y1:\r\n            return bgr, full_path, {\"error\": \"裁剪区域无效\"}\r\n        cropped = bgr[y1:y2, x1:x2]\r\n        crop_path = os.path.join(temp_dir, f\"crop_{ts}.jpg\")\r\n        cv2.imwrite(crop_path, cropped)\r\n    else:\r\n        cropped = bgr\r\n        crop_path = full_path\r\n        x1, y1, x2, y2 = 0, 0, full_w, full_h\r\n\r\n    info = {\r\n        \"full_w\": full_w, \"full_h\": full_h,\r\n        \"crop_x1\": x1, \"crop_y1\": y1, \"crop_x2\": x2, \"crop_y2\": y2,\r\n        \"crop_w\": x2 - x1, \"crop_h\": y2 - y1,\r\n        \"crop_path\": crop_path,\r\n        \"pixels\": (x2 - x1) * (y2 - y1),\r\n\n[267 more lines in file. Use offset=4056 to continue.]"}],"isError":false,"timestamp":1783447579631}}
