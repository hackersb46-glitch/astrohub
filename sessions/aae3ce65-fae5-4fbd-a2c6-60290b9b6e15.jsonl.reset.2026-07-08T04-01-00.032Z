{"type":"message","id":"e91c8113","parentId":"d552d1a3","timestamp":"2026-07-08T03:53:21.256Z","message":{"role":"assistant","content":[{"type":"text","text":"好的，现在我已经掌握了具体位置。让我读取 `executeScheduledSearch` 函数的 SSE 处理部分，看看它具体是如何记录事件的。"},{"type":"toolCall","id":"call_0b63303466a44cc4a51c00a6","name":"read","arguments":{"limit":120,"offset":1622,"path":"C:/Users/admin/.openclaw/agents/dev-factory/astrohub/src/web/includes/console.html"}}],"api":"anthropic-messages","provider":"HP","model":"qwen-3.7-max","usage":{"input":161487,"output":75,"cacheRead":0,"cacheWrite":0,"totalTokens":161562,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783482784739,"responseId":"cht000deef1@dx19f3fdba65929c2503"}}
{"type":"message","id":"616c24e1","parentId":"e91c8113","timestamp":"2026-07-08T03:53:21.270Z","message":{"role":"toolResult","toolCallId":"call_0b63303466a44cc4a51c00a6","toolName":"read","content":[{"type":"text","text":"function executeScheduledSearch(mode) {\r\n    var regionStr = localStorage.getItem('region_' + mode);\r\n    if (!regionStr) {\r\n        var modeLabel = mode === 'whitebalance' ? '白平衡' : mode === 'brightness' ? '亮度' : '对焦';\r\n        showToast('warning', modeLabel + '无保存选区');\r\n        return;\r\n    }\r\n    var dev = window.connectedDevice;\r\n    if (!dev || !dev.ip) { showToast('error', '未连接设备'); return; }\r\n    var region = JSON.parse(regionStr);\r\n    var endpoint = mode === 'whitebalance' ? '/api/v1/vision/whitebalance-search'\r\n                 : mode === 'brightness' ? '/api/v1/vision/brightness-search'\r\n                 : '/api/v1/vision/focus-search';\r\n    var label = mode === 'whitebalance' ? '白平衡' : mode === 'brightness' ? '亮度' : '对焦';\r\n    showToast('info', label + '定时执行中...');\r\n    operationLog('── ' + label + '定时执行 ──', 'info');\r\n\r\n    // v8.66: 流程开始，暂停主控台轮询\r\n    pausePtzPolling();\r\n\r\n    var body;\r\n    if (mode === 'brightness') {\r\n        var target = window.localBrightnessTarget || 50;\r\n        var shutterValues = (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.shutter) ? deviceFunctionData.functions.shutter.opt_values : [];\r\n        var irisValues = (deviceFunctionData && deviceFunctionData.functions && deviceFunctionData.functions.iris) ? deviceFunctionData.functions.iris.opt_values : [];\r\n        var shutterIdx = 0;\r\n        if (deviceImageParams.shutter && deviceImageParams.shutter.current_level) {\r\n            shutterIdx = shutterValues.indexOf(String(deviceImageParams.shutter.current_level));\r\n            if (shutterIdx < 0) shutterIdx = 0;\r\n        }\r\n        var irisIdx = 0;\r\n        if (deviceImageParams.iris && deviceImageParams.iris.current_level) {\r\n            irisIdx = irisValues.indexOf(String(deviceImageParams.iris.current_level));\r\n            if (irisIdx < 0) irisIdx = 0;\r\n        }\r\n        var gainVal = (deviceImageParams.gain && deviceImageParams.gain.current_level) || 0;\r\n        body = JSON.stringify({\r\n            x: region.x, y: region.y, w: region.w, h: region.h,\r\n            target: target, shutter_idx: shutterIdx, iris_idx: irisIdx,\r\n            gain: gainVal, shutter_values: shutterValues, iris_values: irisValues,\r\n            gain_min: 0, gain_max: window.localGainLimit || 100\r\n        });\r\n    } else {\r\n        body = JSON.stringify({ x: region.x, y: region.y, w: region.w, h: region.h });\r\n    }\r\n    fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body })\r\n        .then(function(resp) {\r\n            if (!resp.ok) throw new Error('HTTP ' + resp.status);\r\n            var reader = resp.body.getReader();\r\n            var decoder = new TextDecoder();\r\n            var buf = '';\r\n            function pump() {\r\n                return reader.read().then(function(r) {\r\n                    if (r.done) return;\r\n                    buf += decoder.decode(r.value, { stream: true });\r\n                    var parts = buf.split('\\n\\n');\r\n                    buf = parts.pop();\r\n                    for (var i = 0; i < parts.length; i++) {\r\n                        var line = parts[i];\r\n                        if (!line.startsWith('data: ')) continue;\r\n                        try {\r\n                            var ev = JSON.parse(line.slice(6));\r\n                            if (ev.type === 'wb' || ev.type === 'focus') {\r\n                                operationLog('调整 #' + ev.step + ': ' + ev.stage + ' R=' + ev.red_gain + ' B=' + ev.blue_gain + ' Δ=' + ev.delta, 'info');\r\n                            } else if (ev.type === 'brightness') {\r\n                                operationLog('亮度 #' + ev.step + ': ' + ev.message + ' 快门=' + ev.shutter + ' 光圈=' + ev.iris + ' 增益=' + ev.gain + ' 亮度=' + ev.brightness, 'info');\r\n                            } else if (ev.type === 'done') {\r\n                                if (ev.final_red !== undefined) {\r\n                                    operationLog('── ' + label + '完成: R=' + ev.final_red + ' B=' + ev.final_blue + ' (' + ev.total_steps + '步) ──', 'success');\r\n                                } else if (ev.final_brightness !== undefined) {\r\n                                    operationLog('── ' + label + '完成: 亮度=' + ev.final_brightness + ' 快门=' + ev.shutter + ' 光圈=' + ev.iris + ' 增益=' + ev.gain + ' (' + ev.total_steps + '步) ──', 'success');\r\n                                } else {\r\n                                    operationLog('── ' + label + '完成 (' + ev.total_steps + '步) ──', 'success');\r\n                                }\r\n                            } else if (ev.type === 'error') {\r\n                                operationLog(label + '错误: ' + ev.message, 'error');\r\n                            }\r\n                        } catch (e) {}\r\n                    }\r\n                    return pump();\r\n                });\r\n            }\r\n            return pump();\r\n        })\r\n        .then(function() {\r\n            // 执行完成后，重新启动定时器\r\n            if (mode === 'whitebalance' && wbTimerId === null) {\r\n                var minutes = parseInt(document.getElementById('wbTimerInput').value) || 0;\r\n                if (minutes > 0) {\r\n                    wbTimerSeconds = minutes * 60;\r\n                    updateWbTimerDisplay();\r\n                    wbTimerId = setInterval(function() {\r\n                        wbTimerSeconds--;\r\n                        updateWbTimerDisplay();\r\n                        if (wbTimerSeconds <= 0) {\r\n                            clearInterval(wbTimerId);\r\n                            wbTimerId = null;\r\n                            executeScheduledSearch('whitebalance');\r\n                        }\r\n                    }, 1000);\r\n                }\r\n            }\r\n            if (mode === 'focus' && focusTimerId === null) {\r\n                var minutes = parseInt(document.getElementById('focusTimerInput').value) || 0;\r\n                if (minutes > 0) {\r\n                    focusTimerSeconds = minutes * 60;\r\n                    updateFocusTimerDisplay();\r\n                    focusTimerId = setInterval(function() {\r\n                        focusTimerSeconds--;\r\n                        updateFocusTimerDisplay();\r\n                        if (focusTimerSeconds <= 0) {\r\n                            clearInterval(focusTimerId);\r\n                            focusTimerId = null;\r\n                            executeScheduledSearch('focus');\r\n                        }\r\n                    }, 1000);\r\n                }\r\n            }\r\n            if (mode === 'brightness' && brightnessTimerId === null) {\r\n                var minutes = parseInt(document.getElementById('brightnessTimerInput').value) || 0;\r\n\n[689 more lines in file. Use offset=1742 to continue.]"}],"isError":false,"timestamp":1783482801270}}
