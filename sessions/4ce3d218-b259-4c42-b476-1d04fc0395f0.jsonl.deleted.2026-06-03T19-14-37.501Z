{"type":"message","id":"5514ab70","parentId":"59928558","timestamp":"2026-05-20T19:09:24.912Z","message":{"role":"toolResult","toolCallId":"call_3c9bb3a76f90445b94ed96e5","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python\r\n\"\"\"\r\nM12 Integration - ͳһ�������\r\n\r\nAstroHub v1.0 ����ͻ��� / ��ͷ����ˡ�\r\n\r\n����:\r\n- ʹ�� M12 Orchestrator ���� M1-M11 ģ��\r\n- FastAPI + uvicorn �����\r\n- --headless ģʽ: �� uvicorn\r\n- --host / --port �Զ��������ַ\r\n- ����Ŀ¼�Զ�����\r\n- ���Źر�: lifespan cleanup\r\n\r\nAuthor: ��Ʀ��@�Ϸ�����\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport argparse\r\nimport sys\r\nfrom pathlib import Path\r\n\r\n# ȷ����Ŀ��Ŀ¼�� sys.path �� (ʹ src.* ����ʼ�տ���)\r\n_project_root = str(Path(__file__).resolve().parent.parent)\r\nif _project_root not in sys.path:\r\n    sys.path.insert(0, _project_root)\r\n\r\nimport threading\r\nfrom contextlib import asynccontextmanager\r\n\r\nimport uvicorn\r\nfrom fastapi import FastAPI, Request\r\nfrom fastapi.responses import HTMLResponse, Response, JSONResponse\r\nfrom fastapi.templating import Jinja2Templates\r\nfrom starlette.requests import Request\r\nfrom fastapi.staticfiles import StaticFiles\r\nfrom starlette.middleware.base import BaseHTTPMiddleware\r\n\r\n# M12 Integration core (absolute imports via src package)\r\nfrom src.main.core.orchestrator import Orchestrator\r\nfrom src.main.core.config_merger import ConfigMerger\r\nfrom src.main.constants import VERSION, PROJECT_NAME, AUTHOR\r\n\r\n# Legacy router compatibility (uses set_managers pattern)\r\nfrom src.api.router import api_router, health_router, set_managers\r\nfrom src.config_paths import DATA_DIR, HLS_DIR, CALIBRATION_DIR, ensure_directories, get_web_dir, get_index_html\r\nfrom src.config import HOST, PORT\r\nfrom src.logger import get_logger\r\n\r\nlog = get_logger(\"main\")\r\n\r\n# ================================================================ #\r\n#  ȫ�ֹ���������\r\n# ================================================================ #\r\n\r\n_managers: dict[str, object] = {}\r\n\r\n\r\n# ================================================================ #\r\n#  ����Ŀ¼�Զ�����\r\n# ================================================================ #\r\n\r\ndef _ensure_data_dirs() -> None:\r\n    \"\"\"ȷ����������ʱ����Ŀ¼���ڡ�\"\"\"\r\n    ensure_directories()\r\n    for d in [HLS_DIR, CALIBRATION_DIR]:\r\n        d.mkdir(parents=True, exist_ok=True)\r\n    log.info(\"����Ŀ¼������: %s\", DATA_DIR)\r\n\r\n\r\n# ================================================================ #\r\n#  Lifespan\r\n# ================================================================ #\r\n\r\n@asynccontextmanager\r\nasync def lifespan(app: FastAPI):\r\n    \"\"\"Ӧ����������: ��ʼ�������� �� yield �� ������\"\"\"\r\n    log.info(\"=== M12 Integration ������ (v%s) ===\", VERSION)\r\n\r\n    _ensure_data_dirs()\r\n\r\n    # ��ʼ�������� (���� M1-M11 ģ����������)\r\n    log.info(\"��ʼ�� M12 Orchestrator ...\")\r\n    orchestrator = Orchestrator()\r\n    await orchestrator.start()\r\n    _managers[\"orchestrator\"] = orchestrator\r\n\r\n    # ��ʼ�����úϲ���\r\n    log.info(\"��ʼ�� ConfigMerger ...\")\r\n    merger = ConfigMerger()\r\n    merged_config = merger.merge_all()\r\n    _managers[\"config_merger\"] = merger\r\n\r\n    # ---- ��ʼ��ȫ�� 10 �������� (health �˵�����) ----\r\n\r\n    # 1. PTZManager\r\n    log.info(\"��ʼ�� PTZManager ...\")\r\n    from src.core.ptz_manager import PTZManager as _PTZManager\r\n    ptz_manager = _PTZManager()\r\n    _managers[\"ptz_manager\"] = ptz_manager\r\n\r\n    # 2. DeviceManager\r\n    log.info(\"��ʼ�� DeviceManager ...\")\r\n    from src.core.device_manager import DeviceManager\r\n    device_manager = DeviceManager()\r\n    if hasattr(device_manager, \"load_devices\"):\r\n        device_manager.load_devices()\r\n    _managers[\"device_manager\"] = device_manager\r\n\r\n    # 3. StreamManager\r\n    log.info(\"��ʼ�� StreamManager ...\")\r\n    from src.core.stream_manager import StreamManager\r\n    stream_manager = StreamManager()\r\n    _managers[\"stream_manager\"] = stream_manager\r\n\r\n    # 4. CalibrationManager\r\n    log.info(\"��ʼ�� CalibrationManager ...\")\r\n    try:\r\n        from src.core.calibration_manager import CalibrationManager\r\n        calibration_manager = CalibrationManager()\r\n        _managers[\"calibration_manager\"] = calibration_manager\r\n    except Exception as e:\r\n        log.warning(\"CalibrationManager ��ʼ������: %s\", e)\r\n\r\n    # 5. DBManager\r\n    log.info(\"��ʼ�� DBManager ...\")\r\n    try:\r\n        from src.database.core.db_manager import DatabaseManager\r\n        db_manager = DatabaseManager()\r\n        if hasattr(db_manager, \"init_db\"):\r\n            db_manager.init_db()\r\n        _managers[\"db_manager\"] = db_manager\r\n    except Exception as e:\r\n        log.warning(\"DBManager ��ʼ������: %s\", e)\r\n\r\n    # 6. AuthService\r\n    log.info(\"��ʼ�� AuthService ...\")\r\n    try:\r\n        from src.core.auth import AuthManager\r\n        auth_service = AuthManager()\r\n        _managers[\"auth_service\"] = auth_service\r\n    except Exception as e:\r\n        log.warning(\"AuthService ��ʼ������: %s\", e)\r\n\r\n    # 7. WSManager (WebSocket)\r\n    log.info(\"��ʼ�� WebSocketManager ...\")\r\n    try:\r\n        from src.core.ws_manager import WebSocketManager\r\n        ws_manager = WebSocketManager()\r\n        _managers[\"ws_manager\"] = ws_manager\r\n    except Exception as e:\r\n        log.warning(\"WSManager ��ʼ������: %s\", e)\r\n\r\n    # 8. ASCOMManager\r\n    log.info(\"��ʼ�� ASCOMManager ...\")\r\n    try:\r\n        from src.core.ascom_manager import ASCOMManager\r\n        ascom_manager = ASCOMManager()\r\n        _managers[\"ascom_manager\"] = ascom_manager\r\n    except Exception as e:\r\n        log.warning(\"ASCOMManager ��ʼ������: %s\", e)\r\n\r\n    # 9. HealthMonitor\r\n    log.info(\"��ʼ�� HealthMonitor ...\")\r\n    try:\r\n        from src.core.health_monitor import HealthMonitor\r\n        health_monitor = HealthMonitor()\r\n        _managers[\"health_monitor\"] = health_monitor\r\n    except Exception as e:\r\n        log.warning(\"HealthMonitor ��ʼ������: %s\", e)\r\n\r\n    log.info(\"��������ʼ�����: %d/%d initialized\",\r\n             sum(1 for v in _managers.values() if v is not None),\r\n             len(_managers))\r\n\r\n    # 10. ע�뵽�ɰ�·��ģ�� (����)\r\n    set_managers(\r\n        orchestrator=orchestrator,\r\n        ptz_manager=ptz_manager,\r\n        device_manager=device_manager,\r\n        stream_manager=_managers.get(\"stream_manager\"),\r\n        calibration_manager=_managers.get(\"calibration_manager\"),\r\n        db_manager=_managers.get(\"db_manager\"),\r\n        auth_service=_managers.get(\"auth_service\"),\r\n        ws_manager=_managers.get(\"ws_manager\"),\r\n        ascom_manager=_managers.get(\"ascom_manager\"),\r\n        health_monitor=_managers.get(\"health_monitor\"),\r\n    )\r\n\r\n    # ��ʼ�� ASCOM DriverManager\r\n    log.info(\"��ʼ�� ASCOM DriverManager ...\")\r\n    try:\r\n        from src.ascom.core.driver_manager import init_driver_manager\r\n        init_driver_manager()\r\n        log.info(\"ASCOM DriverManager ��ʼ�����\")\r\n    except Exception as e:\r\n        log.warning(\"ASCOM DriverManager ��ʼ������: %s\", e)\r\n\r\n    # ��ʼ�� WebSocket ������\r\n    log.info(\"��ʼ�� WebSocket ������ ...\")\r\n    try:\r\n        from src.websocket.server import WebSocketServer, WebSocketServerConfig\r\n        ws_server = WebSocketServer(config=WebSocketServerConfig(\r\n            path=\"/ws\",\r\n            heartbeat_interval=30,\r\n            heartbeat_timeout_count=2,\r\n        ))\r\n        ws_server.mount_to(app)\r\n        _managers[\"ws_server\"] = ws_server\r\n        log.info(\"WebSocket ��������ʼ�����\")\r\n    except Exception as e:\r\n        log.warning(\"WebSocket ��������ʼ������: %s\", e)\r\n\r\n    # ��ʼ�� SADP �˵����� (BUG-003 �޸�: ������ PTZManager)\r\n    from src.core.sadp_discovery import SADPManager as SADPDiskManager\r\n    _managers[\"sadp_manager\"] = SADPDiskManager()\r\n\r\n    log.info(\"=== M12 Integration ������� ===\")\r\n\r\n    yield\r\n\r\n    # ---- �رս׶� ----\r\n    log.info(\"=== M12 Integration �ر��� ===\")\r\n\r\n    # �ر� WebSocket ������\r\n    if \"ws_server\" in _managers and hasattr(_managers[\"ws_server\"], \"broadcast_manager\"):\r\n        try:\r\n            await _managers[\"ws_server\"]._cleanup_all_connections()\r\n        except Exception as e:\r\n            log.warning(\"WebSocket �������ر��쳣: %s\", e)\r\n\r\n    # ASCOM DriverManager �ر�\r\n    try:\r\n        from src.ascom.core.driver_manager import get_driver_manager\r\n        dm = get_driver_manager()\r\n        if hasattr(dm, \"shutdown\"):\r\n            dm.shutdown()\r\n            log.info(\"ASCOM DriverManager �ѹر�\")\r\n    except Exception:\r\n        pass\r\n\r\n    # ֹͣ������ (����ֹͣ M1-M11 ģ��)\r\n    if isinstance(orchestrator, Orchestrator):\r\n        await orchestrator.stop()\r\n        log.info(\"Orchestrator ��ֹͣ\")\r\n\r\n    _managers.clear()\r\n    log.info(\"=== M12 Integration �Ѱ�ȫ�ر� ===\")\r\n\r\n\r\n# ================================================================ #\r\n#  ���� FastAPI App\r\n# ================================================================ #\r\n\r\n_WEB_DIR = get_web_dir()\r\n_INDEX_HTML = get_index_html()\r\n_WEB_DIR = get_web_dir()\r\n_templates = Jinja2Templates(directory=str(_WEB_DIR))\r\n\r\n\r\ndef create_app() -> FastAPI:\r\n    \"\"\"���������� FastAPI Ӧ�á�\"\"\"\r\n    app = FastAPI(\r\n        title=str(PROJECT_NAME),\r\n        description=\"ͳһ�����豸����ƽ̨\",\r\n        version=VERSION,\r\n        lifespan=lifespan,\r\n    )\r\n\r\n    # ���� HLS ��̬�ļ�Ŀ¼\r\n    HLS_DIR.mkdir(parents=True, exist_ok=True)\r\n    app.mount(\"/hls\", StaticFiles(directory=str(HLS_DIR), html=True), name=\"hls\")\r\n\r\n    # ���� web ��̬�ļ�\r\n    app.mount(\"/static\", StaticFiles(directory=str(_WEB_DIR), html=True), name=\"static\")\r\n\r\n    # WASM SDK requires COOP/COEP headers for SharedArrayBuffer\r\n    class COOPCOEPMiddleware(BaseHTTPMiddleware):\r\n        async def dispatch(self, request, call_next):\r\n            response = await call_next(request)\r\n            path = request.url.path\r\n            if path == \"/\" or path.startswith(\"/static/\"):\r\n                response.headers.setdefault(\"Cross-Origin-Opener-Policy\", \"same-origin\")\r\n                response.headers.setdefault(\"Cross-Origin-Embedder-Policy\", \"require-corp\")\r\n            return response\r\n\r\n    app.add_middleware(COOPCOEPMiddleware)\r\n    # === ISAPI Proxy for WebSDK WASM noPlugin ===\r\n    import aiohttp\r\n    import traceback\r\n    _isapi_devices = {}\r\n\r\n    def register_isapi_device(ip, username, password, port=80):\r\n        _isapi_devices[ip] = {'username': username, 'password': password, 'port': port}\r\n\r\n    async def _handle_isapi_request(request, path):\r\n        method = request.method\r\n        device_ip = request.query_params.get('ip', '192.168.5.72')\r\n        device = _isapi_devices.get(device_ip, {'username': 'admin', 'password': 'Nftw1357', 'port': 80})\r\n        isapi_url = 'http://{}:{}/ISAPI/{}'.format(device_ip, device['port'], path)\r\n        auth = aiohttp.BasicAuth(device['username'], device['password'])\r\n        log.info('[ISAPI Proxy] %s -> %s', method, isapi_url)\r\n        try:\r\n            async with aiohttp.ClientSession() as session:\r\n                if method in ('POST', 'PUT'):\r\n                    body = await request.body()\r\n                else:\r\n                    body = None\r\n                headers = {k: v for k, v in request.headers.items() if k.lower() not in ('host', 'content-length', 'origin', 'referer')}\r\n                timeout = aiohttp.ClientTimeout(total=30)\r\n                if method == 'GET':\r\n                    async with session.get(isapi_url, auth=auth, headers=headers, timeout=timeout) as resp:\r\n                        rb = await resp.read()\r\n                        return Response(content=rb, status_code=resp.status, media_type=resp.headers.get('content-type', 'application/xml'))\r\n                elif method == 'POST':\r\n                    async with session.post(isapi_url, auth=auth, data=body, headers=headers, timeout=timeout) as resp:\r\n                        rb = await resp.read()\r\n                        return Response(content=rb, status_code=resp.status, media_type=resp.headers.get('content-type', 'application/xml'))\r\n                elif method == 'PUT':\r\n                    async with session.put(isapi_url, auth=auth, data=body, headers=headers, timeout=timeout) as resp:\r\n                        rb = await resp.read()\r\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n        return {\"success\": True, \"message\": \"WASM SDK ��ֱ�ӽ�����Ƶ��\", \"mode\": \"wasm\"}\r\n\r\n    @app.post(\"/api/v1/streams/{device_id}/stop\")\r\n    async def stream_stop(device_id: str):\r\n        \"\"\"WASM ģʽ�µ���ֹͣ��\"\"\"\r\n        log.info('[Stream Stop] WASM mode for %s', device_id)\r\n        return {\"success\": True, \"message\": \"WASM SDK ֹͣ����\", \"mode\": \"wasm\"}\r\n\r\n    @app.get(\"/api/v1/streams/{device_id}/status\")\r\n    async def stream_status(device_id: str):\r\n        \"\"\"WASM ģʽ�µ���״̬��\"\"\"\r\n        return {\"success\": True, \"status\": \"wasm_decoding\", \"device_id\": device_id}\r\n    # === End Stream Routes ===\r\n\r\n    app.include_router(api_router)\r\n    app.include_router(health_router)\r\n\r\n    # ��·�� -> index.html\r\n    @app.get(\"/\", response_class=HTMLResponse)\r\n    async def serve_index(request: Request):\r\n        return _templates.TemplateResponse(\"index.html\", {\"request\": request})\r\n\r\n    return app\r\n\r\n\r\n# ================================================================ #\r\n#  Headless ģʽ\r\n# ================================================================ #\r\n\r\ndef _run_headless(host: str, port: int) -> None:\r\n    \"\"\"Headless ģʽ: ͬ������ uvicorn ����ˡ�\"\"\"\r\n    app = create_app()\r\n    log.info(\"=== Headless ģʽ (M12 Integration v%s) ===\", VERSION)\r\n    uvicorn.run(app, host=host, port=port, log_level=\"info\")\r\n\r\n\r\n# ================================================================ #\r\n#  ���\r\n# ================================================================ #\r\n\r\ndef main() -> None:\r\n    \"\"\"������ڡ�\"\"\"\r\n    parser = argparse.ArgumentParser(description=f\"{PROJECT_NAME} v{VERSION} - ͳһ�����豸����ƽ̨\")\r\n    parser.add_argument(\"--headless\", action=\"store_true\", help=\"������ uvicorn ����ˣ������洰�ڣ�\")\r\n    parser.add_argument(\"--host\", default=HOST, help=f\"������ַ (Ĭ��: {HOST})\")\r\n    parser.add_argument(\"--port\", type=int, default=PORT, help=f\"�����˿� (Ĭ��: {PORT})\")\r\n    args = parser.parse_args()\r\n\r\n    # Headless ģʽ\r\n    if args.headless:\r\n        _run_headless(args.host, args.port)\r\n        return\r\n\r\n    # ����ģʽ (uvicorn + pywebview)\r\n    app = create_app()\r\n    stop_event = threading.Event()\r\n    open_url = f\"http://{args.host}:{args.port}\"\r\n\r\n    # ���� uvicorn �ں�̨�߳�\r\n    def _run_uvicorn() -> None:\r\n        config = uvicorn.Config(\r\n            app=app,\r\n            host=args.host,\r\n            port=args.port,\r\n            log_level=\"info\",\r\n            access_log=True,\r\n        )\r\n        server = uvicorn.Server(config)\r\n\r\n        def _serve() -> None:\r\n            server.run()\r\n\r\n        thread = threading.Thread(target=_serve, daemon=True)\r\n        thread.start()\r\n        log.info(\"Uvicorn ������: http://%s:%d\", args.host, args.port)\r\n\r\n        # �ȴ�ֹͣ�ź�\r\n        try:\r\n            while not stop_event.is_set():\r\n                stop_event.wait(timeout=0.5)\r\n        except KeyboardInterrupt:\r\n            pass\r\n\r\n        server.should_exit = True\r\n        thread.join(timeout=5)\r\n\r\n    uvicorn_thread = threading.Thread(target=_run_uvicorn, daemon=True)\r\n    uvicorn_thread.start()\r\n\r\n    # �� uvicorn һ��ʱ������\r\n    import time\r\n    time.sleep(1)\r\n\r\n    # ���� pywebview ���洰�� (����ֱ�����ڹر�)\r\n    try:\r\n        import webview\r\n        from src.config import WINDOW_TITLE, WINDOW_WIDTH, WINDOW_HEIGHT\r\n        log.info(\"�������洰��: %s (%dx%d)\", open_url, WINDOW_WIDTH, WINDOW_HEIGHT)\r\n        webview.create_window(WINDOW_TITLE, open_url, width=WINDOW_WIDTH, height=WINDOW_HEIGHT)\r\n        webview.start()\r\n    except ImportError:\r\n        log.warning(\"pywebview δ��װ���������ģʽ\")\r\n        # �ȴ� uvicorn �߳�\r\n        try:\r\n            uvicorn_thread.join()\r\n        except KeyboardInterrupt:\r\n            pass\r\n    finally:\r\n        stop_event.set()\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    try:\r\n        main()\r\n    except KeyboardInterrupt:\r\n        log.info(\"�û��ж�\")\r\n        sys.exit(0)\r\n    except Exception as e:\r\n        log.error(\"�����쳣: %s\", e, exc_info=True)\r\n        sys.exit(1)[... 1812 more characters truncated]"}],"details":{"status":"completed","exitCode":0,"durationMs":342,"aggregated":"#!/usr/bin/env python\r\n\"\"\"\r\nM12 Integration - ͳһ�������\r\n\r\nAstroHub v1.0 ����ͻ��� / ��ͷ����ˡ�\r\n\r\n����:\r\n- ʹ�� M12 Orchestrator ���� M1-M11 ģ��\r\n- FastAPI + uvicorn �����\r\n- --headless ģʽ: �� uvicorn\r\n- --host / --port �Զ��������ַ\r\n- ����Ŀ¼�Զ�����\r\n- ���Źر�: lifespan cleanup\r\n\r\nAuthor: ��Ʀ��@�Ϸ�����\r\n\"\"\"\r\n\r\nfrom __future__ import annotations\r\n\r\nimport argparse\r\nimport sys\r\nfrom pathlib import Path\r\n\r\n# ȷ����Ŀ��Ŀ¼�� sys.path �� (ʹ src.* ����ʼ�տ���)\r\n_project_root = str(Path(__file__).resolve().parent.parent)\r\nif _project_root not in sys.path:\r\n    sys.path.insert(0, _project_root)\r\n\r\nimport threading\r\nfrom contextlib import asynccontextmanager\r\n\r\nimport uvicorn\r\nfrom fastapi import FastAPI, Request\r\nfrom fastapi.responses import HTMLResponse, Response, JSONResponse\r\nfrom fastapi.templating import Jinja2Templates\r\nfrom starlette.requests import Request\r\nfrom fastapi.staticfiles import StaticFiles\r\nfrom starlette.middleware.base import BaseHTTPMiddleware\r\n\r\n# M12 Integration core (absolute imports via src package)\r\nfrom src.main.core.orchestrator import Orchestrator\r\nfrom src.main.core.config_merger import ConfigMerger\r\nfrom src.main.constants import VERSION, PROJECT_NAME, AUTHOR\r\n\r\n# Legacy router compatibility (uses set_managers pattern)\r\nfrom src.api.router import api_router, health_router, set_managers\r\nfrom src.config_paths import DATA_DIR, HLS_DIR, CALIBRATION_DIR, ensure_directories, get_web_dir, get_index_html\r\nfrom src.config import HOST, PORT\r\nfrom src.logger import get_logger\r\n\r\nlog = get_logger(\"main\")\r\n\r\n# ================================================================ #\r\n#  ȫ�ֹ���������\r\n# ================================================================ #\r\n\r\n_managers: dict[str, object] = {}\r\n\r\n\r\n# ================================================================ #\r\n#  ����Ŀ¼�Զ�����\r\n# ================================================================ #\r\n\r\ndef _ensure_data_dirs() -> None:\r\n    \"\"\"ȷ����������ʱ����Ŀ¼���ڡ�\"\"\"\r\n    ensure_directories()\r\n    for d in [HLS_DIR, CALIBRATION_DIR]:\r\n        d.mkdir(parents=True, exist_ok=True)\r\n    log.info(\"����Ŀ¼������: %s\", DATA_DIR)\r\n\r\n\r\n# ================================================================ #\r\n#  Lifespan\r\n# ================================================================ #\r\n\r\n@asynccontextmanager\r\nasync def lifespan(app: FastAPI):\r\n    \"\"\"Ӧ����������: ��ʼ�������� �� yield �� ������\"\"\"\r\n    log.info(\"=== M12 Integration ������ (v%s) ===\", VERSION)\r\n\r\n    _ensure_data_dirs()\r\n\r\n    # ��ʼ�������� (���� M1-M11 ģ����������)\r\n    log.info(\"��ʼ�� M12 Orchestrator ...\")\r\n    orchestrator = Orchestrator()\r\n    await orchestrator.start()\r\n    _managers[\"orchestrator\"] = orchestrator\r\n\r\n    # ��ʼ�����úϲ���\r\n    log.info(\"��ʼ�� ConfigMerger ...\")\r\n    merger = ConfigMerger()\r\n    merged_config = merger.merge_all()\r\n    _managers[\"config_merger\"] = merger\r\n\r\n    # ---- ��ʼ��ȫ�� 10 �������� (health �˵�����) ----\r\n\r\n    # 1. PTZManager\r\n    log.info(\"��ʼ�� PTZManager ...\")\r\n    from src.core.ptz_manager import PTZManager as _PTZManager\r\n    ptz_manager = _PTZManager()\r\n    _managers[\"ptz_manager\"] = ptz_manager\r\n\r\n    # 2. DeviceManager\r\n    log.info(\"��ʼ�� DeviceManager ...\")\r\n    from src.core.device_manager import DeviceManager\r\n    device_manager = DeviceManager()\r\n    if hasattr(device_manager, \"load_devices\"):\r\n        device_manager.load_devices()\r\n    _managers[\"device_manager\"] = device_manager\r\n\r\n    # 3. StreamManager\r\n    log.info(\"��ʼ�� StreamManager ...\")\r\n    from src.core.stream_manager import StreamManager\r\n    stream_manager = StreamManager()\r\n    _managers[\"stream_manager\"] = stream_manager\r\n\r\n    # 4. CalibrationManager\r\n    log.info(\"��ʼ�� CalibrationManager ...\")\r\n    try:\r\n        from src.core.calibration_manager import CalibrationManager\r\n        calibration_manager = CalibrationManager()\r\n        _managers[\"calibration_manager\"] = calibration_manager\r\n    except Exception as e:\r\n        log.warning(\"CalibrationManager ��ʼ������: %s\", e)\r\n\r\n    # 5. DBManager\r\n    log.info(\"��ʼ�� DBManager ...\")\r\n    try:\r\n        from src.database.core.db_manager import DatabaseManager\r\n        db_manager = DatabaseManager()\r\n        if hasattr(db_manager, \"init_db\"):\r\n            db_manager.init_db()\r\n        _managers[\"db_manager\"] = db_manager\r\n    except Exception as e:\r\n        log.warning(\"DBManager ��ʼ������: %s\", e)\r\n\r\n    # 6. AuthService\r\n    log.info(\"��ʼ�� AuthService ...\")\r\n    try:\r\n        from src.core.auth import AuthManager\r\n        auth_service = AuthManager()\r\n        _managers[\"auth_service\"] = auth_service\r\n    except Exception as e:\r\n        log.warning(\"AuthService ��ʼ������: %s\", e)\r\n\r\n    # 7. WSManager (WebSocket)\r\n    log.info(\"��ʼ�� WebSocketManager ...\")\r\n    try:\r\n        from src.core.ws_manager import WebSocketManager\r\n        ws_manager = WebSocketManager()\r\n        _managers[\"ws_manager\"] = ws_manager\r\n    except Exception as e:\r\n        log.warning(\"WSManager ��ʼ������: %s\", e)\r\n\r\n    # 8. ASCOMManager\r\n    log.info(\"��ʼ�� ASCOMManager ...\")\r\n    try:\r\n        from src.core.ascom_manager import ASCOMManager\r\n        ascom_manager = ASCOMManager()\r\n        _managers[\"ascom_manager\"] = ascom_manager\r\n    except Exception as e:\r\n        log.warning(\"ASCOMManager ��ʼ������: %s\", e)\r\n\r\n    # 9. HealthMonitor\r\n    log.info(\"��ʼ�� HealthMonitor ...\")\r\n    try:\r\n        from src.core.health_monitor import HealthMonitor\r\n        health_monitor = HealthMonitor()\r\n        _managers[\"health_monitor\"] = health_monitor\r\n    except Exception as e:\r\n        log.warning(\"HealthMonitor ��ʼ������: %s\", e)\r\n\r\n    log.info(\"��������ʼ�����: %d/%d initialized\",\r\n             sum(1 for v in _managers.values() if v is not None),\r\n             len(_managers))\r\n\r\n    # 10. ע�뵽�ɰ�·��ģ�� (����)\r\n    set_managers(\r\n        orchestrator=orchestrator,\r\n        ptz_manager=ptz_manager,\r\n        device_manager=device_manager,\r\n        stream_manager=_managers.get(\"stream_manager\"),\r\n        calibration_manager=_managers.get(\"calibration_manager\"),\r\n        db_manager=_managers.get(\"db_manager\"),\r\n        auth_service=_managers.get(\"auth_service\"),\r\n        ws_manager=_managers.get(\"ws_manager\"),\r\n        ascom_manager=_managers.get(\"ascom_manager\"),\r\n        health_monitor=_managers.get(\"health_monitor\"),\r\n    )\r\n\r\n    # ��ʼ�� ASCOM DriverManager\r\n    log.info(\"��ʼ�� ASCOM DriverManager ...\")\r\n    try:\r\n        from src.ascom.core.driver_manager import init_driver_manager\r\n        init_driver_manager()\r\n        log.info(\"ASCOM DriverManager ��ʼ�����\")\r\n    except Exception as e:\r\n        log.warning(\"ASCOM DriverManager ��ʼ������: %s\", e)\r\n\r\n    # ��ʼ�� WebSocket ������\r\n    log.info(\"��ʼ�� WebSocket ������ ...\")\r\n    try:\r\n        from src.websocket.server import WebSocketServer, WebSocketServerConfig\r\n        ws_server = WebSocketServer(config=WebSocketServerConfig(\r\n            path=\"/ws\",\r\n            heartbeat_interval=30,\r\n            heartbeat_timeout_count=2,\r\n        ))\r\n        ws_server.mount_to(app)\r\n        _managers[\"ws_server\"] = ws_server\r\n        log.info(\"WebSocket ��������ʼ�����\")\r\n    except Exception as e:\r\n        log.warning(\"WebSocket ��������ʼ������: %s\", e)\r\n\r\n    # ��ʼ�� SADP �˵����� (BUG-003 �޸�: ������ PTZManager)\r\n    from src.core.sadp_discovery import SADPManager as SADPDiskManager\r\n    _managers[\"sadp_manager\"] = SADPDiskManager()\r\n\r\n    log.info(\"=== M12 Integration ������� ===\")\r\n\r\n    yield\r\n\r\n    # ---- �رս׶� ----\r\n    log.info(\"=== M12 Integration �ر��� ===\")\r\n\r\n    # �ر� WebSocket ������\r\n    if \"ws_server\" in _managers and hasattr(_managers[\"ws_server\"], \"broadcast_manager\"):\r\n        try:\r\n            await _managers[\"ws_server\"]._cleanup_all_connections()\r\n        except Exception as e:\r\n            log.warning(\"WebSocket �������ر��쳣: %s\", e)\r\n\r\n    # ASCOM DriverManager �ر�\r\n    try:\r\n        from src.ascom.core.driver_manager import get_driver_manager\r\n        dm = get_driver_manager()\r\n        if hasattr(dm, \"shutdown\"):\r\n            dm.shutdown()\r\n            log.info(\"ASCOM DriverManager �ѹر�\")\r\n    except Exception:\r\n        pass\r\n\r\n    # ֹͣ������ (����ֹͣ M1-M11 ģ��)\r\n    if isinstance(orchestrator, Orchestrator):\r\n        await orchestrator.stop()\r\n        log.info(\"Orchestrator ��ֹͣ\")\r\n\r\n    _managers.clear()\r\n    log.info(\"=== M12 Integration �Ѱ�ȫ�ر� ===\")\r\n\r\n\r\n# ================================================================ #\r\n#  ���� FastAPI App\r\n# ================================================================ #\r\n\r\n_WEB_DIR = get_web_dir()\r\n_INDEX_HTML = get_index_html()\r\n_WEB_DIR = get_web_dir()\r\n_templates = Jinja2Templates(directory=str(_WEB_DIR))\r\n\r\n\r\ndef create_app() -> FastAPI:\r\n    \"\"\"���������� FastAPI Ӧ�á�\"\"\"\r\n    app = FastAPI(\r\n        title=str(PROJECT_NAME),\r\n        description=\"ͳһ�����豸����ƽ̨\",\r\n        version=VERSION,\r\n        lifespan=lifespan,\r\n    )\r\n\r\n    # ���� HLS ��̬�ļ�Ŀ¼\r\n    HLS_DIR.mkdir(parents=True, exist_ok=True)\r\n    app.mount(\"/hls\", StaticFiles(directory=str(HLS_DIR), html=True), name=\"hls\")\r\n\r\n    # ���� web ��̬�ļ�\r\n    app.mount(\"/static\", StaticFiles(directory=str(_WEB_DIR), html=True), name=\"static\")\r\n\r\n    # WASM SDK requires COOP/COEP headers for SharedArrayBuffer\r\n    class COOPCOEPMiddleware(BaseHTTPMiddleware):\r\n        async def dispatch(self, request, call_next):\r\n            response = await call_next(request)\r\n            path = request.url.path\r\n            if path == \"/\" or path.startswith(\"/static/\"):\r\n                response.headers.setdefault(\"Cross-Origin-Opener-Policy\", \"same-origin\")\r\n                response.headers.setdefault(\"Cross-Origin-Embedder-Policy\", \"require-corp\")\r\n            return response\r\n\r\n    app.add_middleware(COOPCOEPMiddleware)\r\n    # === ISAPI Proxy for WebSDK WASM noPlugin ===\r\n    import aiohttp\r\n    import traceback\r\n    _isapi_devices = {}\r\n\r\n    def register_isapi_device(ip, username, password, port=80):\r\n        _isapi_devices[ip] = {'username': username, 'password': password, 'port': port}\r\n\r\n    async def _handle_isapi_request(request, path):\r\n        method = request.method\r\n        device_ip = request.query_params.get('ip', '192.168.5.72')\r\n        device = _isapi_devices.get(device_ip, {'username': 'admin', 'password': 'Nftw1357', 'port': 80})\r\n        isapi_url = 'http://{}:{}/ISAPI/{}'.format(device_ip, device['port'], path)\r\n        auth = aiohttp.BasicAuth(device['username'], device['password'])\r\n        log.info('[ISAPI Proxy] %s -> %s', method, isapi_url)\r\n        try:\r\n            async with aiohttp.ClientSession() as session:\r\n                if method in ('POST', 'PUT'):\r\n                    body = await request.body()\r\n                else:\r\n                    body = None\r\n                headers = {k: v for k, v in request.headers.items() if k.lower() not in ('host', 'content-length', 'origin', 'referer')}\r\n                timeout = aiohttp.ClientTimeout(total=30)\r\n                if method == 'GET':\r\n                    async with session.get(isapi_url, auth=auth, headers=headers, timeout=timeout) as resp:\r\n                        rb = await resp.read()\r\n                        return Response(content=rb, status_code=resp.status, media_type=resp.headers.get('content-type', 'application/xml'))\r\n                elif method == 'POST':\r\n                    async with session.post(isapi_url, auth=auth, data=body, headers=headers, timeout=timeout) as resp:\r\n                        rb = await resp.read()\r\n                        return Response(content=rb, status_code=resp.status, media_type=resp.headers.get('content-type', 'application/xml'))\r\n                elif method == 'PUT':\r\n                    async with session.put(isapi_url, auth=auth, data=body, headers=headers, timeout=timeout) as resp:\r\n                        rb = await resp.read()\r\n                        return Response(content=rb, status_code=resp.status, media_type=resp.headers.get('content-type', 'application/xml'))\r\n                elif method == 'DELETE':\r\n                    async with session.delete(isapi_url, auth=auth, headers=headers, timeout=timeout) as resp:\r\n                        rb = await resp.read()\r\n                        return Response(content=rb, status_code=resp.status, media_type=resp.headers.get('content-type', 'application/xml'))\r\n        except Exception as e:\r\n            log.error('[ISAPI Proxy] Error: %s\\n%s', e, traceback.format_exc())\r\n            return JSONResponse(status_code=502, content={'error': str(e)})\r\n\r\n\r\n    @app.get('/ISAPI/{path:path}')\r\n    async def isapi_proxy_get(path: str, request: Request):\r\n        return await _handle_isapi_request(request, path)\r\n\r\n    @app.post('/ISAPI/{path:path}')\r\n    async def isapi_proxy_post(path: str, request: Request):\r\n        return await _handle_isapi_request(request, path)\r\n\r\n    @app.put('/ISAPI/{path:path}')\r\n    async def isapi_proxy_put(path: str, request: Request):\r\n        return await _handle_isapi_request(request, path)\r\n\r\n    @app.delete('/ISAPI/{path:path}')\r\n    async def isapi_proxy_delete(path: str, request: Request):\r\n        return await _handle_isapi_request(request, path)\r\n    # === End ISAPI Proxy ===\r\n\r\n    # ���� API ·�� (���� M1-M11 ����·��)\r\n\r\n    # === WASM SDK Stream Routes (������ SDK Ԥ��) ===\r\n    # ע�⣺WASM �޲��ģʽ����Ҫ��ͳ��Ƶ����SDK ֱ�ӽ��� RTP\r\n    # ��ǰ�� JS �Ե��� /api/v1/streams/{ip}/start�����سɹ�����\r\n    @app.post(\"/api/v1/streams/{device_id}/start\")\r\n    async def stream_start(device_id: str):\r\n        \"\"\"WASM �޲��ģʽ��SDK ֱ�ӽ��룬����Ҫ������������\r\n        \r\n        �˶˵��Ϊǰ�˼����Ա�����ʵ����Ƶ�� WASM SDK ������\r\n        \"\"\"\r\n        log.info('[Stream Start] WASM mode, SDK handles decoding for %s', device_id)\r\n        return {\"success\": True, \"message\": \"WASM SDK ��ֱ�ӽ�����Ƶ��\", \"mode\": \"wasm\"}\r\n\r\n    @app.post(\"/api/v1/streams/{device_id}/stop\")\r\n    async def stream_stop(device_id: str):\r\n        \"\"\"WASM ģʽ�µ���ֹͣ��\"\"\"\r\n        log.info('[Stream Stop] WASM mode for %s', device_id)\r\n        return {\"success\": True, \"message\": \"WASM SDK ֹͣ����\", \"mode\": \"wasm\"}\r\n\r\n    @app.get(\"/api/v1/streams/{device_id}/status\")\r\n    async def stream_status(device_id: str):\r\n        \"\"\"WASM ģʽ�µ���״̬��\"\"\"\r\n        return {\"success\": True, \"status\": \"wasm_decoding\", \"device_id\": device_id}\r\n    # === End Stream Routes ===\r\n\r\n    app.include_router(api_router)\r\n    app.include_router(health_router)\r\n\r\n    # ��·�� -> index.html\r\n    @app.get(\"/\", response_class=HTMLResponse)\r\n    async def serve_index(request: Request):\r\n        return _templates.TemplateResponse(\"index.html\", {\"request\": request})\r\n\r\n    return app\r\n\r\n\r\n# ================================================================ #\r\n#  Headless ģʽ\r\n# ================================================================ #\r\n\r\ndef _run_headless(host: str, port: int) -> None:\r\n    \"\"\"Headless ģʽ: ͬ������ uvicorn ����ˡ�\"\"\"\r\n    app = create_app()\r\n    log.info(\"=== Headless ģʽ (M12 Integration v%s) ===\", VERSION)\r\n    uvicorn.run(app, host=host, port=port, log_level=\"info\")\r\n\r\n\r\n# ================================================================ #\r\n#  ���\r\n# ================================================================ #\r\n\r\ndef main() -> None:\r\n    \"\"\"������ڡ�\"\"\"\r\n    parser = argparse.ArgumentParser(description=f\"{PROJECT_NAME} v{VERSION} - ͳһ�����豸����ƽ̨\")\r\n    parser.add_argument(\"--headless\", action=\"store_true\", help=\"������ uvicorn ����ˣ������洰�ڣ�\")\r\n    parser.add_argument(\"--host\", default=HOST, help=f\"������ַ (Ĭ��: {HOST})\")\r\n    parser.add_argument(\"--port\", type=int, default=PORT, help=f\"�����˿� (Ĭ��: {PORT})\")\r\n    args = parser.parse_args()\r\n\r\n    # Headless ģʽ\r\n    if args.headless:\r\n        _run_headless(args.host, args.port)\r\n        return\r\n\r\n    # ����ģʽ (uvicorn + pywebview)\r\n    app = create_app()\r\n    stop_event = threading.Event()\r\n    open_url = f\"http://{args.host}:{args.port}\"\r\n\r\n    # ���� uvicorn �ں�̨�߳�\r\n    def _run_uvicorn() -> None:\r\n        config = uvicorn.Config(\r\n            app=app,\r\n            host=args.host,\r\n            port=args.port,\r\n            log_level=\"info\",\r\n            access_log=True,\r\n        )\r\n        server = uvicorn.Server(config)\r\n\r\n        def _serve() -> None:\r\n            server.run()\r\n\r\n        thread = threading.Thread(target=_serve, daemon=True)\r\n        thread.start()\r\n        log.info(\"Uvicorn ������: http://%s:%d\", args.host, args.port)\r\n\r\n        # �ȴ�ֹͣ�ź�\r\n        try:\r\n            while not stop_event.is_set():\r\n                stop_event.wait(timeout=0.5)\r\n        except KeyboardInterrupt:\r\n            pass\r\n\r\n        server.should_exit = True\r\n        thread.join(timeout=5)\r\n\r\n    uvicorn_thread = threading.Thread(target=_run_uvicorn, daemon=True)\r\n    uvicorn_thread.start()\r\n\r\n    # �� uvicorn һ��ʱ������\r\n    import time\r\n    time.sleep(1)\r\n\r\n    # ���� pywebview ���洰�� (����ֱ�����ڹر�)\r\n    try:\r\n        import webview\r\n        from src.config import WINDOW_TITLE, WINDOW_WIDTH, WINDOW_HEIGHT\r\n        log.info(\"�������洰��: %s (%dx%d)\", open_url, WINDOW_WIDTH, WINDOW_HEIGHT)\r\n        webview.create_window(WINDOW_TITLE, open_url, width=WINDOW_WIDTH, height=WINDOW_HEIGHT)\r\n        webview.start()\r\n    except ImportError:\r\n        log.warning(\"pywebview δ��װ���������ģʽ\")\r\n        # �ȴ� uvicorn �߳�\r\n        try:\r\n            uvicorn_thread.join()\r\n        except KeyboardInterrupt:\r\n            pass\r\n    finally:\r\n        stop_event.set()\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    try:\r\n        main()\r\n    except KeyboardInterrupt:\r\n        log.info(\"�û��ж�\")\r\n        sys.exit(0)\r\n    except Exception as e:\r\n        log.error(\"�����쳣: %s\", e, exc_info=True)\r\n        sys.exit(1)","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1779304164912}}
