:80\\\")\n        device_identify = request.headers.get('deviceIdentify', '')\n        if device_identify and ':' in device_identify:\n            device_ip = device_identify.split(':')[0]\n            device_port = int(device_identify.split(':')[1])\n        else:\n            device_ip = request.query_params.get('ip', '192.168.5.72')\n            device_port = 80\n\n        device = _isapi_devices.get(device_ip, {'username': 'admin', 'password': 'Nftw1357', 'port': device_port})\n        isapi_url = 'http://{}:{}/ISAPI/{}'.format(device_ip, device['port'], path)'''\n\nif old not in content:\n    print('OLD NOT FOUND')\n    # try to find what we have\n    idx = content.find('_handle_isapi_request')\n    if idx >= 0:\n        print(repr(content[idx:idx+300]))\nelse:\n    content = content.replace(old, new, 1)\n    with open(r'D:\\astro_py\\astro_hub\\src\\main\\main.py', 'w', encoding='utf-8') as f:\n        f.write(content)\n    print('OK - file updated')\n\""}}],"api":"openai-completions","provider":"YerPlan","model":"qwen3.6-plus","usage":{"input":20594,"output":767,"cacheRead":0,"cacheWrite":0,"totalTokens":21361,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779304206964,"responseId":"chatcmpl-e1dbc391-2a8c-9e87-8e2b-a75c88b2c4a3"}}
